		</qry:main>
		<qry:select name="qry_head">
			<qry:xquery>
				for $r in SQL('
select ORG03_EMPRESAS.c_cuit,
LIQ19_LIQUIDACION.e_periodo 
FROM
ORG03_EMPRESAS,
LIQ19_LIQUIDACION
JOIN 
ORG03_EMPRESAS.oi_empresa INNER LIQ19_LIQUIDACION.oi_empresa 
where LIQ19_LIQUIDACION.oi_empresa = {#PARAMIN:@oi_empresa}                   
and LIQ19_LIQUIDACION.oi_liquidacion = {#PARAMIN:@oi_liquidacion}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_cuit" value="translate($r/@c_cuit,'-','')"/>
				<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
				<qry:attribute name="nro_liquidacion" value="fill-left(#PARAMIN:@nroLiquidacion,'0',5)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_liquidaciones_genera">
			<qry:xquery>
				for $r in SQL('
SELECT LIQ19_LIQUIDACION.oi_liq_genera
from
LIQ19_LIQUIDACION
WHERE 
LIQ19_LIQUIDACION.oi_liquidacion = {#PARAMIN:@oi_liquidacion} 
')/ROWS/ROW
