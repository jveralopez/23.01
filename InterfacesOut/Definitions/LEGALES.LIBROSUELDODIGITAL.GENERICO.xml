LIQ99_LIQUIDACION, 
LIQ97_PERSONAL_EMP,
LIQ99_RECIBOS,
LIQ20_TOT_LIQ_PER,
PER01_PERSONAL,
LIQ19_LIQUIDACION,
ORG03_EMPRESAS,
ORG03_UBICACIONES,
LIQ15_UBICACIONES,
LIQ17_ZONAS_SIJP
JOIN           
