							<qry:call>
								<DATA>
									<qry:attribute name="oi_tot_liq_per" value="substring(../../@oi_tot_liq_per,1)"/>
									<qry:attribute name="oi_tot_liq_per_gen" value="substring(../../@oi_tot_liq_per_gen,1)"/>
