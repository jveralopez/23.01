SELECT 
LIQ97_PERSONAL_EMP.c_personal AS c_personal,
LIQ97_PERSONAL_EMP.c_nro_cuil AS c_nro_cuil,
LIQ97_PERSONAL_EMP.d_ape_y_nom AS d_ape_y_nom, 
