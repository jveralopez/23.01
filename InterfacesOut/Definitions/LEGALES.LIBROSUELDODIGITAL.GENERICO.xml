					<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
					<qry:insert-select name="SetFound" to-element="$OUTS/DETAIL[@oi_tot_liq_per = $r/@oi_tot_liq_per ]"/>
				</DETAIL2>
			</qry:out>
