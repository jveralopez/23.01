<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="0">
	<FOR-EACH declare="&lt;DATA oi_empresa=&quot;1&quot; e_periodo=&quot;202211&quot; interface=&quot;LSDIG&quot; oi_liquidacion=&quot;3&quot; nroLiquidacion=&quot;1&quot;&gt;&lt;LIQS/&gt;&lt;/DATA&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATA"/>
			<XXX>
				<HEAD qry-sum="cant_reg">
