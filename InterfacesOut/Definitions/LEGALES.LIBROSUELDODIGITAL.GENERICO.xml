							<qry:attribute value="'00000'" name="cantidad"/>
						</qry:else>
					</qry:if>
					<qry:attribute value="fill-left(FORMAT_NUMBER(ABS($r/@valor), 12, 2, '', '', '0'),'0',15)" name="importe"/>
