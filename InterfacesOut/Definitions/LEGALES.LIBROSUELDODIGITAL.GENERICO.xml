			</qry:out>
		</qry:select>
		<qry:select name="qryPersonas" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
SELECT 
LIQ97_PERSONAL_EMP.c_personal AS c_personal,    
LIQ97_PERSONAL_EMP.c_nro_cuil,
LIQ20_TOT_LIQ_PER.oi_tot_liq_per
FROM 
LIQ99_LIQUIDACION, 
LIQ97_PERSONAL_EMP,
LIQ99_RECIBOS,
LIQ20_TOT_LIQ_PER,
LIQ19_LIQUIDACION,
ORG03_EMPRESAS
JOIN           
LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
LIQ99_LIQUIDACION.c_liquidacion INNER LIQ19_LIQUIDACION.c_liquidacion,
LIQ99_LIQUIDACION.c_empresa INNER ORG03_EMPRESAS.c_empresa
WHERE 
LIQ99_LIQUIDACION.c_estado = \'F\'
AND LIQ19_LIQUIDACION.oi_liquidacion = { #SOURCE:@oi_liq_genera}
AND ORG03_EMPRESAS.oi_empresa = {#PARAMIN:@oi_empresa}
ORDER BY 
c_personal ASC, 
oi_tot_liq_per ASC																		
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qryPersonasInterface">
			<qry:xquery>
				for $r in SQL(' 
SELECT 
LIQ97_PERSONAL_EMP.c_personal AS c_personal,  
LIQ97_PERSONAL_EMP.c_nro_cuil,
max(LIQ20_TOT_LIQ_PER.oi_tot_liq_per) AS oi_tot_liq_per
FROM 
LIQ99_LIQUIDACION, 
LIQ97_PERSONAL_EMP,
LIQ99_RECIBOS,
LIQ20_TOT_LIQ_PER,
PER01_PERSONAL,
LIQ19_LIQUIDACION,
ORG03_EMPRESAS
JOIN           
 	LIQ97_PERSONAL_EMP.c_personal INNER PER01_PERSONAL.c_personal,
LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
LIQ99_LIQUIDACION.c_liquidacion INNER LIQ19_LIQUIDACION.c_liquidacion,
LIQ99_LIQUIDACION.c_empresa INNER ORG03_EMPRESAS.c_empresa
WHERE 
LIQ99_LIQUIDACION.c_estado = \'F\'
AND LIQ19_LIQUIDACION.oi_liquidacion = {#PARAMIN:@oi_liquidacion}					
AND ORG03_EMPRESAS.oi_empresa = {#PARAMIN:@oi_empresa}
GROUP BY LIQ97_PERSONAL_EMP.c_personal, LIQ97_PERSONAL_EMP.c_nro_cuil
ORDER BY c_personal ASC, oi_tot_liq_per ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryJoin" doc="SOURCE">
			<qry:xquery>
				for $n in $NRM/ROW, $i in $INT/ROW 
   join $n/@c_nro_cuil inner $i/@c_nro_cuil
			</qry:xquery>
			<qry:out>
				<qry:if test="number(@count) &gt;= 100">
					<qry:then>
						<qry:call>
							<DATA>
								<qry:attribute name="oi_tot_liq_per" value="substring(../../@oi_tot_liq_per,1)"/>
								<qry:attribute name="oi_tot_liq_per_gen" value="substring(../../@oi_tot_liq_per_gen,1)"/>
							</DATA>
						</qry:call>
						<qry:attribute name="oi_tot_liq_per" value="''"/>
						<qry:attribute name="oi_tot_liq_per_gen" value="''"/>
						<qry:attribute name="count" value="0"/>
					</qry:then>
				</qry:if>
				<qry:attribute name="oi_tot_liq_per_gen" value="@oi_tot_liq_per_gen + ',' + $n/@oi_tot_liq_per "/>
				<qry:attribute name="oi_tot_liq_per" value="@oi_tot_liq_per + ',' + $i/@oi_tot_liq_per "/>
				<qry:attribute name="count" value="number(@count) + 1"/>
			</qry:out>
		</qry:select>
	</FOR-EACH>
	<QUERY declare="&lt;DATA &#13;&#10;  oi_tot_liq_per_gen=&quot;29061,39129,39132,29168,42794,28589,32179,32868,30348,36488,27336,28788,44206,28802,27186,27202,27354,27182,27292,39075,27299,28777,30572,30567,43400,30656,42816,34602,32130,35046,34621,39504,37885,39561,30274,42795,42838,41850,36375,38940,28785,38529,32827,37980,25958,42367,37515,42137,32518,29255,38962,39976,28477,41731,39188,25815,30528,28587,44128,42788,29206,42728,39547,44306,34676,29003,37323,40803,34269,44763,32155,32156,43426,32861,32887,42653,32897,32343,29447,27313,43423,37517,39138,29055,27453,27198,28787,27301,27193,27187,37770,30548,28557,41061,44610,41062,43448,38332,45214,37388&quot; &#13;&#10;  oi_tot_liq_per=&quot;67511,77579,77582,67618,81244,67039,70629,71318,68798,74938,65786,67238,82656,67252,65636,65652,65804,65632,65742,77525,65749,67227,69022,69017,81850,69106,81266,73052,70580,73496,73071,77954,76335,78011,68724,81245,81288,80300,74825,77390,67235,76979,71277,76430,64408,80817,75965,80587,70968,67705,77412,78426,66927,80181,77638,64265,68978,67037,82578,81238,67656,81178,77997,82756,73126,67453,75773,79253,72719,83213,70605,70606,81876,71311,71337,81103,71347,70793,67897,65763,81873,75967,77588,67505,65903,65648,67237,65751,65643,65637,76220,68998,67007,79511,83060,79512,81898,76782,83664,75838&quot;&#13;&#10;/&gt;">
		<qry:main doc="SOURCE">
