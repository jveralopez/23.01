						<qry:then>
							<qry:attribute name="hts:delete" value="1"/>
						</qry:then>
					</qry:if>
				</qry:element>
				<!--<qry:insert-select name="pegar_cantidad" doc-path="$r" to-element="../HEAD"/>-->
				<qry:insert-select name="pegar_tope" doc-path="#DETAIL3:" to-element="./DETAIL[@cuil = $r/@c_nro_cuil]"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryDetailSicoss" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				LIQ96_CONCEPTOS.c_concepto, 
				LIQ20_CONC_LIQ_PER.n_valor
			FROM 
				LIQ20_CONC_LIQ_PER, 
				LIQ96_CONCEPTOS
			JOIN
				LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo
			WHERE
				LIQ20_CONC_LIQ_PER.oi_tot_liq_per = {#SOURCE:@oi_tot_liq_per}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name-calc="'C_'+$r/@c_concepto" value="$r/@n_valor"/>
			</qry:out>
		</qry:select>
