<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="0">
	<QUERY declare="&#13;&#10;&lt;DATA oi_empresa=&quot;1&quot; e_periodo=&quot;202002&quot; interface=&quot;LSDIG&quot; oi_liquidacion=&quot;2102&quot; nroLiquidacion=&quot;1&quot;&gt;&lt;LIQS/&gt;&lt;/DATA&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATA"/>
			<qry:element name="XXX">
				<qry:element name="HEAD">
					<qry:attribute name="cant_reg" value="'000000'"/>
					<qry:insert-select name="qry_head"/>
				</qry:element>
				<qry:element name="DETAILS">
					<qry:append-doc name="DETAILS" doc-path="."/>
					<qry:insert-select name="qry_liquidaciones_genera"/>
					<qry:insert-select name="qryPersonas" doc-path="."/>
					<qry:insert-select name="qryPersonasInterface"/>
					<qry:attribute name="cant" value="fill-left(count(./DETAIL3[@hts:delete != 1]),'0',6)"/>
					<qry:insert-select name="pegar_cantidad" doc-path="#DETAILS:" to-element="../HEAD"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qry_head">
			<qry:xquery>
				for $r in SQL('
			select ORG03_EMPRESAS.c_cuit,
			LIQ19_LIQUIDACION.e_periodo 
			FROM
			ORG03_EMPRESAS,
			LIQ19_LIQUIDACION
			JOIN 
			ORG03_EMPRESAS.oi_empresa INNER LIQ19_LIQUIDACION.oi_empresa 
			where LIQ19_LIQUIDACION.oi_empresa = {#PARAMIN:@oi_empresa}                   
			and LIQ19_LIQUIDACION.oi_liquidacion = {#PARAMIN:@oi_liquidacion}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_cuit" value="translate($r/@c_cuit,'-','')"/>
				<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
				<qry:attribute name="nro_liquidacion" value="fill-left(#PARAMIN:@nroLiquidacion,'0',5)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_liquidaciones_genera">
			<qry:xquery>
				for $r in SQL('
			SELECT LIQ19_LIQUIDACION.oi_liq_genera
			from
			LIQ19_LIQUIDACION
			WHERE 
			LIQ19_LIQUIDACION.oi_liquidacion = {#PARAMIN:@oi_liquidacion} 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_liq_genera" value="$r/@oi_liq_genera"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryPersonas" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
				SELECT 
					LIQ97_PERSONAL_EMP.c_personal AS c_personal,
					LIQ97_PERSONAL_EMP.c_nro_cuil AS c_nro_cuil,
					LIQ97_PERSONAL_EMP.d_ape_y_nom AS d_ape_y_nom, 
					LIQ97_PERSONAL_EMP.e_numero_legajo AS e_numero_legajo,  
					LIQ97_PERSONAL_EMP.c_cbu AS c_cbu,   
					LIQ99_LIQUIDACION.f_pago,
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
					PER01_PERSONAL.d_apellido,
					PER01_PERSONAL.d_nombres,
					LIQ97_PERSONAL_EMP.c_forma_pago,
					LIQ17_ZONAS_SIJP.c_zona_sijp
				FROM 
					LIQ99_LIQUIDACION, 
					LIQ97_PERSONAL_EMP,
					LIQ99_RECIBOS,
					LIQ20_TOT_LIQ_PER,
					PER01_PERSONAL,
					LIQ19_LIQUIDACION,
					ORG03_EMPRESAS,
					ORG03_UBICACIONES,
					LIQ15_UBICACIONES,
					LIQ17_ZONAS_SIJP
				JOIN           
				 	LIQ97_PERSONAL_EMP.c_personal INNER PER01_PERSONAL.c_personal,
					LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
					LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
					LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
					LIQ99_LIQUIDACION.c_liquidacion INNER LIQ19_LIQUIDACION.c_liquidacion,
					LIQ99_LIQUIDACION.c_empresa INNER ORG03_EMPRESAS.c_empresa,
						ORG03_UBICACIONES.c_ubicacion INNER LIQ97_PERSONAL_EMP.c_ubicacion,
					LIQ15_UBICACIONES.oi_ubicacion INNER  ORG03_UBICACIONES.oi_ubicacion,
					LIQ17_ZONAS_SIJP.oi_zona_sijp INNER LIQ15_UBICACIONES.oi_zona_sijp,
					ORG03_EMPRESAS.oi_empresa INNER LIQ15_UBICACIONES.oi_empresa
		
				WHERE 
					LIQ99_LIQUIDACION.c_estado = \'F\'
					AND LIQ19_LIQUIDACION.oi_liquidacion = { #SOURCE:@oi_liq_genera}
					AND ORG03_EMPRESAS.oi_empresa = {#PARAMIN:@oi_empresa}
				ORDER BY 
					c_personal ASC, 
					oi_tot_liq_per ASC																		
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DETAIL">
					<qry:attribute name="c_zona_sijp" value="$r/@c_zona_sijp"/>
					<qry:attribute name="tipo2" value="'02'"/>
					<qry:attribute name="c_nro_cuil" value="translate($r/@c_nro_cuil,'-','')"/>
					<qry:attribute name="c_nro_original" value="$r/@c_nro_cuil"/>
					<qry:attribute name="cuil" value="$r/@c_nro_cuil"/>
					<qry:attribute name="e_numero_legajo" value="FILL-LEFT($r/@e_numero_legajo,'0',10)"/>
					<qry:attribute name="d_revista" value="FILL-LEFT(' ',' ',50)"/>
					<qry:attribute name="f_rubrica" value="FILL-LEFT(' ',' ',8)"/>
					<qry:attribute name="c_cbu" value="NMD_REPLACE(NMD_REPLACE($r/@c_cbu, '-', ''), ' ', '')"/>					
					<qry:attribute name="c_cbu" value="iif(($r/@c_forma_pago = '1' or $r/@c_forma_pago = '2' or $r/@c_forma_pago = '3'),fill-left(normalize-space(@c_cbu),' ',22),fill-left(normalize-space(@c_cbu),'0',22)) "/>
					<qry:attribute name="f_pago" value="$r/@f_pago"/>
					<qry:attribute name="c_forma_pago" value="iif($r/@c_forma_pago = '2','1',iif($r/@c_forma_pago = '3','2','3'))"/>
					<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
					<qry:element name="DET">
						<qry:insert-select name="QRY_DETALLE" doc-path="$r"/>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:element>
					<qry:if test="count(./DET/DETAIL2) = 0">
						<qry:then>
							<qry:attribute name="hts:delete" value="1"/>
						</qry:then>
					</qry:if>
				</qry:element>
				<qry:insert-element doc-path="./DETAIL[@c_nro_original = $r/@c_nro_cuil]/DET/DETAIL2"/>
				<qry:attribute name="c_nro_cuil" value="translate($r/@c_nro_cuil,'-','')"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_DETALLE">
			<qry:xquery>
				for $r in sql('
SELECT 
CLP.oi_conc_liq_per,
CON.c_concepto, 
CON.d_concepto, 
CON.e_secuencia,	
CLP.n_valor AS valor,
CLP.n_cantidad AS cantidad,
CON.c_tipo_concepto, 
T.e_orden,
E.c_equivalencia,
E.l_informa
FROM 
LIQ20_TOT_LIQ_PER AS TLP, 
liq20_conc_liq_per AS CLP, 
liq96_conceptos AS CON, 
LIQ14_CONCEPTOS AS C, 
LIQ12_TIPOS_CONC AS T,
liq14_equivalencia as E
JOIN
TLP.oi_tot_liq_per INNER CLP.oi_tot_liq_per,
CON.oi_concepto_ddo INNER CLP.oi_concepto_ddo,
C.c_concepto INNER CON.c_concepto,
C.oi_tipo_concepto INNER T.oi_tipo_concepto,
C.oi_concepto LEFT OUTER E.oi_concepto 
WHERE
TLP.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}	 AND 
T.l_nolistado = 0  and
CLP.n_valor != 0 and 
CON.ca_fig_recibo != \'N\' 
ORDER BY
	e_orden ASC, 
	c_concepto ASC')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DETAIL2">
					<qry:attribute name="c_nro_cuil" value="translate(../../@c_nro_cuil,'-','')"/>
					<qry:attribute name="tipo3" value="'03'"/>
					<qry:if test="$r/@c_equivalencia !='' and $r/@l_informa!='1' ">
						<qry:then>
							<qry:attribute name="c_concepto" value="fill-left(number($r/@c_equivalencia),' ',10)"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_concepto" value="fill-left(number($r/@c_concepto),' ',10)"/>
						</qry:else>
					</qry:if>
					<qry:attribute value="iif(string-length(substring-before(abs($r/@cantidad),'.')) &lt;=3,fill-left(format_number(abs($r/@cantidad),3,2,'','','0'),0,5),'00000')" name="cantidad"/>
					<qry:attribute value="fill-left(format_number(translate($r/@valor,'-',' '),13,2,'','','0'),'0',15)" name="importe"/>
					<qry:attribute name="deb_cred" value="iif(substring($r/@valor,0,1) = '-','D','C')"/>
					<qry:attribute name="e_periodo_ajuste" value="fill-left(' ',' ',6)"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qryPersonasInterface">
			<qry:xquery>
				for $r in SQL(' 
 		
 select
  LIQ20_TOT_LIQ_PER.oi_tot_liq_per as oi_tot_liq_per,
  LIQ97_PERSONAL_EMP.c_nro_cuil as  c_nro_cuil
   from
  liq19_ejecuciones,
  LIQ99_RECIBOS,
  LIQ20_TOT_LIQ_PER,
  LIQ97_PERSONAL_EMP
  JOIN

    LIQ99_RECIBOS.oi_liquidacion_ddo inner liq19_ejecuciones.oi_liquidacion_ddo,
    LIQ20_TOT_LIQ_PER.oi_tot_liq_per inner LIQ99_RECIBOS.oi_tot_liq_per,
   LIQ97_PERSONAL_EMP.oi_per_emp_ddo inner LIQ20_TOT_LIQ_PER.oi_per_emp_ddo
  where liq19_ejecuciones.oi_liquidacion = {#PARAMIN:@oi_liquidacion}	
 																	
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DETAIL3">
					<qry:append-doc name="DETAIL3" doc-path="."/>
					<qry:attribute name="tipo4" value="'04'"/>
					<qry:attribute name="c_nro_cuil" value="NMD_REPLACE($r/@c_nro_cuil, '-', '')"/>
					<qry:attribute name="c_zona_sijp" value="../DETAIL[@c_nro_original = $r/@c_nro_cuil]/@c_zona_sijp"/>
