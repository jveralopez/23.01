<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="1">
	<FOR-EACH declare="&lt;DATA c_empresa=&quot;1&quot; interface=&quot;SICOSS42&quot; p_periodo=&quot;202211&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="XXX">
				<qry:element name="DETAILS">
					<qry:attribute name="c_empresa" value="#SOURCE:./@c_empresa"/>
					<qry:attribute name="p_periodo" value="#SOURCE:./@p_periodo"/>
					<qry:insert-select name="qryRecibos" doc-path="#SOURCE:."/>
					<qry:if test="number(@count) &gt; 0">
						<qry:then>
							<qry:call>
								<FILTRO>
									<qry:attribute name="ois" value="substring(../../@ois,1)"/>
								</FILTRO>
							</qry:call>
							<qry:attribute name="count" value="''"/>
							<qry:attribute name="ois" value="''"/>
						</qry:then>
					</qry:if>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryRecibos" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
SELECT                          
LIQ97_PERSONAL_EMP.c_personal,
LIQ20_TOT_LIQ_PER.oi_tot_liq_per
FROM 
LIQ99_LIQUIDACION, 
LIQ99_RECIBOS,     
LIQ97_PERSONAL_EMP,
LIQ20_TOT_LIQ_PER
JOIN                                                                     
LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per
WHERE 
LIQ99_LIQUIDACION.c_estado = \'F\'
AND LIQ99_LIQUIDACION.c_tipo_liq = \'6\'
AND LIQ99_LIQUIDACION.e_periodo = {#SOURCE:@p_periodo}					
AND LIQ99_LIQUIDACION.c_empresa = {#SOURCE:@c_empresa}
ORDER BY 
c_personal ASC, oi_tot_liq_per ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="@count &gt;= 100">
					<qry:then>
						<qry:call>
							<FILTRO>
								<qry:attribute name="ois" value="substring(../../@ois,1)"/>
							</FILTRO>
						</qry:call>
						<qry:attribute name="count" value="''"/>
						<qry:attribute name="ois" value="''"/>
					</qry:then>
				</qry:if>
				<qry:attribute name="count" value="number(@count)+1"/>
				<qry:attribute name="ois" value="@ois + ',' + $r/@oi_tot_liq_per"/>
			</qry:out>
		</qry:select>
	</FOR-EACH>
