<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="1">
	<QUERY declare="&lt;DATA interface=&quot;SICOSS&quot; c_empresa=&quot;TadeoCZ&quot; p_periodo=&quot;200904&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="DATA">
				<qry:element name="DETAILS">
					<!--------------------------------------->
					<qry:insert-select name="qryPersonas" doc-path="#SOURCE:/DATA"/>
					<!-- Inserta el registro FINAL solo si existe el registro ----------->
					<qry:insert-select name="qryDetail-ADDreg" doc-path=".[@ultpersona !='']"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryPersonas" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
						SELECT
							PE.c_personal							
						FROM
							LIQ20_TOT_LIQ_PER as TLP,
							LIQ97_PERSONAL_EMP as PE,   
							PER01_PERSONAL as PER, 
							LIQ99_LIQUIDACION as LIQ,
							LIQ93_EMPRESAS as EMP,
							LIQ96_CONCEPTOS as LCON, 
							LIQ20_CONC_LIQ_PER as CON,
							LIQ20_VAR_LIQ_CONC as VAR,
							LIQ99_RECIBOS as REC
						
						JOIN
							TLP.oi_per_emp_ddo 			INNER PE.oi_per_emp_ddo,
							PER.c_personal 					INNER PE.c_personal,
							LIQ.oi_liquidacion_ddo 	INNER REC.oi_liquidacion_ddo,
							TLP.oi_tot_liq_per 			INNER REC.oi_tot_liq_per,
							LIQ.oi_empresa_ddo 			INNER EMP.oi_empresa_ddo,							
							LCON.oi_concepto_ddo 		INNER CON.oi_concepto_ddo,							
							TLP.oi_tot_liq_per 			INNER CON.oi_tot_liq_per,
							CON.oi_conc_liq_per 		INNER VAR.oi_conc_liq_per
													
						WHERE 
							
							LCON.c_concepto = \'99999997\'
							AND LIQ.c_estado = \'F\' 
							AND EMP.c_empresa = { #SOURCE:@c_empresa }
							AND LIQ.e_periodo = { #SOURCE:@p_periodo }                                       
                        GROUP BY 
                        	PE.c_personal
						ORDER BY 
							c_personal ASC													
						')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_personal" value="$r/@c_personal"/>
				<qry:attribute name="c_empresa" value="#SOURCE:@c_empresa"/>
				<qry:attribute name="p_periodo" value="#SOURCE:@p_periodo"/>
				<qry:insert-select name="qryDetail" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qryDetail" doc="SOURCE">
