			<qry:xquery>
				for $r in SQL(' 
				SELECT 
					MAX(LIQ97_PERSONAL_EMP.c_personal) AS c_personal,
					MAX(LIQ97_PERSONAL_EMP.c_nro_cuil) AS c_nro_cuil,
					MAX(LIQ97_PERSONAL_EMP.d_ape_y_nom) AS d_ape_y_nom,
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per
				FROM 
					LIQ99_LIQUIDACION, 
					LIQ19_EJECUCIONES, 
					LIQ25_PERSONAL_LIQ, 
					LIQ97_PERSONAL_EMP,
					LIQ99_RECIBOS,
					LIQ20_TOT_LIQ_PER
				JOIN 
					LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ19_EJECUCIONES.oi_liquidacion_ddo,
					LIQ19_EJECUCIONES.oi_liquidacion INNER LIQ25_PERSONAL_LIQ.oi_liquidacion,
					LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
					LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
					LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per
				WHERE 
					LIQ99_LIQUIDACION.c_tipo_liq = \'11\'
					AND LIQ99_LIQUIDACION.c_estado = \'F\'
					AND LIQ99_LIQUIDACION.e_periodo = {#SOURCE:@p_periodo}					
					AND LIQ99_LIQUIDACION.c_empresa = {#SOURCE:@c_empresa}
				GROUP BY 
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per
				ORDER BY 
					c_personal ASC, 
					oi_tot_liq_per ASC																		
			')/ROWS/ROW
