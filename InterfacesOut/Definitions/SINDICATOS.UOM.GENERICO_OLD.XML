<INTERFACE-DEF entermode="DOS" finalenter="1" xmlns:qry="XXX">
	<QUERY declare="&lt;DATA p_periodo=&quot;200810&quot; oi_sindicato=&quot;1&quot; c_empresa=&quot;80&quot;&gt;   &lt;/DATA&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="DATA">
				<qry:element name="DETAILS">
					<qry:insert-select name="qryDetail" doc-path="#SOURCE:/DATA"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select xmlns:qry="nomad.xquery" name="qryDetail" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
						SELECT 
							PER.oi_personal,
						    PE.f_ingreso,
							PE.c_nro_cuil,
							PE.d_ape_y_nom,
							PE.c_estado_civil,
							PE.c_sexo,
						    NAC.c_nacionalidad,
							PE.f_nacim,
							\'N\' as incapacidad,
							PE.c_categoria_ult,
							SUM(TLP.n_totsret) as n_totsret
							
						FROM
							LIQ20_TOT_LIQ_PER as TLP,
							LIQ97_PERSONAL_EMP as PE,   
							PER01_PERSONAL as PER, 
							LIQ99_LIQUIDACION as LIQ,
							LIQ93_EMPRESAS as EMP,
							PER30_SINDICATOS as S,
							ORG12_NACIONALID as NAC
						
						JOIN
							TLP.oi_per_emp_ddo INNER PE.oi_per_emp_ddo,
							PER.c_personal INNER PE.c_personal,
							LIQ.oi_liquidacion_ddo INNER TLP.oi_liquidacion_ddo,
							LIQ.oi_empresa_ddo INNER EMP.oi_empresa_ddo,
							PE.c_sindicato INNER S.c_sindicato,
							PER.oi_nacionalidad LEFT OUTER NAC.oi_nacionalidad
						
						
						WHERE 
							IsNotNULL(TLP.f_cierre)
							AND LIQ.e_periodo = { #SOURCE:@p_periodo }
							AND S.oi_sindicato = { #SOURCE:@oi_sindicato } 
							AND EMP.c_empresa = { #SOURCE:@c_empresa }
						
						GROUP BY
							PER.oi_personal,
						
							PE.c_nro_cuil,
							PE.d_ape_y_nom,
							PE.c_estado_civil,
							PE.c_sexo,
						    NAC.c_nacionalidad,
							PE.f_nacim,  PE.f_ingreso,
							PE.c_categoria_ult
							
						')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DETAIL">
					<qry:attribute name="d_calle" value="FILL_LEFT('', ' ', 32)"/>
					<qry:attribute name="e_numero" value="FILL_LEFT('', ' ', 5)"/>
					<qry:attribute name="d_localidad" value="FILL_LEFT('', ' ', 13)"/>
					<qry:attribute name="c_postal" value="FILL_LEFT('', ' ', 6)"/>
					<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento"/>
					<qry:attribute name="c_nro_cuil" value="TRANSLATE($r/@c_nro_cuil, '-', '')"/>
					<qry:attribute name="d_ape_y_nom" value="FILL_RIGHT($r/@d_ape_y_nom, ' ', 31)"/>
					<qry:attribute name="c_sexo" value="$r/@c_sexo"/>
					<qry:attribute name="f_nacim" value="FORMAT_DATE($r/@f_nacim, 'dd/mm/yyyy')"/>
					<qry:attribute name="incapacidad" value="FILL_RIGHT($r/@incapacidad, ' ', 1)"/>
					<qry:attribute name="d_grupo_sanguineo" value="$r/@d_grupo_sanguineo"/>
					<qry:attribute name="f_ingreso" value="FORMAT_DATE($r/@f_ingreso, 'dd/mm/yyyy')"/>
					<qry:attribute name="c_obra_social" value="$r/@c_obra_social"/>
					<qry:attribute name="c_estado_civil" value="$r/@c_estado_civil"/>
					<qry:attribute name="sueldo" value="FORMAT_NUMBER($r/@n_totsret, 10, 2, '.', '', ' ')"/>
					<qry:attribute name="c_nacionalidad" value="'300'"/>
					<qry:attribute name="c_categoria" value="'08'"/>
					<qry:insert-select name="qryDetailDir" doc-path="$r"/>
					<qry:insert-select name="qryEST_CIV" doc-path="$r"/>
					<qry:insert-select name="qryNACIONALIDADES" doc-path="$r"/>
					<qry:insert-select name="qryCATEGORIAS" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad.xquery" name="qryDetailDir" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
							SELECT
								DPER.d_calle,
								DPER.e_numero,
								DPER.d_piso,
								DPER.d_departamento,
								LOC.d_localidad,
								PRO.c_provincia,
								LOC.c_postal
							FROM
								PER01_DOMIC_PER as DPER,
								ORG19_LOCALIDADES as LOC,
								ORG35_PROVINCIAS as PRO
							JOIN
								DPER.oi_localidad INNER LOC.oi_localidad,
								LOC.oi_provincia INNER PRO.oi_provincia
												
							WHERE 
								DPER.l_domic_fiscal = 1 AND
								DPER.oi_personal = {%= #SOURCE:@oi_personal %}
						
						')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_calle" value="FILL_RIGHT($r/@d_calle, ' ', 32)"/>
				<qry:attribute name="e_numero" value="FILL_RIGHT($r/@e_numero, ' ', 5)"/>
				<qry:attribute name="d_piso" value="$r/@d_piso"/>
				<qry:attribute name="d_departamento" value="$r/@d_departamento"/>
				<qry:attribute name="d_localidad" value="FILL_RIGHT($r/@d_localidad, ' ', 13)"/>
				<qry:attribute name="c_postal" value="FILL_RIGHT($r/@c_postal, ' ', 6)"/>
				<qry:insert-select name="qryPROVINCIA" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad.xquery" name="qryEST_CIV" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('./INTERFACE-DEF/SINDICATOS.UOM.JOIN.Estados_Civil.XML')/JOINS/JOIN[@n_code=#SOURCE:@c_estado_civil]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_estado_civil" value="$r/@i_code"/>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad.xquery" name="qryPROVINCIA" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('./INTERFACE-DEF/SINDICATOS.UOM.JOIN.Provincias.XML')/JOINS/JOIN[@n_code=#SOURCE:@c_provincia]
			</qry:xquery>
			<qry:out>
				<qry:attribute value="FILL_RIGHT($r/@i_code, ' ', 2)" name="c_provincia"/>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad.xquery" name="qryNACIONALIDADES" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('./INTERFACE-DEF/SINDICATOS.UOM.JOIN.Nacionalidades.XML')/JOINS/JOIN[@n_code=#SOURCE:@c_nacionalidad]
			</qry:xquery>
			<qry:out>
				<qry:attribute value="FILL_RIGHT($r/@i_code, ' ', 3)" name="c_nacionalidad"/>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad.xquery" name="qryCATEGORIAS" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('./INTERFACE-DEF/SINDICATOS.UOM.JOIN.Nacionalidades.XML')/JOINS/JOIN[@n_code=#SOURCE:@c_categoria_ult]
			</qry:xquery>
			<qry:out>
				<qry:attribute value="FILL_RIGHT($r/@i_code, ' ', 2)" name="c_categoria"/>
			</qry:out>
		</qry:select>
	</QUERY>
	<DETAIL>
		{c_nro_cuil:11}{d_ape_y_nom:31}{d_calle:32}{e_numero:5}{space(8)}{d_localidad:13}{c_postal:6}{c_provincia:2}{space(2)}{c_estado_civil:2}{c_sexo:1}{c_nacionalidad:3}{space(4)}{f_nacim}00{space(3)}{incapacidad:1}{space(4)}S{space(1)}{sueldo}{c_categoria:2}{f_ingreso}
	</DETAIL>
	<MESS>
		<EMPTY mess="No se encontraron registros. Por favor valide que los legajos est&#233;n asociados al sindicato correcto y que las liquidaciones del per&#237;odo est&#233;n cerradas."/>
	</MESS>
</INTERFACE-DEF>
