<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="1">
	<QUERY declare="&lt;DATA interface=&quot;SIJP&quot; c_empresa=&quot;TyT&quot; p_periodo=&quot;200902&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="DATA">
				<qry:element name="DETAILS">
					<qry:element name="VAR">
						<qry:append-doc name="VAR" doc-path="."/>
						<qry:insert-select name="qry_variables"/>
						<qry:attribute name="hts:delete" value="1"/>
						<qry:attribute name="c_columnas" value="substring-after(@c_columnas,',')"/>
					</qry:element>
					<qry:element doc-path="ROW">
						<qry:append-doc name="ROW" doc-path="."/>
						<qry:insert-select name="qryDetail" doc-path="#SOURCE:DATA"/>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:element>
					<qry:insert-select name="qry_format" doc-path="#ROW:"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryDetail" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
						SELECT
							max(TLP.oi_per_emp_ddo) as oi_per_emp_ddo,
						    max(PE.c_personal) as c_personal,
							max(TLP.oi_tot_liq_per) as oi_tot_liq_per,						    
						 	max(PE.c_nro_cuil) as c_nro_cuil,
							max(PE.d_ape_y_nom) as d_ape_y_nom,
							max(EMP.c_actividad) as c_actividad,
							max(PE.c_obra_social) as c_obra_social,
							sum(TLP.n_totasig) as n_totasig,
							sum(TLP.n_totsret) as n_totsret, 
							{%=#VAR:@c_columnas%}
							
						FROM
							LIQ20_TOT_LIQ_PER as TLP,
							LIQ97_PERSONAL_EMP as PE,   
							PER01_PERSONAL as PER, 
							LIQ99_LIQUIDACION as LIQ,
							LIQ93_EMPRESAS as EMP,
							LIQ96_CONCEPTOS as LCON, 
							LIQ20_CONC_LIQ_PER as CON,
							LIQ20_VAR_GR_CONC as V,
							LIQ99_RECIBOS as REC
						
						JOIN
							TLP.oi_per_emp_ddo 			INNER PE.oi_per_emp_ddo,
							PER.c_personal 					INNER PE.c_personal,
							LIQ.oi_liquidacion_ddo 	INNER REC.oi_liquidacion_ddo,
							TLP.oi_tot_liq_per 			INNER REC.oi_tot_liq_per,
							LIQ.oi_empresa_ddo 			INNER EMP.oi_empresa_ddo,							
							TLP.oi_tot_liq_per 			INNER V.oi_tot_liq_per,
						 							
						WHERE 							
							 EMP.c_empresa = { #SOURCE:@c_empresa }
							AND LIQ.e_periodo = { #SOURCE:@p_periodo }
							AND LIQ.c_estado = \'F\'                                        
							AND V.c_grupo = \'4\'
                         
                        GROUP BY
                        	 PE.e_numero_legajo               
						ORDER BY 
							c_personal ASC,
							oi_tot_liq_per ASC
														
						')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_format" doc="SOURCE">
			<qry:out>
				<qry:element name="DETAIL">
					<!--------------------------------------------->
					<qry:attribute name="rowdesc" value="$r/@d_ape_y_nom"/>
					<!--------------------------------------------->
					<qry:attribute name="c_nro_cuil" value="NMD_REPLACE($r/@c_nro_cuil, '-', '')"/>
					<qry:attribute name="d_ape_y_nom" value="NMD_FILLRIGHT($r/@d_ape_y_nom, ' ', 30, 'R')"/>
					<qry:attribute name="conyuge" value="IIF($r/@vs_afipconyuge = '1', 'T', 'F')"/>
					<qry:attribute name="q_hijos" value="FORMAT_NUMBER($r/@vs_afipcantidadhijos, 2, 0, '', '', '0')"/>
					<qry:attribute name="situacion" value="FORMAT_NUMBER($r/@vs_afipsiturev1, 2, 0, '', '', '0')"/>
					<qry:attribute name="condicion" value="FORMAT_NUMBER($r/@vs_afipcondicion, 2, 0, '', '', '0')"/>
					<qry:attribute name="actividad" value="FORMAT_NUMBER($r/@vs_afipactividad, 2, 0, '', '', '0')"/>
					<qry:attribute name="zona" value="FORMAT_NUMBER($r/@vs_afipzona, 2, 0, '', '', '0')"/>
					<qry:attribute name="papadicss" value="FORMAT_NUMBER($r/@vs_afippapadicss, 5, 0, '', '', '0')"/>
					<qry:attribute name="modcont" value="FORMAT_NUMBER($r/@vs_afipmodcontratacion, 3, 0, '', '', '0')"/>
					<qry:attribute name="c_obra_social" value="FORMAT_NUMBER($r/@vs_afipobrasocial, 6, 0, '', '', '0')"/>
					<qry:attribute name="adherentes" value="FORMAT_NUMBER($r/@vs_afipcantadherentes, 2, 0, '', '', '0')"/>
					<qry:attribute name="remuntot" value="FORMAT_NUMBER($r/@vs_afipremuntot, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remunimp1" value="FORMAT_NUMBER($r/@vs_afipremunimpo1, 6, 2, '.', '', '0')"/>
					<qry:attribute name="asig_fam_pag" value="FORMAT_NUMBER($r/@vs_totasig, 6, 2, '.', '', '0')"/>
					<qry:attribute name="impapvol" value="FORMAT_NUMBER($r/@vs_afipimpapvolss, 6, 2, '.', '', '0')"/>
					<qry:attribute name="impadicos" value="FORMAT_NUMBER($r/@vs_afipimpadicos, 6, 2, '.', '', '0')"/>
					<qry:attribute name="impexcapss" value="FORMAT_NUMBER($r/@vs_afipimpexcapss, 6, 2, '.', '', '0')"/>
					<qry:attribute name="impexcapos" value="FORMAT_NUMBER($r/@vs_afipimpexcapos, 6, 2, '.', '', '0')"/>
					<qry:attribute name="prov_loc" value="NMD_FILLRIGHT($r/@vs_afiplocalidad, ' ', 50, 'R')"/>
					<qry:attribute name="remunimp2" value="FORMAT_NUMBER($r/@vs_afipremunimpo2, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remunimp3" value="FORMAT_NUMBER($r/@vs_afipremunimpo3, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remunimp4" value="FORMAT_NUMBER($r/@vs_afipremunimpo4, 6, 2, '.', '', '0')"/>
					<qry:attribute name="siniestro" value="FORMAT_NUMBER($r/@vs_afipsiniestro, 2, 0, '', '', '0')"/>
					<qry:attribute name="reduc" value="FORMAT_NUMBER($r/@vs_afipreduc, 1, 0, '', '', '0')"/>
					<qry:attribute name="capreclrt" value="FORMAT_NUMBER($r/@vs_afipcapreclrt, 6, 2, '.', '', '0')"/>
					<qry:attribute name="tipo_emp_sijp" value="NMD_FILLLEFT($r/@vs_afiptipoempresa, ' ', 1, 'R')"/>
					<qry:attribute name="aporteadicos" value="FORMAT_NUMBER($r/@vs_afipadicionalesos, 6, 2, '.', '', '0')"/>
					<qry:attribute name="regimen" value="FORMAT_NUMBER($r/@vs_afipregimen, 1, 0, '', '', '0')"/>
					<qry:attribute name="sitrevista1" value="FORMAT_NUMBER($r/@vs_afipsiturev1, 2, 0, '', '', '0')"/>
					<qry:attribute name="dsitrevista1" value="FORMAT_NUMBER($r/@vs_afipdiasiturev1, 2, 0, '', '', '0')"/>
					<qry:attribute name="sitrevista2" value="FORMAT_NUMBER($r/@vs_afipsiturev2, 2, 0, '', '', '0')"/>
					<qry:attribute name="dsitrevista2" value="FORMAT_NUMBER($r/@vs_afipdiasiturev2, 2, 0, '', '', '0')"/>
					<qry:attribute name="sitrevista3" value="FORMAT_NUMBER($r/@vs_afipsiturev3, 2, 0, '', '', '0')"/>
					<qry:attribute name="dsitrevista3" value="FORMAT_NUMBER($r/@vs_afipdiasiturev3, 2, 0, '', '', '0')"/>
					<qry:attribute name="sueldoadic" value="FORMAT_NUMBER($r/@vs_afipsueldomasadic, 6, 2, '.', '', '0')"/>
					<qry:attribute name="sac" value="FORMAT_NUMBER($r/@vs_afipsac, 6, 2, '.', '', '0')"/>
					<qry:attribute name="hextras" value="FORMAT_NUMBER($r/@vs_afiphextras, 6, 2, '.', '', '0')"/>
					<qry:attribute name="imp_zona_des" value="FORMAT_NUMBER($r/@vs_afipzonadesfavoralble, 6, 2, '.', '', '0')"/>
					<qry:attribute name="vacaciones" value="FORMAT_NUMBER($r/@vs_afipvacaciones, 6, 2, '.', '', '0')"/>
					<qry:attribute name="qdiastrab" value="FORMAT_NUMBER($r/@vs_afipqdiastrab, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remunimp5" value="FORMAT_NUMBER($r/@vs_afipremunimpo5, 6, 2, '.', '', '0')"/>
					<qry:attribute name="convencionado" value="FORMAT_NUMBER($r/@vs_afipconvencionado, 1, 0, '', '', '0')"/>
					<qry:attribute name="remunimp6" value="FORMAT_NUMBER($r/@vs_afipremunimpo6, 6, 2, '.', '', '0')"/>
					<qry:attribute name="tipopera" value="FORMAT_NUMBER($r/@vs_afiptipopera, 1, 0, '', '', '0')"/>
					<qry:attribute name="adicionales" value="FORMAT_NUMBER($r/@vs_afipsueldoadic, 6, 2, '.', '', '0')"/>
					<qry:attribute name="premios" value="FORMAT_NUMBER($r/@vs_afippremios, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remdec788_05" value="FORMAT_NUMBER($r/@vs_afipremundec78805, 6, 2, '.', '', '0')"/>
					<qry:attribute name="remunimp7" value="FORMAT_NUMBER($r/@vs_afipremunimp7, 6, 2, '.', '', '0')"/>
					<qry:attribute name="qhextras" value="FORMAT_NUMBER($r/@vs_afipqhextras, 3, 0, '', '', '0')"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</QUERY>
	<DETAIL>
		{c_nro_cuil:11}{d_ape_y_nom}{conyuge:1}{q_hijos:2}{situacion:2}{condicion:2}{actividad:2}{zona:2}{papadicss:5}{modcont:3}{c_obra_social:6}{adherentes:2}{remuntot:9}{remunimp1:9}{asig_fam_pag:9}{impapvol:9}{impadicos:9}{impexcapss:9}{impexcapos:9}{space(50)}{remunimp2:9}{remunimp3:9}{remunimp4:9}{siniestro:2}{reduc:1}{capreclrt:9}{tipo_emp_sijp:1}{aporteadicos:9}{regimen:1}{sitrevista1:2}{dsitrevista1:2}{sitrevista2:2}{dsitrevista2:2}{sitrevista3:2}{dsitrevista3:2}{sueldoadic:9}{sac:9}{hextras:9}{imp_zona_des:9}{vacaciones:9}{qdiastrab:9}{remunimp5:9}{convencionado:1}{remunimp6:9}{tipopera:1}{adicionales:9}{premios:9}{remdec788_05:9}{remunimp7:9}{qhextras:3}
	</DETAIL>
	<MESS>
		<EMPTY mess="No se encontraron registros. Por favor valide que los legajos est&#233;n asociados al sindicato correcto."/>
	</MESS>
</INTERFACE-DEF>
