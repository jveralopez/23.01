		WHERE 
			ORG26_PARAMETROS.d_clase = \'LIQ\'
			AND ORG26_PARAMETROS.c_modulo = \'LIQ\'
			AND ORG26_PARAMETROS.c_parametro in (\'F1359CodImpuesto\',\'F1359CodConcepto\',\'F1359NroForm\',\'F1359VerSistema\')
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:switch test="$r/@c_parametro">
