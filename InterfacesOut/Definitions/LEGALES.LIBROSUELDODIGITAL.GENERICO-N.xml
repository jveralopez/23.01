<INTERFACE-DEF xmlns:qry="nomad_engine.qry" desc="" entermode="DOS" finalenter="0">
	<FOR-EACH declare="&lt;DATA c_empresa=&quot;1&quot; interface=&quot;LSDIG2&quot; p_periodo=&quot;202302&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATA"/>
			<XXX>
				<HEAD e_modo="2">
					<qry:append-doc name="HEAD" doc-path="."/>
					<qry:attribute name="cant_reg" value="'000000'"/>
					<qry:insert-select name="qry_head"/>
					<qry:insert-select name="qry_param"/>
				</HEAD>
				<DETAILS>
					<qry:insert-select name="qryPersonas" doc-path="$HEAD"/>
					<qry:if test="@oi_tot_liq_per!=''">
						<qry:then>
							<qry:call qry-sum="cant_reg">
								<DATA>
									<qry:attribute name="oi_tot_liq_per" value="substring(../../@oi_tot_liq_per,1)"/>
									<qry:attribute name="c_empresa" value="$HEAD/@c_empresa"/>
									<qry:attribute name="e_periodo" value="$HEAD/@e_periodo"/>
									<qry:attribute name="e_modo" value="$HEAD/@e_modo"/>
								</DATA>
							</qry:call>
							<qry:attribute name="oi_tot_liq_per" value="''"/>
							<qry:attribute name="count" value="''"/>
							<qry:attribute name="e_numero_legajo" value="''"/>
						</qry:then>
					</qry:if>
				</DETAILS>
			</XXX>
		</qry:main>
		<qry:select name="qry_head">
			<qry:xquery>
				for $r in SQL('
select
E.c_cuit,
E.c_empresa
from
ORG03_EMPRESAS as E
where
E.c_empresa = {#PARAMIN:@c_empresa}                   
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_cuit" value="translate($r/@c_cuit,'-','')"/>
				<qry:attribute name="c_empresa" value="#PARAMIN:@c_empresa"/>
				<qry:attribute name="e_periodo" value="#PARAMIN:@p_periodo"/>
				<qry:attribute name="nro_liquidacion" value="iif(number(#PARAMIN:@nroLiquidacion) > 0, fill-left(#PARAMIN:@nroLiquidacion,'0',5), '00001')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_param">
			<qry:xquery>
				for $r in SQL('
select 
P.d_valor 
from 
ORG26_PARAMETROS as P
where P.c_modulo = \'LIQ\' and P.d_clase = \'LSD\' and P.c_parametro = \'LSDConceptos\'
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="e_modo" value="$r/@d_valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryPersonas" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
SELECT 
P.e_numero_legajo,
T.oi_tot_liq_per,
T.f_gen
FROM 
LIQ99_LIQUIDACION as L, 
LIQ97_PERSONAL_EMP as P,
LIQ99_RECIBOS as R,
LIQ20_TOT_LIQ_PER as T
join                                    
R.oi_tot_liq_per INNER T.oi_tot_liq_per,
P.oi_per_emp_ddo INNER T.oi_per_emp_ddo,
L.oi_liquidacion_ddo INNER R.oi_liquidacion_ddo
where
    L.c_tipo_liq = \'6\' and L.c_estado = \'F\' and L.e_periodo = {#HEAD:@e_periodo} and L.c_empresa = {#HEAD:@c_empresa}
order by
e_numero_legajo ASC, f_gen DESC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="@e_numero_legajo != $r/@e_numero_legajo">
					<qry:then>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:if test="number(@count) &gt;= 30">
							<qry:then>
								<qry:call>
									<DATA>
										<qry:attribute name="oi_tot_liq_per" value="substring(../../@oi_tot_liq_per,1)"/>
										<qry:attribute name="c_empresa" value="$HEAD/@c_empresa"/>
										<qry:attribute name="e_periodo" value="$HEAD/@e_periodo"/>
										<qry:attribute name="e_modo" value="$HEAD/@e_modo"/>
									</DATA>
								</qry:call>
								<qry:attribute name="oi_tot_liq_per" value="''"/>
								<qry:attribute name="count" value="0"/>
							</qry:then>
						</qry:if>
						<qry:attribute name="oi_tot_liq_per" value="@oi_tot_liq_per + ',' + $r/@oi_tot_liq_per "/>
						<qry:attribute name="count" value="number(@count) + 1"/>
					</qry:then>
				</qry:if>
			</qry:out>
		</qry:select>
	</FOR-EACH>
	<QUERY declare="&lt;DATA e_modo=&quot;3&quot; e_periodo=&quot;202302&quot; c_empresa=&quot;1&quot; oi_tot_liq_per=&quot;371801,371802&quot;/&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<OUTS qry-vars="cant_reg">
				<qry:append-doc name="OUTS" doc-path="."/>
				<qry:append-doc name="PARAMIN" doc-path="#SOURCE:/DATA"/>
				<SICOSS>
					<qry:append-doc name="Sicoss" doc-path="."/>
					<qry:insert-select name="qrySicoss" doc-path="#PARAMIN:"/>
					<qry:attribute name="hts:delete" value="1"/>
				</SICOSS>
				<qry:insert-select name="qryPersonas" doc-path="#PARAMIN:"/>
				<qry:insert-select name="qryPersonasDetalle" doc-path="#PARAMIN:"/>
				<qry:insert-select name="qryPersonasInterface" doc-path="#PARAMIN:"/>
				<qry:attribute name="cant_reg" value="count(./DETAIL[@hts:delete != 1])"/>
			</OUTS>
		</qry:main>
		<qry:select name="qryPersonas" doc="SOURCE">
			<qry:xquery>
				for $r in SQL(' 
SELECT 
LIQ97_PERSONAL_EMP.c_personal AS c_personal,
LIQ97_PERSONAL_EMP.c_nro_cuil AS c_nro_cuil,
LIQ97_PERSONAL_EMP.d_ape_y_nom AS d_ape_y_nom, 
LIQ97_PERSONAL_EMP.e_numero_legajo AS e_numero_legajo,  
LIQ97_PERSONAL_EMP.c_cbu AS c_cbu,   
LIQ99_LIQUIDACION.f_pago,
LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
PER01_PERSONAL.d_apellido,
PER01_PERSONAL.d_nombres,
LIQ97_PERSONAL_EMP.c_forma_pago,
LIQ17_ZONAS_SIJP.c_zona_sijp
FROM 
LIQ99_LIQUIDACION, 
LIQ97_PERSONAL_EMP,
LIQ99_RECIBOS,
LIQ20_TOT_LIQ_PER,
PER01_PERSONAL,
LIQ19_LIQUIDACION,
ORG03_EMPRESAS,
ORG03_UBICACIONES,
LIQ15_UBICACIONES,
LIQ17_ZONAS_SIJP
JOIN           
 	LIQ97_PERSONAL_EMP.c_personal INNER PER01_PERSONAL.c_personal,
LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
LIQ99_LIQUIDACION.c_liquidacion INNER LIQ19_LIQUIDACION.c_liquidacion,
LIQ99_LIQUIDACION.c_empresa INNER ORG03_EMPRESAS.c_empresa,
ORG03_UBICACIONES.c_ubicacion INNER LIQ97_PERSONAL_EMP.c_ubicacion,
LIQ15_UBICACIONES.oi_ubicacion INNER  ORG03_UBICACIONES.oi_ubicacion,
LIQ15_UBICACIONES.oi_zona_sijp LEFT OUTER LIQ17_ZONAS_SIJP.oi_zona_sijp,
ORG03_EMPRESAS.oi_empresa INNER LIQ15_UBICACIONES.oi_empresa

WHERE 
LIQ20_TOT_LIQ_PER.oi_tot_liq_per in ({%= #SOURCE:@oi_tot_liq_per  %})
ORDER BY 
c_personal ASC, 
oi_tot_liq_per ASC																		
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<DETAIL>
					<qry:attribute name="c_zona_sijp" value="$r/@c_zona_sijp"/>
					<qry:attribute name="tipo2" value="'02'"/>
					<qry:attribute name="c_nro_cuil" value="translate($r/@c_nro_cuil,'-','')"/>
					<qry:attribute name="cuil" value="$r/@c_nro_cuil"/>
					<qry:attribute name="e_numero_legajo" value="FILL-LEFT($r/@e_numero_legajo,'0',10)"/>
					<qry:attribute name="e_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_revista" value="FILL-LEFT(' ',' ',50)"/>
					<qry:attribute name="f_rubrica" value="FILL-LEFT(' ',' ',8)"/>
					<qry:if test="$r/@c_forma_pago = '1' or $r/@c_forma_pago = '2' or $r/@c_forma_pago = '3'">
						<qry:then>
							<qry:attribute name="c_cbu" value="fill-left(normalize-space($r/@c_cbu),' ',22)"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_cbu" value="fill-left(normalize-space($r/@c_cbu),'0',22)"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="f_pago" value="$r/@f_pago"/>
					<qry:switch test="$r/@c_forma_pago">
						<qry:case value="2">
							<qry:attribute name="c_forma_pago" value="'1'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_forma_pago" value="'2'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_forma_pago" value="'3'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
					<qry:attribute name="hts:delete" value="1"/>
				</DETAIL>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qryPersonasDetalle">
			<qry:xquery>
				for $r in sql('
SELECT 
P.c_personal AS c_personal,
CON.c_concepto as c_concepto,
sum(CLP.n_valor) AS valor,
sum(CLP.n_cantidad) AS Scantidad,
max(CLP.n_cantidad) AS Mcantidad,
max(T.e_orden) as e_orden,
max(E.c_equivalencia) as c_equivalencia,
max(E.l_informa) as l_informa, 
max(P.c_nro_cuil) AS c_nro_cuil,
max(C.o_concepto) AS obs
FROM 
LIQ20_TOT_LIQ_PER AS TLP, 
liq20_conc_liq_per AS CLP, 
liq96_conceptos AS CON, 
LIQ14_CONCEPTOS AS C, 
LIQ12_TIPOS_CONC AS T,
liq14_equivalencia as E,
LIQ97_PERSONAL_EMP as P,
LIQ99_LIQUIDACION as LIQ, 
LIQ99_RECIBOS as R
JOIN
R.oi_tot_liq_per INNER TLP.oi_tot_liq_per,
LIQ.oi_liquidacion_ddo INNER R.oi_liquidacion_ddo,
TLP.oi_tot_liq_per INNER CLP.oi_tot_liq_per,
P.oi_per_emp_ddo INNER TLP.oi_per_emp_ddo,
CON.oi_concepto_ddo INNER CLP.oi_concepto_ddo,
C.c_concepto INNER CON.c_concepto,
C.oi_tipo_concepto INNER T.oi_tipo_concepto,
C.oi_concepto LEFT OUTER E.oi_concepto 
WHERE
 
T.l_nolistado = 0  and
CLP.n_valor != 0 and 
CON.ca_fig_recibo != \'N\' and          
LIQ.c_estado = \'F\' and LIQ.c_tipo_liq != \'6\' and LIQ.c_tipo_liq != \'7\' and
LIQ.c_empresa = {#SOURCE:@c_empresa} and
LIQ.e_periodo = {#SOURCE:@e_periodo} and
P.e_numero_legajo in ({%= #OUTS:DETAIL/@e_legajo %})

group by
P.c_personal, CON.c_concepto

ORDER BY
c_personal ASC,
e_orden ASC, 
c_concepto ASC')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:append-doc name="DETAIL2" doc-path="."/>
				<qry:attribute name="c_nro_cuil" value="translate($r/@c_nro_cuil,'-','')"/>
				<qry:insert-select name="SetFound" to-element="$OUTS/DETAIL[@c_nro_cuil = $DETAIL2/@c_nro_cuil ]" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="SetFound" doc="r">
			<qry:out>
				<qry:attribute name="hts:delete" value="''"/>
				<DETAIL2>
					<qry:attribute name="c_nro_cuil" value="translate($r/@c_nro_cuil,'-','')"/>
					<qry:attribute name="tipo3" value="'03'"/>
					<qry:if test="$r/@c_equivalencia !='' and $r/@l_informa!='1' ">
						<qry:then>
							<qry:attribute name="c_concepto" value="fill-left($r/@c_equivalencia,' ',10)"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_concepto" value="fill-left($r/@c_concepto,' ',10)"/>
						</qry:else>
					</qry:if>
					<qry:switch test="#PARAMIN:@e_modo">
						<qry:case value="1">
							<qry:attribute name="c_concepto" value="fill-left(number(@c_concepto),' ',10)"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_concepto" value="fill-left(number(@c_concepto),'0',10)"/>
						</qry:case>
					</qry:switch>
					<qry:if test="contains($r/@obs,'[LSD_NA]')">
						<qry:then>
							<qry:attribute value="format_number(abs($r/@Mcantidad),3,2,'','','0')" name="cantidad"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="format_number(abs($r/@Scantidad),3,2,'','','0')" name="cantidad"/>
						</qry:else>
					</qry:if>
					<qry:if test="number($r/@valor) &gt;= 0">
						<qry:then>
							<qry:attribute value="format_number(number($r/@valor),13,2,'','','0')" name="importe"/>
							<qry:attribute name="deb_cred" value="'C'"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="format_number(0-number($r/@valor),13,2,'','','0')" name="importe"/>
							<qry:attribute name="deb_cred" value="'D'"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="e_periodo_ajuste" value="fill-left(' ',' ',6)"/>
				</DETAIL2>
			</qry:out>
		</qry:select>
