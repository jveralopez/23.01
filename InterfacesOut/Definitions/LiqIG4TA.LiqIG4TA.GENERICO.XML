uot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; cb_confidenciales=&quot;&quot; oi_grupo_ccosto=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; oi_departamento=&quot;&quot; oi_sector=&quot;&quot; secuencia=&quot;22&quot; /&gt;&#13;&#10;&lt;/DATOS&gt;">
		<qry:include mode="CLASS" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.QRY_IG"/>
		<qry:main name="main" doc="SOURCE">
			<qry:append-doc doc-path="#SOURCE:DATOS/DATOS" name="PARAM"/>
			<qry:append-doc doc-path="#SOURCE:DATOS" name="PARAM2"/>
			<DATA>
				<DATOS>
					<!--<qry:attribute name="hts:delete" value="1"/>-->
					<qry:insert-select doc-path="#PARAM:" name="qry_cabecera"/>
					<qry:append-doc name="PARAM3" doc-path="."/>
				</DATOS>
				<qry:element name="HEAD">
					<qry:attribute name="cuit" value="nmd-replace(#PARAM3:@c_cuit,'-','')"/>
					<qry:attribute name="F1357CodImpuesto" value="'0000'"/>
					<qry:attribute name="F1357CodConcepto" value="'000'"/>
					<qry:attribute name="F1357NroForm" value="'0000'"/>
					<qry:attribute name="F1357VerSistema" value="'00000'"/>
					<qry:insert-select name="qry_parametros_f1357"/>					
					<qry:insert-select doc-path="#PARAM:" name="qry_periodo"/>
					<qry:attribute name="secuencia" value="'00'"/>
					<qry:if test="#PARAM:@secuencia!=''">
						<qry:then>
							<qry:attribute name="secuencia" value="nmd-fillleft(#PARAM:@secuencia,'0',2)"/>
						</qry:then>
					</qry:if>
					<qry:attribute name="tipo_liq" value="nmd-fillleft(#PARAM:@tipo_liq,'0',1)"/>
					<qry:if test="#PARAM:@tipo_liq='1.1'">
						<qry:then>
							<qry:attribute name="tipo_liq" value="'1'"/>
						</qry:then>
					</qry:if>					
				</qry:element>
				<DETAILS>
					<qry:insert-select name="qry_ingresos_filtro"/>
					<qry:insert-select doc-path="#PARAM3:" name="qry_detalle"/>
				</DETAILS>
			</DATA>
		</qry:main>
		<qry:select name="qry_periodo" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
		SELECT   
			GetYear(L.f_pago) as anio,
			P.e_periodo
		FROM 
			LIQ19_EJECUCIONES AS E, 
			LIQ99_LIQUIDACION AS L,
			LIQ19_LIQUIDACION AS P
		JOIN
		E.oi_liquidacion_ddo INNER L.oi_liquidacion_ddo,
		E.oi_liquidacion INNER P.oi_liquidacion
		
		WHERE													
			E.oi_liquidacion = {#PARAM:@oi_liquidacionFIL}
			AND L.c_estado = \'F\'
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="#PARAM:@tipo_liq='1' and #PARAM:@l_anioAnterior='1'">
					<qry:then>
						<qry:attribute name="periodo" value="nmd-fillright(number($r/@anio) - 1,'0',6)"/>	
					</qry:then>
					<qry:else>
						<qry:attribute name="periodo" value="$r/@e_periodo"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_parametros_f1357">
			<qry:xquery>
				for $r in SQL('
		SELECT 
			ORG26_PARAMETROS.c_parametro, 
			ORG26_PARAMETROS.d_valor 
		FROM
			ORG26_PARAMETROS
		WHERE 
			ORG26_PARAMETROS.d_clase = \'LIQ\'
			AND ORG26_PARAMETROS.c_modulo = \'LIQ\'
			AND ORG26_PARAMETROS.c_parametro in (\'F1357CodImpuesto\',\'F1357CodConcepto\',\'F1357NroForm\',\'F1357VerSistema\')
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:switch test="$r/@c_parametro">
					<qry:case value="F1357CodImpuesto">
						<qry:attribute name="F1357CodImpuesto" value="nmd-fillleft($r/@d_valor,'0',4)"/>
					</qry:case>
					<qry:case value="F1357CodConcepto">
						<qry:attribute name="F1357CodConcepto" value="nmd-fillleft($r/@d_valor,'0',3)"/>
					</qry:case>
					<qry:case value="F1357NroForm">
						<qry:attribute name="F1357NroForm" value="nmd-fillleft($r/@d_valor,'0',4)"/>
					</qry:case>
					<qry:case value="F1357VerSistema">
						<qry:attribute name="F1357VerSistema" value="nmd-fillleft($r/@d_valor,'0',5)"/>
					</qry:case>
				</qry:switch>
			</qry:out>
		</qry:select>
		<qry:select name="qry_detalle" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:L
			</qry:xquery>
			<qry:out>
				<qry:element name="DETAIL">
					<qry:if test="number($r/@n_tot63)&gt;=number(../@F1357IngresosMaximos)">
						<qry:then>
							<qry:insert-select name="qry_reg02" doc-path="$r"/>
							<qry:insert-select name="qry_reg03" doc-path="$r"/>
							<qry:insert-select name="qry_reg04" doc-path="$r"/>
							<qry:insert-select name="qry_reg05" doc-path="$r"/>
							<qry:insert-select name="qry_reg06" doc-path="$r"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="hts:delete" value="1"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_reg02" doc="PARAM">
			<qry:out>
				<qry:attribute name="cuil" value="nmd-replace($PARAM/@c_cuil,'-','')"/>
				<qry:attribute name="ano_d" value="substring($PARAM/@f_desde,6,4)"/>
				<qry:attribute name="mes_d" value="substring($PARAM/@f_desde,3,2)"/>
				<qry:attribute name="dia_d" value="substring($PARAM/@f_desde,0,2)"/>
				<qry:attribute name="per_desde" value="@ano_d+@mes_d+@dia_d"/>
				<qry:attribute name="ano_h" value="substring($PARAM/@f_hasta,6,4)"/>
				<qry:attribute name="mes_h" value="substring($PARAM/@f_hasta,3,2)"/>
				<qry:attribute name="dia_h" value="substring($PARAM/@f_hasta,0,2)"/>
				<qry:attribute name="per_hasta" value="@ano_h+@mes_h+@dia_h"/>
