<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" xtends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusProject.Base.Project.Parte.rpt">
	<html:query declare="&lt;DATOS oi_recurso=&quot;&quot; f_desde=&quot;20120821&quot; f_hasta=&quot;20121219&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Parte">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="REP" style="padding-left:1px;" type="title">
						<COLS>
							<COL name="recurso_filtro" label="Recurso"/>
							<COL name="f_desde" label="Fecha Desde"/>
							<COL name="f_hasta" label="Fecha Hasta"/>
						</COLS>
						<GROUP tag="TRABAJOS" style="padding-left:1px;" type="table" noreg="No se encontraron registros para los filtros seleccionados.">
							<COLS>
								<COL name="f_fecha" label="Fecha" align="left" style="width:50px;" nowrap="1"/>
								<COL name="proyecto" label="Proyecto" align="left" style="width:200px;" nowrap="1"/>
								<COL name="tarea" label="Tarea" align="left" style="width:200px;" nowrap="1"/>
								<COL name="recurso" label="Recurso" align="left" style="width:200px;" nowrap="1"/>
								<COL name="perfil" label="Perfil" align="left" style="width:200px;" nowrap="1"/>
								<COL name="duracion" label="Duracio&#243;n (Hs)" align="left" style="width:50px;" nowrap="1"/>
								<COL name="mensaje" label="Mensaje" align="left" style="width:400px;" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:attribute value="format_date(#SOURCE:DATOS/@f_desde, 'dd/mm/yyyy')" name="f_desde"/>
						<qry:attribute value="format_date(#SOURCE:DATOS/@f_hasta, 'dd/mm/yyyy')" name="f_hasta"/>
						<qry:insert-select name="QRY_TRABAJOS" doc-path="#SOURCE:DATOS"/>
						<qry:attribute value="iif(#SOURCE:DATOS/@oi_recurso!='',./@recurso,'Todos')" name="recurso_filtro"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_TRABAJOS" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
	pt.f_fecha,
	pt.e_duracion,
	pt.oi_perfil,
	pt.oi_tarea,
	pt.oi_recurso,
	pt.oi_trabajo,
	pt.o_mensaje,
	put1.e_minutos,
	pt2.c_tarea,
	pt2.d_tarea,
	pt2.c_estado,
	pp.c_proyecto,
	pp.d_proyecto,
	pp2.d_ape_y_nom,
	pp3.d_perfil
FROM   
	PRY04_TRABAJOS AS pt
	, PRY03_UND_TIEMPO AS put1
	, PRY02_TAREAS AS pt2
	, PRY05_RECURSOS AS pr
	, PRY01_PROYECTOS AS pp
	, PER01_PERSONAL AS pp2
	, PRY06_PERFILES AS pp3
JOIN	
	put1.oi_unidad_tiempo INNER pt.oi_unidad_tiempo
	, pt2.oi_tarea INNER pt.oi_tarea
	, pt.oi_recurso INNER pr.oi_recurso
	, pp.oi_proyecto INNER pt2.oi_proyecto
	, pp2.oi_personal INNER pr.oi_personal
	, pp3.oi_perfil INNER pt.oi_perfil
WHERE
	1=1
	{%? (#PARAM:@oi_recurso!='') {% AND pt.oi_recurso = {#PARAM:@oi_recurso} %} {% %} %}
	{%? (#PARAM:@f_desde!='') {% AND pt.f_fecha &gt;= {DateTime(#PARAM:@f_desde)} %} {% %} %}
	{%? (#PARAM:@f_hasta!='') {% AND pt.f_fecha &lt;= {DateTime(#PARAM:@f_hasta)} %} {% %} %}    
ORDER BY
	f_fecha ASC, 
	c_proyecto ASC,
	c_tarea ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@d_ape_y_nom" name="recurso"/>
				<qry:element name="TRABAJOS">
					<qry:attribute value="format_date($r/@f_fecha, 'dd/mm/yyyy')" name="f_fecha"/>
					<qry:attribute value="$r/@c_tarea+'-'+$r/@d_tarea" name="tarea"/>
					<qry:attribute value="$r/@c_proyecto+'-'+$r/@d_proyecto" name="proyecto"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="recurso"/>
					<qry:attribute value="$r/@o_mensaje" name="mensaje"/>
					<qry:attribute value="$r/@d_perfil" name="perfil"/>
					<qry:attribute value="number(number($r/@e_duracion) * number($r/@e_minutos)) div 60" name="duracion"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
