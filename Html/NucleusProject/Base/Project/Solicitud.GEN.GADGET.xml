<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="Solicitud" extends="NucleusRH.Base.Configuracion.GadgetBASE.rpt" doc="source">
	<html:query declare="&lt;PARAMS oi_solicitud=&quot;860&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:PARAMS"/>
					<qry:attribute name="total" value="0"/>
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_sol"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_sol">
			<qry:xquery>
				for $r in sql('
SELECT
    sol.oi_solicitud,
    sol.c_solicitud,
    sol.f_solicitud,
    sol.c_estado,
    sol.d_solicitud,
    sol.o_detalle,
    sol.o_observaciones, 
    sol.f_implem as f_implementacion, 
    cont.d_nom_y_ape,
    mod.c_modulo, 
    mod.d_nombre as d_modulo,
    rec.c_recurso

FROM
    PRY07_SOLICITUDES AS sol,  
    PRY05_RECURSOS AS rec,
    PRY11_MODULOS AS mod,
    PRY08_CONTACTOS as cont

JOIN
    sol.oi_recurso LEFT OUTER rec.oi_recurso,
    sol.oi_modulo LEFT OUTER mod.oi_modulo,
    sol.oi_contacto LEFT OUTER cont.oi_contacto

WHERE
    sol.oi_solicitud = {#PARAM:@oi_solicitud}	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
				<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
				<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
				<qry:attribute name="f_implementacion" value="format_date($r/@f_implementacion, 'dd/mm/yyyy')"/>
				<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
				<qry:attribute name="c_modulo" value="$r/@c_modulo"/>
				<qry:attribute name="d_modulo" value="$r/@d_modulo"/>
				<qry:switch test="$r/@c_estado">
					<qry:case value="1">
						<qry:attribute name="d_estado" value="'PENDIENTE'"/>
					</qry:case>
					<qry:case value="2">
						<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
					</qry:case>
					<qry:case value="3">
						<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
					</qry:case>
					<qry:case value="4">
						<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
					</qry:case>
					<qry:case value="5">
						<qry:attribute name="d_estado" value="'CERRADO'"/>
					</qry:case>
					<qry:case value="6">
						<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
					</qry:case>
					<qry:case value="7">
						<qry:attribute name="d_estado" value="'RECHAZADO'"/>
					</qry:case>
					<qry:case value="8">
						<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
					</qry:case>
					<qry:case value="9">
						<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="d_estado" value="$r/@c_estado"/>
					</qry:default>
				</qry:switch>
				<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
				<qry:attribute name="o_detalle" value="$r/@o_detalle"/>
				<qry:attribute name="o_observaciones" value="$r/@o_observaciones"/>
				<qry:insert-select name="qry_tarea_sop" doc-path="$r"/>
				<qry:insert-select name="qry_total_sol" doc-path="."/>
				<qry:attribute name="clasificacion" value="'[' + $r/@c_clasificacion + '] ' + $r/@d_clasificacion"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_tarea_sop" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	  pt.oi_tarea,
	  pt.c_tarea,
	  pt.f_inicio,
	  pt.d_tarea, 
	  pt.c_estado,
	  rec.c_recurso,
	  pt.oi_proyecto,
	  pt.oi_pry_imputa,
	  pry.c_proyecto as c_proyecto,
	  pry.d_proyecto as d_proyecto

FROM 
	  PRY02_TAREAS AS pt,
   	  PRY05_RECURSOS AS rec,
      PRY01_PROYECTOS AS pry
    
JOIN         
	  pt.oi_recurso LEFT OUTER rec.oi_recurso,  
	  pt.oi_proyecto INNER pry.oi_proyecto
	
WHERE 
	  pt.oi_solicitud = {#PARAM:@oi_solicitud}

GROUP BY
	  pt.oi_tarea,
	  pt.c_tarea,
	  pt.f_inicio,
	  pt.d_tarea,
	  rec.c_recurso,
	  pt.c_estado,
	  pt.oi_proyecto, 
	  pt.oi_pry_imputa,
	  pry.c_proyecto,
	  pry.d_proyecto

		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TAREA">
					<qry:attribute name="bandera_datos" value="'si'"/>
					<qry:attribute name="c_proyecto" value="'[' + $r/@c_proyecto + '] ' + $r/@d_proyecto"/>
					<qry:attribute name="c_tarea" value="$r/@c_tarea"/>
					<qry:attribute name="f_tarea" value="format_date($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="I">
							<qry:attribute name="d_estado" value="'Inicializada'"/>
						</qry:case>
						<qry:case value="T">
							<qry:attribute name="d_estado" value="'Trabajando'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="d_estado" value="'Derivada a Testing'"/>
						</qry:case>
						<qry:case value="L">
							<qry:attribute name="d_estado" value="'BLoqueada'"/>
						</qry:case>
						<qry:case value="A">
							<qry:attribute name="d_estado" value="'Anulada'"/>
						</qry:case>
						<qry:case value="F">
							<qry:attribute name="d_estado" value="'Finalizada'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:insert-select name="qry_trabajo" doc-path="$r"/>
					<qry:insert-select name="qry_total_tarea" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_trabajo" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	  tra.f_fecha,
	  tra.o_mensaje,
	  rec.c_recurso,
	  tra.e_duracion,
	  ut.c_unidad_tiempo as unid
FROM 
	  PRY04_TRABAJOS AS tra,
  	  PRY05_RECURSOS AS rec,
      PRY03_UND_TIEMPO AS ut
JOIN         
	  tra.oi_recurso LEFT OUTER rec.oi_recurso,
	  tra.oi_unidad_tiempo INNER ut.oi_unidad_tiempo 
	  
WHERE 
	  tra.oi_tarea = {#PARAM:@oi_tarea}					

ORDER BY
 	  f_fecha DESC
 	  
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TRAB">
					<qry:attribute name="f_trabajo" value="format_date($r/@f_fecha, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_trabajo" value="$r/@o_mensaje"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:switch test="$r/@unid">
						<qry:case value="H">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion,'###0.0')"/>
						</qry:case>
						<qry:case value="M">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion div 60,'###0.0')"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion * 40,'###0.0')"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion * 8,'###0.0')"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total_tarea" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:TRAB
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hs_insumidas_tarea" value="format_number(NUMBER(@hs_insumidas_tarea) + NUMBER($r/@hs_insumidas_trabajo),'###0.0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total_sol" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:TAREA
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hs_insumidas_sol" value="format_number(NUMBER(@hs_insumidas_sol) + NUMBER($r/@hs_insumidas_tarea),'###0.0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:SOL
			</qry:xquery>
			<qry:out>
				<qry:attribute name="total" value="format_number(NUMBER(@total) + NUMBER($r/@hs_insumidas_sol),'###0.0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_tarea_carpetas" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	  pt.oi_tarea,
	  pt.c_tarea,
	  pt.f_inicio,
	  pt.d_tarea,
	  rec.c_recurso
FROM 
	  PRY02_TAREAS AS pt,
   	  PRY05_RECURSOS AS rec,
      PRY04_TRABAJOS AS tra
JOIN         
	  pt.oi_recurso LEFT OUTER rec.oi_recurso,
	  pt.oi_tarea INNER tra.oi_tarea          
	  
WHERE 
	  pt.oi_solicitud = {#PARAM:@oi_solicitud}					
	  AND pt.oi_pry_imputa = {#PARAM:@oi_pry_imputa}

GROUP BY
	  pt.oi_tarea,
	  pt.c_tarea,
	  pt.f_inicio,
	  pt.d_tarea,
	  rec.c_recurso 
	
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TAREA">
					<qry:attribute name="c_tarea" value="$r/@c_tarea"/>
					<qry:attribute name="f_tarea" value="format_date($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:insert-select name="qry_trabajo" doc-path="$r"/>
					<qry:insert-select name="qry_total_tarea" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no">
				<table class="tabla_detail estilo1" style="width:100%; height:100%" cellspacing="0" cellpadding="0">
					<tr>
						<th style="font-size:14px">
							Datos de la Solicitud
						</th>
					</tr>
					<tr>
						<td>
							<div>
								<table style="width:100%" class="tabla_noticia estilo1">
									<tr style="font-size:14px;">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Solicitud:
											</label>
											<xsl:value-of select="concat('  [',@c_solicitud,'] ',@d_solicitud)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Fecha:
											</label>
											<xsl:value-of select="concat('  ',@f_solicitud)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Solicitante:
											</label>
											<xsl:value-of select="concat('  ',@d_solicitante)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Modulo:
											</label>
											<xsl:value-of select="concat('  [',@c_modulo,'] ',@d_modulo)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Estado:
											</label>
											<xsl:value-of select="concat('  ',@d_estado)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Detalle:
											</label>
											<xsl:value-of select="concat('  ',@o_detalle)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Responsable:
											</label>
											<xsl:value-of select="concat('  ',@d_responsable)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Fecha Implementaci&#243;n:
											</label>
											<xsl:value-of select="concat('  ',@f_implementacion)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Horas Insumidas:
											</label>
											<xsl:value-of select="concat('  ',@hs_insumidas_sol)"/>
										</td>
									</tr>
									<tr style="font-size:14px">
										<td style="padding-left:15px; padding-top:5px">
											<label style="font-weight:bold">
												Observaciones:
											</label>
											<xsl:value-of select="concat('  ',@o_observaciones)"/>
										</td>
									</tr>
									<tr style="font-size:14px;">
										<td style="padding-left:15px; padding-top:15px">
											<label style="font-weight:bold">
												Datos de las Tareas
											</label>
										</td>
									</tr>
									<tr>
										<td style="padding-left:10px; padding-right:10px">
											<table class="tabla_noticia estilo1" style="width:100%; font-size:12px; text-align:center" cellspacing="0" cellpadding="0">
												<tr>
													<th style="width:15%; padding-left:0; text-align:center">
														Proyecto
													</th>
													<th style="width:15%; padding-left:0; text-align:center">
														Tarea
													</th>
													<th style="width:10%; padding-left:0; text-align:center">
														Estado
													</th>
													<th style="width:5%; padding-left:0; text-align:center">
														Trabajos
													</th>
													<th style="width:5%; padding-left:0; text-align:center">
														Fecha
													</th>
													<th style="width:10%; padding-left:0; text-align:center">
														Responsable
													</th>
													<th style="width:35%; padding-left:0; text-align:center">
														Detalle
													</th>
													<th style="width:5%; padding-left:0; text-align:center">
														Hs Insumidas
													</th>
												</tr>
												<xsl:if test="TAREA">
													<xsl:for-each select="TAREA">
														<tr style="font-weight:bold; padding-top:7px; padding-bottom:7px">
															<td class="underline">
																<xsl:value-of select="./@c_proyecto"/>
															</td>
															<td class="underline">
																<xsl:value-of select="./@c_tarea"/>
															</td>
															<td class="underline">
																<xsl:value-of select="./@d_estado"/>
															</td>
															<td class="underline">
																&#160;
															</td>
															<td class="underline">
																<xsl:value-of select="./@f_tarea"/>
															</td>
															<td class="underline">
																<xsl:value-of select="./@d_responsable"/>
															</td>
															<td class="underline">
																<xsl:value-of select="./@d_tarea"/>
															</td>
															<td class="underline">
																<xsl:if test="./@hs_insumidas_tarea">
																	<xsl:value-of select="./@hs_insumidas_tarea"/>
																</xsl:if>
																<xsl:if test="not(./@hs_insumidas_tarea)">
																	&#160;
																</xsl:if>
															</td>
														</tr>
														<xsl:for-each select="TRAB">
															<tr style="padding-top:7px; padding-bottom:7px">
																<td class="underline">
																	&#160;
																</td>
																<td class="underline">
																	&#160;
																</td>
																<td class="underline">
																	&#160;
																</td>
																<td class="underline">
																	<center>
																		<img width="16px">
																			<xsl:attribute name="src">
																				<xsl:value-of select="'data:image/png;base64,'"/>
																			</xsl:attribute>
																		</img>
																	</center>
																</td>
																<td class="underline">
																	<xsl:value-of select="./@f_trabajo"/>
																</td>
																<td class="underline">
																	<xsl:value-of select="./@d_responsable"/>
																</td>
																<td class="underline">
																	<xsl:value-of select="./@d_trabajo"/>
																</td>
																<td class="underline">
																	<xsl:value-of select="./@hs_insumidas_trabajo"/>
																</td>
															</tr>
														</xsl:for-each>
													</xsl:for-each>
												</xsl:if>
												<xsl:if test="not(TAREA)">
													<tr style="font-size:12px">
														<td class="underline" style="padding-bottom:15px; padding-top:15px; color:#808080" colspan="9">
															<xsl:value-of select="'No se encontraron tareas asignadas a esta solicitud.'"/>
														</td>
													</tr>
												</xsl:if>
											</table>
										</td>
									</tr>
								</table>
							</div>
						</td>
					</tr>
				</table>
			</body>
		</xsl:template>
	</html:xslt>
</html:html>
