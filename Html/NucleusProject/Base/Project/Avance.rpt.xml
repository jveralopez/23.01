<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusProject.Base.Project.Avance" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;DATA oi_avance=&quot;1206&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT style="width:100%" label="Avance">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP style="width:100%" type="title" tag="AVANCE">
						<COLS>
							<COL style="width:30%; font-size:14px" label="Proyecto"/>
							<COL label="Proyecto" name="proyecto"/>
							<COL label="Cliente" name="d_nom_cliente"/>
							<COL label="L&#237;der de Proyecto" name="lider"/>
						</COLS>
						<GROUP type="title" tag="DETALLE_PROY">
							<COLS>
								<COL style="width:30%; font-size:14px" label="Detalles del Proyecto"/>
								<COL style="width:30%" label="Fecha de Inicio-Fin" name="f_inicio_fin"/>
								<COL style="width:30%" label="Fecha de Inicio-Fin Estimada" name="f_inicio_fin_est"/>
								<COL style="width:30%" label="Tiempo Estimado (en Hs.)" name="e_estimado" type="num"/>
								<COL style="width:30%" label="Tiempo Imputado (en Hs.)" name="e_imputado" type="num"/>
								<COL style="width:30%" label="Duraci&#243;n Estimada (en Meses)" name="e_duracion" type="num"/>
							</COLS>
						</GROUP>
						<GROUP type="title" tag="DETALLE_AVANCE">
							<COLS>
								<COL style="width:30%; font-size:14px" label="Avance"/>
								<COL style="width:30%" label="Creador" name="creador"/>
								<COL style="width:30%" label="Fecha de Creaci&#243;n" name="f_avance"/>
								<COL style="width:30%" label="Estado del Proyecto" name="d_estado"/>
								<COL style="width:700px; height: 40px" label="Descripci&#243;n" name="o_avance"/>
							</COLS>
						</GROUP>
						<GROUP type="title" tag="DETALLE_AVANCE">
							<COLS>
								<COL style="width:30%; font-size:14px" label="Detalle del Avance"/>
								<COL style="width:700px; height: 60px" label="Requerimientos Finalizados" name="o_req_finalizados"/>
								<COL style="width:700px; height: 60px" label="Requerimientos en Proceso" name="o_req_proceso"/>
								<COL style="width:700px; height: 60px" label="Requerimientos Faltantes" name="o_req_faltantes"/>
								<COL style="width:700px; height: 60px" label="Estado Frente a lo Planificado" name="o_estado_planif"/>
								<COL style="width:700px; height: 60px" label="Porcentaje de Avance" name="o_porc_avance"/>
								<COL style="width:700px; height: 60px" label="Identificaci&#243;n de Riesgos" name="o_iden_riesgos"/>
								<COL style="width:700px; height: 60px" label="Pasos a Seguir" name="o_pasos_seguir"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<qry:insert-select name="qryAvance" doc-path="$SOURCE/DATA"/>
				</DATA>
			</REPORT>
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:attribute name="hoy" value="format-date(Now(),'dd/mm/yyyy')"/>
					<qry:attribute value="#SOURCE:DATA/@oi_avance" name="oi_avance"/>
					<qry:insert-select doc-path="." name="qryAvance"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="SOURCE" name="qryAvance">
			<qry:xquery>
				for $r in SQL(' 
SELECT
	a.oi_avance,
	a.oi_proyecto,
	a.oi_cliente,
	a.oi_recurso_asig,
	a.f_inicio,
	a.f_fin,
	a.f_inicio_est,
	a.f_fin_est,
	a.e_estimado,
	a.e_imputado,
	a.e_duracion,
	a.f_avance,
	a.c_estado,
	a.o_avance,
	a.oi_recurso,
	a.o_req_finalizados,
	a.o_req_proceso,
	a.o_req_faltantes,
	a.o_estado_planif,
	a.o_porc_avance,
	a.o_iden_riesgos,
	a.o_pasos_seguir,
	PER01_PERSONAL.d_ape_y_nom,
	PERASIG.d_ape_y_nom as lider_apeynom,
	PRY08_CLIENTES.d_nom_cliente,
	PRY01_PROYECTOS.c_proyecto,
	PRY01_PROYECTOS.d_proyecto
		
FROM
PRY01_AVANCES as a,
PRY05_RECURSOS,
PER01_PERSONAL,
PRY05_RECURSOS as RECASIG,
PER01_PERSONAL as PERASIG,
PRY08_CLIENTES,
PRY01_PROYECTOS

JOIN
a.oi_recurso LEFT OUTER PRY05_RECURSOS.oi_recurso,
PRY05_RECURSOS.oi_personal LEFT OUTER PER01_PERSONAL.oi_personal,
a.oi_recurso_asig LEFT OUTER RECASIG.oi_recurso,
RECASIG.oi_personal LEFT OUTER PERASIG.oi_personal,
a.oi_cliente LEFT OUTER PRY08_CLIENTES.oi_cliente,
a.oi_proyecto LEFT OUTER PRY01_PROYECTOS.oi_proyecto 


WHERE   
a.oi_avance={#SOURCE:@oi_avance}


')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="AVANCE">
					<qry:attribute name="oi_avance" value="$r/@oi_avance"/>
					<qry:attribute name="oi_proyecto" value="$r/@oi_proyecto"/>
					<qry:attribute name="id" value="$r/@oi_proyecto"/>
					<qry:attribute value="concat('[',$r/@c_proyecto,'] ',$r/@d_proyecto)" name="proyecto"/>
					<qry:attribute name="lider" value="$r/@lider_apeynom"/>
					<!--Verifica si debe buscar los datos en el avance, o si la informacion esta en el Proyecto-->
					<qry:if test="$r/@oi_recurso_asig!=''">
						<qry:then>
							<qry:attribute name="d_nom_cliente" value="$r/@d_nom_cliente"/>
							<qry:element name="DETALLE_PROY">
								<qry:attribute name="f_inicio_fin" value="concat(format-date($r/@f_inicio,'dd/mm/yyyy'),' - ',format-date($r/@f_fin,'dd/mm/yyyy'))"/>
								<qry:attribute name="f_inicio_fin_est" value="concat(format-date($r/@f_inicio_est,'dd/mm/yyyy'),' - ',format-date($r/@f_fin_est,'dd/mm/yyyy'))"/>
								<qry:attribute name="e_estimado" value="$r/@e_estimado"/>
								<qry:attribute name="e_duracion" value="$r/@e_duracion"/>
								<qry:attribute name="e_imputado" value="$r/@e_imputado"/>
							</qry:element>
						</qry:then>
						<qry:else>
							<qry:insert-select name="qryProyecto" doc-path="."/>
						</qry:else>
					</qry:if>
					<qry:element name="DETALLE_AVANCE">
						<qry:attribute name="creador" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="f_avance" value="format-date($r/@f_avance,'dd/mm/yyyy')"/>
						<qry:switch test="$r/@c_estado">
							<qry:case value="V">
								<qry:attribute name="d_estado" value="'Verde'"/>
							</qry:case>
							<qry:case value="A">
								<qry:attribute name="d_estado" value="'Amarillo'"/>
							</qry:case>
							<qry:case value="R">
								<qry:attribute name="d_estado" value="'Rojo'"/>
							</qry:case>
							<qry:default/>
						</qry:switch>
						<qry:attribute name="o_avance" value="$r/@o_avance"/>
						<qry:attribute name="oi_recurso" value="$r/@oi_recurso"/>
						<qry:attribute name="o_req_finalizados" value="$r/@o_req_finalizados"/>
						<qry:attribute name="o_req_proceso" value="$r/@o_req_proceso"/>
						<qry:attribute name="o_req_faltantes" value="$r/@o_req_faltantes"/>
						<qry:attribute name="o_estado_planif" value="$r/@o_estado_planif"/>
						<qry:attribute name="o_porc_avance" value="$r/@o_porc_avance"/>
						<qry:attribute name="o_iden_riesgos" value="$r/@o_iden_riesgos"/>
						<qry:attribute name="o_pasos_seguir" value="$r/@o_pasos_seguir"/>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qryProyecto" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
			SELECT
			PRY01_PROYECTOS.oi_proyecto,
			PRY01_PROYECTOS.c_proyecto,
			PRY01_PROYECTOS.d_proyecto,
			PRY01_PROYECTOS.oi_recurso,
			PRY01_PROYECTOS.f_inicio,
			PRY01_PROYECTOS.f_fin,
			PRY01_PROYECTOS.f_inicio_est,
			PRY01_PROYECTOS.f_fin_est,
			PRY03_UND_TIEMPO.e_minutos,
			PRY01_PROYECTOS.oi_cliente,
			PRY01_PROYECTOS.e_estimado,
			PRY08_CLIENTES.d_nom_cliente,
			PER01_PERSONAL.d_ape_y_nom
			
			FROM
			PRY01_PROYECTOS,
			PRY03_UND_TIEMPO,
			PRY08_CLIENTES,
			PRY05_RECURSOS,
			PER01_PERSONAL
			
			JOIN
			PRY01_PROYECTOS.oi_unidad_tiempo LEFT OUTER PRY03_UND_TIEMPO.oi_unidad_tiempo,
			PRY01_PROYECTOS.oi_cliente LEFT OUTER PRY08_CLIENTES.oi_cliente,
			PRY01_PROYECTOS.oi_recurso LEFT OUTER PRY05_RECURSOS.oi_recurso,
			PRY05_RECURSOS.oi_personal LEFT OUTER PER01_PERSONAL.oi_personal 
			
			WHERE
			PRY01_PROYECTOS.oi_proyecto={#PARAM:@id} 

			 
			 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="qryCliente" doc-path="$r"/>
				<qry:if test="@oi_cliente=''">
					<qry:then>
						<qry:attribute name="d_nom_cliente" value="$r/@d_nom_cliente"/>
					</qry:then>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qryCliente" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
	pc.oi_cliente AS oi_cliente,
	pc.d_nom_cliente AS d_nom_cliente,
	pp.oi_proyecto_parent AS oi_proyecto,
	pp.oi_tipo_proyecto AS oi_tipo_proyecto

FROM 
	PRY01_PROYECTOS AS pp, 
    PRY08_CLIENTES AS pc
JOIN

	pp.oi_cliente LEFT OUTER pc.oi_cliente 

WHERE
	pp.oi_proyecto = {#PARAM:@oi_proyecto}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@oi_tipo_proyecto!='6' AND $r/@oi_proyecto!=''">
					<qry:then>
						<qry:insert-select name="qryCliente" doc-path="$r"/>
					</qry:then>
					<qry:else>
						<qry:if test="$r/@oi_tipo_proyecto='6'">
							<qry:then>
								<qry:attribute value="$r/@oi_cliente" name="oi_cliente"/>
								<qry:attribute value="$r/@d_nom_cliente" name="d_nom_cliente"/>
							</qry:then>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
