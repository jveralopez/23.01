<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusProject.Base.Project.PizarraScrumTarea.rpt" extends="NucleusRH.Base.Configuracion.GadgetBASE.rpt" doc="source">
	<html:query declare="&lt;PARAMS recurso=&quot;T&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:attribute name="hoy_mostrar" value="format-date(Now(),'dd/mm/yy')"/>
					<qry:attribute name="cant_tareas" value="0"/>
					<qry:attribute name="cant_vencidas" value="0"/>
					<qry:attribute name="cant_pendiente" value="0"/>
					<qry:attribute name="cant_trabajando" value="0"/>
					<qry:attribute name="cant_testing" value="0"/>
					<qry:attribute name="cant_finalizada" value="0"/>
					<qry:if test="#SOURCE:PARAMS/@oi_proyecto!=''">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_tareas"/>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_tareas_finalizadas"/>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_proyectos_hijos"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_tareas"/>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_tareas_finalizadas"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_tareas">
			<qry:xquery>
				for $r in sql('	
						
					SELECT 
						t.oi_tarea,
						t.c_tarea,
  						t.d_tarea,
  			    		t.f_inicio,
  						t.f_fin_est,
  			    		p.c_proyecto,
  			    		p.oi_proyecto,
  			    		p.d_proyecto,
  			    		t.c_estado,
  			    		p.c_color
  					
					FROM 
						PRY02_TAREAS as t,
						PRY05_RECURSOS as re,
	         			PER01_PERSONAL as pe,                  
	         			PRY01_PROYECTOS as p
	     
					
					JOIN 
				  	t.oi_recurso INNER re.oi_recurso,
		        	re.oi_personal INNER pe.oi_personal,
		        	t.oi_proyecto INNER p.oi_proyecto
					
			                 WHERE 
			                 (c_estado=\'T\' OR c_estado=\'D\' OR c_estado=\'I\')
			                 
			                 {%?(#SOURCE:@recurso = 'A') {%AND pe.oi_usuario_sistema={$PROXY/@etty} %} {% %} %}
                             
                             {%? (#SOURCE:@oi_proyecto!='') {% AND t.oi_proyecto = {#SOURCE:@oi_proyecto}  %} {%  %} %} 
			                 {%? (#SOURCE:@oi_recurso!='') {% AND t.oi_recurso = {#SOURCE:@oi_recurso}  %} {%  %} %}
             	             {%? (#SOURCE:@fecha_desde!='') {% AND t.f_inicio &gt;= {#SOURCE:@fecha_desde}  %} {%  %} %}
             	             {%? (#SOURCE:@fecha_hasta!='') {% AND t.f_inicio &lt;= {#SOURCE:@fecha_hasta}  %} {%  %} %} 
			                 
			                  
			                
			        
			                 
             	
             	
  				ORDER BY f_fin_est ASC
  					
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_tareas" value="number(@cant_tareas)+1"/>
				<qry:if test="$r/@f_fin_est!='' AND $r/@f_fin_est &lt;=  Now()">
					<qry:then>
						<qry:attribute name="cant_vencidas" value="number(@cant_vencidas)+1"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="cant_vencidas" value="number(@cant_vencidas)+0"/>
					</qry:else>
				</qry:if>
				<qry:switch test="$r/@c_estado">
					<qry:case value="D">
						<qry:attribute name="cant_testing" value="number(@cant_testing)+1"/>
					</qry:case>
					<qry:case value="T">
						<qry:attribute name="cant_trabajando" value="number(@cant_trabajando)+1"/>
					</qry:case>
					<qry:case value="I">
						<qry:attribute name="cant_pendiente" value="number(@cant_pendiente)+1"/>
					</qry:case>
					<qry:default/>
				</qry:switch>
				<qry:element name="TAREA">
					<qry:attribute name="oi_tarea" value="$r/@oi_tarea"/>
					<qry:insert-select doc-path="$r" name="qry_foto"/>
					<qry:insert-select doc-path="$r" name="qry_color"/>
					<qry:attribute name="d_tarea" value="'[' + $r/@c_tarea + '] ' + $r/@d_tarea"/>
					<qry:attribute name="f_inicio" value="format-date($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_proyecto" value="'[' + $r/@c_proyecto + '] ' + $r/@d_proyecto"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="D">
							<qry:attribute name="c_estado" value="'Testing'"/>
						</qry:case>
						<qry:case value="T">
							<qry:attribute name="c_estado" value="'Trabajando'"/>
						</qry:case>
						<qry:case value="I">
							<qry:attribute name="c_estado" value="'Pendiente'"/>
						</qry:case>
						<qry:default/>
					</qry:switch>
					<qry:if test="$r/@f_fin_est!='' AND $r/@f_fin_est &lt;=  Now()">
						<qry:then>
							<qry:attribute name="vencida" value="'Si'"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="vencida" value="'No'"/>
						</qry:else>
					</qry:if>
					<qry:if test="$r/@f_fin_est!=''">
						<qry:then>
							<qry:attribute name="f_fin_est" value="format-date($r/@f_fin_est, 'dd/mm/yyyy')"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="f_fin_est" value="'SIN FECHA'"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_tareas_finalizadas">
			<qry:xquery>
				for $r in sql('	
				MAXSIZE 10		
					SELECT 
						t.oi_tarea,
						t.c_tarea,
  						t.d_tarea,
  			    		t.f_inicio,
  						t.f_fin,
  						p.c_color,
  						p.oi_proyecto,
  			    		p.c_proyecto,
  			    		p.d_proyecto,
  			    		t.c_estado
					FROM 
						PRY02_TAREAS as t,
						PRY05_RECURSOS as re,
	         			PER01_PERSONAL as pe,
	         			PRY01_PROYECTOS as p
	     
					
					JOIN 
				  	t.oi_recurso INNER re.oi_recurso,
		        	re.oi_personal INNER pe.oi_personal,
		        	t.oi_proyecto INNER p.oi_proyecto
					
			                 WHERE 
			                  c_estado=\'F\'
			                  
			                  {%?(#SOURCE:@recurso = 'A') {%AND pe.oi_usuario_sistema={$PROXY/@etty} %} {% %} %}
                             
                             {%? (#SOURCE:@oi_proyecto!='') {% AND t.oi_proyecto = {#SOURCE:@oi_proyecto}  %} {%  %} %} 
			                 {%? (#SOURCE:@oi_recurso!='') {% AND t.oi_recurso = {#SOURCE:@oi_recurso}  %} {%  %} %}
             	             {%? (#SOURCE:@fecha_desde!='') {% AND t.f_inicio &gt;= {#SOURCE:@fecha_desde}  %} {%  %} %}
             	             {%? (#SOURCE:@fecha_hasta!='') {% AND t.f_inicio &lt;= {#SOURCE:@fecha_hasta}  %} {%  %} %} 
			           
			                   
			                 
			                       
			                 
			                        

  				ORDER BY f_fin DESC
  				
  				
  					
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_finalizada" value="number(@cant_finalizada)+1"/>
				<qry:element name="TAREA">
					<qry:attribute name="oi_tarea" value="$r/@oi_tarea"/>
					<qry:insert-select doc-path="$r" name="qry_foto"/>
					<qry:insert-select doc-path="$r" name="qry_color"/>
					<qry:attribute name="d_tarea" value="'[' + $r/@c_tarea + '] ' + $r/@d_tarea"/>
					<qry:attribute name="f_inicio" value="format-date($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_proyecto" value="'[' + $r/@c_proyecto + '] ' + $r/@d_proyecto"/>
					<qry:if test="$r/@f_fin!=''">
						<qry:then>
							<qry:attribute name="f_fin" value="format-date($r/@f_fin, 'dd/mm/yyyy')"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="f_fin" value="'SIN FECHA'"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="c_estado" value="'Finalizada'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_foto" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			
			SELECT 
						pe.oi_foto
  					
					FROM 
						PRY02_TAREAS as t,
						PRY05_RECURSOS as re,
	         			PER01_PERSONAL as pe                  
	         			
	     
					
					JOIN 
				  	t.oi_recurso INNER re.oi_recurso,
		        	re.oi_personal INNER pe.oi_personal
		        	
					
			                 WHERE
			                 t.oi_tarea={$SOURCE/@oi_tarea}
			                
			        
			
			
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_foto" value="$r/@oi_foto"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_proyectos_hijos" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			
				 	SELECT 
						p.oi_proyecto
  					
					FROM 
	         			PRY01_PROYECTOS as p                  
	         			
	                WHERE
			            p.oi_proyecto_parent={#SOURCE:@oi_proyecto}
			                
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="recurso" value="#SOURCE:@recurso"/>
				<qry:attribute name="oi_proyecto" value="$r/@oi_proyecto"/>
				<qry:attribute name="oi_recurso" value="#SOURCE:@oi_recurso"/>
				<qry:attribute name="fecha_desde" value="#SOURCE:@fecha_desde"/>
				<qry:attribute name="fecha_hasta" value="#SOURCE:@fecha_hasta"/>
				<qry:insert-select doc-path="." name="qry_tareas"/>
				<qry:insert-select doc-path="." name="qry_tareas_finalizadas"/>
				<qry:insert-select doc-path="." name="qry_proyectos_hijos"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_color" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
	pp.oi_proyecto_parent AS oi_proyecto,
	pp.oi_tipo_proyecto AS oi_tipo_proyecto,
	pp.c_color

FROM 
	PRY01_PROYECTOS AS pp
WHERE
	pp.oi_proyecto = {#PARAM:@oi_proyecto}   
	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@oi_tipo_proyecto!='1' AND $r/@oi_proyecto!=''">
					<qry:then>
						<qry:insert-select name="qry_color" doc-path="$r"/>
					</qry:then>
					<qry:else>
						<qry:if test="$r/@oi_tipo_proyecto='1'">
							<qry:then>
								<qry:attribute value="$r/@c_color" name="c_color"/>
							</qry:then>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no">
				<table class="tabla_detail estilo1" cellspacing="0" cellpadding="0">
					<tr>
						<th>
							<xsl:value-of select="concat('Pizarra Scrum de Mis Tareas al  ',./@hoy_mostrar,':    ',./@cant_vencidas,' vencidas de ',./@cant_tareas,' sin finalizar')"/>
						</th>
					</tr>
					<tr>
						<td>
							<div>
								<table style="width:100%;font-size: 11px;" class="tabla_noticia estilo1">
									<tr>
										<td style="width:25%; vertical-align: top;">
											<table class="tabla_noticia estilo1" style="border-collapse:collapse;">
												<tr>
													<th style="width:25%;">
														<xsl:value-of select="concat('Pendiente [',@cant_pendiente,']')"/>
													</th>
												</tr>
												<xsl:for-each select="TAREA[@c_estado='Pendiente']">
													<xsl:if test="@f_fin_est != 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
												<xsl:for-each select="TAREA[@c_estado='Pendiente']">
													<xsl:if test="@f_fin_est = 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
											</table>
										</td>
										<td style="width:25%; vertical-align: top;">
											<table class="tabla_noticia estilo1" style="border-collapse:collapse;">
												<tr>
													<th style="width:25%;">
														<xsl:value-of select="concat('Trabajando [',@cant_trabajando,']')"/>
													</th>
												</tr>
												<xsl:for-each select="TAREA[@c_estado='Trabajando']">
													<xsl:if test="@f_fin_est != 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
												<xsl:for-each select="TAREA[@c_estado='Trabajando']">
													<xsl:if test="@f_fin_est = 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
											</table>
										</td>
										<td style="width:25%; vertical-align: top;">
											<table class="tabla_noticia estilo1" style="border-collapse:collapse;">
												<tr>
													<th style="width:25%;">
														<xsl:value-of select="concat('Testing [',@cant_testing,']')"/>
													</th>
												</tr>
												<xsl:for-each select="TAREA[@c_estado='Testing']">
													<xsl:if test="@f_fin_est != 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
												<xsl:for-each select="TAREA[@c_estado='Testing']">
													<xsl:if test="@f_fin_est = 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
											</table>
										</td>
										<td style="width:25%; vertical-align: top;">
											<table class="tabla_noticia estilo1" style="border-collapse:collapse;">
												<tr>
													<th style="width:25%;">
														<xsl:value-of select="concat('Finalizada [',@cant_finalizada,']')"/>
													</th>
												</tr>
												<xsl:for-each select="TAREA[@c_estado='Finalizada']">
													<xsl:if test="@f_fin != 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
												<xsl:for-each select="TAREA[@c_estado='Finalizada']">
													<xsl:if test="@f_fin = 'SIN FECHA'">
														<tr>
															<td class="underline" height="55px">
																<xsl:call-template name="ContenidoDiv"/>
															</td>
														</tr>
													</xsl:if>
												</xsl:for-each>
											</table>
										</td>
									</tr>
								</table>
							</div>
						</td>
					</tr>
				</table>
			</body>
		</xsl:template>
		<xsl:template name="ReportSCRIPT">
			function Detail(poiTarea) {
				var dir;

				dir = "ReportViewer.aspx?";
				dir = dir + "report={#PROXY.APP#}.NucleusProject.Base.Project.Tarea.GEN.GADGET";
				dir = dir + "{#CHAR.AMP#}oi_tarea=" + poiTarea;
                
				window.open(dir, 'Buscador', 'width=500,height=350,resizable=yes');
			}
		</xsl:template>
		<xsl:template name="ContenidoDiv">
			<xsl:if test="@oi_foto">
				<xsl:attribute name="style">
					<xsl:value-of select="concat('background-image:url(data:image/jpg;base64,(#IMAGE.DB(x22;NucleusRH.Base.Personal.Imagenes.HEAD;', @oi_foto, ')#));','background-repeat:no-repeat; background-position:100% 60%; background-color:',@c_color)"/>
				</xsl:attribute>
			</xsl:if>
			<xsl:if test="not(@oi_foto)">
				<xsl:attribute name="style">
					<xsl:value-of select="concat('background-image:url(data:image/jpg;base64,); background-position:100% 60%; background-repeat:no-repeat; background-color:',@c_color)"/>
				</xsl:attribute>
			</xsl:if>
			<p style="margin-right:30px;">
				<a>
					<xsl:if test="@vencida = 'Si'">
						<xsl:attribute name="style">
							<xsl:value-of select="'color:#FF3E30'"/>
						</xsl:attribute>
					</xsl:if>
					<xsl:attribute name="href">
						<xsl:value-of select="concat('javascript:Detail(',@oi_tarea, ')')"/>
					</xsl:attribute>
					<xsl:value-of select="@d_tarea"/>
				</a>
			</p>
		</xsl:template>
	</html:xslt>
</html:html>
