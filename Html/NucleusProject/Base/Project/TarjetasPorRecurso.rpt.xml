<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusProject.Base.Project.TarjetasPorRecurso.rpt" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query>
		<qry:main doc="SOURCE">
			<REPORT label="Tarjetas por Usuario" style="font-size:15pt;">
				<qry:attribute name="date" value="#SOURCE:DATOS/@fecha"/>
				<GROUPS>
					<GROUP tag="DATOS" type="title_sinespacios">
						<GROUP tag="MIEMBRO" type="title_sinespacios">
							<COLS>
								<COL name="nombre" label="Miembro" style="font-size:11pt;"/>
							</COLS>
							<GROUP tag="TABLERO" type="title_sinespacios">
								<COLS>
									<COL name="nombre" label="Tablero" style="font-size:11pt;"/>
								</COLS>
								<GROUP tag="COLUMNA" type="title_sinespacios">
									<COLS>
										<COL name="nombre" label="Columna" style="font-size:11pt;"/>
									</COLS>
									<GROUP tag="TARJETA" type="table">
										<COLS>
											<COL name="nombre" label="Tarjeta" style=""/>
											<COL name="desc" label="Descripci&#243;n" style=""/>
											<COL name="usuario" label="Miembros" style=""/>
											<COL name="labels" label="Etiquetas" style=""/>
											<COL name="f_vto" label="Fecha Vencimiento" style=""/>
											<qry:if test="#SOURCE:DATOS/@archivadas='1'">
												<qry:then>
													<COL name="archivada" label="&#191;Archivada?" style="">
														<OPT value="No" id="0"/>
														<OPT value="Si" id="1"/>
													</COL>
												</qry:then>
											</qry:if>
										</COLS>
									</GROUP>
								</GROUP>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-element doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</REPORT>
		</qry:main>
	</html:query>
