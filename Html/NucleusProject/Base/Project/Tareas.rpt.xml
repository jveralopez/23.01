<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="Nomad.Base.BaseReport.rpt" xtends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Liquidacion.ListadoConcepto">
	<html:query declare="&lt;DATA f_desde=&quot;20080301&quot; f_hasta=&quot;20090401&quot; recurso=&quot;7&quot; l_incluir_paralela=&quot;0&quot; l_incluir_fina=&quot;0&quot; l_agruparProyecto=&quot;0&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Recursos" style="width:90%;">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="REP" style="padding-left:0px" type="title" noreg="No se encontraron registros para los filtros seleccionados.">
						<COLS>
							<COL name="d_ape_y_nom" label="Apellido y Nombre" align="left" style=""/>
						</COLS>
						<qry:insert-select doc-path="#SOURCE:.[@l_agruparProyecto=1]" name="ELEMENTOPROYECTO"/>
						<qry:insert-select doc-path="#SOURCE:.[@l_agruparProyecto=0]" name="ELEMENTOTAREA"/>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:append-doc doc-path="#SOURCE:." name="PARAMIN"/>
					<qry:element name="REP">
						<qry:insert-select name="RECURSOS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="ELEMENTOPROYECTO" doc="SOURCE">
			<qry:out>
				<GROUP tag="PROYECTO" style="padding-left:0px" type="title" noreg="No se encontraron registros para los filtros seleccionados.">
					<COLS>
						<COL name="d_proyecto" label="Proyecto" align="left" style=""/>
					</COLS>
					<qry:insert-select doc-path="#SOURCE:" name="ELEMENTOTAREA"/>
				</GROUP>
			</qry:out>
		</qry:select>
		<qry:select name="ELEMENTOTAREA" doc="SOURCE">
			<qry:out>
				<GROUP tag="TAREA" style="padding-left:0px" type="table" noreg="No se encontraron registros para los filtros seleccionados.">
					<COLS>
						<COL name="c_tarea" label="Codigo" align="left" style="width:50px;"/>
						<COL name="d_tarea" label="Tarea" align="left" style="width:200px;"/>
						<!--COL name="f_inicio" label="Fecha Ini." align="left" style="width:50px;"/-->
						<COL name="c_estado" label="Estado" align="right" style="width:80px;">
							<OPT value="Inicializada" id="I"/>
							<OPT value="Asignar Personas" id="AP"/>
							<OPT value="Trabajando" id="T"/>
							<OPT value="Pausada" id="P"/>
							<OPT value="Finalizada" id="F"/>
							<OPT value="Anulada" id="A"/>
							<OPT value="Bloqueada" id="L"/>
						</COL>
						<qry:insert-select doc-path="#SOURCE:.[@l_incluir_paralela=1]" name="Paralela"/>
						<COL name="o_tarea" label="Observaci&#243;n" align="left" style="width:600px;"/>
						<COL name="T1" label="Acciones" align="center" style="width:50px;" type="template"/>
					</COLS>
				</GROUP>
			</qry:out>
		</qry:select>
		<qry:select name="Paralela" doc="">
			<qry:out>
				<COL name="l_simul" label="Paralela" align="right" style="width:50px;">
					<OPT id="0" value="No"/>
					<OPT id="1" value="Si"/>
				</COL>
			</qry:out>
		</qry:select>
		<qry:select name="RECURSOS" doc="">
			<qry:xquery>
				for $r in SQL('select 
	r.oi_recurso,
	r.c_recurso,        
	p.d_ape_y_nom
	
from 
	pry05_recursos as r,
	per01_personal as p
	
join
	r.oi_personal inner p.oi_personal
where 	
	r.oi_recurso= {%=#PARAMIN:@recurso %}
	
order by
	c_recurso ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@oi_recurso" name="oi_recurso"/>
				<qry:attribute value="$r/@c_recurso" name="c_recurso"/>
				<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
				<qry:insert-select doc-path="$r/.[#PARAMIN:@l_agruparProyecto=1]" name="NUEVO"/>
				<qry:insert-select doc-path="$r/.[#PARAMIN:@l_agruparProyecto=0]" name="NUEVOSinProy"/>
				<qry:attribute value="number(@e_time) div 60" name="e_time"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="NUEVO">
			<qry:xquery>
				for $r in SQL('select 	 
	y.c_proyecto, y.d_proyecto, y.oi_proyecto
	 
from 
	
	PRY01_PROYECTOS AS y
	

order by
	c_proyecto ASC
	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<PROYECTO>
					<qry:attribute value="1" name="hts:delete"/>
					<qry:attribute name="d_proyecto" value="$r/@c_proyecto + ' - ' + $r/@d_proyecto"/>
					<qry:attribute value="$r/@oi_proyecto" name="oi_proyecto"/>
					<qry:attribute value="#PARAMIN:@l_incluir_paralela" name="l_incluir_paralela"/>
					<qry:insert-select doc-path=".[@l_incluir_paralela=0]" name="NUEVO1"/>
					<qry:insert-select doc-path=".[@l_incluir_paralela=1]" name="NUEVO2"/>
					<qry:attribute value="number(@e_time) div 60" name="e_time"/>
				</PROYECTO>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="NUEVOSinProy">
			<qry:xquery>
				for $r in SQL('select 	 
	y.c_proyecto, y.d_proyecto, y.oi_proyecto
	 
from 
	
	PRY01_PROYECTOS AS y
	

order by
	c_proyecto ASC
	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<!--qry:attribute value="1" name="hts:delete"/-->
				<qry:attribute name="d_proyecto" value="$r/@c_proyecto + ' - ' + $r/@d_proyecto"/>
				<qry:attribute value="$r/@oi_proyecto" name="oi_proyecto"/>
				<qry:attribute value="#PARAMIN:@l_incluir_paralela" name="l_incluir_paralela"/>
				<qry:insert-select doc-path=".[@l_incluir_paralela=0]" name="NUEVO1"/>
				<qry:insert-select doc-path=".[@l_incluir_paralela=1]" name="NUEVO2"/>
				<qry:attribute value="number(@e_time) div 60" name="e_time"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="NUEVO1">
			<qry:xquery>
				for $r in SQL('select 	
			a.oi_tarea, yCOD.c_proyecto,
			a.c_tarea,
			a.o_tarea,
			a.d_tarea, 
			a.f_inicio, 
			a.c_estado, 
			a.l_simul
from PRY02_TAREAS AS A,
PRY01_PROYECTOS AS y, PRY01_PROYECTOS AS yCOD
JOIN 	A.oi_pry_imputa INNER y.oi_proyecto, A.oi_proyecto INNER yCOD.oi_proyecto 
WHERE	
	A.oi_recurso= {%=#PARAMIN:@recurso %} 
	and y.oi_proyecto= {%=#SOURCE:@oi_proyecto %} 
	{%? (#PARAMIN:@c_estado!='')	{% AND a.c_estado= {#PARAMIN:@c_estado} %} {% %} %}
	{%? (#PARAMIN:@l_incluir_fina!='1')	{% AND a.c_estado not in (\'F\', \'A\', \'L\') %} {% %} %}
	and a.l_simul = 0
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<TAREA>
					<qry:attribute value="$r/@c_proyecto + '-' + $r/@c_tarea" name="c_tarea"/>
					<qry:attribute value="$r/@d_tarea" name="d_tarea"/>
					<qry:attribute value="$r/@o_tarea" name="o_tarea"/>
					<qry:attribute value="format_date($r/@f_inicio,'dd/mm/yyyy')" name="f_inicio"/>
					<qry:attribute value="$r/@c_estado" name="c_estado"/>
					<qry:attribute value="$r/@l_simul" name="l_simul"/>
					<qry:attribute value="$r/@oi_tarea" name="oi_tarea"/>
				</TAREA>
				<qry:attribute value="0" name="hts:delete"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="NUEVO2">
			<qry:xquery>
				for $r in SQL('
SELECT 
	A.oi_tarea, 
	A.c_tarea, 
	A.o_tarea, 
	A.d_tarea, 
	A.f_inicio, 
	A.c_estado, 
	A.l_simul,
	YCOD.c_proyecto
FROM 
	PRY02_TAREAS AS A, 
	PRY01_PROYECTOS AS Y,
	PRY01_PROYECTOS AS YCOD
JOIN 	
	A.oi_pry_imputa INNER Y.oi_proyecto,
	A.oi_proyecto INNER YCOD.oi_proyecto
WHERE 	
	A.oi_recurso= {%=#PARAMIN:@recurso %} 
	and Y.oi_proyecto= {%=#SOURCE:@oi_proyecto %} 
	{%? (#PARAMIN:@c_estado!='')	{% AND A.c_estado= {#PARAMIN:@c_estado} %} {% %} %} 
	{%? (#PARAMIN:@l_incluir_fina!='1')	{% AND A.c_estado not in (\'F\', \'A\', \'L\') %} {% %} %}
UNION

SELECT 
	AA.oi_tarea, 
	AA.c_tarea, 
	AA.o_tarea, 
	AA.d_tarea, 
	AA.f_inicio, 
	AA.c_estado, 
	AA.l_simul,
	YYCOD.c_proyecto
FROM 
	PRY02_TAREAS AS AA, 
	PRY01_PROYECTOS AS YY,
	PRY01_PROYECTOS AS YYCOD
JOIN 	
	AA.oi_pry_imputa INNER YY.oi_proyecto,
	AA.oi_proyecto INNER YYCOD.oi_proyecto
	
WHERE 	
	AA.oi_recurso != {%=#PARAMIN:@recurso %}
	and AA.oi_tarea in (SELECT pp.oi_tarea FROM PRY02_TAREAS_REC AS PP WHERE PP.oi_recurso = {%=#PARAMIN:@recurso %})
	and YY.oi_proyecto= {%=#SOURCE:@oi_proyecto %} 
	{%? (#PARAMIN:@c_estado!='')	{% AND AA.c_estado= {#PARAMIN:@c_estado} %} {% %} %}    
	{%? (#PARAMIN:@l_incluir_fina!='1')	{% AND AA.c_estado not in (\'F\', \'A\', \'L\') %} {% %} %}
	and aa.l_simul = 1
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<TAREA>
					<qry:attribute value="$r/@c_proyecto + '-' + $r/@c_tarea" name="c_tarea"/>
					<qry:attribute value="$r/@d_tarea" name="d_tarea"/>
					<qry:attribute value="$r/@o_tarea" name="o_tarea"/>
					<qry:attribute value="format_date($r/@f_inicio,'dd/mm/yyyy')" name="f_inicio"/>
					<qry:attribute value="$r/@c_estado" name="c_estado"/>
					<qry:attribute value="$r/@l_simul" name="l_simul"/>
					<qry:attribute value="$r/@oi_tarea" name="oi_tarea"/>
				</TAREA>
				<qry:attribute value="0" name="hts:delete"/>
			</qry:out>
		</qry:select>
	</html:query>
