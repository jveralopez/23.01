					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$source/@c_estado='P'">
				<xsl:call-template name="DETENIDA">
					<xsl:with-param name="source" select="$source"/>
