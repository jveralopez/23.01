			<xsl:param name="template"/>
			<xsl:param name="source"/>
			<xsl:if test="$template='T1'">
				<xsl:call-template name="T1">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template=''">
				pepe
			</xsl:if>
		</xsl:template>
		<xsl:template name="T1">
