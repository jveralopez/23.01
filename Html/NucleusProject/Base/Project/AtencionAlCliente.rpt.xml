<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusProject.Base.Project.AtencionAlCliente.rpt" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;DATOS f_desde=&quot;20100101&quot; f_hasta=&quot;20131230&quot; oi_cliente=&quot;1&quot; IDs=&quot;IN(1)&quot;&gt; &lt;ROWS /&gt;&lt;/DATOS&gt; &#13;&#10;&#13;&#10;">
		<qry:main doc="SOURCE">
			<qry:element name="DATOS">
				<qry:element name="CLIENTE">
					<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATOS"/>
					<qry:attribute name="f_desde" value="format_date($PARAMIN/@f_desde,'dd/mm/yyyy')"/>
					<qry:attribute name="f_hasta" value="format_date($PARAMIN/@f_hasta,'dd/mm/yyyy')"/>
					<qry:attribute name="clasificacion" value="$PARAMIN/@clasificacion"/>
					<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_cliente"/>
					<qry:element name="CREADAS">
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_creadas"/>
					</qry:element>
					<qry:element name="CERRADAS">
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_cerradas"/>
					</qry:element>
					<qry:element name="PENDIENTES">
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_pendientes"/>
					</qry:element>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_cliente">
			<qry:xquery>
				for $r in sql('
SELECT 
 	cli.d_nom_cliente
FROM 
	PRY08_CLIENTES as cli
WHERE 
	cli.oi_cliente = {#PARAM:@oi_cliente}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="nom_cliente" value="$r/@d_nom_cliente"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_creadas">
			<qry:xquery>
				for $r in sql('		
SELECT 
	sol.oi_solicitud
	, sol.c_solicitud 
	, sol.d_solicitud 
	, clasif.c_clasificacion
	, clasif.d_clasificacion 
	, cont.d_nom_y_ape
	, sol.f_solicitud
	, sol.c_estado 
	, sol.f_estim_implem
	, rec.c_recurso 

FROM 

    PRY05_RECURSOS AS rec
	, PRY07_SOLICITUDES AS sol
	, PRY08_CONTACTOS as cont 
	, PRY16_CLASIF as clasif 
JOIN         

	 sol.oi_recurso LEFT OUTER rec.oi_recurso
	, sol.oi_contacto LEFT OUTER cont.oi_contacto
	, sol.oi_clasificacion INNER clasif.oi_clasificacion
WHERE 
	cont.oi_cliente = {#PARAM:@oi_cliente}					
AND
	sol.f_solicitud &gt;= {Datetime(#PARAM:@f_desde)}
AND
	sol.f_solicitud &lt;= {Datetime(#PARAM:@f_hasta)} 
{%? (#PARAM:@IDs!='') {% AND sol.oi_clasificacion {%=#PARAM:@IDs%} %} {%  %} %}

ORDER BY
 	f_solicitud DESC		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_solicitudes" value="number(@cant_solicitudes)+1"/>
				<qry:element name="SOL">
					<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
					<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
					<qry:attribute name="clasificacion" value="'[' + $r/@c_clasificacion + '] ' + $r/@d_clasificacion"/>
					<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
					<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="d_estado" value="'PENDIENTE'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="d_estado" value="'CERRADO'"/>
						</qry:case>
						<qry:case value="6">
							<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
						</qry:case>
						<qry:case value="7">
							<qry:attribute name="d_estado" value="'RECHAZADO'"/>
						</qry:case>
						<qry:case value="8">
							<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
						</qry:case>
						<qry:case value="9">
							<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="f_estim_implem" value="format_date($r/@f_estim_implem, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_cerradas">
			<qry:xquery>
				for $r in sql('		
SELECT 
	sol.oi_solicitud
	, sol.c_solicitud 
	, sol.d_solicitud 
	, clasif.c_clasificacion
	, clasif.d_clasificacion 
	, cont.d_nom_y_ape
	, sol.f_solicitud
	, sol.c_estado
	, sol.f_estado 
	, sol.f_estim_implem
	, rec.c_recurso

FROM 

    PRY05_RECURSOS AS rec
	, PRY07_SOLICITUDES AS sol
	, PRY08_CONTACTOS as cont 
	, PRY16_CLASIF as clasif 
JOIN         

	 sol.oi_recurso LEFT OUTER rec.oi_recurso
	, sol.oi_contacto LEFT OUTER cont.oi_contacto
	, sol.oi_clasificacion INNER clasif.oi_clasificacion
WHERE 
	cont.oi_cliente = {#PARAM:@oi_cliente}					
AND
	sol.f_estado &gt;= {Datetime(#PARAM:@f_desde)}
AND
	sol.f_estado &lt;= {Datetime(#PARAM:@f_hasta)} 
AND 
  (sol.c_estado = 5 OR sol.c_estado = 6) 
{%? (#PARAM:@IDs!='') {% AND sol.oi_clasificacion {%=#PARAM:@IDs%} %} {%  %} %}

ORDER BY
 	f_estado DESC		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_solicitudes" value="number(@cant_solicitudes)+1"/>
				<qry:element name="SOL">
					<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
					<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
					<qry:attribute name="clasificacion" value="'[' + $r/@c_clasificacion + '] ' + $r/@d_clasificacion"/>
					<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
					<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="d_estado" value="'PENDIENTE'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="d_estado" value="'CERRADO'"/>
						</qry:case>
						<qry:case value="6">
							<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
						</qry:case>
						<qry:case value="7">
							<qry:attribute name="d_estado" value="'RECHAZADO'"/>
						</qry:case>
						<qry:case value="8">
							<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
						</qry:case>
						<qry:case value="9">
							<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="f_estado" value="format_date($r/@f_estado, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_estim_implem" value="format_date($r/@f_estim_implem, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_pendientes">
			<qry:xquery>
				for $r in sql('		
SELECT 
	sol.oi_solicitud
	, sol.c_solicitud 
	, sol.d_solicitud 
	, clasif.c_clasificacion
	, clasif.d_clasificacion 
	, cont.d_nom_y_ape
	, sol.f_solicitud
	, sol.c_estado 
	, sol.f_estim_implem
	, rec.c_recurso

FROM 

    PRY05_RECURSOS AS rec
	, PRY07_SOLICITUDES AS sol
	, PRY08_CONTACTOS as cont 
	, PRY16_CLASIF as clasif 
JOIN         

	 sol.oi_recurso LEFT OUTER rec.oi_recurso
	, sol.oi_contacto LEFT OUTER cont.oi_contacto
	, sol.oi_clasificacion INNER clasif.oi_clasificacion
WHERE 
	cont.oi_cliente = {#PARAM:@oi_cliente}					
AND
 sol.c_estado NOT IN (5,6,7)  
{%? (#PARAM:@IDs!='') {% AND sol.oi_clasificacion {%=#PARAM:@IDs%} %} {%  %} %}

ORDER BY
 	f_solicitud DESC				
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_solicitudes" value="number(@cant_solicitudes)+1"/>
				<qry:element name="SOL">
					<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
					<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
					<qry:attribute name="clasificacion" value="'[' + $r/@c_clasificacion + '] ' + $r/@d_clasificacion"/>
					<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
					<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="d_estado" value="'PENDIENTE'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="d_estado" value="'CERRADO'"/>
						</qry:case>
						<qry:case value="6">
							<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
						</qry:case>
						<qry:case value="7">
							<qry:attribute name="d_estado" value="'RECHAZADO'"/>
						</qry:case>
						<qry:case value="8">
							<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
						</qry:case>
						<qry:case value="9">
							<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="f_estim_implem" value="format_date($r/@f_estim_implem, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
	</html:query>
