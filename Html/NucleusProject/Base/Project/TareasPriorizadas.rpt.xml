<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusProject.Base.Project.TareasPriorizadas" extends="Nomad.Base.BaseReport.rpt" xtends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATA oi_recurso=&quot;1&quot; f_desde=&quot;&quot; f_hasta=&quot;&quot; selected=&quot;&quot; l_estado=&quot;1&quot; l_horas_imputadas=&quot;1&quot; l_desc_tarea=&quot;1&quot; l_desc_proy=&quot;1&quot; l_desc_cliente=&quot;1&quot; d_laborales=&quot;1111100111110011110000111100111110011111001111100001110011111001111100111100011111001111100111110011011001111100111110001111001111100111110011111001111100111110001111001111100111110011&quot;&gt;&#13;&#10;&#9;&lt;EST /&gt;&#13;&#10;&lt;/DATA&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTER" doc-path="#SOURCE:DATA"/>
			<qry:append-doc name="ESTADOS" doc-path="."/>
			<REPORT label="Tareas Priorizadas de un Responsable" style="width:90%;">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="TITULO" style="padding-left:1px;width:100%;" type="title" noreg="No se encontraron registros para los filtros seleccionados.">
						<COLS>
							<COL name="oi_recurso" label="Responsable" align="left" style="width:100%;"/>
							<COL name="f_desde" label="Fecha Desde" align="left" style="width:100%;"/>
							<COL name="f_hasta" label="Fecha Hasta" align="left" style="width:100%;"/>
						</COLS>
						<GROUP tag="ROW" style="width:100%" type="hor_table">
							<STYLES>
								<STYLE name="head"/>
								<STYLE name="head_h" style="font-weight:bold;background-color:#BBBBBB;width:120px;text-align:center;"/>
								<STYLE name="head_lg" style="font-weight:bold;background-color:#BBBBBB;width:170px;text-align:center;"/>
								<STYLE name="head_sm" style="font-weight:bold;background-color:#BBBBBB;width:50px;text-align:center;"/>
								<STYLE name="detail" style="text-align:center;font-size:13px;"/>
								<STYLE name="extra" style="border:none;"/>
							</STYLES>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="TITULO">
						<qry:attribute name="cant_tareas" value="0"/>
						<qry:insert-select name="qry_get_estados" doc-path="#SOURCE:DATA/EST"/>
						<qry:append-doc name="TEMP" doc-path="."/>
						<qry:attribute name="limite_plan" value="string-length(#FILTER:@d_laborales)"/>
						<qry:attribute name="acum_hs_tareas" value="0"/>
						<qry:attribute value="format_date(#SOURCE:DATA/@f_desde,'dd/mm/yyyy')" name="f_desde"/>
						<qry:attribute value="format_date(#SOURCE:DATA/@f_hasta,'dd/mm/yyyy')" name="f_hasta"/>
						<qry:insert-select name="qry_recurso" doc-path="#SOURCE:DATA"/>
						<ROW>
							<qry:attribute name="estados" value="#ESTADOS:@estados"/>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Prioridad'" name="value"/>
							</COL>
							<COL>
								<qry:attribute value="'head_lg'" name="class"/>
								<qry:attribute value="'Cliente'" name="value"/>
								<qry:attribute value="2" name="colspan"/>
							</COL>
							<COL>
								<qry:attribute value="'head_lg'" name="class"/>
								<qry:attribute value="'Tarea'" name="value"/>
								<qry:if test="#FILTER:@l_desc_tarea = 1">
									<qry:then>
										<qry:attribute value="2" name="colspan"/>
									</qry:then>
								</qry:if>
							</COL>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Hs. Estimadas'" name="value"/>
							</COL>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Hs. Insumidas'" name="value"/>
								<qry:if test="#FILTER:@l_horas_imputadas != 1">
									<qry:then>
										<qry:attribute value="'display:none;'" name="style"/>
									</qry:then>
								</qry:if>
							</COL>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Hs. Disponibles'" name="value"/>
							</COL>
							<qry:if test="#FILTER:@l_estado = 1">
								<qry:then>
									<COL>
										<qry:attribute value="'head_sm'" name="class"/>
										<qry:attribute value="'Estado'" name="value"/>
									</COL>
								</qry:then>
							</qry:if>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Fecha L&#237;mite'" name="value"/>
							</COL>
							<COL>
								<qry:attribute value="'head_sm'" name="class"/>
								<qry:attribute value="'Fecha Planificada'" name="value"/>
							</COL>
							<qry:if test="#FILTER:@l_desc_proy = 1">
								<qry:then>
									<COL>
										<qry:attribute value="'head_lg'" name="class"/>
										<qry:attribute value="'Proyecto'" name="value"/>
									</COL>
								</qry:then>
							</qry:if>
						</ROW>
						<qry:insert-select name="qry_tareas" doc-path="#SOURCE:DATA"/>
						<qry:if test="@cant_tareas = 0">
							<qry:then>
								<ROW>
									<qry:attribute name="columnas" value="8"/>
									<qry:if test="#FILTER:@l_estado = 1">
										<qry:then>
											<qry:attribute name="columnas" value="number(@columnas) + number(1)"/>
										</qry:then>
									</qry:if>
									<qry:if test="#FILTER:@l_horas_imputadas = 1">
										<qry:then>
											<qry:attribute name="columnas" value="number(@columnas) + number(1)"/>
										</qry:then>
									</qry:if>
									<qry:if test="#FILTER:@l_desc_tarea = 1">
										<qry:then>
											<qry:attribute name="columnas" value="number(@columnas) + number(1)"/>
										</qry:then>
									</qry:if>
									<qry:if test="#FILTER:@l_desc_proy = 1">
										<qry:then>
											<qry:attribute name="columnas" value="number(@columnas) + number(1)"/>
										</qry:then>
									</qry:if>
									<COL>
										<qry:attribute value="'detail'" name="class"/>
										<qry:attribute value="'No hay tareas para el filtro seleccionado'" name="value"/>
										<qry:attribute value="../@columnas" name="colspan"/>
									</COL>
								</ROW>
							</qry:then>
							<qry:else/>
						</qry:if>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="qry_tareas" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
SELECT 
tarea.e_prioridad as prioridad,
tarea.oi_tarea,
tarea.oi_recurso,
tarea.c_tarea,
tarea.d_tarea,
tarea.e_estimado,
tarea.c_estado, 
tarea.f_limite,
tarea.f_inicio,
cliente.c_color,
cliente.c_cliente,
cliente.d_nom_cliente,

proyecto.oi_proyecto_parent,
proyecto.c_proyecto,
proyecto.d_proyecto,
ut.e_minutos
FROM
PRY02_TAREAS as tarea,
PRY08_CLIENTES as cliente,
PRY01_PROYECTOS as proyecto,
PRY03_UND_TIEMPO as ut
JOIN
tarea.oi_proyecto INNER proyecto.oi_proyecto,
tarea.oi_unidad_tiempo INNER ut.oi_unidad_tiempo,
proyecto.oi_cliente LEFT OUTER cliente.oi_cliente

WHERE 
tarea.oi_recurso = {%= #PARAM:@oi_recurso %}
{%? (#PARAM:@f_desde!='')	{% AND tarea.f_inicio &gt;= {#PARAM:@f_desde} %} {% %} %}
{%? (#PARAM:@f_hasta!='')	{% AND tarea.f_inicio &lt;= {#PARAM:@f_hasta} %} {% %} %}
{%? (#ESTADOS:@estados!='')	{% AND tarea.c_estado in ({%=string(#ESTADOS:@estados)%}) %} {% %} %}
ORDER BY
prioridad DESC   	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_tareas" value="@cant_tareas + 1"/>
				<ROW>
					<qry:attribute name="e_estimado" value="$r/@e_estimado"/>
					<qry:attribute name="e_minutos" value="$r/@e_minutos"/>
					<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
					<qry:attribute name="hs_estimadas" value="ceiling(number($r/@e_estimado) * number($r/@e_minutos)) div 60"/>
					<COL>
						<!-- Prioridad -->
						<qry:attribute value="$r/@prioridad" name="value"/>
					</COL>
					<COL>
						<!-- Color -->
						<qry:attribute value="'background-color:'+$r/@c_color+';width:35px;'" name="style"/>
						<qry:attribute value="" name="value"/>
					</COL>
					<COL>
						<!-- Cliente -->
						<qry:if test="$r/@c_cliente != ''">
							<qry:then>
								<qry:attribute name="value" value="iif(#FILTER:@l_desc_cliente = 1,$r/@c_cliente +' - '+ $r/@d_nom_cliente ,$r/@c_cliente)"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="value" value="'Sin cliente asignado'"/>
							</qry:else>
						</qry:if>
					</COL>
					<COL>
						<!-- Codigo Tarea -->
						<qry:attribute name="value" value="$r/@c_tarea"/>
					</COL>
					<qry:if test="#FILTER:@l_desc_tarea = 1">
						<qry:then>
							<COL>
								<!-- Descripcion tarea -->
								<qry:attribute name="value" value="$r/@d_tarea"/>
							</COL>
						</qry:then>
					</qry:if>
					<COL>
						<!-- Hs. Estimadas -->
						<qry:attribute name="value" value="../@hs_estimadas"/>
					</COL>
					<COL>
						<!-- Hs. Insumidas -->
						<qry:append-doc name="TEMP_INSU" doc-path="."/>
						<qry:attribute name="hs_insumidas" value="0"/>
						<qry:insert-select name="qry_trabajos_recurso" doc-path="$r"/>
						<qry:attribute value="@hs_insumidas" name="value"/>
						<qry:if test="#FILTER:@l_horas_imputadas != 1">
							<qry:then>
								<qry:attribute value="'display:none;'" name="style"/>
							</qry:then>
						</qry:if>
					</COL>
					<COL>
						<!-- Horas Disponibles -->
						<qry:append-doc name="TEMP_DISP" doc-path="."/>
						<qry:attribute name="hs_disponibles" value="number(../@hs_estimadas) - number(#TEMP_INSU:@value)"/>
						<qry:attribute value="iif(@hs_disponibles &lt; 0,0,@hs_disponibles)" name="value"/>
					</COL>
					<qry:if test="#FILTER:@l_estado = 1">
						<qry:then>
							<COL>
								<!-- Estado -->
								<qry:switch test="$r/@c_estado">
									<qry:case value="I">
										<qry:attribute name="value" value="'Inicializada'"/>
									</qry:case>
									<qry:case value="T">
										<qry:attribute name="value" value="'Trabajando'"/>
									</qry:case>
									<qry:case value="P">
										<qry:attribute name="value" value="'Pausada'"/>
									</qry:case>
									<qry:case value="F">
										<qry:attribute name="value" value="'Finalizada'"/>
									</qry:case>
									<qry:case value="A">
										<qry:attribute name="value" value="'Anulada'"/>
									</qry:case>
									<qry:case value="D">
										<qry:attribute name="value" value="'Derivada a Testing'"/>
									</qry:case>
									<qry:default>
										<qry:attribute name="value" value="'Estado desconocido'"/>
									</qry:default>
								</qry:switch>
							</COL>
						</qry:then>
						<qry:else/>
					</qry:if>
					<COL>
						<!-- Fecha Limite -->
						<qry:attribute value="iif($r/@f_limite != '',format_date($r/@f_limite,'dd/mm/yyyy'),'-')" name="value"/>
						<qry:if test="$r/@f_limite &lt; now()">
							<qry:then>
								<qry:attribute value="'background-color:#F8D7DA;'" name="style"/>
							</qry:then>
							<qry:else/>
						</qry:if>
					</COL>
					<COL>
						<!-- Fecha Planificada -->
						<qry:insert-select name="qry_fecha_planificada"/>
					</COL>
					<qry:if test="#FILTER:@l_desc_proy = 1">
						<qry:then>
							<COL>
								<!-- Proyecto -->
								<qry:if test="$r/@oi_proyecto_parent != ''">
									<qry:then>
										<qry:insert-select name="qry_padre" doc-path="$r"/>
									</qry:then>
									<qry:else>
										<qry:attribute value="iif(#FILTER:@l_desc_proy = 1,$r/@c_proyecto + '-' + $r/@d_proyecto,$r/@c_proyecto)" name="value"/>
									</qry:else>
								</qry:if>
							</COL>
						</qry:then>
					</qry:if>
				</ROW>
				<!-- Actualiza las horas acumuladas -->
				<qry:attribute name="acum_hs_tareas" value="number(number(@acum_hs_tareas) + number(#TEMP_DISP:@value))"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_padre" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
PRY01_PROYECTOS.c_proyecto,
PRY01_PROYECTOS.oi_proyecto_parent,
PRY01_PROYECTOS.d_proyecto,
PRY09_TIPOS_PROYECTO.c_tipo_proyecto
FROM 
PRY01_PROYECTOS,
PRY09_TIPOS_PROYECTO
JOIN
PRY01_PROYECTOS.oi_tipo_proyecto INNER PRY09_TIPOS_PROYECTO.oi_tipo_proyecto
WHERE
PRY01_PROYECTOS.oi_proyecto = {%=#PARAM:@oi_proyecto_parent%}	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@c_tipo_proyecto='PROY'">
					<qry:then>
						<qry:attribute value="iif(#FILTER:@l_desc_proy = 1,$r/@c_proyecto + '-' + $r/@d_proyecto,$r/@c_proyecto)" name="value"/>
					</qry:then>
					<qry:else>
						<qry:if test="$r/@oi_proyecto_parent!=''">
							<qry:then>
								<qry:insert-select name="qry_padre" doc-path="$r"/>
							</qry:then>
							<qry:else/>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_trabajos_recurso" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
pt.e_duracion
, put.e_minutos
FROM 
PRY04_TRABAJOS AS pt
, PRY03_UND_TIEMPO AS put
JOIN
put.oi_unidad_tiempo INNER pt.oi_unidad_tiempo
WHERE
pt.oi_tarea = {#PARAM:@oi_tarea}
and pt.oi_recurso={#PARAM:@oi_recurso}	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="@hs_insumidas + (number($r/@e_duracion) * number($r/@e_minutos)) div 60" name="hs_insumidas"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_recurso" doc="PARAM">
			<qry:xquery>
				for $r in SQL('	
SELECT 
PER01.d_ape_y_nom
FROM 
  PRY05_RECURSOS AS P,
  PER01_PERSONAL AS PER01
JOIN 
P.oi_personal INNER PER01.oi_personal
WHERE
P.oi_recurso = {#PARAM:@oi_recurso}	
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@d_ape_y_nom" name="oi_recurso"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_get_estados" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:C
			</qry:xquery>
			<qry:out>
				<qry:attribute value="iif(@estados='', '\\\''+$r/@id+'\\\'', @estados +', '+ '\\\''+$r/@id+'\\\'')" name="estados"/>
				<qry:append-doc name="ESTADOS" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_fecha_planificada">
			<qry:out>
				<qry:attribute name="puntero" value="0"/>
				<qry:attribute name="acum_dias" value="0"/>
				<qry:attribute name="cant_dias_futuro" value="ceiling(number(number(#TEMP:@acum_hs_tareas) + number(#TEMP_DISP:@value)) div number(8))"/>
				<qry:insert-select name="dia_planificado" doc-path="."/>
				<qry:attribute name="puntero" value="iif(@puntero = 0, 0, number(@puntero) - 1)"/>
				<qry:attribute name="value" value="format_date(DATETIME(now() + number(@puntero)),'dd/mm/yyyy')"/>
			</qry:out>
		</qry:select>
		<qry:select name="dia_planificado" doc="PARAM">
			<qry:out>
				<qry:if test="#PARAM:@acum_dias = #PARAM:@cant_dias_futuro">
					<qry:then/>
					<qry:else>
						<qry:attribute name="laboral" value="substring(#FILTER:@d_laborales,#PARAM:@puntero,1)"/>
						<qry:if test="@laboral = 1">
							<qry:then>
								<qry:attribute name="acum_dias" value="number(#PARAM:@acum_dias) + 1"/>
							</qry:then>
							<qry:else/>
						</qry:if>
						<qry:attribute name="puntero" value="number(#PARAM:@puntero) + 1"/>
						<qry:insert-select name="dia_planificado" doc-path="."/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
