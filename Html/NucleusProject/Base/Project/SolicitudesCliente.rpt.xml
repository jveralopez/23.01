				<body>
					<table class="table_title_style" align="center">
						<tr>
							<td style="text-align:right;">
								<xsl:value-of select="concat('Fecha de Informe: ', ./CLIENTE/@date)"/>
							</td>
						</tr>
					</table>
					<table class="title" align="center">
						<tr>
							<td>
								Horas trabajadas sobre Solicitudes de Clientes
							</td>
						</tr>
					</table>
					<table class="table_title_style" CELLPADDING="0" CELLSPACING="0">
						<tr>
							<td>
								<xsl:value-of select="concat('Cliente: ',./CLIENTE/@nom_cliente)"/>
							</td>
						</tr>
						<tr>
							<td>
								<xsl:value-of select="concat('Fecha Desde: ',./CLIENTE/@f_desde)"/>
							</td>
						</tr>
						<tr>
							<td>
								<xsl:value-of select="concat('Fecha Hasta: ',./CLIENTE/@f_hasta)"/>
							</td>
						</tr>
						<tr>
							<td>
								<xsl:value-of select="concat(concat('Total de horas por convenio: ',./CLIENTE/@horas_totales),' hs')"/>
							</td>
						</tr>
					</table>
					<xsl:for-each select="./CLIENTE/AGRUPA">
						<br/>
						<table class="table_table_style">
							<tr style="font-weight: bold; font-family:verdana; font-size=12px">
								<xsl:value-of select="concat(./@d_agrupa,' (',./@cant_solicitudes,' Solicitud/es)',' Total Hs. Imputadas : ',./@total)"/>
							</tr>
							<xsl:choose>
								<xsl:when test="./@bandera_datos ='si'">
									<tr>
										<th>
											Solicitud
										</th>
										<th>
											Tarea
										</th>
										<th>
											Trabajo
										</th>
										<th>
											Fecha
										</th>
										<th>
											Solicitante
										</th>
										<th>
											Modulo
										</th>
										<th>
											Estado
										</th>
										<th>
											Detalle
										</th>
										<th>
											Responsable
										</th>
										<th>
											Hs. Insumidas
										</th>
										<th>
											Clasificaci&#243;n
										</th>
									</tr>
									<xsl:for-each select="./SOL">
										<tr style="font-weight: bold;">
											<td style="width:8%">
												<xsl:value-of select="./@c_solicitud"/>
											</td>
											<td style="width:7%"/>
											<td style="width:6%"/>
											<td style="width:6%">
