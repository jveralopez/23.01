<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusProject.Base.Project.ImputacionesPorSolicitud.rpt" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;DATOS l_detalle='0' f_desde=&quot;20200519&quot; f_hasta=&quot;20200524&quot;&gt;&lt;ROWS/&gt;&lt;CLIENTES nmd-col=&quot;1&quot;&gt;&lt;CLIENTE id=&quot;2&quot;/&gt;&lt;CLIENTE id=&quot;1&quot;/&gt;&lt;/CLIENTES&gt;&lt;/DATOS&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="DATOS">
				<qry:attribute name="l_detalle" value="#SOURCE:DATOS/@l_detalle"/>
				<qry:element name="CLIENTE">
					<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATOS"/>
					<qry:attribute name="f_desde" value="format_date($PARAMIN/@f_desde,'dd/mm/yyyy')"/>
					<qry:attribute name="f_hasta" value="format_date($PARAMIN/@f_hasta,'dd/mm/yyyy')"/>
					<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_clientes"/>
					<qry:element name="SOPORTE">
						<qry:attribute name="total" value="0"/>
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_soporte"/>
						<qry:insert-select name="qry_total" doc-path="."/>
					</qry:element>
					<qry:element name="IMPUTACIONES">
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:attribute name="total_tarea" value="0"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_tarea_imp"/>
						<qry:if test="@bandera_datos='si'">
							<qry:then>
								<qry:attribute name="total_tarea" value="./TAREA/@total_tarea"/>
							</qry:then>
						</qry:if>
					</qry:element>
					<qry:element name="BUGS">
						<qry:attribute name="bandera_datos" value="'no'"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_bugs"/>
						<qry:insert-select name="qry_total" doc-path="."/>
					</qry:element>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_clientes">
			<qry:xquery>
				for $r in sql('
SELECT 
 	cli.d_nom_cliente,
 	SOP.n_cantidad_horas,
 	cli.oi_cliente,
 	cli.c_cliente as c_cliente
FROM 
PRY08_CLIENTES as cli,
PRY08_SOPORTE as SOP   
JOIN
SOP.oi_cliente INNER cli.oi_cliente
WHERE 
cli.oi_cliente in ({%= #PARAM:CLIENTES/CLIENTE/@id %})  
order by c_cliente asc
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CLIENTE">
					<qry:attribute name="nom_cliente" value="$r/@d_nom_cliente"/>
					<qry:attribute name="horas_convenio" value="$r/@n_cantidad_horas"/>
					<qry:attribute name="oi_cliente" value="$r/@oi_cliente"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_soporte">
			<qry:xquery>
				for $r in sql('		
SELECT 
	sol.oi_solicitud
	, sol.c_solicitud
	, sol.f_solicitud    
	, max(sol.c_reclamo) as c_reclamo
	, cont.d_nom_y_ape
	, mod.c_modulo 
	, sol.c_estado
	, sol.d_solicitud
	, rec.c_recurso
	, pt.oi_pry_imputa
	, pt.oi_tarea
	, max(cli.d_nom_cliente) as d_nom_cliente
	, max(cli.c_cliente) as c_cliente 
	,max(cli.oi_cliente) as oi_cliente
FROM 
	PRY01_PROYECTOS AS padre
	,	PRY01_PROYECTOS AS hijo
	, PRY02_TAREAS AS pt
	, PRY08_CLIENTES AS cli
	, PRY05_RECURSOS AS rec
	, PRY04_TRABAJOS AS tra
	, PRY07_SOLICITUDES AS sol
	, PRY11_MODULOS AS mod
	, PRY08_CONTACTOS as cont  
JOIN         
	padre.oi_proyecto INNER hijo.oi_proyecto_parent					
	, padre.c_enlace INNER cli.c_cliente
	, hijo.oi_proyecto INNER pt.oi_pry_imputa
	, pt.oi_solicitud INNER sol.oi_solicitud
	, sol.oi_recurso LEFT OUTER rec.oi_recurso
  , pt.oi_tarea INNER tra.oi_tarea
	, sol.oi_modulo LEFT OUTER mod.oi_modulo
	, sol.oi_contacto LEFT OUTER cont.oi_contacto
WHERE 
	cli.oi_cliente in ({%= #PARAM:CLIENTES/CLIENTE/@id %})			
AND
	UCASE(hijo.d_proyecto) = UCASE(\'Soporte\')
AND 
	NOT(CONTAIN(pt.d_tarea, \'Soporte Tel\'))
AND
	tra.f_fecha &gt;= {Datetime(#PARAM:@f_desde)}
AND
	tra.f_fecha &lt;= {Datetime(#PARAM:@f_hasta)}
GROUP BY
	sol.oi_solicitud
	, sol.c_solicitud
	, sol.f_solicitud
	, cont.d_nom_y_ape
	, mod.c_modulo 
	, sol.c_estado
	, sol.d_solicitud
	, rec.c_recurso
	, pt.oi_pry_imputa
	, pt.oi_tarea
ORDER BY
 	c_cliente asc, f_solicitud DESC		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="SOL">
					<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
					<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
					<qry:attribute name="c_modulo" value="$r/@c_modulo"/>
					<qry:attribute name="c_reclamo" value="$r/@c_reclamo"/>
					<qry:attribute name="oi_cli" value="$r/@oi_cliente"/>
					<qry:attribute name="d_cliente" value="concat('[',$r/@c_cliente,'] ',$r/@d_nom_cliente)"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="d_estado" value="'PENDIENTE'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="d_estado" value="'CERRADO'"/>
						</qry:case>
						<qry:case value="6">
							<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
						</qry:case>
						<qry:case value="7">
							<qry:attribute name="d_estado" value="'RECHAZADO'"/>
						</qry:case>
						<qry:case value="8">
							<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
						</qry:case>
						<qry:case value="9">
							<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:insert-select name="qry_trabajo" doc-path="$r"/>
					<qry:insert-select name="qry_total_sol" doc-path="."/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_trabajo" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	tra.f_fecha
	, tra.o_mensaje
	, rec.c_recurso
	, tra.e_duracion
	, ut.c_unidad_tiempo as unid
FROM 
	PRY04_TRABAJOS AS tra
  ,	PRY05_RECURSOS AS rec
  , PRY03_UND_TIEMPO AS ut
JOIN         
	tra.oi_recurso LEFT OUTER rec.oi_recurso
	, tra.oi_unidad_tiempo INNER ut.oi_unidad_tiempo
WHERE 
	tra.oi_tarea = {#PARAM:@oi_tarea}					
AND
	tra.f_fecha &gt;= {Datetime(#PARAMIN:@f_desde)}
AND
	tra.f_fecha &lt;= {Datetime(#PARAMIN:@f_hasta)}
ORDER BY
 	f_fecha DESC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TRAB">
					<qry:attribute name="f_trabajo" value="format_date($r/@f_fecha, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_trabajo" value="$r/@o_mensaje"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:switch test="$r/@unid">
						<qry:case value="H">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion,'###0.0')"/>
						</qry:case>
						<qry:case value="M">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion div 60,'###0.0')"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion * 40,'###0.0')"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="hs_insumidas_trabajo" value="format_number($r/@e_duracion * 8,'###0.0')"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_tarea_imp" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	pt.oi_tarea
	, pt.c_tarea
	, pt.f_inicio
	, pt.d_tarea
	, rec.c_recurso
	, max(cli.c_cliente) as c_cliente
	, max(cli.d_nom_cliente) as d_nom_cliente  
		,max(cli.oi_cliente) as oi_cliente
FROM 
	PRY01_PROYECTOS AS padre
	,	PRY01_PROYECTOS AS hijo
	, PRY02_TAREAS AS pt
	, PRY08_CLIENTES AS cli
	, PRY05_RECURSOS AS rec
	, PRY04_TRABAJOS AS tra
JOIN         
	padre.oi_proyecto INNER hijo.oi_proyecto_parent					
	, padre.c_enlace INNER cli.c_cliente
	, hijo.oi_proyecto INNER pt.oi_pry_imputa
	, pt.oi_recurso LEFT OUTER rec.oi_recurso
  , pt.oi_tarea INNER tra.oi_tarea
WHERE 
	cli.oi_cliente   in ({%= #PARAM:CLIENTES/CLIENTE/@id %})					
AND
	UCASE(hijo.d_proyecto) = UCASE(\'Soporte\')
AND 
	CONTAIN(pt.d_tarea, \'Soporte Tel\')
AND
	tra.f_fecha &gt;= {Datetime(#PARAM:@f_desde)}
AND
	tra.f_fecha &lt;= {Datetime(#PARAM:@f_hasta)}
GROUP BY
	pt.oi_tarea
	, pt.c_tarea
	, pt.f_inicio
	, pt.d_tarea
	, rec.c_recurso     
order by c_cliente asc
		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TAREA">
					<qry:attribute name="total_tarea" value="0"/>
					<qry:attribute name="c_tarea" value="$r/@c_tarea"/>
					<qry:attribute name="oi_cli" value="$r/@oi_cliente"/>
					<qry:attribute name="f_tarea" value="format_date($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:attribute name="d_cliente" value="concat('[',$r/@c_cliente,'] ',$r/@d_nom_cliente)"/>
					<qry:insert-select name="qry_trabajo" doc-path="$r"/>
					<qry:insert-select name="qry_total_tarea" doc-path="."/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_bugs">
			<qry:xquery>
				for $r in sql('		
SELECT 
	sol.oi_solicitud
	, sol.c_solicitud
	, sol.f_solicitud
	, cont.d_nom_y_ape
	, mod.c_modulo 
	, sol.c_estado
	, sol.d_solicitud
	, rec.c_recurso
	, pt.oi_pry_imputa
	, pt.oi_tarea
	, max(cli.c_cliente) as c_cliente
	, max(cli.d_nom_cliente) as d_nom_cliente  
		,max(cli.oi_cliente) as oi_cliente
FROM 
	PRY01_PROYECTOS AS padre
	,	PRY01_PROYECTOS AS hijo
	, PRY02_TAREAS AS pt
	, PRY08_CLIENTES AS cli
	, PRY05_RECURSOS AS rec
	, PRY04_TRABAJOS AS tra
	, PRY07_SOLICITUDES AS sol
	, PRY11_MODULOS AS mod
	, PRY08_CONTACTOS as cont  
JOIN         
	padre.oi_proyecto INNER hijo.oi_proyecto_parent					
	, padre.c_enlace INNER cli.c_cliente
	, hijo.oi_proyecto INNER pt.oi_pry_imputa
	, pt.oi_solicitud INNER sol.oi_solicitud
	, sol.oi_recurso LEFT OUTER rec.oi_recurso
  , pt.oi_tarea INNER tra.oi_tarea
	, sol.oi_modulo LEFT OUTER mod.oi_modulo
	, sol.oi_contacto LEFT OUTER cont.oi_contacto
WHERE 
	cli.oi_cliente  in ({%= #PARAM:CLIENTES/CLIENTE/@id %})						
AND
	UCASE(hijo.d_proyecto) = UCASE(\'Bugs\')
AND
	tra.f_fecha &gt;= {Datetime(#PARAM:@f_desde)}
AND
	tra.f_fecha &lt;= {Datetime(#PARAM:@f_hasta)}
GROUP BY
	sol.oi_solicitud
	, sol.c_solicitud
	, sol.f_solicitud
	, cont.d_nom_y_ape
	, mod.c_modulo 
	, sol.c_estado
	, sol.d_solicitud
	, rec.c_recurso
	, pt.oi_pry_imputa
	, pt.oi_tarea
ORDER BY
 	c_cliente asc, f_solicitud DESC		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="SOL">
					<qry:attribute name="c_solicitud" value="$r/@c_solicitud"/>
					<qry:attribute name="f_solicitud" value="format_date($r/@f_solicitud, 'dd/mm/yyyy')"/>
					<qry:attribute name="d_solicitante" value="$r/@d_nom_y_ape"/>
					<qry:attribute name="d_cliente" value="concat('[',$r/@c_cliente,'] ',$r/@d_nom_cliente)"/>
					<qry:attribute name="c_modulo" value="$r/@c_modulo"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="d_estado" value="'PENDIENTE'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="d_estado" value="'DERIVADO A PMO'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="d_estado" value="'DERIVADO A ESTIM/DESA'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="d_estado" value="'DERIVADO A CLIENTE'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="d_estado" value="'CERRADO'"/>
						</qry:case>
						<qry:case value="6">
							<qry:attribute name="d_estado" value="'CERRADO POR EL CLIENTE'"/>
						</qry:case>
						<qry:case value="7">
							<qry:attribute name="d_estado" value="'RECHAZADO'"/>
						</qry:case>
						<qry:case value="8">
							<qry:attribute name="d_estado" value="'TRABAJANDO'"/>
						</qry:case>
						<qry:case value="9">
							<qry:attribute name="d_estado" value="'PRESUPUESTADO'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="d_estado" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="d_solicitud" value="$r/@d_solicitud"/>
					<qry:attribute name="d_responsable" value="$r/@c_recurso"/>
					<qry:insert-select name="qry_trabajo" doc-path="$r"/>
					<qry:insert-select name="qry_total_sol" doc-path="."/>
				</qry:element>
				<qry:attribute name="bandera_datos" value="'si'"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total_sol" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:TRAB
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hs_insumidas_sol" value="format_number(NUMBER(@hs_insumidas_sol) + NUMBER($r/@hs_insumidas_trabajo),'###0.0')"/>
				<qry:attribute name="hs_ins_sol" value=" NUMBER(@hs_ins_sol) + NUMBER($r/@hs_insumidas_trabajo) "/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total_tarea" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:TRAB
			</qry:xquery>
			<qry:out>
				<qry:attribute name="total_tarea" value="format_number(NUMBER(@total_tarea) + NUMBER($r/@hs_insumidas_trabajo),'###0.0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_total" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:SOL
			</qry:xquery>
			<qry:out>
				<qry:attribute name="total" value="format_number(NUMBER(@total) + NUMBER($r/@hs_insumidas_sol),'###0.0')"/>
			</qry:out>
		</qry:select>
	</html:query>
