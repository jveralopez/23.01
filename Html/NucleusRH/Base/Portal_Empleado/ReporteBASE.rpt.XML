<html:html xmlns:html="nomad_engine.html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Portal_Empleado.ReporteBASE" doc="source">
	<html:xslt>
		<xsl:template name="BaseSTYLE">
			<STYLE>
				body {
					background-color: #FFFFFF;
					
					PADDING-RIGHT: 0px;
					PADDING-LEFT: 0px;
					PADDING-BOTTOM: 0px;
					MARGIN: 0px;
					BORDER-TOP-STYLE: none;
					PADDING-TOP: 0px;
					BORDER-RIGHT-STYLE: none;
					BORDER-LEFT-STYLE: none;
					BORDER-BOTTOM-STYLE: none;
				}

				.titulo {
					border-collapse:collapse;
				}

				.titulo td {
					font-weight: bold; 
					font-size: 12px; 
					color: #B4D344; 
					font-family: Verdana;
					border-bottom:#BBDE78 1px solid; 
					padding-bottom:10px;
					Text-Align: left;
				}


				.txt01Button_n {
					color: #007393;
					font-family: Verdana;
					Text-Align: left;
				}

				.txt01Button_o {
					color: #1093FF;
					font-family: Verdana;
					Text-Align: left;
				}

				.rowData_normal {
					color: #007393; 
					font-family: Verdana;
					Text-Align: left;
				}
								
					
				.rowData_bold {
					font-weight: bold; 
					color: #B4D344; 
					font-family: Verdana;
					Text-Align: left;
				}

				.rowData_info {
					color: #909090;
					font-family: Verdana;
					Text-Align: left;
				}

				.size01 {
					font-size: 10px;
				}

				.size02 {
					font-size: 11px;
				}

				.size03 {
					font-size: 12px;
				}


				.rowtipo_0 {
					background-color: #EFEFEF;
				}


				.xtitulo {
					border-collapse:collapse;
				}

				.xtitulo td {
					font-weight: bold; 
					font-size: 18px; 
					color: #B4D344; 
					font-family: Verdana;
					Text-Align: center;
				}

								

				.separador {
					border-bottom:#BBDE78 1px solid; 
				}

				.bullet {
					padding-left:16px;
					background-image: url("images/Reports/item.gif"); 
					background-position:bottom left; 
					background-repeat:no-repeat;
				}

				.emptybullet {
					padding-left:23px;
					background-position:5px 50%; 
					background-repeat:no-repeat;
				}



				.cabecera {
					font-size: 10px;
					font-weight: bold;  
					color: #FFFFFF;
					font-family: Verdana;
					Text-Align: left;
					background-color: #B4D344;
					border-bottom: #BBDE78 1px solid; 
					padding-bottom: 5px;
				}

                

				.seleccionable {
					border-collapse:collapse;
				}

				.seleccionable.cabecera {
					font-size: 10px;
					font-weight: bold;  
					color: #FFFFFF;
					font-family: Verdana;
					Text-Align: left;
					background-color: #B4D344;
					border-bottom: #BBDE78 1px solid; 
					padding-bottom: 5px;
				}

				.seleccionable.rowtipo_n_0 {
					background-color: #EFEFEF;
					cursor:pointer;
				}
				.seleccionable.rowtipo_o_0 {
					background-color: #C6D19E;
					cursor:pointer;
				}
				.seleccionable.rowtipo_n_1 {
					background-color: #FFFFFF;
					cursor:pointer;
				}
				.seleccionable.rowtipo_o_1 {
					background-color: #C6D19E;
					cursor:pointer;
				}
				.seleccionable.mailregular {
					font-size: 1px; 
					padding-left:10px;
					background-image: url("images/Reports/email.gif"); 
					background-position:center left; 
					background-repeat:no-repeat;
					height:17px;
				}
				.seleccionable.mailopen {
					font-size: 1px; 
					padding-left:10px;
					background-image: url("images/Reports/emailopen.gif"); 
					background-position:center left; 
					background-repeat:no-repeat;
					height:17px;
				}
     			




				.textentry {
					border-style: solid;
					sborder-color: #B4D344;
					border-color: #808080;
					border-width: 1px; 
					background-color:white;
				}

				.sbars {
					scrollbar-highlight-color:#EAEAEA; 
					scrollbar-darkshadow-color:#EAEAEA; 
					scrollbar-track-color:#FAFAFA; 
					scrollbar-face-color:#FAFAFA;
					scrollbar-base-color:#C7D39A;
					
					scrollbar-arrow-color:#8FB8C4; 
				}
			</STYLE>
		</xsl:template>
		<xsl:template name="ReportSTYLE"/>
		<xsl:template name="ReportSCRIPT"/>
		<xsl:template name="MainTemplate" match="MAIN">
			<html>
				<xsl:attribute name="nmd_timestamp">
					<xsl:value-of select="@timestamp"/>
				</xsl:attribute>
				<head>
					<META HTTP-EQUIV="PRAGMA" CONTENT="NO-CACHE"/>
					<META HTTP-EQUIV="CACHE-CONTROL" CONTENT="NO-CACHE"/>
					<script src="./Scripts/engComm.js" type="text/javascript" language="javascript">
						//matias
					</script>
					<script src="./Scripts/engReport.js" type="text/javascript" language="javascript">
						//matias
					</script>
					<script src="./Scripts/nmdXML.js" type="text/javascript" language="javascript">
						//matias
					</script>
					<xsl:call-template name="BaseSTYLE"/>
					<xsl:call-template name="ReportSTYLE"/>
					<script type="text/javascript" language="javascript">
						<xsl:call-template name="ReportSCRIPT"/>
						function ChangeStyleSB (pObj, pOver) {
						if (pObj) {
							var imgSrc = pObj.src;
	
							if (pOver)
								imgSrc = imgSrc.replace("_n.", "_o.");
							else
								imgSrc = imgSrc.replace("_o.", "_n.");
							
							pObj.src = imgSrc;
						}
					}

					function ChangeStyleBut (pObj, pImg, pOver) {
						var objImg;
						var objTxt;
                        
						if (pObj) {
							var typeTxt = typeof(pObj);
                            
							if (typeTxt.toUpperCase() == "STRING")
								objTxt = document.getElementById(pObj);
							else 
								objTxt = pObj;

							var strCName = objTxt.className;
	
							if (pOver)
								strCName = strCName.replace("Button_n", "Button_o");
							else
								strCName = strCName.replace("Button_o", "Button_n");
							
							objTxt.className = strCName; 

			           	}
						
						if (pImg) {
							var typeImg = typeof(pImg);

							if (typeImg.toUpperCase() == "STRING")
								objImg = document.getElementById(pImg);
							else 
								objImg = pImg;

							ChangeStyleSB(objImg, pOver);
			           	}
					}
					</script>
				</head>
				<xsl:apply-templates select="DATA"/>
			</html>
		</xsl:template>
	</html:xslt>
</html:html>
