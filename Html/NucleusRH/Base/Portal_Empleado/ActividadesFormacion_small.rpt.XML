<html:html xmlns:html="nomad_engine.html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Portal_Empleado.ActividadesFormacion_small" extends="NucleusRH.Base.Portal_Empleado.ActividadesFormacion.rpt" doc="source">
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC">
				<table border="0" width="100%" class="titulo">
					<tr>
						<td width="100%">
							Actividades de formaci&#243;n
						</td>
					</tr>
				</table>
				<table border="0" width="100%">
					<col class="rowData_bold size01"/>
					<col class="rowData_normal size01"/>
					<xsl:for-each select="DICTADO">
						<tr>
							<xsl:attribute name="class">
								<xsl:value-of select="concat('rowtipo_', @rtipo)"/>
							</xsl:attribute>
							<td width="80px">
								<xsl:value-of select="@inicio"/>
							</td>
							<td>
								<xsl:value-of select="@dictado"/>
							</td>
						</tr>
					</xsl:for-each>
				</table>
			</body>
		</xsl:template>
	</html:xslt>
</html:html>
