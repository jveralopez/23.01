<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="NucleusRH.Base.Portal_Empleado.ReporteBASE.rpt" name="NucleusRH.Base.Portal_Empleado.CumplesDelMes" doc="source">
	<html:query declare="&lt;PARAMS bandeja=&quot;Entrada&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:attribute value="#SOURCE:PARAMS/@bandeja" name="nombre"/>
					<qry:insert-select name="sql-bandeja" doc-path="#SOURCE:PARAMS"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="sql-bandeja" doc="SOURCE">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Mail\\UsuariosBandejas\\001AA0E914F9-4925A82C01A5-BA9D233100C7.USUARIO_BANDEJA.XML')/USUARIO_BANDEJA/BANDEJAS/BANDEJA[@NOMBRE='{%= #SOURCE:@bandeja %}']/CORREOS/CORREO/OI_MAIL
			</qry:xquery>
			<!--qry:xquery>
				for $r in file('Nomad\\Base\\Mail\\UsuariosBandejas\\{%= #PROXY:@ETTY %}.USUARIO_BANDEJA.XML')/USUARIO_BANDEJA/BANDEJAS/BANDEJA[@NOMBRE='{%= #SOURCE:@bandeja %}']/CORREOS/CORREO/OI_MAIL
			</qry:xquery-->
			<qry:out>
				<qry:attribute name="rtipo" value="IIF(number(./@rtipo) = 1, 0, 1)"/>
				<qry:element name="CORREO">
					<qry:attribute value="$r/@id" name="id"/>
					<qry:insert-select name="sql-datos-correo" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="sql-datos-correo" doc="PARAM">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Mail\\InputMails\\{%= #PARAM:@id %}.MAIL.XML')/MAIL
			</qry:xquery>
			<qry:out>
				<qry:attribute name="rtipo" value="../@rtipo"/>
				<qry:attribute value="format_date($r/@FECHA_CREACION,'dd/mm/yyyy hh:MM')" name="date"/>
				<qry:attribute value="$r/@asunto" name="subject"/>
				<qry:attribute value="$r/@FECHA_LECTURA" name="fecha_lectura"/>
				<qry:attribute value="iif($r/@FECHA_LECTURA!='','1','0')" name="read"/>
				<qry:attribute value="iif($r/@FECHA_LECTURA!='','open','regular')" name="img"/>
				<qry:attribute value="$r/ENTIDAD/@value" name="id_entidad"/>
				<qry:insert-select name="sql-remitente" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="sql-remitente" doc="SOURCE">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Login\\Entidades\\{%= #SOURCE:@id_entidad %}.ENTIDAD.XML')/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:attribute name="from" value="$r/@DES"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC">
				<table border="0" width="100%" class="titulo">
					<tr>
						<td width="100%" class="titulo" align="center">
							<span>
								Bandeja de correo '
							</span>
							<xsl:value-of select="@nombre"/>
							<span>
								'
							</span>
						</td>
					</tr>
				</table>
				<table border="0" width="100%" class="seleccionable">
					<tr>
						<td class="cabecera" width="20px">
							&#160;
						</td>
						<td class="cabecera">
							De
						</td>
						<td class="cabecera">
							Asunto
						</td>
						<td class="cabecera">
							Fecha
						</td>
					</tr>
					<xsl:for-each select="CORREO">
						<tr onmouseover="this.className=this.className.replace('_n_', '_o_');" onmouseout="this.className=this.className.replace('_o_', '_n_');">
							<xsl:attribute name="class">
								<xsl:value-of select="concat('rowtipo_n_', @rtipo)"/>
							</xsl:attribute>
							<td class="rowData_normalsize01">
								<xsl:attribute name="class">
									<xsl:value-of select="concat('mail', @img)"/>
								</xsl:attribute>
								&#160;
							</td>
							<td class="rowData_normal size01">
								<xsl:value-of select="@from"/>
							</td>
							<td class="rowData_normal size01">
								<xsl:value-of select="@subject"/>
							</td>
							<td class="rowData_normal size01">
								<xsl:value-of select="@date"/>
							</td>
						</tr>
					</xsl:for-each>
				</table>
			</body>
		</xsl:template>
	</html:xslt>
</html:html>
