<html:html xmlns:html="nomad_engine.html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="NucleusRH.Base.Portal_Empleado.NovedadesEmpresa.GEN.GADGET" name="Novedades de la empresa (Detalle)" doc="source">
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no">
				<table class="tabla_detail estilo1" cellspacing="0" cellpadding="0">
					<tr>
						<th>
							Novedades y sociales
						</th>
					</tr>
					<tr>
						<td>
							<div>
								<table style="width:100%;font-size: 11px;" width="100%" aclass="tabla_noticia estilo1">
									<xsl:for-each select="NOVEDAD">
										<tr>
											<td height="30px" class="img_back2">
												<xsl:if test="@oi_img_tn = '0'">
													<xsl:attribute name="style">
														background-image: url(../../../Images/Reports/generico.gif);
													</xsl:attribute>
												</xsl:if>
												<xsl:if test="@oi_img_tn != '0'">
													<xsl:attribute name="style">
														<xsl:value-of select="concat('background-image:url(data:image/jpg;base64,(#IMAGE.DB(x16;NucleusRH.Base.Portal_Empleado.Imagenes.HEAD;', @oi_img_tn, ')#))')"/>
													</xsl:attribute>
												</xsl:if>
												<span class="titu_2 estilo2">
													<xsl:value-of select="@fecha"/>
												</span>
												<span>
													&#160;|&#160;
												</span>
												<span class="titu_2 estilo1">
													<xsl:value-of select="@titulo"/>
												</span>
											</td>
										</tr>
										<tr>
											<td valign="top">
												<xsl:if test="@oi_img_n != '0'">
													<img style="margin-right:10px; float: left;">
														<xsl:attribute name="src">
															<xsl:value-of select="concat('../../../nomadfile.aspx?ut=', ../@ut, '{#CHAR.AMP#}class=NucleusRH.Base.Portal_Empleado.Imagenes.HEAD{#CHAR.AMP#}mode=DB{#CHAR.AMP#}id=', @oi_img_n)"/>
														</xsl:attribute>
													</img>
												</xsl:if>
												<span class="row_noticia_2" style="font-size:12px;">
													<xsl:value-of select="@des"/>
												</span>
											</td>
										</tr>
									</xsl:for-each>
								</table>
							</div>
						</td>
					</tr>
				</table>
			</body>
		</xsl:template>
	</html:xslt>
</html:html>
