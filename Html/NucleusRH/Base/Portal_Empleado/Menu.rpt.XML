<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Liquidacion.Recibo">
	<html:query declare="&lt;PARAMS &#13;&#10;&#9;Menu=&quot;Base.portal&quot;&#13;&#10;&#9;MOD =&quot;PER&quot; &#13;&#10;&#9;GRP =&quot;0&quot;&#13;&#10;/&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="TITLE">
				<qry:attribute name="LABEL" value="'Sin Menu'"/>
				<qry:attribute name="DESCR" value="'No se encotro el Menu especificado.'"/>
				<qry:insert-select name="qry_menu" doc-path="#SOURCE:/PARAMS"/>
			</qry:element>
		</qry:main>
		<qry:select name="qry_menu" doc="SOURCE">
			<qry:xquery>
				for $r in FILESTORE('Menus\\{%=#SOURCE:@MENU %}.menu.xml')/APP-MENU/MODULE[@image=#SOURCE:@MOD]/SECTION[0]/GROUP[number(#SOURCE:@GRP)]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="LABEL" value="$r/@label"/>
				<qry:attribute name="DESCR" value="$r/@descr"/>
				<qry:insert-select name="qry_item" doc-path="$r/item"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_item" doc="SOURCE">
			<qry:out>
				<qry:insert-element doc-path="#SOURCE:"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="TITLE">
			<html>
				<head>
					<LINK href="../Skins/Styles/GReport.css" type="text/css" rel="stylesheet"/>
					<STYLE>
						body {
				background-color: #FFFFFF; 
				cursor: default;
				PADDING-RIGHT: 0px; 
				PADDING-LEFT: 0px; 
				PADDING-BOTTOM: 0px; 
				MARGIN: 0px; 
				BORDER-TOP-STYLE: none; 
				PADDING-TOP: 0px; 
				BORDER-RIGHT-STYLE: none; 
				BORDER-LEFT-STYLE: none; 
				BORDER-BOTTOM-STYLE: none
			}
			.MenuLabel
			{
				font-size: 14px;
				font-weight: bold;
				font-family: Verdana;
				color: #000000;
				
				padding-right:20px;
				padding-left:5px;
			}
			
			.MenuLine
			{
				font-size: 1px;
				padding-right:20px;
				padding-left:5px;
				
				height:5px;
			}
			
			.MenuDescr
			{
				font-size: 10px;
				font-weight: bold;
				font-family: Arial;
				font-style: Italic;
				color: #909090;
				
				padding-right:20px;
				padding-left:5px;
			}

			.Links {
			    font-family: Verdana;
			    font-size: 11px;
			    text-decoration: none;
			    cursor:pointer;
			    height:16px;
			}
			     
			.LinksImg {
			    font-family: Verdana;
			    font-size: 11px;
			    text-decoration: none;
			    cursor:pointer;
			    background-position:top left; 
				background-repeat:no-repeat;
				padding-left:16px;
				padding-top:2px;
				padding-bottom:2px;
				height:16px;
			}
			     
			.LI_n {background-image: url(./skins/_default/images/links/link_n.gif);}
			.LI_o {background-image: url(./skins/_default/images/links/link_o.gif);}
			.LI_d {background-image: url(./skins/_default/images/links/link_d.gif);}
			
			.LC_n {color:#333333;}
			.LC_o {color:#007EA2;}
			.LC_d {color:#8f8f8f; cursor:default;}
			
			.LA_n {color:#fefffe;}
			.LA_o {color:#ffff00;}
			.LA_d {color:#8f8f8f; cursor:default;}
			
			.LV_n {color:#00002f;}
			.LV_o {color:#000000;}
			.LV_d {color:#00008f; cursor:default;}
			
			.LS_n {background-image: url(./skins/_default/images/links/lock_n.gif); }
			.LSC_n {color:#333333; cursor:default;}
			.LSA_n {color:#fefffe; cursor:default;}
			.LSV_n {color:#00002f; cursor:default;}
					</STYLE>
					<script>
						function Replace(strin, strfnd, strrpl) {
							return strin.replace(new RegExp(strfnd, "ig"), strrpl);
						}
						     
						function CallNothing()
						{
						}
						
						function GenericLinkChgStyle(objLink, newStyle) {
			
				if (objLink?false:true) return;
				
				try {
					switch(newStyle)
					{
						case "OVER":
							objLink.className = Replace(objLink.className, '_n', '_o');
						break;
						
						case "NORMAL":
							objLink.className = Replace(objLink.className, '_o', '_n');
						break;
				
						case "DISABLED":
							objLink.className = Replace(objLink.className, '_n', '_d');
							objLink.className = Replace(objLink.className, '_o', '_d');
						break;
						
						case "ENABLED":
							objLink.className = Replace(objLink.className, '_d', '_n');
							objLink.className = Replace(objLink.className, '_o', '_n');
						break;
					}
				} catch (e) {}
			
			}
					</script>
				</head>
				<body bgcolor="#F2F2EC">
					<table cellspacing="0" cellpadding="0" width="100%">
						<tr>
							<td class="MenuLabel" valign="bottom">
								<xsl:value-of select="@LABEL"/>
							</td>
						</tr>
						<tr>
							<td class="MenuLine">
								<hr width="100%"/>
							</td>
						</tr>
						<tr>
							<td class="MenuDescr" valign="top">
								<xsl:value-of select="@DESCR"/>
							</td>
						</tr>
						<tr>
							<td height="5px" style="font-size:2px;">
								&#160;
							</td>
						</tr>
						<xsl:for-each select="ITEM">
							<tr>
								<td style="padding-left:10px;">
									<a class="LI_n LC_n LinksImg" href="javascript:CallNothing();" onkeypress="" onmouseover="GenericLinkChgStyle(this,'OVER');" onmouseout="GenericLinkChgStyle(this,'NORMAL');" onfocus="GenericLinkChgStyle(this,'OVER');" onblur="GenericLinkChgStyle(this,'NORMAL');">
										<xsl:attribute name="onclick">
											<xsl:value-of select="concat('parent.CallMenu(&quot;.&quot;, &quot;',@action,'&quot;)')"/>
										</xsl:attribute>
										<xsl:value-of select="@label"/>
									</a>
								</td>
							</tr>
						</xsl:for-each>
					</table>
				</body>
			</html>
		</xsl:template>
	</html:xslt>
</html:html>
