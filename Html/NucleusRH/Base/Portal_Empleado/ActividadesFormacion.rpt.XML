<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Portal_Empleado.ReporteBASE.rpt" name="NucleusRH.Base.Portal_Empleado.ActividadesFormacion" doc="source">
	<html:query declare="&lt;PARAMS file=&quot;NucleusRH.Base.Portal_Empleado.CumplesDelMes&quot; service=&quot;minimain&quot; app=&quot;Base-Desa&quot; s=&quot;7&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:attribute name="timestamp" value="FORMAT_DATE((NUMBER(Now()) + 1), 'yyyymmdd') + '000000'"/>
				<qry:element name="DATA">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="qry_dictados"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qry_dictados" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				SELECT
					d.c_dictado,
					d.d_dictado,
					d.f_inicio

				FROM
			   		CYD02_DICTADOS as d

				WHERE
					d.c_estado = \'P\'

			   	ORDER BY 
			   		f_inicio ASC, d_dictado ASC

			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="rtipo" value="IIF(number(./@rtipo) = 1, 0, 1)"/>
				<qry:element name="DICTADO">
					<qry:attribute name="c_dictado" value="$r/@c_dictado"/>
					<qry:attribute name="dictado" value="$r/@d_dictado"/>
					<qry:attribute name="inicio" value="FORMAT_DATE($r/@f_inicio, 'dd/mm/yyyy')"/>
					<qry:attribute name="rtipo" value="../@rtipo"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
