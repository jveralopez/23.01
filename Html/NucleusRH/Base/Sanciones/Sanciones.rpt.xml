<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Sanciones.Sanciones">
	<html:for-each declare="&lt;FILTRO oi_clase_org=&quot;&quot; gcustom=&quot;&quot; oi_empresa=&quot;196&quot; f_desde=&quot;&quot; f_hasta=&quot;&quot; oi_motivo_sancion=&quot;14&quot; oi_sancion=&quot;&quot; agrupacion=&quot;&quot; orden=&quot;PER02_PERSONAL_EMP.e_numero_legajo&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&#13;&#10;  &lt;PERSONAS&gt;&#13;&#10;    &lt;ROW VALUES=&quot;11566,11567,11568,11569,11570,11571,11573,11574,11575,11576,11578,11580,11581,11582,11583,11579,13885,13886,13887,13888,13889,13890,13891,13892,13895,13921,13922,13923,13924,13925,13926,13927,13928,13929,13930,13941,13942,13947,13931,13932,13933,13935,13943,11565,13946,14047,13948,13949&quot;/&gt;&#13;&#10;  &lt;/PERSONAS&gt;&#13;&#10;&lt;/FILTRO&gt;&#13;&#10;">
		<qry:main doc="PARAM">
			<qry:append-doc name="PARAMIN" doc-path="#PARAM:FILTRO"/>
			<REPORT label="Sanciones">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP style="width:100%" tag="DATOS" type="title">
						<COLS>
							<COL name="d_empresa" label="Empresa"/>
							<qry:if test="#PARAM:FILTRO/@f_desde!=''">
								<qry:then>
									<COL name="f_desde" label="Fecha Desde" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@f_hasta!=''">
								<qry:then>
									<COL name="f_hasta" label="Fecha Hasta" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@oi_motivo_sancion!=''">
								<qry:then>
									<COL name="o_motivo_sancion" label="Motivo de Sanci&#243;n"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@oi_sancion!=''">
								<qry:then>
									<COL name="d_sancion" label="Sanci&#243;n"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@agrupacion!=''">
								<qry:then>
									<COL name="agrupacion" label="Agrupaci&#243;n"/>
								</qry:then>
							</qry:if>
						</COLS>
						<qry:if test="#PARAM:FILTRO/@agrupacion!=''">
							<qry:then>
								<GROUP tag="GRUPO" type="title">
									<COLS>
										<COL name="grupo" style="font-weight:bold;"/>
									</COLS>
									<GROUP tag="PERSONA" label="Legajos" type="table">
										<COLS>
											<COL name="c_ubicacion" label="Cod. Ubi." style="width:5%"/>
											<COL name="d_ubicacion" label="Ubicaci&#243;n" style="width:25%"/>
											<COL name="d_personal_emp" label="Legajo" style="width:30%"/>
											<COL name="f_fechahora_sanc" label="Fecha Sanci&#243;n" style="width:15%;text-align:center"/>
											<COL name="f_susp" label="Susp. Desde - Hasta" style="width:5%;text-align:center"/>
											<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '1']" name="sql_attr_motivo"/>
											<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '2']" name="sql_attr_sancion"/>
											<COL name="o_sancion" label="Observaciones"/>
										</COLS>
									</GROUP>
								</GROUP>
							</qry:then>
							<qry:else>
								<GROUP tag="PERSONA" label="Legajos" type="table">
									<COLS>
										<COL name="c_ubicacion" label="Cod. Ubi." style="width:5%"/>
										<COL name="d_ubicacion" label="Ubicaci&#243;n" style="width:25%"/>
										<COL name="d_personal_emp" label="Legajo" style="width:30%"/>
										<COL name="d_sancion" label="Sanci&#243;n" style="width:25%"/>
										<COL name="o_motivo_sancion" label="Motivo de Sanci&#243;n" style="width:25%"/>
										<COL name="f_fechahora_sanc" label="Fecha Sanci&#243;n" style="width:15%;text-align:center"/>
										<COL name="f_susp" label="Susp. Desde - Hasta" style="width:5%;text-align:center"/>
										<COL name="o_sancion" label="Observaciones"/>
										<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '1']" name="sql_attr_motivo"/>
										<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '2']" name="sql_attr_sancion"/>
									</COLS>
								</GROUP>
							</qry:else>
						</qry:if>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<DATOS qry-orderby="orderby">
						<qry:attribute name="oi_empresa" value="#PARAM:FILTRO/@oi_empresa"/>
						<qry:attribute name="orden" value="#PARAM:FILTRO/@orden"/>
						<qry:attribute name="f_desde" value="format_date(#PARAM:FILTRO/@f_desde,'dd/mm/yyyy')"/>
						<qry:attribute name="f_hasta" value="format_date(#PARAM:FILTRO/@f_hasta,'dd/mm/yyyy')"/>
						<qry:attribute value="format_date(now(),'dd/mm/yyyy')" name="f_informe"/>
						<qry:insert-select doc-path="#PARAM:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_EMPRESA"/>
						<qry:if test="#PARAM:FILTRO/@oi_motivo_sancion!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:FILTRO" name="sql3"/>
							</qry:then>
						</qry:if>
						<qry:if test="#PARAM:FILTRO/@oi_sancion!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:FILTRO" name="sql5"/>
							</qry:then>
						</qry:if>
						<qry:if test="#PARAMIN:@agrupacion = ''">
							<qry:then>
								<qry:attribute name="agrupacion" value="''"/>
							</qry:then>
						</qry:if>
						<qry:if test="#PARAMIN:@agrupacion = '1'">
							<qry:then>
								<qry:attribute name="agrupacion" value="'Motivo de Sanci&#243;n'"/>
							</qry:then>
						</qry:if>
						<qry:if test="#PARAMIN:@agrupacion = '2'">
							<qry:then>
								<qry:attribute name="agrupacion" value="'Sanci&#243;n'"/>
							</qry:then>
						</qry:if>
					</DATOS>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
						<qry:attribute name="orden" value="#PARAMIN:@orden"/>
						<qry:attribute name="f_desde" value="#PARAMIN:@f_desde"/>
						<qry:attribute name="f_hasta" value="#PARAMIN:@f_hasta"/>
						<qry:attribute name="oi_motivo_sancion" value="#PARAMIN:@oi_motivo_sancion"/>
						<qry:attribute name="oi_sancion" value="#PARAMIN:@oi_sancion"/>
						<qry:attribute name="agrupacion" value="#PARAMIN:@agrupacion"/>
						<qry:attribute value="#PARAM:@values" name="values"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_EMPRESA">
			<qry:xquery>
				for $r in sql('
SELECT 
	ORG03_EMPRESAS.d_empresa
FROM 
	ORG03_EMPRESAS
WHERE	
	ORG03_EMPRESAS.oi_empresa = {#PARAM:@oi_empresa}
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql_attr_motivo">
			<qry:out>
				<COL name="d_sancion" label="Sanci&#243;n"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql_attr_sancion">
			<qry:out>
				<COL name="o_motivo_sancion" label="Motivo de Sanci&#243;n"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql5">
			<qry:xquery>
				for $r in sql('
	SELECT 
		SAN02_SANCIONES.d_sancion
	FROM 
		SAN02_SANCIONES
	WHERE
		SAN02_SANCIONES.oi_sancion = {#PARAM:@oi_sancion}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_sancion" value="$r/@d_sancion"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql3">
			<qry:xquery>
				for $r in sql('
SELECT 
	SAN01_MOTIVOS_SANC.o_motivo_sancion
FROM 
	SAN01_MOTIVOS_SANC 
WHERE
	SAN01_MOTIVOS_SANC.oi_motivo_sancion = {#PARAM:@oi_motivo_sancion}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="o_motivo_sancion" value="$r/@o_motivo_sancion"/>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO values=&quot;11566,11567,11568,11569,11570,11571,11573,11574,11575,11576,11578,11580,11581,11582,11583,11579,13885,13886,13887,13888,13889,13890,13891,13892,13895,13921,13922,13923,13924,13925,13926,13927,13928,13929,13930,13941,13942,13947,13931,13932,13933,13935,13943,11565,13946,14047,13948,13949&quot; oi_empresa=&quot;196&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:append-doc name="PARAMIN" doc-path="#PARAM:FILTRO"/>
				<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '1']" name="sql_agrupa_motivo"/>
				<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '2']" name="sql_agrupa_sancion"/>
				<qry:attribute name="agrupacion" value="''"/>
				<qry:append-doc name="AGRUP" doc-path="."/>
				<qry:insert-select doc-path="#PARAMIN:.[@agrupacion = '']" name="sql1"/>
			</qry:no-show>
		</qry:main>
		<qry:select doc="PARAM" name="sql_agrupa_motivo">
			<qry:xquery>
				for $r in sql('
	SELECT 
		SAN01_MOTIVOS_SANC.oi_motivo_sancion,
		SAN01_MOTIVOS_SANC.c_motivo_sancion,
		SAN01_MOTIVOS_SANC.o_motivo_sancion,
		SAN01_MOTIVOS_SANC.d_motivo_sancion
		
	FROM 
		SAN01_MOTIVOS_SANC
	ORDER BY c_motivo_sancion ASC  			
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="GRUPO">
					<qry:attribute name="hts:delete" value="1"/>
					<qry:if test="$r/@o_motivo_sancion!=''">
						<qry:then>
							<qry:attribute name="grupo" value="$r/@o_motivo_sancion"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="grupo" value="$r/@d_motivo_sancion"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="agrupacion" value="'AND SAN03_SANCION_PER.oi_motivo_sancion = ' + $r/@oi_motivo_sancion"/>
					<qry:append-doc name="AGRUP" doc-path="."/>
					<qry:insert-select doc-path="." name="sql1"/>
				</qry:element>
				<qry:attribute name="agrupacion" value="'Motivo de Sanci&#243;n'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql_agrupa_sancion">
			<qry:xquery>
				for $r in sql('
	SELECT 
		SAN02_SANCIONES.oi_sancion,
		SAN02_SANCIONES.c_sancion,
		SAN02_SANCIONES.d_sancion
	FROM 
		SAN02_SANCIONES
	ORDER BY c_sancion ASC  			
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="GRUPO">
					<qry:attribute name="hts:delete" value="1"/>
					<qry:attribute name="grupo" value="$r/@d_sancion"/>
					<qry:attribute name="agrupacion" value="'AND SAN03_SANCION_PER.oi_sancion = ' + $r/@oi_sancion"/>
					<qry:append-doc name="AGRUP" doc-path="."/>
					<qry:insert-select doc-path="." name="sql1"/>
				</qry:element>
				<qry:attribute name="agrupacion" value="'sanci&#243;n'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql1">
			<qry:xquery>
				for $r in sql('
	SELECT 
		{%? (#PARAMIN:@orden!=''){% {%= #PARAMIN:@orden %} as Orden,%}{% %} %}
		SAN03_SANCION_PER.oi_sancion_per, 
		SAN03_SANCION_PER.oi_personal_emp,
		SAN03_SANCION_PER.f_fechahora_sanc, 
		SAN03_SANCION_PER.oi_motivo_sancion,												
		SAN03_SANCION_PER.oi_sancion,  
		SAN03_SANCION_PER.o_sancion,  
		ORG03_UBICACIONES.c_ubicacion,
		ORG03_UBICACIONES.d_ubicacion					
	FROM 
		SAN03_SANCION_PER, 
		PER02_PERSONAL_EMP,
		ORG03_UBICACIONES
	JOIN 
		SAN03_SANCION_PER.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
		PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER ORG03_UBICACIONES.oi_ubicacion					
	WHERE 
		PER02_PERSONAL_EMP.oi_empresa = {#PARAMIN:@oi_empresa} AND
		PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAMIN:@values%})
		{%? (#PARAMIN:@f_desde!= '') {% AND SAN03_SANCION_PER.f_fechahora_sanc &gt; {Datetime(#PARAMIN:@f_desde)} %} {% %} %} 
		{%? (#PARAMIN:@f_hasta!= '') {% AND SAN03_SANCION_PER.f_fechahora_sanc &lt; {Datetime(Number(Datetime(#PARAMIN:@f_hasta))+1)} %} {% %} %}					
		{%? (#PARAMIN:@oi_motivo_sancion != '') {% AND SAN03_SANCION_PER.oi_motivo_sancion = {#PARAMIN:@oi_motivo_sancion} %} {% %} %}
		{%? (#PARAMIN:@oi_sancion != '') {% AND SAN03_SANCION_PER.oi_sancion = {#PARAMIN:@oi_sancion} %} {% %} %}					
		{%? (#AGRUP:@agrupacion != '')  {%=#AGRUP:@agrupacion%} {% %} %}					
		
	{%? (#PARAMIN:@orden!='') 
		{%ORDER BY orden ASC %} 
		{% %} 
	%}
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PERSONA">
					<qry:attribute name="oi_sancion_per" value="$r/@oi_sancion_per"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="f_fechahora_sanc" value="format_date($r/@f_fechahora_sanc,'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="oi_motivo_sancion" value="$r/@oi_motivo_sancion"/>
					<qry:attribute name="c_ubicacion" value="$r/@c_ubicacion"/>
					<qry:attribute name="d_ubicacion" value="$r/@d_ubicacion"/>
					<qry:attribute name="oi_sancion" value="$r/@oi_sancion"/>
					<qry:attribute name="o_sancion" value="$r/@o_sancion"/>
					<qry:insert-select doc-path="." name="sql3"/>
					<qry:insert-select doc-path="." name="sql4"/>
					<qry:insert-select doc-path="." name="sql5"/>
					<qry:insert-select doc-path="." name="sql6"/>
					<qry:insert-select doc-path="." name="sql7"/>
					<qry:attribute name="f_susp" value="@f_susp_ini + ' - ' + @f_susp_fin"/>
				</qry:element>
				<qry:attribute name="hts:delete" value="''"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql3">
			<qry:xquery>
				for $r in sql('
	SELECT 
		SAN01_MOTIVOS_SANC.d_motivo_sancion,
		SAN01_MOTIVOS_SANC.o_motivo_sancion
	FROM 
		SAN01_MOTIVOS_SANC 
	WHERE
		SAN01_MOTIVOS_SANC.oi_motivo_sancion = {#PARAM:@oi_motivo_sancion}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@o_motivo_sancion!=''">
					<qry:then>
						<qry:attribute name="o_motivo_sancion" value="$r/@o_motivo_sancion"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="o_motivo_sancion" value="$r/@d_motivo_sancion"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql4">
			<qry:xquery>
				for $r in sql('
	SELECT 
		PER02_PERSONAL_EMP.e_numero_legajo, 
		PER01_PERSONAL.d_ape_y_nom
	FROM 
		PER02_PERSONAL_EMP, 
		PER01_PERSONAL
	JOIN
		PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal 
	WHERE
		PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_personal_emp" value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql5">
			<qry:xquery>
				for $r in sql('
		SELECT 
			SAN02_SANCIONES.d_sancion
		FROM 
			SAN02_SANCIONES
		WHERE
			SAN02_SANCIONES.oi_sancion = {#PARAM:@oi_sancion}
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_sancion" value="$r/@d_sancion"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql6">
			<qry:xquery>
				for $r in sql('
		SELECT 
			SAN03_SUSP_PER.f_fechahora_ini
		FROM 
			SAN03_SUSP_PER
		WHERE
			SAN03_SUSP_PER.oi_sancion_per = {#PARAM:@oi_sancion_per}
		ORDER BY
			f_fechahora_ini DESC			
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_susp_ini" value="format_date($r/@f_fechahora_ini, 'dd/mm')"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql7">
			<qry:xquery>
				for $r in sql('
		SELECT 
			SAN03_SUSP_PER.f_fechahora_fin
		FROM 
			SAN03_SUSP_PER
		WHERE
			SAN03_SUSP_PER.oi_sancion_per = {#PARAM:@oi_sancion_per}
		ORDER BY
			f_fechahora_fin ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_susp_fin" value="format_date($r/@f_fechahora_fin, 'dd/mm')"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
