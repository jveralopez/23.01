										</text>
										<span style="font-weight:bold;">
											<xsl:value-of select="@o_motivo_sancion"/>
										</span>
										<text>
											&#160;impartida el d&#237;a&#160;
										</text>
										<span style="font-weight:bold;">
											<xsl:value-of select="@f_sancion"/>
										</span>
										<text>
											&#160;a las&#160;
										</text>
										<span style="font-weight:bold;">
											<xsl:value-of select="@h_sancion"/>
											<text>
												hs.
											</text>
										</span>
										<text>
											&#160;queda Sancionado mediante&#160;
										</text>
										<span style="font-weight:bold;">
											<xsl:value-of select="@d_sancion"/>
											<text>
												.
											</text>
										</span>
									</td>
								</tr>
							</thead>
						</table>
						<br/>
						<xsl:if test="SUSPENSIONES/SUSP">
							<table class="table_title_style" border="0">
								<tr>
									<td nowrap="1">
