				</head>
				<body bgcolor="#F6F6F1">
					<div class="divmarco">
						<table width="100%" class="stitle" border="0" style="">
							<tr>
								<td align="right">
									<img height="120px">
										<xsl:choose>
											<xsl:when test="@oi_logotipo = 'no'">
												<xsl:attribute name="src">
													<xsl:value-of select="'Images/Reports/unknown-person.jpg'"/>
												</xsl:attribute>
