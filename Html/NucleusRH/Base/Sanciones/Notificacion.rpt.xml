									</td>
								</tr>
							</thead>
						</table>
					</div>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="SUSP">
			<tr>
				<td style="width:33%;text-align:center">
					<xsl:value-of select="@f_fechahora_ini"/>
				</td>
				<td style="width:33%;text-align:center">
					<xsl:value-of select="@f_fechahora_fin"/>
				</td>
				<td style="width:33%;text-align:center">
					<xsl:value-of select="@e_dias_susp"/>
				</td>
			</tr>
		</xsl:template>
	</html:xslt>
</html:html>
