<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Sanciones.Notificacion">
	<html:query declare="&lt;DATO oi_personal_emp=&quot;11566&quot; oi_sancion_per=&quot;327&quot; /&gt;">
		<qry:main doc="PARAM">
			<qry:element name="DATOS">
				<qry:insert-select doc-path="#PARAM:DATO" name="sql1"/>
			</qry:element>
		</qry:main>
		<qry:select name="sql1" doc="PARAM">
			<qry:xquery>
				for $r in sql('
					SELECT
						SAN03_SANCION_PER.oi_sancion_per,
						PER01_PERSONAL.d_ape_y_nom,
						PER01_PERSONAL.c_nro_documento,
						PER02_PERSONAL_EMP.e_numero_legajo,
						ORG03_EMPRESAS.d_empresa,
						SAN01_MOTIVOS_SANC.o_motivo_sancion,
						SAN02_SANCIONES.d_sancion,						
						SAN03_SANCION_PER.o_sancion,
						SAN03_SANCION_PER.f_fechahora_sanc,
						PER02_PERSONAL_EMP.oi_personal_emp
					FROM
						SAN03_SANCION_PER,
						PER02_PERSONAL_EMP,
						PER01_PERSONAL,
						SAN02_SANCIONES,
						SAN01_MOTIVOS_SANC,
						SAN05_TIPOS_SAN,
						ORG03_EMPRESAS
					JOIN
						SAN03_SANCION_PER.oi_personal_emp INNER	PER02_PERSONAL_EMP.oi_personal_emp,
						PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
						PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
						SAN03_SANCION_PER.oi_sancion INNER SAN02_SANCIONES.oi_sancion,
						SAN02_SANCIONES.oi_tipo_san INNER SAN05_TIPOS_SAN.oi_tipo_san,
						SAN03_SANCION_PER.oi_motivo_sancion INNER SAN01_MOTIVOS_SANC.oi_motivo_sancion
					WHERE
						SAN03_SANCION_PER.oi_sancion_per = {#PARAM:@oi_sancion_per}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_emision" value="format_date(now(), 'dd/mm/yyyy HH:MM')"/>
				<qry:attribute name="oi_sancion_per" value="$r/@oi_sancion_per"/>
				<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="c_nro_documento" value="$r/@c_nro_documento"/>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="o_motivo_sancion" value="$r/@o_motivo_sancion"/>
				<qry:attribute name="d_sancion" value="$r/@d_sancion"/>
				<qry:attribute name="o_sancion" value="$r/@o_sancion"/>
				<qry:attribute name="f_sancion" value="format_date($r/@f_fechahora_sanc, 'dd/mm/yyyy')"/>
				<qry:attribute name="h_sancion" value="format_date($r/@f_fechahora_sanc, 'HH:MM')"/>
				<qry:element name="SUSPENSIONES">
					<qry:insert-select name="sql2" doc-path="$r"/>
				</qry:element>
				<qry:insert-select name="qry_logo" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="sql2" doc="PARAM">
			<qry:xquery>
				for $r in sql('
					SELECT
						SAN03_SUSP_PER.oi_suspension_per,
						SAN03_SUSP_PER.f_fechahora_ini,
						SAN03_SUSP_PER.f_fechahora_fin,
						SAN03_SUSP_PER.e_dias_susp						
					FROM
						SAN03_SUSP_PER						
					WHERE
						SAN03_SUSP_PER.oi_sancion_per = {#PARAM:@oi_sancion_per}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="SUSP">
					<qry:attribute name="oi_suspension_per" value="$r/@oi_suspension_per"/>
					<qry:attribute name="f_fechahora_ini" value="format_date($r/@f_fechahora_ini, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_fechahora_fin" value="format_date($r/@f_fechahora_fin, 'dd/mm/yyyy')"/>
					<qry:attribute name="e_dias_susp" value="$r/@e_dias_susp"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_logo">
			<qry:xquery>
				for $r in sql('
			SELECT 
				ORG03_EMPRESAS.oi_logotipo, 
				PER19_IMAGENES.o_imagen 
			FROM 
				ORG03_EMPRESAS, 
				PER02_PERSONAL_EMP, 
				PER19_IMAGENES
			JOIN 
				ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
				ORG03_EMPRESAS.oi_logotipo LEFT OUTER PER19_IMAGENES.oi_imagen_per 
			WHERE 
				PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_logotipo" value="iif($r/@oi_logotipo!='',$r/@oi_logotipo,'no')"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/DATOS">
