						<table class="table_title_style" border="0">
							<thead style="display: table-header-group;">
								<tr valign="top">
									<td>
										<b>
											Fecha de Emisi&#243;n:&#160;
										</b>
										<xsl:value-of select="@f_emision"/>
										<br/>
									</td>
								</tr>
							</thead>
						</table>
						<table class="table_title_style" border="0">
							<thead style="display: table-header-group;">
								<tr>
									<td>
										<text>
											Por medio de la presente se notifica a&#160;
										</text>
