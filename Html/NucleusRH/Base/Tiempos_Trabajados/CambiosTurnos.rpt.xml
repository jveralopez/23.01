<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" name="NucleusRH.Base.Tiempos_Trabajados.CambiosTurnos.rpt" doc="SOURCE">
	<html:for-each declare="&lt;FILTRO f_desde=&quot;20100101&quot; f_hasta=&quot;20110101&quot; empresa=&quot;5&quot; activos=&quot;1&quot; &gt;&#13;&#10;&#9;&lt;PERSONAS&gt;&#13;&#10;&#9;&#9;&lt;ROW VALUES=&quot;628,629,630,631,632,633,634,635,636,637,638,639,640,641,642,643,644,645,646,647,648,650,651,652,653,654,655,656,657,658,659,660,661,662,663,664,665,666,667,668,669,670,671,672,673,674,675,677,678,679,680,681,682,683,684,685,686,687,689,690,691,692,693,694,696,697,698,699,700,701,702,703,704,705,706,707,708,709,710,711,712,713,714,715,716,717,718,719,720,721,722,723,724,725,726,727,728,730,731,732,733,734,735,736,737,738,739,740,741,742,743,744,745,746,747,749,750,751,752,753,754&quot;/&gt;&#13;&#10;&#9;&lt;/PERSONAS&gt;&#13;&#10;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<REPORT label="Cambios de Turnos">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="CAB" type="title" noreg="No se encontraron registros para los filtros seleccionados.">
						<COLS>
							<COL name="d_empresa" label="Empresa" align="left" width="10"/>
							<COL name="f_des" label="Fecha Desde" style="width:13%;" type="date"/>
							<COL name="f_has" label="Fecha Hasta" style="width:10%;" type="date"/>
						</COLS>
						<GROUP tag="HOR" style="padding-left:50px" type="table" noreg="No se encontraron registros para los filtros seleccionados.">
							<COLS>
								<COL name="empresa" label="Empresa" nowrap="1"/>
								<COL name="e_numero_legajo" label="N&#250;mero de Legajo" nowrap="1" style="text-align:center"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" nowrap="1"/>
								<COL name="horario" label="Horario" style="width:40%;" nowrap="1"/>
								<COL name="f_desde" label="Fecha Desde" align="center" style="width:10%;" type="date" nowrap="1"/>
								<COL name="f_hasta" label="Fecha Hasta" align="center" style="width:10%;" type="date" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<CAB qry-orderby="orderby">
						<qry:attribute name="f_des" value="format_date(#FILTRO:@f_desde, 'dd/mm/yyyy')"/>
						<qry:attribute name="f_has" value="format_date(#FILTRO:@f_hasta, 'dd/mm/yyyy')"/>
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_EMPRESAS"/>
					</CAB>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_EMPRESAS">
			<qry:xquery>
				for $r in sql('				
					SELECT 
						ORG03_EMPRESAS.oi_empresa,
						ORG03_EMPRESAS.c_empresa,
						ORG03_EMPRESAS.d_empresa
					FROM						
						ORG03_EMPRESAS
					WHERE
						ORG03_EMPRESAS.oi_empresa = {#PARAM:@empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
				<qry:attribute value="$r/@c_empresa + ' - ' + $r/@d_empresa" name="d_empresa"/>
				<qry:append-doc doc-path="." name="EMP"/>
				<qry:insert-select doc-path="#PARAM:PERSONAS/ROW" name="QRY_PERSONAS"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:xquery>
				for $r in sql('		
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					PER02_PERSONAL_EMP
				WHERE
				  PER02_PERSONAL_EMP.oi_empresa = {#EMP:@oi_empresa}
					AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})
			')/ROWS
			</qry:xquery>
			<qry:out>
				<qry:if test="number($r/@cnt)!=0">
					<qry:then>
						<qry:call>
							<FILTRO>
								<qry:attribute name="fe_desde" value="#FILTRO:@f_desde"/>
								<qry:attribute name="fe_hasta" value="#FILTRO:@f_hasta"/>
								<qry:attribute value="#EMP:@oi_empresa" name="oi_empresa"/>
								<qry:attribute value="string($r/ROW/@oi_personal_emp)" name="values"/>
							</FILTRO>
						</qry:call>
					</qry:then>
					<qry:else/>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&#9;&lt;FILTRO values=&quot;980,981,982,983,984,985,986,987,988,989,990,991,992,993,994,995,996,997,998,999,1000,1001,1002,1003,1004,1005,1006,1007,1008,1009,1010,1011,1012,1013,1014,1015,1389,1390,1391,1392,1393,1394,1395,1416,1431,1440,1441,1442,1443,1444,1445,1446,1447,1448,1449,1450,1451,1452,1453,1454,1455,1456,1457,1458,1459,1460,1461,1462,1498,1499,1500,1504,1505,1507,1508,1509,1510,1515,1516,1524,1547,1562,1568,1569,1581,1582,1583,1584,1585,1586,1587,1588,1589,1590,1608,1616,1617,1627,1628,1629&quot; oi_empresa=&quot;304&quot; fe_hasta=&quot;20191018&quot; fe_desde=&quot;20191018&quot;/&gt;&#13;&#10;&#9;&#9;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:append-doc name="FILTRO" doc-path="#PARAM:FILTRO"/>
				<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_HORARIOS"/>
			</qry:no-show>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_HORARIOS">
			<qry:xquery>
				for $r in sql('		
			SELECT 
				TTA02_HORARIOS.c_horario,
				TTA02_HORARIOS.d_horario,
				TTA02_ESCUADRAS.c_escuadra,
				TTA02_ESCUADRAS.d_escuadra,
				TTA04_HORARIOSPERS.oi_personal_emp,
				TTA04_HORARIOSPERS.f_fechaInicio as f_fechaInicio,
				TTA04_HORARIOSPERS.f_fechaFin,
				TTA04_HORARIOSPERS.oi_escuadra,
				ORG03_EMPRESAS.c_empresa,
				ORG03_EMPRESAS.d_empresa,
	 
				PER02_PERSONAL_EMP.e_numero_legajo, 
				PER01_PERSONAL.d_ape_y_nom  
			FROM 	
				TTA04_HORARIOSPERS,
				TTA02_HORARIOS,
				TTA02_ESCUADRAS,
				ORG03_EMPRESAS, 
				PER02_PERSONAL_EMP, 
				PER01_PERSONAL 
			JOIN  
				TTA04_HORARIOSPERS.oi_horario INNER TTA02_HORARIOS.oi_horario,
				TTA04_HORARIOSPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa, 
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
				TTA04_HORARIOSPERS.oi_escuadra LEFT OUTER TTA02_ESCUADRAS.oi_escuadra
	 	
			WHERE 
				TTA04_HORARIOSPERS.oi_personal_emp in ({%=#PARAM:@values%}) AND
				(TTA04_HORARIOSPERS.f_fechafin &gt;= {Datetime(Number(Datetime(#FILTRO:@fe_desde)+1))} or isnull(TTA04_HORARIOSPERS.f_fechafin))
				AND TTA04_HORARIOSPERS.f_fechaInicio &lt;= {Datetime(Number(Datetime(#FILTRO:@fe_hasta)))}	
			order by e_numero_legajo asc, f_fechaInicio	ASC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="HOR">
					<qry:attribute name="legajo" value="'(' + $r/@c_empresa + ' - ' + $r/@e_numero_legajo + ') ' + $r/@d_ape_y_nom"/>
					<qry:attribute name="empresa" value="concat('[',$r/@c_empresa,'] ',$r/@d_empresa)"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="orderby" value="$r/@c_empresa + '_' + $r/@e_numero_legajo+'_'+$r/@f_fechaInicio"/>
					<qry:attribute name="horario" value="$r/@d_horario + '  ' + iif($r/@oi_escuadra!='',$r/@d_escuadra,'')"/>
					<qry:attribute name="f_desde" value="format_date($r/@f_fechaInicio, 'dd/mm/yyyy')"/>
					<qry:if test="$r/@f_fechaFin!=''">
						<qry:then>
							<qry:attribute name="f_hasta" value="format_date(datetime(number(datetime($r/@f_fechaFin))-1), 'dd/mm/yyyy')"/>
						</qry:then>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
