<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.LegajosConceptos.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;FILTRO detalle=&quot;1&quot; agrupa=&quot;1&quot; f_hasta=&quot;20170831&quot; f_desde=&quot;20170801&quot; oi_liquidacion=&quot;304&quot;&gt;&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW id=&quot;170&quot; /&gt;&lt;ROW id=&quot;173&quot; /&gt;&lt;/ROWS&gt;&lt;CONC nmd-col=&quot;1&quot;&gt;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Normal&quot; id=&quot;1000&quot; /&gt;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Horas compensadas&quot; id=&quot;1339&quot; /&gt;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Ausencia Injustificada&quot; id=&quot;1001&quot; /&gt;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Excedente&quot; id=&quot;1003&quot; /&gt;&lt;/CONC&gt;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<REPORT label="Legajos por Conceptos">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="DATOS" type="title">
						<COLS>
							<COL name="f_des" label="Fecha Desde" type="date"/>
							<COL name="f_has" label="Fecha Hasta" type="date"/>
							<COL name="procesamiento" label="Procesamiento"/>
						</COLS>
						<GROUP tag="REP" type="title">
							<COLS>
								<qry:if test="#FILTRO:@agrupa != '1'">
									<qry:then>
										<COL name="conceptos" label="Conceptos" style="width:20%"/>
									</qry:then>
								</qry:if>
							</COLS>
							<qry:if test="#FILTRO:@agrupa = '1'">
								<qry:then>
									<GROUP tag="CON" type="title">
										<COLS>
											<COL name="concepto" label="Concepto" style="font-weight:bold"/>
										</COLS>
										<qry:if test="#FILTRO:@detalle = '1'">
											<qry:then>
												<GROUP tag="LEG" type="title">
													<COLS>
														<COL name="legajo" label="Detalle de"/>
														<COL name="total" label="Total"/>
													</COLS>
													<GROUP tag="VAL" type="table" style="width:40%">
														<COLS>
															<COL name="fecha" label="Fecha" style="text-align:center" type="date"/>
															<COL name="valor" label="Valor" style="text-align:center"/>
														</COLS>
													</GROUP>
												</GROUP>
											</qry:then>
											<qry:else>
												<GROUP tag="LEG" type="table" style="width:40%">
													<COLS>
														<COL name="empresa" label="Empresa"/>
														<COL name="e_numero_legajo" label="N&#250;mero de Legajo" style="text-align:center"/>
														<COL name="d_ape_y_nom" label="Apellido y Nombre"/>
														<COL name="total" label="Total" style="text-align:center"/>
													</COLS>
												</GROUP>
											</qry:else>
										</qry:if>
									</GROUP>
								</qry:then>
								<qry:else>
									<GROUP tag="LEG" type="table" style="width:70%">
										<COLS>
											<COL name="empresa" label="Empresa"/>
											<COL name="e_numero_legajo" label="N&#250;mero de Legajo" style="width:10%; text-align:center"/>
											<COL name="d_ape_y_nom" label="Apellido y Nombre" style="width:35%"/>
										</COLS>
									</GROUP>
								</qry:else>
							</qry:if>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<DATOS>
						<qry:attribute name="f_des" value="format_date(#PARAM:FILTRO/@f_desde, 'dd/mm/yyyy')"/>
						<qry:attribute name="f_has" value="format_date(#PARAM:FILTRO/@f_hasta, 'dd/mm/yyyy')"/>
						<qry:insert-select doc-path="#PARAM:" name="QRY_PROCESO"/>
						<qry:insert-select name="qry_split" doc-path="#PARAM:FILTRO"/>
					</DATOS>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_split">
			<qry:xquery>
				for $r in split('100;{%= string(#SOURCE:ROWS/ROW/@id) %}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute name="oi_clase_org" value="#SOURCE:@oi_clase_org"/>
						<qry:attribute name="ausencias" value="#SOURCE:@ausencias"/>
						<qry:attribute name="presencias" value="#SOURCE:@presencias"/>
						<qry:attribute name="tardanzas" value="#SOURCE:@tardanzas"/>
						<qry:attribute name="licencias" value="#SOURCE:@licencias"/>
						<qry:attribute name="gcustom" value="#SOURCE:@gcustom"/>
						<qry:attribute name="f_desde" value="#SOURCE:@f_desde"/>
						<qry:attribute name="f_hasta" value="#SOURCE:@f_hasta"/>
						<qry:attribute name="oi_liquidacion" value="#SOURCE:@oi_liquidacion"/>
						<qry:attribute name="agrupa" value="#SOURCE:@agrupa"/>
						<qry:attribute name="nulos" value="#SOURCE:@nulos"/>
						<qry:attribute name="selected" value="#SOURCE:@selected"/>
						<qry:attribute name="gpers" value="#SOURCE:@gpers"/>
						<qry:attribute name="empresa" value="#SOURCE:@empresa"/>
						<qry:attribute name="activos" value="#SOURCE:@activos"/>
						<qry:attribute name="nombre" value="#SOURCE:@nombre"/>
						<qry:attribute name="documento" value="#SOURCE:@documento"/>
						<qry:attribute name="grupo_sanguineo" value="#SOURCE:@grupo_sanguineo"/>
						<qry:attribute name="listlegajos" value="#SOURCE:@listlegajos"/>
						<qry:attribute name="sexo" value="#SOURCE:@sexo"/>
						<qry:attribute name="oi_indic_activo" value="#SOURCE:@oi_indic_activo"/>
						<qry:attribute name="egresado" value="#SOURCE:@egresado"/>
						<qry:attribute name="oi_forma_pago" value="#SOURCE:@oi_forma_pago"/>
						<qry:attribute name="fecha_desde" value="#SOURCE:@fecha_desde"/>
						<qry:attribute name="oi_tipo_personal" value="#SOURCE:@oi_tipo_personal"/>
						<qry:attribute name="fecha_hasta" value="#SOURCE:@fecha_hasta"/>
						<qry:attribute name="oi_centro_costo" value="#SOURCE:@oi_centro_costo"/>
						<qry:attribute name="oi_convenio" value="#SOURCE:@oi_convenio"/>
						<qry:attribute name="soloconvenio" value="#SOURCE:@soloconvenio"/>
						<qry:attribute name="oi_categoria" value="#SOURCE:@oi_categoria"/>
						<qry:attribute name="oi_ubicacion_desde" value="#SOURCE:@oi_ubicacion_desde"/>
						<qry:attribute name="oi_ubicacion_hasta" value="#SOURCE:@oi_ubicacion_hasta"/>
						<qry:attribute name="oi_estructura" value="#SOURCE:@oi_estructura"/>
						<qry:attribute name="escructura_childs" value="#SOURCE:@escructura_childs"/>
						<qry:attribute name="oi_contrato" value="#SOURCE:@oi_contrato"/>
						<qry:attribute name="oi_afjp" value="#SOURCE:@oi_afjp"/>
						<qry:attribute name="oi_obra_social" value="#SOURCE:@oi_obra_social"/>
						<qry:attribute name="oi_sindicato" value="#SOURCE:@oi_sindicato"/>
						<qry:attribute name="l_afiliado_sind" value="#SOURCE:@l_afiliado_sind"/>
						<qry:attribute name="legajo_reloj_desde" value="#SOURCE:@legajo_reloj_desde"/>
						<qry:attribute name="legajo_reloj_hasta" value="#SOURCE:@legajo_reloj_hasta"/>
						<qry:attribute name="chksinreloj" value="#SOURCE:@chksinreloj"/>
						<qry:attribute name="tarjeta_desde" value="#SOURCE:@tarjeta_desde"/>
						<qry:attribute name="tarjeta_hasta" value="#SOURCE:@tarjeta_hasta"/>
						<qry:attribute name="chksintarjeta" value="#SOURCE:@chksintarjeta"/>
						<qry:attribute name="oi_horario" value="#SOURCE:@oi_horario"/>
						<qry:attribute name="oi_escuadra" value="#SOURCE:@oi_escuadra"/>
						<qry:attribute name="oi_grupo_horario" value="#SOURCE:@oi_grupo_horario"/>
						<qry:attribute name="tipo" value="#SOURCE:@tipo"/>
						<qry:attribute name="detalle" value="#SOURCE:@detalle"/>
						<qry:attribute name="values" value="$r/@value"/>
						<qry:insert-element doc-path="#SOURCE:CONC"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PROCESO" doc="PARAM">
			<qry:xquery>
				for $r in sql('		

SELECT 
TTA09_LIQUIDACION.c_liquidacion,
TTA09_LIQUIDACION.d_liquidacion

FROM
TTA09_LIQUIDACION

WHERE
TTA09_LIQUIDACION.oi_liquidacion = {#FILTRO:@oi_liquidacion}

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@c_liquidacion + ' - ' + $r/@d_liquidacion" name="procesamiento"/>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO values=&quot;170,173&quot; detalle=&quot;1&quot; agrupa=&quot;1&quot; oi_liquidacion=&quot;304&quot; f_hasta=&quot;20170831&quot; f_desde=&quot;20170801&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&lt;CONC nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Normal&quot; id=&quot;1000&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Horas compensadas&quot; id=&quot;1339&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Ausencia Injustificada&quot; id=&quot;1001&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;C c_coleccion=&quot;fecha&quot; DES=&quot;Excedente&quot; id=&quot;1003&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&lt;/CONC&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<qry:element name="REP">
				<qry:attribute name="detalle" value="iif(#FILTRO:@detalle='1', 'Si', 'No')"/>
				<!--qry:attribute name="f_des" value="format_date(#FILTRO:@f_desde, 'dd/mm/yyyy')"/-->
				<!--qry:attribute name="f_has" value="format_date(#FILTRO:@f_hasta, 'dd/mm/yyyy')"/-->
				<qry:insert-select doc-path="#FILTRO:" name="QRY_PROCESO"/>
				<qry:if test="#FILTRO:@agrupa = '1'">
					<qry:then>
						<qry:create-doc name="PER"/>
						<qry:insert-select doc-path="" name="QRY_LEGAJOS_SOLOS" to-element="$PER"/>
						<qry:insert-select doc-path="#PER:" name="QRY_CONCEPTOS"/>
					</qry:then>
					<qry:else>
						<qry:insert-select doc-path="" name="QRY_PARAM_CONC"/>
						<qry:insert-select doc-path="" name="QRY_LEGAJOS_NOAGR"/>
					</qry:else>
				</qry:if>
			</qry:element>
		</qry:main>
		<qry:select doc="PER" name="QRY_CONCEPTOS">
			<qry:xquery>
				for $r in sql('

SELECT 
TTA15_CONCEPTOS.oi_concepto,
TTA15_CONCEPTOS.c_concepto,
TTA15_CONCEPTOS.d_concepto,
TTA15_CONCEPTOS.e_mostrar,
TTA15_CONCEPTOS.c_unidad								

FROM 
TTA15_CONCEPTOS 

WHERE
TTA15_CONCEPTOS.e_mostrar != 0								
    		AND TTA15_CONCEPTOS.oi_concepto in ({%=string(#FILTRO:CONC/C/@id) %})

ORDER BY 
e_mostrar ASC

')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<CON qry-delete-child="1">
					<qry:attribute value="$r/@oi_concepto" name="oi_concepto"/>
					<qry:attribute value="$r/@c_concepto + ' - ' + $r/@d_concepto + ' ('+$r/@c_unidad+')'" name="concepto"/>
					<qry:if test="#FILTRO:@detalle= '1'">
						<qry:then>
							<qry:insert-select name="split" doc-path="$r"/>
							<!--qry:insert-select doc-path="$r" name="QRY_DETALLES"/-->
						</qry:then>
						<qry:else>
							<qry:insert-element doc-path="$PER/LEG"/>
							<qry:insert-select doc-path="." name="QRY_LEGAJOS"/>
						</qry:else>
					</qry:if>
				</CON>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PARAM_CONC" doc="">
			<qry:xquery>
				for $r in #FILTRO:CONC/C
			</qry:xquery>
			<qry:out>
				<qry:attribute value="iif(./@conceptos != '', ./@conceptos + '&lt;br/&gt;' + $r/@DES, '&lt;br/&gt;' + $r/@DES)" name="conceptos"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PROCESO" doc="PARAM">
			<qry:xquery>
				for $r in sql('		

SELECT 
TTA09_LIQUIDACION.c_liquidacion,
TTA09_LIQUIDACION.d_liquidacion

FROM
TTA09_LIQUIDACION

WHERE
TTA09_LIQUIDACION.oi_liquidacion = {#FILTRO:@oi_liquidacion}

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@c_liquidacion + ' - ' + $r/@d_liquidacion" name="procesamiento"/>
			</qry:out>
		</qry:select>
		<qry:select doc="" name="QRY_LEGAJOS_NOAGR">
			<qry:xquery>
				for $r in sql('

SELECT 				
ORG03_EMPRESAS.c_empresa, 
ORG03_EMPRESAS.d_empresa,
PER02_PERSONAL_EMP.e_numero_legajo,
PER01_PERSONAL.d_ape_y_nom

FROM 
TTA10_CONC_PER, 
TTA15_CONCEPTOS,
TTA10_LIQUIDACPERS, 
PER02_PERSONAL_EMP, 
PER01_PERSONAL, 
ORG03_EMPRESAS

JOIN
TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto,
TTA10_LIQUIDACPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal

WHERE
TTA15_CONCEPTOS.e_mostrar != 0 
AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde}
    		AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}				
AND TTA10_CONC_PER.oi_concepto in ({%=string(#FILTRO:CONC/C/@id)%})				     					
AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=string(#FILTRO:@values)%})
{%? (#FILTRO:@oi_liquidacion != '')
{% AND TTA10_LIQUIDACPERS.oi_liquidacion = {#FILTRO:@oi_liquidacion} %}
{% %}
%}

GROUP BY 				
ORG03_EMPRESAS.c_empresa, 
ORG03_EMPRESAS.d_empresa,
PER02_PERSONAL_EMP.e_numero_legajo,
PER01_PERSONAL.d_ape_y_nom

ORDER BY
c_empresa ASC,
e_numero_legajo ASC

')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LEG">
					<qry:attribute name="empresa" value="concat('[',$r/@c_empresa,'] ',$r/@d_empresa)"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LEGAJOS_SOLOS" doc="">
			<qry:xquery>
				for $r in SQL('
 
 			SELECT
      	ORG03_EMPRESAS.c_empresa, 				
ORG03_EMPRESAS.d_empresa,
PER02_PERSONAL_EMP.e_numero_legajo,
PER02_PERSONAL_EMP.oi_personal_emp,
PER01_PERSONAL.d_ape_y_nom

FROM 				
PER02_PERSONAL_EMP, 
PER01_PERSONAL,
ORG03_EMPRESAS 

JOIN				
PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
PER02_PERSONAL_EMP.oi_empresa INNER	ORG03_EMPRESAS.oi_empresa

WHERE			
PER02_PERSONAL_EMP.oi_personal_emp IN ({%=string(#FILTRO:@values)%})

ORDER BY 
c_empresa ASC,
e_numero_legajo ASC

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LEG>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="empresa" value="concat('[',$r/@c_empresa,'] ',$r/@d_empresa)"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="total" value="'---'"/>
					<qry:if test="#FILTRO:@nulos != '1'">
						<qry:then>
							<qry:attribute name="hts:delete" value="1"/>
						</qry:then>
					</qry:if>
				</LEG>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LEGAJOS" doc="PARAM">
			<qry:xquery>
				for $r in SQL('          
               
      SELECT
      	ORG03_EMPRESAS.c_empresa, 				
ORG03_EMPRESAS.d_empresa,
PER02_PERSONAL_EMP.e_numero_legajo,
PER02_PERSONAL_EMP.oi_personal_emp,
PER01_PERSONAL.d_ape_y_nom,
TTA15_CONCEPTOS.c_unidad,								
SUM(TTA10_CONC_PER.n_valor) as n_total

FROM 
TTA10_CONC_PER, 
TTA15_CONCEPTOS,
TTA10_LIQUIDACPERS, 
PER02_PERSONAL_EMP, 
PER01_PERSONAL,
ORG03_EMPRESAS 

JOIN
TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto,				
TTA10_LIQUIDACPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,								
PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal,               				
ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa				

WHERE			
PER02_PERSONAL_EMP.oi_personal_emp IN ({%=string(#FILTRO:@values)%}) 					
AND TTA10_CONC_PER.oi_concepto = {#PARAM:@oi_concepto} 
AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde}
    		AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
{%? (#FILTRO:@oi_liquidacion != '')
{% AND TTA10_LIQUIDACPERS.oi_liquidacion = {#FILTRO:@oi_liquidacion} %}
{% %}
%}

GROUP BY
ORG03_EMPRESAS.c_empresa,
ORG03_EMPRESAS.d_empresa,          
PER02_PERSONAL_EMP.oi_personal_emp,
PER02_PERSONAL_EMP.e_numero_legajo,
PER01_PERSONAL.d_ape_y_nom,
TTA15_CONCEPTOS.c_unidad				

ORDER BY 
c_empresa ASC,
e_numero_legajo ASC

')/ROWS/ROW,		

$s in $PARAM/LEG 
JOIN $r/@oi_personal_emp INNER $s/@oi_personal_emp
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="qry_pegar_legajo" doc-path="$r" to-element="$s"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_DETALLES">
			<!--qry:xquery>
for $r in #FILTRO:@values
</qry:xquery-->
			<qry:out>
				<LEG>
					<qry:attribute name="total" value="0"/>
					<qry:attribute value="#PARAM:@oi_concepto" name="oi_concepto"/>
					<qry:attribute value="#PARAM:@id" name="oi_personal_emp"/>
					<!--OBTIENE EL DETALLE DE VALORES PARA UN CONCEPTO Y UN LEGAJO
Y ACTUALIZA EL TOTAL ACUMULADO DE VALORES-->
					<qry:insert-select name="QRY_VALORES" doc-path="."/>
					<qry:if test="#FILTRO:@nulos = '1' OR @total != 0">
						<qry:then>
							<qry:insert-select name="QRY_LEGAJO_DATOS" doc-path="#PARAM:"/>
							<qry:attribute value="#PARAM:@c_unidad" name="c_unidad"/>
							<!--FORMATEA EL VALOR TOTAL SEGUN LA UNIDAD-->
							<qry:insert-select name="qry_formatear" doc-path="."/>
						</qry:then>
						<qry:else>
							<qry:attribute name="hts:delete" value="1"/>
						</qry:else>
					</qry:if>
				</LEG>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LEGAJO_DATOS" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
 
 			SELECT
      	ORG03_EMPRESAS.c_empresa, 				
ORG03_EMPRESAS.d_empresa,
PER02_PERSONAL_EMP.e_numero_legajo,				
PER01_PERSONAL.d_ape_y_nom

FROM 				
PER02_PERSONAL_EMP, 
PER01_PERSONAL,
ORG03_EMPRESAS 

JOIN				
PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
PER02_PERSONAL_EMP.oi_empresa INNER	ORG03_EMPRESAS.oi_empresa

WHERE			
PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@id}

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="'(' + $r/@c_empresa + ' - ' + $r/@e_numero_legajo +') ' + $r/@d_ape_y_nom" name="legajo"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_VALORES">
			<qry:xquery>
				for $r in sql('

SELECT 								
TTA15_CONCEPTOS.c_unidad,			
TTA10_CONC_PER.e_clave,
TTA10_CONC_PER.n_valor			

FROM 
TTA10_CONC_PER, 
TTA15_CONCEPTOS,
TTA10_LIQUIDACPERS				

JOIN
TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto
  
WHERE				
TTA10_LIQUIDACPERS.oi_personal_emp = {#PARAM:@oi_personal_emp} 					
AND TTA10_CONC_PER.oi_concepto = {#PARAM:@oi_concepto} 
AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde}
    		AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
{%? (#FILTRO:@oi_liquidacion != '')
{% AND TTA10_LIQUIDACPERS.oi_liquidacion = {#FILTRO:@oi_liquidacion} %}
{% %}
%}				
    
GROUP BY
TTA15_CONCEPTOS.c_unidad, 								
TTA10_CONC_PER.e_clave,
TTA10_CONC_PER.n_valor

ORDER BY
e_clave ASC

')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VAL">
					<qry:attribute value="format_date($r/@e_clave, 'dd/mm/yyyy')" name="fecha"/>
					<qry:attribute value="$r/@n_valor" name="valor"/>
					<qry:if test="$r/@c_unidad= 'horas'">
						<qry:then>
							<qry:attribute value="floor($r/@n_valor)" name="horas"/>
							<qry:attribute value="format_number(($r/@n_valor*60) MOD 60,'00')" name="minutos"/>
							<qry:attribute value="@horas + ':' + @minutos" name="valor"/>
						</qry:then>
						<qry:else>
							<qry:if test="$r/@c_unidad= 'pesos'">
								<qry:then>
									<qry:attribute value="format_number(Number($r/@n_valor), '$ ####0,00')" name="valor"/>
								</qry:then>
							</qry:if>
						</qry:else>
					</qry:if>
				</qry:element>
				<qry:attribute name="total" value="number(@total) + number($r/@n_valor)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_formatear" doc="r">
			<qry:out>
				<qry:if test="$r/@c_unidad= 'horas'">
					<qry:then>
						<qry:attribute value="floor($r/@total)" name="horas"/>
						<qry:attribute value="format_number(($r/@total*60) MOD 60,'00')" name="minutos"/>
						<qry:attribute value="@horas + ':' + @minutos" name="total"/>
					</qry:then>
					<qry:else>
						<qry:if test="$r/@c_unidad= 'pesos'">
							<qry:then>
								<qry:attribute value="format_number(Number($r/@total), '$ ####0,00')" name="total"/>
							</qry:then>
							<qry:else>
								<qry:attribute value="$r/@total" name="total"/>
							</qry:else>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_pegar_legajo" doc="r">
			<qry:out>
				<qry:attribute name="hts:delete" value="0"/>
				<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				<qry:attribute name="empresa" value="concat('[',$r/@c_empresa,'] ',$r/@d_empresa)"/>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute value="$r/@n_total" name="total"/>
				<qry:if test="$r/@c_unidad= 'horas'">
					<qry:then>
						<qry:attribute value="floor($r/@n_total)" name="horas"/>
						<qry:attribute value="format_number(($r/@n_total*60) MOD 60,'00')" name="minutos"/>
						<qry:attribute value="@horas + ':' + @minutos" name="total"/>
					</qry:then>
					<qry:else>
						<qry:if test="$r/@c_unidad= 'pesos'">
							<qry:then>
								<qry:attribute value="format_number(Number($r/@n_total), '$ ####0,00')" name="total"/>
							</qry:then>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="split" doc="SOURCE">
			<qry:xquery>
				for $r in split('1;{%= string(#FILTRO:@values) %}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute-doc doc="SOURCE" name="id" value="$r/@value"/>
				<qry:insert-select doc-path="#SOURCE:" name="QRY_DETALLES"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
