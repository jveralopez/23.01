							<xsl:value-of select="'Cod. Puesto'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Puesto'"/>
						</th>
					</xsl:if>
					<xsl:if test="./@chkPosicionActual = '1'">
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Cod. Posici&#243;n'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Posici&#243;n'"/>
						</th>
					</xsl:if>
					<xsl:if test="./@chkDepartamentoActual = '1'">
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Cod. Departamento'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Departamento'"/>
						</th>
					</xsl:if>
					<xsl:if test="./@chkSectorActual = '1'">
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Cod. Sector'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Sector'"/>
						</th>
					</xsl:if>
					<xsl:if test="./@chkUbicacionActual = '1'">
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Cod. Ubicaci&#243;n'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Ubicaci&#243;n'"/>
						</th>
					</xsl:if>
					<xsl:if test="./@chkCtroCostoActual = '1'">
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Cod. Centro de Costo'"/>
						</th>
						<th style="text-align:left;background-color:#D8D8D8">
							<xsl:value-of select="'Centro de Costo'"/>
						</th>
					</xsl:if>
					<xsl:for-each select="./CONC/C">
						<th style="background-color:#D8D8D8">
							<xsl:value-of select="./@d_concepto"/>
						</th>
					</xsl:for-each>
					<xsl:for-each select="./CONC/U[@ok=1]">
						<th style="background-color:#D8D8D8">
							<xsl:value-of select="'TOTAL '"/>
							<xsl:value-of select="./@c_unidad"/>
						</th>
					</xsl:for-each>
				</tr>
				<xsl:call-template name="LEG"/>
				<!--xsl:apply-templates select="./LEG"/-->
			</table>
			<!--/xsl:if-->
		</xsl:template>
		<xsl:template name="LEG" match="LEG">
			<xsl:for-each select="./LEG">
				<tr>
					<th style="white-space:nowrap;font-weight: normal;text-align:left;">
						<xsl:value-of select="./@legajo"/>
					</th>
					<th style="white-space:nowrap;font-weight: normal;text-align:left;">
						<xsl:value-of select="./@nomyap"/>
					</th>
					<xsl:if test="../@chkPosicionActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_posicion"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_posicion"/>
						</th>
					</xsl:if>
					<xsl:if test="../@chkPuestoActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_puesto"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_puesto"/>
						</th>
					</xsl:if>
					<xsl:if test="../@chkDepartamentoActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_departamento"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_departamento"/>
						</th>
					</xsl:if>
					<xsl:if test="../@chkSectorActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_sector"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_sector"/>
						</th>
					</xsl:if>
					<xsl:if test="../@chkUbicacionActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_ubicacion"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_ubicacion"/>
						</th>
					</xsl:if>
					<xsl:if test="../@chkCtroCostoActual = '1'">
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@c_centro_costo"/>
						</th>
						<th style="white-space:nowrap;font-weight: normal;text-align:left;">
							<xsl:value-of select="./@d_centro_costo"/>
						</th>
					</xsl:if>
					<xsl:for-each select="./CONC">
						<th style="white-space:nowrap;font-weight: normal;">
							<xsl:value-of select="./@calc"/>
						</th>
					</xsl:for-each>
					<xsl:for-each select=".">
						<th style="white-space:nowrap;font-weight: normal;">
							<xsl:choose>
								<xsl:when test="./@formato_hora='NUM'">
									<xsl:variable name="total_decimal" select="number(./@total)"/>
									<xsl:variable name="horas" select="floor($total_decimal)"/>
									<xsl:variable name="minutos_decimal" select="$total_decimal - $horas"/>
									<xsl:variable name="minutos" select="round($minutos_decimal * 60)"/>
									<xsl:value-of select="concat($horas, ',', format-number($minutos, '00'))"/>
								</xsl:when>
								<xsl:when test="./@formato_hora='HHMM'">
									<xsl:variable name="total_decimal" select="number(./@total)"/>
									<xsl:variable name="horas" select="floor($total_decimal)"/>
									<xsl:variable name="minutos_decimal" select="$total_decimal - $horas"/>
									<xsl:variable name="minutos" select="round($minutos_decimal * 60)"/>
									<xsl:value-of select="concat($horas, ':', format-number($minutos, '00'))"/>
								</xsl:when>
							</xsl:choose>
						</th>
					</xsl:for-each>
				</tr>
			</xsl:for-each>
			<tr>
				<th style="white-space:nowrap;font-weight: bold;text-align:right;">
					<xsl:attribute name="colspan">
						<xsl:value-of select="./@cant_col"/>
					</xsl:attribute>
					<xsl:value-of select="'TOTALES'"/>
				</th>
				<xsl:for-each select="./CC">
					<th style="white-space:nowrap;font-weight: normal;">
						<xsl:value-of select="./@calc"/>
					</th>
				</xsl:for-each>
				<xsl:for-each select="./UN">
					<th style="white-space:nowrap;font-weight: normal;">
						<xsl:value-of select="./@calc"/>
					</th>
				</xsl:for-each>
			</tr>
		</xsl:template>
	</html:xslt>
</html:html>
