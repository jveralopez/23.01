<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Tiempos_Trabajados.ConceptosLegajosHTML.rpt">
	<html:query declare="&lt;FILTRO formato_hora=&quot;NUM&quot; chkPuestoActual=&quot;0&quot; empresa=&quot;1&quot; f_hasta=&quot;20250930&quot; f_desde=&quot;20241203&quot;&gt;&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW id=&quot;25&quot; /&gt;&lt;ROW id=&quot;32&quot; /&gt;&lt;ROW id=&quot;64&quot; /&gt;&lt;ROW id=&quot;145&quot; /&gt;&lt;ROW id=&quot;146&quot; /&gt;&lt;ROW id=&quot;178&quot; /&gt;&lt;ROW id=&quot;294&quot; /&gt;&lt;/ROWS&gt;&lt;CONC nmd-col=&quot;1&quot;&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Normal&quot; c_concepto=&quot;N&quot; DES=&quot;Normal&quot; id=&quot;1000&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Horas de Domingo&quot; c_concepto=&quot;DOM&quot; DES=&quot;Horas de Domingo&quot; id=&quot;1027&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Hora Extra al 50%&quot; c_concepto=&quot;HE50&quot; DES=&quot;Hora Extra al 50%&quot; id=&quot;1021&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Horas Extras al 50% Sabados plus exento IG&quot; c_concepto=&quot;HE50ex&quot; DES=&quot;Horas Extras al 50% Sabados plus exento IG&quot; id=&quot;1226&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Hora Viaje al 50%&quot; c_concepto=&quot;HV50&quot; DES=&quot;Hora Viaje al 50%&quot; id=&quot;1426&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Hora Extra al 100%&quot; c_concepto=&quot;HE100&quot; DES=&quot;Hora Extra al 100%&quot; id=&quot;1020&quot; /&gt;&lt;C c_unidad=&quot;horas&quot; c_coleccion=&quot;fecha&quot; d_concepto=&quot;Excedente&quot; c_concepto=&quot;E&quot; DES=&quot;Excedente&quot; id=&quot;1003&quot; /&gt;&lt;/CONC&gt;&lt;LIQS /&gt;&lt;/FILTRO&gt;&#13;&#10;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<qry:element name="REP">
				<qry:attribute name="chkPuestoActual" value="#FILTRO:@chkPuestoActual"/>
				<qry:attribute name="chkPosicionActual" value="#FILTRO:@chkPosicionActual"/>
				<qry:attribute name="chkDepartamentoActual" value="#FILTRO:@chkDepartamentoActual"/>
				<qry:attribute name="chkSectorActual" value="#FILTRO:@chkSectorActual"/>
				<qry:attribute name="chkUbicacionActual" value="#FILTRO:@chkUbicacionActual"/>
				<qry:attribute name="chkCtroCostoActual" value="#FILTRO:@chkCtroCostoActual"/>
				<qry:attribute name="cant_col" value="2"/>
				<qry:if test="@chkPuestoActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:if test="@chkPosicionActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:if test="@chkDepartamentoActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:if test="@chkSectorActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:if test="@chkUbicacionActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:if test="@chkCtroCostoActual = '1'">
					<qry:then>
						<qry:attribute name="cant_col" value="number(@cant_col) + 2"/>
					</qry:then>
				</qry:if>
				<qry:append-doc name="CONCEPTOS" doc-path="."/>
				<CONC>
					<qry:insert-select name="QRY_CONC_FILTER" doc-path="$FILTRO/CONC"/>
					<qry:insert-select name="QRY_CONC_UNIDADES" doc-path="$FILTRO/CONC"/>
				</CONC>
				<qry:attribute name="f_des" value="format_date(#FILTRO:@f_desde, 'dd/mm/yyyy')"/>
				<qry:attribute name="f_has" value="format_date(#FILTRO:@f_hasta, 'dd/mm/yyyy')"/>
				<qry:if test="@f_des!='' AND @f_has!=''">
					<qry:then>
						<qry:attribute name="fechaINC" value="1"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="fechaINC" value="0"/>
					</qry:else>
				</qry:if>
				<qry:if test="#FILTRO:LIQS/PROC/@id!=''">
					<qry:then>
						<qry:attribute name="proc" value="1"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="proc" value="0"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="f_has" value="format_date(#FILTRO:@f_hasta, 'dd/mm/yyyy')"/>
				<qry:insert-select name="QRY_SPLIT" doc-path="."/>
				<qry:insert-select name="QRY_FORMAT" doc-path="$CONCEPTOS/CONC"/>
				<qry:insert-select name="QRY_FORMAT_UN" doc-path="$CONCEPTOS/CONC"/>
				<qry:insert-select name="QRY_LEGAJO" doc-path="#FILTRO:ROWS/ROW"/>
				<qry:if test="@proc!=0">
					<qry:then>
						<LIQS>
							<qry:insert-select name="QRY_PROCESO" doc-path="#FILTRO:"/>
						</LIQS>
					</qry:then>
					<qry:else/>
				</qry:if>
				<qry:insert-select name="QRY_EMPRESA" doc-path="#FILTRO:"/>
			</qry:element>
		</qry:main>
		<qry:select name="QRY_PROCESO" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
			SELECT 
				TTA09_LIQUIDACION.c_liquidacion,
				TTA09_LIQUIDACION.d_liquidacion
			FROM
				TTA09_LIQUIDACION
			WHERE
				TTA09_LIQUIDACION.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id) %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<PROC>
					<qry:attribute value="$r/@c_liquidacion" name="c_liquidacion"/>
					<qry:attribute value="$r/@d_liquidacion" name="d_liquidacion"/>
				</PROC>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LEGAJO" doc="PARAM">
			<qry:xquery>
				for $r in sql('
			SELECT 
				ORG03_EMPRESAS.c_empresa,
				PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom,
				max(ORG03_UBICACIONES.c_ubicacion) as c_ubicacion, 
				ORG03_UBICACIONES.d_ubicacion,
				ORG08_CS_COSTO.c_centro_costo,
				ORG08_CS_COSTO.d_centro_costo,
				max(P.c_puesto) as c_puesto,
				max(P.d_puesto) as d_puesto,
				max(PO.c_posicion) as c_posicion,
				max(PO.d_posicion) as d_posicion,
				max(D.c_departamento) as c_departamento,
				max(D.d_departamento) as d_departamento,
				max(S.c_sector) as c_sector,
				max(S.d_sector) as d_sector				
			FROM   
				PER02_PERSONAL_EMP, 
				PER01_PERSONAL, 
				ORG03_EMPRESAS,
				ORG03_UBICACIONES,
				TTA15_CONCEPTOS, 
				TTA10_CONC_PER,
				TTA10_LIQUIDACPERS,
				ORG08_CS_COSTO,
				ORG03_UBICACIONES as UBI,
	   		ORG04_PUESTOS as P,
			ORG04_POSICIONES as PO,
			ORG51_DEPARTAMENTOS as D,
			ORG51_SECTORES as S
			JOIN 
				TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
				TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto,
				TTA10_LIQUIDACPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
				PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal,
				PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER ORG03_UBICACIONES.oi_ubicacion,
				PER02_PERSONAL_EMP.oi_ctro_costo_ult INNER ORG08_CS_COSTO.oi_centro_costo,
				PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER UBI.oi_ubicacion,
			 PER02_PERSONAL_EMP.oi_puesto_ult LEFT OUTER  P.oi_puesto,
			PER02_PERSONAL_EMP.oi_posicion_ult LEFT OUTER  PO.oi_posicion,
			PO.oi_departamento LEFT OUTER D.oi_departamento,
			PO.oi_sector LEFT OUTER S.oi_sector
			WHERE
				1 = 1
    			AND TTA10_CONC_PER.oi_concepto in ({%=string(#FILTRO:CONC/C/@id) %})
    			AND PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@id}
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id)%}) 
				   AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
				%}	
				
				{%  %} 
				
				%}
				
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=0) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id) %}) %}	
				
				{%  %} 
				
				%}
				
				
				{%? (#CONCEPTOS:@proc=0 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta} %}	
				
				{%  %} 
				
				%}										
				
			GROUP BY 
				ORG03_EMPRESAS.c_empresa,
				PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom,
				ORG03_UBICACIONES.d_ubicacion,
				ORG08_CS_COSTO.c_centro_costo,
				ORG08_CS_COSTO.d_centro_costo
				
			ORDER BY
				e_numero_legajo ASC
		')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LEG">
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
					<qry:attribute value="$r/@e_numero_legajo " name="legajo"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="nomyap"/>
					<qry:attribute value="$r/@c_ubicacion" name="c_ubicacion"/>
					<qry:attribute value="$r/@d_ubicacion" name="d_ubicacion"/>
					<qry:attribute value="$r/@c_centro_costo" name="c_centro_costo"/>
					<qry:attribute value="$r/@d_centro_costo" name="d_centro_costo"/>
					<qry:attribute value="$r/@c_posicion" name="c_posicion"/>
					<qry:attribute value="$r/@d_posicion" name="d_posicion"/>
					<qry:attribute value="$r/@c_puesto" name="c_puesto"/>
					<qry:attribute value="$r/@d_puesto" name="d_puesto"/>
					<qry:attribute value="$r/@c_departamento" name="c_departamento"/>
					<qry:attribute value="$r/@d_departamento" name="d_departamento"/>
					<qry:attribute value="$r/@c_sector" name="c_sector"/>
					<qry:attribute value="$r/@d_sector" name="d_sector"/>
					<qry:insert-select name="QRY_CONC" doc-path="#CONCEPTOS:"/>
					<qry:insert-select name="QRY_CONC_UN" doc-path="#CONCEPTOS:"/>
					<qry:insert-select name="QRY_CONCEPTOS" doc-path="."/>
					<qry:attribute value="'total'" name="qry-sum"/>
					<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
					<!-- <qry:insert-select name="QRY_TOT_LEG" doc-path="."/> -->
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_EMPRESA" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
			SELECT 
				ORG03_EMPRESAS.c_empresa,
				ORG03_EMPRESAS.d_empresa
			FROM
				ORG03_EMPRESAS
			WHERE
				ORG03_EMPRESAS.oi_empresa = {#FILTRO:@empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@c_empresa + ' - ' + $r/@d_empresa" name="empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_CONCEPTOS">
			<qry:xquery>
				for $r in sql('
			SELECT 
				TTA15_CONCEPTOS.oi_concepto,
				TTA15_CONCEPTOS.c_concepto,
				TTA15_CONCEPTOS.d_concepto,
				TTA15_CONCEPTOS.e_mostrar,
				TTA15_CONCEPTOS.c_unidad,
				sum(TTA10_CONC_PER.n_valor) as n_valor				
			FROM 
				TTA15_CONCEPTOS, 
				TTA10_CONC_PER,
				TTA10_LIQUIDACPERS
			JOIN 
				TTA15_CONCEPTOS.oi_concepto INNER TTA10_CONC_PER.oi_concepto,
				TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers
			WHERE
				1 = 1
    			AND TTA10_CONC_PER.oi_concepto in ({%=string(#FILTRO:CONC/C/@id) %})
    			AND TTA10_LIQUIDACPERS.oi_personal_emp = {#PARAM:@oi_personal_emp}
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id)%}) 
				   AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
				%}	
				
				{%  %} 
				
				%}
				
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=0) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id) %}) %}	
				
				{%  %} 
				
				%}
				
				
				{%? (#CONCEPTOS:@proc=0 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta} %}	
				
				{%  %} 
				
				%}
			GROUP BY    
				TTA15_CONCEPTOS.oi_concepto,
				TTA15_CONCEPTOS.c_concepto,
				TTA15_CONCEPTOS.d_concepto,
				TTA15_CONCEPTOS.e_mostrar,
				TTA15_CONCEPTOS.c_unidad
			ORDER BY 
				e_mostrar ASC
		')ROWS/ROW,
		$s in $PARAM/CONC
		join $r/@c_concepto inner $s/@c_concepto
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="pegar_conceptos" doc-path="$r" to-element="$s"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONC" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:CONC/C[@ok=1]
			</qry:xquery>
			<qry:out>
				<CONC>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
				</CONC>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONC_UN" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:CONC/U[@ok=1]
			</qry:xquery>
			<qry:out>
				<UN>
					<qry:attribute name="c_unidad" value="$r/@c_unidad"/>
				</UN>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_SPLIT" doc="PARAM">
			<qry:xquery>
				for $r in SPLIT('50;{%=string(#FILTRO:ROWS/ROW/@id) %}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="values" value="$r/@value"/>
				<qry:insert-select name="QRY_TOT_CONC" doc-path="."/>
				<qry:insert-select name="QRY_TOT_UNID" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FORMAT" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:C
			</qry:xquery>
			<qry:out>
				<CC>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute name="valor" value="$r/@valor"/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:attribute name="ok" value="1"/>
					<qry:if test="$r/@c_unidad='horas' and $r/@valor !=''">
						<qry:then>
							<qry:attribute value="number($r/@valor)" name="total"/>
							<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
							<qry:if test="@formato_hora = 'HHMM'">
								<qry:then>
									<qry:attribute value="floor($r/@valor)" name="horas"/>
									<qry:attribute value="format_number(round(($r/@valor - @horas) * 60),'00')" name="minutos"/>
									<qry:attribute value="@horas + ':' + @minutos" name="calc"/>
								</qry:then>
								<qry:else>
									<qry:attribute value="format-number($r/@valor,5,2,',','.','')" name="calc"/>
								</qry:else>
							</qry:if>
							<qry:attribute name="hts:delete" value="0"/>
						</qry:then>
						<qry:else>
							<qry:if test="$r/@c_unidad='pesos' and $r/@valor !=''">
								<qry:then>
									<qry:attribute value="format_number(Number($r/@valor), '$ ####0,00')" name="calc"/>
									<qry:attribute name="hts:delete" value="0"/>
								</qry:then>
								<qry:else>
									<qry:if test="$r/@c_unidad='cantidad' and $r/@valor !=''">
										<qry:then>
											<qry:attribute value="$r/@valor" name="calc"/>
											<qry:attribute name="hts:delete" value="0"/>
											<qry:attribute name="ok" value="0"/>
										</qry:then>
										<qry:else>
											<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
											<qry:if test="@formato_hora = 'HHMM'">
												<qry:then>
													<qry:if test="$r/@valor !=''">
														<qry:then>
															<qry:attribute value="$r/@valor + ' ' + $r/@c_unidad" name="calc"/>
														</qry:then>
														<qry:else>
															<qry:attribute value="''" name="calc"/>
														</qry:else>
													</qry:if>
												</qry:then>
												<qry:else>
													<qry:if test="$r/@valor !=''">
														<qry:then>
															<qry:attribute value="$r/@valor" name="calc"/>
														</qry:then>
														<qry:else>
															<qry:attribute value="''" name="calc"/>
														</qry:else>
													</qry:if>
												</qry:else>
											</qry:if>
											<qry:if test="$r/@valor !=''">
												<qry:then>
													<qry:attribute name="hts:delete" value="0"/>
												</qry:then>
												<qry:else>
													<qry:attribute name="hts:delete" value="1"/>
												</qry:else>
											</qry:if>
										</qry:else>
									</qry:if>
								</qry:else>
							</qry:if>
						</qry:else>
					</qry:if>
				</CC>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FORMAT_UN" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:U
			</qry:xquery>
			<qry:out>
				<UN qry-sum="calcQRY_FORMAT_UN">
					<qry:attribute name="valor" value="$r/@valor"/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:attribute name="ok" value="1"/>
					<qry:if test="$r/@c_unidad='horas' and $r/@valor !=''">
						<qry:then>
							<qry:attribute value="number($r/@valor)" name="total"/>
							<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
							<qry:if test="@formato_hora = 'HHMM'">
								<qry:then>
									<qry:attribute value="floor($r/@valor)" name="horas"/>
									<qry:attribute value="format_number(round(($r/@valor - @horas) * 60),'00')" name="minutos"/>
									<qry:attribute value="@horas + ':' + @minutos" name="calc"/>
								</qry:then>
								<qry:else>
									<qry:attribute value="format-number($r/@valor,5,2,',','.','')" name="calc"/>
								</qry:else>
							</qry:if>
							<qry:attribute name="hts:delete" value="0"/>
						</qry:then>
						<qry:else>
							<qry:if test="$r/@c_unidad='pesos' and $r/@valor !=''">
								<qry:then>
									<qry:attribute value="format_number(Number($r/@valor), '$ ####0,00')" name="calc"/>
									<qry:attribute name="hts:delete" value="0"/>
								</qry:then>
								<qry:else>
									<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
									<qry:if test="@formato_hora = 'HHMM'">
										<qry:then>
											<qry:if test="$r/@valor !=''">
												<qry:then>
													<qry:attribute value="$r/@valor + ' ' + $r/@c_unidad" name="calc"/>
												</qry:then>
												<qry:else>
													<qry:attribute value="''" name="calc"/>
												</qry:else>
											</qry:if>
										</qry:then>
										<qry:else>
											<qry:if test="$r/@valor !=''">
												<qry:then>
													<qry:attribute value="$r/@valor" name="calc"/>
												</qry:then>
												<qry:else>
													<qry:attribute value="''" name="calc"/>
												</qry:else>
											</qry:if>
										</qry:else>
									</qry:if>
									<qry:if test="$r/@valor !=''">
										<qry:then>
											<qry:attribute name="hts:delete" value="0"/>
										</qry:then>
										<qry:else>
											<qry:attribute name="hts:delete" value="1"/>
										</qry:else>
									</qry:if>
								</qry:else>
							</qry:if>
						</qry:else>
					</qry:if>
				</UN>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONC_UNIDADES" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:C orderby $r/@c_unidad DESC
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@c_unidad!=@c_unidad_ult">
					<qry:then>
						<U>
							<qry:if test="$r/@c_unidad='cantidad'">
								<qry:then>
									<qry:attribute name="hts:delete" value="1"/>
								</qry:then>
								<qry:else>
									<qry:attribute name="c_unidad" value="$r/@c_unidad"/>
								</qry:else>
							</qry:if>
						</U>
					</qry:then>
					<qry:else/>
				</qry:if>
				<qry:attribute name="c_unidad_ult" value="$r/@c_unidad"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONC_FILTER" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:C
			</qry:xquery>
			<qry:out>
				<C>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute name="c_unidad" value="$r/@c_unidad"/>
				</C>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_TOT_CONC">
			<qry:xquery>
				for $r in sql('
			SELECT 
				TTA15_CONCEPTOS.oi_concepto,
				TTA15_CONCEPTOS.c_concepto,
				TTA15_CONCEPTOS.d_concepto,
				TTA15_CONCEPTOS.e_mostrar,
				TTA15_CONCEPTOS.c_unidad,
				sum(TTA10_CONC_PER.n_valor) as n_valor				
			FROM 
				TTA15_CONCEPTOS, 
				TTA10_CONC_PER,
				TTA10_LIQUIDACPERS,
				ORG03_EMPRESAS,
				PER02_PERSONAL_EMP,
				PER01_PERSONAL
			JOIN 
				TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
				TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto,
				TTA10_LIQUIDACPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
				PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
			WHERE
				1 = 1
    			AND TTA10_CONC_PER.oi_concepto in ({%=string(#FILTRO:CONC/C/@id) %})
    			AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id)%}) 
				   AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
				%}	
				
				{%  %} 
				
				%}
				
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=0) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id) %}) %}	
				
				{%  %} 
				
				%}
				
				
				{%? (#CONCEPTOS:@proc=0 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta} %}	
				
				{%  %} 
				
				%}

			GROUP BY 
				TTA15_CONCEPTOS.oi_concepto,
				TTA15_CONCEPTOS.c_concepto,
				TTA15_CONCEPTOS.d_concepto,
				TTA15_CONCEPTOS.e_mostrar,
				TTA15_CONCEPTOS.c_unidad
			ORDER BY 
				e_mostrar ASC
		')ROWS/ROW,
		$s in $CONCEPTOS/CONC/C
		join $r/@c_concepto inner $s/@c_concepto
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="pegar_totales" doc-path="$r" to-element="$s"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_TOT_UNID">
			<qry:xquery>
				for $r in sql('
			SELECT 
				TTA15_CONCEPTOS.c_unidad,
				sum(TTA10_CONC_PER.n_valor) as n_valor				
			FROM 
				TTA15_CONCEPTOS, 
				TTA10_CONC_PER,
				TTA10_LIQUIDACPERS
			JOIN 
				TTA15_CONCEPTOS.oi_concepto INNER TTA10_CONC_PER.oi_concepto,
				TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers
			WHERE
				1 = 1
    			AND TTA10_CONC_PER.oi_concepto in ({%=string(#FILTRO:CONC/C/@id) %})
    			AND TTA10_LIQUIDACPERS.oi_personal_emp in ({%=#PARAM:@values%})
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id)%}) 
				   AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta}
				%}	
				
				{%  %} 
				
				%}
				
				{%? (#CONCEPTOS:@proc=1 and #CONCEPTOS:@fechaINC=0) 
						
				{% AND TTA10_LIQUIDACPERS.oi_liquidacion in ({%=string(#FILTRO:LIQS/PROC/@id) %}) %}	
				
				{%  %} 
				
				%}
				
				
				{%? (#CONCEPTOS:@proc=0 and #CONCEPTOS:@fechaINC=1) 
						
				{% AND TTA10_CONC_PER.e_clave &gt;= {#FILTRO:@f_desde} AND TTA10_CONC_PER.e_clave &lt;= {#FILTRO:@f_hasta} %}	
				
				{%  %} 
				
				%}

			GROUP BY    
				TTA15_CONCEPTOS.c_unidad
			')ROWS/ROW,
		$s in $CONCEPTOS/CONC/U
		join $r/@c_unidad inner $s/@c_unidad
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="pegar_totales_un" doc-path="$r" to-element="$s"/>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_totales" doc="r">
			<qry:out>
				<qry:attribute name="hts:delete" value="0"/>
				<qry:attribute name="ok" value="1"/>
				<qry:attribute value="number(@valor) + $r/@n_valor" name="valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_totales_un" doc="r">
			<qry:out>
				<qry:attribute name="hts:delete" value="0"/>
				<qry:attribute name="ok" value="1"/>
				<qry:attribute value="number(@valor) + $r/@n_valor" name="valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_conceptos" doc="r">
			<qry:out>
				<qry:attribute value="$r/@c_concepto" name="c_concepto"/>
				<qry:attribute value="$r/@d_concepto" name="d_concepto"/>
				<qry:attribute value="$r/@n_valor" name="valor"/>
				<qry:attribute value="$r/@c_unidad" name="c_unidad"/>
				<qry:if test="@c_unidad='horas'">
					<qry:then>
						<qry:attribute value="number(@total) + number($r/@n_valor)" name="total"/>
						<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
						<qry:if test="@formato_hora = 'HHMM'">
							<qry:then>
								<qry:attribute value="floor($r/@n_valor)" name="horas"/>
								<qry:attribute value="format_number(round(($r/@n_valor - @horas) * 60),'00')" name="minutos"/>
								<qry:attribute value="@horas + ':' + @minutos" name="calc"/>
							</qry:then>
							<qry:else>
								<qry:attribute value="format-number($r/@n_valor,5,2,',','.','')" name="calc"/>
							</qry:else>
						</qry:if>
					</qry:then>
					<qry:else>
						<qry:if test="@c_unidad= 'pesos'">
							<qry:then>
								<qry:attribute value="format_number(Number($r/@n_valor), '$ ####0,00')" name="calc"/>
							</qry:then>
							<qry:else>
								<qry:if test="@c_unidad= 'cantidad'">
									<qry:then>
										<qry:attribute value="Number($r/@n_valor)" name="calc"/>
									</qry:then>
									<qry:else>
										<qry:attribute name="formato_hora" value="#FILTRO:@formato_hora"/>
										<qry:if test="@formato_hora = 'HHMM'">
											<qry:then>
												<qry:attribute value="$r/@n_valor + ' ' + $r/@c_unidad" name="calc"/>
											</qry:then>
											<qry:else>
												<qry:attribute value="$r/@n_valor" name="calc"/>
											</qry:else>
										</qry:if>
									</qry:else>
								</qry:if>
							</qry:else>
						</qry:if>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:query>
