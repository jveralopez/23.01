<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Tiempo_Trabajados.NovedadesGrilla" doc="source">
	<html:query>
		<qry:main doc="SOURCE">
			<REPORT>
				<row id="0"/>
				<row id="1"/>
				<row id="2"/>
				<row id="3"/>
				<row id="4"/>
				<row id="5"/>
				<row id="6"/>
				<row id="7"/>
				<row id="8"/>
				<row id="9"/>
				<row id="10"/>
				<row id="11"/>
				<row id="12"/>
				<row id="13"/>
				<row id="14"/>
				<row id="15"/>
				<row id="16"/>
				<row id="17"/>
				<row id="18"/>
				<row id="19"/>
			</REPORT>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="REPORT">
			<html>
				<head>
					<style>
						.Main {
						background-color: #FFFFFF; 
						cursor: default;
						PADDING-RIGHT: 20px; 
						PADDING-LEFT: 20px; 
						PADDING-BOTTOM: 0px; 
						MARGIN: 0px; 
						PADDING-TOP: 0px; 
						BORDER-TOP: none;
						BORDER-RIGHT: none; 
						BORDER-LEFT: none; 
						BORDER-BOTTOM: none;
					}
					
						body
					{
					
						font-family:verdana;
						font-size:10px;
						cursor:default;
					}
					table
					{
					
						font-size:100%;
						border-collapse:collapse;
						table-layout:fixed;
					}
					th
					{
						text-align:left;
						height:20px;
						background-color:#DDD;
						border:1px solid #888;
						padding-left:3px;
						padding-right:3px; 
						font-weight:bold;
					}
					td
					{
					                
						text-align:left;
						height:20px;
						background-color:#FFF;
						border:1px solid #888;
						padding-left:3px;
						padding-right:3px;
						font-weight:normal;
						white-space: nowrap;
					} 
					input
					{
						border:none;
						font-size:100%;
						width:70px;
					}        
					span
					{
						white-space: nowrap;
					}
					</style>
					<script>
						function RefreshRow(id)
						{
							var xmlROW=parent.GetRow(id);
							document.getElementById("EMP_"+id     ).value    =xmlROW.GetAttr("EMP");
							document.getElementById("EMP_DESC_"+id).innerHTML=parent.Replace(xmlROW.GetAttr("EMP_DESC")," ","&#160;");						
							document.getElementById("LEG_"+id     ).value    =xmlROW.GetAttr("LEG");
							document.getElementById("LEG_DESC_"+id).innerHTML=parent.Replace(xmlROW.GetAttr("LEG_DESC")," ","&#160;");
							document.getElementById("HOR_"+id     ).value    =xmlROW.GetAttr("HOR");
							document.getElementById("HOR_DESC_"+id).innerHTML=parent.Replace(xmlROW.GetAttr("HOR_DESC")," ","&#160;");
							document.getElementById("FECDESDE_"+id     ).value    =xmlROW.GetAttr("FECDESDE");
							document.getElementById("FECHASTA_"+id     ).value    =xmlROW.GetAttr("FECHASTA");
							//document.getElementById("HDESDE_"+id     ).value =xmlROW.GetAttr("HDESDE");
							//document.getElementById("HHASTA_"+id     ).value =xmlROW.GetAttr("HHASTA");
							document.getElementById("DES_"+id).value = xmlROW.GetAttr("DES");
							document.getElementById("OBS_"+id).value = xmlROW.GetAttr("OBS");
							document.getElementById("ERR_"+id).innerHTML=parent.Replace(xmlROW.GetAttr("ERR")," ","&#160;");
							
							switch(xmlROW.GetAttr("EST"))
							{
								case "":
									document.getElementById("EST_"+id).src="./skins/_Default/Images/SmallButtons/right_gre_d.gif";
									break;
									   
								case "1":
									document.getElementById("EST_"+id).src="./skins/_Default/Images/SmallButtons/edit_n.gif";
									break;
									   
								case "2":
									document.getElementById("EST_"+id).src="./skins/_Default/Images/SmallButtons/ok_n.gif";
									break;
									
								case "3":
									document.getElementById("EST_"+id).src="./skins/_Default/Images/SmallButtons/WRN_n.gif";
									break;  
									
								case "4":
									document.getElementById("EST_"+id).src="./skins/_Default/Images/SmallButtons/err_n.gif";
									break;
							}
						}   
						function OnLostFocusEmpresa(id, obj)
						{                        
							parent.OnLostFocusEmpresa(id, obj.value);
							RefreshRow(id);
						}
						function OnLostFocusLegajo(id, obj)
						{                        
							parent.OnLostFocusLegajo(id, obj.value);
							RefreshRow(id);
						}
						function OnLostFocusHorario(id, obj)
						{	
							parent.OnLostFocusHorario(id, obj.value);
							RefreshRow(id);
						}
						function OnLostFocusFechaDesde(id, obj)
						{
							parent.OnLostFocusFechaDesde(id, obj.value);
							RefreshRow(id);
						}     
						function OnLostFocusFechaHasta(id, obj)
						{
							parent.OnLostFocusFechaHasta(id, obj.value);
							RefreshRow(id);
						}
						/*function OnLostFocusHoraDesde(id, obj)
						{                          
							parent.OnLostFocusHoraDesde(id, obj.value);
							RefreshRow(id);
						}     
						function OnLostFocusHoraHasta(id, obj)
						{                          
							parent.OnLostFocusHoraHasta(id, obj.value);
							RefreshRow(id);
						} 
						*/      
						function OnLostFocusDescripcion(id, obj)
						{                          
							parent.OnLostFocusDescripcion(id, obj.value);
							RefreshRow(id);
						}     
						function OnLostFocusObservacion(id, obj)
						{                          
							parent.OnLostFocusObservacion(id, obj.value);
							RefreshRow(id);
						} 
						
						function CleanRow(id)
						{                          
							parent.CleanRow(id);
							RefreshRow(id);
						}
						function OnLoad()
						{      
							var obj;
							var id;
							
							id=0;
							do {      
								obj=document.getElementById("LEG_"+id);
								if (obj) RefreshRow(id);
								id++;
							} while (obj);
							
							document.getElementById("pageCount").innerHTML="P&#225;gina "+(parent.numPage+1)+" de "+(parent.maxPage+1);
							
						}    
						
						function OnKeyPress(obj,event)
						{
						  if (event.keyCode==38)                          
						  {	
						  	num=parseInt(obj.id.substr(4),10)-1;
								obj=document.getElementById(obj.id.substr(0,4)+num);
								if (obj) obj.focus();
						  } else
						  if (event.keyCode==40)                          
						  {
						  	num=parseInt(obj.id.substr(4),10)+1;
								obj=document.getElementById(obj.id.substr(0,4)+num);
								if (obj) obj.focus();
						  }
							
						}
					</script>
				</head>
				<body class="main" style="width:100%;height:100%;" onload="OnLoad();">
					<table style="width:100%;" CELLPADDING="0">
						<col width="20px"/>
						<col width="20px"/>
						<col width="80px"/>
						<col width="160px"/>
						<col width="55px"/>
						<col width="200px"/>
						<col width="50px"/>
						<col width="120px"/>
						<col width="85px"/>
						<col width="85px"/>
						<!--<col width="75px"/>-->
						<col width="200px"/>
						<col width="200px"/>
						<col width="450px"/>
						<tr>
							<th>
								Del
							</th>
							<th>
								Est
							</th>
							<th>
								Cod.&#160;Empresa
							</th>
							<th>
								Desc.&#160;Empresa
							</th>
							<th>
								Legajo
							</th>
							<th>
								Apellido&#160;y&#160;Nombre
							</th>
							<th>
								Tipo de Hora
							</th>
							<th>
								Desc&#160;Tipo Hora
							</th>
							<th>
								Fecha Hora Desde
							</th>
							<th>
								Fecha Hora Hasta
							</th>
							<!--<th>
								Hora&#160;Desde
			</th>
			<th>
								Hora&#160;Hasta
			</th>-->
							<th>
								Descripci&#243;n
							</th>
							<th>
								Observaciones
							</th>
							<th>
								Error
							</th>
						</tr>
						<xsl:for-each select="row">
							<tr>
								<td style="text-align:center;">
									<img src="./skins/_Default/Images/SmallButtons/delall_n.gif" width="16px" height="16px" style="cursor:pointer;" tooltip="Eliminar">
										<xsl:attribute name="onclick">
											<xsl:value-of select="concat('CleanRow(',@id,');')"/>
										</xsl:attribute>
									</img>
								</td>
								<td style="text-align:center;">
									<img src="" width="16px" height="16px">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('EST_',@id)"/>
										</xsl:attribute>
									</img>
								</td>
								<td>
									<input type="text" value="" maxLength="7" onkeyup="OnKeyPress(this,event);">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('EMP_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusEmpresa(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<span id="EMP_DESC_0">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('EMP_DESC_',@id)"/>
										</xsl:attribute>
										...
									</span>
								</td>
								<td>
									<input type="text" value="" maxLength="7" style="width:50px;" onkeyup="OnKeyPress(this,event);">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('LEG_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusLegajo(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<span id="LEG_DESC_0">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('LEG_DESC_',@id)"/>
										</xsl:attribute>
										...
									</span>
								</td>
								<td>
									<input type="text" value="" maxLength="30" onkeyup="OnKeyPress(this,event);" style="width:45px;">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('HOR_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusHorario(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<span id="HOR_DESC_0">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('HOR_DESC_',@id)"/>
										</xsl:attribute>
										...
									</span>
								</td>
								<td>
									<input type="text" value="" maxLength="16" onkeyup="OnKeyPress(this,event);" style="width:80px;">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('FECDESDE_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusFechaDesde(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<input type="text" value="" maxLength="16" onkeyup="OnKeyPress(this,event);" style="width:80px;">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('FECHASTA_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusFechaHasta(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<!--<td>
					<input type="text" value="" maxLength="8" align="center" onkeyup="OnKeyPress(this,event);">
						<xsl:attribute name="id">
							<xsl:value-of select="concat('HDESDE_',@id)"/>
						</xsl:attribute>
						<xsl:attribute name="onblur">
							<xsl:value-of select="concat('OnLostFocusHoraDesde(',@id,',this);')"/>
						</xsl:attribute>
					</input>
				</td>
				<td>
					<input type="text" value="" maxLength="8" align="center" onkeyup="OnKeyPress(this,event);">
						<xsl:attribute name="id">
							<xsl:value-of select="concat('HHASTA_',@id)"/>
						</xsl:attribute>
						<xsl:attribute name="onblur">
							<xsl:value-of select="concat('OnLostFocusHoraHasta(',@id,',this);')"/>
						</xsl:attribute>
					</input>
				</td>  -->
								<td>
									<input type="text" value="" maxLength="100" style="width:190px;" onkeyup="OnKeyPress(this,event);">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('DES_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusDescripcion(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<input type="text" value="" maxLength="100" style="width:190px;" onkeyup="OnKeyPress(this,event);">
										<xsl:attribute name="id">
											<xsl:value-of select="concat('OBS_',@id)"/>
										</xsl:attribute>
										<xsl:attribute name="onblur">
											<xsl:value-of select="concat('OnLostFocusObservacion(',@id,',this);')"/>
										</xsl:attribute>
									</input>
								</td>
								<td>
									<span>
										<xsl:attribute name="id">
											<xsl:value-of select="concat('ERR_',@id)"/>
										</xsl:attribute>
										...
									</span>
								</td>
							</tr>
						</xsl:for-each>
					</table>
					<span id="pageCount" style="width:100%;text-align:right;">
						...
					</span>
				</body>
			</html>
		</xsl:template>
	</html:xslt>
</html:html>
