			</qry:element>
		</qry:main>
		<qry:select name="QRY_PROCESO" doc="PARAM">
			<qry:xquery>
				for $r in sql('
SELECT
TTA09_LIQUIDACION.c_liquidacion,
TTA09_LIQUIDACION.d_liquidacion
FROM
TTA09_LIQUIDACION
WHERE 
TTA09_LIQUIDACION.oi_liquidacion = {#PARAM:@oi_liquidacion}
')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@c_liquidacion + ' - ' + $r/@d_liquidacion" name="proceso"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_CALL">
			<qry:xquery>
				for $r in #PARAM:ROW
			</qry:xquery>
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute value="#FILTRO:@f_desde" name="f_desde"/>
						<qry:attribute value="#FILTRO:@f_hasta" name="f_hasta"/>
						<qry:attribute value="#FILTRO:@anuladas" name="anuladas"/>
						<qry:attribute value="#FILTRO:@pordia" name="pordia"/>
						<qry:attribute value="#FILTRO:@chkPuestoActual" name="chkPuestoActual"/>
						<qry:attribute value="#FILTRO:@chkPosicionActual" name="chkPosicionActual"/>
						<qry:attribute value="#FILTRO:@chkDepartamentoActual" name="chkDepartamentoActual"/>
						<qry:attribute value="#FILTRO:@chkSectorActual" name="chkSectorActual"/>
						<qry:attribute value="#FILTRO:@chkCtroCostoActual" name="chkCtroCostoActual"/>
						<qry:attribute value="#FILTRO:@chkUbicacionActual" name="chkUbicacionActual"/>
						<qry:attribute value="#FILTRO:@oi_liquidacion" name="oi_liquidacion"/>
						<qry:attribute value="$r/@VALUES" name="VALUES"/>
						<qry:attribute value="string(#FILTRO:CONC/C/@id)" name="CONC"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONCEPTOS" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
SELECT 
TTA15_CONCEPTOS.oi_concepto,
TTA15_CONCEPTOS.d_concepto,
TTA15_CONCEPTOS.c_coleccion,
TTA15_CONCEPTOS.e_mostrar,
TTA15_CONCEPTOS.c_unidad
			
FROM 
TTA15_CONCEPTOS
WHERE 
TTA15_CONCEPTOS.oi_concepto in ({%=string(#FILTRO:CONC/C/@id)%})
ORDER BY 
e_mostrar ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="C">
					<qry:attribute value="$r/@oi_concepto" name="id"/>
					<qry:attribute value="$r/@d_concepto" name="d_concepto"/>
					<qry:attribute value="$r/@c_coleccion" name="c_coleccion"/>
					<qry:attribute value="$r/@c_unidad" name="c_unidad"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:for-each>
