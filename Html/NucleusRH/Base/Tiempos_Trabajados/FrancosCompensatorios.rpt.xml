<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" name="NucleusRH.Base.Tiempos_Trabajados.FrancosCompensatorios" doc="source">
	<html:query declare="&lt;FILTRO gcustom=&quot;&quot; f_desde=&quot;20170101&quot; f_hasta=&quot;20190901&quot; oi_banco_hora=&quot;&quot; gpers=&quot;&quot; empresa=&quot;8&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_grupo_ccosto=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; legajo_reloj_desde=&quot;&quot; legajo_reloj_hasta=&quot;&quot; chksinreloj=&quot;&quot; tarjeta_desde=&quot;&quot; tarjeta_hasta=&quot;&quot; chksintarjeta=&quot;&quot; oi_horario=&quot;&quot; oi_escuadra=&quot;&quot; tipo=&quot;&quot; oi_grupo_horario=&quot;&quot;&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;1429&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;1326&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;1430&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;10305&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;2143&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;2144&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;2145&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;10000&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;10200&quot;/&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<REPORT label="Francos Compensatorios">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<COL name="f_desde" label="Fecha Desde"/>
							<COL name="f_hasta" label="Fecha Hasta"/>
							<COL name="banco_hora" label="Banco Hora"/>
						</COLS>
						<GROUP tag="FC" type="table">
							<COLS>
								<COL name="legajo" label="Legajo" style="vertical-align:top;"/>
								<COL name="f_generacion" label="F. Generaci&#243;n" style="vertical-align:top;text-align:center"/>
								<COL name="cant_gen" label="Cant. Generada" style="vertical-align:top;text-align:center"/>
								<COL name="cant_aprob" label="Cant. Aprobada" style="vertical-align:top;text-align:center"/>
								<COL name="banco" label="Banco" style="vertical-align:top;"/>
								<COL name="f_compensacion" label="F. Compensaci&#243;n" type="multiline" style="text-align:center"/>
								<COL name="f_registro_s" label="F. Registro saldado" type="multiline" style="text-align:center"/>
								<COL name="f_blanqueo" label="F. Blanqueo" type="multiline" style="text-align:center"/>
								<COL name="cant_comp" label="Cant. Compensada" type="multiline" style="vertical-align:top;text-align:center"/>
								<COL name="saldo" label="Saldo" style="vertical-align:top;text-align:center"/>
							</COLS>
							<FCOLS>
								<COL label="Total"/>
								<COL/>
								<COL name="tot_gen"/>
								<COL name="tot_aprob"/>
								<COL/>
								<COL/>
								<COL/>
								<COL/>
								<COL name="tot_comp"/>
								<COL name="tot_saldo"/>
							</FCOLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:append-doc name="FILTRO" doc-path="#PARAM:FILTRO"/>
					<qry:element name="REP">
						<qry:attribute value="format_date(#PARAM:FILTRO/@f_desde,'dd/mm/yyyy')" name="f_desde"/>
						<qry:attribute value="format_date(#PARAM:FILTRO/@f_hasta,'dd/mm/yyyy')" name="f_hasta"/>
						<qry:attribute value="'-'" name="banco_hora"/>
						<qry:if test="#FILTRO:@oi_banco_hora!=''">
							<qry:then>
								<qry:insert-select doc-path="#FILTRO:" name="QRY_BANCO"/>
							</qry:then>
							<qry:else/>
						</qry:if>
						<qry:attribute value="'0'" name="tot_gen"/>
						<qry:attribute value="'0'" name="tot_saldo"/>
						<qry:attribute value="'0'" name="tot_comp"/>
						<qry:insert-select doc-path="#FILTRO:" name="QRY_FC"/>
						<qry:insert-select doc-path="#FILTRO:" name="QRY_FCC"/>
						<qry:insert-select doc-path="." name="QRY_TOT_COMP"/>
						<qry:insert-select doc-path="." name="QRY_FORMAT_TOT"/>
						<qry:insert-select doc-path="." name="QRY_FORMATEAR2"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_BANCO" doc="PARAM">
			<qry:xquery>
				for $r in sql('	
				SELECT 
                    TTA21_BANCO_HORA.c_banco_hora,
					TTA21_BANCO_HORA.d_banco_hora
				FROM 
					TTA21_BANCO_HORA
				WHERE
					TTA21_BANCO_HORA.oi_banco_hora = {%=#PARAM:@oi_banco_hora%}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="'[' + $r/@c_banco_hora + '] ' + $r/@d_banco_hora" name="banco_hora"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_FC">
			<qry:xquery>
				for $r in sql('		
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER01_PERSONAL.d_ape_y_nom,
					ORG03_EMPRESAS.c_empresa,
					TTA20_REGISTRO_FC.oi_registro_fc,					
					TTA20_REGISTRO_FC.f_registro_fc,
					TTA20_REGISTRO_FC.f_registro_s,
					TTA20_REGISTRO_FC.f_blanqueo,
					TTA20_REGISTRO_FC.n_cant_gen, 
					TTA20_REGISTRO_FC.n_cant_aprob,
					TTA20_REGISTRO_FC.n_saldo,
					TTA21_BANCO_HORA.d_banco_hora,
					TTA21_BANCO_HORA.c_unidad_tiempo
				FROM 
					PER02_PERSONAL_EMP, 					
					PER01_PERSONAL, 
					ORG03_EMPRESAS,
					TTA20_REGISTRO_FC,
					TTA20_COMP_FC,
					TTA21_BANCO_HORA
				JOIN 					
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal, 
					PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
					PER02_PERSONAL_EMP.oi_personal_emp INNER TTA20_REGISTRO_FC.oi_personal_emp, 
					TTA20_REGISTRO_FC.oi_registro_fc INNER TTA20_COMP_FC.oi_registro_fc,     
					TTA20_REGISTRO_FC.oi_banco_hora INNER TTA21_BANCO_HORA.oi_banco_hora
				WHERE 
					TTA20_COMP_FC.f_comp &gt;=  {Datetime(#FILTRO:@f_desde)}
					AND TTA20_COMP_FC.f_comp &lt;  {Datetime(Number(Datetime(#FILTRO:@f_hasta))+1)}
						{%?(#FILTRO:@oi_banco_hora!=''){% AND TTA20_REGISTRO_FC.oi_banco_hora = {%=#PARAM:@oi_banco_hora%} %}	
					{% %}%}	
				GROUP BY
					TTA20_REGISTRO_FC.oi_registro_fc,
					PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER01_PERSONAL.d_ape_y_nom,
					ORG03_EMPRESAS.c_empresa,				
					TTA20_REGISTRO_FC.f_registro_fc,
					TTA20_REGISTRO_FC.f_registro_s,
					TTA20_REGISTRO_FC.f_blanqueo,
					TTA20_REGISTRO_FC.n_cant_gen, 
					TTA20_REGISTRO_FC.n_cant_aprob,
					TTA20_REGISTRO_FC.n_saldo,
					TTA21_BANCO_HORA.d_banco_hora,
					TTA21_BANCO_HORA.c_unidad_tiempo
				ORDER BY 
					e_numero_legajo ASC,
					f_registro_fc ASC 
				
			')/ROWS/ROW
			,
		$l in #FILTRO:ROWS/ROW
		where
				$r/@oi_personal_emp=$l/@id
			</qry:xquery>
			<qry:out>
				<qry:element name="FC">
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
					<qry:attribute value="'(' + $r/@c_empresa + ' - ' + $r/@e_numero_legajo + ') ' + $r/@d_ape_y_nom" name="legajo"/>
					<qry:attribute value="format_date($r/@f_registro_fc, 'dd/mm/yyyy')" name="f_generacion"/>
					<qry:attribute value="format_date($r/@f_registro_s, 'dd/mm/yyyy')" name="f_registro_s"/>
					<qry:attribute value="format_date($r/@f_blanqueo, 'dd/mm/yyyy')" name="f_blanqueo"/>
					<qry:attribute value="$r/@c_unidad_tiempo" name="c_unidad_tiempo"/>
					<qry:attribute value="$r/@d_banco_hora" name="banco"/>
					<qry:insert-select name="QRY_COMP" doc-path="$r"/>
					<qry:if test="$r/@c_unidad_tiempo='M'">
						<qry:then>
							<qry:attribute value="number($r/@n_cant_gen) div 60" name="cant_gen"/>
							<qry:attribute value="number($r/@n_cant_aprob) div 60" name="cant_aprob"/>
							<qry:attribute value="number($r/@n_saldo) div 60" name="saldo"/>
							<qry:attribute value="number(@n_cant_comp) div 60" name="n_cant_comp"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@n_cant_gen" name="cant_gen"/>
							<qry:attribute value="$r/@n_cant_aprob" name="cant_aprob"/>
							<qry:attribute value="number($r/@n_saldo)" name="saldo"/>
							<qry:attribute value="number(@n_cant_comp)" name="n_cant_comp"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_TOT_COMP" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:FC
			</qry:xquery>
			<qry:out>
				<qry:attribute value="Number(@tot_gen) + $r/@cant_gen" name="tot_gen"/>
				<qry:attribute value="Number(@tot_saldo) + $r/@saldo" name="tot_saldo"/>
				<qry:attribute value="Number(@tot_comp) + $r/@n_cant_comp" name="tot_comp"/>
				<qry:attribute value="Number(@tot_aprob) + $r/@cant_aprob" name="tot_aprob"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_COMP" doc="PARAM">
			<qry:xquery>
				for $r in sql('	
				SELECT 
                    TTA20_COMP_FC.f_comp as f_compensacion,
					TTA20_COMP_FC.n_cant_comp
				FROM 
					TTA20_COMP_FC
				WHERE
					TTA20_COMP_FC.oi_registro_fc = {%=#PARAM:@oi_registro_fc%}

				ORDER BY
					f_compensacion ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="@f_compensacion !=''">
					<qry:then>
						<qry:attribute value="@f_compensacion + '&#10;' + format_date($r/@f_compensacion, 'dd/mm/yyyy')" name="f_compensacion"/>
					</qry:then>
					<qry:else>
						<qry:attribute value="format_date($r/@f_compensacion, 'dd/mm/yyyy')" name="f_compensacion"/>
					</qry:else>
				</qry:if>
				<qry:if test="@cant_comp !=''">
					<qry:then>
						<qry:attribute value="string(@cant_comp) + '&#10;' + iif(#PARAM:@c_unidad_tiempo='M',concat(fill-left(floor(number($r/@n_cant_comp) div 60),'0',2),':',fill-left(number($r/@n_cant_comp) mod 60,'0',2)),concat(fill-left(floor(number($r/@n_cant_comp)),'0',2),':',fill-left(round(number($r/@n_cant_comp)*60.0) mod 60,'0',2)))" name="cant_comp"/>
					</qry:then>
					<qry:else>
						<qry:attribute value="iif(#PARAM:@c_unidad_tiempo='M',concat(fill-left(floor(number($r/@n_cant_comp) div 60),'0',2),':',fill-left(number($r/@n_cant_comp) mod 60,'0',2)),concat(fill-left(floor(number($r/@n_cant_comp)),'0',2),':',fill-left(round(number($r/@n_cant_comp)*60.0) mod 60,'0',2)))" name="cant_comp"/>
					</qry:else>
				</qry:if>
				<qry:attribute value="number(@n_cant_comp) + number($r/@n_cant_comp)" name="n_cant_comp"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FCC" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER01_PERSONAL.d_ape_y_nom,
					ORG03_EMPRESAS.c_empresa,
					TTA20_REGISTRO_FC.oi_registro_fc,					
					TTA20_REGISTRO_FC.f_registro_fc,
					TTA20_REGISTRO_FC.f_registro_s,
					TTA20_REGISTRO_FC.n_cant_gen,   
					TTA20_REGISTRO_FC.n_cant_aprob,
					TTA20_REGISTRO_FC.n_saldo,
					TTA21_BANCO_HORA.d_banco_hora,
					TTA21_BANCO_HORA.c_unidad_tiempo
				FROM 
					PER02_PERSONAL_EMP, 					
					PER01_PERSONAL, 
					ORG03_EMPRESAS,
					TTA20_REGISTRO_FC,
					TTA21_BANCO_HORA
				JOIN 					
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal, 
					PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
					PER02_PERSONAL_EMP.oi_personal_emp INNER TTA20_REGISTRO_FC.oi_personal_emp,
					TTA20_REGISTRO_FC.oi_banco_hora INNER TTA21_BANCO_HORA.oi_banco_hora
				WHERE 
					TTA20_REGISTRO_FC.f_registro_fc &gt;=  {Datetime(#FILTRO:@f_desde)}
					AND TTA20_REGISTRO_FC.f_registro_fc &lt;  {Datetime(Number(Datetime(#FILTRO:@f_hasta))+1)}
					AND TTA20_REGISTRO_FC.oi_registro_fc not in (SELECT TTA20_COMP_FC.oi_registro_fc FROM TTA20_COMP_FC) 
					
					{%?(#FILTRO:@oi_banco_hora!=''){% AND TTA20_REGISTRO_FC.oi_banco_hora = {%=#PARAM:@oi_banco_hora%} %}	
					{% %}%}				
				ORDER BY 
					e_numero_legajo ASC,
					f_registro_fc ASC 
				
			')/ROWS/ROW
			,
		$l in #FILTRO:ROWS/ROW
		where
				$r/@oi_personal_emp=$l/@id
			</qry:xquery>
			<qry:out>
				<qry:element name="FC">
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
					<qry:attribute value="'(' + $r/@c_empresa + ' - ' + $r/@e_numero_legajo + ') ' + $r/@d_ape_y_nom" name="legajo"/>
					<qry:attribute value="format_date($r/@f_registro_fc, 'dd/mm/yyyy')" name="f_generacion"/>
					<qry:attribute value="$r/@c_unidad_tiempo" name="c_unidad_tiempo"/>
					<qry:attribute value="$r/@d_banco_hora" name="banco"/>
					<qry:if test="$r/@c_unidad_tiempo='M'">
						<qry:then>
							<qry:attribute value="number($r/@n_cant_gen) div 60" name="cant_gen"/>
							<qry:attribute value="number($r/@n_cant_aprob) div 60" name="cant_aprob"/>
							<qry:attribute value="number($r/@n_saldo) div 60" name="saldo"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@n_cant_gen" name="cant_gen"/>
							<qry:attribute value="$r/@n_cant_aprob" name="cant_aprob"/>
							<qry:attribute value="number($r/@n_saldo)" name="saldo"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FORMAT_TOT" doc="PARAM">
			<qry:out>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@tot_gen),'0',2),':',fill-left(round(#PARAM:@tot_gen*60.0) mod 60,'0',2))" name="tot_gen"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@tot_saldo),'0',2),':',fill-left(round(#PARAM:@tot_saldo*60.0) mod 60,'0',2))" name="tot_saldo"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@tot_comp),'0',2),':',fill-left(round(#PARAM:@tot_comp*60.0) mod 60,'0',2))" name="tot_comp"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@tot_aprob),'0',2),':',fill-left(round(#PARAM:@tot_aprob*60.0) mod 60,'0',2))" name="tot_aprob"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FORMATEAR2" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:FC
			</qry:xquery>
			<qry:out>
				<qry:insert-select doc-path="$r" to-element="$r" name="QRY_PEGAR"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PEGAR" doc="PARAM">
			<qry:out>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@cant_gen),'0',2),':',fill-left(round(#PARAM:@cant_gen*60.0) mod 60,'0',2))" name="cant_gen"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@cant_aprob),'0',2),':',fill-left(round(#PARAM:@cant_aprob*60.0) mod 60,'0',2))" name="cant_aprob"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@saldo),'0',2),':',fill-left(round(#PARAM:@saldo*60.0) mod 60,'0',2))" name="saldo"/>
				<qry:attribute value="concat(fill-left(floor(#PARAM:@n_cant_comp),'0',2),':',fill-left(round(#PARAM:@n_cant_comp*60.0) mod 60,'0',2))" name="n_cant_comp"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
