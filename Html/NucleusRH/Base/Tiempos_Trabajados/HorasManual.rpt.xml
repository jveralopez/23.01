<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Tiempos_Trabajados.HorasManual" doc="source">
	<html:query declare="&lt;PARAMS empty=&quot;0&quot; idrep=&quot;3D6C038884E0-87A1FA6A4AE1-678400000019_11566&quot;/&gt;">
		<qry:main doc="PARAM">
			<REPORT>
				<qry:if test="#PARAM:PARAMS/@empty">
					<qry:then>
						<qry:attribute name="empty" value="'1'"/>
						<DATOS/>
					</qry:then>
					<qry:else>
						<qry:attribute name="empty" value="'0'"/>
						<qry:insert-select name="qry_datos" doc-path="#PARAM:PARAMS"/>
					</qry:else>
				</qry:if>
			</REPORT>
		</qry:main>
		<qry:select name="qry_datos" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('TEMP/Procesamiento-{%=$SOURCE/@idrep%}.xml')/DATOS
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="REPORT/DATOS">
			<html>
				<head>
					<style>
