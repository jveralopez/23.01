					</style>
					<script>
						function ChangeValue(obj)
{	
	var jor = obj.id.split('_')[1];
	var con = obj.id.split('_')[2];
	
	parent.validateval(obj, con);	
	
	var orig=document.getElementById('o'+obj.id).value;
	var nuev=obj.value;
	
	if(orig=="00:00" || orig == "0") orig = "";
	if(nuev=="00:00" || nuev == "0") nuev = "";
		
	if(orig!="" || nuev!="")
	{		
		if (orig!=nuev)
		{			
			obj.style.backgroundColor = '#F9FF68';
			parent.SetEdited(obj.id, true);
			parent.SetChg(obj);
		}
		else
		{			
			obj.style.backgroundColor = '#FFFFFF';						
			parent.SetEdited(obj.id, false);			
		}		
		parent.OnLostFocusValor(obj, obj.value);		
	}
	else
	{
		obj.style.backgroundColor = '#FFFFFF';						
		parent.SetEdited(obj.id, false);
	}
	if(jor!="0")
	{		
		var tot = parent.SetTotal(con);		
		if(parent.GetUnit(con) == "horas")
			document.getElementById("tot_"+con).value = parent.toTime(tot);	
		else
			document.getElementById("tot_"+con).value = tot;	
	}
}

function OnKeyPress(obj,event)
{ 
  if (event.keyCode==38)
  {	
  	num=parseInt(obj.previousSibling.id.substr(4),10)-1;
		obj=document.getElementById('row_'+num).nextSibling;
		if (obj) obj.focus();
  }      
  else if (event.keyCode==40)                          
  {
  	num=parseInt(obj.previousSibling.id.substr(4),10)+1;
		obj=document.getElementById('row_'+num).nextSibling;
		if (obj) obj.focus();
  }
}
					</script>
				</head>
