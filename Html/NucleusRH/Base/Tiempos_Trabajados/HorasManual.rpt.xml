						MARGIN:0px; 
						PADDING-TOP:10px; 
						BORDER-TOP:none;
						BORDER-RIGHT:none; 
						BORDER-LEFT:none; 
						BORDER-BOTTOM:none;
						text-align:left;
					}
					body
					{					
						font-family:verdana;
						font-size:9px;
						cursor:default;
					}
					table
					{
						font-size:9px;
						border-collapse:collapse;
