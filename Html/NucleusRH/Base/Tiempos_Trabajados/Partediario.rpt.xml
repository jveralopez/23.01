<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.InterfaceHoras.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;REPORT f_informe=&quot;22/03/2021 12:28:11&quot; chkPuestoActual=&quot;1&quot; chkPosicionActual=&quot;1&quot; chkDepartamentoActual=&quot;1&quot; chkSectorActual=&quot;1&quot; chkCtroCostoActual=&quot;1&quot; chkUbicacionActual=&quot;1&quot;&gt;&lt;ROW descHorario=&quot;[1h] Fijo 9 a 18&quot; d_centro_costo=&quot;Mantenimiento&quot; c_centro_costo=&quot;01.02.011&quot; d_ubicacion=&quot;AZUL&quot; c_ubicacion=&quot;2&quot; apeynom=&quot;ACOSTA, RODOLFO CARLOS&quot; empresa=&quot;[1] Azul Natural Beef&quot; legajo=&quot;10001&quot; paramfic=&quot;1&quot; id=&quot;2&quot; presente=&quot;0&quot; hdesde=&quot;09:00&quot; /&gt;&lt;ROW descHorario=&quot;[1h] Fijo 9 a 18&quot; d_centro_costo=&quot;FAENA&quot; c_centro_costo=&quot;01.01.002&quot; d_ubicacion=&quot;AZUL&quot; c_ubicacion=&quot;2&quot; apeynom=&quot;ACU&#209;A, JOSE OMAR&quot; empresa=&quot;[1] Azul Natural Beef&quot; legajo=&quot;10002&quot; paramfic=&quot;1&quot; id=&quot;3&quot; presente=&quot;0&quot; hdesde=&quot;09:00&quot; /&gt;&lt;ROW descHorario=&quot;[1h] Fijo 9 a 18&quot; d_centro_costo=&quot;Limpieza de Planta y Vestuarios&quot; c_centro_costo=&quot;01.02.015&quot; d_ubicacion=&quot;AZUL&quot; c_ubicacion=&quot;2&quot; apeynom=&quot;ALBERTI NU&#209;EZ, JEAN FRANCO&quot; empresa=&quot;[1] Azul Natural Beef&quot; legajo=&quot;10005&quot; paramfic=&quot;1&quot; id=&quot;4&quot; presente=&quot;0&quot; hdesde=&quot;09:00&quot; /&gt;&lt;ROW descHorario=&quot;[1h] Fijo 9 a 18&quot; d_centro_costo=&quot;Mantenimiento&quot; c_centro_costo=&quot;01.02.011&quot; d_ubicacion=&quot;AZUL&quot; c_ubicacion=&quot;2&quot; apeynom=&quot;ALZAMENDI, ANGEL JAVIER&quot; empresa=&quot;[1] Azul Natural Beef&quot; legajo=&quot;10007&quot; paramfic=&quot;1&quot; id=&quot;5&quot; presente=&quot;0&quot; hdesde=&quot;09:00&quot; /&gt;&lt;ROW paramfic=&quot;1&quot; id=&quot;6&quot; presente=&quot;0&quot; /&gt;&lt;ROW paramfic=&quot;1&quot; id=&quot;8&quot; presente=&quot;0&quot; /&gt;&lt;ROW paramfic=&quot;1&quot; id=&quot;9&quot; presente=&quot;0&quot; /&gt;&lt;ROW paramfic=&quot;1&quot; id=&quot;10&quot; presente=&quot;0&quot; /&gt;&lt;ROW paramfic=&quot;1&quot; id=&quot;11&quot; presente=&quot;0&quot; /&gt;&lt;/REPORT&gt;">
		<qry:main doc="PARAM">
			<REPORT label="Parte Diario de Asistencias" style="text-align:center; font-size:16px">
				<qry:append-doc name="FILTRO" doc-path="#PARAM:REPORT"/>
				<qry:attribute name="date" value="#PARAM:REPORT/@f_informe" style="text-align:right;"/>
				<GROUPS>
					<GROUP type="tablestruc" style="font-size:14px">
						<GROUPROW>
							<GROUPCOL>
								<GROUP tag="AUS" type="table" label="Ausentes">
									<COLS>
										<COL name="empresa" label="Empresa" nowrap="1" style="width:150px; text-align:center"/>
										<COL name="legajo" label="Legajo" nowrap="1" style="width:100px; text-align:center"/>
										<COL name="apeynom" label="Apellido y Nombre" nowrap="1" style="width:200px; text-align:center"/>
										<qry:if test="#FILTRO:@chkPuestoActual ='1'">
											<qry:then>
												<COL name="c_puesto" label="Cod. Puesto" style="width:50px;"/>
												<COL name="d_puesto" label="Puesto" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkPosicionActual ='1'">
											<qry:then>
												<COL name="c_posicion" label="Cod. Posici&#243;n" style="width:50px;"/>
												<COL name="d_posicion" label="Posici&#243;n" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkDepartamentoActual ='1'">
											<qry:then>
												<COL name="c_departamento" label="Cod. Departamento" style="width:50px;"/>
												<COL name="d_departamento" label="Departamento" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkSectorActual ='1'">
											<qry:then>
												<COL name="c_sector" label="Cod. Sector" style="width:50px;"/>
												<COL name="d_sector" label="Sector" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkCtroCostoActual ='1'">
											<qry:then>
												<COL name="c_centro_costo" label="Cod. Centro de Costo" style="width:50px;"/>
												<COL name="d_centro_costo" label="Centro de Costo" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkUbicacionActual ='1'">
											<qry:then>
												<COL name="c_ubicacion" label="Cod. Ubicaci&#243;n" style="width:50px;"/>
												<COL name="d_ubicacion" label="Ubicaci&#243;n" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<COL name="descHorario" label="Descripci&#243;n del Horario" nowrap="1" style="width:300px; text-align:center"/>
										<COL name="hdesde" label="Hora Esperada" nowrap="1" style="text-align:center; width:150px"/>
									</COLS>
									<FCOLS>
										<COL label="Total Ausentes " colspan="4" style="text-align:right; vertical-align:middle"/>
										<COL name="tot_aus" style="text-align:center; vertical-align:middle"/>
									</FCOLS>
								</GROUP>
							</GROUPCOL>
						</GROUPROW>
						<GROUPROW>
							<GROUPCOL>
								<GROUP tag="PRE" type="table" style="width:100%" label="Presentes">
									<COLS>
										<COL name="empresa" label="Empresa" nowrap="1" style="width:150px; text-align:center"/>
										<COL name="legajo" label="Legajo" nowrap="1" style="width:100px; text-align:center"/>
										<COL name="apeynom" label="Apellido y Nombre" nowrap="1" style="width:200px; text-align:center"/>
										<qry:if test="#FILTRO:@chkPuestoActual ='1'">
											<qry:then>
												<COL name="c_puesto" label="Cod. Puesto" style="width:50px;"/>
												<COL name="d_puesto" label="Puesto" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkPosicionActual ='1'">
											<qry:then>
												<COL name="c_posicion" label="Cod. Posici&#243;n" style="width:50px;"/>
												<COL name="d_posicion" label="Posici&#243;n" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkDepartamentoActual ='1'">
											<qry:then>
												<COL name="c_departamento" label="Cod. Departamento" style="width:50px;"/>
												<COL name="d_departamento" label="Departamento" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkSectorActual ='1'">
											<qry:then>
												<COL name="c_sector" label="Cod. Sector" style="width:50px;"/>
												<COL name="d_sector" label="Sector" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkCtroCostoActual ='1'">
											<qry:then>
												<COL name="c_centro_costo" label="Cod. Centro de Costo" style="width:50px;"/>
												<COL name="d_centro_costo" label="Centro de Costo" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<qry:if test="#FILTRO:@chkUbicacionActual ='1'">
											<qry:then>
												<COL name="c_ubicacion" label="Cod. Ubicaci&#243;n" style="width:50px;"/>
												<COL name="d_ubicacion" label="Ubicaci&#243;n" style="width:200px;"/>
											</qry:then>
										</qry:if>
										<COL name="descHorario" label="Descripci&#243;n del Horario" nowrap="1" style="width:300px; text-align:center"/>
										<COL name="hora" label="Fichada" nowrap="1" style="text-align:center; width:150px"/>
									</COLS>
									<FCOLS>
										<COL label="Total Presentes " colspan="4" style="text-align:right; vertical-align:middle"/>
										<COL name="tot_pre" style="text-align:center; vertical-align:middle"/>
									</FCOLS>
								</GROUP>
							</GROUPCOL>
						</GROUPROW>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:attribute name="tot_aus" value="'0'"/>
					<qry:attribute name="tot_pre" value="'0'"/>
					<qry:insert-select name="QRY_PRESENTES" doc-path="#PARAM:REPORT"/>
					<qry:insert-select name="QRY_AUSENTES" doc-path="#PARAM:REPORT"/>
					<qry:attribute name="tot_aus" value="@tot_aus + ' Empleados'"/>
					<qry:attribute name="tot_pre" value="@tot_pre + ' Empleados'"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_PRESENTES" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:ROW[@presente='1']
			orderby $r/@hora ASC
			</qry:xquery>
			<qry:out>
				<PRE>
					<qry:attribute name="descHorario" value="$r/@descHorario"/>
					<qry:attribute name="apeynom" value="$r/@apeynom"/>
					<qry:attribute value="$r/@c_ubicacion" name="c_ubicacion"/>
					<qry:attribute value="$r/@d_ubicacion" name="d_ubicacion"/>
					<qry:attribute value="$r/@c_centro_costo" name="c_centro_costo"/>
					<qry:attribute value="$r/@d_centro_costo" name="d_centro_costo"/>
					<qry:attribute value="$r/@c_posicion" name="c_posicion"/>
					<qry:attribute value="$r/@d_posicion" name="d_posicion"/>
					<qry:attribute value="$r/@c_puesto" name="c_puesto"/>
					<qry:attribute value="$r/@d_puesto" name="d_puesto"/>
					<qry:attribute value="$r/@c_departamento" name="c_departamento"/>
					<qry:attribute value="$r/@d_departamento" name="d_departamento"/>
					<qry:attribute value="$r/@c_sector" name="c_sector"/>
					<qry:attribute value="$r/@d_sector" name="d_sector"/>
					<qry:attribute name="empresa" value="$r/@empresa"/>
					<qry:attribute name="hora" value="$r/@hora"/>
					<qry:attribute name="legajo" value="$r/@legajo"/>
					<qry:attribute name="hdesde" value="$r/@hdesde"/>
					<qry:attribute name="id" value="$r/@id"/>
				</PRE>
				<qry:attribute name="tot_pre" value="Number(@tot_pre) + 1"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_AUSENTES" doc="PARAM">
			<qry:xquery>
				for $r in #PARAM:ROW[@presente='0' AND @legajo!='']
			orderby $r/@hdesde ASC
			</qry:xquery>
			<qry:out>
				<AUS>
					<qry:attribute name="descHorario" value="$r/@descHorario"/>
					<qry:attribute name="apeynom" value="$r/@apeynom"/>
					<qry:attribute value="$r/@c_ubicacion" name="c_ubicacion"/>
					<qry:attribute value="$r/@d_ubicacion" name="d_ubicacion"/>
					<qry:attribute value="$r/@c_centro_costo" name="c_centro_costo"/>
					<qry:attribute value="$r/@d_centro_costo" name="d_centro_costo"/>
					<qry:attribute value="$r/@c_posicion" name="c_posicion"/>
					<qry:attribute value="$r/@d_posicion" name="d_posicion"/>
					<qry:attribute value="$r/@c_puesto" name="c_puesto"/>
					<qry:attribute value="$r/@d_puesto" name="d_puesto"/>
					<qry:attribute value="$r/@c_departamento" name="c_departamento"/>
					<qry:attribute value="$r/@d_departamento" name="d_departamento"/>
					<qry:attribute value="$r/@c_sector" name="c_sector"/>
					<qry:attribute value="$r/@d_sector" name="d_sector"/>
					<qry:attribute name="empresa" value="$r/@empresa"/>
					<qry:attribute name="hora" value="$r/@hora"/>
					<qry:attribute name="legajo" value="$r/@legajo"/>
					<qry:attribute name="hdesde" value="$r/@hdesde"/>
					<qry:attribute name="id" value="$r/@id"/>
				</AUS>
				<qry:attribute name="tot_aus" value="Number(@tot_aus) + 1"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
