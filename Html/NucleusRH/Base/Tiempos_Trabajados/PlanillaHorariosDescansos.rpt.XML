<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.PlanillaHorariosDescansos.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;FILTRO gpers=&quot;&quot; empresa=&quot;158&quot; activos=&quot;&quot; l_funcion=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; legajo_reloj_desde=&quot;&quot; legajo_reloj_hasta=&quot;&quot; chksinreloj=&quot;&quot; tarjeta_desde=&quot;&quot; tarjeta_hasta=&quot;&quot; chksintarjeta=&quot;&quot; oi_horario=&quot;&quot; oi_escuadra=&quot;&quot; tipo=&quot;&quot; oi_grupo_horario=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS nmd-col=&quot;1&quot;&gt;&lt;ROW VALUES=&quot;11595,11596,11598,11599,11600,11601,11602,11603,11604,11605,11606,11607,11608,11610,11611,11612,11614,11616,11617,11618,11619,11620,11623,11624,11625,11626,11628,11629,11630,11631,11632,11633,11634,11635,11636,11638,11639,11640,11641,11644,11645,11646,11647,11648,11649,11650,11651,11652,11653,11654&quot;/&gt;&lt;ROW VALUES=&quot;11755,11756,11757,11758,11759,11760,11761,11762,11763,11764,11765,11766,11767,11768,11769,11770,11771,11772,11773,11774,11775,11776,11777,11778,11779,11780,11781,11782,11783,11784,11785,11786,11787,11788,11789,11790,11791,11792,11793,11794,11795,11796,11797,11798,11799,11800,11801,11802,11803,11804&quot;/&gt;&lt;ROW VALUES=&quot;13785,13786,13787,13788,13789,13790,13791,13792,13793,13794,13795,13796,13797,13798,13799,13800,13801,13802,13803,13804,13805,13806,13807,13808,13809,13810,13811,13812,13813,13814,13815,13816,13817,13818,13819,13820,13821,13822,13823,13824,13825,13826,13827,13828,13829,13830,13831,13832,13833,13834&quot;/&gt;&lt;ROW VALUES=&quot;13835,13836,13837,13838,13839,13840,13841,13842,13843,13844,13845,13846,13847,13848,13849,13850,13851,13852,13853,13854,13855,13856,13857,13858,13859,13860,13861,13862,13863,13864,13865,13866,13867,13868,13869,13870,13871,13872,13873,13874,13875,13876,13877,13878,13879,13880,15848,15850&quot;/&gt;&lt;/PERSONAS&gt;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<REPORT label="Planilla de Horarios y Descansos">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
							<COL name="actividad" label="Actividad"/>
							<COL name="cuit" label="C.U.I.T."/>
							<COL name="domicilio" label="Domicilio"/>
						</COLS>
						<GROUP tag="LEG" type="table">
							<COLS>
								<COL name="orden" label="N&#176;" style="width:35px;text-align:right"/>
								<COL name="e_numero_legajo" label="Legajo" style="width:75px;text-align:right"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" style="width:200px;"/>
								<COL name="d_nacionalidad" label="Nacionalidad" style="width:90px;text-align:center"/>
								<COL name="c_sexo" label="Sexo" style="width:40px;text-align:center"/>
								<COL name="d_estado_civil" label="Est.Civil"/>
								<COL name="c_nro_cuil" label="C.U.I.L." style="width:40px;text-align:center"/>
								<COL name="f_nacim" label="F.Nacim" style="width:60px;text-align:center" type="date"/>
								<COL label="Funci&#243;n" name="d_funcion">
									<qry:if test="#PARAM:FILTRO/@l_funcion='1'">
										<qry:then>
											<qry:attribute name="hts:delete" value="0"/>
										</qry:then>
										<qry:else>
											<qry:attribute name="hts:delete" value="1"/>
										</qry:else>
									</qry:if>
								</COL>
								<COL name="f_ingreso" label="F.Ingreso" style="width:60px;text-align:center" type="date"/>
								<COL name="o_planilla" label="Horario"/>
								<COL name="convenio" label="Convenio - Categor&#237;a"/>
								<COL name="n_valor_hora" label="Sueldo B&#225;sico"/>
								<COL name="d_tipo_personal" label="Tipo de Personal"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_EMPRESAS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_EMPRESAS">
			<qry:xquery>
				for $r in sql('				
					SELECT 
						ORG03_EMPRESAS.oi_empresa,
						ORG03_EMPRESAS.c_empresa,
						ORG03_EMPRESAS.d_empresa,
						ORG03_EMPRESAS.c_cuit,						
						ORG34_ACTIVIDADES.d_actividad,
						ORG03_EMPRESAS.d_domicilio
					FROM						
						ORG03_EMPRESAS, ORG34_ACTIVIDADES
					JOIN
						ORG03_EMPRESAS.oi_actividad INNER ORG34_ACTIVIDADES.oi_actividad
					WHERE
						ORG03_EMPRESAS.oi_empresa = {#PARAM:@empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
				<qry:attribute value="$r/@c_empresa + ' - ' + $r/@d_empresa" name="empresa"/>
				<qry:attribute value="$r/@c_cuit" name="cuit"/>
				<qry:attribute value="$r/@d_actividad" name="actividad"/>
				<qry:attribute value="$r/@d_domicilio" name="domicilio"/>
				<qry:append-doc doc-path="." name="EMP"/>
				<qry:insert-select doc-path="#PARAM:PERSONAS/ROW" name="QRY_PERSONAS"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:xquery>
				for $r in sql('		
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					TTA02_HORARIOS,
					TTA04_PERSONAL,
					PER02_PERSONAL_EMP,
					PER01_PERSONAL
				JOIN 
					TTA02_HORARIOS.oi_horario INNER TTA04_PERSONAL.oi_hor_planilla,
					TTA04_PERSONAL.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal					
		
				WHERE 
					PER02_PERSONAL_EMP.oi_empresa = {#EMP:@oi_empresa} and 
					PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})  
			')/ROWS
			</qry:xquery>
			<qry:out>
				<qry:if test="number($r/@cnt)!=0">
					<qry:then>
						<qry:call>
							<FILTRO>
								<qry:attribute value="#EMP:@oi_empresa" name="oi_empresa"/>
								<qry:attribute value="string($r/ROW/@oi_personal_emp)" name="values"/>
								<qry:attribute value="number(../../@ini)" name="ini"/>
							</FILTRO>
						</qry:call>
						<qry:attribute value="number(@ini) + count($r/ROW/@oi_personal_emp)" name="ini"/>
					</qry:then>
					<qry:else/>
				</qry:if>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO ini=&quot;0&quot; values=&quot;11595,11656&quot; oi_empresa=&quot;158&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:/FILTRO" name="QRY_LEGAJOS"/>
			</qry:no-show>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_LEGAJOS">
			<qry:xquery>
				for $r in sql('		
				SELECT 
					TTA04_PERSONAL.oi_personal_emp,
					PER01_PERSONAL.d_ape_y_nom,
					PER02_PERSONAL_EMP.e_numero_legajo,					
					TTA02_HORARIOS.o_planilla,
					ORG12_NACIONALID.d_nacionalidad,
					PER01_PERSONAL.c_sexo,					
					ORG22_EST_CIVIL.d_estado_civil,
					PER01_PERSONAL.c_nro_cuil,
					PER01_PERSONAL.f_nacim,
					ORG03_FUNCIONES.d_funcion,
					PER02_PERSONAL_EMP.f_ingreso,     
					PER11_TIPOS_PERS.d_tipo_personal,
					ORG18_CATEGORIAS.c_categoria,  
     			ORG18_CATEGORIAS.d_categoria,  
					ORG18_CATEGORIAS.n_valor_hora,
					ORG18_CONVENIOS.c_convenio,
					ORG18_CONVENIOS.d_convenio					   
					
				FROM 
					TTA02_HORARIOS,
					TTA04_PERSONAL,
					PER02_PERSONAL_EMP,
					PER01_PERSONAL,
					ORG12_NACIONALID,
					ORG22_EST_CIVIL,
					ORG03_FUNCIONES,
					PER11_TIPOS_PERS,
					ORG18_CATEGORIAS,
					ORG18_CONVENIOS
					
				JOIN 
					TTA02_HORARIOS.oi_horario INNER TTA04_PERSONAL.oi_hor_planilla,
					TTA04_PERSONAL.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal,
					PER01_PERSONAL.oi_nacionalidad LEFT OUTER ORG12_NACIONALID.oi_nacionalidad,
					PER01_PERSONAL.oi_estado_civil LEFT OUTER ORG22_EST_CIVIL.oi_estado_civil,
					PER02_PERSONAL_EMP.oi_funcion LEFT OUTER ORG03_FUNCIONES.oi_funcion,
					PER02_PERSONAL_EMP.oi_tipo_personal LEFT OUTER PER11_TIPOS_PERS.oi_tipo_personal,
					PER02_PERSONAL_EMP.oi_categoria_ult LEFT OUTER ORG18_CATEGORIAS.oi_categoria, 
					ORG18_CATEGORIAS.oi_convenio LEFT OUTER ORG18_CONVENIOS.oi_convenio                     
					                               					
				WHERE                                         
					PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})
				ORDER BY
					e_numero_legajo ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LEG">
					<qry:attribute value="number(#PARAM:@ini) + number(../@indice) + 1" name="orden"/>
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
					<qry:attribute value="$r/@e_numero_legajo" name="e_numero_legajo"/>
					<qry:attribute value="$r/@o_planilla" name="o_planilla"/>
					<qry:attribute value="$r/@d_nacionalidad" name="d_nacionalidad"/>
					<qry:attribute value="$r/@d_estado_civil" name="d_estado_civil"/>
					<qry:attribute value="$r/@c_sexo" name="c_sexo"/>
					<qry:attribute value="$r/@d_est_civil" name="d_est_civil"/>
					<qry:attribute value="$r/@c_nro_cuil" name="c_nro_cuil"/>
					<qry:attribute value="format_date($r/@f_nacim, 'dd/mm/yyyy')" name="f_nacim"/>
					<qry:attribute value="$r/@d_funcion" name="d_funcion"/>
					<qry:attribute value="format_date($r/@f_ingreso, 'dd/mm/yyyy')" name="f_ingreso"/>
					<qry:attribute value="$r/@d_tipo_personal" name="d_tipo_personal"/>
					<qry:attribute value="$r/@n_valor_hora" name="n_valor_hora"/>
					<qry:attribute value="$r/@c_convenio + ' ' + $r/@d_convenio + ' - ' + $r/@c_categoria + ' ' + $r/@d_categoria" name="convenio"/>
				</qry:element>
				<qry:attribute value="number(@indice) + 1" name="indice"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
