								srtSQL = srtSQL + ' , [Tiempo].[' + arrTime[0] + ']' 	
									if (arrTime.length==2){	
											srtSQL = srtSQL + '.[' + arrTime[1]  + ']';       }
								
								
									
									
								
									for (var i=0; i!=100 ; i++)
									{ srtSQL = srtSQL.replace(new RegExp("  ", "ig"), " ");														
																	}
																
									if (srtSQL.length==1)
