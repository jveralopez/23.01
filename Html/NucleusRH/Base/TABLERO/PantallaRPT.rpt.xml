									var arrTime = new Array();	
									
									      
									srtSQLSelect = ' Select {[Measures].[Cantidad], [Measures].[Remuneracion]} ON columns,{([' + document.getElementById("ROW_Oculto").value +  '] )}  ON rows from [PERSONAL]  ';
									'WHERE {( ';
									     
