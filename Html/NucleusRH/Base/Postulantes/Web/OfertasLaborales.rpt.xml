<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Personal.Legajo">
	<html:query declare="&lt;DATA c_sexo=&quot;M&quot; palabraclave=&quot;tel&quot;&gt;&#13;&#10;&#9;&lt;ROWSSIN&gt;&#13;&#10;&#9;&#9;&lt;ROW c_oferta_lab=&quot;REF#00001&quot; c_sexo=&quot;M&quot; oi_oferta_lab=&quot;1&quot; f_cierre=&quot;20080215&quot; f_oferta_lab=&quot;20070201&quot; d_oferta_lab=&quot;Analista Financiero Senior&quot; seniority=&quot;Jefe/Supervisor/Coordinador/Lider&quot;/&gt;&#13;&#10;&#9;&#9;&lt;ROW c_oferta_lab=&quot;REF#000003&quot; c_sexo=&quot;M&quot; oi_oferta_lab=&quot;3&quot; f_cierre=&quot;20080318&quot; f_oferta_lab=&quot;20070306&quot; d_oferta_lab=&quot;Cadete&quot; seniority=&quot;Jefe/Supervisor/Coordinador/Lider&quot;/&gt;&#13;&#10;&#9;&lt;/ROWSSIN&gt;&#13;&#10;&#9;&lt;ROWS&gt;&#13;&#10;&#9;&lt;ROW o_oferta_lab=&quot;&amp;#241;alsdifj&amp;#241;lasjdf s&amp;#241;ladkjfal&amp;#241;sdjf sadljhiurehiwvruhw skdbjvskubvksaeubv&quot; c_oferta_lab=&quot;REF#000003&quot; c_sexo=&quot;M&quot; oi_oferta_lab=&quot;3&quot; f_cierre=&quot;20080318&quot; f_oferta_lab=&quot;20070306&quot; d_oferta_lab=&quot;Cadete&quot; seniority=&quot;Jefe/Supervisor/Coordinador/Lider&quot;/&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&lt;/DATA&gt;&#13;&#10;" name="dd">
		<qry:main doc="SOURCE">
			<qry:insert-element doc-path="#SOURCE:DATA" name="DATA"/>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="/">
			<html>
				<head>
					<LINK href="../Skins/Styles/GReport.css" type="text/css" rel="stylesheet"/>
					<style type="text/css">
						table.tabla
						{
							border-bottom:2px solid grey;
							font-family:verdana;
							font-size: 10px; 
							padding-bottom: 2px;
						}
						
						td.titulo
						{
							font-family:verdana;
							font-weight: bolder;
							font-size: 14px;
							padding: 2px 2px 2px 2px;	
							text-align: center;
						}  				 
						td.fecha
						{							
							text-align: right;
							vertical-align:top;
						}
						td.mas
						{							
							text-align: right;							
						}
					</style>
				</head>
				<body bgcolor="#ffffff">
					<table width="100%">
						<tr>
							<td class="titulo">
								<xsl:text>
									Ofertas Laborales
								</xsl:text>
							</td>
						</tr>
						<tr>
							<td align="center">
								<xsl:choose>
									<xsl:when test="/DATA/ROWS/ROW">
										<xsl:apply-templates select="/DATA/ROWS/ROW"/>
									</xsl:when>
									<xsl:otherwise>
										<h4>
											<xsl:text>
												No se encontraron Ofertas Laborales que cumplan con los requisitos ingresados
											</xsl:text>
										</h4>
									</xsl:otherwise>
								</xsl:choose>
							</td>
						</tr>
					</table>
					<br/>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="ROW">
			<table class="tabla" width="700px">
				<tr>
					<td colspan="2" class="oferta1">
						<xsl:value-of select="@c_oferta_lab"/>
						<xsl:text>
							&#160;-&#160;
						</xsl:text>
						<xsl:value-of select="@d_oferta_lab"/>
					</td>
				</tr>
				<xsl:if test="@o_oferta_lab">
					<tr>
						<td class="subtit">
							<STRONG>
								<u>
									<xsl:text>
										Descripcion:
									</xsl:text>
								</u>
							</STRONG>
							<xsl:text>
								&#160;
							</xsl:text>
						</td>
					</tr>
					<tr>
						<td width="700px" colspan="2" class="oferta2">
							<xsl:value-of select="@o_oferta_lab"/>
						</td>
					</tr>
				</xsl:if>
				<tr>
					<td width="50%" class="subtit">
						<STRONG>
							<u>
								<xsl:text>
									Sexo requerido:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:choose>
							<xsl:when test="@c_sexo='M'">
								<xsl:text>
									Masculino
								</xsl:text>
							</xsl:when>
							<xsl:when test="@c_sexo='F'">
								<xsl:text>
									Femenino
								</xsl:text>
							</xsl:when>
						</xsl:choose>
					</td>
					<td width="50%" class="subtit">
						<STRONG>
							<u>
								<xsl:text>
									Area Laboral:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@area_lab"/>
					</td>
				</tr>
				<tr>
					<td width="50%" class="subtit">
						<STRONG>
							<u>
								<xsl:text>
									Publicado el d&#237;a:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@f_oferta_lab"/>
					</td>
					<td width="50%" class="subtit">
						<STRONG>
							<u>
								<xsl:text>
									Seniority:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@seniority"/>
					</td>
				</tr>
				<tr>
					<td class="subtit" width="50%">
						<STRONG>
							<u>
								<xsl:text>
									Pa&#237;s:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@pais"/>
					</td>
					<td class="subtit" width="50%">
						<STRONG>
							<u>
								<xsl:text>
									Localidad:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@localidad"/>
					</td>
				</tr>
				<tr>
					<td class="subtit" width="50%">
						<STRONG>
							<u>
								<xsl:text>
									Provincia:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@provincia"/>
					</td>
					<td class="subtit" width="50%">
						<STRONG>
							<u>
								<xsl:text>
									Zona:
								</xsl:text>
							</u>
						</STRONG>
						<xsl:text>
							&#160;
						</xsl:text>
						<xsl:value-of select="@zona"/>
					</td>
				</tr>
				<tr>
					<td colspan="2" align="center" class="link">
						<a href="javascript:" onclick="window.parent.postularse(this.getAttribute('oferta'))">
							<xsl:attribute name="oferta">
								<xsl:value-of select="@oi_oferta_lab"/>
							</xsl:attribute>
							<xsl:text>
								Postularse
							</xsl:text>
						</a>
					</td>
				</tr>
			</table>
			<br/>
		</xsl:template>
	</html:xslt>
</html:html>
