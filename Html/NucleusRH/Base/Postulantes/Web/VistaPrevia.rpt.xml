<html:html doc="source" name="NucleusRH.Base.Personal.Legajo" xmlns:html="nomad:html" xmlns:qry="nomad:html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<html:query declare="&lt;CV id=&quot;1&quot;/&gt;&#13;&#10; " name="dd">
		<qry:main doc="SOURCE">
			<qry:append-doc doc-path="#SOURCE:" name="PARAM"/>
			<qry:element name="CV">
				<qry:insert-select doc-path="#SOURCE:CV" name="DatosPrincipales"/>
				<qry:element name="Cursos">
					<qry:insert-select doc-path="#SOURCE:CV" name="CURSOS"/>
				</qry:element>
				<qry:element name="Idiomas">
					<qry:insert-select doc-path="#SOURCE:CV" name="IDIOMAS"/>
				</qry:element>
				<qry:element name="Estudios">
					<qry:insert-select doc-path="#SOURCE:CV" name="ESTUDIOS"/>
				</qry:element>
				<qry:element name="Competencias">
					<qry:insert-select doc-path="#SOURCE:CV" name="COMPETENCIAS"/>
				</qry:element>
				<qry:element name="Antecedentes">
					<qry:insert-select doc-path="#SOURCE:CV" name="ANTECEDENTES"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="SOURCE" name="DatosPrincipales">
			<qry:xquery>
				for $r in table('
select ORG19_LOCALIDADES.d_localidad localidad_residencia,
ORG35_PROVINCIAS.d_provincia provincia_residencia,
ORG35_PAISES.d_pais pais_residencia,
org22_est_civil.d_estado_civil,
per04_titulos.d_titulo,
org20_idiomas.d_idioma,
per10_grupos_sang.d_grupo_sanguineo,
org12_nacionalid.d_nacionalidad,
loc_nac.d_localidad  localidad_nacimiento,
POS01_cv.d_localidad_nac localidad_nacimiento_dsc,
prov_nac.d_provincia provincia_nacimiento,
pais_nac.d_pais pais_nacimiento,
POS01_cv.d_apellido,
POS01_cv.d_nombres,
POS01_cv.c_nro_doc,
POS01_cv.c_sexo, 
POS01_cv.f_nacim,
POS01_cv.c_nro_cuil,
POS01_cv.f_ingreso_pais,
POS01_cv.c_nro_camisa, POS01_cv.c_nro_pantalon, POS01_cv.c_nro_calzado,
POS01_cv.d_email,
POS01_cv.te_celular,
POS01_cv.d_email_1,
POS01_cv.c_codigo_postal,
POS01_cv.d_calle,
POS01_cv.c_nro,
POS01_cv.c_piso,
POS01_cv.c_departamento,
POS01_cv.te_nro,
POS01_cv.oi_foto
from 
POS01_cv, org19_localidades, org22_est_civil
, ORG35_PROVINCIAS, ORG35_PAISES, per04_titulos
, ORG20_IDIOMAS, PER10_GRUPOS_SANG, org12_nacionalid
, ORG35_PROVINCIAS PROV_NAC, ORG35_PAISES PAIS_NAC, org19_localidades LOC_NAC
where
POS01_cv.oi_localidad *= org19_localidades.oi_localidad
and
POS01_cv.oi_estado_civil *= org22_est_civil.oi_estado_civil
and 
ORG35_PROVINCIAS.oi_provincia =* POS01_cv.oi_provincia
and
ORG35_PAISES.oi_pais =* POS01_cv.oi_pais 
and
per04_titulos.oi_titulo =* POS01_cv.oi_titulo
and
POS01_cv.oi_cv = {%= #SOURCE:@id%}
and 
org20_idiomas.oi_idioma =* POS01_cv.oi_idioma
and
per10_grupos_sang.oi_grupo_sanguineo =* POS01_cv.oi_grupo_sanguineo
and
org12_nacionalid.oi_nacionalidad =* POS01_cv.oi_nacionalidad
AND
POS01_cv.oi_localidad_nac *= loc_nac.oi_localidad
and
prov_nac.oi_provincia =* POS01_cv.oi_provincia_nac
and
pais_nac.oi_pais =* POS01_cv.oi_pais_nac
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_apellido" value="$r/@d_apellido" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_nombres" value="$r/@d_nombres" type="Nomad.NSystem.String"/>
				<qry:attribute name="f_nacim" value="format_date($r/@f_nacim,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
				<qry:attribute name="oi_cv" value="#SOURCE:@oi_cv" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@localidad_nacimiento" name="localidad_nacimiento" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@localidad_nacimiento_dsc" name="localidad_nacimiento_dsc" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@provincia_nacimiento" name="provincia_nacimiento" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@pais_nacimiento" name="pais_nacimiento" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@localidad_residencia" name="localidad_residencia" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@localidad_residencia_dsc" name="localidad_residencia_dsc" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@provincia_residencia" name="provincia_residencia" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@pais_residencia" name="pais_residencia" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@d_estado_civil" name="d_estado_civil" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_titulo" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_idioma" value="$r/@d_idioma" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_sexo" value="$r/@c_sexo" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_grupo_sanguineo" value="$r/@d_grupo_sanguineo" type="Nomad.NSystem.String"/>
				<qry:attribute name="f_ingreso_pais" value="format_date($r/@f_ingreso_pais,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_nro_cuil" value="$r/@c_nro_cuil" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_nacionalidad" value="$r/@d_nacionalidad" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_email" value="$r/@d_email" type="Nomad.NSystem.String"/>
				<qry:attribute name="te_celular" value="$r/@te_celular" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@d_email_1" name="d_email_1" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_nro_camisa" value="$r/@c_nro_camisa" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_nro_pantalon" value="$r/@c_nro_pantalon" type="Nomad.NSystem.String"/>
				<qry:attribute name="c_nro_calzado" value="$r/@c_nro_calzado" type="Nomad.NSystem.String"/>
				<qry:attribute value="$r/@c_codigo_postal" name="c_codigo_postal" type="Nomad.NSystem.String"/>
				<qry:attribute name="d_domicilio" value="$r/@d_domicilio" type="Nomad.NSystem.String"/>
				<qry:attribute name="te_nro" value="format_number($r/@te_nro,'#########')" type="Nomad.NSystem.String"/>
				<qry:attribute name="oi_foto" value="'NucleusRH.Base.Postulantes.DocumentosDigitales.HEAD.'+$r/@oi_foto+'.jpg'" type="Nomad.NSystem.String"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="CURSOS">
			<qry:xquery>
				for $r in table('
select
ORG25_UNIDADES_TPO.D_UNIDAD_TIEMPO D_UNIDAD_TIEMPO
,POS01_cursos_cv.D_CURSO_EXT_CV D_CURSO_EXT_CV
,POS01_cursos_cv.F_FIN_CURSO F_FIN_CURSO
,POS01_cursos_cv.E_DURACION E_DURACION 
,POS01_cursos_cv.D_LUGAR D_LUGAR
,POS01_cursos_cv.L_CERTIFICADO L_CERTIFICADO
,POS01_cursos_cv.L_EXTERNO L_EXTERNO
,POS01_cursos_cv.O_CURSO O_CURSO
, ORG06_CURSOS.D_CURSO D_CURSO
from
POS01_cursos_cv, ORG25_UNIDADES_TPO
, ORG06_CURSOS
where
POS01_cursos_cv.OI_CV =  {%= #SOURCE:@id%}
AND
POS01_cursos_cv.OI_UNIDAD_TIEMPO *= ORG25_UNIDADES_TPO.OI_UNIDAD_TIEMPO
AND
ORG06_CURSOS.OI_CURSO =* POS01_cursos_cv.OI_CURSO
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CadaCurso">
					<qry:attribute name="D_UNIDAD_TIEMPO" value="$r/@D_UNIDAD_TIEMPO" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@E_DURACION" name="E_DURACION " type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@D_CURSO_EXT_CV" name="D_CURSO_EXT_CV" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@D_CURSO" name="D_CURSO" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@F_FIN_CURSO,'dd/mm/yyyy')" name="F_FIN_CURSO" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@D_LUGAR" name="D_LUGAR" type="Nomad.NSystem.String"/>
					<qry:attribute name="L_CERTIFICADO" value="$r/@L_CERTIFICADO" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@L_EXTERNO" name="L_EXTERNO" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@O_CURSO" name="O_CURSO" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="IDIOMAS">
			<qry:xquery>
				for $r in table('
select 

niv_habla.d_nivel_idioma Habla,
niv_lee.d_nivel_idioma Lee,
niv_escribe.d_nivel_idioma Escribe,
org20_idiomas.d_idioma d_idioma,
org25_unidades_tpo.d_unidad_tiempo d_unidad_tiempo,
POS01_idiomas_cv.d_lugar_cursado d_lugar_cursado,
POS01_idiomas_cv.o_idioma o_idioma,
POS01_idiomas_cv.e_tiempo_cursado e_tiempo_cursado,
POS01_idiomas_cv.l_certificado l_certificado,
POS01_idiomas_cv.d_certificado d_certificado
from
POS01_idiomas_cv,
org20_idiomas,
org24_niv_idioma niv_habla,
org24_niv_idioma niv_lee,
org24_niv_idioma niv_escribe,
org25_unidades_tpo
where
POS01_idiomas_cv.oi_cv = {%= #SOURCE:@id%}
and
niv_habla.oi_nivel_idioma =* POS01_idiomas_cv.oi_nivel_habla
and
niv_lee.oi_nivel_idioma =* POS01_idiomas_cv.oi_nivel_lee
and
niv_escribe.oi_nivel_idioma =* POS01_idiomas_cv.oi_nivel_escribe
and
org25_unidades_tpo.oi_unidad_tiempo =* POS01_idiomas_cv.oi_unidad_tiempo
and
org20_idiomas.oi_idioma =* POS01_idiomas_cv.oi_idioma


			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CadaIdioma">
					<qry:attribute name="Habla" value="$r/@Habla" type="Nomad.NSystem.String"/>
					<qry:attribute name="Lee" value="$r/@Lee" type="Nomad.NSystem.String"/>
					<qry:attribute name="Escribe" value="$r/@Escribe" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_idioma" value="$r/@d_idioma" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_unidad_tiempo" value="$r/@d_unidad_tiempo" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@e_tiempo_cursado" name="e_tiempo_cursado" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_lugar_cursado" value="$r/@d_lugar_cursado" type="Nomad.NSystem.String"/>
					<qry:attribute name="o_idioma" value="$r/@o_idioma" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@l_certificado" name="l_certificado" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@d_certificado" name="d_certificado" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="ESTUDIOS" doc="SOURCE">
			<qry:xquery>
				for $r in table('
SELECT 
org11_estudios.d_estudio d_estudio, 
per12_niveles_est.d_nivel_estudio d_nivel_estudio,
PER23_T_EST_EDUC.d_tipo_establecim d_tipo_establecim,
POS01_ESTUDIOS_CV.f_ini_estudio f_ini_estudio, 
POS01_ESTUDIOS_CV.f_fin_estudio f_fin_estudio, 
PER13_ESTADOS_EST.d_estado_est d_estado_est, 
POS01_ESTUDIOS_CV.l_est_extranjero l_est_extranjero, 
POS01_ESTUDIOS_CV.d_est_educacional d_est_educacional, 
POS01_ESTUDIOS_CV.e_duracion_estudio e_duracion_estudio, 
org25_unidades_tpo.d_unidad_tiempo d_unidad_tiempo, 
POS01_ESTUDIOS_CV.e_periodo_en_curso e_periodo_en_curso, 
POS01_ESTUDIOS_CV.e_mat_adeudadas e_mat_adeudadas, 
POS01_ESTUDIOS_CV.f_actualiz f_actualiz, 
POS01_ESTUDIOS_CV.n_promedio n_promedio, 
POS01_ESTUDIOS_CV.o_estudio o_estudio 


FROM 
POS01_ESTUDIOS_CV, per12_niveles_est,
org11_estudios, PER13_ESTADOS_EST,
org25_unidades_tpo,
PER23_T_EST_EDUC
where 
POS01_ESTUDIOS_CV.oi_unidad_tiempo *= org25_unidades_tpo.oi_unidad_tiempo
and
POS01_ESTUDIOS_CV.oi_estudio *= org11_estudios.oi_estudio
and
POS01_ESTUDIOS_CV.oi_nivel_estudio *= per12_niveles_est.oi_nivel_estudio 
and
POS01_ESTUDIOS_CV.oi_tipo_establecim *= PER23_T_EST_EDUC.oi_tipo_establecim
and
POS01_ESTUDIOS_CV.oi_estado_est *= PER13_ESTADOS_EST.oi_estado_est 
and
POS01_ESTUDIOS_CV.oi_cv = {%= #SOURCE:@id%}



			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CadaEstudio">
					<qry:attribute name="d_estudio" value="$r/@d_estudio" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@d_unidad_tiempo" name="d_unidad_tiempo" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@e_duracion_estudio" name="e_duracion_estudio" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@f_ini_estudio,'dd/mm/yyyy')" name="f_ini_estudio" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@f_fin_estudio,'dd/mm/yyyy')" name="f_fin_estudio" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_nivel_estudio" value="$r/@d_nivel_estudio" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_tipo_establecim" value="$r/@d_tipo_establecim" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_estado_est" value="$r/@d_estado_est" type="Nomad.NSystem.String"/>
					<qry:attribute name="l_est_extranjero" value="$r/@l_est_extranjero" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@d_est_educacional" name="d_est_educacional" type="Nomad.NSystem.String"/>
					<qry:attribute name="e_periodo_en_curso" value="$r/@e_periodo_en_curso" type="Nomad.NSystem.String"/>
					<qry:attribute name="e_mat_adeudadas" value="$r/@e_mat_adeudadas" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@f_actualiz,'dd/mm/yyyy')" name="f_actualiz" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@n_promedio" name="n_promedio" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@o_estudio" name="o_estudio" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="COMPETENCIAS">
			<qry:xquery>
				for $r in table('
SELECT 

ORG21_COMPETENCIAS.d_competencia, 
POS01_COMPET_CV.c_nivel_comp, 
POS01_COMPET_CV.o_competencia 

FROM POS01_COMPET_CV
, ORG21_COMPETENCIAS

where 
POS01_COMPET_CV.oi_cv = {%= #SOURCE:@id%}
and
POS01_COMPET_CV.oi_competencia *= ORG21_COMPETENCIAS.oi_competencia
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CadaComp">
					<qry:attribute name="d_competencia" value="$r/@d_competencia" type="Nomad.NSystem.String"/>
					<qry:attribute name="c_nivel_comp" value="$r/@c_nivel_comp" type="Nomad.NSystem.String"/>
					<qry:attribute name="o_competencia" value="$r/@o_competencia" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="ANTECEDENTES">
			<qry:xquery>
				for $r in table('
SELECT 
POS01_ANTEC_CV.f_ingreso, 
POS01_ANTEC_CV.f_egreso, 
POS01_ANTEC_CV.d_empresa, 
POS01_ANTEC_CV.d_dom_empresa, 
POS01_ANTEC_CV.c_pais_emp, 
POS01_ANTEC_CV.c_area_emp,
POS01_ANTEC_CV.c_telefono_emp,
POS01_ANTEC_CV.n_ultimo_sueldo, 
POS01_ANTEC_CV.o_antecedente_cv, 
POS01_ANTEC_CV.d_puesto, 
POS01_ANTEC_CV.e_experiencia, 
ORG25_UNIDADES_TPO.d_unidad_tiempo, 
PER22_MOT_EG_PER.d_motivo_eg_per, 
POS01_ANTEC_CV.o_tareas 

FROM POS01_ANTEC_CV
, PER22_MOT_EG_PER, ORG25_UNIDADES_TPO
where 
POS01_ANTEC_CV.oi_cv =  {%= #SOURCE:@id%}
and
POS01_ANTEC_CV.oi_unidad_tiempo *= ORG25_UNIDADES_TPO.oi_unidad_tiempo
and
POS01_ANTEC_CV.oi_motivo_eg_per *= PER22_MOT_EG_PER.oi_motivo_eg_per
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CadaAntecedente">
					<qry:attribute name="d_empresa" value="$r/@d_empresa" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_puesto" value="$r/@d_puesto" type="Nomad.NSystem.String"/>
					<qry:attribute name="te_empresa" value="$r/@c_pais_emp + '-' + $r/@c_area_emp + '-' + $r/@c_telefono_emp" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_dom_empresa" value="$r/@d_dom_empresa" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@f_ingreso,'dd/mm/yyyy')" name="f_ingreso" type="Nomad.NSystem.String"/>
					<qry:attribute value="format_date($r/@f_egreso,'dd/mm/yyyy')" name="f_egreso" type="Nomad.NSystem.String"/>
					<qry:attribute name="n_ultimo_sueldo" value="$r/@n_ultimo_sueldo" type="Nomad.NSystem.String"/>
					<qry:attribute name="o_antecedente_cv" value="$r/@o_antecedente_cv" type="Nomad.NSystem.String"/>
					<qry:attribute name="e_experiencia" value="$r/@e_experiencia" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_unidad_tiempo" value="$r/@d_unidad_tiempo" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_motivo_eg_per" value="$r/@d_motivo_eg_per" type="Nomad.NSystem.String"/>
					<qry:attribute name="o_tareas" value="$r/@o_tareas" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/">
			<html>
				<HEAD>
					<LINK href="../Styles/GReport.css" type="text/css" rel="stylesheet"/>
				</HEAD>
				<body bgcolor="#F2F2EC">
					<xsl:apply-templates select="CV"/>
					<br/>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="CV">
			<table width="100%" border="0">
				<tr>
					<td align="center" colspan="3">
						<h1>
							Curriculum Vitae
						</h1>
					</td>
				</tr>
				<tr>
					<td align="center" colspan="3">
						<h3>
							<xsl:value-of select="@d_apellido"/>
							<xsl:text>
								,&#160;
							</xsl:text>
							<xsl:value-of select="@d_nombres"/>
						</h3>
					</td>
				</tr>
				<tr>
					<td align="Left" style="border-bottom: solid 1px #110000;" colspan="3">
						<b>
							Datos Principales
						</b>
					</td>
				</tr>
				<tr>
					<td width="10px"/>
					<td align="Left">
						<xsl:if test="@f_nacim">
							<b>
								Fecha de Nacimiento:&#160;
							</b>
							<xsl:value-of select="@f_nacim"/>
							<br/>
						</xsl:if>
						<xsl:if test="@pais_nacimiento or @provincia_nacimiento or @localidad_nacimiento or @localidad_nacimiento_dsc">
							<b>
								Lugar de Nacimiento:&#160;
							</b>
							<xsl:if test="@pais_nacimiento">
								<xsl:value-of select="@pais_nacimiento"/>
								<xsl:text>
									&#160;-&#160;
								</xsl:text>
							</xsl:if>
							<xsl:if test="@provincia_nacimiento">
								<xsl:value-of select="@provincia_nacimiento"/>
								<xsl:text>
									&#160;- &#160;
								</xsl:text>
							</xsl:if>
							<xsl:if test="@localidad_nacimiento">
								<xsl:value-of select="@localidad_nacimiento"/>
							</xsl:if>
							<xsl:if test="@localidad_nacimiento=''">
