<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Liquidacion.NovedadesLiquidacion">
	<html:query declare="&lt;DATOS f_desde=&quot;19000101&quot; f_hasta=&quot;20140106&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="#SOURCE:DATOS"/>
			<REPORT label="Ofertas Laborales">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<COL name="f_desde" label="Fecha Desde" type="date"/>
							<COL name="f_hasta" label="Fecha Hasta" type="date"/>
						</COLS>
						<GROUP tag="Selectoras" style="padding-left:50px;" type="title_collapse">
							<COLS>
								<COL name="e_numero_legajo" label="Legajo - Apellido y Nombre" style="font-size:12px"/>
							</COLS>
							<GROUP tag="OFERTAS" style="padding-left:50px;" type="table">
								<COLS>
									<COL name="c_oferta_lab" label="Referencia" style="width: 150px"/>
									<COL name="d_oferta_lab" label="Puesto" style="width: 400px"/>
									<COL name="f_oferta_lab" label="Fecha" style="width: 150px" type="date"/>
									<COL name="f_cierre" label="Fecha Cierre" style="width: 150px" type="date"/>
								</COLS>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:attribute value="format_date(#SOURCE:DATOS/@f_desde,'dd/mm/yyyy')" name="f_desde"/>
						<qry:attribute value="format_date(#SOURCE:DATOS/@f_hasta,'dd/mm/yyyy')" name="f_hasta"/>
						<qry:insert-select name="Selectoras"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="Selectoras">
			<qry:xquery>
				for $r in sql('
					SELECT
						NMD_SECURITY.New_user
					FROM 
						NMD_SECURITY,
						POS03_OFERTAS_LAB
					JOIN
						NMD_SECURITY.id INNER POS03_OFERTAS_LAB.oi_oferta_lab 
					WHERE 
						NMD_SECURITY.class = \'NucleusRH.Base.Postulantes.Ofertas_Laborales.OFERTA_LAB\'					
						AND POS03_OFERTAS_LAB.f_oferta_lab &gt;= {Datetime(#FILTRO:@f_desde)}
						AND POS03_OFERTAS_LAB.f_oferta_lab &lt;= {Datetime(#FILTRO:@f_hasta)}
					GROUP BY
						NMD_SECURITY.New_user
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:append-doc doc-path="$r" name="PARAMIN"/>
				<qry:element name="Selectoras">
					<qry:attribute value="$r/@New_user" name="New_user"/>
					<qry:attribute name="e_numero_legajo" value="'No Asignado'"/>
					<qry:insert-select name="account-name"/>
					<qry:insert-select name="OFERTAS" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="OFERTAS">
			<qry:xquery>
				for $r in sql('
					SELECT 
						POS03_OFERTAS_LAB.c_oferta_lab,
						POS03_OFERTAS_LAB.d_oferta_lab, 
						POS03_OFERTAS_LAB.f_oferta_lab,
						POS03_OFERTAS_LAB.f_cierre
					FROM
						NMD_SECURITY, 
						POS03_OFERTAS_LAB
					JOIN
						NMD_SECURITY.id INNER POS03_OFERTAS_LAB.oi_oferta_lab 	
					WHERE
						NMD_SECURITY.class = \'NucleusRH.Base.Postulantes.Ofertas_Laborales.OFERTA_LAB\'
						AND POS03_OFERTAS_LAB.f_oferta_lab &gt;= {#FILTRO:@f_desde}
						AND POS03_OFERTAS_LAB.f_oferta_lab &lt;= {#FILTRO:@f_hasta}
						AND NMD_SECURITY.New_user = {#SOURCE:@New_User}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="OFERTAS">
					<qry:attribute value="$r/@c_oferta_lab" name="c_oferta_lab"/>
					<qry:attribute value="$r/@d_oferta_lab" name="d_oferta_lab"/>
					<qry:attribute value="format_date($r/@f_oferta_lab,'dd/mm/yyyy')" name="f_oferta_lab"/>
					<qry:attribute value="format_date($r/@f_cierre,'dd/mm/yyyy')" name="f_cierre"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="account-name" doc="SOURCE">
			<qry:xquery>
				for $r in path('Nomad\\Base\\Login\\Cuentas')/CUENTA
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="sql2" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="sql2" doc="PARAM">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Login\\Cuentas\\{%= #PARAM:@FILE %}')/CUENTA[@LOGIN=#PARAMIN:@New_user]/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="sql4" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="sql4" doc="PARAM">
			<qry:xquery>
				for $r in sql('
					SELECT 
						PER02_PERSONAL_EMP.oi_personal_emp,
						PER02_PERSONAL_EMP.e_numero_legajo,
						PER01_PERSONAL.d_ape_y_nom
					FROM
						PER01_PERSONAL, 
						PER02_PERSONAL_EMP
					JOIN 
						PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
					WHERE
						PER01_PERSONAL.oi_usuario_sistema = {#PARAM:@value}
						AND PER02_PERSONAL_EMP.oi_indic_activo = 1
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
				<qry:attribute value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom" name="e_numero_legajo"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
