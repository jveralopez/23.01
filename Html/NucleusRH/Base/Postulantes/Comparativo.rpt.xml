<html:html doc="source" name="NucleusRH.Base.Postulantes.Comparativo" xmlns:html="nomad:html" xmlns:qry="nomad:html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<html:query declare="&lt;xmldiff xmlns:new=&quot;new&quot; xmlns:old=&quot;old&quot; xmlns:del=&quot;del&quot; xmlns:ins=&quot;ins&quot; xmlns:diff=&quot;diff&quot;&gt;&#13;&#10;  &lt;PAIS descr=&quot;[URU] URUGUAY&quot; oi_idioma=&quot;4&quot; d_pais=&quot;URUGUAY&quot; c_pais=&quot;URU&quot; id=&quot;2&quot; old:o_pais=&quot;Fuera las pasteras!!!&quot; new:o_pais=&quot;Fuera las papeleras!!!&quot; diff:status=&quot;~u,&quot;&gt;&#13;&#10;    &lt;oi_nacionalidad value=&quot;73&quot; /&gt;&#13;&#10;    &lt;PROVINCIAS nmd-col=&quot;1&quot;&gt;&#13;&#10;      &lt;PROVINCIA descr=&quot;[URU] URUGUAY - [MO] MONTEVIDEO&quot; d_provincia=&quot;MONTEVIDEO&quot; c_provincia=&quot;MO&quot; oi_pais=&quot;2&quot; id=&quot;28&quot;&gt;&#13;&#10;        &lt;oi_region /&gt;&#13;&#10;      &lt;/PROVINCIA&gt;&#13;&#10;      &lt;PROVINCIA descr=&quot;[URU] URUGUAY - [SA] SALTO&quot; d_provincia=&quot;SALTO&quot; c_provincia=&quot;SA&quot; oi_pais=&quot;2&quot; id=&quot;30&quot;&gt;&#13;&#10;        &lt;oi_region /&gt;&#13;&#10;      &lt;/PROVINCIA&gt;&#13;&#10;      &lt;PROVINCIA descr=&quot;[URU] URUGUAY - [PY] PaysandU&quot; d_provincia=&quot;PaysandU&quot; c_provincia=&quot;PY&quot; oi_pais=&quot;2&quot; id=&quot;31&quot;&gt;&#13;&#10;        &lt;oi_region /&gt;&#13;&#10;      &lt;/PROVINCIA&gt;&#13;&#10;      &lt;PROVINCIA descr=&quot;[URU] URUGUAY - [CA] CANELONES&quot; o_provincia=&quot;Aqui no se inventaron los canelones, por las dudas digo nomas.&quot; d_provincia=&quot;CANELONES&quot; c_provincia=&quot;CA&quot; oi_pais=&quot;2&quot; id=&quot;32&quot; diff:status=&quot;~i,&quot;&gt;&#13;&#10;        &lt;oi_region /&gt;&#13;&#10;      &lt;/PROVINCIA&gt;&#13;&#10;    &lt;/PROVINCIAS&gt;&#13;&#10;  &lt;/PAIS&gt;&#13;&#10;  &lt;package nmd-col=&quot;1&quot;&gt;&#13;&#10;    &lt;class name=&quot;PAIS&quot; description=&quot;PaIses&quot;&gt;&#13;&#10;      &lt;attributes nmd-col=&quot;1&quot;&gt;&#13;&#10;        &lt;attr name=&quot;oi_pais&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;c_pais&quot; description=&quot;COdigo de PaIs. Puede ser un alfanumErico de hasta 30 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;d_pais&quot; description=&quot;DescripciOn de PaIs. Puede ser un alfanumErico de hasta 100 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;oi_idioma&quot; description=&quot;Idioma que se habla en el PaIs.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;o_pais&quot; description=&quot;Observaciones del PaIs. Puede ser un alfanumErico de hasta 1000 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;&quot; /&gt;&#13;&#10;      &lt;/attributes&gt;&#13;&#10;    &lt;/class&gt;&#13;&#10;    &lt;class name=&quot;PROVINCIA&quot; description=&quot;Provincias&quot;&gt;&#13;&#10;      &lt;attributes nmd-col=&quot;1&quot;&gt;&#13;&#10;        &lt;attr name=&quot;oi_provincia&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;oi_pais&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;c_provincia&quot; description=&quot;COdigo de Provincia. Puede ser un alfanumErico de hasta 30 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;d_provincia&quot; description=&quot;DescripciOn de Provincia. Puede ser un alfanumErico de hasta 100 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;c_provincia_sicore&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;c_prov_expl_afjp&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;o_provincia&quot; description=&quot;Observaciones de la Provincia. Puede ser un alfanumErico de hasta 1000 caracteres.&quot; /&gt;&#13;&#10;        &lt;attr name=&quot;&quot; /&gt;&#13;&#10;      &lt;/attributes&gt;&#13;&#10;    &lt;/class&gt;&#13;&#10;  &lt;/package&gt;&#13;&#10;&lt;/xmldiff&gt;">
		<qry:main doc="SOURCE">
			<qry:insert-element doc-path="#SOURCE:/xmldiff"/>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="/">
			<html>
				<head>
					<style>
						table{
					    font-family: Verdana;
					    font-size: 11px;
					    font-weight: bold;
							border-top: 1px solid #889A81;
							border-left: 1px solid #889A81;							
 							border-bottom: 1px solid #889A81;
							width: 100%;}					
						
						td{
							border: 0px solid #889A81;
							nowrap: true;}
					
						th{
							background-color:#889A81;
							font-size: 11px;
							font-weight: bold;
							font-family: Verdana;
							text-align: left;
							color: #ffffff;
 							padding-bottom: 5px;														
						}
						
						.new{
							background-image: url("../Skins/images/audit/new_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat;
							width: 20px; 
						}

						.ins{
							background-image: url("../Skins/images/audit/new_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat;
							width: 20px;
						}

						.del{
							background-image: url("../Skins/images/audit/del_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat; 
							width: 20px;							
						}
							
						.old{
							background-image: url("../Skins/images/audit/del_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat; 
							width: 20px;							
						}

						.upd{
							background-image: url("../Skins/images/audit/edit_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat; 
							width: 20px;							
						}
							
						.eql{
							background-image: url("../Skins/images/audit/equal_o.gif"); 
							background-position:bottom right; 
							background-repeat:no-repeat; 
							width: 20px;							
						}
					</style>
				</head>
				<body width="100%" bgcolor="#FFFFFF">
					<table cellspacing="0" cellpadding="0" style="border-right: 1px solid #889A81;">
						<tr>
							<th colspan="8" style="text-align: center;">
								Referencias
							</th>
						</tr>
						<tr style="padding-top: 10px;">
							<td class="new"/>
							<td style="padding-left: 10px;">
								Nuevo
							</td>
							<td class="upd"/>
							<td style="padding-left: 10px;">
								Actualizado
							</td>
							<td class="del"/>
							<td style="padding-left: 10px;">
								Eliminado
							</td>
							<td class="eql"/>
							<td style="padding-left: 10px;">
								No Modificado
							</td>
						</tr>
					</table>
					<br/>
					<table cellspacing="0" cellpadding="0" style="border-right: 1px solid #889A81;">
						<tr>
							<th colspan="3">
								Entidades
							</th>
						</tr>
						<xsl:for-each select="/xmldiff/*">
							<xsl:call-template name="element"/>
						</xsl:for-each>
					</table>
				</body>
			</html>
		</xsl:template>
		<xsl:template name="element" xmlns:new="new" xmlns:old="old" xmlns:del="del" xmlns:ins="ins" xmlns:diff="diff">
			<xsl:if test="name()!='package'">
				<xsl:variable name="eclass">
					<xsl:choose>
						<xsl:when test="@diff:status='~u,'">
							upd
						</xsl:when>
						<xsl:when test="@diff:status='~i,'">
							new
						</xsl:when>
						<xsl:when test="@diff:status='~d,'">
							del
						</xsl:when>
						<xsl:otherwise>
							eql
						</xsl:otherwise>
					</xsl:choose>
				</xsl:variable>
				<tr>
					<td colspan="2">
						<br/>
					</td>
				</tr>
				<tr>
					<td>
						<xsl:attribute name="class">
							<xsl:value-of select="$eclass"/>
						</xsl:attribute>
					</td>
					<td style="padding-left: 10px;">
						<span style="background-color:#889A81; font-weight: bold; color: #ffffff; padding-left: 10px; padding-right: 10px">
							<xsl:value-of select="name()"/>
						</span>
					</td>
				</tr>
				<xsl:if test="@*[namespace-uri()!='diff' and local-name()!='nmd-col']">
					<tr>
						<td>
							<xsl:text/>
						</td>
						<td style="padding-left: 10px;">
							<table cellspacing="0" cellpadding="0">
								<th colspan="2">
									Atributo
								</th>
								<th style="padding-left: 10px;">
									Valor
								</th>
								<xsl:for-each select="@*">
									<xsl:sort select="local-name()"/>
									<xsl:sort select="namespace-uri()"/>
									<xsl:if test="namespace-uri()!='diff' and local-name()!='nmd-col'">
										<tr>
											<xsl:attribute name="style">
												<xsl:if test="namespace-uri()!=''">
													background-color:#C8D1C5;
												</xsl:if>
											</xsl:attribute>
											<td>
												<xsl:attribute name="class">
													<xsl:if test="namespace-uri()=''">
														eql
													</xsl:if>
													<xsl:value-of select="namespace-uri()"/>
												</xsl:attribute>
											</td>
											<td style="width: 1px; padding-left: 10px;">
												<xsl:value-of select="local-name()"/>
											</td>
											<td style="padding-left: 10px;">
												<xsl:value-of select="."/>
											</td>
										</tr>
									</xsl:if>
								</xsl:for-each>
							</table>
						</td>
					</tr>
				</xsl:if>
				<xsl:if test="*">
					<tr height="5px">
						<td colspan="3">
							<xsl:text/>
						</td>
					</tr>
					<tr>
						<td>
							<xsl:text/>
						</td>
						<td colspan="2" style="padding-left: 10px;">
							<table cellspacing="0" cellpadding="0">
								<tr>
									<th colspan="3">
										Entidades
									</th>
								</tr>
								<xsl:for-each select="*">
									<xsl:call-template name="element"/>
								</xsl:for-each>
							</table>
						</td>
					</tr>
				</xsl:if>
			</xsl:if>
		</xsl:template>
	</html:xslt>
</html:html>
