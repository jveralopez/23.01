<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Liquidacion.EstadisticaConceptos" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;FILTRO gcustom=&quot;&quot; oi_empresa=&quot;164&quot; cod_desde=&quot;&quot; cod_hasta=&quot;&quot; oi_tipo_concepto=&quot;&quot; c_agrupacion=&quot;categ&quot; gpers=&quot;&quot; liq_cod=&quot;&quot; liq_f_des=&quot;201211&quot; liq_f_has=&quot;201212&quot; liq_f_pag_des=&quot;&quot; liq_f_pag_has=&quot;&quot; liq_oi_tipo_liq=&quot;&quot; liq_c_estado=&quot;&quot; liqID=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; oi_banco=&quot;&quot; oi_sucursal=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS&gt;&lt;ROW VALUES=&quot;11471,11496,11497,11498,11499,11500,11501,11502,11503,11504,11505,11506,11509,11464,11511,11513,11514,11554,11470,11468,11469,11510&quot;/&gt;&lt;/PERSONAS&gt;&lt;LIQUIDACIONES&gt;&lt;ROW VALUES=&quot;636&quot;/&gt;&lt;/LIQUIDACIONES&gt;&lt;/FILTRO&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:FILTRO"/>
			<qry:append-doc name="LEGAJOS" doc-path="#SOURCE:FILTRO/PERSONAS"/>
			<qry:append-doc name="LIQUIDACIONES" doc-path="#SOURCE:FILTRO/LIQUIDACIONES"/>
			<REPORT label="Totales por Legajos">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="CAB" type="title" noreg="No se encontraron registros para este concepto.">
						<COLS>
							<COL name="d_empresa" label="Empresa"/>
							<COL name="conc_des_has" label="Concepto Desde - Hasta"/>
						</COLS>
						<GROUP label="Liquidaciones" tag="LIQUIDACIONES" style="width:500px" type="table">
							<COLS>
								<COL name="COD" label="Codigo" width="20%"/>
								<COL name="DES" label="Descripcion" width="40%"/>
								<COL name="PER" label="Periodo" style="text-align:center;" width="10%"/>
								<COL name="TYP" label="Tipo" width="20%"/>
							</COLS>
						</GROUP>
						<GROUP tag="GRUPO" type="title" noreg="No se encontraron registros para este per&#237;odo.">
							<COLS>
								<qry:switch test="#PARAMIN:@c_agrupacion">
									<qry:case value="centro">
										<COL name="grupos" label="Centro de Costo" align="left" width="10"/>
									</qry:case>
									<qry:case value="ubicacion">
										<COL name="grupos" label="Ubicaci&#243;n" align="left" width="10"/>
									</qry:case>
									<qry:case value="obra">
										<COL name="grupos" label="Obra Social" align="left" width="10"/>
									</qry:case>
									<qry:case value="sindicato">
										<COL name="grupos" label="Sindicato" align="left" width="10"/>
									</qry:case>
									<qry:case value="convenio">
										<COL name="grupos" label="Convenio" align="left" width="10"/>
									</qry:case>
									<qry:case value="categ">
										<COL name="grupos" label="Categor&#237;a" align="left" width="10"/>
									</qry:case>
								</qry:switch>
							</COLS>
							<GROUP tag="CONC" style="padding-left:50px;width:1130px;" type="table" noreg="No se encontraron registros para este concepto.">
								<COLS>
									<COL name="e_numero_legajo" label="Legajo" style="width:20px;"/>
									<COL name="d_ape_y_nom" label="Nombre y Apellido" style="width:600px;" type="string"/>
									<COL name="n_valor1" label="Remunerativo" style="width:100px;" type="num"/>
									<COL name="n_valor2" label="No Remunerativo" style="width:110px;" type="num"/>
									<COL name="n_valor3" label="Descuentos" style="width:100px;" type="num"/>
									<COL name="n_valor4" label="Contribuciones" style="width:100px;" type="num"/>
									<COL name="n_valor5" label="Estad&#237;sticos" style="width:100px;" type="num"/>
								</COLS>
								<FCOLS>
									<COL colspan="2"/>
									<COL name="n_valor1" type="num"/>
									<COL name="n_valor2" type="num"/>
									<COL name="n_valor3" type="num"/>
									<COL name="n_valor4" type="num"/>
									<COL name="n_valor5" type="num"/>
								</FCOLS>
							</GROUP>
						</GROUP>
						<qry:if test="#PARAMIN:@c_agrupacion!=''">
							<qry:then>
								<GROUP label="Totales Generales" tag="TGCONC" style="padding-left:50px;" type="table-up">
									<COLS>
										<COL name="n_valor1" label="Remunerativo" type="num"/>
										<COL name="n_valor2" label="No Remunerativo" type="num"/>
										<COL name="n_valor3" label="Descuentos" type="num"/>
										<COL name="n_valor4" label="Contribuciones" type="num"/>
										<COL name="n_valor5" label="Estad&#237;sticos" type="num"/>
									</COLS>
								</GROUP>
							</qry:then>
						</qry:if>
					</GROUP>
				</GROUPS>
				<AUX>
					<qry:append-doc name="AUX" doc-path="."/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:switch test="#PARAMIN:@c_agrupacion">
						<qry:case value="ubicacion">
							<qry:attribute name="col_groupby" value="'LIQ97_PERSONAL_EMP.c_ubicacion'"/>
							<qry:attribute name="col_where" value="'LIQ97_PERSONAL_EMP.c_ubicacion'"/>
						</qry:case>
						<qry:case value="obra">
							<qry:attribute name="col_groupby" value="'LIQ97_PERSONAL_EMP.c_obra_social'"/>
							<qry:attribute name="col_where" value="'LIQ97_PERSONAL_EMP.c_obra_social'"/>
						</qry:case>
						<qry:case value="sindicato">
							<qry:attribute name="col_groupby" value="'LIQ97_PERSONAL_EMP.c_sindicato'"/>
							<qry:attribute name="col_where" value="'LIQ97_PERSONAL_EMP.c_sindicato'"/>
						</qry:case>
						<qry:case value="convenio">
							<qry:attribute name="col_groupby" value="'LIQ97_PERSONAL_EMP.c_convenio'"/>
							<qry:attribute name="col_where" value="'LIQ97_PERSONAL_EMP.c_convenio'"/>
						</qry:case>
						<qry:case value="categ">
							<qry:attribute name="col_groupby" value="'LIQ97_PERSONAL_EMP.c_convenio, LIQ97_PERSONAL_EMP.c_categoria_ult'"/>
							<qry:attribute name="col_where" value="'(LIQ97_PERSONAL_EMP.c_convenio || \\\'_\\\' || LIQ97_PERSONAL_EMP.c_categoria_ult)'"/>
						</qry:case>
						<qry:case value="centro">
							<qry:attribute name="col_groupby" value="'DisCC.cc'"/>
							<qry:attribute name="col_where" value="'DisCC.cc'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="col_groupby" value="''"/>
							<qry:attribute name="col_where" value="''"/>
						</qry:default>
					</qry:switch>
					<qry:if test="#PARAMIN:@c_agrupacion!=''">
						<qry:then>
							<qry:insert-select name="qry_legajos"/>
						</qry:then>
						<qry:else>
							<qry:insert-select name="qry_legajos2"/>
						</qry:else>
					</qry:if>
					<qry:if test="@oi!=''">
						<qry:then>
							<ROW>
								<qry:attribute name="values" value="substring(../@oi,1)"/>
								<qry:attribute name="gb" value="../@gb"/>
							</ROW>
							<qry:attribute name="oi" value="''"/>
							<qry:attribute name="gb" value="''"/>
						</qry:then>
					</qry:if>
				</AUX>
				<DATA>
					<CAB qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
						<qry:append-doc name="CAB" doc-path="."/>
						<qry:attribute name="conc_des_has" value="(#PARAMIN:@cod_desde) + ' - ' + (#PARAMIN:@cod_hasta)"/>
						<qry:insert-select name="qry_empresa" doc-path="#PARAMIN:"/>
						<qry:insert-select name="qry_liquidaciones" doc-path="#LIQUIDACIONES:"/>
						<qry:switch test="#PARAMIN:@c_agrupacion">
							<qry:case value="ubicacion">
								<qry:insert-select name="qry_ubicacion" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:case value="obra">
								<qry:insert-select name="qry_obraSocial" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:case value="sindicato">
								<qry:insert-select name="qry_sindicato" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:case value="convenio">
								<qry:insert-select name="qry_convenio" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:case value="categ">
								<qry:insert-select name="qry_categ" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:case value="centro">
								<qry:insert-select name="qry_ccosto" doc-path="#PARAMIN:"/>
							</qry:case>
							<qry:default>
								<GRUPO qry-delete-child="1" qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
									<qry:call>
										<FILTRO>
											<qry:append-doc name="FILTRO" doc-path="."/>
											<qry:attribute name="col_groupby" value="$AUX/@col_groupby"/>
											<qry:attribute name="col_where" value="$AUX/@col_where"/>
											<qry:attribute name="c_agrupacion" value="#PARAMIN:@c_agrupacion"/>
											<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
											<qry:attribute name="oi_tipo_concepto" value="#PARAMIN:@oi_tipo_concepto"/>
											<qry:attribute name="cod_desde" value="#PARAMIN:@cod_desde"/>
											<qry:attribute name="cod_hasta" value="#PARAMIN:@cod_hasta"/>
											<qry:attribute name="oi_liqs" value="String(#LIQUIDACIONES:ROW/@values)"/>
											<qry:attribute name="l_incluir" value="#PARAMIN:@l_incluir"/>
											<qry:attribute name="gb" value="''"/>
											<qry:attribute name="values" value="#AUX:ROW/@values"/>
										</FILTRO>
									</qry:call>
								</GRUPO>
							</qry:default>
						</qry:switch>
						<qry:element name="TGCONC">
							<qry:if test="#PARAMIN:@c_agrupacion!=''">
								<qry:then>
									<qry:attribute name="d_concepto" value="'Totales Generales'"/>
									<qry:attribute name="CONCEPTO" value="'Total General'"/>
									<qry:attribute name="count" value="../@count"/>
									<qry:attribute name="n_cantidad" value="../@n_cantidad"/>
									<qry:attribute name="n_valor1" value="../@n_valor1"/>
									<qry:attribute name="n_valor2" value="../@n_valor2"/>
									<qry:attribute name="n_valor3" value="../@n_valor3"/>
									<qry:attribute name="n_valor4" value="../@n_valor4"/>
									<qry:attribute name="n_estadistico" value="../@n_estadistico"/>
								</qry:then>
							</qry:if>
						</qry:element>
					</CAB>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_empresa">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ORG03_EMPRESAS.c_empresa,
					ORG03_EMPRESAS.d_empresa
				FROM 
					ORG03_EMPRESAS
				WHERE 
					ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_liquidaciones">
			<qry:xquery>
				for $r in sql('
				SELECT 
					LIQ19_LIQUIDACION.c_liquidacion,
					LIQ19_LIQUIDACION.d_titulo,
					LIQ19_LIQUIDACION.e_periodo,
					LIQ01_TIPOS_LIQ.d_tipo_liq
				FROM 
					LIQ19_LIQUIDACION, LIQ01_TIPOS_LIQ
				JOIN                               
					LIQ19_LIQUIDACION.oi_tipo_liq INNER LIQ01_TIPOS_LIQ.oi_tipo_liq
				WHERE 
					LIQ19_LIQUIDACION.oi_liquidacion in ({%=String(#SOURCE:ROW/@values) %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LIQUIDACIONES>
					<qry:attribute name="COD" value="$r/@c_liquidacion"/>
					<qry:attribute name="DES" value="$r/@d_titulo"/>
					<qry:attribute name="PER" value="format_date($r/@e_periodo+'01','Mmm-yyyy')"/>
					<qry:attribute name="TYP" value="$r/@d_tipo_liq"/>
				</LIQUIDACIONES>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_ubicacion">
			<qry:xquery>
				for $r in sql('
				SELECT ORG03_UBICACIONES.oi_ubicacion, 
							 ORG03_UBICACIONES.c_ubicacion, 
							 ORG03_UBICACIONES.d_ubicacion
				FROM ORG03_UBICACIONES
				WHERE ORG03_UBICACIONES.oi_empresa = {#PARAMIN:@oi_empresa}
				ORDER BY c_ubicacion ASC
			')/ROWS/ROW,
				$l in #AUX:ROW
		join
				$l/@gb inner $r/@c_ubicacion
			</qry:xquery>
			<qry:out>
				<GRUPO qry-delete-child="1" qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
					<qry:call>
						<FILTRO>
							<qry:append-doc name="FILTRO" doc-path="."/>
							<qry:attribute name="col_groupby" value="$AUX/@col_groupby"/>
							<qry:attribute name="col_where" value="$AUX/@col_where"/>
							<qry:attribute name="c_agrupacion" value="#PARAMIN:@c_agrupacion"/>
							<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
							<qry:attribute name="oi_tipo_concepto" value="#PARAMIN:@oi_tipo_concepto"/>
							<qry:attribute name="cod_desde" value="#PARAMIN:@cod_desde"/>
							<qry:attribute name="cod_hasta" value="#PARAMIN:@cod_hasta"/>
							<qry:attribute name="oi_liqs" value="String(#LIQUIDACIONES:ROW/@values)"/>
							<qry:attribute name="l_incluir" value="#PARAMIN:@l_incluir"/>
							<qry:attribute name="c_ubicacion" value="$r/@c_ubicacion"/>
							<qry:attribute name="gb" value="$r/@c_ubicacion"/>
							<qry:attribute name="values" value="$l/@values"/>
						</FILTRO>
					</qry:call>
					<qry:attribute name="grupos" value="$r/@c_ubicacion + ' - ' + $r/@d_ubicacion"/>
				</GRUPO>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_ccosto">
			<qry:xquery>
				for $r in sql('
				SELECT ORG08_CS_COSTO.oi_centro_costo, 
							 ORG08_CS_COSTO.c_centro_costo, 
							 ORG08_CS_COSTO.d_centro_costo
				FROM ORG08_CS_COSTO 
				ORDER BY c_centro_costo asc
			')/ROWS/ROW,
				$l in #AUX:ROW
		join
				$l/@gb inner $r/@c_centro_costo
			</qry:xquery>
			<qry:out>
				<GRUPO qry-delete-child="1" qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
					<qry:call>
						<FILTRO>
							<qry:append-doc name="FILTRO" doc-path="."/>
							<qry:attribute name="col_groupby" value="$AUX/@col_groupby"/>
							<qry:attribute name="col_where" value="$AUX/@col_where"/>
							<qry:attribute name="c_agrupacion" value="#PARAMIN:@c_agrupacion"/>
							<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
							<qry:attribute name="oi_tipo_concepto" value="#PARAMIN:@oi_tipo_concepto"/>
							<qry:attribute name="cod_desde" value="#PARAMIN:@cod_desde"/>
							<qry:attribute name="cod_hasta" value="#PARAMIN:@cod_hasta"/>
							<qry:attribute name="oi_liqs" value="String(#LIQUIDACIONES:ROW/@values)"/>
							<qry:attribute name="l_incluir" value="#PARAMIN:@l_incluir"/>
							<qry:attribute name="c_centro_costo" value="$r/@c_centro_costo"/>
							<qry:attribute name="gb" value="$r/@c_centro_costo"/>
							<qry:attribute name="values" value="$l/@values"/>
						</FILTRO>
					</qry:call>
					<qry:attribute name="grupos" value="$r/@c_centro_costo + ' - ' + $r/@d_centro_costo"/>
				</GRUPO>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_obraSocial">
			<qry:xquery>
				for $r in sql('
				SELECT PER06_OBRAS_SOC.oi_obra_social, 
							 PER06_OBRAS_SOC.c_obra_social, 
							 PER06_OBRAS_SOC.d_obra_social
				FROM PER06_OBRAS_SOC
				ORDER BY c_obra_social ASC
			')/ROWS/ROW,
				$l in #AUX:ROW
		join
				$l/@gb inner $r/@c_obra_social
			</qry:xquery>
			<qry:out>
				<GRUPO qry-delete-child="1" qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
					<qry:call>
						<FILTRO>
							<qry:append-doc name="FILTRO" doc-path="."/>
							<qry:attribute name="col_groupby" value="$AUX/@col_groupby"/>
							<qry:attribute name="col_where" value="$AUX/@col_where"/>
							<qry:attribute name="c_agrupacion" value="#PARAMIN:@c_agrupacion"/>
							<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
							<qry:attribute name="oi_tipo_concepto" value="#PARAMIN:@oi_tipo_concepto"/>
							<qry:attribute name="cod_desde" value="#PARAMIN:@cod_desde"/>
							<qry:attribute name="cod_hasta" value="#PARAMIN:@cod_hasta"/>
							<qry:attribute name="oi_liqs" value="String(#LIQUIDACIONES:ROW/@values)"/>
							<qry:attribute name="l_incluir" value="#PARAMIN:@l_incluir"/>
							<qry:attribute name="c_obra_social" value="$r/@c_obra_social"/>
							<qry:attribute name="gb" value="$r/@c_obra_social"/>
							<qry:attribute name="values" value="$l/@values"/>
						</FILTRO>
					</qry:call>
					<qry:attribute name="grupos" value="$r/@c_obra_social + ' - ' + $r/@d_obra_social"/>
				</GRUPO>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_sindicato">
			<qry:xquery>
				for $r in sql('
				SELECT PER30_SINDICATOS.oi_sindicato, 
							 PER30_SINDICATOS.c_sindicato,
							 PER30_SINDICATOS.d_sindicato
				FROM PER30_SINDICATOS 
				ORDER BY c_sindicato ASC
			')/ROWS/ROW,
				$l in #AUX:ROW
		join
				$l/@gb inner $r/@c_sindicato
			</qry:xquery>
			<qry:out>
				<GRUPO qry-delete-child="1" qry-sum="n_valor1,n_valor2,n_valor3,n_valor4,n_valor5">
					<qry:call>
						<FILTRO>
							<qry:append-doc name="FILTRO" doc-path="."/>
							<qry:attribute name="col_groupby" value="$AUX/@col_groupby"/>
							<qry:attribute name="col_where" value="$AUX/@col_where"/>
							<qry:attribute name="c_agrupacion" value="#PARAMIN:@c_agrupacion"/>
							<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
							<qry:attribute name="oi_tipo_concepto" value="#PARAMIN:@oi_tipo_concepto"/>
							<qry:attribute name="cod_desde" value="#PARAMIN:@cod_desde"/>
							<qry:attribute name="cod_hasta" value="#PARAMIN:@cod_hasta"/>
							<qry:attribute name="oi_liqs" value="String(#LIQUIDACIONES:ROW/@values)"/>
							<qry:attribute name="l_incluir" value="#PARAMIN:@l_incluir"/>
							<qry:attribute name="c_sindicato" value="$r/@c_sindicato"/>
							<qry:attribute name="gb" value="$r/@c_sindicato"/>
							<qry:attribute name="values" value="$l/@values"/>
						</FILTRO>
					</qry:call>
					<qry:attribute name="grupos" value="$r/@c_sindicato + ' - ' + $r/@d_sindicato"/>
				</GRUPO>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_convenio">
			<qry:xquery>
				for $r in sql('
				SELECT ORG18_CONVENIOS.oi_convenio,
							 ORG18_CONVENIOS.c_convenio,
							 ORG18_CONVENIOS.d_convenio
				FROM ORG18_CONVENIOS    
				ORDER BY c_convenio ASC
			')/ROWS/ROW,
				$l in #AUX:ROW
		join
