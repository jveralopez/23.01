<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Liquidacion.DefinicionReportes100" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATA  oi_reporte=&quot;2&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT style="width:80%" label="Definici&#243;n de Reportes 100">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP style="width:100%" type="title" tag="CABECERA">
						<COLS>
							<COL label="C&#243;digo" name="c_reporte"/>
							<COL label="Descripci&#243;n" name="d_reporte"/>
							<COL label="T&#237;tulo" name="titulo"/>
							<COL style="padding-bottom:20px" label="Agrupado Por" name="c_agrupacion"/>
							<COL label="Mostrar sin Conceptos" name="mostrar"/>
							<COL label="Salto de P&#225;gina por Grupo" name="separar"/>
							<COL style="padding-bottom:30px" label="Agregar Columna de Totales" name="agregartotales"/>
						</COLS>
						<GROUP style="width:100%" type="table" label="Columnas Fijas" tag="COLFIJAS" noreg="No posee Columnas Fijas.">
							<COLS>
								<COL style="width:10%; text-align:center" label="Posici&#243;n" name="posicion" nowrap="1"/>
								<COL style="width:35%; text-align:center" label="Nombre" name="nombre" nowrap="1"/>
								<COL style="width:35%; text-align:center" label="Etiqueta" name="etiqueta" nowrap="1"/>
								<COL style="width:20%; text-align:center" label="Tipo de Dato" name="tipo" nowrap="1"/>
							</COLS>
						</GROUP>
						<GROUP style="width:100%" type="table" label="Columnas Calculables" tag="COLCALCULABLES" noreg="No posee Columnas Calculables.">
							<COLS>
								<COL style="width:10%; text-align:center" label="Posici&#243;n" name="posicion" nowrap="1"/>
								<COL style="width:25%; text-align:center" label="Etiqueta" name="etiqueta" nowrap="1"/>
								<COL style="width:20%; text-align:center" label="Tipo" name="tipo" nowrap="1"/>
								<COL style="width:10%; text-align:center" label="Signo" name="signo" nowrap="1"/>
								<COL style="width:10%; text-align:center" label="Sumar" name="sumar" nowrap="1"/>
								<COL style="width:25%;" label="Conceptos" name="conceptos" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<qry:insert-select name="qryReporte" doc-path="$SOURCE"/>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select name="qryReporte" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
			
	SELECT	r.oi_reporte, 	
			r.c_reporte, 
			r.d_reporte, 
			r.o_label, 
			r.c_agrupacion,
			r.l_mostrar,
			r.l_separar,
			r.l_agregartotales
		
	FROM LIQ26_REPORTES as r
					
	WHERE  r.oi_reporte = {$PARAM/DATA/@oi_reporte} 
			
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<CABECERA>
					<qry:attribute name="c_reporte" value="$r/@c_reporte"/>
					<qry:attribute name="d_reporte" value="$r/@d_reporte"/>
					<qry:attribute name="titulo" value="$r/@o_label"/>
					<!--Agrupado por-->
					<qry:switch test="$r/@c_agrupacion">
						<qry:case value="centro">
							<qry:attribute name="c_agrupacion" value="'Centro de Costo'"/>
						</qry:case>
						<qry:case value="afjp">
							<qry:attribute name="c_agrupacion" value="'AFJP'"/>
						</qry:case>
						<qry:case value="obra">
							<qry:attribute name="c_agrupacion" value="'Obra Social'"/>
						</qry:case>
						<qry:case value="sindicato">
							<qry:attribute name="c_agrupacion" value="'Sindicato'"/>
						</qry:case>
						<qry:case value="categ">
							<qry:attribute name="c_agrupacion" value="'Categor&#237;a'"/>
						</qry:case>
						<qry:case value="c_ubic">
							<qry:attribute name="c_agrupacion" value="'Ubicaci&#243;n'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_agrupacion" value="'No esta agrupado'"/>
						</qry:default>
					</qry:switch>
					<!--Fin del Switch de Agrupado Por-->
					<!--Muestra Conceptos-->
					<qry:if test="$r/@l_mostrar=1">
						<qry:then>
							<qry:attribute name="mostrar" value="'Si'"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="mostrar" value="'No'"/>
						</qry:else>
					</qry:if>
					<!--Fin del Muestra Conceptos-->
					<!--Salto de Pagina por Grupo-->
					<qry:if test="$r/@l_separar=1">
						<qry:then>
							<qry:attribute name="separar" value="'Si'"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="separar" value="'No'"/>
						</qry:else>
					</qry:if>
					<!--Fin del Salto de Pagina por Grupo-->
					<!--Agrega Columna de Totales-->
					<qry:if test="$r/@l_agregartotales=1">
						<qry:then>
							<qry:attribute name="agregartotales" value="'Si'"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="agregartotales" value="'No'"/>
						</qry:else>
					</qry:if>
					<!--Fin del Agrega Columna de Totales-->
					<qry:insert-select name="qryColumnasFijas" doc-path="$r"/>
					<qry:insert-select name="qryColumnasCalculables" doc-path="$r"/>
				</CABECERA>
			</qry:out>
		</qry:select>
		<qry:select name="qryColumnasFijas" doc="PARAM">
			<qry:xquery>
				for $r in SQL('

	SELECT 	c.e_posicion,
			c.c_columna,
			c.d_columna,
			c.c_tipo

	FROM 
			LIQ26_COLFIJAS as c

			WHERE c.oi_reporte = {#PARAM:@oi_reporte}

			ORDER BY  e_posicion ASC 
		
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<COLFIJAS>
					<qry:attribute name="posicion" value="$r/@e_posicion"/>
					<!--Nombre-->
					<qry:switch test="$r/@c_columna">
						<qry:case value="c_nro_cuil">
							<qry:attribute name="nombre" value="'CUIL'"/>
						</qry:case>
						<qry:case value="e_numero_legajo">
							<qry:attribute name="nombre" value="'Legajo'"/>
						</qry:case>
						<qry:case value="d_ape_y_nom">
							<qry:attribute name="nombre" value="'Apellido y Nombre'"/>
						</qry:case>
						<qry:case value="f_nacim">
							<qry:attribute name="nombre" value="'Fecha de Nacim.'"/>
						</qry:case>
						<qry:case value="f_ingreso">
							<qry:attribute name="nombre" value="'Fecha de Ingreso'"/>
						</qry:case>
						<qry:case value="f_antiguedad_rec">
							<qry:attribute name="nombre" value="'Fecha Antig.'"/>
						</qry:case>
						<qry:case value="centro">
							<qry:attribute name="nombre" value="'Centro de Costo'"/>
						</qry:case>
						<qry:case value="sexo">
							<qry:attribute name="nombre" value="'Sexo'"/>
						</qry:case>
						<qry:case value="categ">
							<qry:attribute name="nombre" value="'Categor&#237;a'"/>
						</qry:case>
						<qry:case value="c_ubic">
							<qry:attribute name="nombre" value="'C&#243;digo Ubicaci&#243;n'"/>
						</qry:case>
						<qry:case value="d_ubic">
							<qry:attribute name="nombre" value="'Descripci&#243;n Ubicaci&#243;n'"/>
						</qry:case>
						<qry:case value="obra">
							<qry:attribute name="nombre" value="'Obra Social'"/>
						</qry:case>
						<qry:case value="afjp">
							<qry:attribute name="nombre" value="'AFJP'"/>
						</qry:case>
						<qry:case value="sindicato">
							<qry:attribute name="nombre" value="'Sindicato'"/>
						</qry:case>
						<qry:case value="col1">
							<qry:attribute name="nombre" value="'Sujeto a Retenci&#243;n'"/>
						</qry:case>
						<qry:case value="col1-1">
							<qry:attribute name="nombre" value="'No Sujeto a Retenci&#243;n'"/>
						</qry:case>
						<qry:case value="bruto">
							<qry:attribute name="nombre" value="'Sueldo Bruto'"/>
						</qry:case>
						<qry:case value="col1-2">
							<qry:attribute name="nombre" value="'Sueldo Neto'"/>
						</qry:case>
						<qry:case value="col1-3">
							<qry:attribute name="nombre" value="'Descuentos'"/>
						</qry:case>
						<qry:case value="col1-4">
							<qry:attribute name="nombre" value="'Contribuciones'"/>
						</qry:case>
						<qry:case value="col1-5">
							<qry:attribute name="nombre" value="'Asignaciones Familiares'"/>
						</qry:case>
						<qry:case value="c_funcion">
							<qry:attribute name="nombre" value="'C&#243;digo Funci&#243;n'"/>
						</qry:case>
						<qry:case value="d_funcion">
							<qry:attribute name="nombre" value="'Descripci&#243;n Funci&#243;n'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="nombre" value="$r/@c_columna"/>
						</qry:default>
					</qry:switch>
					<!--Fin del Switch Nombre-->
					<qry:attribute name="etiqueta" value="$r/@d_columna"/>
					<!--Tipo de Dato-->
					<qry:switch test="$r/@c_tipo">
						<qry:case value="num">
							<qry:attribute name="tipo" value="'Num&#233;rico'"/>
						</qry:case>
						<qry:case value="alfa">
							<qry:attribute name="tipo" value="'Cadena de Caracteres'"/>
						</qry:case>
						<qry:case value="string">
							<qry:attribute name="tipo" value="'C&#243;digo'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="tipo" value="$r/@c_tipo"/>
						</qry:default>
					</qry:switch>
					<!--Fin del Switch tipo de dato-->
				</COLFIJAS>
			</qry:out>
		</qry:select>
		<qry:select name="qryColumnasCalculables" doc="PARAM">
			<qry:xquery>
				for $r in SQL('

	SELECT  c.oi_columna, 	
			c.e_posicion,
			c.d_columna,
			c.c_tipo,
			c.c_signo,
			c.c_sumar
			

	FROM 
			LIQ26_COLUMNAS as c

			WHERE c.oi_reporte = {#PARAM:@oi_reporte}

			ORDER BY  e_posicion ASC 
		
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<COLCALCULABLES>
					<qry:attribute name="posicion" value="$r/@e_posicion"/>
					<qry:attribute name="etiqueta" value="$r/@d_columna"/>
					<qry:attribute name="tipo" value="$r/@c_tipo"/>
					<!--Signo-->
					<qry:switch test="$r/@c_signo">
						<qry:case value="1">
							<qry:attribute name="signo" value="'Sumar'"/>
						</qry:case>
						<qry:case value="0">
							<qry:attribute name="signo" value="'Restar'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="signo" value="$r/@c_signo"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="sumar" value="$r/@c_sumar"/>
					<!--Sumar-->
					<qry:switch test="$r/@c_sumar">
						<qry:case value="C">
							<qry:attribute name="sumar" value="'Cantidad'"/>
						</qry:case>
						<qry:case value="V">
							<qry:attribute name="sumar" value="'Valor'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="signo" value="$r/@c_sumar"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="conceptos" value="''"/>
					<qry:insert-select name="qryConceptosPorColumna" doc-path="$r"/>
				</COLCALCULABLES>
			</qry:out>
		</qry:select>
		<qry:select name="qryConceptosPorColumna" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
			
	SELECT	LIQ14_CONCEPTOS.d_concepto, 	
			LIQ14_CONCEPTOS.c_concepto
		
	FROM LIQ26_COL_CON,
		 LIQ14_CONCEPTOS
	
	JOIN
		
		LIQ26_COL_CON.oi_concepto INNER LIQ14_CONCEPTOS.oi_concepto 
					
	WHERE  LIQ26_COL_CON.oi_columna = {#PARAM:@oi_columna} 
			
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="conceptos" value="concat(@conceptos,' [',$r/@c_concepto,'] ',$r/@d_concepto,'&lt;br/&gt;')"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
