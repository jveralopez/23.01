}
					</STYLE>
				</head>
				<body>
					<table width="100%">
						<tr>
							<td>
								<xsl:apply-templates select="CONCEPTO"/>
								<xsl:if test="count(CONCEPTO)=0">
									<span style="text-align:center;width:100%;font-size:24px;font-weight:800;">
										No se encontro el Recibo
									</span>
								</xsl:if>
							</td>
						</tr>
					</table>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="CONCEPTO">
			<table class="tabla" width="800px">
				<tr>
					<th colspan="5">
						CONCEPTO
					</th>
				</tr>
				<tr>
					<td>
						<b>
							Codigo:&#160;
						</b>
						<xsl:value-of select="@c_concepto"/>
						<br/>
						<b>
							Descripcion:&#160;
						</b>
						<xsl:value-of select="@d_concepto"/>
						<br/>
					</td>
					<td>
						<b>
							Tipo:&#160;
						</b>
						<xsl:value-of select="@d_tipo_concepto"/>
						<br/>
						<b>
							Version:&#160;
						</b>
						<xsl:value-of select="@c_version"/>
						<br/>
					</td>
					<td>
						<b>
							Secuencia:&#160;
						</b>
						<xsl:value-of select="@e_secuencia"/>
						<br/>
						<b>
							Etapa:&#160;
						</b>
						<xsl:choose>
							<xsl:when test="@e_etapa=1">
								Por Cargos
							</xsl:when>
							<xsl:when test="@e_etapa=2">
								Pos Cargos
							</xsl:when>
							<xsl:otherwise>
								Pre Cargos
							</xsl:otherwise>
						</xsl:choose>
						<br/>
					</td>
					<td>
						<b>
							Acumula Ganancia:&#160;
						</b>
						<xsl:value-of select="@ca_acum_ganancia"/>
						<br/>
						<b>
							Figura en Recibo:&#160;
						</b>
						<xsl:value-of select="@ca_fig_recibo"/>
						<br/>
					</td>
					<td>
						<b>
							Ejecuta en Ajuste:&#160;
						</b>
						<xsl:value-of select="@l_ej_ajuste"/>
						<br/>
						<b>
							Retroactivo:&#160;
						</b>
						<xsl:value-of select="@l_retroactivo"/>
						<br/>
					</td>
				</tr>
			</table>
			<br/>
			<xsl:for-each select="cargo">
				<table class="tabla" width="100%">
					<xsl:if test="@show=1">
						<tr>
							<th colspan="4" style="text-align:left;font-size:12px;font-weight:normal;">
								<xsl:if test="@centrocosto!=''">
									<b>
										Centro&#160;de&#160;Costo:&#160;
									</b>
									<xsl:value-of select="@centrocosto"/>
									<br/>
								</xsl:if>
								<xsl:if test="@categoria!=''">
									<b>
										Categoria:&#160;
									</b>
									<xsl:value-of select="@categoria"/>
									<br/>
								</xsl:if>
								<xsl:if test="@materia!=''">
									<b>
										Materia:&#160;
									</b>
									<xsl:value-of select="@materia"/>
									<br/>
								</xsl:if>
							</th>
						</tr>
					</xsl:if>
					<tr>
						<th colspan="4">
							VARIABLES
						</th>
					</tr>
					<tr>
						<td style="padding:0;" VALIGN="top" colspan="4">
							<table class="mute" style="width:100%;">
								<tr>
									<xsl:if test="entrada/VAR">
										<td style="padding:0;border-right:1px solid black;" VALIGN="top">
											<table class="tablain" style="width:100%;">
												<tr>
													<th colspan="3">
														Entrada
													</th>
												</tr>
												<tr>
													<td colspan="2">
														Nombre
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Valor
													</td>
												</tr>
												<xsl:for-each select="entrada/VAR">
													<tr>
														<td class="img">
															<img src="./Images/Reports/search_n.gif" title="detalles de la Variable" style="cursor:pointer;">
																<xsl:attribute name="onclick">
																	<xsl:value-of select="concat('opener.ShowREPORT(&quot;NucleusRH.Base.Liquidacion.ReciboVariable.rpt&quot;,&quot;oi_tot_liq_per=',../../../@oi_tot_liq_per,'|c_variable=',@nombre,'|cargo=',@cargo,'&quot;);')"/>
																</xsl:attribute>
															</img>
														</td>
														<td>
															<xsl:value-of select="@nombre"/>
															<xsl:if test="@perlabel">
																<xsl:value-of select="concat('[',@perlabel,']')"/>
															</xsl:if>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_e"/>
														</td>
													</tr>
												</xsl:for-each>
											</table>
										</td>
									</xsl:if>
									<xsl:if test="salida/VAR">
										<td style="padding:0;border-right:1px solid black;" VALIGN="top">
											<table class="tablain" style="width:100%;">
												<tr>
													<th colspan="4">
														Entrada/Salida
													</th>
												</tr>
												<tr>
													<td colspan="2">
														Nombre
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Entrada
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Salida
													</td>
												</tr>
												<xsl:for-each select="salida/VAR">
													<tr>
														<td class="img">
															<img src="./Images/Reports/search_n.gif" title="detalles de la Variable" style="cursor:pointer;">
																<xsl:attribute name="onclick">
																	<xsl:value-of select="concat('opener.ShowREPORT(&quot;NucleusRH.Base.Liquidacion.ReciboVariable.rpt&quot;,&quot;oi_tot_liq_per=',../../../@oi_tot_liq_per,'|c_variable=',@nombre,'&quot;);')"/>
																</xsl:attribute>
															</img>
														</td>
														<td>
															<xsl:value-of select="@nombre"/>
															<xsl:if test="@perlabel">
																<xsl:value-of select="concat('[',@perlabel,']')"/>
															</xsl:if>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_e"/>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_s"/>
														</td>
													</tr>
												</xsl:for-each>
											</table>
										</td>
									</xsl:if>
									<xsl:if test="locales/VAR">
										<td style="padding:0;border-right:1px solid black;" VALIGN="top">
											<table class="tablain" style="width:100%;">
												<tr>
													<th colspan="2">
														Locales
													</th>
												</tr>
												<tr>
													<td>
														Nombre
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Valor
													</td>
												</tr>
												<xsl:for-each select="locales/VAR">
													<tr>
														<td>
															<xsl:value-of select="@nombre"/>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_e"/>
														</td>
													</tr>
												</xsl:for-each>
											</table>
										</td>
									</xsl:if>
									<xsl:if test="acumuladores/VAR">
										<td style="padding:0;" VALIGN="top">
											<table class="tablain" style="width:100%;">
												<tr>
													<th colspan="5">
														Acumuladores
													</th>
												</tr>
												<tr>
													<td colspan="2">
														Nombre
													</td>
													<td>
														Tipo
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Entrada
													</td>
													<td style="border-left:1px solid #AAAAAA;text-align:center;">
														Salida
													</td>
												</tr>
												<xsl:for-each select="acumuladores/VAR">
													<tr>
														<td class="img">
															<img src="./Images/Reports/search_n.gif" title="detalles de la Variable" style="cursor:pointer;">
																<xsl:attribute name="onclick">
																	<xsl:value-of select="concat('opener.ShowREPORT(&quot;NucleusRH.Base.Liquidacion.ReciboVariable.rpt&quot;,&quot;oi_tot_liq_per=',../../../@oi_tot_liq_per,'|c_variable=',@nombre,'&quot;);')"/>
																</xsl:attribute>
															</img>
														</td>
														<td>
															<xsl:value-of select="@nombre"/>
															<xsl:if test="@perlabel">
																<xsl:value-of select="concat('[',@perlabel,']')"/>
															</xsl:if>
														</td>
														<td>
															<xsl:value-of select="@tipo"/>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_e"/>
														</td>
														<td style="border-left:1px solid #AAAAAA;text-align:right;">
															<xsl:value-of select="@valor_s"/>
														</td>
													</tr>
												</xsl:for-each>
											</table>
										</td>
									</xsl:if>
								</tr>
							</table>
						</td>
					</tr>
				</table>
				<br/>
				<xsl:if test="*/VAR[@periodo!='']">
					<xsl:variable name="periodo">
						<xsl:value-of select="../@e_periodo"/>
					</xsl:variable>
					<table class="tabla" width="100%">
						<tr>
							<th colspan="4">
								VARIABLES POR PERIODO / VALORES DE ENTRADA
							</th>
						</tr>
						<tr>
							<td style="padding:0;" VALIGN="top" colspan="4">
								<table class="tablain" style="width:100%;">
									<tr>
										<td colspan="2">
											Nombre
										</td>
										<xsl:if test="($periodo mod 100) &lt; 1">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('ENE-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 2">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('FEB-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 3">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('MAR-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 4">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('ABR-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 5">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('MAY-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 6">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('JUN-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 7">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('JUL-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 8">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('AGO-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 9">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('SEP-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 10">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('OCT-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 11">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('NOV-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &lt; 12">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('DIC-',substring($periodo - 100,1,4))"/>
											</td>
										</xsl:if>
										<xsl:if test="($periodo mod 100) &gt;= 1">
											<td style="border-left:1px solid #AAAAAA;text-align:center;">
												<xsl:value-of select="concat('ENE-',substring($periodo,1,4))"/>
											</td>
