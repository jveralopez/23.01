<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Liquidacion.Recibo">
	<html:query declare="&lt;PARAMS oi_tot_liq_per=&quot;13906&quot; c_concepto=&quot;1&quot; c_concepto1=&quot;90000002&quot; /&gt;">
		<qry:main doc="PARAM">
			<qry:element name="datos">
				<qry:insert-select doc-path="#PARAM:/PARAMS" name="qry_concepto"/>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_concepto">
			<qry:xquery>
				for $r in sql('
select 
CON.c_concepto, 
CON.d_concepto, 
CON.c_tipo_concepto, 
TCO.d_tipo_concepto, 
CON.ca_fig_recibo, 
CON.ca_acum_ganancia, 
CON.l_ej_ajuste, 
CON.l_activo, 
CON.t_formula, 
CON.e_secuencia,
CON.e_etapa,  
CON.l_retroactivo,
LIQ.e_periodo,
CON.c_version
from 
liq20_tot_liq_per as REC, 
liq99_liquidacion as LIQ, 
liq96_conceptos as CON,
LIQ12_TIPOS_CONC as TCO
where
REC.oi_liquidacion_ddo=LIQ.oi_liquidacion_ddo and
CON.oi_cab_conc_ddo=LIQ.oi_cab_conc_ddo and
CON.c_tipo_concepto=TCO.c_tipo_concepto and
REC.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per} and
CON.c_concepto = {#PARAM:@c_concepto}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONCEPTO">
					<qry:attribute name="oi_tot_liq_per" value="#PARAM:@oi_tot_liq_per"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
					<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
					<qry:attribute name="d_tipo_concepto" value="$r/@d_tipo_concepto"/>
					<qry:switch test="$r/@ca_fig_recibo">
						<qry:case value="N">
							<qry:attribute name="ca_fig_recibo" value="'No'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="ca_fig_recibo" value="'Si'"/>
						</qry:case>
						<qry:case value="I">
							<qry:attribute name="ca_fig_recibo" value="'Solo Importe'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="ca_fig_recibo" value="$r/@ca_fig_recibo"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@ca_acum_ganancia">
						<qry:case value="N">
							<qry:attribute name="ca_acum_ganancia" value="'No Acumula'"/>
						</qry:case>
						<qry:case value="H">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Deducciones'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="l_ej_ajuste" value="iif($r/@l_ej_ajuste='1','Si','No')"/>
					<qry:attribute name="t_formula" value="$r/@t_formula"/>
					<qry:attribute name="e_secuencia" value="$r/@e_secuencia"/>
					<qry:attribute name="e_etapa" value="$r/@e_etapa"/>
					<qry:attribute name="l_activo" value="iif($r/@l_activo='1','Si','No')"/>
					<qry:attribute name="l_retroactivo" value="iif($r/@l_retroactivo='1','Si','No')"/>
					<qry:switch test="$r/@c_version">
						<qry:case value="">
							<qry:attribute name="c_version" value="'1.0'"/>
						</qry:case>
						<qry:case value="1">
							<qry:attribute name="c_version" value="'1.0'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_version" value="'2.0'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_version" value="$r/@c_version"/>
						</qry:default>
					</qry:switch>
					<qry:insert-select name="qry_variables" doc-path="#PARAM:"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_variables" doc="PARAM">
			<qry:xquery>
				for $r in FILEIO('RECIBOS\\{%=#PROXY:@App %}\\{%=#PARAM:@oi_tot_liq_per %}.recibo.xml')/RECIBO/CONCEPTOS/CONCEPTO[@COD=#PARAM:@c_concepto]
			</qry:xquery>
			<qry:out>
				<cargo>
					<qry:attribute name="manual" value="$r/@manual"/>
					<qry:attribute name="error" value="$r/@error"/>
					<qry:attribute name="cantidad" value="$r/@cantidad"/>
					<qry:attribute name="valor" value="$r/@valor"/>
					<qry:attribute name="cargo" value="$r/@cargo"/>
					<qry:if test="$r/@cargo!=''">
						<qry:then>
							<qry:attribute name="show" value="1"/>
							<qry:attribute name="materia" value="$r/../../CARGOS/CARGO[number($r/@cargo)]/@Materia"/>
							<qry:attribute name="categoria" value="$r/../../CARGOS/CARGO[number($r/@cargo)]/@Categoria"/>
							<qry:attribute name="centrocosto" value="$r/../../CARGOS/CARGO[number($r/@cargo)]/@CentroCosto"/>
						</qry:then>
					</qry:if>
					<entrada>
						<qry:insert-element name="VAR" doc-path="$r/VAR[@tipo='IN']"/>
					</entrada>
					<salida>
						<qry:insert-element name="VAR" doc-path="$r/VAR[@tipo='OUT']"/>
					</salida>
					<locales>
						<qry:insert-element name="VAR" doc-path="$r/VAR[@tipo='LOC']"/>
					</locales>
					<acumuladores>
						<qry:insert-element name="VAR" doc-path="$r/VAR[@tipo='ACC' or @tipo='ACV' or @tipo='AUTO']"/>
					</acumuladores>
				</cargo>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/datos">
			<html>
				<head>
					<LINK href="../Skins/_Default/Styles/GReport.css" type="text/css" rel="stylesheet"/>
					<STYLE>
						body{background-color:#FFFFFF;}
.img
{
width:1px;
font-size:1px;
}

