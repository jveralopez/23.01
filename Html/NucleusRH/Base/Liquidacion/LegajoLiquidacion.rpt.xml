<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Liquidacion.ListadoConcepto">
	<html:query declare="&lt;FILTRO oi_liquidacion=&quot;58&quot; oi_personal_emp=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN3=&quot;&quot; ca_fig_recibo=&quot;&quot; l_activo=&quot;&quot; oi_tipo_concepto=&quot;1&quot; oi_clase_concepto=&quot;&quot;&gt;&lt;CONCEPTOS /&gt;&lt;/FILTRO&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="DATOS">
				<qry:element name="PERSONAS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="QRY_PERSONA"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="QRY_PERSONA" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				SELECT     
PER01_PERSONAL.d_ape_y_nom, 
PER01_PERSONAL.c_sexo, 
PER01_PERSONAL.c_nro_cuil, 
ORG22_EST_CIVIL.d_estado_civil, 
ORG22_EST_CIVIL.c_estado_civil, 
PER03_AFJP.d_afjp, 
PER03_AFJP.c_afjp, 
PER02_PERSONAL_EMP.f_ingreso, 
PER02_PERSONAL_EMP.e_numero_legajo, 
PER02_PERSONAL_EMP.f_antiguedad_rec, 
PER02_PERSONAL_EMP.f_egreso, 
ORG18_CATEGORIAS.c_categoria, 
ORG18_CATEGORIAS.d_categoria, 
ORG18_CATEGORIAS.n_valor_hora, 
ORG18_CONVENIOS.c_convenio, 
ORG18_CONVENIOS.d_convenio, 
PER02_PERSONAL_EMP.n_est_pas_mes, 
PER11_TIPOS_PERS.c_tipo_personal, 
PER11_TIPOS_PERS.d_tipo_personal, 
PER06_OBRAS_SOC.c_obra_social, 
PER06_OBRAS_SOC.d_obra_social, 
PER30_SINDICATOS.c_sindicato, 
PER30_SINDICATOS.d_sindicato, 
PER02_PERSONAL_EMP.n_ult_remun, 
LIQ07_PERSONAL.c_cta_bancaria, 
LIQ07_PERSONAL.c_tarjeta, 
ORG03_EMPRESAS.c_empresa, 
ORG03_EMPRESAS.d_empresa, 
LIQ19_LIQUIDACION.c_liquidacion, 
LIQ19_LIQUIDACION.d_titulo,
PER01_PERSONAL.oi_personal,
PER02_PERSONAL_EMP.oi_personal_emp,
LIQ25_PERSONAL_LIQ.oi_personal_liq,
LIQ19_LIQUIDACION.oi_liquidacion,
LIQ15_EMPRESAS.oi_empresa,
LIQ19_LIQUIDACION.e_periodo

FROM         
PER02_PERSONAL_EMP , PER01_PERSONAL , LIQ07_PERSONAL ,
PER03_AFJP , PER30_SINDICATOS , ORG18_CATEGORIAS , ORG18_CONVENIOS ,
ORG22_EST_CIVIL , PER06_OBRAS_SOC , PER11_TIPOS_PERS ,
ORG03_EMPRESAS , LIQ15_EMPRESAS , LIQ19_LIQUIDACION ,LIQ25_PERSONAL_LIQ
JOIN
PER02_PERSONAL_EMP.oi_personal      INNER PER01_PERSONAL.oi_personal ,
PER01_PERSONAL.oi_afjp              LEFT OUTER PER03_AFJP.oi_afjp ,
PER02_PERSONAL_EMP.oi_personal_emp  INNER LIQ07_PERSONAL.oi_personal_emp ,
PER02_PERSONAL_EMP.oi_sindicato     LEFT OUTER PER30_SINDICATOS.oi_sindicato ,
PER02_PERSONAL_EMP.oi_categoria_ult INNER ORG18_CATEGORIAS.oi_categoria ,
ORG18_CATEGORIAS.oi_convenio        INNER ORG18_CONVENIOS.oi_convenio ,
PER01_PERSONAL.oi_estado_civil      LEFT OUTER ORG22_EST_CIVIL.oi_estado_civil ,
PER02_PERSONAL_EMP.oi_obra_social   LEFT OUTER PER06_OBRAS_SOC.oi_obra_social ,
PER02_PERSONAL_EMP.oi_tipo_personal LEFT OUTER PER11_TIPOS_PERS.oi_tipo_personal ,
PER02_PERSONAL_EMP.oi_empresa       INNER ORG03_EMPRESAS.oi_empresa ,
ORG03_EMPRESAS.oi_empresa           INNER LIQ15_EMPRESAS.oi_empresa ,
LIQ15_EMPRESAS.oi_empresa           INNER LIQ19_LIQUIDACION.oi_empresa ,
LIQ07_PERSONAL.oi_personal_emp      INNER LIQ25_PERSONAL_LIQ.oi_personal_emp , 
LIQ19_LIQUIDACION.oi_liquidacion    INNER LIQ25_PERSONAL_LIQ.oi_liquidacion
where 
LIQ19_LIQUIDACION.oi_liquidacion    = {%= #SOURCE:@oi_liquidacion %} 
{%? (#SOURCE:@oi_personal_emp!='')	{% and LIQ25_PERSONAL_LIQ.oi_personal_emp= {%=#SOURCE:@oi_personal_emp %} %} {% %} %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PERSONA">
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
					<qry:attribute name="c_sexo" value="$r/@c_sexo"/>
					<qry:attribute name="c_nro_cuil" value="$r/@c_nro_cuil"/>
					<qry:attribute name="estado" value="$r/@c_estado_civil + ' - ' + $r/@d_estado_civil"/>
					<qry:attribute name="afjp" value="$r/@c_afjp + ' - ' + $r/@d_afjp"/>
					<qry:attribute name="tipopersonal" value="$r/@c_tipo_personal + ' - ' + $r/@d_tipo_personal"/>
					<qry:attribute name="empresa" value="$r/@c_empresa + ' - ' + $r/@d_empresa"/>
					<qry:attribute name="liquidacion" value="$r/@c_liquidacion + ' - ' + $r/@d_titulo"/>
					<qry:attribute name="categoria" value="$r/@c_categoria + ' - ' + $r/@d_categoria"/>
					<qry:attribute name="sindicato" value="$r/@c_sindicato + ' - ' + $r/@d_sindicato"/>
					<qry:attribute name="convenio" value="$r/@c_convenio + ' - ' + $r/@d_convenio"/>
					<qry:attribute name="obrasocial" value="$r/@c_obra_social + ' - ' + $r/@d_obra_social"/>
					<qry:attribute value="format_date($r/@f_ingreso,'dd/mm/yyyy')" name="f_ingreso"/>
					<qry:attribute value="format_date($r/@f_antiguedad_rec,'dd/mm/yyyy')" name="f_antiguedad_rec"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute value="format_date($r/@f_egreso,'dd/mm/yyyy')" name="f_egreso"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_valor_hora, 10, 2, '.', '', '')" name="n_valor_hora"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_est_pas_mes, 10, 2, '.', '', '')" name="n_est_pas_mes"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_ult_remun, 10, 2, '.', '', '')" name="n_ult_remun"/>
					<qry:attribute name="c_cta_bancaria" value="$r/@c_cta_bancaria"/>
					<qry:attribute name="iniPeriodo" value="$r/@e_periodo + '01'"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:element name="FAMILIARES">
						<qry:insert-select doc-path="$r" name="QRY_FAM"/>
					</qry:element>
					<qry:element name="VAR_FIJAS">
						<qry:insert-select doc-path="$r" name="QRY_VARF"/>
					</qry:element>
					<qry:element name="VAR_ACUM">
						<qry:insert-select doc-path="$r" name="QRY_VARA"/>
					</qry:element>
					<qry:element name="NOVEDADES">
						<qry:insert-select doc-path="$r" name="QRY_VAREN"/>
					</qry:element>
					<qry:element name="NOVEDADESLIQ">
						<qry:insert-select doc-path="$r" name="QRY_VARGN"/>
					</qry:element>
					<qry:element name="EMPFIJAS">
						<qry:insert-select doc-path="$r" name="QRY_VARGF"/>
					</qry:element>
					<qry:element name="CONCEPTOS">
						<qry:insert-select doc-path="$r" name="QRY_CONC"/>
					</qry:element>
					<qry:element name="LICENCIAS">
						<qry:insert-select doc-path=".." name="QRY_LIC"/>
					</qry:element>
					<qry:element name="DEDUCCIONES">
						<qry:insert-select name="QRY_DEDUC" doc-path="$r"/>
					</qry:element>
					<qry:element name="PARAMETROS">
						<qry:insert-select name="QRY_PARAM" doc-path="$r"/>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FAM" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				
SELECT     
PER01_FLIARES_PER.d_ape_y_nom, 
PER08_NIVELES_ESC.d_nivel_escol, 
PER08_NIVELES_ESC.c_nivel_escol, 
PER15_TIPOS_FAM.c_tipo_familiar, 
PER15_TIPOS_FAM.d_tipo_familiar, 
PER01_FLIARES_PER.l_vive, 
PER01_FLIARES_PER.l_discapacidad, 
PER01_FLIARES_PER.l_acargo_af, 
PER01_FLIARES_PER.l_acargo_os, 
PER01_FLIARES_PER.l_acargo_IG,
PER01_FLIARES_PER.f_nacimiento

FROM         
PER01_FLIARES_PER , PER15_TIPOS_FAM , PER08_NIVELES_ESC 
JOIN
PER01_FLIARES_PER.oi_tipo_familiar INNER PER15_TIPOS_FAM.oi_tipo_familiar ,
PER01_FLIARES_PER.oi_nivel_escol LEFT OUTER PER08_NIVELES_ESC.oi_nivel_escol
where            
PER01_FLIARES_PER.oi_personal = {%= #SOURCE:@oi_personal %}
and
l_vive=1
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="FAMILIAR">
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="l_discapacidad" value="$r/@l_discapacidad"/>
					<qry:attribute name="l_acargo_af" value="$r/@l_acargo_af"/>
					<qry:attribute name="l_acargo_os" value="$r/@l_acargo_os"/>
					<qry:attribute name="l_acargo_IG" value="$r/@l_acargo_IG"/>
					<qry:attribute value="format_date($r/@f_nacimiento,'dd/mm/yyyy')" name="f_nacimiento"/>
					<qry:attribute name="tipofamiliar" value="$r/@c_tipo_familiar + ' - ' + $r/@d_tipo_familiar"/>
					<qry:attribute name="nivelescolaridad" value="$r/@c_nivel_escol + ' - ' + $r/@d_nivel_escol"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_VARF" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ07_VAL_VAREF.n_valor
FROM         
LIQ07_VAL_VAREF ,
LIQ09_VARIABLES 
JOIN
LIQ07_VAL_VAREF.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ07_VAL_VAREF.oi_personal_emp = {%= #SOURCE:@oi_personal_emp %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VFIJA">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_VARA" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ07_VAL_VAREA.n_valor
FROM         
LIQ07_VAL_VAREA ,
LIQ09_VARIABLES 
JOIN
LIQ07_VAL_VAREA.oi_variable INNER LIQ09_VARIABLES.oi_variable 
WHERE
LIQ07_VAL_VAREA.oi_personal_emp = {%= #SOURCE:@oi_personal_emp %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VACUM">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_VAREN" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ25_VAL_VAREN.n_valor
FROM         
LIQ25_VAL_VAREN ,
LIQ09_VARIABLES 
JOIN
LIQ25_VAL_VAREN.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ25_VAL_VAREN.oi_personal_liq= {%= #SOURCE:@oi_personal_liq %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="NOVEDAD">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_VARGN" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ19_VAL_VARGN.n_valor
FROM         
LIQ19_VAL_VARGN ,
LIQ09_VARIABLES 
JOIN
LIQ19_VAL_VARGN.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ19_VAL_VARGN.oi_liquidacion= {%= #SOURCE:@oi_liquidacion %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="NOVEDADLIQ">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_VARGF" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ15_VAL_VARGF.n_valor
FROM         
LIQ15_VAL_VARGF ,
LIQ09_VARIABLES 
JOIN
LIQ15_VAL_VARGF.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ15_VAL_VARGF.oi_empresa= {%= #SOURCE:@oi_empresa %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VARGF">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CONC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ14_CONCEPTOS.c_concepto, 
LIQ14_CONCEPTOS.d_concepto, 
ORG08_CS_COSTO.c_centro_costo, 
ORG08_CS_COSTO.d_centro_costo, 
LIQ25_CONC_MAN_PER.n_valor, 
LIQ25_CONC_MAN_PER.n_cantidad
FROM         
LIQ25_CONC_MAN_PER , LIQ14_CONCEPTOS , ORG08_CS_COSTO 
JOIN
LIQ25_CONC_MAN_PER.oi_concepto INNER LIQ14_CONCEPTOS.oi_concepto ,
LIQ25_CONC_MAN_PER.oi_centro_costo INNER ORG08_CS_COSTO.oi_centro_costo
WHERE
LIQ25_CONC_MAN_PER.oi_personal_liq= {%= #SOURCE:@oi_personal_liq %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONCEPTO">
					<qry:attribute name="n_cantidad" value="$r/@n_cantidad"/>
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="concepto" value="$r/@c_concepto + ' - ' + $r/@d_concepto"/>
					<qry:attribute name="centrocosto" value="$r/@c_centro_costo + ' - ' + $r/@d_centro_costo"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LIC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
P16.c_licencia, 
P16.d_licencia, 
P02.f_inicio, 
P02.f_fin, 
P02.f_interrupcion
FROM         
PER02_LICEN_PER as P02 , 
PER16_LICENCIAS as P16 

JOIN
P02.oi_licencia INNER P16.oi_licencia
WHERE
P02.oi_personal_emp = {%= #SOURCE:@oi_personal_emp %}
and
(addmonths(P02.f_inicio,-1) &lt; {Datetime(#SOURCE:@iniPeriodo)}

    and
    ( 
      P02.f_fin &gt;= {Datetime(#SOURCE:@iniPeriodo)} 
      and 
      (
         isnull(P02.f_interrupcion) 
         or 
         P02.f_interrupcion &gt;= {Datetime(#SOURCE:@iniPeriodo)}
       )
     )
   )
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LIC">
					<qry:attribute value="format_date($r/@f_inicio,'dd/mm/yyyy')" name="f_inicio"/>
					<qry:attribute value="format_date($r/@f_fin,'dd/mm/yyyy')" name="f_fin"/>
					<qry:attribute value="format_date($r/@f_interrupcion,'dd/mm/yyyy')" name="f_interrupcion"/>
					<qry:attribute name="licencia" value="$r/@c_licencia + ' - ' + $r/@d_licencia"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_DEDUC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT  
tr.c_item_ig ,  
tr.d_item_ig ,  
tv.c_entidad_ig ,  
tv.d_entidad_ig ,  
t.n_importe 

FROM LIQ07_DEDUC_IG as t ,
LIQ04_ITEMS_IG as tr,
LIQ05_ENTIDADES_IG as tv,
liq19_liquidacion as l  

JOIN
t.oi_item_ig left outer tr.oi_item_ig,
tv.oi_entidad_ig right outer t.oi_entidad_ig
WHERE 
t.oi_personal_emp = {#SOURCE:@oi_personal_emp}
and
l.oi_liquidacion = {#SOURCE:@oi_liquidacion}
order by 
 c_entidad_ig aASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DEDUC">
					<qry:attribute name="ItemIG" value="$r/@c_item_ig + '-' + $r/@d_item_ig"/>
					<qry:attribute name="EntidadIG" value="$r/@c_entidad_ig + '-' + $r/@d_entidad_ig"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_importe, 10, 2, '.', '', '')" name="Importe"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PARAM" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
		SELECT     
LIQ07_PARAM_PER.d_valor, 
ORG26_PARAMETROS.c_parametro, 
ORG26_PARAMETROS.d_parametro
FROM         
LIQ07_PARAM_PER , 
ORG26_PARAMETROS 
JOIN
LIQ07_PARAM_PER.oi_parametro INNER ORG26_PARAMETROS.oi_parametro
WHERE
LIQ07_PARAM_PER.oi_personal_emp = {#SOURCE:@oi_personal_emp}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PARAM">
					<qry:attribute name="parametro" value="$r/@c_parametro + '-' + $r/@d_parametro"/>
					<qry:attribute name="d_valor" value="$r/@d_valor"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/DATOS">
			<html>
