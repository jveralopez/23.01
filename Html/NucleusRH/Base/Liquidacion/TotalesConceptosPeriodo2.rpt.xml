<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Liquidacion.TotalesConceptosPeriodo2" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&#13;&#10;&lt;FILTRO gcustom=&quot;&quot; cb_confidenciales=&quot;NC&quot; oi_personal_emp=&quot;1682&quot; oi_personal=&quot;12545&quot; oi_empresa=&quot;1&quot; gpers=&quot;&quot; l_devengado=&quot;0&quot; &#13;&#10;l_percibido=&quot;1&quot; liq_f_des=&quot;&quot; liq_f_has=&quot;&quot; liq_f_pag_des=&quot;&quot; liq_f_pag_has=&quot;&quot; liqID=&quot;3518&quot; legajo_per=&quot;244 - Casadey, Cecilia&quot;&gt;&#13;&#10;&lt;LIQUIDACIONES&gt;&lt;ROW VALUES=&quot;3507,3516,3518&quot; /&gt;&lt;/LIQUIDACIONES&gt;&lt;/FILTRO&gt;  ">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:FILTRO"/>
			<qry:append-doc name="LIQUIDACIONES" doc-path="#SOURCE:FILTRO/LIQUIDACIONES"/>
			<REPORT label="Totales por Conceptos y Per&#237;odo Por Legajo">
				<qry:element name="PERIODOS">
					<qry:append-doc name="PERIODOS" doc-path="."/>
					<qry:if test="#PARAMIN:@l_devengado=1">
						<qry:then>
							<qry:insert-select name="qry_periodos_liq"/>
						</qry:then>
						<qry:else>
							<qry:insert-select name="qry_periodos"/>
						</qry:else>
					</qry:if>
				</qry:element>
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="CAB" type="title" noreg="No se encontraron registros para este legajo.">
						<COLS>
							<COL name="d_empresa" label="Empresa"/>
						</COLS>
						<COLS>
							<COL name="legajo_per" label="Legajo"/>
						</COLS>
						<GROUP label="Liquidaciones" tag="LIQUIDACIONES" style="width:600px" type="table">
							<COLS>
								<COL name="COD" label="Codigo" width="20%"/>
								<COL name="DES" label="Descripcion" width="40%"/>
								<qry:if test="#PARAMIN:@l_devengado=1">
									<qry:then>
										<COL name="PER" label="Periodo Liquidaci&#243;n" style="text-align:center;" width="10%"/>
									</qry:then>
									<qry:else>
										<COL name="PER" label="Periodo de Pago" style="text-align:center;" width="10%"/>
									</qry:else>
								</qry:if>
								<COL name="TYP" label="Tipo" width="15%"/>
								<COL name="EST" label="Estado Liq" width="5%"/>
							</COLS>
						</GROUP>
						<GROUP tag="CONC" style="padding-left:50px;width:1140px;" type="table" noreg="No se encontraron registros para este concepto.">
							<COLS>
								<COL name="c_concepto" label="C&#243;digo"/>
								<COL name="tipo" label="Tipo de Concepto" type="string"/>
								<COL name="ca_acum_ganancia" label="Acumula Ganancia" type="string"/>
								<COL name="n_coef_ganancia" label="Coeficiente Ganancia" type="string"/>
								<COL name="d_concepto" label="Descripci&#243;n" type="string"/>
								<qry:if test="#PARAMIN:@l_devengado=1">
									<qry:then>
										<qry:insert-select name="qry_columnas_liq"/>
									</qry:then>
									<qry:else>
										<qry:insert-select name="qry_columnas"/>
									</qry:else>
								</qry:if>
								<COL name="tot_concepto" label="Total Concepto" style="text-align:right;"/>
							</COLS>
							<FCOLS>
								<COL name="cant_conc" colspan="5"/>
								<qry:if test="#PARAMIN:@l_devengado=1">
									<qry:then>
										<qry:insert-select name="qry_columnas_tot_liq"/>
									</qry:then>
									<qry:else>
										<qry:insert-select name="qry_columnas_tot"/>
									</qry:else>
								</qry:if>
							</FCOLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<qry:element name="CONCEPTOS">
						<qry:append-doc name="CONCEPTOS" doc-path="."/>
						<qry:insert-select name="qry_conc"/>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:element>
					<CAB qry-orderby="orderby">
						<qry:insert-select name="qry_empresa" doc-path="#PARAMIN:"/>
						<qry:if test="#PARAMIN:@l_devengado=1">
							<qry:then>
								<qry:insert-select name="qry_liquidaciones_liq" doc-path="#LIQUIDACIONES:"/>
								<CONTEMP>
									<qry:append-doc name="CONTEMP" doc-path="."/>
									<qry:insert-select name="qry_conceptos_liq" doc-path="#PARAMIN:"/>
									<qry:attribute name="hts:delete" value="1"/>
								</CONTEMP>
								<qry:insert-select name="qry_por_concepto_liq"/>
								<qry:insert-select name="qry_totales_liq" doc-path="."/>
							</qry:then>
							<qry:else>
								<qry:insert-select name="qry_liquidaciones" doc-path="#LIQUIDACIONES:"/>
								<CONTEMP>
									<qry:append-doc name="CONTEMP" doc-path="."/>
									<qry:insert-select name="qry_conceptos" doc-path="#PARAMIN:"/>
									<qry:attribute name="hts:delete" value="1"/>
								</CONTEMP>
								<qry:insert-select name="qry_por_concepto"/>
								<qry:insert-select name="qry_totales" doc-path="."/>
							</qry:else>
						</qry:if>
					</CAB>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select name="qry_periodos_liq" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('	
 	SELECT
	LIQ19_LIQUIDACION.e_periodo
	FROM 
	LIQ19_LIQUIDACION	
   	WHERE  
    LIQ19_LIQUIDACION.oi_liquidacion in   ({%=#LIQUIDACIONES:ROW/@VALUES %})  
    group by 
    LIQ19_LIQUIDACION.e_periodo 
    order by e_periodo asc
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_periodos" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('	
	SELECT
  L2.e_periodo_pago 
  FROM
  LIQ19_LIQUIDACION as L,
  (   SELECT
       L.oi_liquidacion,
       GetPer(L.f_pago) as e_periodo_pago
      FROM
      LIQ19_LIQUIDACION as L
      WHERE
      L.oi_liquidacion in   ({%=#LIQUIDACIONES:ROW/@VALUES %})
  ) as L2
  join
  L.oi_liquidacion  inner  L2.oi_liquidacion  
     WHERE
    L.oi_liquidacion in   ({%=#LIQUIDACIONES:ROW/@VALUES %})
    group by L2.e_periodo_pago
    order by e_periodo_pago asc		
			
			
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_conc">
			<qry:xquery>
				for $r in SQL('
			
			SELECT
  LIQ96_CONCEPTOS.c_concepto as c_concepto,
 max(LIQ96_CONCEPTOS.d_concepto ) as d_concepto,
 max(LIQ96_CONCEPTOS.ca_acum_ganancia) as ca_acum_ganancia,
	max(LIQ96_CONCEPTOS.n_coef_ganancia) as n_coef_ganancia, 
 max(LIQ12_TIPOS_CONC.d_tipo_concepto) as tipo,
 max(LIQ12_TIPOS_CONC.c_tipo_concepto) as c_tipo_concepto 
 
FROM 
LIQ19_EJECUCIONES,
LIQ99_LIQUIDACION,
LIQ99_RECIBOS,
LIQ20_TOT_LIQ_PER,
LIQ20_CONC_LIQ_PER,
LIQ96_CONCEPTOS,
 LIQ12_TIPOS_CONC,
 LIQ14_CONCEPTOS
JOIN 
 LIQ19_EJECUCIONES.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo,
 LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo, 
   LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per, 
   LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ20_CONC_LIQ_PER.oi_tot_liq_per, 
   LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo, 
    LIQ96_CONCEPTOS.c_tipo_concepto INNER LIQ12_TIPOS_CONC.c_tipo_concepto,
     LIQ96_CONCEPTOS.c_concepto INNER LIQ14_CONCEPTOS.c_concepto 
   WHERE  
   LIQ20_CONC_LIQ_PER.n_valor  !=  0.0  
   AND  LIQ99_LIQUIDACION.c_estado  =  \'F\'  
   AND LIQ19_EJECUCIONES.oi_liquidacion in   ({%=#LIQUIDACIONES:ROW/@VALUES %})   
  GROUP BY 
LIQ96_CONCEPTOS.c_concepto 
order by 
 c_tipo_concepto asc, c_concepto asc			
			
			
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
					<qry:attribute name="n_coef_ganancia" value="$r/@n_coef_ganancia"/>
					<qry:attribute name="c_tipo_concepto" value="iif($r/@c_tipo_concepto='0','1',iif($r/@c_tipo_concepto='1','0',$r/@c_tipo_concepto))"/>
					<qry:attribute name="tipo" value="$r/@tipo"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_empresa">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ORG03_EMPRESAS.c_empresa,
					ORG03_EMPRESAS.d_empresa
				FROM 
					ORG03_EMPRESAS
				WHERE 
					ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
				<qry:attribute name="legajo_per" value="#SOURCE:@legajo_per"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_liquidaciones_liq">
			<qry:xquery>
				for $r in sql('
				SELECT 
					LIQ19_LIQUIDACION.c_liquidacion,
					LIQ19_LIQUIDACION.d_titulo,
					LIQ19_LIQUIDACION.e_periodo,
					LIQ19_LIQUIDACION.c_estado,
					LIQ01_TIPOS_LIQ.d_tipo_liq
				FROM 
					LIQ19_LIQUIDACION, LIQ01_TIPOS_LIQ
				JOIN                               
					LIQ19_LIQUIDACION.oi_tipo_liq INNER LIQ01_TIPOS_LIQ.oi_tipo_liq
				WHERE 
					LIQ19_LIQUIDACION.oi_liquidacion in ({%=String(#SOURCE:ROW/@VALUES) %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LIQUIDACIONES>
					<qry:attribute name="COD" value="$r/@c_liquidacion"/>
					<qry:attribute name="DES" value="$r/@d_titulo"/>
					<qry:attribute name="PER" value="format_date($r/@e_periodo+'01','Mmm-yyyy')"/>
					<qry:attribute name="TYP" value="$r/@d_tipo_liq"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="A">
							<qry:attribute name="EST" value="'Abierta'"/>
						</qry:case>
						<qry:case value="I">
							<qry:attribute name="EST" value="'Inicializada'"/>
						</qry:case>
						<qry:case value="G">
							<qry:attribute name="EST" value="'Generada'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="EST" value="'Secuenciada'"/>
						</qry:case>
						<qry:case value="C">
							<qry:attribute name="EST" value="'Cerrada'"/>
						</qry:case>
						<qry:case value="PC">
							<qry:attribute name="EST" value="'En proceso de cierre'"/>
						</qry:case>
						<qry:case value="B">
							<qry:attribute name="EST" value="'Bloqueada'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="EST" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
				</LIQUIDACIONES>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_liquidaciones">
			<qry:xquery>
				for $r in sql('
				SELECT 
					LIQ19_LIQUIDACION.c_liquidacion,
					LIQ19_LIQUIDACION.d_titulo,
					GetPer(LIQ19_LIQUIDACION.f_pago) as e_periodo_pago,
					LIQ19_LIQUIDACION.c_estado,
					LIQ01_TIPOS_LIQ.d_tipo_liq
				FROM 
					LIQ19_LIQUIDACION, LIQ01_TIPOS_LIQ
				JOIN                               
					LIQ19_LIQUIDACION.oi_tipo_liq INNER LIQ01_TIPOS_LIQ.oi_tipo_liq
				WHERE 
					LIQ19_LIQUIDACION.oi_liquidacion in ({%=String(#SOURCE:ROW/@VALUES) %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LIQUIDACIONES>
					<qry:attribute name="COD" value="$r/@c_liquidacion"/>
					<qry:attribute name="DES" value="$r/@d_titulo"/>
					<qry:attribute name="PER" value="format_date($r/@e_periodo_pago+'01','Mmm-yyyy')"/>
					<qry:attribute name="TYP" value="$r/@d_tipo_liq"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="A">
							<qry:attribute name="EST" value="'Abierta'"/>
						</qry:case>
						<qry:case value="I">
							<qry:attribute name="EST" value="'Inicializada'"/>
						</qry:case>
						<qry:case value="G">
							<qry:attribute name="EST" value="'Generada'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="EST" value="'Secuenciada'"/>
						</qry:case>
						<qry:case value="C">
							<qry:attribute name="EST" value="'Cerrada'"/>
						</qry:case>
						<qry:case value="PC">
							<qry:attribute name="EST" value="'En proceso de cierre'"/>
						</qry:case>
						<qry:case value="B">
							<qry:attribute name="EST" value="'Bloqueada'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="EST" value="$r/@c_estado"/>
						</qry:default>
					</qry:switch>
				</LIQUIDACIONES>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_conceptos_liq">
			<qry:xquery>
				for $r in sql('
SELECT                                          
	LIQ96_CONCEPTOS.c_concepto,   
	liq99_liquidacion.e_periodo, 
	max(LIQ96_CONCEPTOS.ca_acum_ganancia) as ca_acum_ganancia,
	max(LIQ96_CONCEPTOS.n_coef_ganancia) as n_coef_ganancia, 
	max(LIQ96_CONCEPTOS.d_concepto) as d_concepto,
      sum(LIQ20_CONC_LIQ_PER.n_valor) as n_valor
FROM 
	LIQ19_EJECUCIONES,
	LIQ99_LIQUIDACION,
	LIQ99_RECIBOS, 
	LIQ20_TOT_LIQ_PER,
	LIQ20_CONC_LIQ_PER, 
	LIQ96_CONCEPTOS,
	LIQ12_TIPOS_CONC,
	LIQ25_PERSONAL_LIQ, 
    PER02_PERSONAL_emp,
    LIQ14_CONCEPTOS
JOIN
	LIQ19_EJECUCIONES.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo,
	LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
	LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
	LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ20_CONC_LIQ_PER.oi_tot_liq_per,
	LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo,
	LIQ96_CONCEPTOS.c_tipo_concepto INNER LIQ12_TIPOS_CONC.c_tipo_concepto,
	LIQ19_EJECUCIONES.oi_liquidacion INNER LIQ25_PERSONAL_LIQ.oi_liquidacion,	 
	LIQ25_PERSONAL_LIQ.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp, 
	LIQ99_RECIBOS.e_numero_legajo INNER PER02_PERSONAL_EMP.e_numero_legajo,
    LIQ96_CONCEPTOS.c_concepto INNER LIQ14_CONCEPTOS.c_concepto
WHERE
	LIQ20_CONC_LIQ_PER.n_valor != 0.0 AND
	LIQ99_LIQUIDACION.c_estado = \'F\' AND
  LIQ19_EJECUCIONES.oi_liquidacion in ({%=#LIQUIDACIONES:ROW/@values %})  
  and LIQ25_PERSONAL_LIQ.oi_personal_emp in ({%=#SOURCE:@oi_personal_emp %})  
  
GROUP BY                         
	LIQ96_CONCEPTOS.c_concepto,liq99_liquidacion.e_periodo
ORDER BY
   e_periodo asc 
 
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<CONC>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
					<qry:attribute name="n_coef_ganancia" value="$r/@n_coef_ganancia"/>
					<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
					<qry:attribute name="codigo" value="concat('c_',@e_periodo,'_',@c_concepto)"/>
				</CONC>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_conceptos">
			<qry:xquery>
				for $r in sql('
SELECT                                          
	LIQ96_CONCEPTOS.c_concepto,   
	L2.e_periodo_pago, 
	max(LIQ96_CONCEPTOS.ca_acum_ganancia) as ca_acum_ganancia,
	max(LIQ96_CONCEPTOS.n_coef_ganancia) as n_coef_ganancia, 
	max(LIQ96_CONCEPTOS.d_concepto) as d_concepto,
   sum(LIQ20_CONC_LIQ_PER.n_valor) as n_valor
FROM 
	LIQ19_EJECUCIONES,
	LIQ99_LIQUIDACION,
	LIQ99_RECIBOS, 
	LIQ20_TOT_LIQ_PER,
	LIQ20_CONC_LIQ_PER, 
	LIQ96_CONCEPTOS,
	LIQ12_TIPOS_CONC,
	LIQ25_PERSONAL_LIQ, 
   PER02_PERSONAL_emp,
   LIQ14_CONCEPTOS,
  (   SELECT
       L.oi_liquidacion,
       GetPer(L.f_pago) as e_periodo_pago
      FROM
      LIQ19_LIQUIDACION as L
      WHERE
      L.oi_liquidacion in   ({%=#LIQUIDACIONES:ROW/@VALUES %})
  ) as L2
  	
JOIN
	LIQ19_EJECUCIONES.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo,
	LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
	LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
	LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ20_CONC_LIQ_PER.oi_tot_liq_per,
	LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo,
	LIQ96_CONCEPTOS.c_tipo_concepto INNER LIQ12_TIPOS_CONC.c_tipo_concepto,
	LIQ19_EJECUCIONES.oi_liquidacion INNER LIQ25_PERSONAL_LIQ.oi_liquidacion,	 
	LIQ25_PERSONAL_LIQ.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp, 
	LIQ99_RECIBOS.e_numero_legajo INNER PER02_PERSONAL_EMP.e_numero_legajo,
    LIQ96_CONCEPTOS.c_concepto INNER LIQ14_CONCEPTOS.c_concepto,
    LIQ19_EJECUCIONES.oi_liquidacion  inner  L2.oi_liquidacion
WHERE
	LIQ20_CONC_LIQ_PER.n_valor != 0.0 AND
	LIQ99_LIQUIDACION.c_estado = \'F\' AND
  LIQ19_EJECUCIONES.oi_liquidacion in ({%=#LIQUIDACIONES:ROW/@values %})  
  and LIQ25_PERSONAL_LIQ.oi_personal_emp in ({%=#SOURCE:@oi_personal_emp %})  
  
GROUP BY                         
	LIQ96_CONCEPTOS.c_concepto, L2.e_periodo_pago
ORDER BY
   e_periodo_pago asc 
 
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<CONC>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
					<qry:attribute name="n_coef_ganancia" value="$r/@n_coef_ganancia"/>
					<qry:attribute name="e_periodo_pago" value="$r/@e_periodo_pago"/>
					<qry:attribute name="codigo" value="concat('c_',@e_periodo_pago,'_',@c_concepto)"/>
				</CONC>
			</qry:out>
		</qry:select>
		<qry:select name="qry_por_concepto_liq" doc="SOURCE">
			<qry:xquery>
				for $r in #CONCEPTOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONC">
					<qry:attribute name="orderby" value="$r/@c_tipo_concepto"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:switch test="$r/@ca_acum_ganancia">
						<qry:case value="H">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes'"/>
						</qry:case>
						<qry:case value="P">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes No Habituales (Prorrateo)'"/>
						</qry:case>
						<qry:case value="E">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Horas Extras'"/>
						</qry:case>
						<qry:case value="X">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes Exentos'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Deducciones'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula SAC'"/>
						</qry:case>
						<qry:case value="N">
							<qry:attribute name="ca_acum_ganancia" value="'No Acumula'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="n_coef_ganancia" value="FORMAT_NUMBER($r/@n_coef_ganancia,10,2,',','.','')"/>
					<qry:attribute name="tipo" value="$r/@tipo"/>
					<qry:insert-select name="qry_final_liq" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_por_concepto" doc="SOURCE">
			<qry:xquery>
				for $r in #CONCEPTOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONC">
					<qry:attribute name="orderby" value="$r/@c_tipo_concepto"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:switch test="$r/@ca_acum_ganancia">
						<qry:case value="H">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes'"/>
						</qry:case>
						<qry:case value="P">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes No Habituales (Prorrateo)'"/>
						</qry:case>
						<qry:case value="E">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Horas Extras'"/>
						</qry:case>
						<qry:case value="X">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Haberes Exentos'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula Deducciones'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="ca_acum_ganancia" value="'Acumula SAC'"/>
						</qry:case>
						<qry:case value="N">
							<qry:attribute name="ca_acum_ganancia" value="'No Acumula'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="ca_acum_ganancia" value="$r/@ca_acum_ganancia"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="n_coef_ganancia" value="FORMAT_NUMBER($r/@n_coef_ganancia,10,2,',','.','')"/>
					<qry:attribute name="tipo" value="$r/@tipo"/>
					<qry:insert-select name="qry_final" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_final_liq" doc="SOURCE">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute-doc doc="SOURCE" name="cod" value="concat('c_',$r/@e_periodo,'_',#SOURCE:@c_concepto)"/>
				<qry:attribute name-calc="concat('c_',$r/@e_periodo)" value="format-number(sum(#CONTEMP:CONC[@codigo = #SOURCE:@cod]/@n_valor),0,2,',','.','')"/>
				<qry:attribute name="auxsum" value="sum(#CONTEMP:CONC[@codigo = #SOURCE:@cod]/@n_valor)"/>
				<qry:attribute value="number(@auxtot_concepto) + number(@auxsum)" name="auxtot_concepto"/>
				<qry:attribute value="format_number(@auxtot_concepto,0,2,',','.','')" name="tot_concepto"/>
				<qry:if test="@tot_concepto=0">
					<qry:then>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="hts:delete" value="0"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_final" doc="SOURCE">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute-doc doc="SOURCE" name="cod" value="concat('c_',$r/@e_periodo_pago,'_',#SOURCE:@c_concepto)"/>
				<qry:attribute name-calc="concat('c_',$r/@e_periodo_pago)" value="format-number(sum(#CONTEMP:CONC[@codigo = #SOURCE:@cod]/@n_valor),0,2,',','.','')"/>
				<qry:attribute name="auxsum" value="sum(#CONTEMP:CONC[@codigo = #SOURCE:@cod]/@n_valor)"/>
				<qry:attribute value="number(@auxtot_concepto) + number(@auxsum)" name="auxtot_concepto"/>
				<qry:attribute value="format_number(@auxtot_concepto,0,2,',','.','')" name="tot_concepto"/>
				<qry:if test="@tot_concepto=0">
					<qry:then>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="hts:delete" value="0"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_columnas_liq">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="label" value="format-date(concat($r/@e_periodo,'01'),'mmm - yyyy')"/>
					<qry:attribute name="name" value="concat('c_',$r/@e_periodo)"/>
					<qry:attribute name="style" value="'text-align:right;'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_columnas">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="label" value="format-date(concat($r/@e_periodo_pago,'01'),'mmm - yyyy')"/>
					<qry:attribute name="name" value="concat('c_',$r/@e_periodo_pago)"/>
					<qry:attribute name="style" value="'text-align:right;'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_columnas_tot_liq">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="label" value="format-date(concat($r/@e_periodo,'01'),'mmm - yyyy')"/>
					<qry:attribute name="name" value="concat('t_',$r/@e_periodo)"/>
					<qry:attribute name="style" value="'text-align:right;'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_columnas_tot">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="label" value="format-date(concat($r/@e_periodo_pago,'01'),'mmm - yyyy')"/>
					<qry:attribute name="name" value="concat('t_',$r/@e_periodo_pago)"/>
					<qry:attribute name="style" value="'text-align:right;'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_totales_liq" doc="SOURCE">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name-calc="concat('t_',$r/@e_periodo)" value="format-number(sum(#CONTEMP:CONC[@e_periodo = $r/@e_periodo]/@n_valor),0,2,',','.','')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_totales" doc="SOURCE">
			<qry:xquery>
				for $r in #PERIODOS:ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name-calc="concat('t_',$r/@e_periodo_pago)" value="format-number(sum(#CONTEMP:CONC[@e_periodo_pago = $r/@e_periodo_pago]/@n_valor),0,2,',','.','')"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
