<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Liquidacion.Recibo">
	<html:query declare="&lt;PARAMS ut=&quot;7E8703C82C3B-81001A88153C-12DB0000001B&quot; file=&quot;NucleusRH.Base.Liquidacion.Recibo.rpt&quot; oi_personal_liq=&quot;1&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="PARAMIN" doc-path="#PARAM:."/>
			<qry:element name="datos">
				<qry:if test="#PARAMIN:@oi_personal_liq != ''">
					<qry:then>
						<qry:insert-select name="qry_obtieneOITLP" doc-path="#PARAMIN:"/>
					</qry:then>
				</qry:if>
				<qry:insert-select doc-path="#PARAMIN:" name="qry_cabecera"/>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_cabecera">
			<qry:xquery>
				for $r in sql('
				SELECT   TLP.oi_tot_liq_per , TLP.c_numero,
EMP.d_empresa, 
EMP.d_domicilio AS domin, 
EMP.c_cuit  AS c_cuit,
PEM.e_numero_legajo, 
PEM.d_ape_y_nom, 
LIQ.oi_liquidacion_ddo,
LIQ.f_pago, 
LIQ.e_periodo,
LIQ.f_deposito, 
LIQ.c_mes_deposito, 
LIQ.d_banco, 
PEM.c_centro_costo_ult  AS cCentroCosto,
LIQ.c_liquidacion, 
LIQ.d_titulo, 
PEM.f_ingreso, 
PEM.f_egreso, 
PEM.f_antiguedad_rec, 
PEM.c_nro_cuil  AS nro_cuil,
PEM.c_cta_bancaria ,
PEM.d_sucursal,
PEM.d_banco as d_banco_sucursal,
PEM.c_convenio,
PEM.c_categoria_ult as c_categoria
 
from 	LIQ20_TOT_LIQ_PER AS TLP , 
	LIQ97_PERSONAL_EMP AS PEM, 
	LIQ99_Liquidacion AS LIQ ,
	LIQ93_EMPRESAS  AS EMP

JOIN TLP.oi_liquidacion_ddo INNER LIQ.oi_liquidacion_ddo , 
		LIQ.oi_empresa_ddo INNER EMP.oi_empresa_ddo  , 
		TLP.oi_per_emp_ddo INNER PEM.oi_per_emp_ddo

 WHERE
	TLP.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per }
	
																
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="cabecera">
					<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
					<qry:attribute name="f_emision" value="format_date(now(),'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="c_numero" value="$r/@c_numero" type="Nomad.NSystem.String"/>
					<qry:insert-select name="qry_parametro"/>
					<qry:attribute name="d_empresa" value="$r/@d_empresa" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_domicilio" value="$r/@domin" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_cuit" value="$r/@c_cuit" type="Nomad.NSystem.String"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_pago" value="format_date($r/@f_pago,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
					<qry:attribute name="e_periodo" value="substring($r/@e_periodo,4,2) + '/' + substring($r/@e_periodo,0,4)" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_deposito" value="format_date($r/@f_deposito,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
					<qry:attribute name="c_mes_deposito" value="$r/@c_mes_deposito" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_banco" value="$r/@d_banco" type="Nomad.NSystem.String"/>
					<qry:attribute name="CentroCosto" value="$r/@cCentroCosto" type="Nomad.NSystem.String"/>
					<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_titulo" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_egreso" value="format_date($r/@f_egreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_antiguedad_rec" value="format_date($r/@f_antiguedad_rec,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
					<qry:attribute name="nro_cuil" value="substring($r/@nro_cuil,0,2) + '-'+ substring($r/@nro_cuil,2,string_length($r/@nro_cuil) - 3 )+ '-'+ substring($r/@nro_cuil,string_length($r/@nro_cuil) - 1 ,1)" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@c_cta_bancaria" name="c_cta_bancaria"/>
					<qry:attribute value="$r/@d_sucursal" name="d_sucursal"/>
					<qry:insert-select doc-path="$r" name="qry_categoria"/>
					<qry:element name="detalles">
						<qry:attribute value="$r/@d_empresa" name="aa"/>
						<qry:insert-select doc-path="#PARAM:" name="qry_detalle"/>
						<qry:element name="PieDetalle">
							<qry:attribute value="$r/@d_empresa" name="ab"/>
							<qry:insert-select doc-path="#PARAM:" name="qry_Remuneraciones"/>
						</qry:element>
						<qry:element name="Pie">
							<qry:attribute value="$r/@d_empresa" name="ac"/>
							<qry:insert-select doc-path="$r" name="qry_pie"/>
						</qry:element>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_parametro" doc="PARAM">
			<qry:xquery>
				for $r in sql('
SELECT 
	o.d_valor 
FROM
	org26_Parametros as  o
where 
	o.c_parametro = \'AdmNumRec\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_valor" value="$r/@d_valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_categoria" doc="PARAM">
			<qry:xquery>
				for $r in sql('
			SELECT LIQ94_CATEG.d_categoria
			FROM LIQ94_CONVENIOS, LIQ94_CATEG, LIQ99_LIQUIDACION
			WHERE LIQ94_CONVENIOS.oi_convenio_ddo = LIQ94_CATEG.oi_convenio_ddo AND
			LIQ94_CONVENIOS.c_convenio = {#PARAM:@c_convenio} AND 
			LIQ94_CATEG.c_categoria = {#PARAM:@c_categoria} AND 
			LIQ94_CONVENIOS.oi_codif_ddo = LIQ99_LIQUIDACION.oi_codif_ddo AND
			LIQ99_LIQUIDACION.oi_liquidacion_ddo = {#PARAM:@oi_liquidacion_ddo}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="D_CATEGORIA" value="$r/@d_categoria"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_detalle">
			<qry:xquery>
				for $r in sql('
SELECT 
	CLP.oi_conc_liq_per,
	CON.c_concepto, 
	CON.d_concepto, 
	CON.e_secuencia,	
	CLP.n_valor AS valor,
	CLP.n_cantidad AS cantidad,
	CON.c_tipo_concepto, 
	T.e_orden
FROM 
	LIQ20_TOT_LIQ_PER AS TLP, 
	liq20_conc_liq_per AS CLP, 
	liq96_conceptos AS CON, 
	LIQ14_CONCEPTOS AS C, 
	LIQ12_TIPOS_CONC AS T
JOIN
	TLP.oi_tot_liq_per INNER CLP.oi_tot_liq_per,
	CON.oi_concepto_ddo INNER CLP.oi_concepto_ddo,
	C.c_concepto INNER CON.c_concepto,
	C.oi_tipo_concepto INNER T.oi_tipo_concepto 
WHERE
	TLP.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}	 AND 
	T.l_nolistado = 0  and
	CLP.n_valor != 0 and 
	CON.ca_fig_recibo != \'N\' 
ORDER BY
	e_orden ASC, 
	c_concepto ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="detalle">
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute value="format_number($r/@cantidad,0,2,'.','','')" name="cantidad"/>
					<qry:attribute value="iif($r/@c_tipo_concepto='0' or $r/@c_tipo_concepto='1' or $r/@c_tipo_concepto='2' or $r/@c_tipo_concepto='5',format_number($r/@valor,0,2,'.','',''),'')" name="remun"/>
					<qry:attribute value="iif($r/@c_tipo_concepto='3' or $r/@c_tipo_concepto='7' or $r/@c_tipo_concepto='8' or $r/@c_tipo_concepto='4',format_number(0 - $r/@valor,0,2,'.','',''),'')" name="deduc"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_Remuneraciones">
			<qry:xquery>
				for $r in sql('
		SELECT  
			TLP.n_totsret, 
			TLP.n_totnsret,
			TLP.n_totasig,
			TLP.n_totdesc,
			TLP.n_totant,
			TLP.n_totemb
		FROM 
			LIQ20_TOT_LIQ_PER as TLP
		WHERE 
			TLP.oi_tot_liq_per =  {#PARAM:@oi_tot_liq_per}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="detalle">
					<qry:attribute value="number($r/@n_totsret) + number($r/@n_totnsret) + number($r/@n_totasig)" name="remuneraciones"/>
					<qry:attribute value="number($r/@n_totdesc) + number($r/@n_totant) + number($r/@n_totemb)" name="deduccciones"/>
					<qry:attribute value="number(@remuneraciones) + number(@deduccciones)" name="Resultado"/>
					<qry:attribute value="format_number(@remuneraciones,0,2,'.','','')" name="remuneraciones"/>
					<qry:attribute value="format_number(0-@deduccciones,0,2,'.','','')" name="deduccciones"/>
					<qry:attribute value="format_number(@Resultado,0,2,'.','','')" name="Resultado"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_pie">
			<qry:out>
				<qry:attribute value="#PARAM:@c_cta_bancaria" name="c_cta_bancaria" type="Nomad.NSystem.String"/>
				<qry:attribute value="#PARAM:@d_banco_sucursal+' '+#PARAM:@d_sucursal" name="d_banco" type="Nomad.NSystem.String"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_obtieneOITLP">
			<qry:xquery>
				for $r in sql('
				SELECT
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per
				FROM
					LIQ99_RECIBOS, 
					LIQ19_EJECUCIONES, 
					LIQ25_PERSONAL_LIQ,
					LIQ99_LIQUIDACION,
					LIQ20_TOT_LIQ_PER,
					PER02_PERSONAL_EMP
				JOIN	
					LIQ99_RECIBOS.oi_liquidacion_ddo INNER LIQ19_EJECUCIONES.oi_liquidacion_ddo,
					LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ19_EJECUCIONES.oi_liquidacion_ddo,
					LIQ25_PERSONAL_LIQ.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					LIQ19_EJECUCIONES.oi_liquidacion INNER LIQ25_PERSONAL_LIQ.oi_liquidacion,
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ99_RECIBOS.oi_tot_liq_per,
					LIQ99_RECIBOS.e_numero_legajo INNER PER02_PERSONAL_EMP.e_numero_legajo					
				WHERE 	
					LIQ99_LIQUIDACION.c_estado = \'F\'					
					AND LIQ25_PERSONAL_LIQ.oi_personal_liq = {#PARAM:@oi_personal_liq}	
 ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute-doc doc="PARAMIN" value="$r/@oi_tot_liq_per" name="oi_tot_liq_per"/>
			</qry:out>
		</qry:select>
	</html:query>
