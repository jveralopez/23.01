<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Liquidacion.CargaMasivaManual" doc="source">
	<html:query declare="&lt;PARAMS oi_empresa=&quot;102&quot; oi_variable=&quot;315&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT>
				<qry:insert-select name="qry_datos" doc-path=""/>
			</REPORT>
		</qry:main>
		<qry:select name="qry_datos" doc="SOURCE">
			<qry:xquery>
				for $r in FILEIO('TEMP/CMM-{%=$PROXY/@TOKEN%}.xml')/DATOS
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/REPORT/DATOS/ROWS">
			<html>
				<head>
					<style>
						.Main {
						background-color: #FFFFFF; 
						cursor: default;
						PADDING-RIGHT: 20px; 
						PADDING-LEFT: 20px; 
						PADDING-BOTTOM: 0px; 
						MARGIN: 0px; 
						PADDING-TOP: 10px; 
						BORDER-TOP: none;
						BORDER-RIGHT: none; 
						BORDER-LEFT: none; 
						BORDER-BOTTOM: none;
						text-align:center;
					}
					
						body
					{
					
						font-family:verdana;
						font-size:10px;
						cursor:default;
					}
					table
					{
					
						font-size:100%;
						border-collapse:collapse;
						table-layout:fixed;
						margin-left:auto;
						margin-right:auto;
					}
					th
					{
						text-align:left;
						height:20px;
						background-color:#DDD;
						border:1px solid #888;
						padding-left:3px;
						padding-right:3px; 
						font-weight:bold;
					}
					td
					{
					                
						atext-align:left;
						height:20px;
						xxxbackground-color:#FFF;
						border:1px solid #888;
						padding-left:3px;
						padding-right:3px;
						font-weight:normal;
						white-space: nowrap;
					} 
					input
					{
						border:none;
						font-size:100%;
						width:70px;
					}        
					span
					{
						white-space: nowrap;
					}
					
					tr.fila
					{
						background-color:#F9FF68;
					}
					</style>
					<script>
						function ChangeValue(id, obj, value)
{
	var orig=document.getElementById('o'+obj.id).value;
	var nuev=value;
	if (orig=="") orig = 0;
	if (nuev=="") nuev = 0;
	
	if (orig!=nuev)
		obj.parentNode.parentNode.className="fila";
	else
		obj.parentNode.parentNode.className="";
	
	parent.OnLostFocusValor(id, obj, value);
}

function OnKeyPress(obj,event)
{
  if (event.keyCode==38)                          
  {	
  	num=parseInt(obj.previousSibling.id.substr(4),10)-1;
		obj=document.getElementById('row_'+num).nextSibling;
		if (obj) obj.focus();
  } else
  if (event.keyCode==40)                          
  {
  	num=parseInt(obj.previousSibling.id.substr(4),10)+1;
		obj=document.getElementById('row_'+num).nextSibling;
		if (obj) obj.focus();
  }
}
					</script>
				</head>
				<body class="main" style="width:95%;height:98%;text-align:center;">
					<div style="width:100%;height:100%;text-align:center;">
						<table style="width:500px;margin-bottom:20px;" CELLPADDING="0">
							<col width="100px"/>
							<col width="300px"/>
							<col width="100px"/>
							<tr>
								<th>
									Legajo
								</th>
								<th>
									Apellido&#160;y&#160;Nombre
								</th>
								<th>
									Valor
								</th>
							</tr>
							<xsl:for-each select="ROW">
								<tr>
									<td>
										<xsl:value-of select="@leg"/>
									</td>
									<td>
										<xsl:value-of select="@nom"/>
									</td>
									<td>
										<input type="hidden">
											<xsl:attribute name="id">
												<xsl:value-of select="concat('oval_',@id)"/>
											</xsl:attribute>
											<xsl:attribute name="value">
												<xsl:value-of select="@val"/>
											</xsl:attribute>
										</input>
										<input type="hidden">
											<xsl:attribute name="id">
												<xsl:value-of select="concat('row_',@pos)"/>
											</xsl:attribute>
										</input>
										<xsl:if test="../../@c_tipo_dato!='bool'">
											<input type="text" maxLength="15" style="width:95px;" onfocus="this.select()" onkeyup="OnKeyPress(this,event);">
												<xsl:attribute name="id">
													<xsl:value-of select="concat('val_',@id)"/>
												</xsl:attribute>
												<xsl:attribute name="onblur">
													<xsl:value-of select="concat('ChangeValue(',@id,',this, this.value);')"/>
												</xsl:attribute>
												<xsl:attribute name="value">
													<xsl:value-of select="@val"/>
												</xsl:attribute>
											</input>
										</xsl:if>
										<xsl:if test="../../@c_tipo_dato='bool'">
											<input type="checkbox" maxLength="15" style="width:95px;" onfocus="this.select()" onkeyup="OnKeyPress(this,event);">
												<xsl:attribute name="id">
													<xsl:value-of select="concat('val_',@id)"/>
												</xsl:attribute>
												<xsl:attribute name="onclick">
													<xsl:value-of select="concat('ChangeValue(',@id,',this, this.checked?1:0);')"/>
												</xsl:attribute>
												<xsl:if test="@val=1">
													<xsl:attribute name="checked">
														<xsl:value-of select="'true'"/>
													</xsl:attribute>
												</xsl:if>
											</input>
										</xsl:if>
									</td>
								</tr>
							</xsl:for-each>
						</table>
					</div>
				</body>
			</html>
		</xsl:template>
	</html:xslt>
</html:html>
