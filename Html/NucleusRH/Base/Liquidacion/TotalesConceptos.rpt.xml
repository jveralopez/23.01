		<qry:select doc="SOURCE" name="qry_legajos">
			<qry:xquery>
				for $r in sql('
SELECT                                          
	LIQ96_CONCEPTOS.c_concepto,
	LIQ96_CONCEPTOS.c_tipo_concepto,          
	LIQ97_PERSONAL_EMP.e_numero_legajo,
	LIQ97_PERSONAL_EMP.d_ape_y_nom,
	count(LIQ97_PERSONAL_EMP.e_numero_legajo) as n_ocurrencia,
	sum(LIQ20_CONC_LIQ_PER.n_cantidad) as n_cantidad,
	{%? (#PARAMIN:@c_agrupacion='centro')     
		{% sum(LIQ20_CONC_LIQ_PER.n_valor*DisCC.por) as n_valor %}
		{% sum(LIQ20_CONC_LIQ_PER.n_valor) as n_valor %}
	%}

FROM 
	LIQ19_EJECUCIONES,
	LIQ99_LIQUIDACION,
	LIQ99_RECIBOS, 
	LIQ20_TOT_LIQ_PER,
	LIQ20_CONC_LIQ_PER, 
	LIQ96_CONCEPTOS,
	LIQ97_PERSONAL_EMP,
	LIQ12_TIPOS_CONC
	{%? (#PARAMIN:@c_agrupacion='centro')     
		{% 
			,(select              
				P.oi_per_emp_ddo, 
				iifisnull(D.c_centro_costo, P.c_centro_costo_ult) as cc, 
				iifisnull(D.n_p_distrib, 1) as por
			from 
				liq97_personal_emp as P, 
				liq97_distrib_cos as D
			join
				P.oi_per_emp_ddo left outer D.oi_per_emp_ddo
			) as DisCC
		%}
		{% %}
	%}

JOIN
	LIQ19_EJECUCIONES.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo,
	LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
	LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
	LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ20_CONC_LIQ_PER.oi_tot_liq_per,
	LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo,
	LIQ20_TOT_LIQ_PER.oi_per_emp_ddo INNER LIQ97_PERSONAL_EMP.oi_per_emp_ddo,
	LIQ96_CONCEPTOS.c_tipo_concepto INNER LIQ12_TIPOS_CONC.c_tipo_concepto
	{%? (#PARAMIN:@c_agrupacion='centro')     
		{% ,DisCC.oi_per_emp_ddo INNER LIQ97_PERSONAL_EMP.oi_per_emp_ddo %}
		{% %}
	%}
	
WHERE
	LIQ20_CONC_LIQ_PER.n_valor != 0.0 AND
	LIQ99_LIQUIDACION.c_estado = \'F\' AND
	LIQ96_CONCEPTOS.c_tipo_concepto in (0,1,2,3,4,6,7,8) AND
  LIQ19_EJECUCIONES.oi_liquidacion in ({%=#PARAMIN:@oi_liqs %}) AND
  LIQ97_PERSONAL_EMP.e_numero_legajo in ({%=#SOURCE:@value %}) 
  {%? (#PARAMIN:@oi_tipo_concepto!='') {% AND LIQ12_TIPOS_CONC.oi_tipo_concepto = {#PARAMIN:@oi_tipo_concepto} %} {% %} %}
  {%? (#PARAMIN:@cod_desde!='') {% AND LIQ96_CONCEPTOS.c_concepto &gt;= {#PARAMIN:@cod_desde} %} {% %} %}
  {%? (#PARAMIN:@cod_hasta!='') {% AND LIQ96_CONCEPTOS.c_concepto &lt;= {#PARAMIN:@cod_hasta} %} {% %} %}
	{%? (#PARAMIN:@c_agrupacion='centro')     
		{% AND DisCC.cc = {#PARAMIN:@c_centro_costo} %}
		{% %}
	%}
    {%?(#PARAMIN:@col_where!='') {% AND {%=$PARAMIN/@col_where%} = {$PARAMIN/@gb} %} {% %} %}

GROUP BY                         
	LIQ96_CONCEPTOS.c_concepto,
	LIQ96_CONCEPTOS.c_tipo_concepto,
	LIQ97_PERSONAL_EMP.e_numero_legajo,
	LIQ97_PERSONAL_EMP.d_ape_y_nom

ORDER BY
e_numero_legajo ASC
')/ROWS/ROW,
		$l in $conceptos/CONC
JOIN
		$l/@c_concepto INNER $r/@c_concepto
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="qry_leg_detail" doc-path="$r" to-element="$l"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_leg_detail" doc="SOURCE">
			<qry:out>
				<qry:element name="PER">
					<qry:attribute name="e_numero_legajo" value="$source/@e_numero_legajo"/>
					<qry:attribute name="c_concepto" value="$source/@c_concepto"/>
					<qry:attribute name="orderby" value="nmd_fillleft($source/@e_numero_legajo,'0',10)"/>
					<qry:attribute name="d_ape_y_nom" value="$source/@d_ape_y_nom"/>
					<qry:attribute name="n_ocurrencia" value="number($source/@n_ocurrencia)"/>
					<qry:attribute name="n_cantidad" value="number($source/@n_cantidad)"/>
					<qry:attribute name="n_valor" value="number($source/@n_valor)"/>
					<qry:if test="$SOURCE/@c_tipo_concepto='1'">
						<qry:then>
							<qry:attribute name="n_valor1" value="@n_valor"/>
