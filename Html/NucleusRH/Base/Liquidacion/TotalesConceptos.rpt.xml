	<html:xslt>
		<xsl:template name="GROUP_TABLE_UP">
			<xsl:param name="CHILDS"/>
			<xsl:variable name="group" select="."/>
			<xsl:variable name="tag" select="@tag"/>
			<xsl:if test="count($CHILDS/*[name()= $tag])=0">
				<xsl:if test="@noreg!=''">
					<br/>
					<span style="font-weight:bold;">
						<xsl:value-of select="@noreg"/>
					</span>
					<br/>
				</xsl:if>
			</xsl:if>
			<xsl:if test="count($CHILDS/*[name()= $tag])&gt;0">
				<span class="table_span_style">
					<xsl:value-of select="@label"/>
				</span>
				<table VALIGN="top" class="table_table_style" cellspacing="0" cellpadding="0" border="0">
					<xsl:if test="@style">
						<xsl:attribute name="style">
							<xsl:value-of select="@style"/>
						</xsl:attribute>
					</xsl:if>
					<xsl:call-template name="HEAD_GROUP"/>
					<tbody>
						<xsl:for-each select="$CHILDS">
							<xsl:variable name="current_child_x" select="."/>
							<xsl:if test="not($current_child_x/@visible='0')">
								<tr>
									<xsl:if test="$current_child_x/@style">
										<xsl:attribute name="style">
											<xsl:value-of select="$current_child_x/@style"/>
										</xsl:attribute>
									</xsl:if>
									<xsl:for-each select="$group/COLS/COL">
										<xsl:variable name="current_col" select="@name"/>
										<td>
											<xsl:if test="@align">
												<xsl:attribute name="align">
													<xsl:value-of select="@align"/>
												</xsl:attribute>
											</xsl:if>
											<xsl:if test="@style">
												<xsl:attribute name="style">
													<xsl:value-of select="@style"/>
												</xsl:attribute>
											</xsl:if>
											<xsl:if test="@colspan">
												<xsl:attribute name="colspan">
													<xsl:value-of select="@colspan"/>
												</xsl:attribute>
											</xsl:if>
											<xsl:if test="@nowrap='1'">
												<xsl:attribute name="nowrap">
													<xsl:value-of select="'1'"/>
												</xsl:attribute>
											</xsl:if>
											<xsl:choose>
												<xsl:when test="@type='num'">
													<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
														<xsl:value-of select="$current_child_x/attribute::*[name() = $current_col]"/>
														<xsl:value-of select="$current_child_x/attr[@name = $current_col]/@val"/>
													</xsl:attribute>
													<xsl:attribute name="id">
														num
													</xsl:attribute>
													<xsl:if test="$current_child_x/attribute::*[name() = $current_col]!=''">
														<xsl:value-of select="format-number($current_child_x/attribute::*[name() = $current_col], '###,###,##0.00')"/>
													</xsl:if>
													<xsl:if test="$current_child_x/attr[@name = $current_col]/@val!=''">
														<xsl:value-of select="format-number($current_child_x/attr[@name = $current_col]/@val, '###,###,##0.00')"/>
													</xsl:if>
												</xsl:when>
												<xsl:when test="@type='text'">
													<pre>
														<xsl:value-of select="$current_child_x/attribute::*[name() = $current_col]" disable-output-escaping="yes"/>
														<xsl:value-of select="$current_child_x/attr[@name = $current_col]/@val" disable-output-escaping="yes"/>
													</pre>
												</xsl:when>
												<xsl:when test="@type='multiline'">
													<xsl:call-template name="Multiline">
														<xsl:with-param name="stringIn" select="$current_child_x/attribute::*[name() = $current_col]"/>
													</xsl:call-template>
												</xsl:when>
												<xsl:when test="@type='template'">
													<xsl:call-template name="T0">
														<xsl:with-param name="template" select="$current_col"/>
														<xsl:with-param name="source" select="$current_child_x"/>
													</xsl:call-template>
												</xsl:when>
												<xsl:when test="OPT">
													<xsl:value-of select="OPT[@id=$current_child_x/attribute::*[name() = $current_col]]/@value" disable-output-escaping="yes"/>
													<xsl:value-of select="OPT[@id=$current_child_x/attr[@name = $current_col]/@val]/@value" disable-output-escaping="yes"/>
												</xsl:when>
												<xsl:otherwise>
													<xsl:value-of select="$current_child_x/attribute::*[name() = $current_col]" disable-output-escaping="yes"/>
													<xsl:value-of select="$current_child_x/attr[@name = $current_col]/@val" disable-output-escaping="yes"/>
												</xsl:otherwise>
											</xsl:choose>
										</td>
									</xsl:for-each>
								</tr>
								<xsl:if test="$group/GROUP">
									<tr>
										<td>
											<xsl:if test="$group/GROUP/COLS/@style">
												<xsl:attribute name="style">
													<xsl:value-of select="$group/GROUP/COLS/@style"/>
												</xsl:attribute>
											</xsl:if>
											<xsl:attribute name="colspan">
												<xsl:value-of select="count($group/COLS/COL)"/>
											</xsl:attribute>
											<xsl:for-each select="$group/GROUP">
												<xsl:call-template name="GROUP_TYPE">
													<xsl:with-param name="CHILDS" select="$current_child_x"/>
												</xsl:call-template>
											</xsl:for-each>
										</td>
									</tr>
								</xsl:if>
							</xsl:if>
						</xsl:for-each>
					</tbody>
					<xsl:call-template name="FOOT_GROUP">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</table>
				<br/>
			</xsl:if>
		</xsl:template>
		<xsl:template name="GROUP_TYPE">
			<xsl:param name="CHILDS"/>
			<xsl:choose>
				<xsl:when test="@type='title'">
					<xsl:call-template name="GROUP_TITLE">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='title_collapse'">
					<xsl:call-template name="GROUP_TITLE_COLLAPSE">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='title_sinespacios'">
					<xsl:call-template name="GROUP_TITLE_SINESPACIOS">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='table'">
					<xsl:call-template name="GROUP_TABLE">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='table-up'">
					<xsl:call-template name="GROUP_TABLE_UP">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='hor_table'">
					<xsl:call-template name="GROUP_HOR_TABLE">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='table_parent'">
					<xsl:call-template name="GROUP_TABLE_PARENT">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:when test="@type='tablestruc'">
					<xsl:call-template name="GROUP_TABLESTRUC">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:when>
				<xsl:otherwise>
					<xsl:call-template name="GROUP_TABLE">
						<xsl:with-param name="CHILDS" select="$CHILDS"/>
					</xsl:call-template>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:template>
	</html:xslt>
</html:html>
