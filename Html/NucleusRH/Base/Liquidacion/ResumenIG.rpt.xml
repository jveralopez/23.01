<html:html doc="source" name="NucleusRH.Base.Liquidacion.ListadoConcepto" xmlns:html="nomad:html" xmlns:qry="nomad:query" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
	<html:query declare="&lt;FILTRO e_anio=&quot;2008&quot;/&gt;">
		<qry:main xmlns:qry="nomad_engine.qry" doc="SOURCE">
			<qry:element name="DATOS">
				<qry:element name="ITEMS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="QRY_ITEMS"/>
				</qry:element>
				<qry:element name="GANANCIA">
					<qry:element name="MES1">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="1"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES2">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="2"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES3">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="3"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES4">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="4"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES5">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="5"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES6">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="6"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES7">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="7"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES8">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="8"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES9">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="9"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES10">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="10"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES11">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="11"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
					<qry:element name="MES12">
						<qry:element name="MES">
							<qry:attribute name="e_anio" value="#SOURCE:FILTRO/@e_anio"/>
							<qry:attribute name="e_mes" value="12"/>
							<qry:insert-select doc-path="." name="QRY_GAN"/>
						</qry:element>
					</qry:element>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_ITEMS" doc="SOURCE">
			<qry:xquery>
				for $r in sql('SELECT c.oi_item_ig, c.c_item_ig, 
		c.d_item_ig, d.d_tipo_deduc, c.e_orden
		FROM LIQ04_ITEMS_IG as c,
		LIQ03_TIPOS_DEDUC as d
		JOIN
		c.oi_tipo_deduc INNER d.oi_tipo_deduc')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ITEM">
					<qry:attribute name="c_item_ig" value="$r/@c_item_ig"/>
					<qry:attribute name="d_item_ig" value="$r/@d_item_ig"/>
					<qry:attribute name="d_tipo_deduc" value="$r/@d_tipo_deduc"/>
					<qry:attribute name="oi_item_ig" value="$r/@oi_item_ig"/>
					<qry:attribute name="e_anio" value="#SOURCE:@e_anio"/>
					<qry:attribute name="e_mes" value="1"/>
					<qry:element name="TOPE1">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="2"/>
					<qry:element name="TOPE2">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="3"/>
					<qry:element name="TOPE3">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="4"/>
					<qry:element name="TOPE4">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="5"/>
					<qry:element name="TOPE5">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="6"/>
					<qry:element name="TOPE6">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="7"/>
					<qry:element name="TOPE7">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="8"/>
					<qry:element name="TOPE8">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="9"/>
					<qry:element name="TOPE9">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="10"/>
					<qry:element name="TOPE10">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="11"/>
					<qry:element name="TOPE11">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
					<qry:attribute name="e_mes" value="12"/>
					<qry:element name="TOPE12">
						<qry:insert-select doc-path=".." name="QRY_TOPES"/>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_TOPES" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT 
s.e_mes, 
s.n_importe
FROM LIQ04_IDIG as s
where
s.oi_item_ig = {#SOURCE:@oi_item_ig} 
and 
s.e_anio = {#SOURCE:@e_anio} 
and 
s.e_mes = {#SOURCE:@e_mes} 
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="FORMAT_NUMBER($r/@n_importe, 10, 2, '.', '', '')" name="n_importe"/>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_GAN" doc="SOURCE">
			<qry:xquery>
				for $r in sql('SELECT s.n_tot_imp_d, 
s.n_tot_imp_h, 
s.n_cuota, 
s.n_p_rango,
s.e_anio,
s.e_mes
FROM LIQ06_IG as s
WHERE
s.e_anio = {#SOURCE:@e_anio}
and
s.e_mes = {#SOURCE:@e_mes}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="GAN">
					<qry:attribute value="FORMAT_NUMBER($r/@n_tot_imp_d, 10, 2, '.', '', '')" name="n_tot_imp_d"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_tot_imp_h, 10, 2, '.', '', '')" name="n_tot_imp_h"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_cuota, 10, 2, '.', '', '')" name="n_cuota"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_p_rango, 10, 2, '.', '', '')" name="n_p_rango"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_VARA" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
				
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ07_VAL_VAREA.n_valor
FROM         
LIQ07_VAL_VAREA ,
LIQ09_VARIABLES 
JOIN
LIQ07_VAL_VAREA.oi_variable INNER LIQ09_VARIABLES.oi_variable 
WHERE
LIQ07_VAL_VAREA.oi_personal_emp = {%= #SOURCE:@oi_personal_emp %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VACUM">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_VAREN" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ25_VAL_VAREN.n_valor
FROM         
LIQ25_VAL_VAREN ,
LIQ09_VARIABLES 
JOIN
LIQ25_VAL_VAREN.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ25_VAL_VAREN.oi_personal_liq= {%= #SOURCE:@oi_personal_liq %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="NOVEDAD">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_VARGN" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ19_VAL_VARGN.n_valor
FROM         
LIQ19_VAL_VARGN ,
LIQ09_VARIABLES 
JOIN
LIQ19_VAL_VARGN.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ19_VAL_VARGN.oi_liquidacion= {%= #SOURCE:@oi_liquidacion %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="NOVEDADLIQ">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_VARGF" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ09_VARIABLES.c_variable, 
LIQ09_VARIABLES.d_variable, 
LIQ09_VARIABLES.c_tipo_variable, 
LIQ15_VAL_VARGF.n_valor
FROM         
LIQ15_VAL_VARGF ,
LIQ09_VARIABLES 
JOIN
LIQ15_VAL_VARGF.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ15_VAL_VARGF.oi_empresa= {%= #SOURCE:@oi_empresa %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VARGF">
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="d_tipo_variable" value="$r/@c_tipo_variable"/>
					<qry:attribute name="variable" value="$r/@c_variable + ' - ' + $r/@d_variable"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_CONC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
LIQ14_CONCEPTOS.c_concepto, 
LIQ14_CONCEPTOS.d_concepto, 
ORG08_CS_COSTO.c_centro_costo, 
ORG08_CS_COSTO.d_centro_costo, 
LIQ25_CONC_MAN_PER.n_valor, 
LIQ25_CONC_MAN_PER.n_cantidad
FROM         
LIQ25_CONC_MAN_PER , LIQ14_CONCEPTOS , ORG08_CS_COSTO 
JOIN
LIQ25_CONC_MAN_PER.oi_concepto INNER LIQ14_CONCEPTOS.oi_concepto ,
LIQ25_CONC_MAN_PER.oi_centro_costo INNER ORG08_CS_COSTO.oi_centro_costo
WHERE
LIQ25_CONC_MAN_PER.oi_personal_liq= {%= #SOURCE:@oi_personal_liq %}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONCEPTO">
					<qry:attribute name="n_cantidad" value="$r/@n_cantidad"/>
					<qry:attribute name="n_valor" value="$r/@n_valor"/>
					<qry:attribute name="concepto" value="$r/@c_concepto + ' - ' + $r/@d_concepto"/>
					<qry:attribute name="centrocosto" value="$r/@c_centro_costo + ' - ' + $r/@d_centro_costo"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_LIC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
P16.c_licencia, 
P16.d_licencia, 
P02.f_inicio, 
P02.f_fin, 
P02.f_interrupcion
FROM         
PER02_LICEN_PER as P02 , 
PER16_LICENCIAS as P16 

JOIN
P02.oi_licencia INNER P16.oi_licencia
WHERE
P02.oi_personal_emp = {%= #SOURCE:@oi_personal_emp %}
and
(addmonths(P02.f_inicio,-1) &lt; {Datetime(#SOURCE:@iniPeriodo)}

    and
    ( 
      P02.f_fin &gt;= {Datetime(#SOURCE:@iniPeriodo)} 
      and 
      (
         isnull(P02.f_interrupcion) 
         or 
         P02.f_interrupcion &gt;= {Datetime(#SOURCE:@iniPeriodo)}
       )
     )
   )
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LIC">
					<qry:attribute value="format_date($r/@f_inicio,'dd/mm/yyyy')" name="f_inicio"/>
					<qry:attribute value="format_date($r/@f_fin,'dd/mm/yyyy')" name="f_fin"/>
					<qry:attribute value="format_date($r/@f_interrupcion,'dd/mm/yyyy')" name="f_interrupcion"/>
					<qry:attribute name="licencia" value="$r/@c_licencia + ' - ' + $r/@d_licencia"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_DEDUC" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT  
tr.c_item_ig ,  
tr.d_item_ig ,  
tv.c_entidad_ig ,  
tv.d_entidad_ig ,  
t.f_fecha ,  
t.n_importe 

FROM LIQ07_DEDUC_IG as t ,
LIQ04_ITEMS_IG as tr,
LIQ05_ENTIDADES_IG as tv,
liq19_liquidacion as l  

JOIN
t.oi_item_ig left outer tr.oi_item_ig,
tv.oi_entidad_ig right outer t.oi_entidad_ig
WHERE 
t.oi_personal_emp = {#SOURCE:@oi_personal_emp}
and
l.oi_liquidacion = {#SOURCE:@oi_liquidacion}
AND
GETYEAR(t.f_fecha) = GETYEAR(l.f_pago)
and
GETMONTH(t.f_fecha) &lt;= GETMONTH(l.f_pago)
order by 
 f_fecha DESC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DEDUC">
					<qry:attribute name="ItemIG" value="$r/@c_item_ig + '-' + $r/@d_item_ig"/>
					<qry:attribute name="EntidadIG" value="$r/@c_entidad_ig + '-' + $r/@d_entidad_ig"/>
					<qry:attribute value="format_date($r/@f_fecha,'dd/mm/yyyy')" name="Fecha"/>
					<qry:attribute value="FORMAT_NUMBER($r/@n_importe, 10, 2, '.', '', '')" name="Importe"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select xmlns:qry="nomad_engine.qry" name="QRY_PARAM" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
		SELECT     
LIQ07_PARAM_PER.d_valor, 
ORG26_PARAMETROS.c_parametro, 
ORG26_PARAMETROS.d_parametro
FROM         
LIQ07_PARAM_PER , 
ORG26_PARAMETROS 
JOIN
LIQ07_PARAM_PER.oi_parametro INNER ORG26_PARAMETROS.oi_parametro
WHERE
LIQ07_PARAM_PER.oi_personal_emp = {#SOURCE:@oi_personal_emp}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PARAM">
					<qry:attribute name="parametro" value="$r/@c_parametro + '-' + $r/@d_parametro"/>
					<qry:attribute name="d_valor" value="$r/@d_valor"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/DATOS">
			<html>
				<head>
					<LINK href="../Skins/Styles/GReport.css" type="text/css" rel="stylesheet"/>
					<STYLE>
						body{background-color:#FFFFFF;}
table.tabla
{
	cellpadding: 0;
	cellspacing: 0;
	border-collapse: collapse;
}
td.tit
{
	font-family:verdana;
	font-weight: bolder;
	font-size: 18px;
	padding: 2px 2px 2px 2px;	
	text-align: center;
}
td.a1
{
	text-align:center;
	font-family:verdana;
	font-weight: bold;
	font-size: 12px;
	font-style: normal;
	background-color:#C0C0C0;
	border-top-width: 1;
	border-top-style: solid;
	border-top-color: #000000;
	border-left-width: 1;
	border-left-style: solid;
	border-left-color: #000000;
	border-bottom-width: 1;
	border-bottom-style: solid;
	border-bottom-color: #000000;
	border-right-width: 1;
	border-right-style: solid;
	border-right-color: #000000;	
	padding: 2px 2px 2px 2px;		
}
td.a2
{
	text-align:right;
	font-family:verdana;
	font-weight: normal;
	font-size: 10px;
	font-style: normal;
	border-bottom-width: 1;
	border-bottom-style: solid;
	border-bottom-color: #000000;
	border-left-width: 1;
	border-left-style: solid;
	border-left-color: #000000;
	border-top-width: 1;
	border-top-style: solid;
	border-top-color: #000000;
	border-right-width: 1;
	border-right-style: solid;
	border-right-color: #000000;
	padding: 2px 2px 2px 2px;	
}
					</STYLE>
				</head>
				<body bgcolor="#F2F2EC">
					<xsl:apply-templates select="ITEMS"/>
					<br/>
					<xsl:apply-templates select="GANANCIA"/>
					<br/>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="ITEMS">
			<table class="tabla" width="100%">
				<tr>
					<td colspan="13" class="tit">
						Items Deducibles - 4ta Categoria
					</td>
				</tr>
				<tr>
					<td class="a1">
						Item
					</td>
					<td class="a1">
						Acumulado Enero
					</td>
					<td class="a1">
						Acumulado Febrero
					</td>
					<td class="a1">
						Acumulado Marzo
					</td>
					<td class="a1">
						Acumulado Abril
					</td>
					<td class="a1">
						Acumulado Mayo
					</td>
					<td class="a1">
						Acumulado Junio
					</td>
					<td class="a1">
						Acumulado Julio
					</td>
					<td class="a1">
						Acumulado Agosto
					</td>
					<td class="a1">
						Acumulado Septiembre
					</td>
					<td class="a1">
						Acumulado Octubre
					</td>
					<td class="a1">
						Acumulado Noviembre
					</td>
					<td class="a1">
						Acumulado Diciembre
					</td>
				</tr>
				<xsl:for-each select="ITEM">
					<tr>
						<td class="a2">
							<xsl:value-of select="@d_item_ig"/>
							&#160;
