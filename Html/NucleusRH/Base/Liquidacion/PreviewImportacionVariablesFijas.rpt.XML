<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" name="NucleusRH.Base.Liquidacion.PreviewImportacionVariablesFijas" doc="source">
	<html:query>
		<qry:main>
			<REPORT label="Importacio&#243;n de Datos Fijos">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="ENTRADA" type="table">
						<COLS>
							<COL name="e_numero_legajo" label="Legajo"/>
							<COL name="c_variable" label="Variable"/>
							<COL name="n_valor" label="Valor" type="num"/>
						</COLS>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="sql1">
			<qry:xquery>
				for $r in INTERFACE('GET_PTR:IntVarLiqFij.dat')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="sql2" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="sql2" doc="PARAM">
			<qry:xquery>
				for $r in DDO('NucleusRH.Base.Liquidacion.InterfaceVariablesFijas.ENTRADA:{%= #PARAM:@id %}')/object/ENTRADA
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
