		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<REPORT label="LISTADO DE EMBARGOS">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
							<qry:if test="#PARAM:FILTRO/@c_tipo_embargo != ''">
								<qry:then>
									<COL name="c_tipo_embargo" label="Tipo Embargo"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@c_estado != ''">
								<qry:then>
									<COL name="c_estado" label="Estado"/>
								</qry:then>
							</qry:if>
						</COLS>
						<GROUP tag="LEG" type="title" noreg="No se encontraron registros de Embargos.">
							<COLS>
								<COL name="e_numero_legajo" label="Legajo"/>
							</COLS>
							<GROUP tag="DATOS" type="table" style="width:100%">
								<COLS>
									<COL name="nro_oficio" label="Nro. Oficio" style="width:10%"/>
									<COL name="f_oficio" label="Fecha Oficio" style="width:10%" type="date"/>
									<COL name="tipo_embargo" label="Tipo Embargo" style="width:35%"/>
									<COL name="f_recepcion" label="Fecha Recepci&#243;n" style="width:10%" type="date"/>
									<COL name="c_estado" label="Estado" style="width:15%"/>
									<COL name="n_monto_total" label="Monto Total" style="width:10%;text-align:right"/>
									<COL name="n_monto_pend" label="Monto Pendiente" style="width:10%;text-align:right"/>
								</COLS>
							</GROUP>
							<!-- Grupo de Detalle-->
							<qry:if test="$PARAM/FILTRO/@listar_detalle=1">
								<qry:then>
									<GROUP tag="DETALLE" type="title">
										<COLS>
											<COL name="detalle" label="Detalle"/>
										</COLS>
										<GROUP tag="Titulo_Detalle" type="title" noreg="No se encontr&#243; el detalle del embargo">
											<COLS>
												<COL name="c_tipo_embargo" label="Tipo"/>
												<COL name="e_nro_oficio" label="Oficio"/>
											</COLS>
											<GROUP tag="Tabla_Detalle" type="table" noreg="No hay movimientos" style="width:75%;text-align:center">
												<COLS>
													<COL name="d_titulo" label="Liquidaci&#243;n"/>
													<COL name="f_descuento" label="Fecha Descuento" type="date"/>
													<COL name="n_importe" label="Monto Descontado" style="text-align:right"/>
												</COLS>
												<FCOLS>
													<COL/>
													<COL label="Total" style="text-align:right"/>
													<COL name="total" style="text-align:right"/>
												</FCOLS>
											</GROUP>
										</GROUP>
									</GROUP>
								</qry:then>
							</qry:if>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:insert-select name="DATOS_EMPRESA" doc-path="#PARAM:FILTRO"/>
						<qry:attribute name="c_tipo_embargo" value="iif(#FILTRO:@c_tipo_embargo='CA', 'Cuota Alimentaria', 'Otra Causa')"/>
						<qry:switch test="#FILTRO:@c_estado">
							<qry:case value="I">
								<qry:attribute name="c_estado" value="'Iniciado'"/>
							</qry:case>
							<qry:case value="A">
								<qry:attribute name="c_estado" value="'Activo'"/>
							</qry:case>
							<qry:case value="N">
								<qry:attribute name="c_estado" value="'Inactivo'"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="c_estado" value="'Finalizado'"/>
							</qry:default>
						</qry:switch>
						<qry:attribute name="qry-orderby" value="orderby"/>
						<qry:insert-select doc-path="#PARAM:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="DATOS_EMPRESA">
			<qry:xquery>
				for $r in SQL(' 
			SELECT
				EMPRE.c_empresa, 
				EMPRE.d_empresa 
			FROM
				ORG03_EMPRESAS AS EMPRE
			WHERE
				EMPRE.oi_empresa = {#PARAM:@oi_empresa}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@c_empresa + '-' + $r/@d_empresa" name="empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute value="#PARAM:@values" name="values"/>
						<qry:attribute value="#FILTRO:@oi_empresa" name="oi_empresa"/>
						<qry:attribute value="#FILTRO:@c_tipo_embargo" name="c_tipo_embargo"/>
						<qry:attribute value="#FILTRO:@c_estado" name="c_estado"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO oi_empresa=&quot;196&quot; values=&quot;1050,1051,1052,1053,1054,1056,1057,1070,1071,1073,1075,1077,1079,1080,1081,1089,1093,1096,1097,1098,1101,1103,1105,1110,1114,1115,1116,1117,1123,1125,1126,1130,1131,1132,1133,1134,1135,1138,1139,1140,1141,1147,1148,1150,11565,1160,1161,1162,1163,1166,1168,1169,1176,1180,1181,1182,1184,1185,1186,1194,1197,1201,1205,1206,1219,1220,1225,1230,1232,1233,1239,1250,1261,1263,1265,1266,1267,1283,1285,1287,1290,1297,1301,1307,1311,1312,1313,1319,1330,1331,1332,1335,1336,1342,1343,1344,1347,1349,1354,1355,1356&quot;/&gt;&#13;&#10;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO2" doc-path="#PARAM:FILTRO"/>
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:/FILTRO" name="DATOS_PERSONAS"/>
			</qry:no-show>
		</qry:main>
		<qry:select doc="PARAM" name="DATOS_PERSONAS">
			<qry:xquery>
				for $r in sql(' 
			SELECT 
				PER02.e_numero_legajo, 
				PER01.d_ape_y_nom, 
				PER02.oi_personal_emp
			FROM 
				PER02_PERSONAL_EMP AS PER02,
				PER01_PERSONAL AS PER01  
			JOIN
				PER02.oi_personal INNER PER01.oi_personal                  
			WHERE
				PER02.oi_empresa = {#PARAM:@oi_empresa} AND
				PER02.oi_personal_emp in ({%=#PARAM:@values%})    
			ORDER BY
				e_numero_legajo ASC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LEG">
					<qry:attribute name="orderby" value="nmd_fillleft($r/@e_numero_legajo,'0',10)"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo + '-' + $r/@d_ape_y_nom"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="QRY_EMBARGOS" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_EMBARGOS">
			<qry:xquery>
				for $r in SQL(' 
			SELECT 
				LIQ07.e_nro_oficio, 
				LIQ07.f_oficio,
				LIQ07.f_recepcion,
				LIQ07.c_tipo_embargo,
				LIQ07.c_estado, 
				LIQ07.oi_embargo,
				LIQ07.n_monto_total,
				LIQ07.n_monto_pend
			FROM
				LIQ07_EMBARGOS AS LIQ07
			WHERE
				LIQ07.oi_personal_emp = {#PARAM:@oi_personal_emp}
			 	{%? (#FILTRO2:@c_estado != '') 
					{% AND (LIQ07.c_estado = {#FILTRO2:@c_estado}) %} 
					{% %} 
				%}
				{%? (#FILTRO2:@c_tipo_embargo != '') 
					{% AND (LIQ07.c_tipo_embargo = {#FILTRO2:@c_tipo_embargo}) %} 
					{% %} 
				%}  
			ORDER BY
				f_recepcion ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hts:delete" value="'0'"/>
				<qry:element name="DATOS">
					<qry:attribute name="nro_oficio" value="$r/@e_nro_oficio"/>
					<qry:attribute name="f_oficio" value="format_date($r/@f_oficio,'dd/mm/yyyy')"/>
					<qry:attribute name="tipo_embargo" value="iif($r/@c_tipo_embargo='CA', 'Cuota Alimentaria', 'Otra Causa')"/>
					<qry:attribute name="f_recepcion" value="format_date($r/@f_recepcion,'dd/mm/yyyy')"/>
					<qry:attribute name="oi_embargo" value="$r/@oi_embargo"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="I">
							<qry:attribute name="c_estado" value="'Iniciado'"/>
						</qry:case>
						<qry:case value="A">
							<qry:attribute name="c_estado" value="'Activo'"/>
						</qry:case>
						<qry:case value="N">
							<qry:attribute name="c_estado" value="'Inactivo'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_estado" value="'Finalizado'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="n_monto_total" value="iif($r/@n_monto_total !='', concat('$',format-number($r/@n_monto_total,0,2,'.','','')), '')"/>
					<qry:attribute name="n_monto_pend" value="iif($r/@n_monto_pend !='', concat('$',format-number($r/@n_monto_pend,0,2,'.','','')), '')"/>
				</qry:element>
				<DETALLE>
					<Titulo_Detalle>
						<qry:if test="$r/@c_tipo_embargo='CA'">
							<qry:then>
								<qry:attribute name="c_tipo_embargo" value="'Cuota Alimentaria'"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="c_tipo_embargo" value="'Otra Causa'"/>
							</qry:else>
						</qry:if>
						<qry:attribute name="e_nro_oficio" value="$r/@e_nro_oficio"/>
						<qry:attribute name="total" value="0"/>
						<qry:insert-select name="qry_detalle" doc-path="$r"/>
						<qry:attribute name="total" value="concat('$' ,format-number(@total,0,2,'.',',',''))"/>
					</Titulo_Detalle>
				</DETALLE>
			</qry:out>
		</qry:select>
		<qry:select name="sqldelete" doc="PARAM">
			<qry:out>
				<qry:attribute name="hts:delete" value="'0'"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_detalle" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			SELECT L.d_titulo,
			 D.f_descuento,
			 D.n_importe
			FROM  LIQ07_DESC_EMB  as D,
			LIQ19_LIQUIDACION as L
			JOIN

				D.oi_liquidacion INNER L.oi_liquidacion
				WHERE d.oi_embargo = {$PARAM/@oi_embargo}
				
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<Tabla_Detalle>
					<qry:attribute name="d_titulo" value="$r/@d_titulo"/>
					<qry:attribute name="f_descuento" value="format-date($r/@f_descuento,'dd/mm/yyyy')"/>
					<qry:attribute name="n_importe" value="concat('$',format-number($r/@n_importe,0,2,'.',',',''))"/>
				</Tabla_Detalle>
				<qry:attribute name="total" value="number(./@total) + number($r/@n_importe)"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
