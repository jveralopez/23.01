<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Liquidacion.">
	<html:for-each declare="&lt;DATOS oi_empresa=&quot;1&quot; salida=&quot;HTML&quot; oi_liquidacion=&quot;&quot; oi_variable=&quot;&quot; report=&quot;&quot; gconceptos=&quot;1&quot; gcustom=&quot;&quot; mostrar=&quot;v&quot; oi_tipo_concepto=&quot;&quot; gpers=&quot;&quot; liq_cod=&quot;&quot; liq_f_liq_des=&quot;&quot; liq_f_liq_has=&quot;&quot; liq_f_des=&quot;&quot; liq_f_has=&quot;&quot; liq_f_pag_des=&quot;&quot; liq_f_pag_has=&quot;&quot; liq_oi_tipo_liq=&quot;&quot; liq_c_estado=&quot;&quot; l_listar_lsd=&quot;&quot; liqID=&quot;301&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;1-10&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; cb_confidenciales=&quot;&quot; oi_grupo_ccosto=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_oficina_pago=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; oi_departamento=&quot;&quot; oi_sector=&quot;&quot; oi_banco=&quot;&quot; oi_sucursal=&quot;&quot; legID=&quot;&quot; leg_where=&quot;(LEG.e_numero_legajo &amp;gt;= 1 AND LEG.e_numero_legajo &amp;lt;= 10)&quot; nom_where=&quot;&quot;&gt;&lt;ROWS /&gt;&lt;PERSONAS&gt;&lt;ROW VALUES=&quot;1,84549,3,64586,5,6,7,8,9,10&quot; /&gt;&lt;/PERSONAS&gt;&lt;LIQUIDACIONES&gt;&lt;ROW VALUES=&quot;301&quot; /&gt;&lt;/LIQUIDACIONES&gt;&lt;/DATOS&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<REPORT label="Listado de Conceptos por Personas">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="EMP" type="title" style="width:95%;">
						<COLS>
							<qry:append-doc name="FILTRO" doc-path="#SOURCE:."/>
							<COL name="d_empresa" label="Empresa"/>
							<qry:if test="#SOURCE:DATOS/@oi_tipo_concepto!=''">
								<qry:then>
									<COL name="tipo_concepto" label="Tipo de concepto"/>
								</qry:then>
							</qry:if>
						</COLS>
						<GROUP tag="LIQ" style="padding-left:50px;width:400px;" type="table">
							<COLS>
								<COL name="c_liquidacion" label="C&#243;digo"/>
								<COL name="d_liquidacion" label="Titulo"/>
								<COL name="e_periodo" label="Periodo" style="text-align:center;"/>
							</COLS>
						</GROUP>
						<GROUP tag="PER" style="padding-left:50px;" type="table">
							<COLS>
								<COL name="e_numero_legajo" label="Legajo" nowrap="1"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" nowrap="1"/>
								<COL name="f_nacim" label="Fecha Nac." nowrap="1" type="date"/>
								<COL name="f_ingreso" label="Fecha Ing." nowrap="1" type="date"/>
								<COL name="f_antiguedad_rec" label="Fecha a Comp." nowrap="1" type="date"/>
								<COL name="c_cuil" label="CUIL" nowrap="1"/>
								<COL name="d_categoria" label="Categor&#237;a" nowrap="1"/>
								<qry:if test="#SOURCE:DATOS/@mostrar_funcion='1'">
									<qry:then>
										<COL name="d_funcion" label="Funci&#243;n" nowrap="1"/>
									</qry:then>
								</qry:if>
								<COL name="d_convenio" label="Convenio" nowrap="1"/>
								<COL name="d_centro_costo" label="Centro de costos" nowrap="1"/>
								<COL name="d_obra_social" label="Obra Social" nowrap="1"/>
								<qry:insert-select name="qry_conceptos" doc-path="#SOURCE:DATOS/LIQUIDACIONES"/>
								<qry:switch test="#FILTRO:@mostrar">
									<qry:case value="v">
										<COL name="tot_pag" label="Total" type="num"/>
									</qry:case>
									<qry:case value="c">
										<COL name="tot_pag" label="Total" type="num"/>
									</qry:case>
									<qry:default>
										<COL name="tot_pag_V" label="Total por Valor" type="num"/>
										<COL name="tot_pag_C" label="Total por Cantidad" type="num"/>
									</qry:default>
								</qry:switch>
							</COLS>
							<FCOLS>
								<COL name="e_numero_legajo" label="Legajo"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre"/>
								<COL name="f_nacim" label="Fecha Nac." nowrap="1" type="date"/>
								<COL name="f_ingreso" label="Fecha Ing." nowrap="1" type="date"/>
								<COL name="f_antiguedad_rec" label="Fecha a Comp." nowrap="1" type="date"/>
								<COL name="c_cuil" label="CUIL"/>
								<COL name="d_categoria" label="Categor&#237;a" nowrap="1"/>
								<COL name="d_convenio" label="Convenio" nowrap="1"/>
								<COL name="d_centro_costo" label="Centro de costos"/>
								<COL name="d_obra_social" label="Obra Social"/>
								<qry:insert-select name="qry_conceptos" doc-path="#SOURCE:DATOS/LIQUIDACIONES"/>
								<qry:switch test="#FILTRO:@mostrar">
									<qry:case value="v">
										<COL name="tot_pag" label="Total" type="num"/>
									</qry:case>
									<qry:case value="c">
										<COL name="tot_pag" label="Total" type="num"/>
									</qry:case>
									<qry:default>
										<COL name="tot_pag_V" label="Total por Valor" type="num"/>
										<COL name="tot_pag_C" label="Total por Cantidad" type="num"/>
									</qry:default>
								</qry:switch>
							</FCOLS>
							<qry:append-doc name="CONCEPTOS" doc-path="."/>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<EMP qry-orderby="orderby">
						<qry:attribute name="qry-sum" value="String(../../GROUPS/GROUP/GROUP/FCOLS/COL[@type='num']/@name)"/>
						<qry:if test="#SOURCE:DATOS/@oi_tipo_concepto!=''">
							<qry:then>
								<qry:insert-select name="qry_tipo_concepto" doc-path="#SOURCE:DATOS"/>
							</qry:then>
						</qry:if>
						<qry:insert-select name="qry_cabecera" doc-path="#SOURCE:DATOS"/>
					</EMP>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select name="qry_conceptos" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
	CONC.c_concepto,   
	max(CONC.d_concepto) as d_concepto,
	TCONC.e_orden
	
FROM         
	LIQ12_TIPOS_CONC as TCONC,
	LIQ96_CONCEPTOS as CONC,
	LIQ20_CONC_LIQ_PER as RCONC,
	LIQ99_RECIBOS as REC,
	LIQ99_LIQUIDACION as LIQ, 
	LIQ19_EJECUCIONES as EJE
	
JOIN
 	CONC.c_tipo_concepto INNER TCONC.c_tipo_concepto,
 	CONC.oi_concepto_ddo INNER RCONC.oi_concepto_ddo,
 	RCONC.oi_tot_liq_per INNER REC.oi_tot_liq_per,
 	REC.oi_liquidacion_ddo INNER LIQ.oi_liquidacion_ddo,
 	EJE.oi_liquidacion_ddo INNER LIQ.oi_liquidacion_ddo
 	
WHERE                  
	LIQ.c_estado = \'F\' AND 
	EJE.oi_liquidacion in ({%=string(#SOURCE:ROW/@VALUES) %})   
	{%? (#SOURCE:../@oi_tipo_concepto!='') 
		{% 
			AND TCONC.oi_tipo_concepto={#SOURCE:../@oi_tipo_concepto} 
		%} 
		{% 
			AND TCONC.l_nolistado = 0
		%} 
	%}
	
GROUP BY
	CONC.c_concepto, TCONC.e_orden	
	
ORDER BY
	e_orden ASC, c_concepto ASC')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:switch test="#FILTRO:@mostrar">
					<qry:case value="v">
						<qry:element name="COL">
							<qry:attribute name="name" value="'V_'+$r/@c_concepto"/>
							<qry:attribute name="label" value="'[' + $r/@c_concepto + ']' + $r/@d_concepto"/>
							<qry:attribute name="type" value="'num'"/>
						</qry:element>
					</qry:case>
					<qry:case value="c">
						<qry:element name="COL">
							<qry:attribute name="name" value="'C_'+$r/@c_concepto"/>
							<qry:attribute name="label" value="'[' + $r/@c_concepto + ']' + $r/@d_concepto"/>
							<qry:attribute name="type" value="'num'"/>
						</qry:element>
					</qry:case>
					<qry:default>
						<qry:element name="COL">
							<qry:attribute name="name" value="'V_'+$r/@c_concepto"/>
							<qry:attribute name="label" value="'Valor - [' + $r/@c_concepto + ']' + $r/@d_concepto"/>
							<qry:attribute name="type" value="'num'"/>
						</qry:element>
						<qry:element name="COL">
							<qry:attribute name="name" value="'C_'+$r/@c_concepto"/>
							<qry:attribute name="label" value="'Cantidad - [' + $r/@c_concepto + ']' + $r/@d_concepto"/>
							<qry:attribute name="type" value="'num'"/>
						</qry:element>
					</qry:default>
				</qry:switch>
			</qry:out>
		</qry:select>
		<qry:select name="qry_cabecera" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	ORG03_EMPRESAS.d_empresa, 
	ORG03_EMPRESAS.c_empresa
FROM 
	ORG03_EMPRESAS
WHERE
	ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@c_empresa + ' - ' + $r/@d_empresa"/>
				<qry:attribute name="l_mostrarTodos" value="#SOURCE:@l_mostrarTodos"/>
				<qry:insert-select name="qry_liquidacion" doc-path="#SOURCE:LIQUIDACIONES"/>
				<qry:insert-select name="qry_personas" doc-path="#SOURCE:PERSONAS/ROW"/>
				<qry:attribute name="tot_pag" value="0"/>
				<qry:attribute name="d_ape_y_nom" value="'Total'"/>
				<!--qry:insert-select name="qry_totales" doc-path="."/-->
				<!--qry:insert-select name="qry_totales3" doc-path="."/-->
			</qry:out>
		</qry:select>
		<qry:select name="qry_liquidacion" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	LIQ19_LIQUIDACION.c_liquidacion, 
	LIQ19_LIQUIDACION.o_liquidacion, 
	LIQ19_LIQUIDACION.d_titulo,
	LIQ19_LIQUIDACION.e_periodo 
FROM 
	LIQ19_LIQUIDACION
WHERE
	LIQ19_LIQUIDACION.oi_liquidacion in ({%=string(#SOURCE:ROW/@VALUES) %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LIQ>
					<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion"/>
					<qry:attribute name="d_liquidacion" value="$r/@d_titulo"/>
					<qry:attribute name="e_periodo" value="format_date($r/@e_periodo+'01','mm/yyyy')"/>
					<qry:attribute name="o_liquidacion" value="$r/@o_liquidacion"/>
				</LIQ>
			</qry:out>
		</qry:select>
		<qry:select name="qry_tipo_concepto" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
  LIQ12_TIPOS_CONC.c_tipo_concepto
  , LIQ12_TIPOS_CONC.d_tipo_concepto
  , LIQ12_TIPOS_CONC.oi_tipo_concepto
FROM 
  LIQ12_TIPOS_CONC
WHERE
  LIQ12_TIPOS_CONC.oi_tipo_concepto = {#SOURCE:@oi_tipo_concepto}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="tipo_concepto" value="$r/@c_tipo_concepto + ' - ' + $r/@d_tipo_concepto" type="Nomad.NSystem.Int"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_personas" doc="SOURCE">
			<qry:out>
				<qry:call>
					<ROW>
						<qry:attribute name="oi_tipo_concepto" value="#SOURCE:../../@oi_tipo_concepto"/>
						<qry:attribute name="pers" value="#SOURCE:@values"/>
						<qry:attribute name="liqs" value="String(#SOURCE:../../LIQUIDACIONES/ROW/@values)"/>
						<qry:attribute name="mostrar" value="#SOURCE:../../@mostrar"/>
					</ROW>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;ROW mostrar=&quot;v&quot; liqs=&quot;1,101,102,201,202,301,302,303,401,402,403,405,501,503,504,505,602,801,802,803,804,805,806,901,902,1001,1101,1201,1202,1203,1302,1303,1304,1308,1605,1606,1607,1609,1610,1703,1704,1901,1902,2001,2201,2301,2401,2501,2601,2701,2801,3001,3101&quot; pers=&quot;3&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:no-show>
				<qry:append-doc name="PARAMIN" doc-path="#SOURCE:/ROW"/>
				<qry:insert-select name="qry_personas" doc-path="#SOURCE:/ROW"/>
				<qry:if test="@oi_tot_liq_per!=''">
					<qry:then>
						<qry:element name="PER">
							<qry:attribute name="e_numero_legajo" value="../@e_numero_legajo"/>
							<qry:attribute name="orderby" value="nmd_fillleft(../@e_numero_legajo,'0',10)"/>
							<qry:attribute name="d_ape_y_nom" value="../@d_ape_y_nom"/>
							<qry:attribute name="c_cuil" value="../@c_cuil"/>
							<qry:attribute name="d_centro_costo" value="../@d_centro_costo"/>
							<qry:attribute name="d_obra_social" value="../@d_obra_social"/>
							<qry:attribute name="f_nacim" value="../@f_nacim"/>
							<qry:attribute name="d_convenio" value="../@d_convenio"/>
							<qry:attribute name="f_ingreso" value="../@f_ingreso"/>
							<qry:attribute name="f_antiguedad_rec" value="../@f_antiguedad_rec"/>
							<qry:attribute name="d_categoria" value="../@d_categoria"/>
							<qry:attribute name="oi_tot_liq_per" value="substring(../@oi_tot_liq_per,1)"/>
							<qry:attribute name="tot_pag" value="0"/>
							<qry:attribute name="total" value="0"/>
							<qry:switch test="#PARAMIN:@mostrar">
								<qry:case value="v">
									<qry:insert-select name="qry_conceptos_PER" doc-path="."/>
								</qry:case>
								<qry:case value="c">
									<qry:insert-select name="qry_conceptos_PER2" doc-path="."/>
								</qry:case>
								<qry:default>
									<qry:insert-select name="qry_conceptos_PER" doc-path="."/>
									<qry:insert-select name="qry_conceptos_PER2" doc-path="."/>
								</qry:default>
							</qry:switch>
							<qry:attribute name="d_funcion" value="../@d_funcion"/>
						</qry:element>
					</qry:then>
				</qry:if>
			</qry:no-show>
		</qry:main>
		<qry:select name="qry_personas" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
	LIQ20_TOT_LIQ_PER.oi_tot_liq_per, 
	LIQ97_PERSONAL_EMP.e_numero_legajo, 
	LIQ97_PERSONAL_EMP.d_ape_y_nom, 
	ORG08_CS_COSTO.d_centro_costo, 
	LIQ97_PERSONAL_EMP.c_nro_cuil, 
	PER06_OBRAS_SOC.d_obra_social,
	PER06_OBRAS_SOC.dc_obra_soc,
	LIQ97_PERSONAL_EMP.f_ingreso, 
	LIQ97_PERSONAL_EMP.f_antiguedad_rec, 
	LIQ97_PERSONAL_EMP.f_nacim, 
	ORG18_CATEGORIAS.d_categoria,
	ORG18_CONVENIOS.d_convenio,
	ORG03_FUNCIONES.d_funcion
	

FROM               
	LIQ19_EJECUCIONES, 
	LIQ25_PERSONAL_LIQ,
	PER02_PERSONAL_EMP,
	LIQ99_LIQUIDACION,
	LIQ99_RECIBOS, 
	LIQ20_TOT_LIQ_PER, 
	LIQ97_PERSONAL_EMP, 
	ORG08_CS_COSTO, 
	PER06_OBRAS_SOC,
	ORG18_CATEGORIAS,
	ORG18_CONVENIOS,
	ORG03_FUNCIONES
	
JOIN
	LIQ25_PERSONAL_LIQ.oi_liquidacion INNER LIQ19_EJECUCIONES.oi_liquidacion, 
	LIQ25_PERSONAL_LIQ.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
	LIQ99_RECIBOS.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo,
	LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
	LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ19_EJECUCIONES.oi_liquidacion_ddo,
	PER02_PERSONAL_EMP.e_numero_legajo INNER LIQ99_RECIBOS.e_numero_legajo,
	LIQ97_PERSONAL_EMP.oi_per_emp_ddo INNER LIQ20_TOT_LIQ_PER.oi_per_emp_ddo,
	LIQ97_PERSONAL_EMP.c_centro_costo_ult LEFT OUTER ORG08_CS_COSTO.c_centro_costo, 
	LIQ97_PERSONAL_EMP.c_obra_social LEFT OUTER PER06_OBRAS_SOC.c_obra_social,
	PER02_PERSONAL_EMP.oi_funcion LEFT OUTER ORG03_FUNCIONES.oi_funcion,
	LIQ97_PERSONAL_EMP.c_categoria_ult INNER ORG18_CATEGORIAS.c_categoria,
	LIQ97_PERSONAL_EMP.c_convenio INNER ORG18_CONVENIOS.c_convenio,
	ORG18_CONVENIOS.oi_convenio INNER ORG18_CATEGORIAS.oi_convenio
	

WHERE                                                 
	LIQ19_EJECUCIONES.oi_liquidacion in ({%= #SOURCE:@liqs %}) AND
	PER02_PERSONAL_EMP.oi_personal_emp in ({%= #SOURCE:@pers %}) AND
	LIQ99_LIQUIDACION.c_estado = \'F\'
	
ORDER BY 
	e_numero_legajo ASC	
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="@e_numero_legajo!=$r/@e_numero_legajo and @oi_tot_liq_per!=''">
					<qry:then>
						<qry:element name="PER">
							<qry:attribute name="e_numero_legajo" value="../@e_numero_legajo"/>
							<qry:attribute name="orderby" value="nmd_fillleft(../@e_numero_legajo,'0',10)"/>
							<qry:attribute name="d_ape_y_nom" value="../@d_ape_y_nom"/>
							<qry:attribute name="f_nacim" value="../@f_nacim"/>
							<qry:attribute name="f_ingreso" value="../@f_ingreso"/>
							<qry:attribute name="f_antiguedad_rec" value="../@f_antiguedad_rec"/>
							<qry:attribute name="c_cuil" value="../@c_cuil"/>
							<qry:attribute name="d_categoria" value="../@d_categoria"/>
							<qry:attribute name="d_convenio" value="../@d_convenio"/>
							<qry:attribute name="d_centro_costo" value="../@d_centro_costo"/>
							<qry:attribute name="d_obra_social" value="../@d_obra_social"/>
							<qry:attribute name="oi_tot_liq_per" value="substring(../@oi_tot_liq_per,1)"/>
							<qry:attribute name="tot_pag" value="0"/>
							<qry:attribute name="total" value="0"/>
							<qry:attribute name="d_funcion" value="../@d_funcion"/>
							<qry:switch test="#PARAMIN:@mostrar">
								<qry:case value="v">
									<qry:insert-select name="qry_conceptos_PER" doc-path="."/>
								</qry:case>
								<qry:case value="c">
									<qry:insert-select name="qry_conceptos_PER2" doc-path="."/>
								</qry:case>
								<qry:default>
									<qry:insert-select name="qry_conceptos_PER" doc-path="."/>
									<qry:insert-select name="qry_conceptos_PER2" doc-path="."/>
								</qry:default>
							</qry:switch>
						</qry:element>
						<qry:attribute name="oi_tot_liq_per" value="''"/>
					</qry:then>
				</qry:if>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="f_nacim" value="format_date($r/@f_nacim,'dd/mm/yyyy')"/>
				<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso,'dd/mm/yyyy')"/>
				<qry:attribute name="f_antiguedad_rec" value="format_date($r/@f_antiguedad_rec,'dd/mm/yyyy')"/>
				<qry:attribute name="c_cuil" value="$r/@c_nro_cuil"/>
				<qry:attribute name="d_funcion" value="$r/@d_funcion"/>
				<qry:attribute name="d_categoria" value="$r/@d_categoria"/>
				<qry:attribute name="d_convenio" value="$r/@d_convenio"/>
				<qry:attribute name="d_centro_costo" value="$r/@d_centro_costo"/>
				<qry:attribute name="d_obra_social" value="iif($r/@dc_obra_soc='',$r/@d_obra_social,$r/@dc_obra_soc)"/>
				<qry:attribute name="oi_tot_liq_per" value="@oi_tot_liq_per+','+$r/@oi_tot_liq_per"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_conceptos_PER" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
	LIQ96_CONCEPTOS.c_concepto,
	sum(LIQ20_CONC_LIQ_PER.n_valor) AS n_valor   
FROM         
	LIQ12_TIPOS_CONC,
	LIQ20_CONC_LIQ_PER,
	LIQ96_CONCEPTOS
JOIN
	LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo,
	LIQ12_TIPOS_CONC.c_tipo_concepto INNER LIQ96_CONCEPTOS.c_tipo_concepto
WHERE	
	LIQ20_CONC_LIQ_PER.oi_tot_liq_per in ({%=#SOURCE:@oi_tot_liq_per %})
	AND LIQ20_CONC_LIQ_PER.n_valor != 0
	{%? (#PARAMIN:@oi_tipo_concepto!='') 
		{% 
			AND LIQ12_TIPOS_CONC.oi_tipo_concepto={#PARAMIN:@oi_tipo_concepto} 
		%} 
		{% 
			AND LIQ12_TIPOS_CONC.l_nolistado = 0
		%} 
	%}
GROUP BY 	
  LIQ96_CONCEPTOS.c_concepto
  ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name-calc="'V_'+$r/@c_concepto" value="$r/@n_valor"/>
				<qry:if test="#PARAMIN:@mostrar = 'v'">
					<qry:then>
						<qry:attribute name="tot_pag" value="number(@tot_pag)+number($r/@n_valor)"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="tot_pag_V" value="number(@tot_pag_V)+number($r/@n_valor)"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_conceptos_PER2" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT     
	LIQ96_CONCEPTOS.c_concepto,
	sum(LIQ20_CONC_LIQ_PER.n_cantidad) AS n_valor
FROM         
	LIQ12_TIPOS_CONC,
	LIQ20_CONC_LIQ_PER,
	LIQ96_CONCEPTOS
JOIN
	LIQ20_CONC_LIQ_PER.oi_concepto_ddo INNER LIQ96_CONCEPTOS.oi_concepto_ddo,
	LIQ12_TIPOS_CONC.c_tipo_concepto INNER LIQ96_CONCEPTOS.c_tipo_concepto
WHERE	
	LIQ20_CONC_LIQ_PER.oi_tot_liq_per in ({%=#SOURCE:@oi_tot_liq_per %})
	AND LIQ20_CONC_LIQ_PER.n_valor != 0
	{%? (#PARAMIN:@oi_tipo_concepto!='') 
		{% 
			AND LIQ12_TIPOS_CONC.oi_tipo_concepto={#PARAMIN:@oi_tipo_concepto} 
		%} 
		{% 
			AND LIQ12_TIPOS_CONC.l_nolistado = 0
		%} 
	%}
GROUP BY 	
  LIQ96_CONCEPTOS.c_concepto
  ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name-calc="'C_'+$r/@c_concepto" value="$r/@n_valor"/>
				<qry:if test="#PARAMIN:@mostrar = 'c'">
					<qry:then>
						<qry:attribute name="tot_pag" value="number(@tot_pag)+number($r/@n_valor)"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="tot_pag_C" value="number(@tot_pag_C)+number($r/@n_valor)"/>
