<NOMAD-ENVELOP SRV="nucleusnet" PORT="1711" service="xquery" request="get-sql" user-token="Anonimo" xmlns:qry="xxx" >
	<qry:declare>	
<DATOS oi_empresa="1">
	<PERSONAS>
		<PERSONA id="1"/>
		<PERSONA id="2"/>         
		<PERSONA id="3"/>
		<PERSONA id="15"/>
		<PERSONA id="144"/>
	</PERSONAS>
</DATOS>
	</qry:declare>
	<qry:main doc="SOURCE">
		<qry:element name="DATOS">
			<qry:element name="EMPRESA">
				<qry:insert-select doc-path="#SOURCE:DATOS" name="QRY_PADRE"/>
				<qry:element name="PERSONAS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="QRY_PERSONAS"/>
				</qry:element>				
			</qry:element>
		</qry:element>
	</qry:main>
	<qry:select doc="SOURCE" name="QRY_PADRE">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT ORG03_EMPRESAS.OI_EMPRESA, ORG03_EMPRESAS.D_EMPRESA, 
			ORG03_EMPRESAS.C_EMPRESA, org03_empresas.oi_per_autorizado,
			ORG03_EMPRESAS.d_calle, ORG03_EMPRESAS.e_numero, ORG03_EMPRESAS.e_piso,
			ORG03_EMPRESAS.d_departamento, ORG03_EMPRESAS.oi_localidad,
			ORG03_EMPRESAS.c_cuit, ORG03_EMPRESAS.te_telefono,
			liq15_empresas.c_actividad, d_domic_radic
			FROM ORG03_EMPRESAS, liq15_empresas
			WHERE ORG03_EMPRESAS.OI_EMPRESA = {%= #SOURCE:@oi_empresa%}
			and liq15_empresas.OI_EMPRESA = ORG03_EMPRESAS.OI_EMPRESA 
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="OI_EMPRESA" value="$r/@OI_EMPRESA" type="Nomad.NSystem.Int"/>
			<qry:attribute name="D_EMPRESA" value="$r/@D_EMPRESA" type="Nomad.NSystem.String"/>
			<qry:attribute name="C_EMPRESA" value="$r/@C_EMPRESA" type="Nomad.NSystem.String"/>
			<qry:attribute name="d_calle" value="$r/@d_calle" type="Nomad.NSystem.String"/>
			<qry:attribute name="e_numero" value="$r/@e_numero" type="Nomad.NSystem.String"/>
			<qry:attribute name="e_piso" value="$r/@e_piso" type="Nomad.NSystem.String"/>
			<qry:attribute name="c_cuit" value="$r/@c_cuit" type="Nomad.NSystem.String"/>
			<qry:attribute name="te_telefono" value="$r/@te_telefono" type="Nomad.NSystem.String"/>
			<qry:attribute name="d_departamento" value="$r/@d_departamento" type="Nomad.NSystem.String"/>
			<qry:attribute name="c_actividad" value="$r/@c_actividad" type="Nomad.NSystem.String"/>
			<qry:attribute name="d_domic_radic" value="$r/@d_domic_radic" type="Nomad.NSystem.String"/>
		
			<qry:attribute name="oi_per_autorizado" value="$r/@oi_per_autorizado" type="Nomad.NSystem.Int"/>
			<qry:attribute name="oi_localidad" value="$r/@oi_localidad" type="Nomad.NSystem.Int"/>
			<qry:insert-select doc-path=".[@oi_per_autorizado > 0]" name="QRY_PERSONAL_AUTORIZADO"/>
			<qry:insert-select doc-path=".[@oi_localidad > 0]" name="QRY_LOCALIDAD"/>
		</qry:out>
	</qry:select>   
	<qry:select doc="SOURCE" name="QRY_LOCALIDAD">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT ORG19_LOCALIDADES.OI_LOCALIDAD, ORG19_LOCALIDADES.C_LOCALIDAD,
			ORG19_LOCALIDADES.D_LOCALIDAD, ORG19_LOCALIDADES.C_POSTAL, 
			ORG35_PROVINCIAS.C_PROVINCIA, ORG35_PROVINCIAS.D_PROVINCIA
			
			from ORG19_LOCALIDADES, ORG35_PROVINCIAS
			
			WHERE ORG19_LOCALIDADES.oi_localidad = {%= #SOURCE:@oi_localidad%}
			and ORG19_LOCALIDADES.OI_PROVINCIA = ORG35_PROVINCIAS.OI_PROVINCIA
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="OI_LOCALIDAD" value="$r/@OI_LOCALIDAD" type="Nomad.NSystem.Int"/>
			<qry:attribute name="C_LOCALIDAD" value="$r/@C_LOCALIDAD" type="Nomad.NSystem.Int"/>
			<qry:attribute name="D_LOCALIDAD" value="$r/@D_LOCALIDAD" type="Nomad.NSystem.Int"/>
			<qry:attribute name="C_POSTAL" value="$r/@C_POSTAL" type="Nomad.NSystem.Int"/>
			<qry:attribute name="C_PROVINCIA" value="$r/@C_PROVINCIA" type="Nomad.NSystem.Int"/>
			<qry:attribute name="d_PROVINCIA" value="$r/@d_PROVINCIA" type="Nomad.NSystem.Int"/>
		</qry:out>
	</qry:select>	
	<qry:select doc="SOURCE" name="QRY_PERSONAL_AUTORIZADO">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT d_ape_y_nom
			from per02_personal_emp, per01_personal
			WHERE per02_personal_emp.Oi_personal_emp = {%= #SOURCE:@oi_per_autorizado%}
			and per01_personal.oi_personal = per02_personal_emp.oi_personal
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.Int"/>
		</qry:out>
	</qry:select>   
	
	<qry:select doc="SOURCE" name="QRY_PERSONAS">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT d_ape_y_nom, per01_personal.oi_personal, per01_personal.c_dni,
			per02_personal_emp.f_fin_contrato,per02_personal_emp.OI_PERSONAL_EMP,
			EXTINCION = (case ISNULL(per02_personal_emp.f_fin_contrato,1)
			WHEN 1 THEN \'NO\'
			ELSE \'SI\'
			END),                                               
			datediff (yy,f_ingreso, f_egreso) dif_ing_finC
			from per02_personal_emp, per01_personal
			WHERE per01_personal.oi_personal = per02_personal_emp.oi_personal
			and per02_personal_emp.OI_EMPRESA= {%= #SOURCE:@oi_empresa%}
			{%? (string(#SOURCE:PERSONAS/PERSONA/@id)!=&apos;&apos;) {% AND per02_personal_emp.oi_personal_emp in ({%=string(#SOURCE:PERSONAS/PERSONA/@id) %}) %} {%  %} %}			
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>      
			<qry:element name="PERSONA">
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.Int"/>
				<qry:attribute name="oi_personal" value="$r/@oi_personal" type="Nomad.NSystem.Int"/>
				<qry:attribute name="OI_PERSONAL_EMP" value="$r/@OI_PERSONAL_EMP" type="Nomad.NSystem.Int"/>
				<qry:attribute name="c_dni" value="$r/@c_dni" type="Nomad.NSystem.String"/>
				<qry:attribute name="f_fin_contrato" value="$r/@f_fin_contrato" type="Nomad.NSystem.Date"/>
				<qry:attribute name="EXTINCION" value="$r/@EXTINCION" type="Nomad.NSystem.Date"/>
				<qry:attribute name="dif_ing_finC" value="$r/@dif_ing_finC" type="Nomad.NSystem.Date"/>
				<qry:insert-select doc-path="." name="QRY_CI"/>
				<qry:attribute name="TotalAnios" value="'0'" type="Nomad.NSystem.Date"/>
				<qry:element name="REMUNERACIONES">
					<qry:insert-select doc-path=".." name="QRY_REMUNERACIONES"/>
					
				</qry:element>		
			</qry:element>	
		</qry:out>
	</qry:select>

	<qry:select doc="SOURCE" name="QRY_REMUNERACIONES">
		<qry:xquery>
			for $r in table(&apos;
				select SUMA= (sum(n_totsret - n_totsac)), year(f_liquidacion) ANIO, month(f_liquidacion) MES
				from liq20_tot_liq_per, liq19_liquidacion
				, liq25_personal_liq
				where liq25_personal_liq.oi_personal_emp = {#SOURCE:@OI_PERSONAL_EMP}
				and liq20_tot_liq_per.oi_tot_liq_per = liq25_personal_liq.oi_tot_liq_pers
				and liq25_personal_liq.oi_liquidacion = liq19_liquidacion.oi_liquidacion
				group by year(f_liquidacion), month(f_liquidacion)			
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>      
			<qry:element name="REMUNERACION">
				<qry:attribute name="SUMA" value="$r/@SUMA" type="Nomad.NSystem.Int"/>
				<qry:attribute name="OI_PERSONAL_EMP" value="#SOURCE:@OI_PERSONAL_EMP" type="Nomad.NSystem.Int"/>
				<qry:attribute name="ANIO" value="$r/@ANIO" type="Nomad.NSystem.Int"/>
				<qry:attribute name="MES" value="fill_left($r/@MES,'0',2)" type="Nomad.NSystem.Int"/>
				<qry:insert-select doc-path="." name="QRY_CATEGORIA"/>
				<qry:element name="LICENCIAS">
					<qry:insert-select doc-path=".." name="QRY_LICENCIAS"/>
				</qry:element>                                
				<qry:element name="LICENCIAS_AUS">
					<qry:insert-select doc-path=".." name="QRY_LICENCIAS_AUS"/>
				</qry:element>				
			</qry:element>
		</qry:out>
	</qry:select>	
	<qry:select doc="SOURCE" name="QRY_CATEGORIA">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT D_CATEGORIA
FROM PER02_CATEG_PER, ORG18_CATEGORIAS
WHERE PER02_CATEG_PER.OI_PERSONAL_EMP = {%= #SOURCE:@OI_PERSONAL_emp%}
AND PER02_CATEG_PER.OI_CATEGORIA = ORG18_CATEGORIAS.OI_CATEGORIA
AND PER02_CATEG_PER.F_INGRESO &lt;= \' {%= #SOURCE:@anio %}{%= #SOURCE:@MES %}01\'
AND 
(
PER02_CATEG_PER.F_EGRESO IS NULL OR
PER02_CATEG_PER.F_EGRESO &gt; DATEADD(M,1,\'{%= #SOURCE:@anio %}{%= #SOURCE:@mes %}01\')
)
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="D_CATEGORIA" value="$r/@D_CATEGORIA" type="Nomad.NSystem.Int"/>
			
		</qry:out>
	</qry:select>		
	<qry:select doc="SOURCE" name="QRY_CI">
		<qry:xquery>
			for $r in table(&apos;                         
			SELECT C_DOCUMENTO, d_resp_expedicion
			from PER01_DOCUM_PER, PER20_TIPOS_DOC
			WHERE per01_DOCUM_PER.oi_personal = {%= #SOURCE:@OI_PERSONAL%}
			and PER01_DOCUM_PER.OI_TIPO_DOCUMENTO = PER20_TIPOS_DOC.OI_TIPO_DOCUMENTO
			AND PER20_TIPOS_DOC.c_tipo_documento = \'CI\'
			
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="C_DOCUMENTO" value="$r/@C_DOCUMENTO" type="Nomad.NSystem.Int"/>
			<qry:attribute name="d_resp_expedicion" value="$r/@d_resp_expedicion" type="Nomad.NSystem.Int"/>
		</qry:out>
	</qry:select>	    
	<qry:select doc="SOURCE" name="QRY_LICENCIAS">
		<qry:xquery>
			for $r in table(&apos;                         
select PER02_LICEN_PER.oi_licencia,  
PER02_LICEN_PER.f_inicio, PER02_LICEN_PER.f_fin
, PER02_LICEN_PER.e_cant_dias, per16_licencias.c_licencia
, per16_licencias.d_licencia              
from PER02_LICEN_PER, per16_licencias
where PER02_LICEN_PER.f_fin &gt;=  \' {%= #SOURCE:@anio %}{%= #SOURCE:@MES %}01\'
and PER02_LICEN_PER.f_inicio &lt;= DATEADD(M,1,\' {%=#SOURCE:@anio %}{%= #SOURCE:@mes %}01\')
and PER02_LICEN_PER.oi_personal_emp = {%= #SOURCE:@OI_PERSONAL_emp%}
and per16_licencias.oi_licencia = per02_licen_per.oi_licencia
and l_ausentismo = 0			
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>       
		<qry:element name="LICENCIA">
			<qry:attribute name="oi_licencia" value="$r/@oi_licencia" type="Nomad.NSystem.Int"/>
			<qry:attribute name="f_inicio" value="$r/@f_inicio" type="Nomad.NSystem.Int"/>
			<qry:attribute name="f_fin" value="$r/@f_fin" type="Nomad.NSystem.Int"/>
			<qry:attribute name="e_cant_dias" value="$r/@e_cant_dias" type="Nomad.NSystem.Int"/>
			<qry:attribute name="c_licencia" value="$r/@c_licencia" type="Nomad.NSystem.Int"/>
			<qry:attribute name="d_licencia" value="$r/@d_licencia" type="Nomad.NSystem.Int"/>
		</qry:element>
		</qry:out>
	</qry:select>	      
	<qry:select doc="SOURCE" name="QRY_LICENCIAS_AUS">
		<qry:xquery>
			for $r in table(&apos;                         
select PER02_LICEN_PER.oi_licencia,  
PER02_LICEN_PER.f_inicio, PER02_LICEN_PER.f_fin
, PER02_LICEN_PER.e_cant_dias, per16_licencias.c_licencia
, per16_licencias.d_licencia              
from PER02_LICEN_PER, per16_licencias
where PER02_LICEN_PER.f_fin &gt;=  \' {%= #SOURCE:@anio %}{%= #SOURCE:@MES %}01\'
and PER02_LICEN_PER.f_inicio &lt;= DATEADD(M,1,\' {%=#SOURCE:@anio %}{%= #SOURCE:@mes %}01\')
and PER02_LICEN_PER.oi_personal_emp = {%= #SOURCE:@OI_PERSONAL_emp%}
and per16_licencias.oi_licencia = per02_licen_per.oi_licencia
and l_ausentismo = 1			
			&apos;)/ROWS/ROW
		</qry:xquery>
		<qry:out>       
		<qry:element name="LICENCIA_AUS">
			<qry:attribute name="oi_licencia" value="$r/@oi_licencia" type="Nomad.NSystem.Int"/>
			<qry:attribute name="f_inicio" value="$r/@f_inicio" type="Nomad.NSystem.Int"/>
			<qry:attribute name="f_fin" value="$r/@f_fin" type="Nomad.NSystem.Int"/>
			<qry:attribute name="e_cant_dias" value="$r/@e_cant_dias" type="Nomad.NSystem.Int"/>
			<qry:attribute name="c_licencia" value="$r/@c_licencia" type="Nomad.NSystem.Int"/>
			<qry:attribute name="d_licencia" value="$r/@d_licencia" type="Nomad.NSystem.Int"/>
		</qry:element>
		</qry:out>
	</qry:select>		
</NOMAD-ENVELOP>	



