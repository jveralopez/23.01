<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Liquidacion.OtrosEmpleadoresIG" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;FILTRO gcustom=&quot;&quot; e_periodo_desde=&quot;201901&quot; e_periodo_hasta=&quot;202001&quot; c_interfaz=&quot;0&quot; gpers=&quot;&quot; empresa=&quot;2&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS nmd-col=&quot;1&quot;&gt;&lt;ROW VALUES=&quot;1,2&quot;/&gt;&lt;/PERSONAS&gt;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="PARAMIN" doc-path="#PARAM:FILTRO"/>
			<REPORT label="Imp. a las Ganancias - Otros empleadores del legajo">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="EMP" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
							<COL name="periodo_desde" label="Per&#237;odo desde"/>
							<COL name="periodo_hasta" label="Per&#237;odo hasta"/>
							<COL name="interfaz" label="S&#243;lo cargado por interfaz Siradig"/>
						</COLS>
						<GROUP tag="PER" type="table">
							<COLS>
								<COL name="e_numero_legajo" label="Legajo" nowrap="1"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" nowrap="1"/>
								<COL name="c_cuit" label="Cuit" nowrap="1"/>
								<COL name="d_denominacion" label="Denominaci&#243;n" nowrap="1"/>
								<COL name="e_periodo_ag" label="Per&#237;odo Agente de Retenci&#243;n" nowrap="1"/>
								<COL name="l_agente" label="Es Agente de Retenci&#243;n?" nowrap="1"/>
								<COL name="e_periodo" label="Per&#237;odo" nowrap="1"/>
								<COL name="n_ganbruta" label="Ganancia Bruta" nowrap="1" type="num"/>
								<COL name="n_obrasocial" label="Obra Social" nowrap="1" type="num"/>
								<COL name="n_segsocial" label="Seg. Social" nowrap="1" type="num"/>
								<COL name="n_sindicato" label="Sindicato" nowrap="1" type="num"/>
								<COL name="n_retganancias" label="Ret. IG Practicadas" nowrap="1" type="num"/>
								<COL name="n_retribnohab" label="Ret. No Habit." nowrap="1" type="num"/>
								<COL name="n_ajuste" label="Ajuste" nowrap="1" type="num"/>
								<COL name="n_exenoalc" label="Conceptos Exentos" nowrap="1" type="num"/>
								<COL name="n_sac" label="Sueldo Anual Complementario" nowrap="1" type="num"/>
								<COL name="n_horasextgr" label="Horas Extras Gravadas" nowrap="1" type="num"/>
								<COL name="n_horasextex" label="Horas Extras Exentas" nowrap="1" type="num"/>
								<COL name="n_matdid" label="Material Did&#225;ctico" nowrap="1" type="num"/>
								<COL name="n_movilidad" label="Movilidad" nowrap="1" type="num"/>
								<COL name="n_viaticos" label="Vi&#225;ticos" nowrap="1" type="num"/>
								<COL name="n_otrosConAn" label="Otros Conceptos An&#225;logos" nowrap="1" type="num"/>
								<COL name="n_bonosProd" label="Bonos de Productividad" nowrap="1" type="num"/>
								<COL name="n_fallosCaja" label="Fallos de Caja" nowrap="1" type="num"/>
								<COL name="n_conSimNat" label="Conceptos de Similiar Naturaleza" nowrap="1" type="num"/>
								<COL name="n_remunExLey27549" label="Remuneraci&#243;n Exenta Ley 27.549" nowrap="1" type="num"/>
								<COL name="n_supPartLey19101" label="Suplementos Part. Art. 57 Ley 19.101" nowrap="1" type="num"/>
								<COL name="n_teletrabExento" label="Compensaci&#243;n Gastos Teletrabajo Exentos" nowrap="1" type="num"/>
								<COL name="n_SegSocANSES" label="Apo. p/fondos de Jub., Ret., Pen. o Subs. - ANSES" nowrap="1" type="num"/>
								<COL name="n_segSocCajas" label="Apo. p/fondos de Jub., Ret., Pen. o Subs. - Cajas Prev. Prov., Mun. o p/Prof." nowrap="1" type="num"/>
								<COL name="n_ajRemGravadas" label="Aj. de Per. Ant. por Remu. Gravadas" nowrap="1" type="num"/>
								<COL name="n_ajRemExeNoAlc" label="Aj. de Per. Ant. por Remu. Exen. o No Alcanzadas" nowrap="1" type="num"/>
								<COL name="n_asignFam" label="Asignaciones Familiares" nowrap="1" type="num"/>
								<COL name="n_intPrestEmp" label="Int. por Pr#amos al Empleador" nowrap="1" type="num"/>
								<COL name="n_indemLey4003" label="Indem. establecidas en incisos c) d) y e) del apartado 'A' Anexo II de la RG4003/2017" nowrap="1" type="num"/>
								<COL name="n_remunLey19640" label="Remu. bajo el Art. 1 de la Ley 19.640 'Territorio Nacional Tierra del Fuego'" nowrap="1" type="num"/>
								<COL name="n_remunCctPetro" label="Remuneraciones bajo el CCT 396/2204" nowrap="1" type="num"/>
								<COL name="n_cursosSemin" label="Cur. y Semi. - Inc. o) del apartado 'A' Anexo II de la RG 4003/20217" nowrap="1" type="num"/>
								<COL name="n_indumEquipEmp" label="Ind. y Equi. provistos por el Empleador" nowrap="1" type="num"/>
								<COL name="n_remunJudiciales" label="Remuneraciones Judiciales" nowrap="1" type="num"/>								
								<COL name="l_interfaz" label="Cargado Por Interfaz" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="EMP">
						<qry:attribute name="periodo_desde" value="format_date(#PARAM:FILTRO/@e_periodo_desde + '01', 'mm/yyyy')"/>
						<qry:attribute name="periodo_hasta" value="format_date(#PARAM:FILTRO/@e_periodo_hasta + '01', 'mm/yyyy')"/>
						<qry:attribute name="interfaz" value="iif(#PARAM:FILTRO/@c_interfaz='1','SI', 'NO')"/>
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_EMPRESAS"/>
						<qry:insert-select doc-path="#PARAM:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_EMPRESAS">
			<qry:xquery>
				for $r in sql('	
SELECT
	ORG03_EMPRESAS.oi_empresa,
	ORG03_EMPRESAS.c_empresa,
	ORG03_EMPRESAS.d_empresa
FROM
	ORG03_EMPRESAS					 
WHERE 
	ORG03_EMPRESAS.oi_empresa = {#PARAM:@empresa}  
			
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="empresa" value="$r/@c_empresa + ' - ' +$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute name="oi_empresa" value="#PARAMIN:@empresa"/>
						<qry:attribute name="periodo_des" value="#PARAMIN:@e_periodo_desde"/>
						<qry:attribute name="periodo_has" value="#PARAMIN:@e_periodo_hasta"/>
						<qry:attribute name="c_interfaz" value="#PARAMIN:@c_interfaz"/>
						<qry:attribute value="#PARAM:@values" name="values"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO values=&quot;1,2&quot; c_interfaz=&quot;1&quot; periodo_has=&quot;202001&quot; periodo_des=&quot;201901&quot; oi_empresa=&quot;2&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_OTROS_EMPLEADORES"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="QRY_OTROS_EMPLEADORES" doc="PARAM">
			<qry:xquery>
				for $r in sql('
SELECT
LEG.e_numero_legajo, 
PER.d_ape_y_nom, 
OE.c_cuit,                         
OE.d_denominacion, 
OE.e_periodo as e_periodo_ag,
OE.l_agente,
LM.e_periodo,   
LM.n_ganbruta,                              
LM.n_obrasocial,                            
LM.n_segsocial,                             
LM.n_sindicato,                             
LM.n_retganancias,                          
LM.n_retribnohab,                           
LM.n_ajuste, 
LM.n_exenoalc,
LM.n_sac,
LM.n_horasextgr,
LM.n_horasextex,
LM.n_matdid,                              
LM.n_movilidad,                              
LM.n_viaticos,                              
LM.n_otrosConAn,                              
LM.n_bonosProd,                              
LM.n_fallosCaja,                              
LM.n_conSimNat,                              
LM.n_remunExLey27549,                              
LM.n_supPartLey19101,                              
LM.n_teletrabExento,                              
LM.n_SegSocANSES,      
LM.n_segSocCajas,      
LM.n_ajRemGravadas,      
LM.n_ajRemExeNoAlc,      
LM.n_asignFam,      
LM.n_intPrestEmp,      
LM.n_indemLey4003,      
LM.n_remunLey19640,      
LM.n_remunCctPetro,      
LM.n_cursosSemin,      
LM.n_indumEquipEmp,  
LM.n_remunJudiciales,  
LM.l_interfaz
FROM
PER02_PERSONAL_EMP AS LEG,
PER01_PERSONAL AS PER,
LIQ07_OTROS_EMP AS OE,
LIQ07_ING_MENSUAL AS LM

JOIN
LEG.oi_personal INNER PER.oi_personal,
LEG.oi_personal_emp INNER OE.oi_personal_emp,
OE.oi_otros_emp INNER LM.oi_otros_emp

WHERE
LEG.oi_empresa = {#PARAM:@oi_empresa}
and LEG.oi_personal_emp in ({%=#PARAM:@values%})
AND LM.e_periodo &gt;= {#PARAM:@periodo_des} 
AND LM.e_periodo &lt;= {#PARAM:@periodo_has} 

ORDER BY 
e_numero_legajo ASC

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PER">
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="c_cuit" value="$r/@c_cuit"/>
					<qry:attribute name="d_denominacion" value="$r/@d_denominacion"/>
					<qry:attribute name="e_periodo" value="format_date($r/@e_periodo + '01', 'mm/yyyy')"/>
					<qry:attribute name="n_ganbruta" value="$r/@n_ganbruta"/>
					<qry:attribute name="n_obrasocial" value="$r/@n_obrasocial"/>
					<qry:attribute name="n_segsocial" value="$r/@n_segsocial"/>
					<qry:attribute name="n_sindicato" value="$r/@n_sindicato"/>
					<qry:attribute name="n_retganancias" value="$r/@n_retganancias"/>
					<qry:attribute name="n_retribnohab" value="$r/@n_retribnohab"/>
					<qry:attribute name="n_ajuste" value="$r/@n_ajuste"/>
					<qry:attribute name="n_exenoalc" value="$r/@n_exenoalc"/>
					<qry:attribute name="n_sac" value="$r/@n_sac"/>
					<qry:attribute name="n_horasextgr" value="$r/@n_horasextgr"/>
					<qry:attribute name="n_horasextex" value="$r/@n_horasextex"/>
					<qry:attribute name="n_matdid" value="$r/@n_matdid"/>
					<qry:attribute name="n_movilidad" value="$r/@n_movilidad"/>
					<qry:attribute name="n_viaticos" value="$r/@n_viaticos"/>
					<qry:attribute name="n_otrosConAn" value="$r/@n_otrosConAn"/>
					<qry:attribute name="n_bonosProd" value="$r/@n_bonosProd"/>
					<qry:attribute name="n_fallosCaja" value="$r/@n_fallosCaja"/>
					<qry:attribute name="n_conSimNat" value="$r/@n_conSimNat"/>
					<qry:attribute name="n_remunExLey27549" value="$r/@n_remunExLey27549"/>
					<qry:attribute name="n_supPartLey19101" value="$r/@n_supPartLey19101"/>
					<qry:attribute name="n_teletrabExento" value="$r/@n_teletrabExento"/>
					<qry:attribute name="n_SegSocANSES" value="$r/@n_SegSocANSES"/>
					<qry:attribute name="n_segSocCajas" value="$r/@n_segSocCajas"/>
					<qry:attribute name="n_ajRemGravadas" value="$r/@n_ajRemGravadas"/>
					<qry:attribute name="n_ajRemExeNoAlc" value="$r/@n_ajRemExeNoAlc"/>
					<qry:attribute name="n_asignFam" value="$r/@n_asignFam"/>
					<qry:attribute name="n_intPrestEmp" value="$r/@n_intPrestEmp"/>
					<qry:attribute name="n_indemLey4003" value="$r/@n_indemLey4003"/>
					<qry:attribute name="n_remunLey19640" value="$r/@n_remunLey19640"/>
					<qry:attribute name="n_remunCctPetro" value="$r/@n_remunCctPetro"/>
					<qry:attribute name="n_cursosSemin" value="$r/@n_cursosSemin"/>
					<qry:attribute name="n_indumEquipEmp" value="$r/@n_indumEquipEmp"/>
					<qry:attribute name="n_remunJudiciales" value="$r/@n_remunJudiciales"/>					
					<qry:attribute name="l_agente" value="iif($r/@l_agente = '1','Si','No')"/>
					<qry:attribute name="e_periodo_ag" value="$r/@e_periodo_ag"/>
					<qry:attribute name="l_interfaz" value="iif($r/@l_interfaz ='1', 'SI', 'NO')"/>
					<qry:if test="#PARAM:@c_interfaz='1'">
						<qry:then>
							<qry:attribute name="hts:delete" value="iif(./@l_interfaz='SI','0', '1')"/>
						</qry:then>
						<qry:else/>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
