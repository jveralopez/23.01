		<qry:select name="QRY_PERSONA" doc="SOURCE">
			<qry:xquery>
				for $r in sql(' 
SELECT 
	LIQ19_EJECUCIONES.oi_ejecucion,
	LIQ20_VAR_LIQ_CONC.c_variable, 
	LIQ20_VAR_LIQ_CONC.n_valor_s
FROM 
	LIQ20_TOT_LIQ_PER
	, LIQ20_CONC_LIQ_PER
	, LIQ96_CONCEPTOS
	, LIQ99_LIQUIDACION
	, LIQ20_VAR_LIQ_CONC
	, LIQ19_EJECUCIONES
	, LIQ19_LIQUIDACION
	, LIQ99_RECIBOS
JOIN
	LIQ20_TOT_LIQ_PER.oi_tot_liq_per INNER LIQ20_CONC_LIQ_PER.oi_tot_liq_per 
	, LIQ96_CONCEPTOS.oi_concepto_ddo INNER LIQ20_CONC_LIQ_PER.oi_concepto_ddo 	
	, LIQ99_LIQUIDACION.oi_cab_conc_ddo INNER LIQ96_CONCEPTOS.oi_cab_conc_ddo 
	, LIQ20_VAR_LIQ_CONC.oi_conc_liq_per INNER LIQ20_CONC_LIQ_PER.oi_conc_liq_per	
	, LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ19_EJECUCIONES.oi_liquidacion_ddo 
	, LIQ19_LIQUIDACION.oi_liquidacion INNER LIQ19_EJECUCIONES.oi_liquidacion 
	, LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo 
	, LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per 
where
	LIQ99_RECIBOS.e_numero_legajo = {#SOURCE:../../@e_numero_legajo}		
	AND LIQ20_VAR_LIQ_CONC.c_variable = {#SOURCE:@c_variable}
	AND LIQ99_LIQUIDACION.c_estado = \'F\'
	AND LIQ96_CONCEPTOS.c_concepto = \'99999998\'
	AND GETYEAR(LIQ99_LIQUIDACION.f_pago)*100+GETMONTH(LIQ99_LIQUIDACION.f_pago) = {#SOURCE:@e_periodo}
	AND LIQ99_LIQUIDACION.c_tipo_liq in (\'1\', \'2\', \'3\', \'5\')
	AND LIQ19_LIQUIDACION.oi_empresa = {#SOURCE:../../@oi_empresa}
ORDER BY oi_ejecucion desc
')/ROWS/ROW[0]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="valor" value="$r/@n_valor_s"/>
			</qry:out>
		</qry:select>
