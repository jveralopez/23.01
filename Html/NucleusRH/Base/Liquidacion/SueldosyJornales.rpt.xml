SELECT 0 as priQuin,0 as segQuin, 0 as mensual, 0 as sac, 0 as egresos, 0 as vac, SUM(C1111.n_valor) as otros, a3.c_concepto, a3.c_tipo_concepto, d3.d_tipo_concepto
FROM LIQ20_CONC_LIQ_PER AS C1111, liq96_conceptos as a3, LIQ12_TIPOS_CONC as d3
JOIN 
