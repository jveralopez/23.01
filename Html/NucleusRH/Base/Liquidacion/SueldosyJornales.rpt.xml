	<xsl:template match="REPORT">
		<table class="tabla" border="1" width="100%">
			<tr style="background-color:#FFFFFF; font-size:17px; text-align:center;">
				<td colspan="9">
					<xsl:value-of select="@label"/>
				</td>
			</tr>
			<tr style="font-size:12px">
				<td colspan="9" align="right">
					<b>
						<xsl:text>
							Fecha de Emisi&#243;n:&#160;
						</xsl:text>
					</b>
					<xsl:value-of select="@f_emision"/>
				</td>
			</tr>
			<tr style="font-size:12px">
				<td colspan="9" align="left">
					<b>
						<xsl:text>
							Empresa:&#160;
						</xsl:text>
					</b>
					<xsl:value-of select="@empresa"/>
				</td>
			</tr>
			<tr style="font-size:12px">
				<td colspan="9" align="left">
					<b>
						<xsl:text>
							Periodo:&#160;
						</xsl:text>
					</b>
					<xsl:value-of select="@e_periodo"/>
				</td>
			</tr>
			<tr style="font-size:12px">
				<td colspan="9" align="left">
					<b>
						<xsl:text>
							Criterio de Orden:&#160;
						</xsl:text>
					</b>
					<xsl:choose>
						<xsl:when test="@e_orden = 'COrden'">
							Clase de Concepto
						</xsl:when>
						<xsl:when test="@e_orden = 'TOrden'">
							Tipo de Concepto
						</xsl:when>
						<xsl:when test="@e_orden = 'C_CONCEPTO'">
							C&#243;digo de Concepto
						</xsl:when>
						<xsl:when test="@e_orden = 'D_CONCEPTO'">
							Descripci&#243;n de Concepto
						</xsl:when>
					</xsl:choose>
				</td>
			</tr>
			<xsl:apply-templates select="LIQUIDACIONES"/>
			<xsl:for-each select="TIPOS/TIPO">
				<xsl:if test="CONCEPTOS/CONCEPTO">
					<tr style="background-color:#BBBBBB; font-size:13px;  font-weight:bold">
						<td colspan="9" align="left">
							<xsl:text>
								&#160;&#160;&#160;
							</xsl:text>
							<xsl:value-of select="@TIPO"/>
						</td>
					</tr>
					<tr style="background-color:#BBBBBB; font-size:11px;">
						<th NOWRAP="1">
							Concepto
						</th>
						<th NOWRAP="1">
							1&#186;Quincena
						</th>
						<th NOWRAP="1">
							2&#186;Quincena
						</th>
						<th NOWRAP="1">
							Mensual
						</th>
						<th NOWRAP="1">
							SAC
						</th>
						<th NOWRAP="1">
							Egreso
						</th>
						<th NOWRAP="1">
							Vacaciones
						</th>
						<th NOWRAP="1">
							Otros
						</th>
						<th NOWRAP="1">
							Total
						</th>
					</tr>
					<xsl:for-each select="CONCEPTOS/CONCEPTO">
						<xsl:if test="not(@priQuin=0 and @segQuin=0 and @mensual=0 and @sac=0 and @egresos=0 and @vac=0  and @otros=0)">
							<tr>
								<td NOWRAP="1" align="left">
									<xsl:value-of select="@CONCEPTO"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@priQuin"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@priQuin, '###,###,##0.00')"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@segQuin"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@segQuin, '###,###,##0.00')"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@mensual"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@mensual, '###,###,##0.00')"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@sac"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@sac, '###,###,##0.00')"/>
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@egresos"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@egresos, '###,###,##0.00')"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@vac"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@vac, '###,###,##0.00')"/>
									&#160;
								</td>
								<td style="mso-number-format:0\.000" NOWRAP="1" align="right">
									<xsl:attribute name="x:num" namespace="urn:schemas-microsoft-com:office:excel">
										<xsl:value-of select="@otros"/>
									</xsl:attribute>
									<xsl:value-of select="format-number(@otros, '###,###,##0.00')"/>
