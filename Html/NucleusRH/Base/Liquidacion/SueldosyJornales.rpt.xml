FROM LIQ20_CONC_LIQ_PER AS C11, liq96_conceptos as a1, LIQ12_TIPOS_CONC as d1
JOIN d1.c_tipo_concepto INNER a1.c_tipo_concepto,
a1.oi_concepto_ddo INNER C11.oi_concepto_ddo 
WHERE
a1.c_tipo_concepto != \'6\' AND
