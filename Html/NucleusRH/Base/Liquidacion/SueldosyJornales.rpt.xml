<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Liquidacion.ReportesGenericos">
	<html:query declare="&lt;DATOS c_empresa=&quot;000125&quot; orden=&quot;C_CONCEPTO&quot; e_periodo=&quot;200909&quot; modo=&quot;HTML&quot; l_simulacion=&quot;0&quot;/&gt;&#13;&#10;&#13;&#10;&#9;">
		<qry:main doc="SOURCE">
			<REPORT label="Sueldos y Jornales">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="EMP" type="title" style="padding-left:0px;">
						<COLS>
							<COL name="d_empresa" label="Empresa"/>
							<COL name="e_periodo" label="Periodo"/>
							<COL name="e_orden" label="Criterio de Orden">
								<OPT id="C_CONCEPTO" value="C&#243;digo"/>
								<OPT id="D_CONCEPTO" value="Descripci&#243;n"/>
								<OPT id="TOrden" value="Tipo de Concepto"/>
								<OPT id="COrden" value="Clase de Concepto"/>
							</COL>
						</COLS>
						<GROUP tag="LIQ" type="table" style="padding-left:0px;" noreg="No se encontraron registros para los filtros seleccionados.">
							<COLS>
								<COL name="d_liquidacion" label="Liquidaci&#243;n"/>
								<COL name="f_liquidacion" label="Fecha" type="date"/>
								<COL name="c_clase" label="Clase"/>
								<COL name="totPag" label="Total a Pagar" type="num"/>
							</COLS>
						</GROUP>
						<GROUP tag="TCONC" style="padding-left:0px;" type="title_collapse">
							<COLS>
								<COL name="tipo" label="Tipo de Concepto"/>
							</COLS>
							<GROUP tag="CONC" type="table">
								<COLS>
									<COL name="CONCEPTO" label="Concepto" style="width:34%"/>
									<COL name="priQuin" label="1&#186; Quincena" type="num" style="width:8%"/>
									<COL name="segQuin" label="2&#186; Quincena" type="num" style="width:8%"/>
									<COL name="mensual" label="Mensual" type="num" style="width:8%"/>
									<COL name="sac" label="S.A.C." type="num" style="width:8%"/>
									<COL name="egresos" label="Egresos" type="num" style="width:8%"/>
									<COL name="vac" label="Vacaciones" type="num" style="width:8%"/>
									<COL name="otros" label="Otros" type="num" style="width:8%"/>
									<COL name="TOTAL" label="Total" type="num" style="width:10%"/>
								</COLS>
								<FCOLS>
									<COL name="CONCEPTO" label="Concepto"/>
									<COL name="priQuin" label="1&#186; Quincena" type="num" style="text-align:right;"/>
									<COL name="segQuin" label="2&#186; Quincena" type="num" style="text-align:right;"/>
									<COL name="mensual" label="Mensual" type="num" style="text-align:right;"/>
									<COL name="sac" label="S.A.C." type="num" style="text-align:right;"/>
									<COL name="egresos" label="Egresos" type="num" style="text-align:right;"/>
									<COL name="vac" label="Vacaciones" type="num" style="text-align:right;"/>
									<COL name="otros" label="Otros" type="num" style="text-align:right;"/>
									<COL name="TOTAL" label="Total" type="num" style="text-align:right;"/>
								</FCOLS>
							</GROUP>
						</GROUP>
						<GROUP tag="TGCONC" style="padding-left:20px;" type="table">
							<COLS>
								<COL name="CONCEPTO" label="Concepto" style="width:34%"/>
								<COL name="priQuin" label="1&#186; Quincena" type="num" style="width:8%"/>
								<COL name="segQuin" label="2&#186; Quincena" type="num" style="width:8%"/>
								<COL name="mensual" label="Mensual" type="num" style="width:8%"/>
								<COL name="sac" label="S.A.C." type="num" style="width:8%"/>
								<COL name="egresos" label="Egresos" type="num" style="width:8%"/>
								<COL name="vac" label="Vacaciones" type="num" style="width:8%"/>
								<COL name="otros" label="Otros" type="num" style="width:8%"/>
								<COL name="TOTAL" label="Total" type="num" style="width:10%"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:append-doc doc-path="#SOURCE:DATOS" name="DOCUM"/>
				<qry:element name="ROWS">
					<qry:insert-select name="priQuin"/>
					<qry:insert-select name="segQuin"/>
					<qry:insert-select name="mensual"/>
					<qry:insert-select name="sac"/>
					<qry:insert-select name="egresos"/>
					<qry:insert-select name="vac"/>
					<qry:insert-select name="otros"/>
				</qry:element>
				<qry:append-doc doc-path="." name="POSTA"/>
				<DATA>
					<EMP>
						<qry:insert-select name="EMPRESAS" doc-path="#SOURCE:DATOS"/>
						<qry:attribute name="e_orden" value="#SOURCE:DATOS/@orden"/>
						<qry:attribute name="e_periodo" value="#SOURCE:DATOS/@e_periodo"/>
						<qry:attribute name="hayLiq" value="'0'"/>
						<qry:insert-select name="LIQUIDACIONES"/>
						<qry:insert-select name="TIPOS" doc-path=".[@hayLiq='1']"/>
						<qry:element name="TGCONC">
							<qry:attribute name="tipo" value="'Totales Generales'"/>
							<qry:attribute name="hts:delete" value="1"/>
							<qry:insert-select name="SUPER_TOTALES" doc-path=".."/>
						</qry:element>
						<qry:attribute name="e_periodo" value="format_date(#SOURCE:DATOS/@e_periodo + '01', 'mm/yyyy')"/>
					</EMP>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="priQuin">
			<qry:xquery>
				for $r in sql('
SELECT 
	SUM(C1.n_valor) as priQuin, 0 as segQuin, 0 as mensual, 0 as sac, 0 as egresos, 0 as vac, 0 as otros, a.c_concepto, a.c_tipo_concepto, d.d_tipo_concepto
FROM 
	LIQ20_CONC_LIQ_PER AS C1, liq96_conceptos as a, LIQ12_TIPOS_CONC as d
JOIN 	
	d.c_tipo_concepto INNER a.c_tipo_concepto,
	a.oi_concepto_ddo INNER c1.oi_concepto_ddo 
WHERE
	a.c_tipo_concepto != \'6\' AND
	C1.n_valor != 0 AND
	C1.oi_tot_liq_per in (
		select 
			ll.oi_tot_liq_per 
		FROM 
			liq99_recibos AS ll, 
			liq99_liquidacion as l, 
			liq93_empresas as e, 
			liq19_liquidacion as l19, 
			liq19_ejecuciones as e19
		JOIN 
			e.oi_empresa_ddo 			INNER l.oi_empresa_ddo, 
			l.oi_liquidacion_ddo 	INNER ll.oi_liquidacion_ddo,
			l.oi_liquidacion_ddo 	INNER e19.oi_liquidacion_ddo,
			e19.oi_liquidacion 		INNER l19.oi_liquidacion
		WHERE 
			e.c_empresa = \'{%=#DOCUM:@c_empresa %}\' 
			and l.e_periodo = {%= #DOCUM:@e_periodo %}
			and l.c_estado = \'F\' 
			and l.c_clase = \'Q\' 
			and l.e_quincena = 1 
			and l.c_tipo_liq = \'1\'
			{%? (#DOCUM:@l_simulacion!='')	{% AND l19.l_simulacion = {%= #DOCUM:@l_simulacion %} %} {% %} %}
	)
group by 
		a.c_concepto, a.c_tipo_concepto, d.d_tipo_concepto
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="priQuin" value="number($r/@priQuin)"/>
					<qry:attribute name="segQuin" value="number($r/@segQuin)"/>
					<qry:attribute name="mensual" value="number($r/@mensual)"/>
					<qry:attribute name="sac" value="number($r/@sac)"/>
					<qry:attribute name="egresos" value="number($r/@egresos)"/>
					<qry:attribute name="vac" value="number($r/@vac)"/>
					<qry:attribute name="otros" value="number($r/@otros)"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="segQuin">
			<qry:xquery>
				for $r in sql('
SELECT 
	0 as priQuin, SUM(C11.n_valor) as segQuin, 0 as mensual, 0 as sac, 0 as egresos, 0 as vac, 0 as otros, a1.c_concepto, a1.c_tipo_concepto, d1.d_tipo_concepto
FROM 
	LIQ20_CONC_LIQ_PER AS C11, 
	liq96_conceptos as a1, 
	LIQ12_TIPOS_CONC as d1
JOIN 
	d1.c_tipo_concepto INNER a1.c_tipo_concepto, 
	a1.oi_concepto_ddo INNER C11.oi_concepto_ddo 
WHERE
	a1.c_tipo_concepto != \'6\' AND
	C11.n_valor != 0 AND
	C11.oi_tot_liq_per in 
	(
		select 
			ll1.oi_tot_liq_per 
		FROM 
			liq99_recibos AS ll1, 
			liq99_liquidacion as l1 , 
			liq93_empresas as e1 , 
			liq19_liquidacion as l19, 
			liq19_ejecuciones as e19
		JOIN 
			e1.oi_empresa_ddo INNER l1.oi_empresa_ddo, 
			l1.oi_liquidacion_ddo INNER ll1.oi_liquidacion_ddo,
			l1.oi_liquidacion_ddo 	INNER e19.oi_liquidacion_ddo,
			e19.oi_liquidacion 		INNER l19.oi_liquidacion
		WHERE 
			e1.c_empresa = \'{%=#DOCUM:@c_empresa %}\' and 
			l1.e_periodo = {%= #DOCUM:@e_periodo %} and 
			l1.c_estado = \'F\' and 
			l1.c_clase = \'Q\' and 
			l1.e_quincena = 2 and 
			l1.c_tipo_liq = \'1\'
			{%? (#DOCUM:@l_simulacion!='')	{% AND l19.l_simulacion = {%= #DOCUM:@l_simulacion %} %} {% %} %} )
		group by 
			a1.c_concepto, a1.c_tipo_concepto, d1.d_tipo_concepto
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
