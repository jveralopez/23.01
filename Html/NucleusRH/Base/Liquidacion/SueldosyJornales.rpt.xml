			liq19_ejecuciones as e19
			JOIN 
			e4.oi_empresa_ddo INNER l4.oi_empresa_ddo, 
			l4.oi_liquidacion_ddo INNER ll4.oi_liquidacion_ddo,
			l4.oi_liquidacion_ddo 	INNER e19.oi_liquidacion_ddo,
			e19.oi_liquidacion 		INNER l19.oi_liquidacion
			WHERE 
				e4.c_empresa = \'{%=#DOCUM:@c_empresa %}\' 
				and l4.e_periodo = {%= #DOCUM:@e_periodo %} 
				and l4.c_estado = \'F\' 
				and l4.c_tipo_liq not in (\'1\', \'2\', \'3\', \'5\')
				{%? (#DOCUM:@l_simulacion!='')	{% AND l19.l_simulacion = {%= #DOCUM:@l_simulacion %} %} {% %} %} 
		)
	group by a3.c_concepto, a3.c_tipo_concepto, d3.d_tipo_concepto
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="priQuin" value="number($r/@priQuin)"/>
					<qry:attribute name="segQuin" value="number($r/@segQuin)"/>
					<qry:attribute name="mensual" value="number($r/@mensual)"/>
					<qry:attribute name="sac" value="number($r/@sac)"/>
					<qry:attribute name="egresos" value="number($r/@egresos)"/>
					<qry:attribute name="vac" value="number($r/@vac)"/>
					<qry:attribute name="otros" value="number($r/@otros)"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="TIPOS">
			<qry:xquery>
				for $r in sql('
	SELECT  
	S.C_TIPO_CONCEPTO , 
	S.D_TIPO_CONCEPTO , 
	S.E_ORDEN ,
	S.l_nolistado
	FROM LIQ12_TIPOS_CONC AS S
	WHERE 
	S.l_nolistado != 1 ORDER BY E_ORDEN ASC, C_TIPO_CONCEPTO ASC')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TCONC">
					<qry:attribute name="COD" value="$r/@C_TIPO_CONCEPTO"/>
					<qry:attribute name="tipo" value="$r/@C_TIPO_CONCEPTO + '-' + $r/@D_TIPO_CONCEPTO"/>
					<qry:insert-select name="CONCEPTOS" doc-path="."/>
					<qry:attribute name="CONCEPTO" value="'Totales'"/>
					<qry:attribute name="priQuin" value="0"/>
					<qry:attribute name="segQuin" value="0"/>
					<qry:attribute name="mensual" value="0"/>
					<qry:attribute name="sac" value="0"/>
					<qry:attribute name="egresos" value="0"/>
					<qry:attribute name="vac" value="0"/>
					<qry:attribute name="otros" value="0"/>
					<qry:attribute name="TOTAL" value="0"/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:insert-select name="TOTALES" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="CONCEPTOS">
			<qry:xquery>
				for $r in sql('
SELECT 
	S.C_CONCEPTO, 
	max(S.D_CONCEPTO) as D_CONCEPTO, 
	S.C_TIPO_CONCEPTO, 
	T.e_orden as TOrden, 
	C.e_orden as COrden
FROM 
	LIQ96_CONCEPTOS AS S, 
	LIQ14_CONCEPTOS AS L, 
	LIQ12_TIPOS_CONC AS T, 
	LIQ13_CLASES_CONC AS C, 
	liq99_liquidacion as l99
JOIN 
	S.c_concepto INNER L.c_concepto,
	L.oi_tipo_concepto INNER T.oi_tipo_concepto,
	L.oi_clase_concepto LEFT OUTER C.oi_clase_concepto, 
	l99.oi_cab_conc_ddo INNER S.oi_cab_conc_ddo 
WHERE
	S.C_TIPO_CONCEPTO = {#SOURCE:@COD}
  and l99.c_estado = \'F\' 
	and l99.c_empresa = {#DOCUM:@c_empresa}
	AND l99.e_periodo = {#DOCUM:@e_periodo}	
GROUP BY 
	S.C_CONCEPTO, 
	S.C_TIPO_CONCEPTO, 
	T.e_orden,
	C.e_orden
ORDER BY 
	{%? (#DOCUM:@orden!='C_CONCEPTO')	
	{%  {%= #DOCUM:@orden %} ASC, %}
	{% %} %}
	C_CONCEPTO ASC')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONC">
					<qry:attribute name="TIP" value="#SOURCE:@COD"/>
					<qry:attribute name="COD" value="$r/@C_CONCEPTO"/>
					<qry:attribute name="CONCEPTO" value="$r/@C_CONCEPTO + '-' + $r/@D_CONCEPTO"/>
					<qry:attribute name="priQuin" value="0"/>
					<qry:attribute name="segQuin" value="0"/>
					<qry:attribute name="mensual" value="0"/>
					<qry:attribute name="sac" value="0"/>
					<qry:attribute name="egresos" value="0"/>
					<qry:attribute name="vac" value="0"/>
					<qry:attribute name="otros" value="0"/>
					<qry:insert-select name="DETALLES" doc-path="."/>
					<qry:attribute name="TOTAL" value="number(@priQuin) + (@segQuin) + number(@mensual) + number(@otros)"/>
					<qry:attribute name="TOTAL" value="number(@TOTAL) + number(@sac) + number(@egresos) + number(@vac)"/>
					<qry:attribute name="hts:delete" value="iif(@priQuin='0' and @segQuin='0' and @mensual='0' and @sac='0' and @egresos='0' and @vac='0' and @otros='0','1','')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="TOTALES">
			<qry:xquery>
				for $r in #SOURCE:CONC
			</qry:xquery>
			<qry:out>
				<qry:attribute name="priQuin" value="number($r/@priQuin) + number(@priQuin)"/>
				<qry:attribute name="segQuin" value="number($r/@segQuin) + number(@segQuin)"/>
				<qry:attribute name="mensual" value="number($r/@mensual) + number(@mensual)"/>
				<qry:attribute name="sac" value="number($r/@sac) + number(@sac)"/>
				<qry:attribute name="egresos" value="number($r/@egresos) + number(@egresos)"/>
				<qry:attribute name="vac" value="number($r/@vac) + number(@vac)"/>
				<qry:attribute name="otros" value="number($r/@otros) + number(@otros)"/>
				<qry:attribute name="TOTAL" value="number($r/@TOTAL) + number(@TOTAL)"/>
				<qry:attribute name="hts:delete" value="0"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="DETALLES">
			<qry:xquery>
				for $r in #POSTA:ROWS/ROW[@c_tipo_concepto = #SOURCE:@TIP AND @c_concepto = #SOURCE:@COD ]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
				<qry:attribute name="priQuin" value="number(@priQuin) + number($r/@priQuin)"/>
				<qry:attribute name="segQuin" value="number(@segQuin) + number($r/@segQuin)"/>
				<qry:attribute name="mensual" value="number(@mensual) + number($r/@mensual)"/>
				<qry:attribute name="sac" value="number(@sac) + number($r/@sac)"/>
				<qry:attribute name="egresos" value="number(@egresos) + number($r/@egresos)"/>
				<qry:attribute name="vac" value="number(@vac) + number($r/@vac)"/>
				<qry:attribute name="otros" value="number(@otros) + number($r/@otros)"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="LIQUIDACIONES">
			<qry:xquery>
				for $r in sql('
		SELECT     
		  l.oi_liquidacion_ddo,
		  l.c_liquidacion, 
		  l.d_titulo, 
		  l.e_quincena, 
		  l.e_periodo, 
		  l.f_liquidacion, 
		  l.c_estado, 
		  Q.l_simulacion,
		  l.c_clase
		FROM         
			LIQ99_LIQUIDACION as l, LIQ19_EJECUCIONES as E, LIQ19_LIQUIDACION as Q
		JOIN
			l.oi_liquidacion_ddo INNER E.oi_liquidacion_ddo,
			E.oi_liquidacion INNER Q.oi_liquidacion
		WHERE     
			l.c_estado = \'F\' 
			and
			l.c_empresa = \'{%=#DOCUM:@c_empresa %}\'
			{%? (#DOCUM:@l_simulacion!='')	{% AND Q.l_simulacion = {%= #DOCUM:@l_simulacion %} %} {% %} %}
			AND 
			l.e_periodo = {#DOCUM:@e_periodo}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="LIQ">
					<qry:attribute name="d_liquidacion" value="$r/@c_liquidacion + '-' + $r/@d_titulo"/>
					<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
					<qry:attribute name="f_liquidacion" value="format_date($r/@f_liquidacion,'dd/mm/yyyy')"/>
					<qry:attribute name="c_clase" value="iif($r/@c_clase='M','Mensual','Quincenal'+ '-' + $r/@e_quincena)"/>
					<qry:insert-select name="TotalPagar" doc-path="$r"/>
				</qry:element>
				<qry:attribute name="hayLiq" value="'1'"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="TotalPagar">
			<qry:xquery>
				for $r in sql('SELECT SUM(LIQ20_TOT_LIQ_PER.n_totpag) AS totPag 
			FROM LIQ20_TOT_LIQ_PER , LIQ99_RECIBOS 
WHERE 
LIQ20_TOT_LIQ_PER.oi_tot_liq_per = LIQ99_RECIBOS.oi_tot_liq_per
and
LIQ99_RECIBOS.oi_liquidacion_ddo = {#SOURCE:@oi_liquidacion_ddo}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="totPag" value="$r/@totPag"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="SUPER_TOTALES">
			<qry:xquery>
				for $r in #SOURCE:TCONC[@hts:delete!=1]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="CONCEPTO" value="'Total General'"/>
				<qry:attribute name="priQuin" value="number($r/@priQuin) + number(@priQuin)"/>
				<qry:attribute name="segQuin" value="number($r/@segQuin) + number(@segQuin)"/>
				<qry:attribute name="mensual" value="number($r/@mensual) + number(@mensual)"/>
				<qry:attribute name="sac" value="number($r/@sac) + number(@sac)"/>
				<qry:attribute name="egresos" value="number($r/@egresos) + number(@egresos)"/>
				<qry:attribute name="vac" value="number($r/@vac) + number(@vac)"/>
				<qry:attribute name="otros" value="number($r/@otros) + number(@otros)"/>
				<qry:attribute name="TOTAL" value="number($r/@TOTAL) + number(@TOTAL)"/>
				<qry:attribute name="hts:delete" value="0"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="EMPRESAS">
			<qry:xquery>
				for $r in sql('
		SELECT 
			ORG03_EMPRESAS.d_empresa
		FROM 
			ORG03_EMPRESAS as ORG03_EMPRESAS 
		WHERE 
		  ORG03_EMPRESAS.c_empresa = {#SOURCE:@c_empresa}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="#SOURCE:@c_empresa + '-' + $r/@d_empresa"/>
			</qry:out>
		</qry:select>
	</html:query>
