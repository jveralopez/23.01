					<qry:attribute name="otros" value="number($r/@otros)"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="sac">
			<qry:xquery>
				for $r in sql('
SELECT 
	0 as priQuin,0 as segQuin, 0 as mensual, SUM(C1.n_valor)  as sac, 0 as egresos, 0 as vac, 0 as otros, a0.c_concepto, a0.c_tipo_concepto, d0.d_tipo_concepto
