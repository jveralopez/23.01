<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.BaseReport.rpt" doc="source" name="NucleusRH.Base.Liquidacion.ConceptosSegunIG">
	<html:query declare="&lt;DATOS oi_empresa=&quot;1&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATOS"/>
			<REPORT label="Asignacion de bandas salariales y convenios a los puestos/posiciones">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="EMP" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
						</COLS>
						<GROUP tag="DCG" style="padding-left:0px;" type="title_collapse">
							<COLS>
								<COL name="Grupo" label="Grupo"/>
							</COLS>
							<GROUP tag="DC" style="padding-left:50px;" type="title_collapse">
								<GROUP tag="Nivel1" style="padding-left:50px;" type="title_collapse">
									<COLS>
										<COL name="Convenio" label="Convenio" style=""/>
									</COLS>
									<GROUP tag="Nivel2" style="padding-left:50px;" type="title_collapse">
										<COLS>
											<COL name="Categoria" label="Categoria" style=""/>
										</COLS>
										<GROUP tag="Puesto" style="padding-left:50px;" type="table">
											<COLS>
												<COL name="Puesto" label="Puesto" type="string"/>
												<COL name="Posicion" label="Posicion"/>
											</COLS>
										</GROUP>
									</GROUP>
								</GROUP>
							</GROUP>
						</GROUP>
						<GROUP tag="FCG" style="padding-left:0px;" type="title_collapse">
							<COLS>
								<COL name="Grupo" label="Grupo"/>
							</COLS>
							<GROUP tag="FC" style="padding-left:50px;" type="title_collapse">
								<GROUP tag="Nivel1" style="padding-left:50px;" type="title_collapse">
									<COLS>
										<COL name="Banda" label="Banda" style=""/>
									</COLS>
									<GROUP tag="Nivel2" style="padding-left:50px;" type="title_collapse">
										<COLS>
											<COL name="Nivel" label="Nivel" style=""/>
										</COLS>
										<GROUP tag="Puesto" style="padding-left:50px;" type="table">
											<COLS>
												<COL name="Puesto" label="Puesto" type="string"/>
												<COL name="Posicion" label="Posicion"/>
											</COLS>
										</GROUP>
									</GROUP>
								</GROUP>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="EMP">
						<qry:insert-select name="qry_cabecera" doc-path="#SOURCE:DATOS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="qry_cabecera" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT     
				  O.c_empresa, O.d_empresa, O.oi_empresa
				FROM
				 	ORG03_EMPRESAS as O
				WHERE
					O.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="empresa" value="$r/@c_empresa + '-' + $r/@d_empresa" type="Nomad.NSystem.Int"/>
				<qry:attribute name="oi_empresa" value="$r/@oi_empresa" type="Nomad.NSystem.Int"/>
				<qry:element name="DCG">
					<qry:attribute name="Grupo" value="'Dentro de Convenio'" type="Nomad.NSystem.Int"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa" type="Nomad.NSystem.Int"/>
					<qry:element name="DC">
						<qry:insert-select name="qry_dc" doc-path=".."/>
					</qry:element>
				</qry:element>
				<qry:element name="FCG">
					<qry:attribute name="Grupo" value="'Fuera de Convenio'" type="Nomad.NSystem.Int"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa" type="Nomad.NSystem.Int"/>
					<qry:element name="FC">
						<qry:insert-select name="qry_fc" doc-path=".."/>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dc" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	N.c_convenio, N.d_convenio, N.oi_convenio
FROM 
	ORG18_CONVENIOS AS N
ORDER BY
	c_convenio ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Nivel1">
					<qry:attribute name="Convenio" value="$r/@c_convenio + '-' + $r/@d_convenio" type="Nomad.NSystem.Int"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="qry_categ" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_categ" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	C.c_categoria, C.d_categoria, C.oi_categoria, C.n_valor_hora
FROM 
	ORG18_CATEGORIAS AS C
WHERE
 	C.oi_convenio = {#SOURCE:@oi_convenio}
ORDER BY
	c_categoria ASC 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Nivel2">
					<qry:attribute name="Categoria" value="$r/@c_categoria + '-' + $r/@d_categoria + ' [Base: $' + $r/@n_valor_hora +']'" type="Nomad.NSystem.Int"/>
					<qry:attribute name="oi_categoria" value="$r/@oi_categoria" type="Nomad.NSystem.Int"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:attribute name="eliminar" value="1"/>
					<qry:insert-select name="qry_Posiciones_dc" doc-path="."/>
				</qry:element>
				<qry:insert-select name="Elim" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="Elim" doc="SOURCE">
			<qry:xquery>
				for $r in #SOURCE:Nivel2[@eliminar=0]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hts:delete" value="''"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_Posiciones_dc" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	P.c_puesto, P.d_puesto, P.l_convenio,
	O.c_posicion, O.d_posicion
FROM
	ORG04_PUESTOS AS P, ORG04_POSICIONES AS O
JOIN
	P.oi_puesto LEFT OUTER O.oi_puesto
WHERE
	O.oi_categoria = {#SOURCE:@oi_categoria}
	AND P.l_convenio = 1
	AND P.oi_empresa = {#PARAMIN:@oi_empresa}
ORDER BY 
	c_puesto asc, c_posicion asc
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<Puesto>
					<qry:attribute name="Puesto" value="$r/@c_puesto + '-' + $r/@d_puesto" type="Nomad.NSystem.Int"/>
					<qry:attribute name="Posicion" value="$r/@c_posicion + '-' + $r/@d_posicion" type="Nomad.NSystem.Int"/>
				</Puesto>
				<qry:attribute name="hts:delete" value="''"/>
				<qry:attribute name="eliminar" value="0"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_fc" doc="SOURCE">
			<qry:xquery>
				for $r in sql('

SELECT
	B.c_banda_sal, B.d_banda_sal, B.oi_banda_sal
FROM 
	ORG17_BANDAS_SAL AS B
ORDER BY 
	c_banda_sal asc
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Nivel1">
					<qry:attribute name="Banda" value="$r/@c_banda_sal + '-' + $r/@d_banda_sal" type="Nomad.NSystem.Int"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="qry_niveles" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_niveles" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	N.e_orden, 
	N.c_nivel_sal, N.d_nivel_sal, N.oi_nivel_sal,
	N.n_sal_minimo, N.n_sal_maximo
FROM 
	ORG17_NIVELES_SAL AS N
WHERE 
	N.oi_banda_sal = {#SOURCE:@oi_banda_sal}
ORDER BY 
	e_orden asc 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Nivel2">
					<qry:attribute name="Nivel" value="$r/@c_nivel_sal + '-' + $r/@d_nivel_sal + ' [$' + $r/@n_sal_minimo + ' a $' + $r/@n_sal_maximo + ']'" type="Nomad.NSystem.Int"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:attribute name="eliminar" value="1"/>
					<qry:insert-select name="qry_Posiciones_fc" doc-path="$r"/>
				</qry:element>
				<qry:insert-select name="Elim" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_Posiciones_fc" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	P.c_puesto, P.d_puesto, P.l_convenio,
	O.c_posicion, O.d_posicion
FROM
	ORG04_PUESTOS AS P, ORG04_POSICIONES AS O
JOIN
	P.oi_puesto LEFT OUTER O.oi_puesto
WHERE
	O.oi_nivel_sal = {#SOURCE:@oi_nivel_sal}
	AND P.l_convenio = 0
	AND P.oi_empresa = {#PARAMIN:@oi_empresa}
ORDER BY 
	c_puesto asc, c_posicion asc
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<Puesto>
					<qry:attribute name="Puesto" value="$r/@c_puesto + '-' + $r/@d_puesto" type="Nomad.NSystem.Int"/>
					<qry:attribute name="Posicion" value="$r/@c_posicion + '-' + $r/@d_posicion" type="Nomad.NSystem.Int"/>
				</Puesto>
				<qry:attribute name="hts:delete" value="''"/>
				<qry:attribute name="eliminar" value="0"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
