	REM02_PERIODOS
WHERE
	REM02_PERIODOS.oi_personal_emp =  {#SOURCE:@oi_personal_emp}
	{%? (#PARAMIN:@e_periodoDesde!='')	{% AND REM02_PERIODOS.e_periodo &gt;= {%= #PARAMIN:@e_periodoDesde%} %} {% %} %}	
	{%? (#PARAMIN:@e_periodoHasta!='')	{% AND REM02_PERIODOS.e_periodo &lt;= {%= #PARAMIN:@e_periodoHasta%} %} {% %} %}		
