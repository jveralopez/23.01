<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.AnalisisRemun.DesviosConvenio" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATOS &#13;&#10;&#9;agrupar=&quot;G&quot; &#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;&#13;&#10;&#9;oi_empresa=&quot;200&quot; &#13;&#10;&#9;diferencia=&quot;B&quot; &#13;&#10;&#9;oi_ccosto=&quot;&quot; &#13;&#10;&#9;oi_convenio=&quot;1&quot; e_periodo=&quot;200801&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATOS"/>
			<REPORT label="An&#225;lisis de desv&#237;os de las remuneraciones por Convenio / Categorias">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="EMP" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
							<COL name="Diferencia" label="Diferencia">
								<OPT id="B" value="Basico"/>
								<OPT id="A" value="Adicionales"/>
								<OPT id="C" value="Conformado"/>
							</COL>
							<qry:insert-select name="qry_ColumnaPeriodo" doc-path="#SOURCE:DATOS[@e_periodo!='']"/>
							<qry:insert-select name="qry_ColumnaCCosto" doc-path="#SOURCE:DATOS[@oi_ccosto!='']"/>
							<qry:insert-select name="qry_ColumnaConvenio" doc-path="#SOURCE:DATOS[@oi_convenio!='']"/>
						</COLS>
						<qry:insert-select name="qry_SinAgruparFiltro" doc-path="#SOURCE:DATOS[@agrupar='S']"/>
						<qry:insert-select name="qry_AgruparConvenioFiltro" doc-path="#SOURCE:DATOS[@agrupar='C']"/>
						<qry:insert-select name="qry_AgruparCentroFiltro" doc-path="#SOURCE:DATOS[@agrupar='G']"/>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="EMP">
						<qry:insert-select name="qry_cabecera" doc-path="#SOURCE:DATOS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="qry_ColumnaPeriodo" doc="SOURCE">
			<qry:out>
				<COL name="Periodo" label="Periodo"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_ColumnaCCosto" doc="SOURCE">
			<qry:out>
				<COL name="CCosto" label="Centro de Costo"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_ColumnaConvenio" doc="SOURCE">
			<qry:out>
				<COL name="Convenio" label="Convenio"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_SinAgruparFiltro" doc="SOURCE">
			<qry:out>
				<GROUP tag="PERSONAS" style="padding-left:50px;" type="table">
					<COLS>
						<COL name="Convenio" label="Convenio" style="" type="string" nowrap="1"/>
						<COL name="Categoria" label="Categoria" style="" type="string" nowrap="1"/>
						<COL name="Legajo" label="Legajo" type="string" nowrap="1"/>
						<COL name="NombreApellido" label="Apellido y Nombre" type="string" nowrap="1"/>
						<COL name="CentroCosto" label="Centro de Costo" type="string" nowrap="1"/>
						<qry:insert-select name="qry_ColumnaBasico" doc-path="#PARAMIN:.[@diferencia='B']" nowrap="1"/>
						<qry:insert-select name="qry_ColumnaAdicionales" doc-path="#PARAMIN:.[@diferencia='A']" nowrap="1"/>
						<qry:insert-select name="qry_ColumnaConformado" doc-path="#PARAMIN:.[@diferencia='C']" nowrap="1"/>
						<COL name="Diferencia" label="Diferencia" style="" type="num" nowrap="1"/>
						<COL name="Porcentaje" label="Porcentaje" style="" type="num" nowrap="1"/>
					</COLS>
				</GROUP>
			</qry:out>
		</qry:select>
		<qry:select name="qry_ColumnaConformado" doc="SOURCE">
			<qry:out>
				<COL name="Conformado" label="Conformado Categoria" style="" type="num" nowrap="1"/>
				<COL name="ConformadoReal" label="Conformado Real" style="" type="num" nowrap="1"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_ColumnaAdicionales" doc="SOURCE">
			<qry:out>
				<COL name="Adicionales" label="Adicionales Categoria" style="" type="num" nowrap="1"/>
				<COL name="AdicionalesReal" label="Adicionales Real" style="" type="num" nowrap="1"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_ColumnaBasico" doc="SOURCE">
			<qry:out>
				<COL name="Basico" label="Basico Categoria" style="" type="num" nowrap="1"/>
				<COL name="BasicoReal" label="Basico Real" style="" type="num" nowrap="1"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparCentroFiltro" doc="SOURCE">
			<qry:out>
				<GROUP tag="Niv1" style="padding-left:50px;" type="title_collapse">
					<COLS>
						<COL name="GCentro" label="Grupo de Centros de Costos" type="string"/>
					</COLS>
					<GROUP tag="Niv2" style="padding-left:50px;" type="title_collapse">
						<COLS>
							<COL name="Centro" label="Centro de Costos" type="string"/>
						</COLS>
						<GROUP tag="PERSONAS" style="padding-left:50px;" type="table">
							<COLS>
								<COL name="Convenio" label="Convenio" style="" type="string" nowrap="1"/>
								<COL name="Categoria" label="Categoria" style="" type="string" nowrap="1"/>
								<COL name="Legajo" label="Legajo" type="string" nowrap="1"/>
								<COL name="NombreApellido" label="Apellido y Nombre" type="string" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaBasico" doc-path="#PARAMIN:.[@diferencia='B']" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaAdicionales" doc-path="#PARAMIN:.[@diferencia='A']" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaConformado" doc-path="#PARAMIN:.[@diferencia='C']" nowrap="1"/>
								<COL name="Diferencia" label="Diferencia" style="" type="num" nowrap="1"/>
								<COL name="Porcentaje" label="Porcentaje" style="" type="num" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUP>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparConvenioFiltro" doc="SOURCE">
			<qry:out>
				<GROUP tag="Niv1" style="padding-left:50px;" type="title_collapse">
					<COLS>
						<COL name="Convenio" label="Convenio" type="string"/>
					</COLS>
					<GROUP tag="Niv2" style="padding-left:50px;" type="title_collapse">
						<COLS>
							<COL name="Categoria" label="Categoria" type="string"/>
						</COLS>
						<GROUP tag="PERSONAS" style="padding-left:50px;" type="table">
							<COLS>
								<COL name="Legajo" label="Legajo" type="string" nowrap="1"/>
								<COL name="NombreApellido" label="Apellido y Nombre" type="string" nowrap="1"/>
								<COL name="CentroCosto" label="Centro de Costo" type="string" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaBasico" doc-path="#PARAMIN:.[@diferencia='B']" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaAdicionales" doc-path="#PARAMIN:.[@diferencia='A']" nowrap="1"/>
								<qry:insert-select name="qry_ColumnaConformado" doc-path="#PARAMIN:.[@diferencia='C']" nowrap="1"/>
								<COL name="Diferencia" label="Diferencia" style="" type="num" nowrap="1"/>
								<COL name="Porcentaje" label="Porcentaje" style="" type="num" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUP>
			</qry:out>
		</qry:select>
		<qry:select name="qry_cabecera" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT     
				  O.c_empresa, O.d_empresa, O.oi_empresa
				FROM
				 	ORG03_EMPRESAS as O
				WHERE
					O.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="empresa" value="$r/@c_empresa + '-' + $r/@d_empresa" type="Nomad.NSystem.Int"/>
				<qry:attribute name="Periodo" value="format_date(#PARAMIN:@e_periodo + '01','mm/yyyy')" type="Nomad.NSystem.Int"/>
				<qry:attribute name="Diferencia" value="#PARAMIN:@diferencia" type="Nomad.NSystem.Int"/>
				<qry:insert-select name="qry_filtroConvenio" doc-path="#PARAMIN:.[@oi_convenio!='']"/>
				<qry:insert-select name="qry_filtroCentroCosto" doc-path="#PARAMIN:.[@oi_ccosto!='']"/>
				<qry:attribute name="oi_empresa" value="$r/@oi_empresa" type="Nomad.NSystem.Int"/>
				<qry:insert-select name="qry_SinAgrupar" doc-path="#PARAMIN:.[@agrupar='S']"/>
				<qry:insert-select name="qry_AgruparConvenio" doc-path="#PARAMIN:.[@agrupar='C']"/>
				<qry:insert-select name="qry_AgruparGCentro" doc-path="#PARAMIN:.[@agrupar='G']"/>
				<qry:insert-select name="qry_AgruparGCentroSinGrupo" doc-path="#PARAMIN:.[@agrupar='G']"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparGCentroSinGrupo" doc="SOURCE">
			<qry:out>
				<qry:element name="Niv1">
					<qry:attribute name="GCentro" value="'Centros de Costos Sin Grupo'"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="qry_AgruparCentroSinGrupo"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparConvenio" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	o18.c_convenio, 
	o18.d_convenio,
	o18.oi_convenio	
FROM 	
	ORG18_CONVENIOS AS o18
ORDER BY
	c_convenio ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Niv1">
					<qry:attribute name="Convenio" value="$r/@c_convenio + '-' + $r/@d_convenio"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="qry_AgruparCategoria" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparCategoria" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT 
	Ca18.oi_categoria,
	Ca18.c_categoria,
	Ca18.d_categoria
FROM 
	ORG18_CATEGORIAS AS Ca18
WHERE 
	Ca18.oi_convenio = {#SOURCE:@oi_convenio}	
ORDER BY	
	oi_categoria ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Niv2">
					<qry:attribute name="Categoria" value="$r/@c_categoria + '-' + $r/@d_categoria"/>
					<qry:attribute name="oi_categAgrupada" value="$r/@oi_categoria"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:attribute name="eliminar" value="1"/>
					<qry:insert-select name="qry_SinAgrupar" doc-path="."/>
				</qry:element>
				<qry:insert-select name="Elim" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparGCentro" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	ORG09_GR_CCOSTO.oi_grupo_ccosto,
	ORG09_GR_CCOSTO.c_grupo_ccosto,
	ORG09_GR_CCOSTO.d_grupo_ccosto
FROM
	ORG09_GR_CCOSTO
ORDER BY
	c_grupo_ccosto ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Niv1">
					<qry:attribute name="GCentro" value="$r/@c_grupo_ccosto + '-' + $r/@d_grupo_ccosto"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:insert-select name="qry_AgruparCentro" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparCentro" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	ORG08_CS_COSTO.oi_centro_costo,
	ORG08_CS_COSTO.c_centro_costo,	
	ORG08_CS_COSTO.d_centro_costo
FROM
	ORG08_CS_COSTO
WHERE
	ORG08_CS_COSTO.oi_grupo_ccosto = {#SOURCE:@oi_grupo_ccosto}	
ORDER BY	
	c_centro_costo ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Niv2">
					<qry:attribute name="Centro" value="$r/@c_centro_costo + '-' + $r/@d_centro_costo"/>
					<qry:attribute name="oi_centroAgrupada" value="$r/@oi_centro_costo"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:attribute name="eliminar" value="1"/>
					<qry:insert-select name="qry_SinAgrupar" doc-path="."/>
				</qry:element>
				<qry:insert-select name="Elim" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_AgruparCentroSinGrupo" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	ORG08_CS_COSTO.oi_centro_costo,
	ORG08_CS_COSTO.c_centro_costo,	
	ORG08_CS_COSTO.d_centro_costo
FROM
	ORG08_CS_COSTO, Per02_personal_emp
WHERE
	ORG08_CS_COSTO.oi_centro_costo = Per02_personal_emp.oi_ctro_costo_ult
	and
	isnull(ORG08_CS_COSTO.oi_grupo_ccosto)
ORDER BY	
	c_centro_costo ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Niv2">
					<qry:attribute name="Centro" value="$r/@c_centro_costo + '-' + $r/@d_centro_costo"/>
					<qry:attribute name="oi_centroAgrupada" value="$r/@oi_centro_costo"/>
					<qry:attribute name="hts:delete" value="'1'"/>
					<qry:attribute name="eliminar" value="1"/>
					<qry:insert-select name="qry_SinAgrupar" doc-path="."/>
				</qry:element>
				<qry:insert-select name="Elim" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_SinAgrupar" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT  
	Co.c_convenio, 
	Co.d_convenio,
	Ca.c_categoria, 
	Ca.d_categoria, 
	E.oi_personal_emp, 
	E.e_numero_legajo, 
	EE.d_ape_y_nom, 
	c.c_centro_costo, c.d_centro_costo,
	Ca.n_valor_hora, 
	Ca.n_suplemento_1,
	Ca.n_suplemento_2,
	Ca.n_suplemento_3,
	Ca.n_suplemento_4,
	
	{%? (#PARAMIN:@e_periodo='')	
		{% R1.n_basico, R1.n_adicionales , R1.n_conformado %} 
		{% RP.n_basico, RP.n_adicionales , RP.n_conformado %} 
	%}
FROM 
	ORG18_CATEGORIAS AS Ca, 
	ORG18_CONVENIOS AS Co,
	PER02_PERSONAL_EMP AS E, 
	PER01_PERSONAL AS EE, 
	REM02_PERSONAL_EMP AS R1, 
	ORG08_CS_COSTO AS C
	{%? (#PARAMIN:@e_periodo!='') {% ,REM02_PERIODOS as RP %} {% %} %}
JOIN
	Ca.oi_convenio INNER Co.oi_convenio , 
	E.oi_personal INNER ee.oi_personal ,
	E.oi_personal_emp INNER R1.oi_personal_emp ,
	E.oi_categoria_ult INNER Ca.oi_categoria , 
	e.oi_ctro_costo_ult INNER c.oi_centro_costo
	{%? (#PARAMIN:@e_periodo!='')	{% , RP.oi_personal_emp INNER R1.oi_personal_emp %} {% %} %}
WHERE
	E.oi_empresa = {#PARAMIN:@oi_empresa} 
	{%? (#PARAMIN:@oi_convenio!='')	{% AND Co.oi_convenio = {%= #PARAMIN:@oi_convenio%} %} {% %} %}
	{%? (#PARAMIN:@oi_ccosto!='')	{% AND e.oi_ctro_costo_ult = {%= #PARAMIN:@oi_ccosto%} %} {% %} %}	
	{%? (#PARAMIN:@e_periodo!='')	{% AND RP.e_periodo = {%= #PARAMIN:@e_periodo%} %} {% %} %}      
	{%? (#SOURCE:@oi_categAgrupada!='')	{% AND Ca.oi_categoria = {%= #SOURCE:@oi_categAgrupada %} %} {% %} %}
	{%? (#SOURCE:@oi_centroAgrupada!='')	{% AND e.oi_ctro_costo_ult = {%= #SOURCE:@oi_centroAgrupada %} %} {% %} %}
ORDER BY
	c_convenio ASC,
	c_categoria ASC,
	e_numero_legajo ASC 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PERSONAS">
					<qry:attribute name="Convenio" value="$r/@c_convenio + '-' + $r/@d_convenio"/>
					<qry:attribute name="Categoria" value="$r/@c_categoria + '-' + $r/@d_categoria"/>
					<qry:attribute name="Legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="NombreApellido" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="CentroCosto" value="$r/@c_centro_costo + '-' + $r/@d_centro_costo"/>
					<qry:attribute name="Basico" value="$r/@n_valor_hora"/>
					<qry:attribute name="BasicoReal" value="$r/@n_basico"/>
					<qry:attribute name="Adicionales" value="0 + number($r/@n_suplemento_1)"/>
					<qry:attribute name="Adicionales" value="number(@Adicionales) + number($r/@n_suplemento_2)"/>
					<qry:attribute name="Adicionales" value="number(@Adicionales) + number($r/@n_suplemento_3)"/>
					<qry:attribute name="Adicionales" value="number(@Adicionales) + number($r/@n_suplemento_4)"/>
					<qry:insert-select name="qry_adicionalesCateg" doc-path="$r"/>
					<qry:attribute name="AdicionalesReal" value="$r/@n_adicionales"/>
					<qry:attribute name="Conformado" value="number(@Basico) + number(@Adicionales)"/>
					<qry:attribute name="ConformadoReal" value="$r/@n_conformado"/>
					<qry:attribute name="monto" value="0"/>
					<qry:attribute name="monto" value="iif(#PARAMIN:@diferencia='B',@Basico,@monto)"/>
					<qry:attribute name="monto" value="iif(#PARAMIN:@diferencia='A',@Adicionales,@monto)"/>
					<qry:attribute name="monto" value="iif(#PARAMIN:@diferencia='C',@Conformado,@monto)"/>
					<qry:attribute name="montoReal" value="0"/>
					<qry:attribute name="montoReal" value="iif(#PARAMIN:@diferencia='B',@BasicoReal,@montoReal)"/>
					<qry:attribute name="montoReal" value="iif(#PARAMIN:@diferencia='A',@AdicionalesReal,@montoReal)"/>
					<qry:attribute name="montoReal" value="iif(#PARAMIN:@diferencia='C',@ConformadoReal,@montoReal)"/>
					<qry:attribute name="Diferencia" value="number(@monto) - number(@montoReal)"/>
					<qry:attribute name="Porcentaje" value="number(@montoReal) div Number(@monto) * 100"/>
					<qry:attribute name="e_periodo" value="#PARAMIN:@e_periodo"/>
					<qry:attribute name="f_desde" value="@e_periodo + '01'"/>
					<qry:attribute name="f_hasta" value="number(@e_periodo) + 1"/>
					<qry:attribute name="f_hasta" value="@f_hasta + '01'"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:insert-select name="qry_CategPeriodos" doc-path=".[@e_periodo!='']"/>
				</qry:element>
				<qry:attribute name="hts:delete" value="''"/>
				<qry:attribute name="eliminar" value="0"/>
			</qry:out>
		</qry:select>
		<qry:select name="Elim" doc="SOURCE">
			<qry:xquery>
				for $r in #SOURCE:Niv2[@eliminar=0]
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hts:delete" value="''"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_filtroConvenio" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT  
	P.c_convenio, P.d_convenio
FROM 
	ORG18_CONVENIOS AS P
WHERE
	P.oi_convenio = {#PARAMIN:@oi_convenio}		
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Convenio" value="$r/@c_convenio + '-' + $r/@d_convenio"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_filtroCentroCosto" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT
	ORG08_CS_COSTO.oi_centro_costo,
	ORG08_CS_COSTO.c_centro_costo,
	ORG08_CS_COSTO.d_centro_costo
FROM
	ORG08_CS_COSTO
WHERE
	ORG08_CS_COSTO.oi_centro_costo = {#PARAMIN:@oi_ccosto}			
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="CCosto" value="$r/@c_centro_costo + '-' + $r/@d_centro_costo"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_adicionalesCateg" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
SELECT ORG18_CATEG_ADIC.n_valor 
FROM 
	ORG18_CATEG_ADIC, 
	ORG39_ADICIONALES
JOIN
	ORG18_CATEG_ADIC.oi_adicional INNER ORG39_ADICIONALES.oi_adicional
WHERE
  ORG18_CATEG_ADIC.oi_categoria = {#SOURCE:@oi_categoria}			
	AND ORG39_ADICIONALES.l_porcentaje = 0 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Adicionales" value="number(@Adicionales) + number($r/@n_valor)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_CategPeriodos" doc="SOURCE">
			<qry:xquery>
				for $r in sql('

SELECT 
	c.c_categoria, C.d_categoria,
	O.c_convenio, o.d_convenio
FROM 
	PER02_CATEG_PER AS P, ORG18_CATEGORIAS AS C, ORG18_CONVENIOS AS O
WHERE 
	P.oi_categoria_per = C.oi_categoria AND
	C.oi_convenio = o.oi_convenio
	AND P.f_ingreso &lt;= {#SOURCE:@f_desde}
	AND (isnull(P.f_egreso) or P.f_egreso &gt;= {#SOURCE:@f_hasta})
	AND p.oi_personal_emp = {#SOURCE:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Convenio" value="$r/@c_convenio + '-' + $r/@d_convenio"/>
				<qry:attribute name="Categoria" value="$r/@c_categoria + '-' + $r/@d_categoria"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
