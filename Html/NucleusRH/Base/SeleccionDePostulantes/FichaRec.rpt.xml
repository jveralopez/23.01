<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="NucleusRH.Base.SeleccionDePostulantes.CV.rpt" name="NucleusRH.Base.SeleccionDePostulantes.FichaRecNuevo.rpt" doc="source">
	<html:query declare="&lt;PARAMS oi_aviso=&quot;1&quot; id=&quot;1&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc doc-path="#PARAM:/PARAMS" name="FILTRO"/>
			<qry:element name="Legajo">
				<qry:insert-select doc-path="#PARAM:/PARAMS" name="RECLUTADOS"/>
				<qry:attribute name="id" value="@oi_cv"/>
				<qry:element name="Estudios">
					<qry:insert-select doc-path=".." name="qry_estudios"/>
				</qry:element>
				<qry:element name="Idiomas">
					<qry:insert-select doc-path=".." name="qry_idiomas"/>
				</qry:element>
				<qry:element name="Experiencias">
					<qry:insert-select doc-path=".." name="qry_experiencias"/>
				</qry:element>
				<qry:element name="Conocimientos">
					<qry:insert-select doc-path=".." name="qry_conocimientos"/>
				</qry:element>
				<qry:element name="Postulaciones">
					<qry:insert-select doc-path=".." name="qry_postulaciones"/>
				</qry:element>
				<qry:element name="Areas_Interes">
					<qry:insert-select doc-path=".." name="qry_areasinteres"/>
				</qry:element>
				<qry:insert-select doc-path="#PARAM:/PARAMS" name="qry_logo"/>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="qry_legajo_a">
			<qry:xquery>
				for $r in sql('
			SELECT 
				SDP01.d_localidad as localidad_residencia,
				ORG35.d_provincia as provincia_residencia,
				ORG35PA.d_pais as pais_residencia,
				ORG22.d_estado_civil,
				SDP01.d_apellido,
				SDP01.d_nombres,
				SDP01.c_nro_doc,
				SDP01.c_sexo, 
				SDP01.f_nacim,
				SDP01.c_nro_cuil,
				SDP01.d_email,  
				SDP01.c_area_cel,
				SDP01.te_celular,
				SDP01.c_codigo_postal,
				SDP01.d_calle,
				SDP01.c_nro,
				SDP01.c_piso,
				SDP01.c_departamento, 
				SDP01.c_area,
				SDP01.te_nro,
				SDP01.oi_foto,
				SDP02.o_doc_digital,
				SDP01.c_viajar as c_viajar,
				SDP01.c_radicarse as c_radicarse,
				SDP01.c_lic_conduc,
				SDP01.c_vehiculo,
				SDP16.d_tipo_jor_lab,
				SDP17.d_sit_laboral,
				SDP01.n_remuneracion,
				SDP01.oi_cv,          
				DOC.c_tipo_documento,
				SDP01.oi_personal
		   FROM
				SDP01_CV AS SDP01,   
				ORG22_EST_CIVIL AS ORG22,
				ORG35_PROVINCIAS AS ORG35,
				ORG35_PAISES AS ORG35PA,
				SDP02_DOC_DIG as SDP02,
				SDP16_TIPOS_JORNADA AS SDP16,
				SDP17_SIT_LABORALES AS SDP17,
				PER20_TIPOS_DOC AS DOC
		   JOIN
				SDP01.oi_estado_civil LEFT OUTER ORG22.oi_estado_civil,
				ORG35.oi_provincia RIGHT OUTER SDP01.oi_provincia,
				ORG35PA.oi_pais RIGHT OUTER SDP01.oi_pais,				
				SDP02.oi_doc_digital RIGHT OUTER SDP01.oi_foto,
				SDP01.oi_tipo_jor_lab LEFT OUTER SDP16.oi_tipo_jor_lab,
				SDP01.oi_sit_laboral LEFT OUTER SDP17.oi_sit_laboral,  
				SDP01.oi_tipo_documento LEFT OUTER DOC.oi_tipo_documento  
		   WHERE
				SDP01.oi_cv = {#PARAM:@oi_cv}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_cv" value="$r/@d_apellido + ', ' + $r/@d_nombres"/>
				<qry:attribute name="d_apellido" value="$r/@d_apellido"/>
				<qry:attribute name="d_nombres" value="$r/@d_nombres"/>
				<qry:attribute name="f_nacim" value="format_date($r/@f_nacim,'dd/mm/yyyy')"/>
				<qry:attribute name="edad" value="FLOOR((Number(now()) - Number(Datetime($r/@f_nacim))) DIV 365)"/>
				<qry:attribute name="oi_cv" value="$r/@oi_cv"/>
				<qry:attribute value="$r/@localidad_residencia" name="localidad_residencia"/>
				<qry:attribute value="$r/@provincia_residencia" name="provincia_residencia"/>
				<qry:attribute value="$r/@pais_residencia" name="pais_residencia"/>
				<qry:attribute value="$r/@d_estado_civil" name="d_estado_civil"/>
				<qry:attribute name="d_idioma" value="$r/@d_idioma"/>
				<qry:attribute name="c_sexo" value="iif($r/@c_sexo ='M', 'Masculino', iif($r/@c_sexo ='F','Femenino','Sin Especificar'))"/>
				<qry:attribute name="c_nro_cuil" value="$r/@c_nro_cuil"/>
				<qry:attribute name="d_email" value="$r/@d_email"/>
				<qry:attribute name="te_celular" value="$r/@c_area_cel + ' - 15' + $r/@te_celular"/>
				<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
				<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento"/>
				<qry:attribute value="$r/@c_codigo_postal" name="c_codigo_postal"/>
				<qry:attribute name="d_domicilio" value="$r/@d_domicilio"/>
				<qry:attribute name="te_nro" value="$r/@c_area + ' -' + format_number($r/@te_nro,'#########')"/>
				<qry:attribute name="oi_foto" value="iif($r/@oi_foto!='','./NomadFile.aspx?mode=DB&amp;class=NucleusRH.Base.SeleccionDePostulantes.DocumentosDigitales.HEAD&amp;height=110&amp;id='+$r/@oi_foto,'no')"/>
				<qry:switch test="$r/@c_lic_conduc">
					<qry:case value="N">
						<qry:attribute name="c_lic_conduc" value="'No'"/>
					</qry:case>
					<qry:case value="S">
						<qry:attribute name="c_lic_conduc" value="'Si'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="c_lic_conduc" value="''"/>
					</qry:default>
				</qry:switch>
				<qry:switch test="$r/@c_vehiculo">
					<qry:case value="N">
						<qry:attribute name="c_vehiculo" value="'No'"/>
					</qry:case>
					<qry:case value="S">
						<qry:attribute name="c_vehiculo" value="'Si'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="c_vehiculo" value="''"/>
					</qry:default>
				</qry:switch>
				<qry:switch test="$r/@c_radicarse">
					<qry:case value="NO">
						<qry:attribute name="c_radicarse" value="'No'"/>
					</qry:case>
					<qry:case value="NA">
						<qry:attribute name="c_radicarse" value="'Solo Nacional'"/>
					</qry:case>
					<qry:case value="EX">
						<qry:attribute name="c_radicarse" value="'Nacional y Extranjero'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="c_radicarse" value="''"/>
					</qry:default>
				</qry:switch>
				<qry:switch test="$r/@c_viajar">
					<qry:case value="NO">
						<qry:attribute name="c_viajar" value="'No'"/>
					</qry:case>
					<qry:case value="NA">
						<qry:attribute name="c_viajar" value="'Solo Nacional'"/>
					</qry:case>
					<qry:case value="EX">
						<qry:attribute name="c_viajar" value="'Nacional y Extranjero'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="c_viajar" value="''"/>
					</qry:default>
				</qry:switch>
				<qry:attribute name="d_tipo_jor_lab" value="$r/@d_tipo_jor_lab"/>
				<qry:attribute name="d_sit_laboral" value="$r/@d_sit_laboral"/>
				<qry:attribute name="n_remuneracion" value="iif($r/@n_remuneracion !='', format_number($r/@n_remuneracion, '$#####.00'), '')"/>
				<qry:attribute name="chkDatosPersonales" value="#PARAM:@chkDatosPersonales"/>
				<qry:attribute name="chkDatosReferenciales" value="#PARAM:@chkDatosReferenciales"/>
				<qry:attribute name="chkEstudios" value="#PARAM:@chkEstudios"/>
				<qry:attribute name="chkIdiomas" value="#PARAM:@chkIdiomas"/>
				<qry:attribute name="chkCursos" value="#PARAM:@chkCursos"/>
				<qry:attribute name="chkConocimientos" value="#PARAM:@chkConocimientos"/>
				<qry:attribute name="chkPostulaciones" value="#PARAM:@chkpostulaciones"/>
				<qry:attribute name="chkDatosFam" value="#PARAM:@chkDatosFam"/>
				<qry:attribute name="chkDatosPrincipales" value="#PARAM:@chkDatosPrincipales"/>
				<qry:insert-select doc-path="$r" name="qry_foto_per"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_domicilio">
			<qry:xquery>
				for $r in sql('
				SELECT 
					PER09_TIPOS_DOMIC.d_tipo_domicilio, 
					ORG19_LOCALIDADES.d_localidad, 
					PER01_DOMIC_PER.d_calle, 
					PER01_DOMIC_PER.e_numero, 
					PER01_DOMIC_PER.d_piso, 
					PER01_DOMIC_PER.d_departamento, 
					PER01_DOMIC_PER.te_1				
				FROM 
					PER01_DOMIC_PER, 
					PER01_PERSONAL, 
					ORG19_LOCALIDADES, 
					PER09_TIPOS_DOMIC, 
					PER02_PERSONAL_EMP				
				JOIN 
					PER01_DOMIC_PER.oi_personal INNER PER01_PERSONAL.oi_personal,
					PER09_TIPOS_DOMIC.oi_tipo_domicilio INNER PER01_DOMIC_PER.oi_tipo_domicilio,
					PER01_PERSONAL.oi_personal INNER PER01_DOMIC_PER.oi_personal,
					ORG19_LOCALIDADES.oi_localidad RIGHT OUTER PER01_DOMIC_PER.oi_localidad,
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Domicilio">
					<qry:attribute name="d_tipo_domicilio" value="$r/@d_tipo_domicilio"/>
					<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
					<qry:attribute name="d_calle" value="$r/@d_calle"/>
					<qry:attribute name="e_numero" value="$r/@e_numero"/>
					<qry:attribute name="d_piso" value="$r/@d_piso"/>
					<qry:attribute name="d_departamento" value="$r/@d_departamento"/>
					<qry:attribute name="te_1" value="$r/@te_1"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_estudios">
			<qry:xquery>
				for $r in SQL('
					SELECT 
						ORG43.d_area_est as d_area_est,
						org35.d_pais as d_pais,
						PER12.d_nivel_estudio as d_nivel_estudio,
						SDP01.c_estado,
						SDP01.d_otro_est_educ as d_otro_est_educ, 
						SDP01.f_actualiz as f_actualiz, 
						SDP01.o_estudio as o_estudio,
						SDP01.d_localidad,
						SDP01.d_institucion,
						SDP01.d_nom_carrera,
						EST.d_estudio
						
					FROM 
						SDP01_ESTUDIOS_CV AS SDP01, 
						SDP01_CV AS CV,
						PER12_NIVELES_EST AS PER12,	
						ORG35_PAISES AS ORG35,
						ORG43_AREAS_EST AS ORG43,
						ORG35_PROVINCIAS AS PROV,
						ORG11_ESTUDIOS AS EST
					JOIN
						SDP01.oi_area_est LEFT OUTER ORG43.oi_area_est,
						SDP01.oi_nivel_estudio LEFT OUTER PER12.oi_nivel_estudio,					
						CV.oi_cv LEFT OUTER SDP01.oi_cv,
						SDP01.oi_estudio LEFT OUTER EST.oi_estudio,
						CV.oi_provincia LEFT OUTER PROV.oi_provincia,
						PROV.oi_pais LEFT OUTER ORG35.oi_pais
					WHERE 
						SDP01.oi_cv = {#PARAM:@id}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Estudio">
					<qry:switch test="@c_estado">
						<qry:case value="1">
							<qry:attribute name="c_estado" value="'Completo'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_estado" value="'Incompleto'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_estado" value="'En Curso'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="d_area_est" value="$r/@d_area_est"/>
					<qry:attribute name="d_pais" value="$r/@d_pais"/>
					<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
					<qry:attribute name="d_nom_carrera" value="$r/@d_nom_carrera"/>
					<qry:attribute name="d_estudio" value="iif($r/@d_estudio!='',$r/@d_estudio,$r/@d_otro_est_educ)"/>
					<qry:attribute name="d_institucion" value="$r/@d_institucion"/>
					<qry:attribute name="d_nivel_estudio" value="$r/@d_nivel_estudio"/>
					<qry:attribute value="$r/@d_otro_est_educ" name="d_otro_est_educ"/>
					<qry:attribute value="format_date($r/@f_actualiz,'dd/mm/yyyy')" name="f_actualiz"/>
					<qry:attribute value="$r/@o_estudio" name="o_estudio"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_idiomas">
			<qry:xquery>
				for $r in sql('
			SELECT
				SDP01.c_nivel_habla as Habla,
				SDP01.c_nivel_lee as Lee,
				SDP01.c_nivel_escribe as Escribe,
				ORG20.d_idioma AS d_idioma
			FROM
				SDP01_IDIOMAS_CV AS SDP01,
				ORG20_IDIOMAS AS ORG20
			JOIN
				ORG20.oi_idioma RIGHT OUTER SDP01.oi_idioma
			WHERE
				SDP01.oi_cv = {#PARAM:@id}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Idioma">
					<qry:switch test="$r/@Habla">
						<qry:case value="1">
							<qry:attribute name="Habla" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="Habla" value="'Intermedio'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="Habla" value="'Avanzado'"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@Lee">
						<qry:case value="1">
							<qry:attribute name="Lee" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="Lee" value="'Intermedio'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="Lee" value="'Avanzado'"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@Escribe">
						<qry:case value="1">
							<qry:attribute name="Escribe" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="Escribe" value="'Intermedio'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="Escribe" value="'Avanzado'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="d_idioma" value="$r/@d_idioma"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_experiencias" doc="PARAM">
			<qry:xquery>
				for $r in sql('
					SELECT 
						SDP01.d_empresa,
						SDP01.f_ingreso, 
						SDP01.f_egreso, 
						EXP.d_puesto_exp,
						SDP01.o_contacto, 
						SDP01.d_actividad,
						SDP01.l_per_cargo,
						SDP01.n_ultimo_sueldo, 
						SDP01.e_experiencia, 
						SDP01.o_tareas,
						SDP01.d_localidad,
						AEXP.d_area_exp
					FROM
						SDP01_EXPERIENCIA AS SDP01,
						SDP09_PUESTO_EXP AS EXP,
						SDP18_AREAS_EXP AS AEXP
					JOIN
						SDP01.oi_puesto_exp LEFT OUTER EXP.oi_puesto_exp,
						SDP01.oi_area_exp LEFT OUTER AEXP.oi_area_exp
					WHERE 
						SDP01.oi_cv =  {#PARAM:@id}	
					ORDER BY
						f_ingreso ASC	
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Experiencia">
					<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
					<qry:attribute name="d_puesto_exp" value="$r/@d_puesto_exp"/>
					<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
					<qry:attribute name="o_contacto" value="$r/@o_contacto"/>
					<qry:attribute name="l_per_cargo" value="iif($r/@l_per_cargo='1', 'Si', 'No')"/>
					<qry:attribute name="d_actividad" value="$r/@d_actividad"/>
					<qry:attribute name="d_area_exp" value="$r/@d_area_exp"/>
					<qry:attribute value="format_date($r/@f_ingreso,'dd/mm/yyyy')" name="f_ingreso"/>
					<qry:attribute value="format_date($r/@f_egreso,'dd/mm/yyyy')" name="f_egreso"/>
					<qry:attribute name="n_ultimo_sueldo" value="'$ ' + $r/@n_ultimo_sueldo"/>
					<qry:attribute name="e_experiencia" value="$r/@e_experiencia"/>
					<qry:attribute name="o_tareas" value="$r/@o_tareas"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_conocimientos" doc="PARAM">
			<qry:xquery>
				for $r in sql('
				SELECT 
				CON.d_informatica as d_informatica, 
				C_V.c_nivel as c_nivel 
			
			FROM 
				SDP01_INFORMATICA AS C_V,
				SDP08_INFORMATICA AS CON
			JOIN
				con.oi_informatica INNER c_v.oi_informatica
			WHERE 
				C_V.oi_cv= {#PARAM:@id}

			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Conocimiento">
					<qry:attribute name="d_informatica" value="$r/@d_informatica"/>
					<qry:switch test="$r/@c_nivel">
						<qry:case value="1">
							<qry:attribute name="c_nivel" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_nivel" value="'Intermedio'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_nivel" value="'Avanzado'"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_postulaciones">
			<qry:xquery>
				for $r in sql('
			SELECT 
				P_CV.f_postulacion, 
				SDP05.c_aviso, 
				SDP05.d_puesto as d_puesto,
				SDP07.d_jerarquia as d_jerarquia,
				SDP09.d_area as d_area, 
				loc.d_localidad as d_localidad,
				pro.d_provincia as d_provincia, 
				PAIS.d_pais as d_pais,
				SDP05.c_sexo as c_sexo, 
				SDP05.d_mail as d_mail, 
				SDP05.d_mail_alt_1 as d_mail_alt_1
				
			FROM 
				SDP01_POSTU_CV AS P_CV,
				SDP05_AVISOS AS SDP05,
				SDP07_JERARQUIA AS SDP07,
				SDP09_AREAS AS SDP09,
				ORG19_LOCALIDADES AS LOC,
				ORG35_PROVINCIAS AS PRO,
				ORG35_PAISES AS PAIS
			JOIN 
				SDP05.oi_aviso INNER P_CV.oi_aviso,
				SDP07.oi_jerarquia INNER SDP05.oi_jerarquia,
				SDP09.oi_area INNER SDP05.oi_area,
				SDP05.oi_pais INNER PAIS.oi_pais,
				SDP05.oi_provincia LEFT OUTER PRO.oi_provincia,
				SDP05.oi_localidad LEFT OUTER LOC.oi_localidad 		
			WHERE
				P_CV.oi_cv= {#PARAM:@id}
	
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="Postulacion">
					<qry:attribute name="Aviso" value="$r/@d_puesto"/>
					<qry:attribute name="Fecha_Postulacion" value="format_date($r/@f_postulacion,'dd/mm/yyyy')"/>
					<qry:attribute name="Jerarquia" value="$r/@d_jerarquia"/>
					<qry:attribute name="Area_laboral" value="$r/@d_area"/>
					<qry:attribute name="Localidad" value="$r/@d_localidad"/>
					<qry:attribute name="Provincia" value="$r/@d_provincia"/>
					<qry:attribute name="Pais" value="$r/@d_pais"/>
					<qry:attribute name="Mail" value="$r/@d_mail"/>
					<qry:attribute name="Mail_alternativo" value="$r/@d_mail_alt_1"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_areasinteres">
			<qry:xquery>
				for $r in sql('
			SELECT 
				SDP09_AREAS.d_area
			FROM 
				SDP01_AREAS_CV,
