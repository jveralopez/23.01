	<html:xslt>
		<xsl:template match="T0" name="T0">
			<xsl:param name="template"/>
			<xsl:param name="source"/>
			<xsl:if test="$template='oi_doc_digital'">
				<xsl:call-template name="T1">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template='foto'">
				<xsl:call-template name="T2">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template='cv'">
				<xsl:call-template name="T3">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template=''">
				No tiene CV
			</xsl:if>
		</xsl:template>
		<xsl:template match="T1" name="T1">
			<xsl:param name="source"/>
			<xsl:if test="$source/@oi_doc_digital != 'No'">
				Si
			</xsl:if>
			<xsl:if test="$source/@oi_doc_digital = 'No'">
				No
			</xsl:if>
		</xsl:template>
		<xsl:template match="T2" name="T2">
			<xsl:param name="source"/>
			<xsl:if test="$source/@foto != 'No'">
				Si
			</xsl:if>
			<xsl:if test="$source/@foto = 'No'">
				No
			</xsl:if>
		</xsl:template>
		<xsl:template match="T3" name="T3">
			<xsl:param name="source"/>
			<a href="" target="_blank">
				<xsl:attribute name="href">
					<xsl:value-of select="$source/@cv"/>
				</xsl:attribute>
				<xsl:value-of select="$source/@c_cv"/>
			</a>
		</xsl:template>
	</html:xslt>
</html:html>
