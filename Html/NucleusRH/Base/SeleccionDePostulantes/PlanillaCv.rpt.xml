						<qry:else>
							<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="cod_postal" value="$r/@c_codigo_postal"/>
					<qry:attribute name="telefono" value="$r/@c_pais + ' ' + $r/@c_area + ' ' + $r/@te_nro"/>
					<qry:attribute name="te_celular" value="$r/@c_pais_cel + ' ' + $r/@c_area_cel + ' ' + $r/@te_celular"/>
					<qry:attribute name="d_mail" value="$r/@d_email"/>
					<qry:attribute name="c_estado" value="$r/@c_estado"/>
					<qry:attribute name="o_cv" value="$r/@o_cv"/>
