							<qry:attribute name="c_estado" value="'Contratado'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="n_remuneracion" value="iif($r/@n_remuneracion !='', format_number($r/@n_remuneracion, '$#####.00'), '')"/>
					<qry:attribute name="c_viajar" value="iif($r/@viajar='1', 'Si', 'No')"/>
					<qry:attribute name="c_radicarse" value="iif($r/@l_radicarse='1', 'Si', 'No')"/>
					<qry:switch test="$r/@c_radicarse">
						<qry:case value="NO">
							<qry:attribute name="c_radicarse" value="'No'"/>
						</qry:case>
						<qry:case value="NA">
							<qry:attribute name="c_radicarse" value="'Solo Nacional'"/>
						</qry:case>
						<qry:case value="EX">
							<qry:attribute name="c_radicarse" value="'Nacional y Extranjero'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_radicarse" value="''"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@c_viajar">
						<qry:case value="NO">
							<qry:attribute name="c_viajar" value="'No'"/>
						</qry:case>
						<qry:case value="NA">
							<qry:attribute name="c_viajar" value="'Solo Nacional'"/>
						</qry:case>
						<qry:case value="EX">
							<qry:attribute name="c_viajar" value="'Nacional y Extranjero'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_viajar" value="''"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@c_lic_conduc">
						<qry:case value="N">
							<qry:attribute name="c_lic_conduc" value="'No'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="c_lic_conduc" value="'Si'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_lic_conduc" value="''"/>
						</qry:default>
					</qry:switch>
					<qry:switch test="$r/@c_vehiculo">
						<qry:case value="N">
							<qry:attribute name="c_vehiculo" value="'No'"/>
						</qry:case>
						<qry:case value="S">
							<qry:attribute name="c_vehiculo" value="'Si'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_vehiculo" value="''"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="sit_laboral" value="$r/@d_sit_laboral"/>
					<qry:attribute name="jor_laboral" value="$r/@d_tipo_jor_lab"/>
					<qry:attribute name="foto" value="iif($r/@oi_foto!='', 'Si', 'No')"/>
					<qry:attribute name="cv" value="concat(#F:@location, 'ReportViewer.aspx?report=', #PROXY:@app,'.NucleusRH.Base.SeleccionDePostulantes.CV.GEN.GADGET&amp;id=',$r/@oi_cv)"/>
					<qry:attribute name="oi_doc_digital" value="iif($r/@oi_doc_digital!='','Si', 'No')"/>
					<qry:attribute name="l_alta_web" value="iif($r/@l_alta_web='1', 'Si', 'No')"/>
					<qry:attribute name="f_postulacion" value="format_date($r/@f_postulacion,'dd/mm/yyyy')"/>
					<qry:attribute name="f_actualizacion" value="format_date($r/@f_actualizacion,'dd/mm/yyyy')"/>
					<qry:attribute name="f_alta_cv" value="format_date($r/@f_alta_cv,'dd/mm/yyyy')"/>
					<qry:insert-select name="QRY_IDIOMA" doc-path="$r"/>
					<qry:attribute name="oi_idioma" value="SUBSTRING(@oi_idioma,1)"/>
					<qry:insert-select name="QRY_NIVEL_EST" doc-path="$r"/>
					<qry:attribute name="oi_nivel_est" value="SUBSTRING(@oi_nivel_est,1)"/>
					<qry:insert-select name="QRY_ESTUDIOS" doc-path="$r"/>
					<qry:attribute name="oi_estudio" value="SUBSTRING(@oi_estudio,1)"/>
					<qry:insert-select name="QRY_AREA_EST" doc-path="$r"/>
					<qry:attribute name="oi_area_est" value="SUBSTRING(@oi_area_est,1)"/>
					<qry:insert-select name="QRY_INFORMATICA" doc-path="$r"/>
					<qry:attribute name="oi_informatica" value="SUBSTRING(@oi_informatica,1)"/>
					<qry:insert-select name="QRY_EXPERIENCIA" doc-path="$r"/>
					<qry:attribute name="oi_experiencia" value="SUBSTRING(@oi_experiencia,1)"/>
					<qry:insert-select name="QRY_AREA_EXPERIENCIA" doc-path="$r"/>
					<qry:attribute name="oi_area_experiencia" value="SUBSTRING(@oi_area_experiencia,1)"/>
					<qry:insert-select name="QRY_AREAS" doc-path="$r"/>
					<qry:attribute name="oi_area" value="SUBSTRING(@oi_area,1)"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_cod_postal">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'cod_postal'"/>
