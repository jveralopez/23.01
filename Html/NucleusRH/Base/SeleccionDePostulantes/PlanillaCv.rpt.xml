<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.SeleccionDePostulantes.PlanillaCV" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;PARAMETERS oi_aviso=&quot;&quot; sexo=&quot;&quot; oi_provincia=&quot;&quot; edad_desde=&quot;&quot; edad_hasta=&quot;&quot; h_edad_desde=&quot;&quot; h_edad_hasta=&quot;&quot; f_desdeact=&quot;20220207&quot; f_hastaact=&quot;20220208&quot; f_desdealta=&quot;&quot; f_hastaalta=&quot;&quot; idioma=&quot;&quot; informatica=&quot;&quot; experiencia=&quot;&quot; area_experiencia=&quot;&quot; estudio=&quot;&quot; area_est=&quot;&quot; area=&quot;&quot; c_nro_cuil=&quot;&quot; c_sexo=&quot;&quot; oi_estado_civil=&quot;&quot; domicilio=&quot;&quot; f_nacim=&quot;1&quot; edad=&quot;1&quot; d_localidad=&quot;&quot; cod_postal=&quot;&quot; telefono=&quot;&quot; te_celular=&quot;&quot; d_mail=&quot;&quot; c_estado=&quot;&quot; n_remuneracion=&quot;&quot; c_lic_conduc=&quot;&quot; c_vehiculo=&quot;&quot; c_viajar=&quot;&quot; c_radicarse=&quot;&quot; sit_laboral=&quot;&quot; jor_laboral=&quot;&quot; oi_foto=&quot;&quot; oi_doc_digital=&quot;&quot; l_alta_web=&quot;&quot; f_postulacion=&quot;0&quot; o_cv=&quot;&quot; oi_idioma=&quot;&quot; oi_informatica=&quot;&quot; oi_nivel_est=&quot;&quot; oi_area_est=&quot;&quot; oi_estudio=&quot;&quot; oi_experiencia=&quot;&quot; oi_area=&quot;&quot; location=&quot;http://nucmaya/Desa186/&quot; /&gt;&#13;&#10;">
		<qry:main doc="PARAM">
			<qry:append-doc name="F" doc-path="#PARAM:PARAMETERS"/>
			<REPORT label="Planilla de CVs">
				<GROUPS>
					<GROUP tag="CAB" type="title">
						<COLS>
							<COL name="f_informe" label="Fecha de Emisi&#243;n"/>
							<qry:if test="#F:@oi_aviso!=''">
								<qry:then>
									<COL name="oi_aviso" label="Postulado a"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@oi_provincia!=''">
								<qry:then>
									<COL name="provincia" label="Provincia"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@edad_desde!=''">
								<qry:then>
									<COL name="edad_desde" label="Edad Desde"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@edad_hasta!=''">
								<qry:then>
									<COL name="edad_hasta" label="Edad Hasta"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@f_desdeact!=''">
								<qry:then>
									<COL name="f_desdeact" label="Fecha Actualizaci&#243;n Desde" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@f_hastaact!=''">
								<qry:then>
									<COL name="f_hastaact" label="Fecha Actualizaci&#243;n Hasta" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@f_desdealta!=''">
								<qry:then>
									<COL name="f_desdealta" label="Fecha Alta CV Desde" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@f_hastaalta!=''">
								<qry:then>
									<COL name="f_hastaalta" label="Fecha Alta CV Hasta" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@idioma!=''">
								<qry:then>
									<COL name="idioma" label="Idioma"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@informatica!=''">
								<qry:then>
									<COL name="informatica" label="Con. Inform&#225;tico"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@experiencia!=''">
								<qry:then>
									<COL name="experiencia" label="Puesto de Experiencia Laboral"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@area_experiencia!=''">
								<qry:then>
									<COL name="area_experiencia" label="&#193;rea de Experiencia Laboral"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@area_est!=''">
								<qry:then>
									<COL name="area_est" label="&#193;rea de Estudio"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@estudio!=''">
								<qry:then>
									<COL name="estudio" label="Nivel de Estudio"/>
								</qry:then>
							</qry:if>
							<qry:if test="#F:@area!=''">
								<qry:then>
									<COL name="area" label="&#193;rea de Inter&#233;s"/>
								</qry:then>
							</qry:if>
						</COLS>
						<GROUP tag="CV" type="table">
							<COLS>
								<qry:insert-select doc-path="#F:" name="qry_c_cv"/>
								<qry:insert-select doc-path=".[#F:@c_nro_documento=1 OR #F:@c_nro_documento='']" name="qry_doc"/>
								<COL name="d_ape_y_nom" nowrap="1" label="Apellido y Nombre" style=" width:50%"/>
								<qry:insert-select doc-path=".[#F:@c_nro_cuil=1]" name="qry_c_nro_cuil"/>
								<qry:insert-select doc-path=".[#F:@c_sexo=1]" name="qry_sexo"/>
								<qry:insert-select doc-path=".[#F:@f_nacim=1]" name="qry_f_nacim"/>
								<qry:insert-select doc-path=".[#F:@edad=1]" name="qry_edad"/>
								<qry:insert-select doc-path=".[#F:@oi_estado_civil=1]" name="qry_oi_estado_civil"/>
								<qry:insert-select doc-path=".[#F:@domicilio=1]" name="qry_domicilio"/>
								<qry:insert-select doc-path=".[#F:@d_localidad=1]" name="qry_oi_localidad"/>
								<qry:insert-select doc-path=".[#F:@cod_postal=1]" name="qry_cod_postal"/>
								<qry:insert-select doc-path=".[#F:@telefono=1]" name="qry_telefono"/>
								<qry:insert-select doc-path=".[#F:@te_celular=1]" name="qry_te_celular"/>
								<qry:insert-select doc-path=".[#F:@d_mail=1]" name="qry_d_email"/>
								<qry:insert-select doc-path=".[#F:@c_estado=1]" name="qry_c_estado"/>
								<qry:insert-select doc-path=".[#F:@oi_foto=1]" name="qry_oi_foto"/>
								<qry:insert-select doc-path=".[#F:@oi_doc_digital=1]" name="qry_oi_doc_digital"/>
								<qry:insert-select doc-path=".[#F:@n_remuneracion=1]" name="qry_remuneracion"/>
								<qry:insert-select doc-path=".[#F:@l_alta_web=1]" name="qry_l_alta_web"/>
								<qry:insert-select doc-path=".[#F:@c_lic_conduc=1]" name="qry_c_lic_conduc"/>
								<qry:insert-select doc-path=".[#F:@c_radicarse=1]" name="qry_c_radicarse"/>
								<qry:insert-select doc-path=".[#F:@c_vehiculo=1]" name="qry_c_vehiculo"/>
								<qry:insert-select doc-path=".[#F:@c_viajar=1]" name="qry_c_viajar"/>
								<qry:insert-select doc-path=".[#F:@jor_laboral=1]" name="qry_jor_laboral"/>
								<qry:insert-select doc-path=".[#F:@sit_laboral=1]" name="qry_sit_laboral"/>
								<qry:if test="#F:@f_desdeact!='' OR #F:@f_hastaact!=''">
									<qry:then>
										<COL name="f_actualizacion" label="Fecha Actualizaci&#243;n" type="date"/>
									</qry:then>
								</qry:if>
								<qry:if test="#F:@f_desdealta!='' OR #F:@f_hastaalta!=''">
									<qry:then>
										<COL name="f_alta_cv" label="Fecha Alta" type="date"/>
									</qry:then>
								</qry:if>
								<qry:insert-select doc-path=".[#F:@f_postulacion=1]" name="qry_f_postulacion"/>
								<qry:insert-select doc-path=".[#F:@oi_idioma=1]" name="qry_oi_idioma"/>
								<qry:insert-select doc-path=".[#F:@oi_nivel_est=1]" name="qry_oi_nivel_est"/>
								<qry:insert-select doc-path=".[#F:@oi_area_est=1]" name="qry_oi_area_est"/>
								<qry:insert-select doc-path=".[#F:@oi_estudio=1]" name="qry_oi_estudio"/>
								<qry:insert-select doc-path=".[#F:@oi_informatica=1]" name="qry_oi_informatica"/>
								<qry:insert-select doc-path=".[#F:@oi_experiencia=1]" name="qry_oi_experiencia"/>
								<qry:insert-select doc-path=".[#F:@oi_experiencia=1]" name="qry_oi_area_experiencia"/>
								<qry:insert-select doc-path=".[#F:@oi_area=1]" name="qry_oi_area"/>
								<qry:insert-select doc-path=".[#F:@o_cv=1]" name="qry_o_cv"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="CAB">
						<qry:attribute name="FechaEmision" value="format_date(now(),'dd/mm/yyyy HH:MM')"/>
						<qry:attribute name="fecha" value="string(datetime(format_date(now(), 'yyyymmdd')))"/>
						<qry:attribute value="#F:@edad_desde" name="edad_desde"/>
						<qry:attribute value="#F:@edad_hasta" name="edad_hasta"/>
						<qry:attribute name="h_edad_desde" value="iif(#F:@edad_desde!='',number(@fecha)-number(#F:@edad_desde)*10000,'')"/>
						<qry:attribute name="h_edad_hasta" value="iif(#F:@edad_hasta!='',number(@fecha)-(number(#F:@edad_hasta)*10000+9999),'')"/>
						<qry:append-doc name="FECHAS" doc-path="."/>
						<qry:attribute value="format_date(#F:@f_desdeact, 'dd/mm/yyyy')" name="f_desdeact"/>
						<qry:attribute value="format_date(#F:@f_hastaact, 'dd/mm/yyyy')" name="f_hastaact"/>
						<qry:attribute value="format_date(#F:@f_desdealta, 'dd/mm/yyyy')" name="f_desdealta"/>
						<qry:attribute value="format_date(#F:@f_hastaalta, 'dd/mm/yyyy')" name="f_hastaalta"/>
						<qry:insert-select doc-path="#PARAM:PARAMETERS" name="QRY_PROVINCIA"/>
						<qry:insert-select doc-path="#PARAM:PARAMETERS" name="QRY_POSTULADOS"/>
						<qry:insert-select doc-path="#PARAM:PARAMETERS" name="QRY_CV"/>
						<qry:if test="#F:@idioma!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="IDIOMA"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@informatica!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="INFORMATICA"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@experiencia!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="EXPERIENCIA"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@area_experiencia!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="AREA_EXPERIENCIA"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@estudio!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="ESTUDIO"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@area_est!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="AREA_EST"/>
							</qry:then>
						</qry:if>
						<qry:if test="#F:@area!=''">
							<qry:then>
								<qry:insert-select doc-path="#PARAM:PARAMETERS" name="AREA"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="qry_c_nro_cuil">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'c_nro_cuil'"/>
					<qry:attribute name="label" value="'CUIL'"/>
					<qry:attribute name="style" value="'width:10%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_doc">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'c_nro_documento'"/>
					<qry:attribute name="label" value="'Documento'"/>
					<qry:attribute name="style" value="'width:15%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_sexo">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'c_sexo'"/>
					<qry:attribute name="label" value="'Sexo'"/>
					<qry:attribute name="style" value="'width:15%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_oi_estado_civil">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'oi_estado_civil'"/>
					<qry:attribute name="label" value="'Estado Civil'"/>
					<qry:attribute name="style" value="' width:15%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_oi_localidad">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'d_localidad'"/>
					<qry:attribute name="label" value="'Localidad de Residencia'"/>
					<qry:attribute name="style" value="' width:25%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_d_email">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'d_mail'"/>
					<qry:attribute name="label" value="'Mail'"/>
					<qry:attribute name="style" value="' width:20%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_te_celular">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'te_celular'"/>
					<qry:attribute name="label" value="'Celular'"/>
					<qry:attribute name="style" value="'text-align:center;width:15%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_oi_foto">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'foto'"/>
					<qry:attribute name="label" value="'Foto'"/>
					<qry:attribute name="style" value="' width:10%'"/>
					<qry:attribute name="type" value="'template'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_c_cv">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'cv'"/>
					<qry:attribute name="label" value="'C&#243;digo CV'"/>
					<qry:attribute name="style" value="' width:10%'"/>
					<qry:attribute name="type" value="'template'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_auxattr">
			<qry:xquery>
				for $r in sql('
			SELECT 
				ORG40_ATRIB_AUX.oi_atrib_aux, 
				ORG40_ATRIB_AUX.c_atrib_aux,
				ORG40_ATRIB_AUX.d_atrib_aux
			FROM 
				ORG40_ATRIB_AUX, 
				ORG40_CLASES_AUX
			JOIN 
				ORG40_ATRIB_AUX.oi_clase_aux INNER ORG40_CLASES_AUX.oi_clase_aux
			WHERE 
				ORG40_CLASES_AUX.c_clase_aux = \'PER\'
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="$r/@c_atrib_aux"/>
					<qry:attribute name="label" value="$r/@d_atrib_aux"/>
					<!--qry:attribute name="style" value="'width:10%'"/-->
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_domicilio">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'domicilio'"/>
					<qry:attribute name="label" value="'Domicilio'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_telefono">
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'telefono'"/>
					<qry:attribute name="label" value="'Tel&#233;fono'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PROVINCIA">
			<qry:xquery>
				for $r in sql('
					SELECT 
						ORG35_PROVINCIAS.oi_provincia, ORG35_PROVINCIAS.c_provincia,
						ORG35_PROVINCIAS.d_provincia
					FROM 
						ORG35_PROVINCIAS					 
					{%? (#F:@oi_provincia != '') {% WHERE ORG35_PROVINCIAS.oi_provincia = {#F:@oi_provincia} %} {% %} %}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="f_informe"/>
				<qry:attribute name="oi_provincia" value="$r/@oi_provincia"/>
				<qry:attribute name="c_provincia" value="$r/@c_provincia"/>
				<qry:attribute name="d_provincia" value="$r/@d_provincia"/>
				<qry:attribute name="provincia" value="$r/@c_provincia + ' - ' +$r/@d_provincia"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_CV">
			<qry:xquery>
				for $r in sql('  
		SELECT 
			CV.oi_cv,
			CV.c_cv, 
			CV.d_ape_y_nom as d_ape_y_nom,
			CV.f_actualizacion,
			CV.f_alta_cv,
			CV.oi_provincia,
			CV.o_cv
			{%? (#F:@c_nro_documento ='1' OR #F:@c_nro_documento ='') {% ,PER20_TIPOS_DOC.c_tipo_documento, CV.c_nro_doc %} {% %} %}
			{%? (#F:@c_nro_cuil ='1') {% , CV.c_nro_cuil %} {% %} %}
			{%? (#F:@c_sexo ='1') {% , CV.c_sexo %} {% %} %}
			{%? (#F:@oi_estado_civil ='1'){% , ORG22_EST_CIVIL.d_estado_civil %} {% %} %}		
			{%? (#F:@domicilio ='1') {% , CV.d_calle, CV.c_nro, CV.c_piso, CV.c_departamento %} {% %} %}
			{%? (#F:@d_localidad ='1') {% , CV.d_localidad, CV.oi_localidad, LOC.d_localidad as localidad %} {% %} %}
			{%? (#F:@cod_postal ='1') {% , CV.c_codigo_postal %} {% %} %}
			{%? (#F:@telefono ='1')  {% , CV.c_pais, CV.c_area, CV.te_nro %} {% %} %}
			{%? (#F:@te_celular ='1') {% , CV.c_pais_cel, CV.c_area_cel, CV.te_celular %} {% %} %}
			{%? (#F:@d_mail ='1') {% , CV.d_email %} {% %} %}
			{%? (#F:@c_estado ='1') {% , CV.c_estado %} {% %} %}
			{%? (#F:@oi_foto ='1')   {% , CV.oi_foto %} {% %} %}
		 	{%? (#F:@oi_doc_digital ='1')   {% , CV.oi_doc_digital %} {% %} %}
		 	{%? (#F:@l_alta_web ='1') {% , CV.l_alta_web %} {% %} %}     
		 	{%? (#F:@f_postulacion ='1') {% , SDP01_POSTU_CV.f_postulacion %} {% %} %}
		 	{%? (#F:@f_nacim ='1' OR #F:@f_nacim='0') {% , CV.f_nacim %} {% %} %}
		 	{%? (#F:@c_lic_conduc ='1') {% , CV.c_lic_conduc %} {% %} %}
		 	{%? (#F:@c_radicarse ='1') {% , CV.c_radicarse %} {% %} %}
		 	{%? (#F:@c_viajar ='1') {% , CV.c_viajar %} {% %} %}
		 	{%? (#F:@c_vehiculo ='1') {% , CV.c_vehiculo %} {% %} %}
		 	{%? (#F:@n_remuneracion ='1') {% , CV.n_remuneracion %} {% %} %}
		 	{%? (#F:@sit_laboral ='1') {% , SDP17_SIT_LABORALES.d_sit_laboral %} {% %} %}
		 	{%? (#F:@jor_laboral ='1') {% , SDP16_TIPOS_JORNADA.d_tipo_jor_lab %} {% %} %}		
		FROM 
			SDP01_CV AS CV
			{%? (#F:@d_localidad ='1')
				{% , ORG19_LOCALIDADES AS LOC %} 
				{% %} 
			%}
			{%? (#F:@c_nro_documento ='1' OR #F:@c_nro_documento ='')
				{% , PER20_TIPOS_DOC %} 
				{% %} 
			%}
			{%? (#F:@oi_aviso !='')
				{% , SDP01_POSTU_CV %} 
				{% %} 
			%}
			{%? (#F:@oi_estado_civil ='1' OR #F:@oi_estado_civil ='')
				{% , ORG22_EST_CIVIL %} 
				{% %} 
			%}
			{%? (#F:@oi_tipo_jor_lab ='1' OR #F:@oi_tipo_jor_lab ='')
				{% , SDP16_TIPOS_JORNADA %}
				{% %} 
			%}
			{%? (#f:@oi_sit_laboral = '1' OR #F:@oi_sit_laboral ='')
				{% , SDP17_SIT_LABORALES %}
				{% %}
			%}
			{%? (#F:@idioma !='')
				{% , SDP01_IDIOMAS_CV %} 
				{% %} 
			%}
			{%? (#F:@informatica !='')
				{% , SDP01_INFORMATICA %} 
				{% %} 
			%}
			{%? (#F:@experiencia !='' or #F:@area_experiencia !='')
				{% , SDP01_EXPERIENCIA, SDP18_AREAS_EXP%} 
				{% %} 
			%}
			{%? (#F:@estudio !='' OR #F:@area_est !='' )
				{% , SDP01_ESTUDIOS_CV %} 
				{% %} 
			%}
			{%? (#F:@area !='')
				{% , SDP01_AREAS_CV %} 
				{% %} 
			%}  				
		JOIN 
			
			{%? (#F:@c_nro_documento ='1' OR #F:@c_nro_documento ='') 
				{% CV.oi_tipo_documento LEFT OUTER PER20_TIPOS_DOC.oi_tipo_documento %} 
				{% %} 
			%}
			{%? (#F:@oi_aviso !='' ) 
				{% ,CV.oi_cv LEFT OUTER SDP01_POSTU_CV.oi_cv %} 
				{% %} 
			%}
			{%? (#F:@oi_estado_civil ='1' OR #F:@oi_estado_civil ='')
				{% ,CV.oi_estado_civil LEFT OUTER ORG22_EST_CIVIL.oi_estado_civil %} 
				{% %} 
			%}
			{%? (#F:@oi_tipo_jor_lab ='1' OR #F:@oi_tipo_jor_lab ='')
				{% ,CV.oi_tipo_jor_lab LEFT OUTER SDP16_TIPOS_JORNADA.oi_tipo_jor_lab %}
				{% %}
			%}
			{%? (#F:@oi_sit_laboral ='1' OR #F:@oi_sit_laboral ='')
				{% ,CV.oi_sit_laboral LEFT OUTER SDP17_SIT_LABORALES.oi_sit_laboral %}
				{% %}
			%}
			{%? (#F:@idioma !='')
				{% , CV.oi_cv INNER SDP01_IDIOMAS_CV.oi_cv %} 
				{% %} 
			%}
			{%? (#F:@informatica !='')
				{% , CV.oi_cv INNER SDP01_INFORMATICA.oi_cv %} 
				{% %} 
			%}
			{%? (#F:@experiencia !='' or #F:@area_experiencia !='')
				{% , CV.oi_cv INNER SDP01_EXPERIENCIA.oi_cv
					 , SDP01_EXPERIENCIA.oi_area_exp LEFT OUTER SDP18_AREAS_EXP.oi_area_exp %} 
				{% %} 
			%}
			{%? (#F:@estudio !='' OR #F:@area_est !='' )
				{% , CV.oi_cv INNER SDP01_ESTUDIOS_CV.oi_cv %} 
				{% %} 
			%}
			{%? (#F:@area !='')
				{% , CV.oi_cv INNER SDP01_AREAS_CV.oi_cv %} 
				{% %} 
			%}	
			{%? (#F:@d_localidad ='1')
				{% , CV.oi_localidad LEFT OUTER LOC.oi_localidad %} 
				{% %} 
			%}
		WHERE 1=1
			{%? (#F:@oi_provincia!='') 
  			{% AND CV.oi_provincia = {#F:@oi_provincia} 
  			%} 
  			{%  %}
 			%}
 			{%? (#F:@sexo!='') 
  			{% AND CV.c_sexo= {#F:@sexo} 
  			%} 
  			{%  %}
 			%}
 			{%? (#F:@oi_aviso!='') 
  			{% AND SDP01_POSTU_CV.oi_aviso = {#F:@oi_aviso} 
  			%} 
  			{%  %}
 			%}       
			{%?(#FECHAS:@h_edad_desde!='') 
			
				{% and CV.f_nacim &lt;= {Datetime(#FECHAS:@h_edad_desde)} %} 
				{% %} 
			%}
			{%?(#FECHAS:@h_edad_hasta!='') 
				{% and CV.f_nacim &gt;= {Datetime(#FECHAS:@h_edad_hasta)} %} 
				{% %} 
			%}
				
			{%? (#F:@f_desdeact!='') 
  			{% AND CV.f_actualizacion &gt;= {Datetime(#F:@f_desdeact)} 
  			%} 
  			{%  %}
 			%}
      {%? (#F:@f_hastaact!='') 
  			{% AND CV.f_actualizacion &lt;= {Datetime(#F:@f_hastaact)} 
  			%} 
  			{%  %}
  		%}
  		{%? (#F:@f_desdealta!='') 
  			{% AND CV.f_alta_cv &gt;= {Datetime(#F:@f_desdealta)} 
  			%} 
  			{%  %}
 			%}
      {%? (#F:@f_hastaalta!='') 
  			{% AND CV.f_alta_cv &lt;= {Datetime(#F:@f_hastaalta)} 
  			%} 
  			{%  %}
  		%}
  		{%? (#F:@idioma !='')
				{% AND SDP01_IDIOMAS_CV.oi_idioma = {#F:@idioma}  %} 
				{% %} 
			%}
			{%? (#F:@informatica !='')
				{% AND SDP01_INFORMATICA.oi_informatica = {#F:@informatica}  %} 
				{% %} 
			%}
			{%? (#F:@experiencia !='')
				{% AND SDP01_EXPERIENCIA.oi_puesto_exp = {#F:@experiencia}   %} 
				{% %} 
			%}  
			{%? (#F:@area_experiencia !='')
				{% AND SDP01_EXPERIENCIA.oi_area_exp = {#F:@area_experiencia}  %} 
				{% %} 
			%}
			{%? (#F:@estudio !='')
				{% AND SDP01_ESTUDIOS_CV.oi_nivel_estudio = {#F:@estudio}  %} 
				{% %} 
			%}
			{%? (#F:@area_est !='')
				{% AND SDP01_ESTUDIOS_CV.oi_area_est = {#F:@area_est}  %} 
				{% %} 
			%}
			{%? (#F:@area !='')
				{% AND SDP01_AREAS_CV.oi_area = {#F:@area}  %} 
				{% %} 
			%}      			
		 ORDER BY
				d_ape_y_nom ASC
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CV">
					<qry:attribute name="oi_cv" value="$r/@oi_cv"/>
					<qry:attribute name="c_cv" value="$r/@c_cv"/>
					<qry:attribute name="c_nro_documento" value="$r/@c_tipo_documento + ' ' + $r/@c_nro_doc"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
