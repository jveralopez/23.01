					<qry:attribute name="name" value="'oi_idioma'"/>
					<qry:attribute name="label" value="'Idiomas'"/>
					<qry:attribute name="style" value="' width:15%'"/>
					<qry:attribute name="nowrap" value="'1'"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_IDIOMA">
			<qry:xquery>
				for $r in sql('
			maxsize 4		
					SELECT 
						CV.oi_cv,
						IDIOMA.c_idioma,
						IDIOMA.d_idioma,
						CV.oi_idioma_cv as oi_idioma_cv
					FROM 
						SDP01_IDIOMAS_CV AS CV, 
						ORG20_IDIOMAS AS IDIOMA
					JOIN
						CV.oi_idioma INNER IDIOMA.oi_idioma
					WHERE
						CV.oi_cv = {#PARAM:@oi_cv}
					ORDER BY oi_idioma_cv DESC	
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_idioma" value="./@oi_idioma + '-' + $r/@d_idioma"/>
