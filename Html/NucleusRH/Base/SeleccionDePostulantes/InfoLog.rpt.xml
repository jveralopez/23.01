<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.InfoLog" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATOS f_hastaact=&quot;20110317&quot; f_desdeact=&quot;20100317&quot; d_localidad=&quot;Rosario&quot; oi_provincia=&quot;22&quot; oi_estado_civil=&quot;1&quot; c_sexo=&quot;M&quot; edad_hasta=&quot;45&quot; edad_desde=&quot;19&quot; oi_aviso=&quot;162&quot; gaviso=&quot;&quot; grecluta=&quot;&quot; l_incluir_post=&quot;&quot; oi_tipo_jor_lab=&quot;&quot; oi_sit_laboral=&quot;&quot; remun_desde=&quot;&quot; remun_hasta=&quot;&quot; oi_area=&quot;&quot; h_edad_desde=&quot;&quot; h_edad_hasta=&quot;&quot; batch-id=&quot;000007E8-0000087C-20110321-165514-0000005D&quot; report=&quot;B5FF82792112-B5FFE6C8DD9A-00000000000B&quot;&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;ROW n_merito=&quot;100&quot; id=&quot;1&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW n_merito=&quot;100&quot; id=&quot;2&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW n_merito=&quot;100&quot; id=&quot;3&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW n_merito=&quot;100&quot; id=&quot;4&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW n_merito=&quot;&quot; id=&quot;5&quot; /&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&lt;/DATOS&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="#SOURCE:DATOS"/>
			<REPORT label="Informe de Proceso">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="AVI" type="title">
						<COLS>
							<COL name="aviso" label="Aviso"/>
							<COL name="f_aviso" label="Fecha Aviso" type="date"/>
							<COL name="tipo_aviso" label="Tipo Aviso"/>
							<COL name="puesto" label="Puesto"/>
						</COLS>
						<GROUP tag="CV" type="table">
							<COLS>
								<COL name="d_ape_y_nom" label="CV"/>
								<qry:insert-select name="QRY_MERITOS"/>
								<COL name="result" type="num" label="Total" style="font-weight:bold;font-size:10pt"/>
							</COLS>
						</GROUP>
						<GROUP type="tablestruc" label="Filtros" style="font-weight:bold;font-size:12pt">
							<GROUPROW>
								<GROUPCOL>
									<GROUP tag="FIL" type="title" style="text-align:left">
										<COLS>
											<COL name="f_desdeact" label="Act. Desde" nowrap="1" type="date"/>
											<COL name="f_hastaact" label="Act. Hasta" nowrap="1" type="date"/>
											<COL name="d_provincia" label="Provincia" nowrap="1"/>
											<COL name="d_localidad" label="Localidad" nowrap="1"/>
											<COL name="d_estado_civil" label="Estado Civil" nowrap="1"/>
										</COLS>
									</GROUP>
								</GROUPCOL>
								<GROUPCOL>
									<GROUP tag="FIL" type="title" style="text-align:left">
										<COLS>
											<COL name="edad_desde" label="Edad hasta" nowrap="1"/>
											<COL name="edad_hasta" label="Edad Hasta" nowrap="1"/>
											<COL name="c_sexo" label="Sexo" nowrap="1"/>
											<COL name="l_incluir_post" label="Postulo" nowrap="1"/>
											<COL name="d_tipo_jor_lab" label="Jor. Laboral" nowrap="1"/>
										</COLS>
									</GROUP>
								</GROUPCOL>
								<GROUPCOL>
									<GROUP tag="FIL" type="title" style="text-align:left">
										<COLS>
											<COL name="d_sit_laboral" label="Sit. Laboral" nowrap="1"/>
											<COL name="remun_desde" label="Rem. Desde" nowrap="1"/>
											<COL name="remun_hasta" label="Rem. Hasta" nowrap="1"/>
											<COL name="d_area" label="&#193;rea" nowrap="1"/>
										</COLS>
									</GROUP>
								</GROUPCOL>
							</GROUPROW>
						</GROUP>
						<GROUP type="title" label="*Los CVs no seleccionados fueron aquellos que no cumplieron con los m&#233;ritos y filtros elegidos."/>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select name="QRY_AVISO" doc-path="#SOURCE:DATOS"/>
					<qry:element name="FIL"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_AVISO" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						SDP05_AVISOS.c_aviso,
						SDP05_AVISOS.oi_aviso,
						SDP05_AVISOS.d_puesto,
						SDP05_AVISOS.f_aviso,
						SDP05_AVISOS.c_tipo,
						SDP05_AVISOS.oi_puesto										                                                                       
					FROM
						SDP05_AVISOS
					WHERE 
						SDP05_AVISOS.oi_aviso = {#PARAM:@oi_aviso} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="AVI">
					<qry:switch test="@c_tipo">
						<qry:case value="I">
							<qry:attribute name="tipo_aviso" value="'Interno'"/>
						</qry:case>
						<qry:case value="E">
							<qry:attribute name="tipo_aviso" value="'Externo'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="tipo_aviso" value="'Interno / Externo'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="aviso" value="$r/@c_aviso + ' - ' + $r/@d_puesto"/>
					<qry:attribute name="f_aviso" value="format_date($r/@f_aviso,'dd/mm/yyyy')"/>
					<qry:attribute name="puesto" value="$r/@oi_puesto"/>
					<qry:insert-select doc-path="$r" name="PUESTOS"/>
					<qry:insert-select name="QRY_FILE_BATCH" doc-path="#FILTRO:"/>
					<qry:element name="FIL">
						<qry:if test="#FILTRO:@f_desdeact !=''">
							<qry:then>
								<qry:attribute name="f_desdeact" value="format_date(#FILTRO:@f_desdeact,'dd/mm/yyyy')"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="f_desdeact" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@f_hastaact !=''">
							<qry:then>
								<qry:attribute name="f_hastaact" value="format_date(#FILTRO:@f_hastaact,'dd/mm/yyyy')"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="f_hastaact" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@edad_desde !=''">
							<qry:then>
								<qry:attribute name="edad_desde" value="#FILTRO:@edad_desde"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="edad_desde" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@edad_hasta !=''">
							<qry:then>
								<qry:attribute name="edad_hasta" value="#FILTRO:@edad_hasta"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="edad_hasta" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@d_localidad !=''">
							<qry:then>
								<qry:attribute name="d_localidad" value="#FILTRO:@d_localidad"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_localidad" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@remun_desde !=''">
							<qry:then>
								<qry:attribute name="remun_desde" value="#FILTRO:@remun_desde"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="remun_desde" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@remun_hasta !=''">
							<qry:then>
								<qry:attribute name="remun_hasta" value="#FILTRO:@remun_hasta"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="remun_hasta" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@l_incluir_post !='0'">
							<qry:then>
								<qry:attribute name="l_incluir_post" value="iif(#FILTRO:@l_incluir_post='1', 'SI', 'NO')"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="l_incluir_post" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@c_sexo !=''">
							<qry:then>
								<qry:attribute name="c_sexo" value="iif(#FILTRO:@c_sexo='M', 'Masculino', 'Femenino')"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="c_sexo" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@oi_provincia !=''">
							<qry:then>
								<qry:insert-select name="QRY_PROVINCIA" doc-path="#FILTRO:"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_provincia" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@oi_area !=''">
							<qry:then>
								<qry:insert-select name="QRY_AREA" doc-path="#FILTRO:"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_area" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@oi_estado_civil !=''">
							<qry:then>
								<qry:insert-select name="QRY_EST_CIVIL" doc-path="#FILTRO:"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_estado_civil" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@oi_tipo_jor_lab !=''">
							<qry:then>
								<qry:insert-select name="QRY_JORNADA" doc-path="#FILTRO:"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_tipo_jor_lab" value="'-'"/>
							</qry:else>
						</qry:if>
						<qry:if test="#FILTRO:@oi_sit_laboral !=''">
							<qry:then>
								<qry:insert-select name="QRY_SITUACION" doc-path="#FILTRO:"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="d_sit_laboral" value="'-'"/>
							</qry:else>
						</qry:if>
					</qry:element>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="PUESTOS">
			<qry:xquery>
				for $r in SQL('
					SELECT
						ORG04_PUESTOS.c_puesto,
						ORG04_PUESTOS.d_puesto
					FROM
						ORG04_PUESTOS
					WHERE 
						ORG04_PUESTOS.oi_puesto = {#PARAM:@oi_puesto}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="puesto" value="$r/@c_puesto + ' - ' + $r/@d_puesto"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_FILE_BATCH" doc="PARAM">
			<qry:xquery>
				for $r in fileio('TEMP\\SDP_Reclutamiento_{%=#PARAM:@batch-id%}.xml')/DATA/CV
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_APE_Y_NOM" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				CV.d_ape_y_nom
			FROM 
				SDP01_CV AS CV			
			WHERE 
				CV.oi_cv = {#PARAM:@oi_cv}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_MERITOS" doc="PARAM">
			<qry:xquery>
				for $r in #FILTRO:ROWS/ROW[@n_merito!='']
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="name" value="'mer_'+$r/@id"/>
					<qry:attribute name="type" value="'num'"/>
					<qry:insert-select name="QRY_MERITOS_DESC" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_MERITOS_DESC" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
			SELECT
				SDP15_MERITOS.d_merito
			FROM 
				SDP15_MERITOS
			WHERE
				SDP15_MERITOS.oi_merito = {#PARAM:@id}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="label" value=" $r/@d_merito + ' (' + #PARAM:@n_merito + ')'"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_AREA" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						SDP09_AREAS.d_area
					FROM
						SDP09_AREAS
					WHERE 
						SDP09_AREAS.oi_area = {#PARAM:@oi_area} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_area" value="$r/@d_area"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PROVINCIA" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						ORG35_PROVINCIAS.d_provincia,
						ORG35_PROVINCIAS.oi_provincia
					FROM
						ORG35_PROVINCIAS
					WHERE 
						ORG35_PROVINCIAS.oi_provincia = {#PARAM:@oi_provincia} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_provincia" value="$r/@d_provincia"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_EST_CIVIL" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						ORG22_EST_CIVIL.d_estado_civil
					FROM
						ORG22_EST_CIVIL
					WHERE 
						ORG22_EST_CIVIL.oi_estado_civil = {#PARAM:@oi_estado_civil} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_estado_civil" value="$r/@d_estado_civil"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_JORNADA" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						SDP16_TIPOS_JORNADA.d_tipo_jor_lab
					FROM
						SDP16_TIPOS_JORNADA
					WHERE 
						SDP16_TIPOS_JORNADA.oi_tipo_jor_lab = {#PARAM:@oi_tipo_jor_lab} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_tipo_jor_lab" value="$r/@d_tipo_jor_lab"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_SITUACION" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
					SELECT
						SDP17_SIT_LABORALES.d_sit_laboral
					FROM
						SDP17_SIT_LABORALES
					WHERE 
						SDP17_SIT_LABORALES.oi_sit_laboral = {#PARAM:@oi_sit_laboral} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_sit_laboral" value="$r/@d_sit_laboral"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
