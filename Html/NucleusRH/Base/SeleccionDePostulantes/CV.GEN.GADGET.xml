<html:html xmlns:html="nomad_engine.html" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="NucleusRH.Base.SeleccionDePostulantes.CV.rpt" name="NucleusRH.Base.SeleccionDePostulantes.CV.GEN.GADGET" doc="source">
	<html:xslt>
		<xsl:template name="DocDigital">
			<xsl:choose>
				<xsl:when test="@oi_doc_digital = 'no'">
					<span class="FontP">
						No posee CV Digital
					</span>
				</xsl:when>
				<xsl:otherwise>
					<a href="" target="_blank" class="FontLink">
						<xsl:attribute name="href">
							<xsl:value-of select="concat('../../../', @oi_doc_digital)"/>
						</xsl:attribute>
						Posee CV Digital
					</a>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:template>
	</html:xslt>
</html:html>
