<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.ReclutadosAviso" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATOS oi_aviso=&quot;9&quot; c_estado=&quot;&quot; l_excluir=&quot;&quot; /&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Reclutados por Aviso">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="AVI" type="title">
						<COLS>
							<COL name="aviso" label="Aviso"/>
							<qry:if test="#SOURCE:DATOS/@c_estado!=''">
								<qry:then>
									<COL name="c_estado" label="Estado"/>
								</qry:then>
							</qry:if>
							<COL name="l_excluir" label="Excluye Descartados"/>
						</COLS>
						<GROUP tag="REC" type="table" label="Reclutados">
							<COLS>
								<COL name="documento" label="Documento" nowrap="1"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" nowrap="1"/>
								<COL name="c_estado" label="Estado" nowrap="1"/>
								<COL name="edad" label="Edad" nowrap="1"/>
								<COL name="provincia" label="Provincia" nowrap="1"/>
								<COL name="localidad" label="Localidad" nowrap="1"/>
								<COL name="domicilio" label="Domicilio" nowrap="1"/>
								<COL name="te_telefono" label="Tel&#233;fono" nowrap="1"/>
								<COL name="e_mail" label="E-Mail" nowrap="1"/>
								<COL name="n_merito" label="M&#233;rito" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="AVI">
						<qry:attribute name="l_excluir" value="iif(#SOURCE:DATOS/@l_excluir='1', 'Si', 'No')"/>
						<qry:switch test="#SOURCE:DATOS/@c_estado">
							<qry:case value="V">
								<qry:attribute name="c_estado" value="'Vigente'"/>
							</qry:case>
							<qry:case value="D">
								<qry:attribute name="c_estado" value="'Descartado'"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="c_estado" value="'Contratado'"/>
							</qry:default>
						</qry:switch>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="RECLUTADOS"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="CVS">
			<qry:xquery>
				for $r in SQL('     
					SELECT 
						SDP01_CV.d_ape_y_nom,
						SDP01_CV.c_nro_doc,
						SDP01_CV.c_pais,
						SDP01_CV.c_area,
						SDP01_CV.te_nro,
						SDP01_CV.c_pais_cel,
						SDP01_CV.c_area_cel,
						SDP01_CV.te_celular,
						SDP01_CV.d_email,
						PER20_TIPOS_DOC.c_tipo_documento,
						SDP01_CV.d_localidad,   
						SDP01_CV.oi_localidad,
						SDP01_CV.f_nacim,
						SDP01_CV.d_calle,
						SDP01_CV.c_nro,
						SDP01_CV.c_piso, 
						SDP01_CV.c_departamento,
						ORG35_PROVINCIAS.d_provincia,
						ORG19_LOCALIDADES.d_localidad as localidad
					FROM
						SDP01_CV,
						PER20_TIPOS_DOC,
						ORG35_PROVINCIAS,
						ORG19_LOCALIDADES
					JOIN
						SDP01_CV.oi_tipo_documento INNER PER20_TIPOS_DOC.oi_tipo_documento,
						SDP01_CV.oi_provincia LEFT OUTER ORG35_PROVINCIAS.oi_provincia,
						SDP01_CV.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad
					WHERE
						{%? 
							(#SOURCE:@oi_cv!='')	
							{% SDP01_CV.oi_cv = {#SOURCE:@oi_cv} AND %} 
							{% %} 
						%}
						1=1 
					ORDER BY d_ape_y_nom ASC
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="documento" value="'('+$r/@c_tipo_documento+')'+' '+$r/@c_nro_doc"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:if test="$r/@te_nro!=''">
					<qry:then>
						<qry:attribute name="te_telefono" value="'('+$r/@c_pais+')'+' '+$r/@c_area+'-'+$r/@te_nro"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="te_telefono" value="iif($r/@te_celular!='','('+$r/@c_pais_cel+')'+' '+$r/@c_area_cel+'-'+$r/@te_celular,'')"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
				<qry:attribute name="e_mail" value="$r/@d_email"/>
				<qry:attribute name="edad" value="FLOOR((Number(now()) - Number(Datetime($r/@f_nacim))) DIV 365)"/>
				<qry:attribute name="domicilio" value="$r/@d_calle + ' ' + $r/@c_nro + ' ' + $r/@c_piso + ' ' + $r/@c_departamento"/>
				<qry:if test="$r/@oi_localidad!=''">
					<qry:then>
						<qry:attribute name="localidad" value="$r/@localidad"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="localidad" value="$r/@d_localidad"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="provincia" value="$r/@d_provincia"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="RECLUTADOS">
			<qry:xquery>
				for $r in SQL('
		SELECT
			REC.oi_cv,
			REC.oi_aviso,
			REC.f_estado,
			REC.oi_reclutado,
			REC.c_estado,
			REC.n_merito,
			AVISO.c_aviso,
			AVISO.d_puesto			
		FROM
			SDP14_RECLUTADOS AS REC,
			SDP05_AVISOS AS AVISO                            
		JOIN
			REC.oi_aviso INNER AVISO.oi_aviso
		WHERE 
			{%? 
				(#SOURCE:@c_estado='V')	
				{% REC.c_estado = {#SOURCE:@c_estado} AND %} 
				{% %} 
			%}
			{%? 
				(#SOURCE:@c_estado='D')	
				{% REC.c_estado = {#SOURCE:@c_estado} AND %} 
				{% %} 
			%}
			{%? 
				(#SOURCE:@c_estado='C')	
				{% REC.c_estado = {#SOURCE:@c_estado} AND %} 
				{% %} 
			%}       
			 {%? 
				(#SOURCE:@oi_aviso!='')	
				{% REC.oi_aviso = {#SOURCE:@oi_aviso} AND %} 
				{% %} 
			%}    
			{%?
				(#SOURCE:@l_excluir ='1') 
				{% REC.c_estado!= \'D\' AND %} 
				{% %} 
			%}
			1=1
		ORDER BY 
			n_merito DESC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="aviso" value="$r/@c_aviso + ' - ' + $r/@d_puesto"/>
				<qry:element name="REC">
					<qry:switch test="$r/@c_estado">
						<qry:case value="V">
							<qry:attribute name="c_estado" value="'Vigente'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="c_estado" value="'Descartado'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="c_estado" value="'Contratado'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="n_merito" value="number($r/@n_merito)"/>
					<qry:attribute name="oi_cv" value="$r/@oi_cv"/>
					<qry:insert-select doc-path="$r" name="CVS"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
