<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.PostulacionesAvisos" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATOS oi_aviso=&quot;&quot; f_desde=&quot;20120101&quot; f_hasta=&quot;20120131&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="#SOURCE:DATOS"/>
			<REPORT label="Postulaciones por Aviso">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<qry:if test="#SOURCE:DATOS/@f_desde!=''">
								<qry:then>
									<COL name="f_desde" label="Fecha Desde" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#SOURCE:DATOS/@f_hasta!=''">
								<qry:then>
									<COL name="f_hasta" label="Fecha Hasta" type="date"/>
								</qry:then>
							</qry:if>
						</COLS>
						<GROUP tag="AVI" type="title">
							<COLS>
								<COL name="aviso" label="Aviso"/>
								<COL name="f_aviso" label="Fecha Aviso" type="date"/>
								<COL name="tipo_aviso" label="Tipo Aviso"/>
								<COL name="puesto" label="Puesto"/>
								<COL name="cantidad" label="Cantidad de Postulaciones"/>
							</COLS>
							<GROUP tag="POS" type="table" label="Postulaciones" style="width:100%;">
								<COLS>
									<COL name="documento" label="Documento" style="width:15%"/>
									<COL name="d_ape_y_nom" label="Apellido y Nombre" style="width:30%"/>
									<COL name="f_postulacion" label="Fecha Postulaci&#243;n" style="width:20%;text-align:center;" type="date"/>
									<COL name="te_telefono" label="Tel&#233;fono" style="width:20%"/>
									<COL name="e_mail" label="E-Mail" style="width:20%"/>
								</COLS>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:attribute name="f_desde" value="format_date(#SOURCE:DATOS/@f_desde, 'dd/mm/yyyy')"/>
						<qry:attribute name="f_hasta" value="format_date(#SOURCE:DATOS/@f_hasta, 'dd/mm/yyyy')"/>
						<qry:insert-select doc-path="#SOURCE:DATOS" name="AVISO"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="AVISO">
			<qry:xquery>
				for $r in SQL('
					SELECT
						SDP05_AVISOS.c_aviso,
						SDP05_AVISOS.oi_aviso,
						SDP05_AVISOS.d_puesto,
						SDP05_AVISOS.f_aviso,
						SDP05_AVISOS.c_tipo,
						SDP05_AVISOS.oi_puesto										                                                                       
					FROM
						SDP05_AVISOS
					WHERE 
						1=1   
					  {%? (#SOURCE:@oi_aviso!='') 
  						{% 	AND STRING2NUMBER(SDP05_AVISOS.oi_aviso) = {#SOURCE:@oi_aviso} %}                               
  						{%  %}                     
 						%}
 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="AVI">
					<qry:switch test="@c_tipo">
						<qry:case value="I">
							<qry:attribute name="tipo_aviso" value="'Interno'"/>
						</qry:case>
						<qry:case value="E">
							<qry:attribute name="tipo_aviso" value="'Externo'"/>
						</qry:case>
						<qry:default>
							<qry:attribute name="tipo_aviso" value="'Interno / Externo'"/>
						</qry:default>
					</qry:switch>
					<qry:attribute name="aviso" value="$r/@c_aviso + ' - ' + $r/@d_puesto"/>
					<qry:attribute name="f_aviso" value="format_date($r/@f_aviso,'dd/mm/yyyy')"/>
					<qry:attribute name="puesto" value="$r/@oi_puesto"/>
					<qry:attribute name="cantidad" value="0"/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:insert-select doc-path="$r" name="PUESTOS"/>
					<qry:insert-select doc-path="$r" name="POSTULACIONES"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="POSTULACIONES">
			<qry:xquery>
				for $r in SQL('     
					SELECT 
						SDP01_CV.d_ape_y_nom,
						SDP01_CV.c_nro_doc,
						SDP01_CV.c_pais,
						SDP01_CV.c_area,
						SDP01_CV.te_nro,
						SDP01_CV.d_email,
						SDP01_POSTU_CV.f_postulacion,
						PER20_TIPOS_DOC.c_tipo_documento
					FROM
						SDP01_CV,
						SDP01_POSTU_CV,
						PER20_TIPOS_DOC
					JOIN
						SDP01_CV.oi_cv INNER SDP01_POSTU_CV.oi_cv,
						SDP01_CV.oi_tipo_documento INNER PER20_TIPOS_DOC.oi_tipo_documento
					WHERE
						SDP01_POSTU_CV.oi_aviso = {#SOURCE:@oi_aviso}
						{%? (#FILTRO:@f_desde!='') 
  						{% 	AND SDP01_POSTU_CV.f_postulacion &gt;= {Datetime(#FILTRO:@f_desde)} %}
  						{%  %}                     
 						%}
 						{%? (#FILTRO:@f_hasta!='') 
  						{% 	AND SDP01_POSTU_CV.f_postulacion &lt;= {Datetime(Number(Datetime(#FILTRO:@f_hasta))+1)} %}
  						{%  %}
  					%} 
					ORDER BY d_ape_y_nom ASC
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cantidad" value="number(@cantidad) + 1"/>
				<qry:attribute name="hts:delete" value="'0'"/>
				<qry:element name="POS">
					<qry:attribute name="documento" value="'('+$r/@c_tipo_documento+')'+' '+$r/@c_nro_doc"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:if test="$r/@te_nro!=''">
						<qry:then>
							<qry:attribute name="te_telefono" value="'('+$r/@c_pais+')'+' '+$r/@c_area+'-'+$r/@te_nro"/>
						</qry:then>
					</qry:if>
					<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
					<qry:attribute name="e_mail" value="$r/@d_email"/>
					<qry:attribute name="f_postulacion" value="format_date($r/@f_postulacion,'dd/mm/yyyy')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="PUESTOS">
			<qry:xquery>
				for $r in SQL('
					SELECT
						ORG04_PUESTOS.c_puesto,
						ORG04_PUESTOS.d_puesto
						
					FROM
						ORG04_PUESTOS
					WHERE 
						ORG04_PUESTOS.oi_puesto = {#SOURCE:@oi_puesto}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="puesto" value="$r/@c_puesto + ' - ' + $r/@d_puesto"/>
			</qry:out>
		</qry:select>
		<qry:select name="sqldelete" doc="SOURCE">
			<qry:out>
				<qry:attribute name="hts:delete" value="'0'"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
