<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.SeleccionDepostulantes.CVWeb.rpt" doc="source">
	<html:query declare="&lt;PARAMS oi_cv = '1' c_seguridad=&quot;E600AFB0-3B4DEAA6-E6E8F2FD-E29F0253&quot;/&gt;" name="dd">
		<qry:main doc="SOURCE">
			<qry:element name="CV">
				<qry:insert-select doc-path="#SOURCE:PARAMS" name="qryDatosPrincipales"/>
				<qry:element name="ESTUDIOS">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sqlESTUDIOS"/>
				</qry:element>
				<qry:element name="EXPERIENCIAS">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sqlEXPERIENCIA"/>
				</qry:element>
				<qry:element name="IDIOMAS">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sqlIDIOMAS_CV"/>
				</qry:element>
				<qry:element name="INFORMATICAS">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sqlINFORMATICA"/>
				</qry:element>
				<qry:element name="AREAS_CV">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sqlAREAS_CV"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="SOURCE" name="qryDatosPrincipales">
			<qry:xquery>
				for $r in SQL('
				SELECT 
					cv.oi_cv,
					cv.oi_tipo_documento,
					cv.oi_provincia,
					cv.oi_estado_civil,
					cv.oi_foto,
					cv.oi_doc_digital,
					cv.c_cv,
					cv.d_apellido,
					cv.d_nombres,
					cv.d_ape_y_nom,
					cv.c_nro_doc,
					cv.c_estado,
					cv.c_sexo,
					cv.f_nacim,
					cv.c_nro_cuil,
					cv.d_localidad,
					cv.oi_localidad,    
					loc.d_localidad as localidad,
					
					cv.c_codigo_postal,
					cv.d_calle,
					cv.c_nro,
					cv.c_piso,
					cv.c_departamento,
					cv.d_email,
					cv.c_pais_cel,
					cv.c_area_cel,
					cv.te_celular,
					cv.c_pais,
					cv.c_area,
					cv.te_nro,
					cv.f_actualizacion,
					cv.c_seguridad,
					cv.c_lic_conduc,
					cv.c_vehiculo,
					cv.c_radicarse,
					cv.c_viajar,
					cv.oi_sit_laboral,
					cv.oi_tipo_jor_lab,
					cv.n_remuneracion,

					cv.d_ape_y_nom_fam1,
					cv.d_email_fam1,
					cv.te_nro_fam1,
					cv.oi_tipo_fam1,
					cv.d_ape_y_nom_fam2,
					cv.d_email_fam2,
					cv.te_nro_fam2,
					cv.oi_tipo_fam2,
					cv.d_ape_y_nom_ref1,
					cv.d_email_ref1,
					cv.te_nro_ref1,
					cv.d_ape_y_nom_ref2,
					cv.d_email_ref2,
					cv.te_nro_ref2,
					
					cv.d_custom_1,					
					cv.d_custom_2,
					cv.d_custom_3,					
					cv.d_custom_4,					
					cv.d_custom_5,					
					cv.d_custom_6,					
					cv.d_custom_7,					
					cv.d_custom_8,					
					cv.d_custom_9,					
					cv.d_custom_10,										
					
					ec.d_estado_civil,
					td.d_tipo_documento,
					pro.d_provincia,
					p.d_pais,
					sl.d_sit_laboral,
					tj.d_tipo_jor_lab,
					tf1.d_tipo_familiar as d_tipo_familiar1,
					tf2.d_tipo_familiar as d_tipo_familiar2
				
				FROM 
					SDP01_CV as cv,
					ORG22_EST_CIVIL as ec,
					PER20_TIPOS_DOC as td,
					ORG35_PROVINCIAS as pro,
					ORG35_PAISES as p,
					SDP17_SIT_LABORALES as sl,
					SDP16_TIPOS_JORNADA as tj,
					PER15_TIPOS_FAM as tf1,
					PER15_TIPOS_FAM as tf2,
					ORG19_LOCALIDADES as loc
					
				
				JOIN
					cv.oi_estado_civil LEFT OUTER ec.oi_estado_civil,
					cv.oi_tipo_documento INNER td.oi_tipo_documento,
					cv.oi_provincia LEFT OUTER pro.oi_provincia,
					cv.oi_pais LEFT OUTER p.oi_pais,
					cv.oi_sit_laboral LEFT OUTER sl.oi_sit_laboral,
					cv.oi_tipo_jor_lab LEFT OUTER tj.oi_tipo_jor_lab,
					cv.oi_tipo_fam1 LEFT OUTER tf1.oi_tipo_familiar,
					cv.oi_tipo_fam2 LEFT OUTER tf2.oi_tipo_familiar,
					cv.oi_localidad LEFT OUTER loc.oi_localidad
					
				WHERE 
					cv.oi_cv = {#SOURCE:@oi_cv} AND
					cv.c_seguridad = {#SOURCE:@c_seguridad} 
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_actualizacion" value="format_date($r/@f_actualizacion,'dd/mm/yyyy')"/>
				<!-- Datos principales-->
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="d_apellido" value="$r/@d_apellido"/>
				<qry:attribute name="d_nombres" value="$r/@d_nombres"/>
				<qry:attribute name="f_nacim" value="format_date($r/@f_nacim,'dd/mm/yyyy')"/>
				<qry:attribute name="edad" value="FLOOR((Number(now()) - Number(Datetime($r/@f_nacim))) DIV 365)"/>
				<qry:attribute name="d_estado_civil" value="$r/@d_estado_civil"/>
				<qry:attribute name="c_sexo" value="iif($r/@c_sexo ='M', 'Masculino', 'Femenino')"/>
				<qry:attribute name="c_nro_cuil" value="$r/@c_nro_cuil"/>
				<qry:attribute name="c_nro_cuil_2" value="SUBSTRING($r/@c_nro_cuil, 0, 2) + '-' + SUBSTRING($r/@c_nro_cuil, 2, 8) + '-' + SUBSTRING($r/@c_nro_cuil, 10, 1)"/>
				<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
				<qry:attribute name="d_tipo_documento" value="$r/@d_tipo_documento"/>
				<qry:attribute name="oi_foto" value="iif($r/@oi_foto = '', 'no', $r/@oi_foto)"/>
				<qry:attribute name="oi_doc_digital" value="$r/@oi_doc_digital"/>
				<qry:attribute name="crc32" value="iif($r/@oi_foto!='',nmd_crc('PARAMS:mode=DB|class=NucleusRH.Base.SeleccionDePostulantes.DocumentosDigitales.HEAD|id=' + $r/@oi_foto),'')"/>
				<!-- Datos adicionales-->
				<qry:attribute name="d_lic_conduc" value="iif($r/@c_lic_conduc = 'S', 'Si', iif($r/@c_lic_conduc = 'N', 'No', ''))"/>
				<qry:attribute name="d_vehiculo" value="iif($r/@c_vehiculo = 'S', 'Si', iif($r/@c_vehiculo = 'N', 'No', ''))"/>
				<qry:switch test="$r/@c_radicarse">
					<qry:case value="NO">
						<qry:attribute name="d_radicarse" value="'No'"/>
					</qry:case>
					<qry:case value="NA">
						<qry:attribute name="d_radicarse" value="'Solo nacional'"/>
					</qry:case>
					<qry:case value="EX">
						<qry:attribute name="d_radicarse" value="'Nacional y extranjero'"/>
					</qry:case>
				</qry:switch>
				<qry:switch test="$r/@c_viajar">
					<qry:case value="NO">
						<qry:attribute name="d_viajar" value="'No'"/>
					</qry:case>
					<qry:case value="NA">
						<qry:attribute name="d_viajar" value="'Solo nacional'"/>
					</qry:case>
					<qry:case value="EX">
						<qry:attribute name="d_viajar" value="'Nacional y extranjero'"/>
					</qry:case>
				</qry:switch>
				<qry:attribute name="n_remuneracion" value="$r/@n_remuneracion"/>
				<qry:attribute name="d_sit_laboral" value="$r/@d_sit_laboral"/>
				<qry:attribute name="d_tipo_jor_lab" value="$r/@d_tipo_jor_lab"/>
				<qry:attribute name="fam1" value="$r/@d_ape_y_nom_fam1 + iif($r/@d_tipo_familiar1 !='', ' (' + $r/@d_tipo_familiar1 + ')', '') + iif($r/@d_email_fam1 !='', ' - ' + $r/@d_email_fam1, '') + iif($r/@te_nro_fam1 !='', ' - ' + $r/@te_nro_fam1, '')"/>
				<qry:attribute name="fam2" value="$r/@d_ape_y_nom_fam2 + iif($r/@d_tipo_familiar2 !='', ' (' + $r/@d_tipo_familiar2 + ')', '') + iif($r/@d_email_fam2 !='', ' - ' + $r/@d_email_fam2, '') + iif($r/@te_nro_fam2 !='', ' - ' + $r/@te_nro_fam2, '')"/>
				<qry:attribute name="ref1" value="$r/@d_ape_y_nom_ref1 + iif($r/@d_email_ref1 !='', ' - ' + $r/@d_email_ref1, '') + iif($r/@te_nro_ref1 !='', ' - ' + $r/@te_nro_ref1, '')"/>
				<qry:attribute name="ref2" value="$r/@d_ape_y_nom_ref2 + iif($r/@d_email_ref2 !='', ' - ' + $r/@d_email_ref2, '') + iif($r/@te_nro_ref2 !='', ' - ' + $r/@te_nro_ref2, '')"/>
				<!-- localizacion-->
				<qry:attribute name="d_provincia" value="$r/@d_provincia"/>
				<!--qry:if test="$r/@oi_localidad!=''">
					<qry:then>
						<qry:attribute name="d_localidad" value="$r/@localidad"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
					</qry:else>
		</qry:if-->
				<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
				<qry:attribute name="c_codigo_postal" value="$r/@c_codigo_postal"/>
				<qry:attribute name="d_email" value="$r/@d_email"/>
				<qry:attribute name="d_calle" value="$r/@d_calle"/>
				<qry:attribute name="c_nro" value="$r/@c_nro"/>
				<qry:attribute name="c_piso" value="$r/@c_piso"/>
				<qry:attribute name="c_departamento" value="$r/@c_departamento"/>
				<qry:attribute name="d_domicilio" value="$r/@d_calle + ' ' + $r/@c_nro"/>
				<qry:attribute name="d_domicilio" value="@d_domicilio + iif($r/@c_piso !='', ' piso ' + $r/@c_piso, '')"/>
				<qry:attribute name="d_domicilio" value="@d_domicilio + iif($r/@c_departamento !='', ' dpto. ' + $r/@c_departamento, '')"/>
				<qry:attribute name="tel_nro" value="iif($r/@te_nro !='', '(' + $r/@c_pais + ')' + $r/@c_area + ' - ' + format_number($r/@te_nro,'#########'), '')"/>
				<qry:attribute name="cel_nro" value="iif($r/@te_celular !='', '(' + $r/@c_pais_cel + ')' + $r/@c_area_cel + ' - ' + format_number($r/@te_celular,'#########'), '')"/>
				<qry:attribute name="d_pais" value="$r/@d_pais"/>
				<!-- Customs -->
				<qry:attribute name="d_custom_1" value="$r/@d_custom_1"/>
				<qry:attribute name="d_custom_2" value="$r/@d_custom_2"/>
				<qry:attribute name="d_custom_3" value="$r/@d_custom_3"/>
				<qry:attribute name="d_custom_4" value="$r/@d_custom_4"/>
				<qry:attribute name="d_custom_5" value="$r/@d_custom_5"/>
				<qry:attribute name="d_custom_6" value="$r/@d_custom_6"/>
				<qry:attribute name="d_custom_7" value="$r/@d_custom_7"/>
				<qry:attribute name="d_custom_8" value="$r/@d_custom_8"/>
				<qry:attribute name="d_custom_9" value="$r/@d_custom_9"/>
				<qry:attribute name="d_custom_10" value="$r/@d_custom_10"/>
			</qry:out>
		</qry:select>
		<qry:select name="sqlESTUDIOS" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					est.oi_estudio_cv,
					est.d_otro_est_educ,
					est.c_estado,
					est.oi_nivel_estudio,
					est.oi_area_est,
					
					niv.d_nivel_estudio,
					
					area.d_area_est
				
				FROM 
					SDP01_ESTUDIOS_CV as est,
					PER12_NIVELES_EST as niv,
					ORG43_AREAS_EST as area
				
				JOIN
					est.oi_nivel_estudio INNER niv.oi_nivel_estudio,
					est.oi_area_est LEFT OUTER area.oi_area_est
				
				WHERE 
					est.oi_cv = {#SOURCE:@oi_cv} 
					
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ESTUDIO">
					<qry:attribute name="oi_nivel_estudio_txt" value="$r/@d_nivel_estudio"/>
					<qry:attribute name="d_estudio" value="iif($r/@d_otro_est_educ != '', $r/@d_otro_est_educ, $r/@d_area_est)"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="1">
							<qry:attribute name="c_estado_txt" value="'Completo'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_estado_txt" value="'Incompleto'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_estado_txt" value="'En Curso'"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="sqlEXPERIENCIA" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					exp.oi_experiencia,
					exp.oi_puesto_exp,
					exp.d_empresa,
					exp.d_actividad,
					exp.o_contacto,
					exp.f_ingreso,
					exp.f_egreso,
					exp.o_tareas,
					exp.l_actual,
					
					exp.d_custom_1,
					exp.d_custom_2,
					exp.d_custom_3,
					exp.d_custom_4,
					exp.d_custom_5,
					exp.d_custom_6,
					exp.d_custom_7,
					exp.d_custom_8,
					exp.d_custom_9,
					exp.d_custom_10,
					
					p.d_puesto_exp
				
				FROM 
					SDP01_EXPERIENCIA as exp,
					SDP09_PUESTO_EXP as p
				
				JOIN
					exp.oi_puesto_exp INNER p.oi_puesto_exp
				
				WHERE 
					exp.oi_cv = {#SOURCE:@oi_cv} 
				
				ORDER BY
					f_ingreso DESC
					
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EXPERIENCIA">
					<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
					<qry:attribute name="d_actividad" value="$r/@d_actividad"/>
					<qry:attribute name="o_contacto" value="$r/@o_contacto"/>
					<qry:attribute name="f_fecha" value="FORMAT_DATE($r/@f_ingreso, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_fecha" value="@f_fecha + iif($r/@f_egreso != '', ' - ' + FORMAT_DATE($r/@f_egreso, 'dd/mm/yyyy'), '')"/>
					<qry:attribute name="f_ingreso" value="FORMAT_DATE($r/@f_ingreso, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_egreso" value="iif($r/@f_egreso != '', FORMAT_DATE($r/@f_egreso, 'dd/mm/yyyy'), '')"/>
					<qry:attribute name="oi_puesto_exp_txt" value="$r/@d_puesto_exp"/>
					<qry:attribute name="d_custom_1" value="$r/@d_custom_1"/>
					<qry:attribute name="d_custom_2" value="$r/@d_custom_2"/>
					<qry:attribute name="d_custom_3" value="$r/@d_custom_3"/>
					<qry:attribute name="d_custom_4" value="$r/@d_custom_4"/>
					<qry:attribute name="d_custom_5" value="$r/@d_custom_5"/>
					<qry:attribute name="d_custom_6" value="$r/@d_custom_6"/>
					<qry:attribute name="d_custom_7" value="$r/@d_custom_7"/>
					<qry:attribute name="d_custom_8" value="$r/@d_custom_8"/>
					<qry:attribute name="d_custom_9" value="$r/@d_custom_9"/>
					<qry:attribute name="d_custom_10" value="$r/@d_custom_10"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="sqlIDIOMAS_CV" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					i.oi_idioma_cv,
					i.oi_idioma,
					i.c_nivel_habla,
					i.c_nivel_lee,
					i.c_nivel_escribe,
					i.d_idioma,
					
					oi.d_idioma as d_idioma_org
				
				FROM 
					SDP01_IDIOMAS_CV as i,
					ORG20_IDIOMAS as oi
				
				JOIN
					i.oi_idioma INNER oi.oi_idioma
				
				WHERE 
					i.oi_cv = {#SOURCE:@oi_cv} 
				
				ORDER BY
					d_idioma ASC,
					d_idioma_org ASC
					
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="IDIOMA">
					<qry:attribute name="d_idioma" value="iif($r/@d_idioma != '', $r/@d_idioma, $r/@d_idioma_org)"/>
					<qry:switch test="$r/@c_nivel_habla">
						<qry:case value="1">
							<qry:attribute name="c_nivel_habla_txt" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_nivel_habla_txt" value="'Intermedio'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_nivel_habla_txt" value="'Avanzado'"/>
						</qry:case>
					</qry:switch>
					<qry:switch test="$r/@c_nivel_lee">
						<qry:case value="1">
							<qry:attribute name="c_nivel_lee_txt" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_nivel_lee_txt" value="'Intermedio'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_nivel_lee_txt" value="'Avanzado'"/>
						</qry:case>
					</qry:switch>
					<qry:switch test="$r/@c_nivel_escribe">
						<qry:case value="1">
							<qry:attribute name="c_nivel_escribe_txt" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_nivel_escribe_txt" value="'Intermedio'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_nivel_escribe_txt" value="'Avanzado'"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="sqlINFORMATICA" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					i.oi_informatica_cv,
					i.oi_informatica,
					i.c_nivel,
					i.o_detalle,
					
					si.d_informatica
				
				FROM 
					SDP01_INFORMATICA as i,
					SDP08_INFORMATICA as si
				
				JOIN
					i.oi_informatica INNER si.oi_informatica
				
				WHERE 
					i.oi_cv = {#SOURCE:@oi_cv} 
				
				ORDER BY
					d_informatica ASC
					
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="INFORMATICA">
					<qry:attribute name="oi_informatica_txt" value="$r/@d_informatica"/>
					<qry:attribute name="o_detalle" value="$r/@o_detalle"/>
					<qry:switch test="$r/@c_nivel">
						<qry:case value="1">
							<qry:attribute name="c_nivel_txt" value="'B&#225;sico'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="c_nivel_txt" value="'Intermedio'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="c_nivel_txt" value="'Avanzado'"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="sqlAREAS_CV" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					acv.oi_area,
					
					a.d_area
				
				FROM 
					SDP01_AREAS_CV as acv,
					SDP09_AREAS as a
				
				JOIN
					acv.oi_area INNER a.oi_area
				
				WHERE 
					acv.oi_cv = {#SOURCE:@oi_cv} 
				
				ORDER BY
					d_area ASC
					
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="AREA">
					<qry:attribute name="oi_area" value="$r/@oi_area"/>
					<qry:attribute name="oi_area_txt" value="$r/@d_area"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/CV">
			<html>
				<head>
					<LINK href="./Styles/Reports.css" type="text/css" rel="stylesheet" media="screen"/>
					<LINK href="./Styles/Reports_print.css" type="text/css" rel="stylesheet" media="print"/>
					<script src="./Scripts/controls.js" type="text/javascript">
						//
					</script>
					<script type="text/javascript">
						function nmdPageLoad() {
						if (GetUrlVariable('print')=="1") {
							window.print();
						}
					}
					</script>
					<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
					<style media="screen">
						body {
