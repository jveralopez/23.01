								Veh&#237;culos Habilitados
							</td>
						</tr>
						<tr>
							<td style="text-align:center; font-weight: normal;">
								<xsl:value-of select="concat('Fecha: ', ./@fecha)"/>
							</td>
						</tr>
					</table>
					<xsl:for-each select="./EMPRESA">
						<br/>
						<table class="table_table_style">
							<tr style="font-weight: bold; font-family:verdana; font-size=12px">
								<xsl:value-of select="concat('Empresa: ',./@d_empresa)"/>
							</tr>
							<xsl:choose>
								<xsl:when test="@cant_vehiculos_habilitados != 0">
									<tr>
										<th>
											Dominio
										</th>
										<th>
											Marca
										</th>
										<th>
											Modelo
										</th>
										<th>
											A&#241;o
										</th>
										<th>
											Tipo Veh&#237;culo
										</th>
										<th>
											Fecha Hasta Aptitud
										</th>
									</tr>
									<xsl:for-each select="./VEHICULO">
										<xsl:choose>
											<xsl:when test="@habilitado = 1">
												<tr>
													<td style="text-align:center; width:10%">
														<xsl:value-of select="./@c_dominio"/>
													</td>
													<td style="text-align:center; width:35%">
														<xsl:value-of select="./@c_marca"/>
													</td>
													<td style="text-align:center; width:10%">
														<xsl:value-of select="./@d_modelo"/>
													</td>
													<td style="text-align:center; width:5%">
														<xsl:value-of select="./@e_anio"/>
													</td>
													<td style="text-align:center; width:25%">
														<xsl:value-of select="./@tipo_vehiculo"/>
													</td>
													<td style="text-align:center; width:15%">
														<xsl:value-of select="./@f_aptitud"/>
													</td>
												</tr>
											</xsl:when>
										</xsl:choose>
									</xsl:for-each>
								</xsl:when>
							</xsl:choose>
						</table>
					</xsl:for-each>
					<br/>
				</body>
			</html>
		</xsl:template>
	</html:xslt>
</html:html>
