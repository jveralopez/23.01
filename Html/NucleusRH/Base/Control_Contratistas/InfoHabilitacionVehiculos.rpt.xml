<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Control_Contratistas.InfoHabilitacionVehiculos" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;FILTRO fecha=&quot;20150421&quot; oi_vehiculo=&quot;114&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:FILTRO"/>
			<REPORT label="Informe detallado de Habilitaci&#243;n de Veh&#237;culo" date="">
				<GROUPS>
					<GROUP tag="REPORTE" type="title">
						<GROUP tag="VEHICULO" type="title_sinespacios" label="" style="">
							<COLS>
								<COL name="f_hoy" label="Fecha de Ejecuci&#243;n de Informe" style="font-size:11;text-align:right;"/>
								<COL name="tipo_vehiculo" label="Tipo de Veh&#237;culo"/>
								<COL name="c_dominio" label="Dominio"/>
								<COL name="c_marca" label="Marca"/>
								<COL name="d_modelo" label="Modelo"/>
								<COL name="e_anio" label="A&#241;o Modelo"/>
								<COL name="d_empresa" label="Empresa"/>
								<COL name="d_poliza" label="P&#243;liza" style="padding-bottom:25px"/>
							</COLS>
						</GROUP>
						<GROUP type="tablestruc" label="" style="width:100%;border-top:1px solid black;">
							<GROUPROW>
								<GROUPCOL/>
							</GROUPROW>
						</GROUP>
						<GROUP tag="VEHICULO" type="title_sinespacios" label="" style="">
							<COLS>
								<COL name="fecha" label="Fecha"/>
								<COL name="habilitado" label="Estado"/>
							</COLS>
						</GROUP>
						<GROUP type="tablestruc" label="" style="width:100%;border-top:1px solid black;padding-bottom:25px">
							<GROUPROW>
								<GROUPCOL>
									<GROUP tag="VEHICULO" type="title_sinespacios" label="" style=""/>
								</GROUPCOL>
							</GROUPROW>
						</GROUP>
						<GROUP type="tablestruc" label="Informaci&#243;n a controlar de Empresa contratista" style="">
							<GROUPROW>
								<GROUPCOL>
									<GROUP tag="VEHICULO" type="title_sinespacios" label="" style="">
										<GROUP tag="ATRIBUTO_EMP" type="table" label="" style="">
											<COLS>
												<COL name="descr" label="Atributo de control" style="text-align:center; width:25%"/>
												<COL name="f_vencimiento" label="Fecha de Vencimiento" style="text-align:center; width:14%"/>
												<COL name="o_atrib_emp_con" label="Observaciones" style="text-align:center; width:45%"/>
												<COL name="c_aplica_emp" label="Aplica a Empresa" style="text-align:center; width:11%"/>
											</COLS>
										</GROUP>
									</GROUP>
								</GROUPCOL>
							</GROUPROW>
						</GROUP>
						<GROUP type="tablestruc" label="Informaci&#243;n a controlar de Veh&#237;culo contratista" style="">
							<GROUPROW>
								<GROUPCOL>
									<GROUP tag="VEHICULO" type="title_sinespacios" label="" style="">
										<GROUP tag="ATRIBUTO_VEH" type="table" label="" style="">
											<COLS>
												<COL name="descr" label="Atributo de control" style="text-align:center; width:25%"/>
												<COL name="f_vencimiento" label="Fecha de Vencimiento" style="text-align:center; width:14%"/>
												<COL name="o_atrib_vehic" label="Observaciones" style="text-align:center; width:45%"/>
												<COL name="c_aplica_veh" label="Aplica a Veh&#237;culo" style="text-align:center; width:11%"/>
											</COLS>
										</GROUP>
									</GROUP>
								</GROUPCOL>
							</GROUPROW>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REPORTE">
						<qry:insert-select doc-path="#SOURCE:FILTRO" name="qry_vehiculo"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="qry_vehiculo">
			<qry:xquery>
				for $r in sql('		
SELECT		
  CCO04_VEHICULOS.oi_vehiculo as oi_vehiculo,
  CCO04_VEHICULOS.d_modelo as d_modelo,
  CCO06_TIPOS_VEHICULO.c_tipo_vehiculo,
  CCO06_TIPOS_VEHICULO.d_tipo_vehiculo,
  CCO04_VEHICULOS.c_dominio as c_dominio,
  CCO04_VEHICULOS.c_marca as c_marca,
  CCO04_VEHICULOS.e_anio as e_anio,
  CCO04_VEHICULOS.d_poliza as d_poliza,
  CCO01_EMPRESAS_CONT.oi_empresa,
  ORG03_EMPRESAS.c_empresa,
  ORG03_EMPRESAS.d_empresa

FROM 
  CCO04_VEHICULOS, 
  CCO06_TIPOS_VEHICULO, 
  CCO01_EMPRESAS_CONT,
  ORG03_EMPRESAS
  
JOIN 
  CCO04_VEHICULOS.oi_tipo_vehiculo INNER CCO06_TIPOS_VEHICULO.oi_tipo_vehiculo,
  CCO04_VEHICULOS.oi_empresa INNER  CCO01_EMPRESAS_CONT.oi_empresa,
  CCO01_EMPRESAS_CONT.oi_empresa INNER ORG03_EMPRESAS.oi_empresa

WHERE   
 CCO04_VEHICULOS.oi_vehiculo = {%=#PARAM:@oi_vehiculo%} 

		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VEHICULO">
					<!--todos los atributos de control de empresa que si tiene la empresa -->
					<qry:insert-select name="qry_atrib_emp_todos_2" doc-path="$r"/>
					<!--todos los atributos de control de empresa que no tiene la empresa -->
					<qry:insert-select name="qry_atrib_emp_todos" doc-path="$r"/>
					<!--todos los atributos de control que si tiene el vehiculo -->
					<qry:insert-select name="qry_atrib_veh_todos_2" doc-path="$r"/>
					<!--todos los atributos de control que no tiene el vehiculo -->
					<qry:insert-select name="qry_atrib_veh_todos" doc-path="$r"/>
					<!--ACA EMPIEZA VALIDACION PARA VER SI ESTA HABILITADO -->
					<qry:attribute name="habilitado" value="'0'"/>
					<qry:attribute name="cant_atrib_veh" value="0"/>
					<qry:attribute name="cant_atrib_veh_habilitado" value="0"/>
					<qry:insert-select name="qry_atrib_veh" doc-path="$r"/>
					<!--si no existen atributos de control obligatorios cargados en el sistema para el vehiculo, se considera habilitado-->
					<qry:if test="@cant_atrib_veh=0">
						<qry:then>
							<qry:attribute name="habilitado" value="'1'"/>
						</qry:then>
						<qry:else>
							<!--si el vehiculo tiene atributos de control hay que verificar todos-->
							<qry:insert-select name="qry_atrib_veh_habilitado" doc-path="$r"/>
							<!--si todos cumplen la condicion-->
							<qry:attribute name="habilitado" value="iif(@cant_atrib_veh = @cant_atrib_veh_habilitado, '1','0')"/>
						</qry:else>
					</qry:if>
					<!--si pasa primera validacion-->
					<qry:if test="@habilitado='1'">
						<qry:then>
							<qry:attribute name="cant_atrib_emp_habilitado" value="0"/>
							<qry:insert-select name="qry_atrib_emp" doc-path="$r"/>
							<!--si la empresa no tiene atributos de control se considera habilitado-->
							<qry:if test="@cant_atrib_emp=0">
								<qry:then>
									<qry:attribute name="habilitado" value="'1'"/>
								</qry:then>
								<qry:else>
									<!--si la empresa tiene atributos de control hay que verificar todos-->
									<qry:insert-select name="qry_atrib_emp_habilitado" doc-path="$r"/>
									<!--si todos cumplen la condicion-->
									<qry:attribute name="habilitado" value="iif(@cant_atrib_emp = @cant_atrib_emp_habilitado, '1','0')"/>
								</qry:else>
							</qry:if>
						</qry:then>
						<qry:else/>
					</qry:if>
					<!--ACA TERMINA VALIDACION PARA VER SI ESTA HABILITADO -->
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
					<qry:attribute name="f_aptitud" value="iif(@f_aptitud!=0,format_date(@f_aptitud, 'dd/mm/yyyy'),'-')"/>
					<qry:attribute value="$r/@oi_vehiculo" name="oi_vehiculo"/>
					<qry:attribute value="$r/@d_modelo" name="d_modelo"/>
					<qry:attribute value="$r/@c_tipo_vehiculo+'-'+$r/@d_tipo_vehiculo" name="tipo_vehiculo"/>
					<qry:attribute value="$r/@c_dominio" name="c_dominio"/>
					<qry:attribute value="$r/@c_marca" name="c_marca"/>
					<qry:attribute value="$r/@e_anio" name="e_anio"/>
					<qry:attribute value="$r/@d_poliza" name="d_poliza"/>
					<qry:attribute name="habilitado" value="iif(@habilitado = '1','Habilitado','Inhabilitado')"/>
					<qry:attribute name="f_hoy" value="format_date(now(),'dd/mm/yyyy hh:MM')"/>
					<qry:attribute name="fecha" value="format_date($PARAM/@fecha,'dd/mm/yyyy')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_emp_todos" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_emp as c_aplica_emp
from
  CCO05_ATRIB_CTROL
WHERE 
CCO05_ATRIB_CTROL.c_aplica_emp != \'N\'
AND 
   CCO05_ATRIB_CTROL.oi_atributo_ctrol not in
    (   
     select
     CCO05_ATRIB_CTROL.oi_atributo_ctrol
     from
     CCO05_ATRIB_CTROL,  CCO01_ATRIB_EMP_CON
     JOIN
     CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO01_ATRIB_EMP_CON.oi_atributo_ctrol
     WHERE 
     CCO01_ATRIB_EMP_CON.oi_empresa={%=#PARAM:@oi_empresa%}
    )
 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ATRIBUTO_EMP">
					<qry:attribute name="oi_atrib_emp_con" value=""/>
					<qry:attribute name="id" value="$r/@ID"/>
					<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="c_aplica_emp" value="iif($r/@c_aplica_emp='S', 'Obligatorio', 'Opcional')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_emp_todos_2" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO01_ATRIB_EMP_CON.oi_atrib_emp_con as oi_atrib_emp_con,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_emp as c_aplica_emp,
  CCO01_ATRIB_EMP_CON.oi_empresa,
  CCO01_ATRIB_EMP_CON.f_vencimiento,
  CCO01_ATRIB_EMP_CON.o_atrib_emp_con
from
  CCO05_ATRIB_CTROL,
  CCO01_ATRIB_EMP_CON
JOIN
  CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO01_ATRIB_EMP_CON.oi_atributo_ctrol
WHERE 
 CCO01_ATRIB_EMP_CON.oi_empresa={#PARAM:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ATRIBUTO_EMP">
					<qry:attribute name="oi_atrib_emp_con" value="$r/@oi_atrib_emp_con"/>
					<qry:attribute name="id" value="$r/@ID"/>
					<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="f_vencimiento" value="format-date($r/@f_vencimiento,'dd/mm/yyyy')"/>
					<qry:attribute name="o_atrib_emp_con" value="$r/@o_atrib_emp_con"/>
					<qry:attribute name="c_aplica_emp" value="iif($r/@c_aplica_emp='S', 'Obligatorio', 'Opcional')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_veh_todos" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_veh as c_aplica_veh
from
  CCO05_ATRIB_CTROL
WHERE 
CCO05_ATRIB_CTROL.c_aplica_veh != \'N\'
AND 
   CCO05_ATRIB_CTROL.oi_atributo_ctrol not in
    (   
     select
     CCO05_ATRIB_CTROL.oi_atributo_ctrol
     from
     CCO05_ATRIB_CTROL,  CCO04_ATRIB_VEHIC
     JOIN
     CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO04_ATRIB_VEHIC.oi_atributo_ctrol
     WHERE 
     CCO04_ATRIB_VEHIC.oi_vehiculo={%=#PARAM:@oi_vehiculo%}
    )
 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ATRIBUTO_VEH">
					<qry:attribute name="oi_atrib_vehic" value=""/>
					<qry:attribute name="id" value="$r/@ID"/>
					<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
					<qry:attribute name="oi_vehiculo" value="$r/@oi_vehiculo"/>
					<qry:attribute name="c_aplica_veh" value="iif($r/@c_aplica_veh='S', 'Obligatorio', 'Opcional')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_veh_todos_2" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO04_ATRIB_VEHIC.oi_atrib_vehic as oi_atrib_vehic,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_veh as c_aplica_veh,
  CCO04_ATRIB_VEHIC.oi_vehiculo,
  CCO04_ATRIB_VEHIC.f_vencimiento,
  CCO04_ATRIB_VEHIC.o_atrib_vehic
from
  CCO05_ATRIB_CTROL,
  CCO04_ATRIB_VEHIC
JOIN
  CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO04_ATRIB_VEHIC.oi_atributo_ctrol
WHERE 
 CCO04_ATRIB_VEHIC.oi_vehiculo={#PARAM:@oi_vehiculo}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ATRIBUTO_VEH">
					<qry:attribute name="oi_atrib_vehic" value="$r/@oi_atrib_vehic"/>
					<qry:attribute name="id" value="$r/@ID"/>
					<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
					<qry:attribute name="oi_vehiculo" value="$r/@oi_vehiculo"/>
					<qry:attribute name="f_vencimiento" value="format-date($r/@f_vencimiento,'dd/mm/yyyy')"/>
					<qry:attribute name="o_atrib_vehic" value="$r/@o_atrib_vehic"/>
					<qry:attribute name="c_aplica_veh" value="iif($r/@c_aplica_veh='S', 'Obligatorio', 'Opcional')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_veh" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	CCO05_ATRIB_CTROL.oi_atributo_ctrol as oi_atributo_ctrol,
	CCO05_ATRIB_CTROL.c_atributo_ctrol as c_atributo_ctrol
	
FROM
	CCO05_ATRIB_CTROL
WHERE 
  CCO05_ATRIB_CTROL.c_aplica_veh = \'S\'
		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_atrib_veh" value="number(@cant_atrib_veh)+1"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_veh_habilitado" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	CCO05_ATRIB_CTROL.oi_atributo_ctrol as oi_atributo_ctrol,
	CCO04_ATRIB_VEHIC.oi_atrib_vehic as oi_atrib_vehic,
 	CCO04_ATRIB_VEHIC.f_vencimiento
FROM
	CCO05_ATRIB_CTROL, 
	CCO04_ATRIB_VEHIC
JOIN         
  CCO05_ATRIB_CTROL.oi_atributo_ctrol INNER CCO04_ATRIB_VEHIC.oi_atributo_ctrol
WHERE 
  CCO05_ATRIB_CTROL.c_aplica_veh = \'S\'
AND
  CCO04_ATRIB_VEHIC.oi_vehiculo = {#PARAM:@oi_vehiculo}
AND 
  CCO04_ATRIB_VEHIC.f_vencimiento &gt;= {Datetime(#PARAMIN:@fecha)} 
		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="habilitado" value="'1'"/>
				<qry:attribute name="cant_atrib_veh_habilitado" value="number(@cant_atrib_veh_habilitado)+1"/>
				<qry:element name="ATRIB_VEH">
					<qry:attribute name="oi_atrib_vehic" value="$r/@oi_atrib_vehic"/>
					<qry:attribute name="oi_atributo_ctrol" value="$r/@oi_atributo_ctrol"/>
					<qry:attribute name="f_vencimiento" value="format-date($r/@f_vencimiento, 'yyyymmdd')"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_emp" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	CCO05_ATRIB_CTROL.oi_atributo_ctrol as oi_atributo_ctrol
FROM
	CCO05_ATRIB_CTROL
WHERE 
  CCO05_ATRIB_CTROL.c_aplica_emp = \'S\'
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_atrib_emp" value="number(@cant_atrib_emp)+1"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_atrib_emp_habilitado" doc="PARAM">
			<qry:xquery>
				for $r in sql('		
SELECT 
	CCO05_ATRIB_CTROL.oi_atributo_ctrol as oi_atributo_ctrol,
	CCO01_ATRIB_EMP_CON.oi_atrib_emp_con as oi_atrib_emp_con,
	CCO01_ATRIB_EMP_CON.oi_empresa,
	CCO01_ATRIB_EMP_CON.f_vencimiento
FROM
	CCO05_ATRIB_CTROL, 
	CCO01_ATRIB_EMP_CON
JOIN         
  CCO05_ATRIB_CTROL.oi_atributo_ctrol INNER CCO01_ATRIB_EMP_CON.oi_atributo_ctrol
WHERE 
  CCO05_ATRIB_CTROL.c_aplica_emp = \'S\'
AND
  CCO01_ATRIB_EMP_CON.oi_empresa = {#PARAM:@oi_empresa} 
AND 
  CCO01_ATRIB_EMP_CON.f_vencimiento &gt;= {Datetime(#PARAMIN:@fecha)} 
		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="habilitado" value="'1'"/>
				<qry:attribute name="cant_atrib_emp_habilitado" value="number(@cant_atrib_emp_habilitado)+1"/>
				<qry:element name="ATRIB_EMP">
					<qry:attribute name="oi_atrib_emp_con" value="$r/@oi_atrib_emp_con"/>
					<qry:attribute name="oi_atributo_ctrol" value="$r/@oi_atributo_ctrol"/>
					<qry:attribute name="f_vencimiento" value="format-date($r/@f_vencimiento, 'yyyymmdd')"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
