<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Personal.LegajosPorEmpresa">
	<html:query declare="&lt;DATOS oi_accidente=&quot;14&quot; /&gt;">
		<qry:main doc="PARAM">
			<qry:element name="DATOS">
				<qry:insert-select doc-path="#PARAM:DATOS" name="sql1"/>
				<qry:element name="TESTIGOS">
					<qry:insert-select doc-path="#PARAM:DATOS" name="sql91"/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="sql1">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ACC01_ACCIDENTES.oi_elemento_pp, 
					ACC01_ACCIDENTES.oi_ocupacion, 
					ACC01_ACCIDENTES.oi_incapacidad, 
					ACC01_ACCIDENTES.oi_condic_pelig, 
					ACC01_ACCIDENTES.oi_acto_inseg, 
					ACC01_ACCIDENTES.oi_reg_cuerpo, 
					ACC01_ACCIDENTES.oi_factor_cont, 
					ACC01_ACCIDENTES.oi_tipo_acc, 
					ACC01_ACCIDENTES.oi_agente_caus, 
					ACC01_ACCIDENTES.oi_personal_emp, 					
					ACC01_ACCIDENTES.f_fechahora_revis, 
					ACC01_ACCIDENTES.e_dias_perdidos, 
					ACC01_ACCIDENTES.f_fechahora_acc, 
					ACC01_ACCIDENTES.f_fechahora_baja, 
					ACC01_ACCIDENTES.f_fechahora_alta, 
					ACC01_ACCIDENTES.o_accion_aconsej, 
					ACC01_ACCIDENTES.o_accidente,
					ACC01_ACCIDENTES.oi_natur_lesion, 
					ACC01_ACCIDENTES.l_denunciado,
					ACC01_ACCIDENTES.e_valor_grado, 
					ACC01_ACCIDENTES.n_porc_grado,
					ACC01_ACCIDENTES.oi_tipo_siniestro
				FROM 
					ACC01_ACCIDENTES		
				WHERE 
					ACC01_ACCIDENTES.oi_accidente = {#PARAM:@oi_accidente}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				<qry:attribute name="f_fechahora_revis" value="format_date($r/@f_fechahora_revis,'dd/mm/yyyy')"/>
				<qry:attribute name="e_dias_perdidos" value="$r/@e_dias_perdidos"/>
				<qry:attribute name="f_fecha_acc" value="format_date($r/@f_fechahora_acc,'dd/mm/yyyy')"/>
				<qry:attribute name="f_hora_acc" value="format_date($r/@f_fechahora_acc,'HH:MM:SS')"/>
				<qry:attribute name="f_fechahora_baja" value="format_date($r/@f_fechahora_baja,'dd/mm/yyyy')"/>
				<qry:attribute name="f_fechahora_alta" value="format_date($r/@f_fechahora_alta,'dd/mm/yyyy')"/>
				<qry:attribute name="o_accion_aconsej" value="$r/@o_accion_aconsej"/>
				<qry:attribute name="o_accidente" value="$r/@o_accidente"/>
				<qry:attribute name="e_valor_grado" value="$r/@e_valor_grado"/>
				<qry:attribute name="n_porc_grado" value="number($r/@n_porc_grado)"/>
				<qry:attribute name="l_denunciado" value="iif($r/@l_denunciado='1', 'Si', 'No')"/>
				<qry:insert-select name="sql_personal" doc-path="."/>
				<qry:insert-select name="sql_empresa" doc-path="."/>
				<qry:insert-select name="sql2" doc-path="$r"/>
				<qry:insert-select name="sql3" doc-path="$r"/>
				<qry:insert-select name="sql4" doc-path="$r"/>
				<qry:insert-select name="sql5" doc-path="$r"/>
				<qry:insert-select name="sql6" doc-path="$r"/>
				<qry:insert-select name="sql7" doc-path="$r"/>
				<qry:insert-select name="sql8" doc-path="$r"/>
				<qry:insert-select name="sql9" doc-path="$r"/>
				<qry:insert-select name="sql10" doc-path="$r"/>
				<qry:insert-select name="sql11" doc-path="$r"/>
				<qry:insert-select name="sql12" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql_personal">
			<qry:xquery>
				for $r in sql('
					SELECT PER02_PERSONAL_EMP.e_numero_legajo, PER02_PERSONAL_EMP.oi_empresa, 
					PER01_PERSONAL.d_ape_y_nom, PER01_PERSONAL.c_nro_documento, 
					PER01_PERSONAL.oi_tipo_documento, PER02_PERSONAL_EMP.f_ingreso
					FROM PER02_PERSONAL_EMP, PER01_PERSONAL
					JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
					WHERE PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="c_nro_documento" value="$r/@c_nro_documento"/>
				<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso,'dd/mm/yyyy')"/>
				<qry:insert-select name="sql92" doc-path="$r"/>
				<qry:insert-select name="sql_empresa" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql_empresa">
			<qry:xquery>
				for $r in sql('
					SELECT ORG03_EMPRESAS.d_empresa, ORG03_EMPRESAS.c_cuit, 
					ORG03_EMPRESAS.te_telefono, ORG03_EMPRESAS.d_calle, ORG03_EMPRESAS.e_piso,
					ORG03_EMPRESAS.d_departamento, ORG03_EMPRESAS.e_numero
					FROM ORG03_EMPRESAS
					WHERE ORG03_EMPRESAS.oi_empresa = {#PARAM:@oi_empresa}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="c_cuit" value="$r/@c_cuit"/>
				<qry:attribute name="te_telefono" value="$r/@te_telefono"/>
				<qry:attribute name="d_calle" value="$r/@d_calle"/>
				<qry:attribute name="e_numero" value="$r/@e_numero"/>
				<qry:attribute name="e_piso" value="$r/@e_piso"/>
				<qry:attribute name="d_departamento" value="$r/@d_departamento"/>
				<qry:attribute name="d_domicilio" value="$r/@d_calle + ' ' + $r/@e_numero"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql2">
			<qry:xquery>
				for $r in sql('
					SELECT ORG07_ELEMENTOS_PP.oi_elemento_pp, 
					ORG07_ELEMENTOS_PP.c_elemento_pp, 
					ORG07_ELEMENTOS_PP.d_elemento_pp
					FROM ORG07_ELEMENTOS_PP 
					WHERE ORG07_ELEMENTOS_PP.oi_elemento_pp={#PARAM:@oi_elemento_pp}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_elemento_pp" value="$r/@c_elemento_pp"/>
				<qry:attribute name="d_elemento_pp" value="$r/@d_elemento_pp"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql3">
			<qry:xquery>
				for $r in sql('
					SELECT ACC09_REG_CUERPO.oi_reg_cuerpo, 
					ACC09_REG_CUERPO.c_reg_cuerpo, 
					ACC09_REG_CUERPO.d_reg_cuerpo
					FROM ACC09_REG_CUERPO 
					WHERE ACC09_REG_CUERPO.oi_reg_cuerpo={#PARAM:@oi_reg_cuerpo}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_reg_cuerpo" value="$r/@c_reg_cuerpo"/>
				<qry:attribute name="d_reg_cuerpo" value="$r/@d_reg_cuerpo"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql4">
			<qry:xquery>
				for $r in sql('
					SELECT ACC10_TIPOS_ACC.oi_tipo_acc,
					ACC10_TIPOS_ACC.c_tipo_acc,
					ACC10_TIPOS_ACC.d_tipo_acc
					FROM ACC10_TIPOS_ACC 
					WHERE ACC10_TIPOS_ACC.oi_tipo_acc={#PARAM:@oi_tipo_acc}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_tipo_acc" value="$r/@c_tipo_acc"/>
				<qry:attribute name="d_tipo_acc" value="$r/@d_tipo_acc"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql5">
			<qry:xquery>
				for $r in sql('
					SELECT ACC02_ACTOS_INSEG.oi_acto_inseg,
					ACC02_ACTOS_INSEG.c_acto_inseg,
					ACC02_ACTOS_INSEG.d_acto_inseg
					FROM ACC02_ACTOS_INSEG 
					WHERE ACC02_ACTOS_INSEG.oi_acto_inseg={#PARAM:@oi_acto_inseg}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_acto_inseg" value="$r/@c_acto_inseg"/>
				<qry:attribute name="d_acto_inseg" value="$r/@d_acto_inseg"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql6">
			<qry:xquery>
				for $r in sql('
					SELECT ACC03_AGENTES_CAUS.oi_agente_caus,
					ACC03_AGENTES_CAUS.c_agente_caus,
					ACC03_AGENTES_CAUS.d_agente_caus
					FROM ACC03_AGENTES_CAUS 
					WHERE ACC03_AGENTES_CAUS.oi_agente_caus={#PARAM:@oi_agente_caus}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_agente_caus" value="$r/@c_agente_caus"/>
				<qry:attribute name="d_agente_caus" value="$r/@d_agente_caus"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql7">
			<qry:xquery>
				for $r in sql('
					SELECT ACC04_CONDIC_PELIG.oi_condic_pelig,
					ACC04_CONDIC_PELIG.c_condic_pelig,
					ACC04_CONDIC_PELIG.d_condic_pelig
					FROM ACC04_CONDIC_PELIG 
					WHERE ACC04_CONDIC_PELIG.oi_condic_pelig={#PARAM:@oi_condic_pelig}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_condic_pelig" value="$r/@c_condic_pelig"/>
				<qry:attribute name="d_condic_pelig" value="$r/@d_condic_pelig"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql8">
			<qry:xquery>
				for $r in sql('
					SELECT ACC05_FACTOR_CONT.oi_factor_cont,
					ACC05_FACTOR_CONT.c_factor_cont,
					ACC05_FACTOR_CONT.d_factor_cont
					FROM ACC05_FACTOR_CONT 
					WHERE ACC05_FACTOR_CONT.oi_factor_cont={#PARAM:@oi_factor_cont}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_factor_cont" value="$r/@c_factor_cont"/>
				<qry:attribute name="d_factor_cont" value="$r/@d_factor_cont"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql9">
			<qry:xquery>
				for $r in sql('
					SELECT ACC06_INCAPACIDAD.oi_incapacidad,
					ACC06_INCAPACIDAD.c_incapacidad,
					ACC06_INCAPACIDAD.d_incapacidad
					FROM ACC06_INCAPACIDAD 
					WHERE ACC06_INCAPACIDAD.oi_incapacidad={#PARAM:@oi_incapacidad}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_incapacidad" value="$r/@c_incapacidad"/>
				<qry:attribute name="d_incapacidad" value="$r/@d_incapacidad"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql10">
			<qry:xquery>
				for $r in sql('
					SELECT ACC07_NATUR_LESION.oi_natur_lesion,
					ACC07_NATUR_LESION.c_natur_lesion,
					ACC07_NATUR_LESION.d_natur_lesion
					FROM ACC07_NATUR_LESION 
					WHERE ACC07_NATUR_LESION.oi_natur_lesion={#PARAM:@oi_natur_lesion}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_natur_lesion" value="$r/@c_natur_lesion"/>
				<qry:attribute name="d_natur_lesion" value="$r/@d_natur_lesion"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql11">
			<qry:xquery>
				for $r in sql('
					SELECT ACC08_OCUPACIONES.oi_ocupacion,
					ACC08_OCUPACIONES.c_ocupacion,
					ACC08_OCUPACIONES.d_ocupacion
					FROM ACC08_OCUPACIONES 
					WHERE ACC08_OCUPACIONES.oi_ocupacion={#PARAM:@oi_ocupacion}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_ocupacion" value="$r/@c_ocupacion"/>
				<qry:attribute name="d_ocupacion" value="$r/@d_ocupacion"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql91">
			<qry:xquery>
				for $r in sql('
					SELECT ACC01_TESTIGOS.oi_testigo, 
					ACC01_TESTIGOS.oi_accidente, 
					ACC01_TESTIGOS.e_testigo, 
					ACC01_TESTIGOS.c_nro_documento, 
					ACC01_TESTIGOS.d_apellido, 
					ACC01_TESTIGOS.d_nombres, 
					ACC01_TESTIGOS.d_domicilio, 
					ACC01_TESTIGOS.o_testigo, 
					ACC01_TESTIGOS.oi_tipo_documento 
					FROM ACC01_TESTIGOS 
					WHERE ACC01_TESTIGOS.oi_accidente={#PARAM:@oi_accidente}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="TESTIGO">
					<qry:attribute name="e_testigo" value="$r/@e_testigo"/>
					<qry:attribute name="c_nro_documento" value="$r/@c_nro_documento"/>
					<qry:attribute name="d_apellido" value="$r/@d_apellido"/>
					<qry:attribute name="d_nombres" value="$r/@d_nombres"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_apellido + ', ' + $r/@d_nombres"/>
					<qry:attribute name="d_domicilio" value="$r/@d_domicilio"/>
					<qry:insert-select name="sql92" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql92">
			<qry:xquery>
				for $r in sql('
					SELECT PER20_TIPOS_DOC.oi_tipo_documento,
					PER20_TIPOS_DOC.c_tipo_documento,
					PER20_TIPOS_DOC.d_tipo_documento
					FROM PER20_TIPOS_DOC 
					WHERE PER20_TIPOS_DOC.oi_tipo_documento={#PARAM:@oi_tipo_documento}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento"/>
				<qry:attribute name="d_tipo_documento" value="$r/@d_tipo_documento"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql12">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ACC13_TIP_SINIESTRO.oi_tipo_siniestro,
					ACC13_TIP_SINIESTRO.c_tipo_siniestro,
					ACC13_TIP_SINIESTRO.d_tipo_siniestro
				FROM 
					ACC13_TIP_SINIESTRO 
				WHERE 
					ACC13_TIP_SINIESTRO.oi_tipo_siniestro={#PARAM:@oi_tipo_siniestro}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="c_tipo_siniestro" value="$r/@c_tipo_siniestro"/>
				<qry:attribute name="d_tipo_siniestro" value="$r/@d_tipo_siniestro"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="DATOS">
			<html>
				<head>
					<style>
						table	{ border:1px solid black; font-size:8pt; border-collapse: collapse; }
				 	td		{ border:solid 1px black; }
				 .title	{ font-size:8pt; }
				 .title1{ font-size:10pt; background-color:#DDDDDD }
				 .title2{ font-size:8pt; background-color:#DDDDDD }
				 .space{ background-color:#AAAAAA; font-size:2px; }
					</style>
				</head>
				<body bgcolor="#FFFFFF" style="font-size:9pt; font-family:arial">
					<table width="100%" border="0" cellspacing="0" cellpadding="2">
						<tr>
							<td colspan="4" align="center" class="title1">
								<span>
									<b>
										DENUNCIA DE ACCIDENTE DE TRABAJO
									</b>
								</span>
							</td>
						</tr>
						<tr>
							<td width="100%" colspan="3">
								<span>
									&#160;
								</span>
							</td>
							<td width="40%" align="center" nowrap="1">
								<span class="title">
									<b>
										Fecha Siniestro
									</b>
								</span>
								<br/>
								<xsl:value-of select="@f_fecha_acc"/>
							</td>
						</tr>
						<tr class="space">
							<td colspan="4" height="2px">
								<span>
									&#160;
								</span>
							</td>
						</tr>
						<tr class="title2">
							<td align="center" colspan="4">
								<b>
									Datos del Empleador
								</b>
							</td>
						</tr>
						<tr>
							<td width="40%" nowrap="1" colspan="2">
								<span class="title">
									<b>
										Raz&#243;n Social
									</b>
								</span>
								<br/>
								<xsl:value-of select="@d_empresa"/>
							</td>
							<td width="30%" nowrap="1">
								<span class="title">
									<b>
										C.U.I.T. N&#176;
									</b>
								</span>
								<br/>
								<xsl:value-of select="@c_cuit"/>
							</td>
							<td width="30%" nowrap="1">
								<span class="title">
									<b>
										Tel&#233;fono
									</b>
								</span>
								<br/>
								<xsl:value-of select="@te_telefono"/>
							</td>
						</tr>
						<tr class="space">
							<td colspan="4" height="2px">
								<span>
									&#160;
								</span>
							</td>
						</tr>
						<tr class="title2">
							<td align="center" colspan="4">
								<b>
									Datos del Trabajador Accidentado
								</b>
							</td>
						</tr>
						<tr>
							<td nowrap="1" colspan="2">
								<span class="title">
									<b>
										Apellido y Nombre
									</b>
								</span>
								<br/>
								<xsl:value-of select="@d_ape_y_nom"/>
							</td>
							<td nowrap="1" colspan="2">
								<span class="title">
									<b>
										Ocupaci&#243;n
									</b>
								</span>
								<br/>
								<xsl:value-of select="@d_ocupacion"/>
							</td>
						</tr>
						<tr>
							<td width="40%" nowrap="1">
								<span class="title">
									<b>
										N&#250;mero de Legajo
									</b>
								</span>
								<br/>
								<xsl:value-of select="@e_numero_legajo"/>
							</td>
							<td width="30%" nowrap="1" colspan="2">
								<span class="title">
									<b>
										Tipo / N&#250;mero de Documento
									</b>
