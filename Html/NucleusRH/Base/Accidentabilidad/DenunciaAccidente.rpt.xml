									<b>
										Fecha de Ingreso
									</b>
								</span>
								<br/>
								<xsl:value-of select="@f_ingreso"/>
							</td>
						</tr>
						<tr class="space">
							<td colspan="4" height="2px">
								<span>
									&#160;
								</span>
							</td>
						</tr>
						<tr class="title2">
							<td align="center" colspan="4">
								<b>
									Datos del Accidente
								</b>
							</td>
						</tr>
						<tr>
