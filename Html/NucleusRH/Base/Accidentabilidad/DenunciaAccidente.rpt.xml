								<span class="title">
									<b>
										Fecha del Accidente
									</b>
								</span>
								<br/>
								<xsl:value-of select="@f_fecha_acc"/>
							</td>
							<td width="20%" nowrap="1">
								<span class="title">
									<b>
										Hora del Accidente
									</b>
								</span>
								<br/>
								<xsl:value-of select="@f_hora_acc"/>
							</td>
							<td width="20%" nowrap="1">
								<span class="title">
									<b>
