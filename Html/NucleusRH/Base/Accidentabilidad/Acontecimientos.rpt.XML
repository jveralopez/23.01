<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Accidentabilidad.Acontecimientos">
	<html:query declare="&lt;DATA  f_desde=&quot;20070101&quot; f_hasta=&quot;20140101&quot; c_group=&quot;sinagrup&quot; l_acciones=&quot;1&quot;/&gt;">
		<qry:main doc="SOURCE">
			<DATOS>
				<qry:append-doc name="PARAMETRO" doc-path="#SOURCE:DATA"/>
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<qry:attribute name="f_desde" value="format_date(#PARAMETRO:@f_desde,'dd/mm/yyyy')"/>
				<qry:attribute name="f_hasta" value="format_date(#PARAMETRO:@f_hasta,'dd/mm/yyyy')"/>
				<qry:attribute name="c_group" value="#PARAMETRO:@c_group"/>
				<qry:attribute name="l_acciones" value="#PARAMETRO:@l_acciones"/>
				<qry:if test="#PARAMETRO:@c_group!='causa'">
					<qry:then>
						<qry:insert-select name="qryAcontecimientos" doc-path="#SOURCE:DATA"/>
					</qry:then>
					<qry:else>
						<qry:insert-select name="qryGroup" doc-path="#SOURCE:DATA"/>
					</qry:else>
				</qry:if>
			</DATOS>
		</qry:main>
		<qry:select name="qryGroup" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT
					ACC12_ACONTEC.o_causa_acontec
				FROM
					ACC12_ACONTEC
				WHERE
					ACC12_ACONTEC.f_fechahora_acont &gt;= {Datetime(#PARAM:@f_desde)}
				AND ACC12_ACONTEC.f_fechahora_acont &lt;= {Datetime(#PARAM:@f_hasta)}
				
				GROUP BY
					ACC12_ACONTEC.o_causa_acontec	
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<CAUSA>
					<qry:attribute name="o_causa_acontec" value="$r/@o_causa_acontec"/>
					<qry:attribute name="f_desde" value="#PARAM:@f_desde"/>
					<qry:attribute name="f_hasta" value="#PARAM:@f_hasta"/>
					<qry:attribute name="l_acciones" value="#PARAM:@l_acciones"/>
					<qry:attribute name="c_group" value="#PARAM:@c_group"/>
					<qry:insert-select name="qryAcontecimientos" doc-path="."/>
				</CAUSA>
			</qry:out>
		</qry:select>
		<qry:select name="qryAcontecimientos" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT
					ACC12_ACONTEC.oi_acontecimiento,
					ACC12_ACONTEC.c_acontecimiento,
					ACC12_ACONTEC.d_acontecimiento,
					ACC12_ACONTEC.f_fechahora_acont,
					ACC12_ACONTEC.o_causa_acontec,
					ACC12_ACONTEC.e_gravedad,
					ACC12_ACONTEC.n_probabilidad,
					ACC12_ACONTEC.o_acontecimiento
				FROM
					ACC12_ACONTEC
				WHERE
					ACC12_ACONTEC.f_fechahora_acont &gt;= {Datetime(#PARAM:@f_desde)}
				AND ACC12_ACONTEC.f_fechahora_acont &lt;= {Datetime(#PARAM:@f_hasta)}
					{%? (#PARAM:@c_group = 'causa') 
						{% AND ACC12_ACONTEC.o_causa_acontec = {#PARAM:@o_causa_acontec} %} 
						{% %} 
					%}
				
				ORDER BY
					f_fechahora_acont DESC		
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<ACONTECIMIENTO>
					<qry:attribute name="oi_acontecimiento" value="$r/@oi_acontecimiento"/>
					<qry:attribute name="c_acontecimiento" value="$r/@c_acontecimiento"/>
					<qry:attribute name="d_acontecimiento" value="$r/@d_acontecimiento"/>
					<qry:attribute name="f_fechahora_acont" value="format-date($r/@f_fechahora_acont,'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="o_causa_acontec" value="$r/@o_causa_acontec"/>
					<qry:attribute name="e_gravedad" value="$r/@e_gravedad"/>
					<qry:attribute name="n_probabilidad" value="$r/@n_probabilidad"/>
					<qry:attribute name="o_acontecimiento" value="$r/@o_acontecimiento"/>
					<qry:insert-select name="qryAccionesCorrectivas" doc-path="."/>
				</ACONTECIMIENTO>
			</qry:out>
		</qry:select>
		<qry:select name="qryAccionesCorrectivas" doc="PARAM">
			<qry:xquery>
				for $r in SQL('    
				SELECT
					ACC12_ACC_CORREC.c_acc_correc,
					ACC12_ACC_CORREC.d_acc_correc,
					ACC12_ACC_CORREC.f_prog_accion, 
					ACC12_ACC_CORREC.f_ejec_accion,
					ACC12_ACC_CORREC.o_acc_correc,
					PER02_PERSONAL_EMP.e_numero_legajo,  
					PER01_PERSONAL.d_ape_y_nom
				FROM
					ACC12_ACC_CORREC,
					PER02_PERSONAL_EMP,
					PER01_PERSONAL 
				JOIN
					ACC12_ACC_CORREC.oi_personal_resp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE
					ACC12_ACC_CORREC.oi_acontecimiento = {#PARAM:@oi_acontecimiento}
		
					')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<ACCION_CORRECTIVA>
					<qry:attribute name="c_acc_correc" value="$r/@c_acc_correc"/>
					<qry:attribute name="d_acc_correc" value="$r/@d_acc_correc"/>
					<qry:attribute name="f_prog_accion" value="format-date($r/@f_prog_accion,'dd/mm/yyyy')"/>
					<qry:attribute name="f_ejec_accion" value="format-date($r/@f_ejec_accion,'dd/mm/yyyy')"/>
					<qry:attribute name="o_acc_correc" value="$r/@o_acc_correc"/>
					<qry:attribute name="usuario_resp" value="concat($r/@e_numero_legajo,'-',$r/@d_ape_y_nom)"/>
				</ACCION_CORRECTIVA>
			</qry:out>
		</qry:select>
	</html:query>
