		<qry:select doc="PARAM" name="sql1">
			<qry:xquery>
				for $r in sql('
			SELECT
				{%? (#PARAM:@orden!=''){% {%= #PARAM:@orden %} as Orden,%}{% %} %}
				ACC01_ACCIDENTES.oi_personal_emp, 
				ACC01_ACCIDENTES.f_fechahora_acc, 
				PER01_PERSONAL.d_ape_y_nom, 
				PER02_PERSONAL_EMP.e_numero_legajo,
				ORG03_UBICACIONES.c_ubicacion,
				ORG03_UBICACIONES.d_ubicacion,
				ACC01_ACCIDENTES.f_fechahora_baja,
				ACC01_ACCIDENTES.f_fechahora_alta,
				ACC01_ACCIDENTES.e_dias_perdidos,
				ACC01_ACCIDENTES.oi_tipo_siniestro
			FROM 
				ACC01_ACCIDENTES, 
				PER02_PERSONAL_EMP, 
				PER01_PERSONAL,
				ORG03_UBICACIONES
			JOIN 
				ACC01_ACCIDENTES.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
				PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER ORG03_UBICACIONES.oi_ubicacion
			WHERE 
				PER02_PERSONAL_EMP.oi_empresa = {#PARAM:@oi_empresa} AND
				PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})
				{%? (#PARAM:@f_hasta!= '') {% AND ACC01_ACCIDENTES.f_fechahora_baja &lt; {Datetime(Number(Datetime(#PARAM:@f_hasta))+1)} %} {% %} %} 
				{%? (#PARAM:@f_desde!= '') {% AND ACC01_ACCIDENTES.f_fechahora_alta &gt; {Datetime(Number(Datetime(#PARAM:@f_desde)))} %} {% %} %}
				
			{%? (#PARAM:@orden!='') 
				{%ORDER BY orden ASC %} 
				{% %} 
			%}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PERSONA">
					<qry:attribute name="orderby" value="$r/@orden"/>
					<qry:attribute name="oi_tipo_siniestro" value="$r/@oi_tipo_siniestro"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="d_personal_emp" value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom"/>
					<qry:attribute name="f_fechahora_acc" value="format_date($r/@f_fechahora_acc,'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="c_ubicacion" value="$r/@c_ubicacion"/>
					<qry:attribute name="d_ubicacion" value="$r/@d_ubicacion"/>
					<qry:attribute name="f_fechahora_baja" value="format_date($r/@f_fechahora_baja,'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="f_fechahora_alta" value="format_date($r/@f_fechahora_alta,'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="e_dias_perdidos" value="$r/@e_dias_perdidos"/>
					<qry:insert-select doc-path="." name="sql2"/>
				</qry:element>
			</qry:out>
		</qry:select>
