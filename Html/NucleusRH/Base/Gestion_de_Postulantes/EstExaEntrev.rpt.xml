<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Gestion_de_Postulantes.EstExaEntrev" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;PARAMS id=&quot;1178&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Estado de Ex&#225;menes y Entrevistas">
				<GROUPS>
					<GROUP tag="REC" type="title">
						<COLS>
							<COL name="d_reclutado" label="Reclutado"/>
						</COLS>
						<GROUP tag="EXA" type="table" style="width:65%;" label="Ex&#225;menes" noreg="No tiene ex&#225;menes registrados.">
							<COLS>
								<COL name="d_tipo_examen" label="Tipo Examen" style="width:25%;"/>
								<COL name="d_examen" label="Examen" style="width:25%;"/>
								<COL name="f_fecha_hora_exa" label="Fecha" style="width:20%;text-align:center;"/>
								<COL name="estado" label="Estado" style="width:20%;text-align:center;"/>
							</COLS>
						</GROUP>
						<GROUP tag="ENTREV" type="table" style="width:40%;" label="Entrevistas" noreg="No tiene entrevistas registradas.">
							<COLS>
								<COL name="f_fecha_hora_ent" label="Fecha" style="width:20%;"/>
								<COL name="estado" label="Estado" style="width:20%;text-align:center;"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REC">
						<qry:insert-select doc-path="#SOURCE:PARAMS" name="QRY_RECLUTADO"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="QRY_RECLUTADO">
			<qry:xquery>
				for $r in SQL('
				SELECT
					SEL13_RECLUTADOS.oi_reclutado,					
					SEL13_RECLUTADOS.d_reclutado
				FROM
					SEL13_RECLUTADOS
				WHERE
					SEL13_RECLUTADOS.oi_reclutado={#SOURCE:@id}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_reclutado" value="$r/@d_reclutado"/>
				<qry:insert-select doc-path="$r" name="QRY_EXAMEN"/>
				<qry:insert-select doc-path="$r" name="QRY_ENTREVISTA"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="QRY_ENTREVISTA">
			<qry:xquery>
				for $r in SQL('
				SELECT
					SEL13_ENTREV_REC.f_fecha_hora_ent,					
					SEL13_ENTREV_REC.c_estado
				FROM
					SEL13_ENTREV_REC
				WHERE
					SEL13_ENTREV_REC.oi_reclutado={#SOURCE:@oi_reclutado}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ENTREV">
					<qry:attribute value="format_date($r/@f_fecha_hora_ent,'dd/mm/yyyy')" name="f_fecha_hora_ent"/>
					<qry:attribute name="estado" value="iif($r/@c_estado = 'RE', 'Realizada', 'No Realizada')"/>
					<!--qry:switch test="$r/@c_estado">
				<qry:case value="PL">
					<qry:attribute name="estado" value="'Planificada'"/>
				</qry:case>
				<qry:case value="RE">
					<qry:attribute name="estado" value="'Realizada'"/>
				</qry:case>
				<qry:case value="PO">
					<qry:attribute name="estado" value="'Postergada'"/>
				</qry:case>
				<qry:case value="NR">
					<qry:attribute name="estado" value="'No Realizada'"/>
				</qry:case>
			</qry:switch-->
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="QRY_EXAMEN">
			<qry:xquery>
				for $r in SQL('
				SELECT
					SEL07_EXAMENES.d_examen,					
					SEL13_EXA_REC.f_fecha_hora_exa,					
					SEL13_EXA_REC.c_estado,
					SEL24_TIPOS_EXAMEN.d_tipo_examen
				FROM
					SEL13_EXA_REC,
					SEL02_REF_EXAMEN,
					SEL07_EXAMENES,
					SEL24_TIPOS_EXAMEN
				JOIN
					SEL13_EXA_REC.oi_ref_examen INNER SEL02_REF_EXAMEN.oi_ref_examen,
					SEL02_REF_EXAMEN.oi_examen INNER SEL07_EXAMENES.oi_examen,
					SEL07_EXAMENES.oi_tipo_examen LEFT OUTER SEL24_TIPOS_EXAMEN.oi_tipo_examen
				WHERE
					SEL13_EXA_REC.oi_reclutado={#SOURCE:@oi_reclutado}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EXA">
					<qry:attribute value="$r/@d_examen" name="d_examen"/>
					<qry:attribute value="$r/@d_tipo_examen" name="d_tipo_examen"/>
					<qry:attribute value="format_date($r/@f_fecha_hora_exa,'dd/mm/yyyy')" name="f_fecha_hora_exa"/>
					<qry:attribute name="estado" value="iif($r/@c_estado = 'RE', 'Realizado', 'No Realizado')"/>
					<!--qry:switch test="$r/@c_estado">
				<qry:case value="PL">
					<qry:attribute name="estado" value="'Planificado'"/>
				</qry:case>
				<qry:case value="RE">
					<qry:attribute name="estado" value="'Realizado'"/>
				</qry:case>
				<qry:case value="PO">
					<qry:attribute name="estado" value="'Postergado'"/>
				</qry:case>
				<qry:case value="NR">
					<qry:attribute name="estado" value="'No Realizado'"/>
				</qry:case>
			</qry:switch-->
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
