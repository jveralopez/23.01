<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Gestion_de_Postulantes.ListadoSeleccionados.rpt" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;DATOS oi_referencia=&quot;1&quot; Mensaje=&quot;&quot; cant=&quot;2&quot;&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;1580&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;1575&quot; /&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&lt;/DATOS&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Listado de Seleccionados" marco="0">
				<GROUPS>
					<GROUP tag="DATOS" type="title">
						<COLS>
							<COL name="empresa" label="Empresa"/>
							<COL name="referencia" label="Referencia"/>
							<COL name="puesto" label="Puesto"/>
						</COLS>
						<GROUP tag="ROWS" type="title">
							<GROUP tag="ROW" type="table" style="width:600px;" noreg="No se encontraron registros Seleccionados.">
								<COLS>
									<COL name="c_reclutado" label="C&#243;digo" style="width:100px;"/>
									<COL name="d_reclutado" label="Persona" style="width:400px;"/>
									<COL name="f_reclutamiento" label="Fecha Reclutamiento" style="width:100px;text-align:center" type="date"/>
								</COLS>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="DATOS">
						<qry:insert-select name="QRY_REF" doc-path="#SOURCE:DATOS"/>
						<ROWS>
							<qry:insert-select name="QRY_DATOS" doc-path="#SOURCE:DATOS/ROWS/ROW"/>
						</ROWS>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_REF" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				REF.c_referencia,
				REF.d_referencia,
				REF.oi_puesto
			FROM 
				SEL02_REFERENCIAS AS REF
			WHERE
				REF.oi_referencia = {#SOURCE:@oi_referencia}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="referencia" value="$r/@c_referencia + ' - ' + $r/@d_referencia"/>
				<qry:insert-select name="QRY_PUESTO" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PUESTO" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				PUES.c_puesto,
				PUES.d_puesto,
				PUES.oi_empresa
			FROM 
				ORG04_PUESTOS AS PUES
			WHERE
				PUES.oi_puesto = {#SOURCE:@oi_puesto}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="puesto" value="$r/@c_puesto + ' - ' + $r/@d_puesto"/>
				<qry:insert-select name="QRY_EMPRESA" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_EMPRESA" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				EMP.c_empresa,
				EMP.d_empresa
			FROM 
				ORG03_EMPRESAS AS EMP
			WHERE
				EMP.oi_empresa = {#SOURCE:@oi_empresa}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="empresa" value="$r/@c_empresa + ' - ' + $r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_DATOS" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				REC.f_reclutamiento,
				REC.c_reclutado,
				REC.d_reclutado
			FROM 
				SEL13_RECLUTADOS AS REC
			WHERE
				REC.oi_reclutado = {#SOURCE:@id}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<ROW>
					<qry:attribute name="f_reclutamiento" value="format_date($r/@f_reclutamiento, 'dd/mm/yyyy')"/>
					<qry:attribute name="c_reclutado" value="$r/@c_reclutado"/>
					<qry:attribute name="d_reclutado" value="$r/@d_reclutado"/>
				</ROW>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
