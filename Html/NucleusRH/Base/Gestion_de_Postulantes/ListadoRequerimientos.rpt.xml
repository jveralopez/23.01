<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Gestion_de_Postulantes.ListadoRequerimientos.rpt" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query declare="&lt;FILTRO oi_empresa=&quot;&quot; oi_req=&quot;&quot; f_desde_req=&quot;20010108&quot; f_hasta_req=&quot;20111208&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="#SOURCE:FILTRO"/>
			<REPORT label="Listado de Requerimientos">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="REP" type="title">
						<COLS>
							<qry:if test="#FILTRO:@f_desde_req!=''">
								<qry:then>
									<COL name="f_desde_req" label="Fecha Desde" type="date"/>
								</qry:then>
							</qry:if>
							<qry:if test="#FILTRO:@f_hasta_req!=''">
								<qry:then>
									<COL name="f_hasta_req" label="Fecha Hasta" type="date"/>
								</qry:then>
							</qry:if>
						</COLS>
						<GROUP tag="EMP" type="title">
							<COLS>
								<COL name="empresa" label="Empresa"/>
							</COLS>
							<GROUP tag="REQ" type="table" style="width:1310px;" noreg="No se encontraron registros de Requerimientos.">
								<COLS>
									<COL name="requerimiento" label="Requerimiento" style="width:300px;"/>
									<COL name="f_req" label="Fecha" style="width:50px;" type="date"/>
									<COL name="ca_estado" label="Estado" style="width:80px;">
										<OPT id="A" value="Abierto"/>
										<OPT id="I" value="Inicializado"/>
										<OPT id="C" value="Cerrado"/>
										<OPT id="N" value="Anulada"/>
									</COL>
									<COL name="c_tipo_req" label="Tipo" style="width:80px;">
										<OPT id="1" value="Propio"/>
										<OPT id="2" value="Tercerizado"/>
										<OPT id="3" value="Mixto"/>
									</COL>
									<COL name="d_consultora" label="Consultora" style="width:100px;"/>
									<COL name="uni_org" label="Unidad Organizativa" style="width:300px;"/>
									<COL name="e_numero_legajo" label="Legajo Solicitante" style="width:150px;"/>
									<COL name="req_preced" label="Requerimiento Precedente" style="width:150px;"/>
									<COL name="f_cierre" label="Fecha Cierre" style="width:50px;" type="date"/>
									<COL name="n_costo" label="Costo Total" style="width:50px;text-align:right;"/>
								</COLS>
							</GROUP>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="REP">
						<qry:attribute name="f_desde_req" value="format_date(#FILTRO:@f_desde_req, 'dd/mm/yyyy')"/>
						<qry:attribute name="f_hasta_req" value="format_date(#FILTRO:@f_hasta_req, 'dd/mm/yyyy')"/>
						<qry:insert-select doc-path="#SOURCE:FILTRO" name="EMPRESA"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="EMPRESA" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ORG03_EMPRESAS.oi_empresa,
					ORG03_EMPRESAS.c_empresa, 
					ORG03_EMPRESAS.d_empresa
				FROM
					ORG03_EMPRESAS 
				WHERE
				{%? (#FILTRO:@oi_empresa!='') {% oi_empresa={#FILTRO:@oi_empresa} %} {% 1 = 1 %} %} 
	    ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EMP">
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="empresa" value="$r/@c_empresa + ' - ' + $r/@d_empresa"/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:insert-select doc-path="$r" name="QRY_REQ"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_REQ" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT
					SEL02_REQ.oi_req, 
					SEL02_REQ.c_req, 
					SEL02_REQ.d_req, 
	        SEL02_REQ.f_req,
					SEL02_REQ.ca_estado,
					SEL02_REQ.d_consultora, 
					SEL02_REQ.c_tipo_req, 
					SEL02_REQ.oi_req_preced, 
					SEL02_REQ.oi_personal_emp,
					SEL02_REQ.f_cierre,
					SEL02_REQ.oi_estructura					
				FROM 
					SEL02_REQ
				WHERE
					SEL02_REQ.oi_empresa = {#SOURCE:@oi_empresa}
					{%? (#FILTRO:@oi_req!='') {% AND SEL02_REQ.oi_req={#FILTRO:@oi_req} %} {% %} %}
					{%? (#FILTRO:@f_desde_req!='') {% AND SEL02_REQ.f_req &gt;= {#FILTRO:@f_desde_req} %} {% %} %}
					{%? (#FILTRO:@f_hasta_req!='') {% AND SEL02_REQ.f_req &lt;={#FILTRO:@f_hasta_req} %} {% %} %}
				ORDER BY
					c_req ASC
		 ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="hts:delete" value="0"/>
				<qry:element name="REQ">
					<qry:attribute name="oi_req" value="$r/@oi_req"/>
					<qry:attribute name="requerimiento" value="$r/@c_req + ' - ' + $r/@d_req"/>
					<qry:attribute name="f_req" value="format_date($r/@f_req,'dd/mm/yyyy')"/>
					<qry:attribute name="f_cierre" value="format_date($r/@f_cierre,'dd/mm/yyyy')"/>
					<qry:attribute name="ca_estado" value="$r/@ca_estado"/>
					<qry:attribute name="d_consultora" value="$r/@d_consultora"/>
					<qry:attribute name="c_tipo_req" value="$r/@c_tipo_req"/>
					<qry:insert-select name="QRY_UNIDAD" doc-path="$r"/>
					<qry:insert-select name="QRY_LEGAJO" doc-path="$r"/>
					<qry:insert-select name="QRY_REQ_PREC" doc-path="$r"/>
					<qry:insert-select name="QRY_COSTO" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_UNIDAD" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				select 
					UNI.c_unidad_org,
					UNI.d_unidad_org
				FROM 
					ORG02_ESTRUCTURAS AS EST,
					ORG01_UNI_ORG AS UNI     
				JOIN
					EST.oi_unidad_org INNER UNI.oi_unidad_org	
				WHERE
					EST.oi_estructura = {#SOURCE:@oi_estructura}
	    ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="uni_org" value="$r/@c_unidad_org + ' - ' + $r/@d_unidad_org"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_LEGAJO" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT
					PER02.e_numero_legajo,
					PER01.d_ape_y_nom
				FROM 
					PER02_PERSONAL_EMP AS PER02,
					PER01_PERSONAL AS PER01
				JOIN 
					PER02.oi_personal INNER PER01.oi_personal
				WHERE 
					PER02.oi_personal_emp = {#SOURCE:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo + '-' + $r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_REQ_PREC" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT
					SEL02_REQ.c_req, 
					SEL02_REQ.d_req 
	      FROM 
					SEL02_REQ
				WHERE
					SEL02_REQ.oi_req = {#SOURCE:@oi_req_preced}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="req_preced" value="$r/@c_req + ' - ' + $r/@d_req"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_COSTO" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT
					COSTO.n_costo
				FROM 
					SEL02_COSTOS_REQ AS COSTO
				WHERE 
					COSTO.oi_req = {#SOURCE:@oi_req}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="n_costo" value="Number(@n_costo) + Number($r/@n_costo)"/>
			</qry:out>
		</qry:select>
		<qry:select name="sqldelete" doc="SOURCE">
			<qry:out>
				<qry:attribute name="hts:delete" value="'0'"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
