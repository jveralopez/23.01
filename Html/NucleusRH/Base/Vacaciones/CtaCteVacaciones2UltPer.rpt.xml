<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Vacaciones.CtaCteVacaciones2UltPer" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;DATA TIPO_PER=&quot;&quot; oi_empresa=&quot;&quot; gpers=&quot;&quot; empresa=&quot;196&quot; activos=&quot;1&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&#13;&#10;&#9;&lt;PERSONAS&gt;&#13;&#10;&#9;&#9;&lt;ROW VALUES=&quot;11566,11567,11568,11569,11570,11573,11574,11575,11576,11578,11580,11581,11582,11583,13886,13887,13888,13889,13890,13891,13892,13895,13921,13922,13924,13925,13926,13927,13928,13929,13930,13941,13942,14547,13947,14647,13931,13932,13933,13935,13943,11565,13946,14047,13948,13949&quot;/&gt;&#13;&#10;&#9;&lt;/PERSONAS&gt;&#13;&#10;&lt;/DATA&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO1" doc-path="#PARAM:"/>
			<qry:element name="DATA">
				<EMPRESA qry-orderby="orderby">
					<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
					<qry:insert-select doc-path="#PARAM:" name="SQL_EMPRESA"/>
					<qry:insert-select doc-path="#PARAM:DATA/PERSONAS/ROW" name="QRY_PERSONAS"/>
				</EMPRESA>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute value="$PARAM/@values" name="values"/>
						<qry:attribute name="oi_empresa" value="$FILTRO1/DATA/@empresa"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="SQL_EMPRESA">
			<qry:xquery>
				for $r in sql('
					SELECT 
						ORG03_EMPRESAS.d_empresa,
						ORG03_EMPRESAS.c_empresa
					FROM 
						ORG03_EMPRESAS
					WHERE
						ORG03_EMPRESAS.oi_empresa = {#PARAM:DATA/@empresa} 						
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="($r/@c_empresa+' - '+$r/@d_empresa)"/>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO oi_empresa=&quot;196&quot; values=&quot;11566,11567,11568,11569,11570,11573,11574,11575,11576,11578,11580,11581,11582,11583,13886,13887,13888,13889,13890,13891,13892,13895,13921,13922,13924,13925,13926,13927,13928,13929,13930,13941,13942,14547,13947,14647,13931,13932,13933,13935,13943,11565,13946,14047,13948,13949&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:/FILTRO" name="qry_legajos"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="qry_legajos" doc="PARAM">
			<qry:xquery>
				for $r in sql(' 
			   SELECT
			    emp.d_empresa
			    , leg.e_numero_legajo as leg
					, per.d_ape_y_nom
					, leg.f_ingreso
					, leg.oi_personal_emp
					, per.c_nro_documento
					, tipodoc.c_tipo_documento
					, pos.d_posicion
					, vac_per.f_ant_rec_vac
			   FROM
			   	ORG03_EMPRESAS as emp, 
			   	PER02_PERSONAL_EMP as leg,
			   	PER01_PERSONAL as per,
			   	PER20_TIPOS_DOC as tipodoc,
			   	ORG04_POSICIONES as pos,
			   	VAC01_PERSONAL as vac_per			   				   	  
			   JOIN
			   	emp.oi_empresa INNER leg.oi_empresa
			   	, per.oi_personal INNER leg.oi_personal
			   	, tipodoc.oi_tipo_documento INNER per.oi_tipo_documento
			    , leg.oi_posicion_ult LEFT OUTER pos.oi_posicion
			    , leg.oi_personal_emp LEFT OUTER vac_per.oi_personal_emp
			   WHERE 
			   	leg.oi_personal_emp in ({%=#PARAM:@values%})
				 ORDER BY
				  leg ASC
			 ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:element name="LEG">
					<qry:attribute name="legajo" value="($r/@leg+' - '+$r/@d_ape_y_nom)"/>
					<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso, 'dd/mm/yyyy')"/>
					<qry:attribute name="documento" value="($r/@c_tipo_documento+' - '+$r/@c_nro_documento)"/>
					<qry:attribute name="posicion" value="$r/@d_posicion"/>
					<qry:attribute name="f_computar" value="iif(f_ant_rec_vac=null, format_date($r/@f_ant_rec_vac, 'dd/mm/yyyy'), ' ')"/>
					<qry:attribute name="bandera_licencia" value="'no'"/>
					<qry:insert-select doc-path="$r" name="qry_periodos"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_periodos" doc="PARAM">
			<qry:xquery>
				for $r in sql(' 		   
			   maxsize 2
			   SELECT
			   	cta.oi_personal_emp, 
			   	cta.oi_periodo, 
			   	cta.e_dias_gen,
			   	cta.e_dias_otorg,
			   	cta.e_dias_pend,
			   	PERIODOS.c_periodo, 
					PERIODOS.f_desde_periodo 
			   FROM
					(
				    SELECT
							VAC04_PERIODOS.oi_periodo  
							, VAC04_PERIODOS.c_periodo
							, VAC04_PERIODOS.f_desde_periodo
						FROM
							VAC04_PERIODOS
						WHERE
							VAC04_PERIODOS.oi_periodo !=1000
					) as PERIODOS
					, VAC01_CTA_CTE_VAC as cta
		   	 JOIN
			   	cta.oi_periodo INNER PERIODOS.oi_periodo
			   WHERE
					cta.oi_personal_emp = {#PARAM:@oi_personal_emp}
			   ORDER BY 
			   	c_periodo DESC, f_desde_periodo DESC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="bandera_licencia" value="'si'"/>
				<qry:element name="PER">
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="oi_periodo" value="$r/@oi_periodo"/>
					<qry:attribute name="c_periodo" value="$r/@c_periodo"/>
					<qry:attribute name="e_dias_gen" value="$r/@e_dias_gen"/>
					<qry:attribute name="e_dias_tomados_a_cuenta" value="$r/@e_dias_otorg"/>
					<qry:attribute name="e_saldo_pendiente" value="$r/@e_dias_pend"/>
					<!--qry:insert-select doc-path="$r" name="qry_dias_tomados_a_cuenta"/>
			<qry:insert-select doc-path="$r" name="qry_dias_liquidados"/>
			<qry:insert-select doc-path="$r" name="qry_dias_interrumpidos"/-->
					<qry:attribute name="bandera_solicitudes" value="'no'"/>
					<qry:insert-select doc-path="$r" name="qry_detalle"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dias_tomados_a_cuenta" doc="SOURCE">
			<qry:xquery>
				for $r in sql('     
				SELECT 
					SUM (VAC01_SOLIC_PER.e_cant_dias) AS e_dias_aprobados
				FROM 
					VAC01_SOLIC_PER, 
					VAC01_SOLICITUDES,
					VAC02_ESTADOS_SOL
				JOIN
					VAC01_SOLICITUDES.oi_solicitud INNER VAC01_SOLIC_PER.oi_solicitud,
					VAC01_SOLICITUDES.oi_estado_solic INNER VAC02_ESTADOS_SOL.oi_estado_solic
				WHERE 
					VAC01_SOLICITUDES.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND VAC01_SOLIC_PER.oi_periodo = {#SOURCE:@oi_periodo}				
          AND VAC02_ESTADOS_SOL.c_estado_solic = \'A\'				  
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="e_dias_tomados_a_cuenta" value="iif($r/@e_dias_aprobados!='', $r/@e_dias_aprobados, '0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dias_liquidados" doc="SOURCE">
			<qry:xquery>
				for $r in sql('     
				SELECT 
				  SUM (VAC01_SOLIC_PER.e_cant_dias) AS e_dias_liquidados
				FROM 
					VAC01_SOLIC_PER, 
					VAC01_SOLICITUDES,
					VAC02_ESTADOS_SOL
				JOIN
					VAC01_SOLICITUDES.oi_solicitud INNER VAC01_SOLIC_PER.oi_solicitud,
					VAC01_SOLICITUDES.oi_estado_solic INNER VAC02_ESTADOS_SOL.oi_estado_solic
				WHERE
					VAC01_SOLICITUDES.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND VAC01_SOLIC_PER.oi_periodo = {#SOURCE:@oi_periodo}
					AND VAC02_ESTADOS_SOL.c_estado_solic = \'L\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="e_dias_liquidados" value="iif($r/@e_dias_liquidados!='', $r/@e_dias_liquidados, '0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dias_interrumpidos" doc="SOURCE">
			<qry:xquery>
				for $r in sql('     
				SELECT 
				  SUM (VAC01_SOLIC_PER.e_cant_dias) AS e_dias_interrumpidos
				FROM 
					VAC01_SOLIC_PER, 
					VAC01_SOLICITUDES,
					VAC02_ESTADOS_SOL
				JOIN
					VAC01_SOLICITUDES.oi_solicitud INNER VAC01_SOLIC_PER.oi_solicitud,
					VAC01_SOLICITUDES.oi_estado_solic INNER VAC02_ESTADOS_SOL.oi_estado_solic
				WHERE
					VAC01_SOLICITUDES.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND VAC01_SOLIC_PER.oi_periodo = {#SOURCE:@oi_periodo}
					AND VAC02_ESTADOS_SOL.c_estado_solic = \'I\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="e_dias_interrumpidos" value="iif($r/@e_dias_interrumpidos!='', $r/@e_dias_interrumpidos, '0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_detalle" doc="SOURCE">
			<qry:xquery>
				for $r in sql('     
				SELECT 
					VAC01_SOLIC_PER.f_desde,
					VAC01_SOLIC_PER.f_hasta, 
					VAC01_SOLIC_PER.e_cant_dias, 
					VAC01_SOLICITUDES.e_dias_bonif, 
					VAC02_ESTADOS_SOL.d_estado_solic,
					VAC01_SOLICITUDES.f_interrupcion
				FROM 
					VAC01_SOLIC_PER, 
					VAC01_SOLICITUDES, 
					VAC02_ESTADOS_SOL
				JOIN
					VAC01_SOLICITUDES.oi_estado_solic INNER VAC02_ESTADOS_SOL.oi_estado_solic,
					VAC01_SOLICITUDES.oi_solicitud INNER VAC01_SOLIC_PER.oi_solicitud
				WHERE 
					VAC01_SOLICITUDES.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND VAC01_SOLIC_PER.oi_periodo = {#SOURCE:@oi_periodo}
					AND VAC02_ESTADOS_SOL.c_estado_solic IN (\'A\', \'L\', \'I\')
				ORDER BY f_desde DESC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="bandera_solicitudes" value="'si'"/>
				<qry:element name="SOL">
					<qry:attribute name="f_desde" value="format_date($r/@f_desde,'dd/mm/yyyy')"/>
					<qry:attribute name="f_hasta" value="iif($r/@f_interrupcion='', format_date($r/@f_hasta,'dd/mm/yyyy'), format_date($r/@f_interrupcion, 'dd/mm/yyyy'))"/>
					<!--qry:attribute name="f_hasta" value="format_date($r/@f_hasta,'dd/mm/yyyy')"/-->
					<qry:attribute name="e_cant_dias" value="$r/@e_cant_dias"/>
					<qry:attribute name="e_dias_bonif" value="$r/@e_dias_bonif"/>
					<!--qry:attribute name="d_estado_solic" value="$r/@d_estado_solic"/-->
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
