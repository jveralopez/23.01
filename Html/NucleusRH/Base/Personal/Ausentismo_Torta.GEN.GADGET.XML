<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="Ausentismo por tipo de licencia (Tortas)" doctype="HTML5" extends="NucleusRH.Base.Configuracion.GadgetBASE.rpt" doc="source">
	<html:query declare="&lt;PARAMS empresas='000129,000124'/&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:element name="ROOT">
						<qry:attribute name="type" value="'O'"/>
						<qry:append-doc name="LICEN" doc-path="."/>
						<qry:attribute name="c" value="0"/>
						<qry:attribute value="#SOURCE:PARAMS/@empresas" name="empresas"/>
						<qry:attribute name="empresas" value="concat('\\\'', nmd-replace(#SOURCE:PARAMS/@empresas,',','\\\',\\\''), '\\\'')"/>
						<qry:insert-select doc-path="." name="qry_dempresas"/>
						<qry:element name="property">
							<qry:attribute name="value" value="#SOURCE:PARAMS/@altura"/>
							<qry:attribute name="name" value="'height'"/>
							<qry:attribute name="type" value="'S'"/>
						</qry:element>
						<property>
							<qry:attribute name="type" value="'ARRO'"/>
							<qry:attribute name="name" value="'data'"/>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qryLicTot"/>
							<qry:insert-select doc-path="#SOURCE:PARAMS" name="qryLicencias"/>
							<qry:element name="item">
								<qry:attribute name="c" value="3"/>
								<qry:attribute name="type" value="'O'"/>
								<property>
									<qry:attribute name="name" value="'label'"/>
									<qry:attribute name="value" value="'Otros'"/>
									<qry:attribute name="type" value="'S'"/>
								</property>
								<property>
									<qry:attribute name="name" value="'value'"/>
									<qry:attribute name="value" value="format-number(number(../../@total - ../../@total2) div ../../@total * 100, '00.00')"/>
									<qry:attribute name="type" value="'S'"/>
								</property>
							</qry:element>
						</property>
					</qry:element>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryLicTot" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
	 
				SELECT
          			sum(LPER.e_cant_dias) as cantidad
				FROM
			   		PER02_LICEN_PER as LPER,
			   		PER16_LICENCIAS as LIC,
			   		PER02_PERSONAL_EMP AS LEG,
			   		ORG03_EMPRESAS as EMP 
				JOIN 
					LPER.oi_licencia INNER LIC.oi_licencia,
					LPER.oi_personal_emp INNER LEG.oi_personal_emp,
					LEG.oi_empresa INNER EMP.oi_empresa
				WHERE
					EMP.c_empresa in ({%=#LICEN:@empresas%})	 
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="total" value="number($r/@cantidad)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryLicencias" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
			MAXSIZE 2
				SELECT
          			sum(LPER.e_cant_dias) as cantidad,
          			LIC.oi_licencia,
          			LIC.c_licencia,
          			LIC.d_licencia
				FROM
			   		PER02_LICEN_PER as LPER,
			   		PER16_LICENCIAS as LIC,
			   		PER02_PERSONAL_EMP as LEG,
			   		ORG03_EMPRESAS as EMP 
				JOIN 
					LPER.oi_licencia INNER LIC.oi_licencia,
					lPER.oi_personal_emp INNER LEG.oi_personal_emp,
					LEG.oi_empresa INNER EMP.oi_empresa 
			   	WHERE
					EMP.c_empresa in ({%=#LICEN:@empresas%})
			   	GROUP BY 
			   		LIC.oi_licencia,
          			LIC.c_licencia,
          			LIC.d_licencia
                ORDER BY
                	cantidad DESC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="total2" value="@total2 + number($r/@cantidad)"/>
				<qry:attribute name="c" value="number(@c) + 1"/>
				<qry:element name="item">
					<qry:attribute name="type" value="'O'"/>
					<qry:if test="../@c&gt;2">
						<qry:then>
							<qry:attribute name="hts:delete" value="1"/>
							<qry:attribute name="flag" value="1"/>
						</qry:then>
						<qry:else/>
					</qry:if>
					<property>
						<qry:attribute name="name" value="'label'"/>
						<qry:attribute name="value" value="$r/@d_licencia"/>
						<qry:attribute name="type" value="'S'"/>
					</property>
					<property>
						<qry:attribute name="name" value="'value'"/>
						<qry:attribute name="value" value="format-number($r/@cantidad div ../../@total * 100, '00.00')"/>
						<qry:attribute name="type" value="'S'"/>
					</property>
					<qry:attribute name="c_licencia" value="$r/@c_licencia"/>
					<qry:attribute name="c" value="../@c"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dempresas" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
				SELECT
          			ORG.d_empresa
				FROM
			   		ORG03_EMPRESAS as ORG 
				WHERE
					ORG.c_empresa in ({%=#LICEN:@empresas%})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresas" value="iif(@d_empresas!='', @d_empresas+' - '+$r/@d_empresa,$r/@d_empresa)"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no" style="margin:5px">
				<div id="general" style="padding: 10px;">
					<table class="tabla_detail estilo1" cellspacing="0" cellpadding="0" style="text-align:center;">
						<tr id="trtitulo">
							<th id="thid" style="border-radius: 15px;-moz-border-radius: 15px;-webkit-border-radius: 15px;border-top-style:none;border-left-style:none;border-right-style:none;">
								<xsl:value-of select="concat('Ausentismo - Empresas: ', ./ROOT/@d_empresas)"/>
							</th>
						</tr>
					</table>
					<div id="graphActCV" style="top:50px; bottom:10px; position:absolute; left:10px; right:10px;"/>
					<script>
						var datos = new Array();
				var strXML = document.getElementById("xml").innerHTML;
				var xmlData = new NomadXML("XML");
				var objxml = new NomadXML("objxml"); 
				var propxml = new NomadXML("propxml");
				xmlData.AddText(strXML);    
				var objROOT = new Object();
				objROOT = toObject(xmlData.FirstChild().FirstChild().ToString());  
				
				Morris.Donut({
										  element: 'graphActCV',
										  data: objROOT.data,
										  colors: ['#112233','#AABBCC','#3490AD'],
										  formatter: function (y, data) { return '%' + y },
										  rezise: true
										});
					</script>
				</div>
			</body>
		</xsl:template>
		<xsl:template name="ReportSCRIPT">
			function Detail(poiNov) {
				var dir;
				
				dir = "../../../ReportViewer.aspx?";
				dir = dir + "report={#PROXY.APP#}.NucleusRH.Base.Portal_Empleado.NovedadesEmpresa_detail.GEN.GADGET";
				dir = dir + "{#CHAR.AMP#}oi_novedad=" + poiNov;
        dir = dir + "{#CHAR.AMP#}LANG={#PROXY.LANG#}";
                
				window.open(dir, 'Novedades', 'width=800,height=600,resizable=yes');
			}
		</xsl:template>
		<xsl:template name="BaseSCRIPT">
			<script id="xml" type="text/xml">
				<xsl:copy-of select="DATA"/>
			</script>
		</xsl:template>
		<xsl:template name="GADGET_PARAM">
			<param name="empresas" label="Empresas" type="STRING"/>
		</xsl:template>
	</html:xslt>
</html:html>
