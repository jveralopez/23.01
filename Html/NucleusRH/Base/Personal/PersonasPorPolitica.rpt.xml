<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Seguridad.PersonasPolitica" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query>
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
			<REPORT label="Listado de Personas por Pol&#237;tica (Organigrama)">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="POLICY" type="title">
						<COLS>
							<COL name="valor_path" label="Pol&#237;tica"/>
						</COLS>
						<GROUP tag="PER" label="Personas" type="table">
							<COLS>
								<COL name="nombre" label="Nombre y Apellido" style="width:55%" nowrap="1"/>
							</COLS>
						</GROUP>
						<GROUP tag="PERSONA_ENTIDAD" label="Personas con acceso" type="table">
							<COLS>
								<COL name="nombre" label="Nombre y Apellido" style="width:34%" nowrap="1"/>
								<COL name="COD" label="C&#243;digo" style="width:33%" nowrap="1"/>
								<COL name="DES" label="Descipci&#243;n" style="width:33%" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select doc-path="#SOURCE:" name="QRY"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY" doc="PARAM">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Security\\Values\\{%=#PROXY:@APP%}.POLICY_VALUES.XML')/POLICY_VALUES/VALUE/POLICY_VALUE
			</qry:xquery>
			<qry:out>
				<qry:if test="substring($r/@XPATH,0,5)='./ORG'">
					<qry:then>
						<POLICY>
							<qry:attribute name="XPATH" value="$r/@XPATH"/>
							<qry:insert-select name="qry_split_path" doc-path="."/>
							<qry:attribute name="cuentas" value="$r/USERS/POLICY_USER/@ACCOUNT"/>
							<qry:insert-select name="qry_pers" doc-path="."/>
							<qry:insert-select name="qry_pre_cuentas" doc-path="."/>
						</POLICY>
					</qry:then>
					<qry:else/>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_split_path">
			<qry:xquery>
				for $r in SPLIT('1;{%=translate(#PARAM:@XPATH, '/', ',')%}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="valor_path" value="$r/@value"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_pre_cuentas">
			<qry:xquery>
				for $r in SPLIT('1;{%=#PARAM:@cuentas%}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cuenta" value="$r/@value"/>
				<qry:insert-select name="qry_cuentas" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_cuentas">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Login\\Cuentas\\{%=#PARAM:@cuenta%}.CUENTA.XML')/CUENTA/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:element name="PERSONA_ENTIDAD">
					<qry:attribute name="entidad" value="$r/@value"/>
					<qry:insert-select name="qry_entidad" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_entidad">
			<qry:xquery>
				for $r in file('Nomad\\Base\\Login\\Entidades\\{%=#PARAM:@entidad%}.ENTIDAD.XML')/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:attribute name="id" value="$r/@id"/>
				<qry:attribute name="COD" value="$r/@COD"/>
				<qry:attribute name="DES" value="$r/@DES"/>
				<qry:insert-select name="qry_entidad_per" doc-path="."/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_entidad_per">
			<qry:xquery>
				for $r in sql('		
					SELECT 
						PER.oi_personal,
					  PER.d_ape_y_nom
					FROM 
						PER01_PERSONAL as PER					 
					WHERE
						PER.oi_usuario_sistema ={#PARAM:@id}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="nombre" value="$r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_pers">
			<qry:xquery>
				for $r in sql('		
					SELECT 
						PER.oi_personal,
					  PER.d_ape_y_nom
					FROM 
						NMD_SECURITY as SEC,
						PER01_PERSONAL as PER,
						PER02_PERSONAL_EMP as LEG 							 
					JOIN
						SEC.id INNER PER.oi_personal,
						PER.oi_personal INNER LEG.oi_personal
					WHERE
						SEC.policy ={#PARAM:@XPATH}
						AND SEC.class = \'NucleusRH.Base.Personal.Legajo.PERSONAL\'	 
						AND LEG.oi_indic_activo = 1
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="PER">
					<qry:attribute name="nombre" value="$r/@d_ape_y_nom"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
