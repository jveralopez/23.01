							<COL name="d_grado_escol" label="Grado de escolaridad" nowrap="1"/>
							<COL name="d_estudio" label="Estudio" nowrap="1"/>
							<COL name="e_duracion_estudio" label="Duraci&#243;n Estudio" nowrap="1"/>
							<COL name="d_unidad_tiempo" label="Unidad de tiempo" nowrap="1"/>
							<COL name="e_anio_inic_esc" label="A&#241;o inicio escolar" nowrap="1"/>
							<COL name="e_anio_fin_esc" label="A&#241;o fin escolar" nowrap="1"/>
							<COL name="e_periodo_en_curso" label="Per&#237;odo en curso" nowrap="1"/>
							<COL name="o_familiar" label="Observaciones" nowrap="1"/>
						</COLS>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select doc-path="#PARAM:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute value="#PARAM:@values" name="values"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO values=&quot;953,4315,954,955,956,957,4316,958,4317,959,960,961,962,4318,4319,963,141,964,965,966,967,968,4320,969,4321,4322,970,971,972,142,973,4323,974,975,976,977,978,979,4324,980,981,982,983,984,985,986,143,987,988,989,990,991,992,993,144,145,994,4325,146,995,996,147,997,998,148,4326,149,4327,4328,999,150,1000,151,1001,1002,1003,1004,1005,4329,1006,152,1007,1008,1009,1010,1011,4330,1012,1013,153,1014,1015,1016,1017,1018,154,1019,1020,1021,1022&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:/FILTRO" name="QRY_SPLIT"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="QRY_SPLIT" doc="PARAM">
			<qry:xquery>
				for $r in SPLIT('50;{%=#PARAM:@values%}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select doc-path="$r" name="QRY_DATOS"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_DATOS" doc="PARAM">
			<qry:xquery>
				for $r in sql('
				SELECT
					0 as ord,
					PER02.e_numero_legajo as leg,
					PER02.oi_personal_emp,
				  EMP1.c_empresa,
					PER01.d_ape_y_nom,
					TIPOSDOC.c_tipo_documento,
					PER01.c_nro_documento,
					null as d_tipo_familiar,
					PER01.f_nacim as f_nacimiento,
					1 as l_vive,
					PER01.c_sexo,	
					0 as l_discapacidad,
					CIVIL.d_estado_civil,
					null as f_desde_IG,
					PER02.f_antiguedad_rec,
					PER02.f_ingreso,
					null  as d_estudio,
					null  as d_grado_escol, 
					null  as d_nivel_escol,
					null  as d_ocupacion_fam,
					null  as d_unidad_tiempo,
					null  as o_familiar,
					null  as e_duracion_estudio,
					null  as e_anio_inic_esc,
					null  as e_anio_fin_esc,
					null	as e_periodo_en_curso
				FROM 
					PER02_PERSONAL_EMP AS PER02,
					ORG03_EMPRESAS AS EMP1,
					PER01_PERSONAL AS PER01,
					ORG22_EST_CIVIL AS CIVIL,
					PER20_TIPOS_DOC AS TIPOSDOC				
				JOIN
					EMP1.oi_empresa INNER PER02.oi_empresa,
					PER02.oi_personal INNER PER01.oi_personal,
					PER01.oi_estado_civil LEFT OUTER CIVIL.oi_estado_civil,
					PER01.oi_tipo_documento INNER TIPOSDOC.oi_tipo_documento
				WHERE
					PER02.oi_personal_emp in ({%=#PARAM:@value%})
			UNION
				SELECT
					1 as ord,
					PEM.e_numero_legajo as leg,
					PEM.oi_personal_emp,
					EMP2.c_empresa,
					FAM.d_ape_y_nom,
					TIPOSDOC.c_tipo_documento,
					FAM.c_nro_documento,
					TIPOS.d_tipo_familiar,
					FAM.f_nacimiento,
					FAM.l_vive,
					FAM.c_sexo,
					FAM.l_discapacidad,
					CIVIL.d_estado_civil,
					FAM.f_desde_IG,
					null as f_antiguedad_rec,
					null as f_ingreso,
					EST.d_estudio,
					G_ESCOL.d_grado_escol, 
					N_ESCOL.d_nivel_escol,
					OC_FAM.d_ocupacion_fam,
					TPO.d_unidad_tiempo,
					FAM.o_familiar,
					FAM.e_duracion_estudio,
					FAM.e_anio_inic_esc,
					FAM.e_anio_fin_esc,
					FAM.e_periodo_en_curso
				FROM 
					PER01_FLIARES_PER AS FAM,
					ORG03_EMPRESAS AS EMP2,
					PER15_TIPOS_FAM AS TIPOS,
					ORG22_EST_CIVIL AS CIVIL,
					PER02_PERSONAL_EMP AS PEM,
					PER20_TIPOS_DOC AS TIPOSDOC,
					ORG11_ESTUDIOS as EST,
					PER24_GRADOS_ESCOL as G_ESCOL,
					PER08_NIVELES_ESC as N_ESCOL,
					PER18_OCUP_FAM as OC_FAM,
					ORG25_UNIDADES_TPO as TPO
				JOIN
					EMP2.oi_empresa INNER PEM.oi_empresa,
					FAM.oi_tipo_familiar INNER TIPOS.oi_tipo_familiar,
					FAM.oi_estado_civil LEFT OUTER CIVIL.oi_estado_civil,
					PEM.oi_personal INNER FAM.oi_personal,
					FAM.oi_tipo_documento LEFT OUTER TIPOSDOC.oi_tipo_documento,
					FAM.oi_estudio LEFT OUTER EST.oi_estudio,
					FAM.oi_grado_escol LEFT OUTER G_ESCOL.oi_grado_escol,
					FAM.oi_nivel_escol LEFT OUTER N_ESCOL.oi_nivel_escol,
					FAM.oi_ocupacion_fam LEFT OUTER OC_FAM.oi_ocupacion_fam,
					FAM.oi_unidad_tiempo LEFT OUTER TPO.oi_unidad_tiempo
				WHERE
					PEM.oi_personal_emp in ({%=#PARAM:@value%})
				
				ORDER BY c_empresa ASC, leg asc, ord ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="FAM">
					<qry:attribute name="style" value="iif($r/@ord=0,'background-color:#E0E0E0;','')"/>
					<qry:attribute name="empresa" value="$r/@c_empresa"/>
					<qry:attribute name="ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="documento" value="$r/@c_tipo_documento+' '+$r/@c_nro_documento"/>
					<qry:attribute name="tipo_familiar_per" value="$r/@d_tipo_familiar"/>
					<qry:attribute name="l_vive" value="iif($r/@l_vive='1', 'SI', 'NO')"/>
					<qry:attribute name="f_nacimiento" value="format_date($r/@f_nacimiento, 'dd/mm/yyyy')"/>
					<!--<qry:attribute name="c_sexo" value="iif($r/@c_sexo='M', 'Masculino', 'Femenino')"/>-->
					<qry:attribute name="c_sexo" value="iif($r/@c_sexo='','',iif($r/@c_sexo='M','Masculino', 'Femenino'))"/>
					<qry:attribute name="legajo" value="$r/@leg"/>
					<qry:attribute name="f_computar" value="format_date($r/@f_antiguedad_rec, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso, 'dd/mm/yyyy')"/>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
					<qry:attribute name="d_estado_civil" value="$r/@d_estado_civil"/>
					<qry:attribute name="l_discapacidad" value="iif($r/@l_discapacidad='1', 'Si', 'No')"/>
					<qry:attribute name="d_estudio" value="$r/@d_estudio"/>
					<qry:attribute name="d_grado_escol" value="$r/@d_grado_escol"/>
					<qry:attribute name="d_nivel_escol" value="$r/@d_nivel_escol"/>
					<qry:attribute name="d_ocupacion_fam" value="$r/@d_ocupacion_fam"/>
					<qry:attribute name="d_unidad_tiempo" value="$r/@d_unidad_tiempo"/>
					<qry:attribute name="o_familiar" value="$r/@o_familiar"/>
					<qry:attribute name="e_duracion_estudio" value="$r/@e_duracion_estudio"/>
					<qry:attribute name="e_anio_inic_esc" value="$r/@e_anio_inic_esc"/>
					<qry:attribute name="e_anio_fin_esc" value="$r/@e_anio_fin_esc"/>
					<qry:attribute name="e_periodo_en_curso" value="$r/@e_periodo_en_curso"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_FAMS">
			<qry:out>
				<qry:insert-element doc-path="#PARAM:"/>
			</qry:out>
		</qry:select>
