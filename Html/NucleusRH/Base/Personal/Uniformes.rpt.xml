	<html:for-each declare="&lt;DATA empresa=&quot;1&quot; ID=&quot;&quot; PARENT=&quot;&quot; gcustom=&quot;&quot; uniformes=&quot;&quot; FechaDesde=&quot;20130401&quot; FechaHasta=&quot;20130430&quot; gpers=&quot;&quot; activos=&quot;1&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS nmd-col=&quot;1&quot;&gt;&lt;ROW VALUES=&quot;101,102,158,103,104,105,159,160,106,161,107,108,162,109,163,164,165,166,167,110,168,169,170,111,171,172,173,112,174,175,176,177,178,179,180,181,182,183,113,114,381,184,185,186,187,188,115,189,190,191,192,116,193,194,195,196,197,198,117,199,200,201,118,202,203,204,205,206,207,119,208,209,210,211,212,213,120,214,121,215,216,217,218,219,122,123,124,220,382,221,383,384,385,222,223,224,225,125,226,227&quot;/&gt;&lt;ROW VALUES=&quot;126,228,229,230,231,127,232,128,233,129,234,130,235,236,237,238,239,240,241,242,243,244,245,246,247,386,387,248,249,250,131,132,251,252,253,254,255,256,257,258,133,134,259,260,135,136,261,262,263,264,265,266,137,138,267,268,269,270,271,272,273,274,275,276,277,278,139,279,280,281,282,140,283,284,285,286,287,288,289,290,291,292,293,294,295,296,297,298,299,300,141,301,142,302,388,303,304,305,389,306&quot;/&gt;&lt;ROW VALUES=&quot;307,308,309,310,311,312,313,314,315,316,317,390,318,319,391,320,321,322,323,324,325,326,327,328,143,329,330,331,332,333,334,335,336,337,144,145,338,339,146,340,341,147,148,342,343,344,345,346,347,348,349,350,351,352,353,354,355,356,149,150,151,357,152,153,358,154,359,360,361,362,155,363,364,365,366,367,156,368,369,370,371,157,372,373,374,375,376,392,377,378,379,380,402,403,404,405,406,408,409,410&quot;/&gt;&lt;ROW VALUES=&quot;411,412,413,414,415,416,417,418,419,421,551,552,553,554,555,556,557,558,559,560,561,562,563,564,566,567,568,569,570,571,572,573,574,651,652,653,751,752,754,755,756,757,758,759,760,761,762,763,851,852,853,855,856,857,858,859,860,861,862,863,864,865,866,867,868,869,870,871,872,873,874,875,876,877,878,879,880,881,882,883,887,888,889,890,951,952,953,954,955,956,957,958,959,1051,1052,1053,1054,1055,1056,1057&quot;/&gt;&lt;ROW VALUES=&quot;1058,1059,1060,1061,1062,1063,1151,1152,1153,1154,1155,1156,1157,1158,1159,1160,1161,1162,1163,1251,1252,1253,1254,1255,1256,1257,1258,1259,1260,1261,1262,1263,1264,1265,1266,1267,1268,1269,1270,1271,1272,1273,1274,1275,1351,1352,1353,1354,1355,1356,1357,1358,1359,1360,1361,1362,1363,1364,1365,1366,1367,1368,1369,1370,1371,1372,1373,1374,1375,1376,1377,1378,1379,1380,1381,1382,1383,1384,1385,1386,1387,1388,1389,1390,1391,1392,1393,1394,1395,1396,1397,1398,1399,1400,1401,1403,1404,1405,1406,1407&quot;/&gt;&lt;ROW VALUES=&quot;1408,1409,1410,1411,1412,1414,1415,1416,1417,1418,1419,1420,1422,1423,1424,1425,1426,1427,1428,1429,1430,1431,1432,1433,1434,1435,1436,1437,1438,1439,1440,1441,1442,1443,1444,1451,1452,1453&quot;/&gt;&lt;/PERSONAS&gt;&lt;/DATA&gt;&#13;&#10;">
		<qry:main doc="SOURCE">
			<REPORT label="Uniformes Entregados Por Empresa">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="FILTRO" type="title">
						<COLS>
							<COL name="Empresa" label="Empresa"/>
							<qry:if test="$SOURCE/DATA/@uniformes!=''">
								<qry:then>
									<COL name="Uniforme" label="Uniforme"/>
								</qry:then>
								<qry:else/>
							</qry:if>
							<qry:if test="$SOURCE/DATA/@fechaDesde!=''">
								<qry:then>
									<COL name="FechaDesde" label="Fecha De Entrega Desde" type="date"/>
								</qry:then>
								<qry:else/>
							</qry:if>
							<qry:if test="$SOURCE/DATA/@fechaHasta!=''">
								<qry:then>
									<COL name="FechaHasta" label="Fecha De Entrega Hasta" type="date"/>
								</qry:then>
								<qry:else/>
							</qry:if>
						</COLS>
						<GROUP tag="UNIFORMES" type="table" noreg="No se encontraron coincidencias con los par&#225;metros de busqueda ingresados">
							<COLS>
								<COL name="Nombre" label="Nombre y Apellido"/>
								<COL name="Uniforme" label="Uniforme"/>
								<COL name="FechaD" label="Fecha Desde" style="text-align:center" type="date"/>
								<COL name="Fechah" label="Fecha Hasta" style="text-align:center" type="date"/>
								<COL name="e_cantidad" label="Cantidad" style="text-align:center"/>
								<COL name="e_pendiente" label="Pendiente" style="text-align:center"/>
								<COL name="Duracion" label="Duraci&#243;n"/>
								<COL name="Unifper" label="Observaciones"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<FILTRO qry-orderby="orderby">
						<qry:insert-select name="QRYUNIFORMES_EMPRESA" doc-path="$SOURCE/DATA"/>
						<qry:insert-select name="QRYUNIFORMES" doc-path="$SOURCE/DATA"/>
						<qry:attribute name="FechaDesde" value="format_date($SOURCE/DATA/@fechaDesde,'dd/mm/yyyy')"/>
						<qry:attribute name="FechaHasta" value="format_date($SOURCE/DATA/@fechaHasta,'dd/mm/yyyy')"/>
						<qry:insert-select name="QRYUNIFORMES_PERSONAS" doc-path="$SOURCE/DATA/PERSONAS/ROW"/>
					</FILTRO>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRYUNIFORMES_PERSONAS" doc="PARAM">
			<qry:out>
				<QRY:CALL>
					<DATA>
						<qry:attribute name="empresa" value="$PARAM/../../@empresa"/>
						<qry:attribute name="uniformes" value="$PARAM/../../@uniformes"/>
						<qry:attribute name="VALUES" value="$PARAM/@VALUES"/>
						<qry:attribute name="fechaDesde" value="$PARAM/../../@fechaDesde"/>
						<qry:attribute name="fechaHasta" value="$PARAM/../../@fechaHasta"/>
					</DATA>
				</QRY:CALL>
			</qry:out>
		</qry:select>
		<qry:select name="QRYUNIFORMES_EMPRESA" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
				SELECT 
				   emp.d_empresa  
				FROM
					ORG03_EMPRESAS as emp 								  				
				WHERE 
					emp.oi_empresa={$PARAM/@empresa}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Empresa" value="$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRYUNIFORMES" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
				SELECT 
				   d.oi_uniforme,
				   d.d_uniforme  
				FROM
					ORG16_UNIFORMES as d  								  				
				WHERE 
					d.oi_uniforme={$PARAM/@uniformes}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Uniforme" value="$r/@d_uniforme"/>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;DATA fechaHasta=&quot;20130430&quot; fechaDesde=&quot;20130401&quot; VALUES=&quot;101,102,158,103,104,105,159,160,106,161,107,108,162,109,163,164,165,166,167,110,168,169,170,111,171,172,173,112,174,175,176,177,178,179,180,181,182,183,113,114,381,184,185,186,187,188,115,189,190,191,192,116,193,194,195,196,197,198,117,199,200,201,118,202,203,204,205,206,207,119,208,209,210,211,212,213,120,214,121,215,216,217,218,219,122,123,124,220,382,221,383,384,385,222,223,224,225,125,226,227&quot; empresa=&quot;1&quot;/&gt;">
		<qry:main doc="SOURCE">
			<QRY:NO-SHOW>
				<qry:insert-select name="QRYUNIFORMES_PERSONAS" doc-path="$SOURCE/DATA"/>
			</QRY:NO-SHOW>
		</qry:main>
		<qry:select name="QRYUNIFORMES_PERSONAS" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
			SELECT 
			   p.oi_personal_emp,			   
			   per.d_ape_y_nom,
			   emp.d_empresa,
			   d.d_uniforme, 
			   u.oi_uniforme,
			   u.f_desde,
			   u.f_hasta,
			   u.e_cantidad,
			   u.e_pendiente,
			   u.e_duracion,
			   u.o_uniforme_per,
			   ut.d_unidad_tiempo
			FROM
				PER02_PERSONAL_EMP as p,
				ORG03_EMPRESAS as emp, 
				PER01_PERSONAL as per,
				ORG16_UNIFORMES as d, 
				PER02_UNIF_PER as  u,
				ORG25_UNIDADES_TPO as ut
			JOIN  
			  p.oi_personal INNER per.oi_personal,  
			  emp.oi_empresa INNER p.oi_empresa,  
			  u.oi_personal_emp INNER   p.oi_personal_emp,
			  u.oi_uniforme INNER  d.oi_uniforme, 
			  u.oi_unidad_tiempo LEFT OUTER ut.oi_unidad_tiempo
			WHERE 
				emp.oi_empresa={$PARAM/@empresa} 
				and p.oi_personal_emp IN ({%=$PARAM/@values %})   
				{%?($PARAM/@uniformes!='')
			  	{% and d.oi_uniforme ={$PARAM/@uniformes}%}
			  	{% %}
			  %}   
			  {%?($PARAM/@fechaDesde !='')
			  	{% and u.f_desde &gt;= {Datetime($PARAM/@fechaDesde)} %}
			  	{% %} 
			  %} 
			  {%?($PARAM/@fechaHasta !='')
			  	{% and  u.f_desde &lt;= {Datetime($PARAM/@fechaHasta)} %}
			  	{% %} 
			 	%}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="UNIFORMES">
					<qry:attribute name="orderby" value="nmd_fillleft($r/@e_numero_legajo,'0',10)+'_'+$r/@d_ape_y_nom"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="Nombre" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="Uniforme" value="$r/@d_uniforme"/>
					<qry:attribute name="Codunif" value="$r/@oi_uniforme"/>
					<qry:attribute name="FechaD" value="format_date($r/@f_desde,'dd/mm/yyyy')"/>
					<qry:attribute name="Fechah" value="format_date($r/@f_hasta,'dd/mm/yyyy')"/>
					<qry:attribute name="Duracion" value="concat($r/@e_duracion, ' ', $r/@d_unidad_tiempo)"/>
					<qry:attribute name="e_cantidad" value="$r/@e_cantidad"/>
					<qry:attribute name="e_pendiente" value="$r/@e_pendiente"/>
					<qry:attribute name="Unifper" value="$r/@o_uniforme_per"/>
					<qry:attribute name="Empresa" value="$r/@d_empresa"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
