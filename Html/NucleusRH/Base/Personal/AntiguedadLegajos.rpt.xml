<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Personal.AntiguedadLegajos" doc="source" extends="Nomad.Base.BaseReport.rpt">
	<html:query>
		<qry:main doc="SOURCE">
			<REPORT label="Listado de antig&#252;edad">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="FILTRO" type="title">
						<COLS>
							<COL label="Fecha de c&#225;lculo" name="f_calculo"/>
							<COL label="Empresa" name="d_empresa"/>
						</COLS>
						<GROUP tag="LEGAJO" type="table" style="width:100%">
							<COLS>
								<COL name="e_numero_legajo" label="Legajo" style="text-align:right"/>
								<COL name="d_ape_y_nom" label="Apellido y nombre"/>
								<COL name="ultima_f_ingreso" label="&#218;ltima fecha ingreso" style="text-align:center"/>
								<COL name="f_antiguedad_rec" label="Fecha antig&#252;edad reconocida" style="text-align:center"/>
								<COL name="reingreso" label="&#191;Reingres&#243;?" style="text-align:center"/>
								<COL name="antiguedad" label="Antig&#252;edad"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:insert-element doc-path="$SOURCE/DATA"/>
			</REPORT>
		</qry:main>
	</html:query>
</html:html>
