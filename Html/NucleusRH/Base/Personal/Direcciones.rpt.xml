	<html:query declare="&lt;FILTRO values=&quot;101,102,103,104,105,106,107,108,109,110,111,112,113,114,115,116,117,118,119,120,121,122,123,124,125,126,127,128,129,130,131,132,133,134,135,136,137,138,139,140,141,142,143,144,145,146,147,148,149,150,151,152,153,154,155,156,157,158,159,160,161,162,163,164,165,166,167,168,169,170,171,172,173,174,175,176,177,178,179,180,181,182,183,184,185,186,187,189,191,192,193,194,195,196,197,198,199,200,201,202&quot;/&gt;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:insert-select doc-path="#PARAM:/FILTRO" name="qry_Domicilios"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="qry_Domicilios" doc="PARAM">
			<qry:xquery>
				for $r in sql('										
			SELECT       
				ORG03_EMPRESAS.d_empresa,
				PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom,
				PER01_PERSONAL.c_nro_documento,
				PER21_INDIC_ACTIVO.d_indic_activo,
				PER09_TIPOS_DOMIC.d_tipo_domicilio,
				ORG19_LOCALIDADES.d_localidad,
				ORG35_PROVINCIAS.d_provincia,
				ORG35_PAISES.d_pais,
				PER01_DOMIC_PER.d_entre_calle_1,
				PER01_DOMIC_PER.d_entre_calle_2,
				PER01_DOMIC_PER.c_postal,
				PER01_DOMIC_PER.d_calle,
				PER01_DOMIC_PER.e_numero,
				PER01_DOMIC_PER.d_piso,
				PER01_DOMIC_PER.d_departamento,
				PER01_DOMIC_PER.te_1,
				PER01_DOMIC_PER.te_2,
				PER01_DOMIC_PER.te_celular,
				PER01_DOMIC_PER.o_domicilio,
				PER01_DOMIC_PER.d_email,
				PER01_DOMIC_PER.l_domic_fiscal,
				PER01_DOMIC_PER.d_partido
			FROM 	
				PER01_DOMIC_PER,
				PER09_TIPOS_DOMIC,
				ORG19_LOCALIDADES,
				ORG35_PROVINCIAS,
				ORG35_PAISES,
				ORG03_EMPRESAS,
				PER02_PERSONAL_EMP,
				PER01_PERSONAL,
				PER21_INDIC_ACTIVO
			JOIN	
			  PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,				                
				PER02_PERSONAL_EMP.oi_indic_activo LEFT OUTER PER21_INDIC_ACTIVO.oi_indic_activo,
				PER01_PERSONAL.oi_personal INNER PER01_DOMIC_PER.oi_personal,
				PER01_DOMIC_PER.oi_tipo_domicilio INNER PER09_TIPOS_DOMIC.oi_tipo_domicilio,
				PER01_DOMIC_PER.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad,
				ORG19_LOCALIDADES.oi_provincia LEFT OUTER ORG35_PROVINCIAS.oi_provincia,
				ORG35_PROVINCIAS.oi_pais LEFT OUTER ORG35_PAISES.oi_pais				 
			WHERE 
				PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%})
			ORDER BY	
				d_empresa ASC, e_numero_legajo ASC		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DOM">
					<qry:attribute value="$r/@d_empresa" name="d_empresa"/>
					<qry:attribute value="$r/@e_numero_legajo" name="e_numero_legajo"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
					<qry:attribute value="$r/@c_nro_documento" name="c_nro_documento"/>
					<qry:attribute value="$r/@d_indic_activo" name="d_indic_activo"/>
					<qry:attribute value="$r/@d_tipo_domicilio" name="d_tipo_domicilio"/>
					<qry:attribute value="$r/@d_localidad" name="d_localidad"/>
					<qry:attribute value="$r/@d_provincia" name="d_provincia"/>
					<qry:attribute value="$r/@d_pais" name="d_pais"/>
					<qry:attribute value="$r/@d_entre_calle_1" name="d_entre_calle_1"/>
					<qry:attribute value="$r/@d_entre_calle_2" name="d_entre_calle_2"/>
					<qry:attribute value="$r/@c_postal" name="c_postal"/>
					<qry:attribute value="$r/@d_calle" name="d_calle"/>
					<qry:attribute value="$r/@e_numero" name="e_numero"/>
					<qry:attribute value="$r/@d_piso" name="d_piso"/>
					<qry:attribute value="$r/@d_departamento" name="d_departamento"/>
					<qry:attribute value="$r/@te_1" name="te_1"/>
					<qry:attribute value="$r/@te_2" name="te_2"/>
					<qry:attribute value="$r/@te_celular" name="te_celular"/>
					<qry:attribute value="$r/@o_domicilio" name="o_domicilio"/>
					<qry:attribute value="$r/@d_email" name="d_email"/>
					<qry:attribute value="$r/@d_partido" name="d_partido"/>
					<qry:attribute value="iif($r/@l_domic_fiscal='1', 'Si', '')" name="l_domic_fiscal"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
