<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:QRY="nomad_engine.QRY" name="NucleusRH.Base.Organizacion.Elementos" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;DATA empresa=&quot;1&quot; ID=&quot;&quot; PARENT=&quot;&quot; gcustom=&quot;&quot; Elemento=&quot;18&quot; FechaDesde=&quot;20000924&quot; FechaHasta=&quot;20080924&quot; gpers=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&#13;&#10;&lt;PERSONAS nmd-col=&quot;1&quot;&gt;&#13;&#10;&lt;ROW VALUES=&quot;69,36,224,70,37,73,64,71,74,75,20,68,21,38,39,4,72,209,5,35,40,41,22,13893,42,8,23,9,43,24,44,45,25,46,26,47,76,66,10,67,13,65,19,14,48,49,27,50,28,29,51,11,12,52,53,30,15,54,31,16,17,55,32,33,18,56,34,57,58,59,60,61,62,63,124,125,126,136,138,142,145,146,147,148,149,150,156,157,159,160,162,165,167,169,170,171,173,182,183,188&quot;/&gt;&#13;&#10;&lt;ROW VALUES=&quot;1,7,3,2,13898,11419,11420,11421,11422,225,212,213,214,151,166,168,184,186,187,189,230,231,217,11417,11424,219,11431,6,220,11418,11425,202,11459&quot;/&gt;&#13;&#10;&lt;/PERSONAS&gt;&#13;&#10;&lt;/DATA&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Elementos por Legajo">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="FILTRO" type="title">
						<COLS>
							<COL name="Empresa" label="Empresa"/>
							<qry:if test="$SOURCE/DATA/@elemento!=''">
								<qry:then>
									<COL name="Elemento" label="Elemento"/>
								</qry:then>
								<qry:else/>
							</qry:if>
							<qry:if test="$SOURCE/DATA/@fechaDesde!=''">
								<qry:then>
									<COL name="FechaDesde" label="Fecha De Entrega Desde" type="date"/>
								</qry:then>
								<qry:else/>
							</qry:if>
							<qry:if test="$SOURCE/DATA/@fechaHasta!=''">
								<qry:then>
									<COL name="FechaHasta" label="Fecha De Entrega Hasta" type="date"/>
								</qry:then>
								<qry:else/>
							</qry:if>
						</COLS>
						<GROUP tag="ELEMENTOS" type="table" noreg="No se encontraron coincidencias con los par&#225;metros de busqueda ingresados">
							<COLS>
								<COL name="Nombre" label="Nombre y Apellido"/>
								<COL name="Elemento" label="Elemento"/>
								<COL name="Cantidad" label="Cantidad"/>
								<COL name="fEntrega" label="Fecha de Entrega" type="date"/>
								<COL name="Estado" label="Estado"/>
								<COL name="Talle" label="Talle"/>
								<COL name="Marca" label="Marca"/>
								<COL name="NumeroSerie" label="Nu&#250;mero de Serie"/>
								<COL name="MotivoEntrega" label="Motivo"/>
								<COL name="Devolucion" label="Devoluci&#243;n"/>
								<COL name="Denuncia" label="Denuncia"/>
								<COL name="Repuesto" label="Repuesto"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="FILTRO">
						<qry:insert-select name="QRYELEMENTOS_EMPRESA" doc-path="$SOURCE/DATA"/>
						<qry:insert-select name="QRYELEMENTOS_ELEMENTO" doc-path="$SOURCE/DATA"/>
						<qry:attribute name="FechaDesde" value="format_date($SOURCE/DATA/@fechaDesde,'dd/mm/yyyy')"/>
						<qry:attribute name="FechaHasta" value="format_date($SOURCE/DATA/@fechaHasta,'dd/mm/yyyy')"/>
						<qry:insert-select name="QRYELEMENTOS_PERSONAS" doc-path="$SOURCE/DATA/PERSONAS/ROW"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRYELEMENTOS_PERSONAS" doc="PARAM">
			<qry:out>
				<QRY:CALL>
					<DATA>
						<qry:attribute name="empresa" value="$PARAM/../../@empresa"/>
						<qry:attribute name="elemento" value="$PARAM/../../@elemento"/>
						<qry:attribute name="VALUES" value="$PARAM/@VALUES"/>
						<qry:attribute name="fechaDesde" value="$PARAM/../../@fechaDesde"/>
						<qry:attribute name="fechaHasta" value="$PARAM/../../@fechaHasta"/>
					</DATA>
				</QRY:CALL>
			</qry:out>
		</qry:select>
		<qry:select name="QRYELEMENTOS_EMPRESA" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
			      
SELECT 
   emp.d_empresa  
FROM
	ORG03_EMPRESAS as emp 								  				
        
WHERE 
  
	emp.oi_empresa={$PARAM/@empresa}
	
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Empresa" value="$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRYELEMENTOS_ELEMENTO" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
			      
SELECT 
   t.d_elemento_pp  
FROM
	ORG07_ELEMENTOS_PP as t 								  				
        
WHERE 
  
	t.oi_elemento_pp={$PARAM/@elemento}
	
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="Elemento" value="$r/@d_elemento_pp"/>
				<!--qry:attribute name="hts:delete" value="'0'"/-->
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;DATA VALUES=&quot;1,7,3,2,13898,11419,11420,11421,11422,225,212,213,214,151,166,168,184,186,187,189,230,231,217,11417,11424,219,218,11431,6,220,11418,11425,202,11459&quot; empresa=&quot;1&quot;/&gt;">
		<qry:main doc="SOURCE">
			<QRY:NO-SHOW>
				<qry:insert-select name="QRYELEMENTOS_PERSONAS" doc-path="$SOURCE/DATA"/>
			</QRY:NO-SHOW>
		</qry:main>
		<qry:select name="QRYELEMENTOS_PERSONAS" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' 
			      
SELECT 
   p.oi_personal_emp,			   
   per.d_ape_y_nom,
   emp.d_empresa,
   t.d_elemento_pp,
   el.e_cantidad,
   el.f_entrega,
   el.c_estado,
   el.c_talle,
   el.c_marca,
   el.c_numero_serie,
   el.c_motivo_entrega,
   el.l_devolucion_EPP,
   el.l_denuncia,
   el.l_repuesto
   
FROM
	PER02_PERSONAL_EMP as p,
	ORG03_EMPRESAS as emp, 
	PER01_PERSONAL as per,
	ORG07_ELEMENTOS_PP as t, 
	PER02_EPP_PER as  el
									  				
JOIN  
  p.oi_personal INNER per.oi_personal,  
  emp.oi_empresa INNER p.oi_empresa,  
  el.oi_personal_emp INNER   p.oi_personal_emp,
  el.oi_elemento_pp INNER  t.oi_elemento_pp        
WHERE 
  
	emp.oi_empresa={$PARAM/@empresa}
	and p.oi_personal_emp IN ({%=$PARAM/@values %})   
	
	
	
 {%?($PARAM/@elemento!='')
  {% and t.oi_elemento_pp={$PARAM/@Elemento}%}
  {% %}
 %} 
 
 {%?($PARAM/@fechaDesde !='')
  {% and  el.f_entrega &gt;= {Datetime($PARAM/@fechaDesde)} %}
  {% %} 
 %} 
 {%?($PARAM/@fechaHasta !='')
  {% and  el.f_entrega &lt;= {Datetime($PARAM/@fechaHasta)} %}
  {% %} 
 %}

	   
 ORDER BY
   d_ape_y_nom ASC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ELEMENTOS">
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="Nombre" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="Elemento" value="$r/@d_elemento_pp"/>
					<qry:attribute name="Cantidad" value="$r/@e_cantidad"/>
					<qry:attribute name="fEntrega" value="format_date($r/@f_entrega,'dd/mm/yyyy')"/>
					<qry:attribute name="Estado" value="$r/@c_estado"/>
					<qry:attribute name="Talle" value="$r/@c_talle"/>
					<qry:attribute name="Marca" value="$r/@c_marca"/>
					<qry:attribute name="NumeroSerie" value="$r/@c_numero_serie"/>
					<qry:attribute name="MotivoEntrega" value="$r/@c_motivo_entrega"/>
					<qry:attribute name="Devolucion" value="$r/@l_devolucion_EPP"/>
					<qry:attribute name="Denuncia" value="$r/@l_denuncia"/>
					<qry:attribute name="Repuesto" value="$r/@l_repuesto"/>
					<qry:attribute name="Empresa" value="$r/@d_empresa"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
