<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="LicenciasPersonal" doc="source" extends="NucleusRH.Base.Configuracion.GadgetBASE.rpt">
	<html:query declare="&lt;PARAMS oi_licencia_per=&quot;1402&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:element name="DATA">
					<qry:attribute name="oi_licencia_per" value="#SOURCE:PARAMS/@oi_licencia_per"/>
					<qry:insert-select name="qryLicencia" doc-path="."/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryLicencia" doc="SOURCE">
			<qry:xquery>
				for $r in sql('		
				SELECT 		
					ORG03_EMPRESAS.c_empresa,
					ORG03_EMPRESAS.d_empresa,
					PER01_PERSONAL.d_ape_y_nom,
					PER02_PERSONAL_EMP.e_numero_legajo, 
					PER16_LICENCIAS.c_licencia,
					PER16_LICENCIAS.d_licencia,			
					PER02_LICEN_PER.f_inicio,
					PER02_LICEN_PER.f_fin,
					PER02_LICEN_PER.e_anio_corresp,
					PER02_LICEN_PER.o_licencia_per	
				FROM 
					PER02_PERSONAL_EMP
					, PER01_PERSONAL
					, PER02_LICEN_PER
					, PER16_LICENCIAS
					, ORG03_EMPRESAS
				JOIN 
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
					, PER02_LICEN_PER.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp
					, PER16_LICENCIAS.oi_licencia INNER PER02_LICEN_PER.oi_licencia
					, PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE        
					PER02_LICEN_PER.oi_licencia_per = {%= #SOURCE:@oi_licencia_per%}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="empresa" value="concat('[',$r/@c_empresa,'] ',$r/@d_empresa)"/>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="licencia" value="concat('[',$r/@c_licencia,'] ',$r/@d_licencia)"/>
				<qry:attribute name="f_inicio" value="format-date($r/@f_inicio,'dd/mm/yyyy')"/>
				<qry:attribute name="f_fin" value="format-date($r/@f_fin,'dd/mm/yyyy')"/>
				<qry:attribute name="e_anio_corresp" value="$r/@e_anio_corresp"/>
				<qry:attribute name="o_licencia_per" value="$r/@o_licencia_per"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no">
				<table class="tabla_detail estilo1" style="width:100%; height:30%" cellspacing="0" cellpadding="0">
					<tr>
						<th>
							Licencia de Personal
						</th>
					</tr>
					<tr>
						<td>
							<table style="width:100%" class="tabla_noticia estilo1">
								<!--Datos del Legajo-->
								<tr style="font-size:14px; ">
									<td style="padding-left:15px">
										<label style="font-weight:bold">
											Datos del Legajo
										</label>
									</td>
								</tr>
								<tr style="font-size:12px; ">
									<td style="padding-left:15px">
										<label style="font-weight:bold">
											Apellido y Nombre:
										</label>
										<xsl:value-of select="concat(' ',@d_ape_y_nom)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px">
										<label style="font-weight:bold">
											Empresa:
										</label>
										<xsl:value-of select="concat(' ',@empresa)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px;">
										<label style="font-weight:bold">
											N&#250;mero de Legajo:
										</label>
										<xsl:value-of select="concat(' ',@e_numero_legajo)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px; border-bottom:1px solid #C0C0C0">
										<p>
											&#160;
										</p>
									</td>
								</tr>
								<!--Fin de los Datos del Legajo-->
								<!--Datos de la Licencia-->
								<tr style="font-size:14px; ">
									<td style="padding-left:15px">
										<label style="font-weight:bold">
											Datos de la Licencia
										</label>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px;">
										<label style="font-weight:bold">
											Licencia:
										</label>
										<xsl:value-of select="concat(' ',@licencia)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px;">
										<label style="font-weight:bold">
											Fecha Desde:
										</label>
										<xsl:value-of select="concat(' ',@f_inicio)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px;">
										<label style="font-weight:bold">
											Fecha Hasta:
										</label>
										<xsl:value-of select="concat(' ',@f_fin)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px;">
										<label style="font-weight:bold">
											A&#241;o Correspondiente:
										</label>
										<xsl:value-of select="concat(' ',@e_anio_corresp)"/>
									</td>
								</tr>
								<tr style="font-size:12px;">
									<td style="padding-left:15px">
										<label style="font-weight:bold">
											Observaci&#243;n:
										</label>
										<xsl:value-of select="concat(' ',@o_licencia_per)"/>
									</td>
								</tr>
								<!--Fin de la Solicitud de Vacaciones-->
							</table>
						</td>
					</tr>
				</table>
			</body>
		</xsl:template>
		<xsl:template name="ReportSCRIPT"/>
		<xsl:template name="GADGET_PARAM"/>
	</html:xslt>
</html:html>
