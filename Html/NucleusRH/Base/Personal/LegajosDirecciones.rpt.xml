		<qry:select doc="PARAM" name="qry_Legajos">
			<qry:xquery>
				for $r in sql('				
			SELECT
				PER01_PERSONAL.oi_personal,				  
				PER02_PERSONAL_EMP.oi_personal_emp,
				ORG03_EMPRESAS.d_empresa,
				PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom,
				PER01_PERSONAL.c_nro_documento,
				PER21_INDIC_ACTIVO.d_indic_activo,
				ORG02_ESTRUC_PERS.oi_estructura,
				(PER02_PERSONAL_EMP.e_numero_legajo + 10000000) as orden
			FROM 
				PER02_PERSONAL_EMP,
				ORG03_EMPRESAS,
				PER01_PERSONAL,			
				ORG02_ESTRUC_PERS,
				ORG02_CLASES_ORG,			
				PER21_INDIC_ACTIVO
			JOIN   
				PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal, 
				PER02_PERSONAL_EMP.oi_personal_emp INNER ORG02_ESTRUC_PERS.oi_personal_emp,
				ORG02_ESTRUC_PERS.oi_clase_org INNER ORG02_CLASES_ORG.oi_clase_org,
				PER02_PERSONAL_EMP.oi_indic_activo LEFT OUTER PER21_INDIC_ACTIVO.oi_indic_activo
			WHERE 
				PER02_PERSONAL_EMP.oi_empresa = {#PARAM:@oi_empresa} 									
				{%? (#PARAM:@values!='') {% AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=#PARAM:@values%}) %} {% %} %}							
				AND ORG02_CLASES_ORG.c_estado = \'V\'
				AND ORG02_CLASES_ORG.l_automatica = 1
		')/ROWS/ROW,
		$x in $ESTRUC/E
		join $r/@oi_estructura inner $x/@id  
		orderby $r/@orden ASC
			</qry:xquery>
			<qry:out>
				<qry:append-doc name="ESTRUCTURASL" doc-path="$x"/>
				<qry:insert-select name="qry_Domicilios" doc-path="$r"/>
