		<qry:select name="QRY_COL" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				ORG26_PARAMETROS.c_parametro,
				ORG26_PARAMETROS.d_valor
			FROM
				ORG26_PARAMETROS                
			WHERE
				ORG26_PARAMETROS.c_modulo = \'PER\' AND 
				ORG26_PARAMETROS.d_clase = \'RepTrayectorias\' AND
				ORG26_PARAMETROS.c_parametro IN (\'NivelEstruct\')
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="qry_pegar_columnas" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_pegar_columnas" doc="SOURCE">
			<qry:xquery>
				for $r in secuence('int,1,{%=#SOURCE:@d_valor%},1')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="COL">
					<qry:attribute name="label" value="'Estructura ' + $r/@value"/>
					<qry:attribute name="name" value="'desc'+ number(number(#SOURCE:@d_valor) - (number($r/@value) - 1))"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_SQL1">
			<qry:xquery>
				for $r in sql('				
			SELECT 
				ORG01_UNI_ORG.d_unidad_org, 
				ORG02_CLASES_ORG.oi_estructura_org			
			FROM 
				ORG02_CLASES_ORG,
				ORG02_ESTRUCTURAS,
				ORG01_UNI_ORG,
				ORG03_EMPRESAS			
			JOIN
				ORG02_CLASES_ORG.oi_estructura_org INNER ORG02_ESTRUCTURAS.oi_estructura,
				ORG01_UNI_ORG.oi_unidad_org INNER ORG02_ESTRUCTURAS.oi_unidad_org,
				ORG01_UNI_ORG.c_unidad_org INNER ORG03_EMPRESAS.c_empresa  
			WHERE
				ORG02_CLASES_ORG.c_estado = \'V\' 
				AND ORG02_CLASES_ORG.l_automatica = 1 
				AND ORG01_UNI_ORG.oi_tipo_uni_org = 1
				AND ORG03_EMPRESAS.oi_empresa = {#PARAM:@oi_empresa}		
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="E">
					<qry:attribute value="$r/@d_unidad_org" name="desc1"/>
					<qry:attribute value="$r/@oi_estructura_org" name="id"/>
					<qry:attribute value="1" name="nivel"/>
				</qry:element>
				<qry:attribute-doc doc="DOCNIVEL" name="nivel" value="1"/>
				<qry:insert-select name="qry_SQL3"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_SQL3">
			<qry:xquery>
				for $r in sql('				
			SELECT 
				ORG02_ESTRUCTURAS.oi_estructura,
				ORG01_UNI_ORG.d_unidad_org,  
				ORG02_ESTRUCTURAS.oi_estr_padre,
				tablaCantidad.cantidad
			FROM
				ORG02_ESTRUCTURAS,
				ORG01_UNI_ORG,
				(SELECT count(ORG02_ESTRUCTURAS.oi_estructura) as cantidad
					FROM
					ORG02_ESTRUCTURAS,
					ORG01_UNI_ORG			
					JOIN
					ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org
					WHERE
					ORG02_ESTRUCTURAS.oi_estr_padre in ({%=string(#ESTRUCTURAS:E[@nivel=#DOCNIVEL:@nivel]/@id)%})) as tablaCantidad			
			JOIN
				ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org	
			WHERE				
				ORG02_ESTRUCTURAS.oi_estr_padre in ({%=string(#ESTRUCTURAS:E[@nivel=#DOCNIVEL:@nivel]/@id)%})														
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="E">
					<qry:attribute value="number(#DOCNIVEL:@nivel) + 1" name="nivel"/>
					<qry:attribute value="$r/@d_unidad_org" name-calc="'desc' + (number(#DOCNIVEL:@nivel) + 1)"/>
					<qry:attribute value="$r/@oi_estructura" name="id"/>
					<qry:attribute value="$r/@oi_estr_padre" name="oi_estr_padre"/>
					<qry:attribute-doc doc="DOCPADRE" name="oi_estr_padre" value="$r/@oi_estr_padre"/>
					<qry:insert-select name="qry_DESC"/>
				</qry:element>
				<qry:attribute name="cantidad_reg" value="$r/@cantidad"/>
				<qry:attribute value="count(#ESTRUCTURAS:E[@nivel=(number(#DOCNIVEL:@nivel) + 1)])" name="cantidad_doc"/>
