<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="Cumplea&#241;osAniversarios" extends="NucleusRH.Base.Configuracion.GadgetBASE.rpt" doc="source">
	<html:query declare="&lt;PARAMS seldate=&quot;12&quot; evento=&quot;c&quot; tipoFam=&quot;1,2,3,4,5,6,T&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:element name="MAIN">
				<qry:attribute name="timestamp" value="concat(FORMAT_DATE(Now()+1, 'yyyymmdd'), '000000')"/>
				<qry:element name="DATA">
					<qry:attribute name="ut" value="#PROXY:@TOKEN"/>
					<qry:attribute name="seldate" value="#SOURCE:PARAMS/@seldate"/>
					<qry:attribute name="evento" value="IIF ((upper-case(#SOURCE:PARAMS/@evento)='A' OR upper-case(#SOURCE:PARAMS/@evento)='C' OR upper-case(#SOURCE:PARAMS/@evento)='AC' ), upper-case(#SOURCE:PARAMS/@evento), 'AC')"/>
					<qry:if test="@seldate = ''">
						<qry:then>
							<qry:attribute name="seldate" value="'13'"/>
						</qry:then>
					</qry:if>
					<qry:if test="@seldate = '13'">
						<qry:then>
							<qry:attribute name="mes" value="'hoy'"/>
							<qry:attribute name="selmes" value="'13'"/>
						</qry:then>
						<qry:else>
							<qry:if test="@seldate = '00'">
								<qry:then>
									<qry:attribute name="mes" value="FORMAT_DATE(Now(), 'mmm')"/>
									<qry:attribute name="selmes" value="FORMAT_DATE(Now(), 'mm')"/>
								</qry:then>
								<qry:else>
									<qry:attribute name="mes" value="FORMAT_DATE(DATETIME('2009' + @seldate + '01'), 'mmm')"/>
									<qry:attribute name="selmes" value="FORMAT_DATE(DATETIME('2009' + @seldate + '01'), 'mm')"/>
								</qry:else>
							</qry:if>
						</qry:else>
					</qry:if>
					<qry:attribute name="tipoFam" value="concat('\\\'', nmd-replace(#SOURCE:PARAMS/@tipoFam,',','\\\',\\\''), '\\\'')"/>
					<qry:attribute name="tipoFamHid" value="#SOURCE:PARAMS/@tipoFam"/>
					<qry:insert-select doc-path="." name="qryCumplesAniversarios"/>
					<qry:attribute name="oi_personal_ant" value=""/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qryCumplesAniversarios" doc="SOURCE">
			<qry:xquery>
				for $r in sql('
			{%? ((#SOURCE:@evento = 'AC') OR (#SOURCE:@evento = 'A'))
				{%
				SELECT
					per.oi_personal,
					per.d_nombres,
					per.d_apellido,
			 	  	pemp.f_ingreso as fecha,
					GETDAY(pemp.f_ingreso) as dia,
					per.oi_foto, 
					loc.d_localidad,
					pues.d_puesto,
					emp.d_empresa,  
					\'\' as parentesco,
					\'\' as familiarde_nombre,
					\'\' as familiarde_apellido,
					\'Aniversario\' as evento

				FROM
			   		PER01_PERSONAL as per,
					PER02_PERSONAL_EMP as pemp,
					ORG04_PUESTOS as pues,
					ORG03_EMPRESAS as emp,
					ORG19_LOCALIDADES as loc
                
				JOIN 
					per.oi_personal INNER pemp.oi_personal,
					pemp.oi_puesto_ult LEFT OUTER pues.oi_puesto,
					pemp.oi_empresa LEFT OUTER emp.oi_empresa,
					emp.oi_localidad LEFT OUTER loc.oi_localidad

				WHERE
					pemp.oi_indic_activo = 1
				  {%? (#SOURCE:@selmes = '13')
				      {% and GETMONTH(pemp.f_ingreso) = {%=STRING(month_from_dateTime(Now()))%} and GETDAY(pemp.f_ingreso) = {%=STRING(day_from_dateTime(Now()))%} %}
				      {% and GETMONTH(pemp.f_ingreso) = {#SOURCE:@selmes} %}
				  %}
              	%}
              	{%%}
              %}      
                    
                 {%?(#SOURCE:@evento = 'AC')
                 {% 
                 UNION
                 %}
                 {% %}
                 %}   
                    
                    
            {%? ((#SOURCE:@evento = 'AC') OR (#SOURCE:@evento = 'C'))
				{%        
            SELECT
					per.oi_personal,
					per.d_nombres,
					per.d_apellido,
			 	  	per.f_nacim as fecha,
					GETDAY(per.f_nacim) as dia,
					per.oi_foto,
					loc.d_localidad,
					pues.d_puesto,
					emp.d_empresa,     
					\'\' as parentesco,
					\'\' as familiarde_nombre,
					\'\' as familiarde_apellido,
					\'Cumplea&#241;os\' as evento

				FROM
			   		PER01_PERSONAL as per,
					PER02_PERSONAL_EMP as pemp,
					ORG04_PUESTOS as pues,
					ORG03_EMPRESAS as emp,
					ORG19_LOCALIDADES as loc
                
				JOIN 
					per.oi_personal INNER pemp.oi_personal,
					pemp.oi_puesto_ult LEFT OUTER pues.oi_puesto,
					pemp.oi_empresa LEFT OUTER emp.oi_empresa,
					emp.oi_localidad LEFT OUTER loc.oi_localidad

				WHERE
					pemp.oi_indic_activo = 1
				  {%? (#SOURCE:@selmes = '13')
				      {% and GETMONTH(per.f_nacim) = {%=STRING(month_from_dateTime(Now()))%} and GETDAY(per.f_nacim) = {%=STRING(day_from_dateTime(Now()))%} %}
				      {% and GETMONTH(per.f_nacim) = {#SOURCE:@selmes} %}
				  %}

                 UNION          
                 
                  SELECT
					PER01_PERSONAL.oi_personal,
					PER01_FLIARES_PER.d_nombres,
					PER01_FLIARES_PER.d_apellido,
			 	  	PER01_FLIARES_PER.f_nacimiento as fecha,
					GETDAY(PER01_FLIARES_PER.f_nacimiento) as dia,
					PER01_PERSONAL.oi_foto,
					ORG19_LOCALIDADES.d_localidad,
					ORG04_PUESTOS.d_puesto,
					ORG03_EMPRESAS.d_empresa,     
					PER15_TIPOS_FAM.d_tipo_familiar as parentesco,
					PER01_PERSONAL.d_nombres as familiarde_nombre,
					PER01_PERSONAL.d_apellido as familiarde_apellido,
					\'Cumplea&#241;os\' as evento

				FROM
			   		PER01_PERSONAL,
					PER02_PERSONAL_EMP,
					ORG04_PUESTOS,
					ORG03_EMPRESAS,
					ORG19_LOCALIDADES,
					PER01_FLIARES_PER,
					PER15_TIPOS_FAM
                
				JOIN       
					PER01_FLIARES_PER.oi_personal INNER  PER01_PERSONAL.oi_personal,                  
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal,
					PER02_PERSONAL_EMP.oi_puesto_ult LEFT OUTER ORG04_PUESTOS.oi_puesto,
					PER02_PERSONAL_EMP.oi_empresa LEFT OUTER ORG03_EMPRESAS.oi_empresa,
					ORG03_EMPRESAS.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad,
					PER15_TIPOS_FAM.oi_tipo_familiar INNER PER01_FLIARES_PER.oi_tipo_familiar
					
				WHERE
					PER02_PERSONAL_EMP.oi_indic_activo = 1 and
					PER01_FLIARES_PER.l_vive=1 and
					PER15_TIPOS_FAM.c_tipo_familiar IN ({%=#SOURCE:@tipoFam%})  
				
				  {%? (#SOURCE:@selmes = '13')
				      {% and GETMONTH(PER01_FLIARES_PER.f_nacimiento) = {%=STRING(month_from_dateTime(Now()))%} and GETDAY(PER01_FLIARES_PER.f_nacimiento) = {%=STRING(day_from_dateTime(Now()))%} %}
				      {% and GETMONTH(PER01_FLIARES_PER.f_nacimiento) = {#SOURCE:@selmes} %}
				  %}
				  
				  %}
                  {% %}
                  %}

				
				 {%? ((#SOURCE:@evento = 'AC') OR (#SOURCE:@evento = 'A') OR (#SOURCE:@evento = 'C') )
					{%
				 ORDER BY 
				 dia ASC, d_nombres ASC, d_apellido ASC
                     %} 
                     {%
                     
                     
                     %}
                     %}
                    
                    

			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="col" value="number(./@col) + 1"/>
				<qry:attribute name="col" value="IIF(./@col = '4', 1, ./@col)"/>
				<qry:attribute name="rtipo" value="IIF(number(./@rtipo) = 1, 0, 1)"/>
				<qry:element name="LEGAJO">
					<qry:attribute name="primero" value="IIF($r/@oi_personal = ../@oi_personal_ant, 0, 1)"/>
					<qry:attribute name="oi_foto" value="IIF($r/@oi_foto = '', '0', $r/@oi_foto)"/>
					<qry:attribute name="dia" value="FORMAT_DATE($r/@fecha, 'dd')"/>
					<qry:attribute name="nombre" value="$r/@d_nombres + ' ' + $r/@d_apellido"/>
					<qry:attribute name="nombre_cap" value="nmd_capital(@nombre)"/>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
					<qry:attribute name="loc_empresa" value="$r/@d_localidad"/>
					<qry:attribute name="fecha" value="$r/@fecha"/>
					<qry:attribute name="mesdia" value="FORMAT_DATE($r/@fecha, 'dd-mm')"/>
					<qry:attribute name="cant" value="Number(format_date(now(), 'yyyy')) - Number(format_date(@fecha, 'yyyy'))"/>
					<qry:attribute name="puesto" value="$r/@d_puesto"/>
					<qry:attribute name="empresa" value="$r/@d_empresa + ' - ' + $r/@d_localidad"/>
					<qry:attribute name="col" value="../@col"/>
					<qry:attribute name="rtipo" value="../@rtipo"/>
					<qry:attribute name="evento" value="$r/@evento"/>
					<qry:attribute name="parentesco" value="$r/@parentesco"/>
					<qry:attribute name="familiarde_nombre" value="$r/@familiarde_nombre + ' ' + $r/@familiarde_apellido"/>
					<qry:attribute name="familiarde_nombre_cap" value="nmd_capital(@familiarde_nombre)"/>
				</qry:element>
				<qry:attribute name="oi_personal_ant" value="$r/@oi_personal"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template name="MainReport" match="DATA">
			<body bgcolor="#F2F2EC" scroll="no">
				<table class="tabla_detail estilo1" cellspacing="0" cellpadding="0">
					<tr>
						<th>
							<input id="txtEvento" name="txtEvento" type="hidden">
								<xsl:attribute name="value">
									<xsl:value-of select="@evento"/>
								</xsl:attribute>
							</input>
							<xsl:choose>
								<xsl:when test="@evento = 'A'">
									Aniversarios
								</xsl:when>
								<xsl:when test="@evento = 'C'">
									Cumplea&#241;os
								</xsl:when>
								<xsl:when test="@evento = 'AC'">
									Aniversarios y Cumplea&#241;os
								</xsl:when>
								<xsl:otherwise>
									Aniversarios y Cumplea&#241;os
								</xsl:otherwise>
							</xsl:choose>
							<input id="txtTiposFamiliares" name="txtTiposFamiliares" type="hidden">
								<xsl:attribute name="value">
									<xsl:value-of select="@tipoFamHid"/>
								</xsl:attribute>
							</input>
						</th>
					</tr>
					<tr>
						<td class="titu_1 underline" height="28px">
							<xsl:text>
								Fecha:&#160;
							</xsl:text>
							<SELECT id="cboDate" name="cboDate" onChange="ChangeDate(this);">
								<OPTION VALUE="13">
									<xsl:if test="@seldate = '13'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Hoy
								</OPTION>
								<OPTION VALUE="00">
									<xsl:if test="@seldate = '00'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Mes actual
								</OPTION>
								<OPTION VALUE="01">
									<xsl:if test="@seldate = '01'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Enero
								</OPTION>
								<OPTION VALUE="02">
									<xsl:if test="@seldate = '02'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Febrero
								</OPTION>
								<OPTION VALUE="03">
									<xsl:if test="@seldate = '03'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Marzo
								</OPTION>
								<OPTION VALUE="04">
									<xsl:if test="@seldate = '04'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Abril
								</OPTION>
								<OPTION VALUE="05">
									<xsl:if test="@seldate = '05'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Mayo
								</OPTION>
								<OPTION VALUE="06">
									<xsl:if test="@seldate = '06'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Junio
								</OPTION>
								<OPTION VALUE="07">
									<xsl:if test="@seldate = '07'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Julio
								</OPTION>
								<OPTION VALUE="08">
									<xsl:if test="@seldate = '08'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Agosto
								</OPTION>
								<OPTION VALUE="09">
									<xsl:if test="@seldate = '09'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Septiembre
								</OPTION>
								<OPTION VALUE="10">
									<xsl:if test="@seldate = '10'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Octubre
								</OPTION>
								<OPTION VALUE="11">
									<xsl:if test="@seldate = '11'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Noviembre
								</OPTION>
								<OPTION VALUE="12">
									<xsl:if test="@seldate = '12'">
										<xsl:attribute name="selected">
											<xsl:value-of select="@seldate"/>
										</xsl:attribute>
									</xsl:if>
									Diciembre
								</OPTION>
							</SELECT>
						</td>
					</tr>
					<tr>
						<td>
							<div>
								<table style="width:100%;font-size: 11px;" class="tabla_noticia estilo1">
									<xsl:for-each select="LEGAJO[@primero = 1]">
										<tr>
											<td height="40px" class="img_back underline">
												<xsl:if test="@oi_foto != '0'">
													<xsl:attribute name="style">
														<xsl:value-of select="concat('background-image:url(data:image/jpg;base64,(#IMAGE.DB(x36;NucleusRH.Base.Personal.Imagenes.HEAD;', @oi_foto, ')#))')"/>
													</xsl:attribute>
												</xsl:if>
												<xsl:if test="@oi_foto = '0'">
													<xsl:attribute name="style">
														<xsl:value-of select="'background-image:url(data:image/jpg;base64,)'"/>
													</xsl:attribute>
												</xsl:if>
												<xsl:if test="@evento = 'Aniversario'">
													<img width="24px">
														<xsl:attribute name="src">
															<xsl:value-of select="'data:image/jpg;base64,'"/>
														</xsl:attribute>
													</img>
												</xsl:if>
												<xsl:if test="@evento = 'Cumplea&#241;os'">
													<img width="24px">
														<xsl:attribute name="src">
															<xsl:value-of select="'data:image/jpg;base64,'"/>
														</xsl:attribute>
													</img>
												</xsl:if>
												<span class="row_estilo_1" style="padding-left:10px">
													<xsl:value-of select="@dia"/>
												</span>
												<span>
													&#160;|&#160;
												</span>
												<xsl:if test="not(@parentesco)">
													<span>
														<a>
															<xsl:attribute name="href">
																<xsl:value-of select="concat('javascript:Detail(', @oi_personal, ')')"/>
															</xsl:attribute>
															<xsl:value-of select="@nombre_cap"/>
														</a>
													</span>
												</xsl:if>
												<xsl:if test="@parentesco!=''">
													<span class="row_estilo_1" style="color:#338F4A">
														<xsl:value-of select="@nombre_cap"/>
													</span>
												</xsl:if>
												<xsl:if test="../@evento = 'AC'">
													<span>
														&#160;|&#160;
													</span>
													<span class="row_estilo_1" style="color:grey">
														<xsl:value-of select="@evento"/>
													</span>
												</xsl:if>
												<xsl:if test="@evento = 'Aniversario'">
													<span>
														&#160;[
													</span>
													<span>
														<xsl:value-of select="@cant"/>
													</span>
													<span style="padding-right:10px">
														]&#160;
													</span>
												</xsl:if>
												<xsl:if test="@parentesco != ''">
													<span>
														&#160;|&#160;
													</span>
													<span class="row_estilo_1" style="color:grey">
														<xsl:value-of select="concat(@parentesco,' de ')"/>
													</span>
													<a>
														<xsl:attribute name="href">
															<xsl:value-of select="concat('javascript:Detail(', @oi_personal, ')')"/>
														</xsl:attribute>
														<xsl:value-of select="@familiarde_nombre_cap"/>
													</a>
												</xsl:if>
											</td>
										</tr>
									</xsl:for-each>
								</table>
							</div>
						</td>
					</tr>
				</table>
			</body>
		</xsl:template>
		<xsl:template name="ReportSCRIPT">
			function Detail(poiPer) {
				var dir;

				dir = "../../../ReportViewer.aspx?";
				dir = dir + "report={#PROXY.APP#}.NucleusRH.Base.Personal.BuscadorLegajos.GEN.GADGET";
				dir = dir + "{#CHAR.AMP#}oi_personal=" + poiPer;
                
				window.open(dir, 'Buscador', 'width=800,height=600,resizable=yes');
			}

			function ChangeDate(objCbo) {
				
				var dir;
				

				dir = "../../../ReportViewer.aspx?";
				dir = dir + "report={#PROXY.APP#}.NucleusRH.Base.Personal.CumplesAniversarios.GEN.GADGET";
				dir = dir + "{#CHAR.AMP#}seldate=" + objCbo.value; 
				dir = dir + "{#CHAR.AMP#}evento=" + document.getElementById('txtEvento').value;
				dir = dir + "{#CHAR.AMP#}tipoFam=" + document.getElementById('txtTiposFamiliares').value;
				
				document.location = dir;
				return;
			}
		</xsl:template>
		<xsl:template name="GADGET_PARAM">
			<param name="seldate" label="Mes" type="ENUM">
				<ROWS>
					<row id="00" text="Mes actual"/>
					<row id="01" text="Enero"/>
					<row id="02" text="Febrero"/>
					<row id="03" text="Marzo"/>
					<row id="04" text="Abril"/>
					<row id="05" text="Mayo"/>
					<row id="06" text="Junio"/>
					<row id="07" text="Julio"/>
					<row id="08" text="Agosto"/>
					<row id="09" text="Septiembre"/>
					<row id="10" text="Octubre"/>
					<row id="11" text="Noviembre"/>
					<row id="12" text="Diciembre"/>
					<row id="13" text="Hoy"/>
				</ROWS>
			</param>
			<param name="evento" label="Evento" type="ENUM">
				<ROWS>
					<row id="AC" text="Aniversarios y Cumplea&#241;os"/>
					<row id="A" text="Aniversarios"/>
					<row id="C" text="Cumplea&#241;os"/>
				</ROWS>
			</param>
			<param name="tipoFam" label="Tipos de Familiares" type="STRING"/>
		</xsl:template>
	</html:xslt>
</html:html>
