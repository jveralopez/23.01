				<a href="" target="_blank">
					<xsl:attribute name="href">
						<xsl:value-of select="$source/@oi_doc_digital"/>
					</xsl:attribute>
					<xsl:value-of select="$source/@doc_dig"/>
				</a>
			</xsl:if>
			<xsl:if test="$source/@oi_doc_digital = 'No'">
				No
			</xsl:if>
		</xsl:template>
		<xsl:template name="lnk_reporte">
			<xsl:param name="source"/>
			<a href="#">
				<xsl:attribute name="onclick">
					<xsl:value-of select="$source/@lnk_reporte"/>
				</xsl:attribute>
				<xsl:value-of select="$source/@nombre_reporte"/>
			</a>
		</xsl:template>
		<xsl:template name="lnk_recibo">
			<xsl:param name="source"/>
			<xsl:if test="$source/@lnk_recibo='No encontrado'">
				<xsl:text>
					No encontrado
				</xsl:text>
			</xsl:if>
			<xsl:if test="$source/@lnk_recibo!='No encontrado'">
				<xsl:if test="$source/@lnk_recibo='Sin recibo'">
					<xsl:text>
						Sin recibo
					</xsl:text>
				</xsl:if>
				<xsl:if test="$source/@lnk_recibo!='Sin recibo'">
					<a href="#">
						<xsl:attribute name="onclick">
							<xsl:value-of select="$source/@lnk_recibo"/>
						</xsl:attribute>
						<xsl:value-of select="$source/@nombre_recibo"/>
					</a>
				</xsl:if>
			</xsl:if>
