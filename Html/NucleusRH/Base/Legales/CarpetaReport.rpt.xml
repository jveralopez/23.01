					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template='lnk_reporte'">
				<xsl:call-template name="lnk_reporte">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template='lnk_recibo'">
				<xsl:call-template name="lnk_recibo">
					<xsl:with-param name="source" select="$source"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$template=''">
				&#160;
			</xsl:if>
		</xsl:template>
		<xsl:template match="T1" name="T1">
			<xsl:param name="source"/>
