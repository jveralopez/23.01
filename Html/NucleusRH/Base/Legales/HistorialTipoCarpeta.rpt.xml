<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" doc="source" extends="Nomad.Base.BaseReport.rpt" name="NucleusRH.Base.Legales.HistorialTipoCarpeta">
	<html:query declare="&lt;PARAMS oi_carpeta=&quot;206&quot;/&gt;&#13;&#10;">
		<qry:main name="" doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:PARAMS"/>
			<REPORT label="Historial de Tipo de Carpeta" style="width:100%">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
				<GROUPS>
					<GROUP tag="CARPETA" type="title" label="" style="">
						<COLS>
							<COL name="empresa" label="Empresa" style="width:30%"/>
							<COL name="d_carpeta" label="Carpeta" style="width:30%"/>
							<COL name="tipoActual" label="Tipo Actual" style="width:30%"/>
						</COLS>
						<GROUP tag="HIST" type="table" style="width:100%">
							<COLS>
								<COL name="f_hist_tipo_car" label="Fecha" type="date"/>
								<COL name="usuario_cambia" label="Usuario"/>
								<COL name="tipo_ant" label="Tipo Carpeta Anterior"/>
								<COL name="tipo_nu" label="Tipo Carpeta Nuevo"/>
								<COL name="o_hist_tipo_car" label="Motivo de Cambio"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="CARPETA">
						<qry:insert-select name="qry_carpeta" doc-path="#PARAMIN:"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_carpeta">
			<qry:xquery>
				for $r in sql('
				SELECT
					C.oi_carpeta,
					C.c_carpeta,
					C.d_carpeta,
					E.c_empresa,
					E.d_empresa,
					C.oi_tipo_carpeta
					
				FROM
					LEG01_CARPETAS as C,
					ORG03_EMPRESAS as E
					
				JOIN
				C.oi_empresa INNER E.oi_empresa
				WHERE
					C.oi_carpeta = {#SOURCE:@oi_carpeta}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="empresa" value="'[' + $r/@c_empresa +']' + ' - ' + $r/@d_empresa"/>
				<qry:attribute name="d_carpeta" value="'[' + $r/@c_carpeta + ']' + ' - ' + $r/@d_carpeta"/>
				<qry:insert-select name="getTipoActual" doc-path="$r"/>
				<qry:insert-select name="qry_cambios" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_cambios">
			<qry:xquery>
				for $r in sql('
				SELECT
					LEG01_HIST_TIPO_CAR.f_hist_tipo_car,
					LEG01_HIST_TIPO_CAR.usuario_cambia,
					ANT.d_tipo_carpeta as tipo_ant,
					NU.d_tipo_carpeta as tipo_nu,
					LEG01_HIST_TIPO_CAR.o_hist_tipo_car
				FROM
					LEG01_HIST_TIPO_CAR,
					LEG42_TIPO_CARPETA as ANT,
					LEG42_TIPO_CARPETA as NU
				JOIN
					LEG01_HIST_TIPO_CAR.oi_tipo_car_ant INNER ANT.oi_tipo_carpeta,
					LEG01_HIST_TIPO_CAR.oi_tipo_car_nu INNER NU.oi_tipo_carpeta
				WHERE
					LEG01_HIST_TIPO_CAR.oi_carpeta = {#SOURCE:@oi_carpeta}
				ORDER BY
					f_hist_tipo_car DESC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="HIST">
					<qry:attribute name="f_hist_tipo_car" value="format-date($r/@f_hist_tipo_car, 'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="usuario_cambia" value="$r/@usuario_cambia"/>
					<qry:attribute name="tipo_ant" value="$r/@tipo_ant"/>
					<qry:attribute name="tipo_nu" value="$r/@tipo_nu"/>
					<qry:attribute name="o_hist_tipo_car" value="$r/@o_hist_tipo_car"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="getTipoActual" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			  SELECT 
			  C.c_tipo_carpeta,
			  C.d_tipo_carpeta
			  FROM LEG42_TIPO_CARPETA as C
			  WHERE C.oi_tipo_carpeta = {$PARAM/@oi_tipo_carpeta}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="tipoActual" value="'['+$r/@c_tipo_carpeta+'] '+$r/@d_tipo_carpeta"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
