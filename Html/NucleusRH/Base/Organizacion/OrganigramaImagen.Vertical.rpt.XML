<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="NucleusRH.Base.Organizacion.OrganigramaImagen.rpt" name="Organigrama Clasico Vertical" doc="source" type="image">
	<html:query declare="&lt;DATA staff=&quot;&quot; oi_estructura=&quot;1&quot; uplevel=&quot;1&quot; level=&quot;8&quot; title=&quot;&quot; legend=&quot;&quot; resp=&quot;1&quot; respimg=&quot;1&quot; leg=&quot;1&quot; legimg=&quot;1&quot; legcount=&quot;&quot; extern=&quot;1&quot; hid-fic=&quot;1&quot; maxwidth=&quot;&quot; maxheight=&quot;&quot;/&gt;">
		<qry:include name="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.QRY_REPORTE_IMAGEN"/>
		<qry:main doc="PARAM">
			<qry:create-doc name="INFO"/>
			<qry:insert-select name="info-data" to-element="$INFO"/>
			<qry:insert-select name="main" doc-path="$PARAM/DATA"/>
		</qry:main>
		<qry:select name="info-data">
			<qry:out>
				<CELD width="200" height="0" min-height="250" spacing="20" border-width="2" border-color="#666666" noresp-color="#FFC430" resp-color="#C1DD79">
					<CLASS height="7" color="#00000"/>
					<UNIT height="9" color="#00000" len="25"/>
					<LEGAJO height="8" color="#00000" len="25"/>
					<IMAGE width="180" height="180"/>
					<PERSONAL height="6" color="#00000"/>
					<PERSONAL-IMAGE width="25" height="25"/>
					<PERSONAL-AD height="6" color="#00000"/>
					<ADITIONAL height="8" color="#00000" count="0"/>
					<STAFF top="-6" pen-color="#666666" brush-color2="#5882FA"/>
				</CELD>
				<LEGEND width="400" height="50" color="#CCCCCC">
					<TITLE height="12" color="#00000" len="40"/>
					<TEXT height="8" color="#00000"/>
				</LEGEND>
			</qry:out>
		</qry:select>
		<qry:select name="QRY-ADITIONAL-ESTR-EJEMPLO" doc="PARAM">
			<qry:out>
				<qry:attribute name="height" value="number(@height) + number($INFO/CELD/LEGAJO/@height)"/>
				<ADITIONAL>
					<ROW text="Caso 1"/>
					<ROW text="Caso 2"/>
					<ROW text="Caso 3"/>
					<qry:attribute name="height" value="(Count(./ROW)) * (1 + number($INFO/CELD/PERSONAL-AD/@height))"/>
				</ADITIONAL>
			</qry:out>
		</qry:select>
		<qry:select name="QRY-ADITIONAL-PER-EJEMPLO" doc="PARAM">
			<qry:out>
				<ROW text="Dato 1"/>
				<ROW text="Dato 2"/>
				<ROW text="Dato 3"/>
				<qry:attribute name="l-height" value="number(@height)-2"/>
				<qry:if test="$FILTRO/@legimg=1">
					<qry:then>
						<qry:attribute name="ad-height" value="2 + number($INFO/CELD/PERSONAL/@height) * 2 + (Count(./ROW) + 1) * (1 + number($INFO/CELD/PERSONAL-AD/@height))"/>
						<qry:attribute name="height" value="iif(number(@height)&gt;number(@ad-height),number(@height),number(@ad-height))"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="height" value="number(@height) + (Count(./ROW) + 1) * (1 + number($INFO/CELD/PERSONAL-AD/@height))"/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="QRY-ADITIONAL-RESP-EJEMPLO" doc="PARAM">
			<qry:out>
				<ROW text="Resp 1"/>
				<ROW text="Resp 2"/>
				<ROW text="Resp 3"/>
				<ROW text="Resp 4"/>
				<ROW text="Resp 5"/>
				<ROW text="Resp 6"/>
				<ROW text="Resp 7"/>
				<ROW text="Resp 8"/>
				<qry:attribute name="height" value="number(@height) + (Count(./ROW) + 1) * (1 + number($INFO/CELD/PERSONAL-AD/@height))"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="IMG">
			<graph>
				<xsl:attribute name="height">
					<xsl:value-of select="@height"/>
				</xsl:attribute>
				<xsl:attribute name="width">
					<xsl:value-of select="@width"/>
				</xsl:attribute>
				<xsl:attribute name="scale">
					<xsl:value-of select="@scale"/>
				</xsl:attribute>
				<functions>
					<function id="DrawNode">
						<shape style="nodo-line">
							<start-point top="5" left="0"/>
							<line top="3" left="1"/>
							<line top="1" left="3"/>
							<line top="0" left="5"/>
							<line top="0" right="5"/>
							<line top="1" right="3"/>
							<line top="4" right="1"/>
							<line top="5" right="0"/>
							<line bottom="6" right="0"/>
							<line bottom="3" right="2"/>
							<line bottom="2" right="3"/>
							<line bottom="0" right="6"/>
							<line bottom="0" left="6"/>
							<line bottom="2" left="3"/>
							<line bottom="3" left="2"/>
							<line bottom="6" left="0"/>
							<line/>
						</shape>
					</function>
					<function id="DrawNodeStaff">
						<shape style="nodo-line-staff">
							<start-point top="5" left="0"/>
							<line top="3" left="1"/>
							<line top="1" left="3"/>
							<line top="0" left="5"/>
							<line top="0" right="5"/>
							<line top="1" right="3"/>
							<line top="4" right="1"/>
							<line top="5" right="0"/>
							<line bottom="6" right="0"/>
							<line bottom="3" right="2"/>
							<line bottom="2" right="3"/>
							<line bottom="0" right="6"/>
							<line bottom="0" left="6"/>
							<line bottom="2" left="3"/>
							<line bottom="3" left="2"/>
							<line bottom="6" left="0"/>
							<line/>
						</shape>
					</function>
					<function id="DrawLegend" p1="title" p2="title_ext" p3="legend" p4="height" p5="width">
						<area top="20" left="20" height="[%height%]" width="[%width%]">
							<function id="DrawNode" style="nodo-legend"/>
							<text left="0" right="0" top="5" height="20" style="title" value="[%title%]"/>
							<text left="0" right="0" top="20" height="20" style="title" value="[%title_ext%]"/>
							<text left="5" right="5" top="40" bottom="5" style="legend" value="[%legend%]"/>
						</area>
					</function>
					<!-- -->
					<function id="DrawNodeNoRespNoPerStaff" p1="clase" p2="unidad" p3="unidad_ext">
						<area top="0" left="0" bottom="0">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/@width"/>
							</xsl:attribute>
							<function id="DrawNodeStaff" style="nodo-staff"/>
							<text value="[%clase%]" top="1" left="0" bottom="0" right="0" style="clase"/>
							<text value="[%unidad%]" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="6+INFO/CELD/CLASS/@height"/>
								</xsl:attribute>
							</text>
							<text value="[%unidad_ext%]" top="28" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="9+INFO/CELD/CLASS/@height+INFO/CELD/UNIT/@height"/>
								</xsl:attribute>
							</text>
						</area>
					</function>
					<!-- -->
					<function id="DrawNodeNoRespNoPer" p1="clase" p2="unidad" p3="unidad_ext">
						<area top="0" left="0" bottom="0">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/@width"/>
							</xsl:attribute>
							<function id="DrawNode" style="nodo-normal"/>
							<text value="[%clase%]" top="1" left="0" bottom="0" right="0" style="clase"/>
							<text value="[%unidad%]" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="6+INFO/CELD/CLASS/@height"/>
								</xsl:attribute>
							</text>
							<text value="[%unidad_ext%]" top="28" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="9+INFO/CELD/CLASS/@height+INFO/CELD/UNIT/@height"/>
								</xsl:attribute>
							</text>
						</area>
					</function>
					<function id="DrawNodeRespNoPer" p1="clase" p2="unidad" p3="unidad_ext" p4="responsable">
						<area top="0" left="0" bottom="0">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/@width"/>
							</xsl:attribute>
							<function id="DrawNode" style="nodo-resp"/>
							<text value="[%clase%]" top="1" left="0" bottom="0" right="0" style="clase"/>
							<text value="[%unidad%]" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="6+INFO/CELD/CLASS/@height"/>
								</xsl:attribute>
							</text>
							<text value="[%unidad_ext%]" left="0" height="10" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="9+INFO/CELD/CLASS/@height+INFO/CELD/UNIT/@height"/>
								</xsl:attribute>
							</text>
						</area>
					</function>
					<function id="DrawNodeRespNoPerImage" p1="clase" p2="unidad" p3="unidad_ext" p4="responsable" p5="foto" p6="with-foto">
						<area top="0" left="0" bottom="0">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/@width"/>
							</xsl:attribute>
							<function id="DrawNode" style="nodo-resp"/>
							<text value="[%clase%]" top="1" left="0" bottom="0" right="0" style="clase"/>
							<text value="[%unidad%]" left="0" bottom="0" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="6+INFO/CELD/CLASS/@height"/>
								</xsl:attribute>
							</text>
							<text value="[%unidad_ext%]" left="0" height="10" right="0" style="unidad">
								<xsl:attribute name="top">
									<xsl:value-of select="9+INFO/CELD/CLASS/@height+INFO/CELD/UNIT/@height"/>
								</xsl:attribute>
							</text>
						</area>
					</function>
					<function id="ShowFoto1" p1="foto">
						<img type="db" id="[%foto%]" class="NucleusRH.Base.Personal.Imagenes.Head"/>
					</function>
					<function id="ShowFoto">
						<img type="bin">
							
						</img>
					</function>
					<function id="DrawPersona" p1="value">
						<text left="4" right="0" style="personal" value="[%value%]"/>
					</function>
					<function id="DrawPersonaImage" p1="legajo" p2="nombre" p3="foto" p4="with-foto">
						<function id="ShowFoto[%with-foto%]" top="0" left="4" foto="[%foto%]">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/PERSONAL-IMAGE/@width"/>
							</xsl:attribute>
							<xsl:attribute name="height">
								<xsl:value-of select="INFO/CELD/PERSONAL-IMAGE/@height"/>
							</xsl:attribute>
						</function>
						<text right="0" top="2" height="10" style="personal" value="Legajo: [%legajo%]">
							<xsl:attribute name="left">
								<xsl:value-of select="8 + INFO/CELD/PERSONAL-IMAGE/@width"/>
							</xsl:attribute>
						</text>
						<text right="0" top="15" height="10" style="personal" value="[%nombre%]">
							<xsl:attribute name="left">
								<xsl:value-of select="8 + INFO/CELD/PERSONAL-IMAGE/@width"/>
							</xsl:attribute>
							<xsl:attribute name="top">
								<xsl:value-of select="6 + INFO/CELD/PERSONAL/@height"/>
							</xsl:attribute>
						</text>
						<rectangle top="0" left="4" style="borde-simple">
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/CELD/PERSONAL-IMAGE/@width"/>
							</xsl:attribute>
							<xsl:attribute name="height">
								<xsl:value-of select="INFO/CELD/PERSONAL-IMAGE/@height"/>
							</xsl:attribute>
						</rectangle>
					</function>
				</functions>
				<palettes>
					<palette id="default">
						<style id="default" pen-width="1" pen-color="#000000" pen-type="Solid" brush-type="unfilled"/>
						<style id="borde-simple" pen-width="1" pen-color="#AAAAAA" pen-type="Solid"/>
						<style id="borde-staff" pen-width="1" pen-color="#AAAAAA" pen-type="Dash"/>
						<style id="nodo-staff" brush-type="gradient" brush-color="#CEE3F6" brush-top="-10" brush-bottom="-10" brush-left="0" brush-width="0" brush-color2="#5882FA"/>
						<style id="nodo-line" pen-type="Solid">
							<xsl:attribute name="pen-color">
								<xsl:value-of select="INFO/CELD/@border-color"/>
							</xsl:attribute>
							<xsl:attribute name="pen-width">
								<xsl:value-of select="INFO/CELD/@border-width"/>
							</xsl:attribute>
						</style>
						<!-- nodo-line-staff -->
						<style id="nodo-line-staff" pen-type="Dash">
							<xsl:attribute name="pen-color">
								<xsl:value-of select="INFO/CELD/STAFF/@pen-color"/>
							</xsl:attribute>
							<xsl:attribute name="pen-width">
								<xsl:value-of select="INFO/CELD/@border-width"/>
							</xsl:attribute>
						</style>
						<!-- -->
						<style id="nodo-normal" brush-type="gradient" brush-color="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="0" brush-width="0">
							<xsl:attribute name="brush-color2">
								<xsl:value-of select="INFO/CELD/@noresp-color"/>
							</xsl:attribute>
						</style>
						<!-->
	<style id="nodo-normal" brush-type="gradient" brush-color="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="0" brush-width="0">
		<xsl:attribute name="brush-color2">
			<xsl:value-of select="INFO/CELD/@noresp-color"/>
		</xsl:attribute>
	</style> 
	<-->
						<style id="nodo-resp" brush-type="gradient" brush-color="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="0" brush-width="0">
							<xsl:attribute name="brush-color2">
								<xsl:value-of select="INFO/CELD/@resp-color"/>
							</xsl:attribute>
						</style>
						<style id="nodo-legend" brush-type="gradient" brush-color="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="0" brush-width="0">
							<xsl:attribute name="brush-color2">
								<xsl:value-of select="INFO/LEGEND/@color"/>
							</xsl:attribute>
						</style>
						<style id="clase" font-style="normal" brush-type="solid" text-align="center top">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/CLASS/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/CLASS/@color"/>
							</xsl:attribute>
						</style>
						<style id="unidad" font-style="normal" brush-type="solid" text-align="center top">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/UNIT/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/UNIT/@color"/>
							</xsl:attribute>
						</style>
						<style id="responsable" font-style="normal" brush-type="solid" text-align="left center">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/LEGAJO/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/LEGAJO/@color"/>
							</xsl:attribute>
						</style>
						<style id="responsablecenter" font-style="normal" brush-type="solid" text-align="center center">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/LEGAJO/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/LEGAJO/@color"/>
							</xsl:attribute>
						</style>
						<style id="personal" font-style="normal" brush-type="solid" text-align="left center">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/PERSONAL/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/PERSONAL/@color"/>
							</xsl:attribute>
						</style>
						<style id="aditional" font-style="normal" brush-type="solid" text-align="left center">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/CELD/PERSONAL-AD/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/CELD/PERSONAL-AD/@color"/>
							</xsl:attribute>
						</style>
						<style id="title" font-style="bold" brush-type="solid" text-align="center center">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/LEGEND/TITLE/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/LEGEND/TITLE/@color"/>
							</xsl:attribute>
						</style>
						<style id="legend" font-style="normal" brush-type="solid" text-align="left top">
							<xsl:attribute name="font-size">
								<xsl:value-of select="INFO/LEGEND/TEXT/@height"/>
							</xsl:attribute>
							<xsl:attribute name="brush-color">
								<xsl:value-of select="INFO/LEGEND/TEXT/@color"/>
							</xsl:attribute>
						</style>
					</palette>
				</palettes>
				<main-area palette="default" style="default">
					<cols>
						<col>
							<xsl:attribute name="width">
								<xsl:value-of select="@ad-width"/>
							</xsl:attribute>
						</col>
						<col>
							<rows>
								<xsl:for-each select="par/est-parent">
									<row top="0">
										<xsl:attribute name="height">
											<xsl:value-of select="@height + (../../INFO/CELD/@spacing)"/>
										</xsl:attribute>
										<xsl:call-template name="est-parent">
											<xsl:with-param name="INFO" select="../../INFO"/>
											<xsl:with-param name="DEEPS" select="../../DEEPS"/>
										</xsl:call-template>
									</row>
								</xsl:for-each>
								<row top="0">
									<xsl:attribute name="height">
										<xsl:value-of select="DEEPS/DEEP[@deep='1']/@height"/>
									</xsl:attribute>
									<cols>
										<xsl:for-each select="est">
											<xsl:call-template name="est">
												<xsl:with-param name="DEEPS" select="../DEEPS"/>
												<xsl:with-param name="INFO" select="../INFO"/>
											</xsl:call-template>
										</xsl:for-each>
									</cols>
								</row>
							</rows>
						</col>
					</cols>
					<xsl:if test="@title!=''">
						<function id="DrawLegend">
							<xsl:attribute name="title">
								<xsl:value-of select="@title"/>
							</xsl:attribute>
							<xsl:attribute name="title_ext">
								<xsl:value-of select="@title_1"/>
							</xsl:attribute>
							<xsl:attribute name="legend">
								<xsl:value-of select="@legend"/>
							</xsl:attribute>
							<xsl:attribute name="height">
								<xsl:value-of select="INFO/LEGEND/@height+((INFO/LEGEND/TEXT/@height + 4)*@legend-count)"/>
							</xsl:attribute>
							<xsl:attribute name="width">
								<xsl:value-of select="INFO/LEGEND/@width"/>
							</xsl:attribute>
						</function>
					</xsl:if>
				</main-area>
			</graph>
		</xsl:template>
		<xsl:template name="CELL">
			<xsl:param name="INFO"/>
			<xsl:param name="DEEPS"/>
			<area>
				<xsl:if test="@p_staff='no'">
					<xsl:attribute name="top">
						<xsl:value-of select="($INFO/CELD/@spacing div 2)"/>
					</xsl:attribute>
					<xsl:attribute name="height">
						<xsl:value-of select="@height"/>
					</xsl:attribute>
					<xsl:attribute name="width">
						<xsl:value-of select="@width"/>
					</xsl:attribute>
					<xsl:attribute name="left">
						<xsl:if test="local-name(.)='est-parent'">
							<xsl:value-of select="(../../@width - ../../@ad-width - @width) div 2"/>
						</xsl:if>
						<xsl:if test="local-name(.)='est'">
							<xsl:value-of select="(@child-width - @width) div 2"/>
						</xsl:if>
					</xsl:attribute>
					<xsl:if test="local-name(.)!='fic'">
						<xsl:variable name="top">
							<xsl:choose>
								<xsl:when test="@d_unidad_org_1!=''">
									<xsl:if test="ADITIONAL">
										<xsl:value-of select="22 + $INFO/CELD/CLASS/@height + 2*$INFO/CELD/UNIT/@height + ADITIONAL/@height"/>
									</xsl:if>
									<xsl:if test="not(ADITIONAL)">
										<xsl:value-of select="22 + $INFO/CELD/CLASS/@height + 2*$INFO/CELD/UNIT/@height"/>
									</xsl:if>
								</xsl:when>
								<xsl:otherwise>
									<xsl:if test="ADITIONAL">
										<xsl:value-of select="22 + $INFO/CELD/CLASS/@height + $INFO/CELD/UNIT/@height + ADITIONAL/@height"/>
									</xsl:if>
									<xsl:if test="not(ADITIONAL)">
										<xsl:value-of select="22 + $INFO/CELD/CLASS/@height + $INFO/CELD/UNIT/@height"/>
									</xsl:if>
								</xsl:otherwise>
							</xsl:choose>
						</xsl:variable>
						<xsl:if test="RESP">
							<xsl:if test="$DEEPS/../@respimg=1">
								<function id="DrawNodeRespNoPerImage">
									<xsl:attribute name="clase">
										<xsl:value-of select="@d_tipo_uni_org"/>
									</xsl:attribute>
									<xsl:attribute name="unidad">
										<xsl:value-of select="@d_unidad_org"/>
									</xsl:attribute>
									<xsl:attribute name="unidad_ext">
										<xsl:value-of select="@d_unidad_org_1"/>
									</xsl:attribute>
									<xsl:attribute name="foto">
										<xsl:value-of select="RESP/@oi_foto"/>
									</xsl:attribute>
								</function>
								<function id="ShowFoto" left="7" right="7">
									<xsl:attribute name="top">
										<xsl:value-of select="$top"/>
									</xsl:attribute>
									<xsl:attribute name="height">
										<xsl:value-of select="$INFO/CELD/IMAGE/@height"/>
									</xsl:attribute>
									<xsl:attribute name="foto">
										<xsl:value-of select="RESP/@oi_foto"/>
									</xsl:attribute>
									<xsl:attribute name="foto">
										<xsl:value-of select="RESP/@oi_foto"/>
									</xsl:attribute>
									<xsl:if test="RESP/@oi_foto">
										<xsl:attribute name="id">
