<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Organizaci&#243;n.CentrosCostos" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query>
		<qry:main doc="PARAM">
			<REPORT label="Listado Centros de Costos">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="CENTROS" type="table">
						<COLS>
							<COL name="c_centro_costo" label="C&#243;digo" nowrap="1"/>
							<COL name="d_centro_costo" label="Descripci&#243;n" nowrap="1"/>
							<COL name="grupo" label="Grupo" nowrap="1"/>
							<COL name="unidad_org" label="Unidad Organizativa" nowrap="1"/>
							<COL name="o_centro_costo" label="Observaciones" nowrap="1"/>
							<COL name="l_activo" label="Estado" nowrap="1"/>
						</COLS>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select name="QRY_CENTRO"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select name="QRY_CENTRO">
			<qry:xquery>
				for $r in sql('
				SELECT 
				  ORG08_CS_COSTO.oi_centro_costo,
				  ORG08_CS_COSTO.c_centro_costo,
					ORG08_CS_COSTO.d_centro_costo,
					ORG09_GR_CCOSTO.c_grupo_ccosto,
					ORG09_GR_CCOSTO.d_grupo_ccosto,
					ORG08_CS_COSTO.o_centro_costo,
					ORG01_UNI_ORG.c_unidad_org,
					ORG01_UNI_ORG.d_unidad_org,
					ORG08_CS_COSTO.l_activo
					
				FROM 
					ORG08_CS_COSTO,
					ORG09_GR_CCOSTO,
					ORG01_UNI_ORG
				JOIN
					ORG08_CS_COSTO.oi_grupo_ccosto LEFT OUTER ORG09_GR_CCOSTO.oi_grupo_ccosto,
					ORG08_CS_COSTO.oi_unidad_org LEFT OUTER ORG01_UNI_ORG.oi_unidad_org
				ORDER BY 
					c_centro_costo ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CENTROS">
					<qry:attribute name="c_centro_costo" value="$r/@c_centro_costo"/>
					<qry:attribute name="d_centro_costo" value="$r/@d_centro_costo"/>
					<qry:attribute name="o_centro_costo" value="$r/@o_centro_costo"/>
					<qry:attribute name="grupo" value="iif($r/@c_grupo_ccosto!='',$r/@c_grupo_ccosto  + ' - ' + $r/@d_grupo_ccosto,'')"/>
					<qry:attribute name="unidad_org" value="iif($r/@c_unidad_org!='',$r/@c_unidad_org  + ' - ' + $r/@d_unidad_org,'')"/>
					<qry:attribute name="l_activo" value="iif($r/@l_activo='1','Activo','Inactivo')"/>
					<!--qry:attribute name="oi_recurso" value="@oi_recurso + iif(@oi_recurso!= '',' - ','') + $PARAM/@rec_dic"/-->
				</qry:element>
			</qry:out>
		</qry:select>
		<!-- -->
		<!-- -->
		<!-- funcion qry_categoria de tipo consulta -->
		<!-- -->
		<!-- -->
	</html:query>
</html:html>
