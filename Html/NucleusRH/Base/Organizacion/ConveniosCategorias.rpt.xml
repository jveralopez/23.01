<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Organizaci&#243;n.CategoriasporConvenio" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;FILTRO selected=&quot;5&quot;&gt;&#13;&#10;  &lt;ROWS /&gt;&#13;&#10;  &lt;CONV nmd-col=&quot;1&quot;&gt;&#13;&#10;    &lt;C id=&quot;1&quot; /&gt;&#13;&#10;    &lt;C id=&quot;2&quot; /&gt;&#13;&#10;    &lt;C id=&quot;4&quot; /&gt;&#13;&#10;    &lt;C id=&quot;5&quot; /&gt;&#13;&#10;    &lt;C id=&quot;6&quot; /&gt;&#13;&#10;    &lt;C id=&quot;7&quot; /&gt;&#13;&#10;    &lt;C id=&quot;8&quot; /&gt;&#13;&#10;    &lt;C id=&quot;9&quot; /&gt;&#13;&#10;    &lt;C id=&quot;10&quot; /&gt;&#13;&#10;    &lt;C id=&quot;13&quot; /&gt;&#13;&#10;    &lt;C id=&quot;17&quot; /&gt;&#13;&#10;    &lt;C id=&quot;27&quot; /&gt;&#13;&#10;    &lt;C id=&quot;28&quot; /&gt;&#13;&#10;    &lt;C id=&quot;29&quot; /&gt;&#13;&#10;    &lt;C id=&quot;30&quot; /&gt;&#13;&#10;    &lt;C id=&quot;31&quot; /&gt;&#13;&#10;  &lt;/CONV&gt;&#13;&#10;&lt;/FILTRO&gt;">
		<qry:main doc="PARAM">
			<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
			<REPORT label="Listado de Categor&#237;as Por Convenio">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="CONVENIO" type="title">
						<COLS>
							<COL name="convenio" label="Convenio"/>
						</COLS>
						<GROUP tag="CATEGORIA" label="Categor&#237;as" type="table">
							<COLS>
								<COL name="c_categoria" label="C&#243;digo" style="width:15%" nowrap="1"/>
								<COL name="d_categoria" label="Descripci&#243;n" style="width:35%" nowrap="1"/>
								<COL name="n_valor_hora" label="Valor Hora/Bas. Mes" style="width:5%" nowrap="1" type="num"/>
								<COL name="n_suplemento_1" label="Suplemento 1" style="width:5%" nowrap="1" type="num"/>
								<COL name="n_suplemento_2" label="Suplemento 2" style="width:5%" nowrap="1" type="num"/>
								<COL name="n_suplemento_3" label="Suplemento 3" style="width:5%" nowrap="1" type="num"/>
								<COL name="n_suplemento_4" label="Suplemento 4" style="width:5%" nowrap="1" type="num"/>
								<COL name="promocion" label="Promoci&#243;n Aut." style="width:5%" nowrap="1"/>
								<COL name="o_categoria" label="Observaciones" style="width:25%" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_CONVENIO"/>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_CONVENIO">
			<qry:xquery>
				for $r in sql('
				SELECT 
				  ORG18_CONVENIOS.oi_convenio,
				  ORG18_CONVENIOS.c_convenio AS c_convenio,
					ORG18_CONVENIOS.d_convenio
				FROM 
					ORG18_CONVENIOS
				WHERE
					ORG18_CONVENIOS.oi_convenio in ({%=string(#PARAM:CONV/C/@id) %})
					
				ORDER BY c_convenio ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CONVENIO">
					<qry:attribute name="convenio" value="$r/@c_convenio + ' - ' + $r/@d_convenio"/>
					<qry:insert-select doc-path="$r" name="QRY_CATEGORIA"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<!-- -->
		<!-- -->
		<!-- funcion qry_categoria de tipo consulta -->
		<!-- -->
		<!-- -->
		<qry:select doc="PARAM" name="QRY_CATEGORIA">
			<qry:xquery>
				for $r in sql('		
					SELECT 
					  ORG18_CATEGORIAS.oi_convenio,
						ORG18_CATEGORIAS.c_categoria,
						ORG18_CATEGORIAS.d_categoria,
						ORG18_CATEGORIAS.n_valor_hora,
						ORG18_CATEGORIAS.n_suplemento_1,
					  ORG18_CATEGORIAS.n_suplemento_2,
					  ORG18_CATEGORIAS.n_suplemento_3,
					  ORG18_CATEGORIAS.n_suplemento_4,
					  ORG18_CATEGORIAS.l_prom_auto,
					  ORG18_CATEGORIAS.o_categoria, 
					  ORG18_CATEGORIAS.e_secuencia
					FROM 
						ORG18_CATEGORIAS							 
					WHERE
						ORG18_CATEGORIAS.oi_convenio ={#PARAM:@oi_convenio} 		 
				  ORDER BY
          	e_secuencia ASC, c_categoria ASC
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="CATEGORIA">
					<qry:attribute name="c_categoria" value="$r/@c_categoria"/>
					<qry:attribute name="d_categoria" value="$r/@d_categoria"/>
					<qry:attribute name="n_valor_hora" value="$r/@n_valor_hora"/>
					<qry:attribute name="n_suplemento_1" value="$r/@n_suplemento_1"/>
					<qry:attribute name="n_suplemento_2" value="$r/@n_suplemento_2"/>
					<qry:attribute name="n_suplemento_3" value="$r/@n_suplemento_3"/>
					<qry:attribute name="n_suplemento_4" value="$r/@n_suplemento_4"/>
					<qry:attribute name="promocion" value="iif($r/@l_prom_auto='1','Si','No')"/>
					<qry:attribute name="o_categoria" value="$r/@o_categoria"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
