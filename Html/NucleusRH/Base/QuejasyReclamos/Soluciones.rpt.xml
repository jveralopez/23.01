<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.QuejasyReclamos.Soluciones.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;ROW id=&quot;1&quot; search=&quot;&quot; /&gt;" name="">
		<qry:main doc="PARAM">
			<qry:element name="ROWS">
				<qry:insert-select name="sql1" doc-path="#PARAM:ROW"/>
			</qry:element>
		</qry:main>
		<qry:select name="sql1" doc="PARAM">
			<qry:xquery>
				for $r in SQL(' maxsize 5
					SELECT 
						QYR03_SOLUCIONES.oi_solucion,
						QYR03_SOLUCIONES.f_solucion, 
						QYR03_SOLUCIONES.t_solucion 
					FROM 
						QYR03_SOLUCIONES
					WHERE 
						QYR03_SOLUCIONES.l_vigente = \'1\' AND 
						QYR03_SOLUCIONES.oi_tipo_problema  = {#PARAM:@id}
						{%?(#PARAM:@search!='')
							{% AND contain(QYR03_SOLUCIONES.t_solucion, {#PARAM:@search}) %}
							{% %}
						%}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="oi_solucion" value="$r/@oi_solucion"/>
					<qry:attribute name="f_solucion" value="format_date($r/@f_solucion, 'dd/mm/yyyy')"/>
					<qry:attribute name="t_solucion" value="iif($r/@t_solucion = '', 'No hay soluciones cargadas', $r/@t_solucion)"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
