<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.QuejasyReclamos.ReclamosOficinaInactiva.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;PARAM oi_oficina=&quot;OFI:01&quot;/&gt;" name="">
		<qry:main doc="PARAM">
			<qry:element name="ROWS">
				<qry:insert-select name="sql1"/>
			</qry:element>
		</qry:main>
		<qry:select name="sql1" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT
					QYR01_RECLAMOS.oi_reclamo,
					QYR08_OFICINAS.c_oficina,
					QYR08_OFICINAS.d_oficina
				FROM
					QYR01_RECLAMOS,
					QYR01_HISTORICOS,
					QYR08_OFICINAS
				JOIN
					QYR01_RECLAMOS.oi_reclamo INNER QYR01_HISTORICOS.oi_reclamo
					,QYR01_HISTORICOS.oi_ofi_hasta INNER QYR08_OFICINAS.oi_oficina
				WHERE
					QYR01_RECLAMOS.n_historico = QYR01_HISTORICOS.n_historico
					AND QYR08_OFICINAS.l_inactiva = 1   
				ORDER BY d_oficina ASC,
				oi_reclamo ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="oi_reclamo" value="$r/@oi_reclamo"/>
					<qry:attribute name="d_oficina" value="'['+$r/@c_oficina+'] '+$r/@d_oficina"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="ROWS">
			<table width="100%" border="solid">
				<tr>
					<td style="font-family:verdana; font-weight:bold; font-size:11px;">
						<b>
							Oficina
						</b>
					</td>
					<td style="font-family:verdana; font-weight:bold; font-size:11px;">
						<b>
							Nro. Reclamo
						</b>
					</td>
				</tr>
				<xsl:for-each select="ROW">
					<tr>
						<td style="font-family:verdana; font-size:11px;">
							<xsl:value-of select="@d_oficina"/>
						</td>
						<td style="font-family:verdana; font-size:11px;">
							<xsl:value-of select="@oi_reclamo"/>
						</td>
					</tr>
				</xsl:for-each>
			</table>
		</xsl:template>
	</html:xslt>
</html:html>
