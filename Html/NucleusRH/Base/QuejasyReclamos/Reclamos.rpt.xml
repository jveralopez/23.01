				<xsl:if test="@origen='PEN'">
					<td title="Ver historial" style="cursor:pointer;">
						<xsl:attribute name="onclick">
							<xsl:value-of select="concat('javascript:openReclamo(&quot;', @ut, '&quot;,&quot;', @oi_reclamo, '&quot;)')"/>
						</xsl:attribute>
						<xsl:value-of select="@d_oficina"/>
