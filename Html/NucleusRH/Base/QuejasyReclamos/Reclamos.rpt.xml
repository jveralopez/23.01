<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.QuejasyReclamos.Reclamos.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;ROW origen=&quot;CER&quot; dias=&quot;&quot; n_criticidad=&quot;&quot; oi_oficina=&quot;&quot;/&gt;" name="">
		<qry:main doc="SOURCE">
			<qry:element name="ROWS">
				<qry:insert-select doc-path="#SOURCE:ROW" name="sql1"/>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="sql1">
			<qry:xquery>
				for $r in SQL('
			SELECT
				QYR01_RECLAMOS.oi_reclamo,
				QYR01_RECLAMOS.f_reclamo,
				QYR01_RECLAMOS.d_usuario,
				QYR01_RECLAMOS.c_estado,
				QYR01_RECLAMOS.f_ult_estado,
				QYR01_RECLAMOS.c_asunto,
				QYR01_RECLAMOS.n_criticidad,
				QYR01_RECLAMOS.f_vencimiento
				
				{%?(#PARAM:@origen ='PEN') 
					{%
					,QYR08_OFICINAS.c_oficina
					,QYR08_OFICINAS.d_oficina
					,QYR01_HISTORICOS.f_reclamo as f_historico
					,COUNT(QYR01_MENSAJES.oi_mensaje) as cant_mensaje 
					,QYR01_HISTORICOS.d_custom_1
					FROM  
						QYR01_RECLAMOS,
						QYR01_HISTORICOS,
					  QYR01_MENSAJES,
						QYR08_OFICINAS
					JOIN           
						QYR01_RECLAMOS.oi_reclamo INNER QYR01_HISTORICOS.oi_reclamo,
						QYR01_HISTORICOS.oi_ofi_hasta LEFT OUTER QYR08_OFICINAS.oi_oficina,
						QYR01_RECLAMOS.oi_reclamo LEFT OUTER QYR01_MENSAJES.oi_reclamo
					WHERE
      			QYR01_RECLAMOS.c_estado != \'Reclamo finalizado\'
      			AND QYR01_RECLAMOS.n_historico = QYR01_HISTORICOS.n_historico
						  {%?(#PARAM:@n_criticidad!='')
									{% AND QYR01_RECLAMOS.n_criticidad = {%=#PARAM:@n_criticidad %} %}
									{% %}
							%}
							{%?(#PARAM:@oi_oficina!='')
									{% AND QYR08_OFICINAS.oi_oficina = {%=#PARAM:@oi_oficina %} %}
									{% %}
							%}
					GROUP BY
						QYR01_RECLAMOS.oi_reclamo,
						QYR01_RECLAMOS.f_reclamo,
						QYR01_RECLAMOS.d_usuario,
						QYR01_RECLAMOS.c_estado,
						QYR01_RECLAMOS.f_ult_estado,
						QYR01_RECLAMOS.c_asunto,
						QYR01_RECLAMOS.n_criticidad,
						QYR01_RECLAMOS.f_vencimiento,
						QYR08_OFICINAS.c_oficina,
						QYR08_OFICINAS.d_oficina,
						QYR01_HISTORICOS.f_reclamo,
						QYR01_HISTORICOS.d_custom_1
						
					%}
					{%  %}
				%}
				{%?(#PARAM:@origen ='') 
					{%
					,QYR08_OFICINAS.c_oficina
					,QYR08_OFICINAS.d_oficina
					,QYR01_HISTORICOS.f_reclamo as f_historico
					,COUNT(QYR01_MENSAJES.oi_mensaje) as cant_mensaje  
					,QYR01_HISTORICOS.d_custom_1
					FROM  
						QYR01_RECLAMOS,
						QYR01_HISTORICOS,
					  QYR01_MENSAJES,
						QYR08_OFICINAS
					JOIN           
						QYR01_RECLAMOS.oi_reclamo INNER QYR01_HISTORICOS.oi_reclamo,
						QYR01_HISTORICOS.oi_ofi_hasta LEFT OUTER QYR08_OFICINAS.oi_oficina,
						QYR01_RECLAMOS.oi_reclamo LEFT OUTER QYR01_MENSAJES.oi_reclamo
					WHERE
      			QYR01_RECLAMOS.n_historico = QYR01_HISTORICOS.n_historico
						  {%?(#PARAM:@n_criticidad!='')
									{% AND QYR01_RECLAMOS.n_criticidad = {%=#PARAM:@n_criticidad %} %}
									{% %}
							%}
							{%?(#PARAM:@oi_oficina!='')
									{% AND QYR08_OFICINAS.oi_oficina = {%=#PARAM:@oi_oficina %} %}
									{% %}
							%}
					GROUP BY
						QYR01_RECLAMOS.oi_reclamo,
						QYR01_RECLAMOS.f_reclamo,
						QYR01_RECLAMOS.d_usuario,
						QYR01_RECLAMOS.c_estado,
						QYR01_RECLAMOS.f_ult_estado,
						QYR01_RECLAMOS.c_asunto,
						QYR01_RECLAMOS.n_criticidad,
						QYR01_RECLAMOS.f_vencimiento,
						QYR08_OFICINAS.c_oficina,
						QYR08_OFICINAS.d_oficina,
						QYR01_HISTORICOS.f_reclamo,
						QYR01_HISTORICOS.d_custom_1
					%}
					{%  %}
				%}
				{%? (#PARAM:@origen ='CER') 
					{% 
						,COUNT(QYR01_MENSAJES.oi_mensaje) as cant_mensaje
						FROM  
							QYR01_RECLAMOS, 
							QYR01_MENSAJES
						JOIN           
							QYR01_RECLAMOS.oi_reclamo LEFT OUTER QYR01_MENSAJES.oi_reclamo
						WHERE 
							  QYR01_RECLAMOS.c_estado = \'Reclamo finalizado\'
							  {%?(#PARAM:@n_criticidad!='')
										{% AND QYR01_RECLAMOS.n_criticidad = {%=#PARAM:@n_criticidad %} %}
										{% %}
								%}
						GROUP BY
							QYR01_RECLAMOS.oi_reclamo,
							QYR01_RECLAMOS.f_reclamo,
							QYR01_RECLAMOS.d_usuario,
							QYR01_RECLAMOS.c_estado,
							QYR01_RECLAMOS.f_ult_estado,
							QYR01_RECLAMOS.c_asunto,
							QYR01_RECLAMOS.n_criticidad,
							QYR01_RECLAMOS.f_vencimiento
							%}  
					{%  %} 
				%} 
				{%? (#PARAM:@origen ='DER') 
					{% FROM  
							QYR01_RECLAMOS,
							( SELECT MAX(HIS.n_historico+1) as n_historico, 
							 	 HIS.oi_reclamo,
							 	 MAX(HIS.f_reclamo) as f_reclamo
								FROM QYR01_HISTORICOS AS HIS
								WHERE isNull(HIS.oi_ofi_hasta)
								GROUP BY HIS.oi_reclamo ) as QYR01_HISTORICOS
						JOIN           
							QYR01_RECLAMOS.oi_reclamo INNER QYR01_HISTORICOS.oi_reclamo
						WHERE 
							
							{%?(#PARAM:@n_criticidad!='')
										{% QYR01_RECLAMOS.n_criticidad = {%=#PARAM:@n_criticidad %} %}
										{% %}
								%}					
						 %}  
					{%  %} 
				%}
			ORDER BY f_reclamo DESC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ROW">
					<qry:attribute name="cantidad" value="$r/@cantidad"/>
					<qry:attribute name="origen" value="iif(#PARAM:@origen='','0', #PARAM:@origen)"/>
					<qry:attribute name="mensaje" value="iif($r/@cant_mensaje!=0, $r/@cant_mensaje+' mensaje(s)', 'Sin mensajes')"/>
					<qry:attribute name="ut" value="#PROXY:@token"/>
					<qry:attribute name="app" value="#PROXY:@app"/>
					<qry:attribute name="oi_reclamo" value="$r/@oi_reclamo"/>
					<qry:attribute name="f_order" value="format_date(Now(), 'yyyymmdd')"/>
					<qry:if test="#PARAM:@origen = 'PEN'">
						<qry:then>
							<qry:attribute name="f_historico" value="format_date($r/@f_historico, 'yyyymmdd')"/>
							<qry:attribute name="diff_dias" value="(Number(DateTime(@f_order)) - Number(DateTime(@f_historico)))"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="fec_rec" value="format_date($r/@f_reclamo, 'yyyymmdd')"/>
							<qry:attribute name="diff_dias" value="(Number(DateTime(@f_order)) - Number(DateTime(@fec_rec)))"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="f_reclamo" value="format_date($r/@f_reclamo, 'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="f_solucion" value="format_date($r/@f_solucion, 'dd/mm/yyyy HH:MM')"/>
					<qry:insert-select name="ENTIDAD" doc-path="$r"/>
					<qry:insert-select name="ORIGEN" doc-path="$r"/>
					<qry:insert-select name="SOLUCION" doc-path="$r"/>
					<qry:attribute name="c_estado" value="iif($r/@d_custom_1 = '', $r/@c_estado, $r/@d_custom_1)"/>
					<qry:attribute name="f_ult_estado" value="format_date($r/@f_ult_estado, 'dd/mm/yyyy HH:MM')"/>
					<qry:attribute name="c_asunto" value="$r/@c_asunto"/>
					<qry:attribute name="d_oficina" value="$r/@d_oficina"/>
					<qry:attribute name="c_oficina" value="$r/@c_oficina"/>
					<qry:attribute name="f_vencimiento" value="format_date($r/@f_vencimiento, 'dd/mm/yyyy HH:MM')"/>
					<qry:switch test="$r/@n_criticidad">
						<qry:default>
							<qry:attribute name="n_criticidad" value="'-'"/>
						</qry:default>
						<qry:case value="1">
							<qry:attribute name="n_criticidad" value="'Muy Baja'"/>
						</qry:case>
						<qry:case value="2">
							<qry:attribute name="n_criticidad" value="'Baja'"/>
						</qry:case>
						<qry:case value="3">
							<qry:attribute name="n_criticidad" value="'Normal'"/>
						</qry:case>
						<qry:case value="4">
							<qry:attribute name="n_criticidad" value="'Alta'"/>
						</qry:case>
						<qry:case value="5">
							<qry:attribute name="n_criticidad" value="'Muy Alta'"/>
						</qry:case>
					</qry:switch>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="ENTIDAD" doc="DOC">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Login\\Entidades\\{%=#DOC:@d_usuario %}.ENTIDAD.XML')/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_usuario" value="$r/@DES"/>
			</qry:out>
		</qry:select>
		<qry:select name="ORIGEN" doc="DOC">
			<qry:xquery>
				for $r in SQL('
				SELECT
					QYR01_DETALLES.d_detalle
				FROM
					QYR01_DETALLES
				WHERE
					QYR01_DETALLES.oi_reclamo = {#DOC:@oi_reclamo}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ORIGEN">
					<qry:attribute name="d_detalle" value="$r/@d_detalle + '- '"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="SOLUCION" doc="DOC">
			<qry:xquery>
				for $r in SQL('
				SELECT
					MAX(QYR01_SOLS_RECLAMO.f_solucion) as f_solucion
				FROM
					QYR01_SOLS_RECLAMO
				WHERE
					QYR01_SOLS_RECLAMO.oi_reclamo = {#DOC:@oi_reclamo}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_solucion" value="format_date($r/@f_solucion, 'dd/mm/yyyy')"/>
			</qry:out>
		</qry:select>
	</html:query>
