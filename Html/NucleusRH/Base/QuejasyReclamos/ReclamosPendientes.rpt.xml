<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.QuejasyReclamos.Reclamos.rpt" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;ROW oi_reclamo=&quot;47&quot; oi_tipo_problema=&quot;&quot; c_asunto=&quot;&quot; t_reclamo=&quot;&quot; d_usuario=&quot;&quot; oi_modulo=&quot;&quot; n_criticidad=&quot;&quot; &#13;&#10;c_estado=&quot;&quot; f_desde=&quot;&quot; f_hasta=&quot;&quot; llamado_desde=&quot;&quot; /&gt;" name="">
		<qry:main doc="SOURCE">
			<qry:append-doc name="ENTRADA" doc-path="#SOURCE:ROW"/>
			<qry:insert-select doc-path="#SOURCE:" name="CONFIG"/>
			<qry:element name="TAREAS_ASIGNADAS">
				<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				<qry:element name="ETAPAS">
					<qry:insert-select doc-path="#SOURCE:" name="sql2"/>
					<qry:insert-select doc-path="#SOURCE:" name="sql3"/>
					<qry:append-doc name="ETAPAS" doc-path="."/>
					<qry:attribute name="hts:delete" value="1"/>
				</qry:element>
				<qry:element name="TAREAS">
					<qry:attribute name="count" value="'0'"/>
					<qry:insert-select doc-path="#SOURCE:" name="sql4"/>
					<qry:attribute name="hts:delete" value="1"/>
				</qry:element>
				<qry:insert-select doc-path="./TAREAS" name="sql5"/>
				<qry:if test="TAREAS/@count = '0'">
					<qry:then>
						<qry:element name="NO_TAREA">
							<qry:attribute name="cod" value="'No tiene reclamos pendientes'"/>
						</qry:element>
					</qry:then>
					<qry:else/>
				</qry:if>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="sql1">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Session\\Tokens\\{%=#PROXY:@token%}.TOKEN.XML')/TOKEN
			</qry:xquery>
			<qry:out>
				<qry:element name="CUENTA">
					<qry:insert-select name="CUENTA" doc-path="$r"/>
					<qry:append-doc name="DATOS" doc-path="."/>
					<qry:attribute name="hts:delete" value="1"/>
					<qry:attribute name="#PROXY:@token" value="#PROXY:@token"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="CUENTA" doc="DOC">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Login\\Cuentas\\{%=#DOC:@CU_LOGIN_ID%}.CUENTA.XML')/CUENTA/GRUPOS/USUARIO_GRUPO/GRUPO
			</qry:xquery>
			<qry:out>
				<qry:attribute name="entidad" value="#PROXY:@etty"/>
				<qry:element name="GRUPO">
					<qry:attribute name="grupo" value="$r/@value"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql2">
			<qry:xquery>
				for $x in #DATOS:GRUPO ,
			$r in FILE('Nomad\\Base\\Workflow\\WorkflowConfig\\{%=#PROXY:@app%}.NucleusRH.Base.QuejasyReclamos.Reclamo.WF.XML')/WF/ETAPAS/ETAPA/RESPONSABLES/RESPONSABLE/GRUPO
			where 
				$r/@value = $x/@grupo
			</qry:xquery>
			<qry:out>
				<qry:element name="ETAPA">
					<qry:attribute name="etapa" value="$r/../../../@id"/>
					<qry:attribute name="cod_etapa" value="$r/../../../@COD"/>
					<qry:attribute name="DIV" value="$r/../@DIVISION"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql3">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Workflow\\WorkflowConfig\\{%=#PROXY:@app%}.NucleusRH.Base.QuejasyReclamos.Reclamo.WF.XML')/WF/ETAPAS/ETAPA/RESPONSABLES/RESPONSABLE/ENTIDAD[@value = #PROXY:@etty]
			</qry:xquery>
			<qry:out>
				<qry:element name="ETAPA">
					<qry:append-doc name="CONFIG" doc-path="$r"/>
					<qry:attribute name="etapa" value="$r/../../../@id"/>
					<qry:attribute name="cod_etapa" value="$r/../../../@COD"/>
					<qry:attribute name="DIV" value="$r/../@DIVISION"/>
					<qry:attribute name="etty" value="#PROXY:@etty"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="sql4">
			<qry:xquery>
				for $l in #ETAPAS:ETAPA,
			$r in FILE('Nomad\\Base\\Workflow\\Indices\\{%=#PROXY:@app%}.NucleusRH.Base.QuejasyReclamos.Reclamo.IDX.XML')/index/files/file/etapa
			where
				$r/@cod = $l/@cod_etapa AND
				$r/../@div = $l/@DIV
			</qry:xquery>
			<qry:out>
				<qry:element name="TAREA">
					<qry:attribute name="id" value="$r/../@name"/>
					<qry:attribute name="cod" value="$r/@cod"/>
					<qry:attribute name="entrada" value="#ENTRADA:@llamado_desde"/>
					<qry:insert-select name="RECLAMO" doc-path="."/>
					<qry:attribute name="url" value="'../Skins/_Default/Pages/MiniMain.htm?skin=_Default&amp;ut='+#PROXY:@token+'&amp;wfclass='+#PROXY:@app+'.NucleusRH.Base.QuejasyReclamos.Reclamo&amp;wfid='+./@id+'&amp;wfetapa='+$l/@cod_etapa"/>
					<qry:attribute name="wfid" value="./@id"/>
					<qry:attribute name="etapa" value="$l/@cod_etapa"/>
					<qry:attribute name="app" value="#PROXY:@app"/>
				</qry:element>
				<qry:attribute name="count" value="iif($r/../@name != '', '1', '0')"/>
			</qry:out>
		</qry:select>
		<qry:select name="RECLAMO" doc="DOC">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Workflow\\WorkflowInstancias\\{%=#DOC:@id%}')/WFI
			</qry:xquery>
			<qry:out>
				<qry:attribute name="id" value="$r/@id"/>
				<qry:attribute name="oi_reclamo" value="$r/DATOS/RECLAMO/@oi_reclamo"/>
				<qry:attribute name="t_reclamo" value="$r/DATOS/RECLAMO/@t_reclamo"/>
				<qry:switch test="$r/DATOS/RECLAMO/@c_estado">
					<qry:case value="An&#225;lisis de Resoluci&#243;n">
						<qry:attribute name="c_estado" value="'RES'"/>
					</qry:case>
					<qry:case value="A Clasificar">
						<qry:attribute name="c_estado" value="'CLA'"/>
					</qry:case>
					<qry:case value="Derivado">
						<qry:attribute name="c_estado" value="'DER'"/>
					</qry:case>
					<qry:case value="En espera de conformidad">
						<qry:attribute name="c_estado" value="'CON'"/>
					</qry:case>
				</qry:switch>
				<qry:attribute name="criticidad" value="$r/DATOS/RECLAMO/@n_criticidad"/>
				<qry:attribute name="f_reclamo" value="$r/DATOS/RECLAMO/@f_reclamo"/>
				<qry:attribute name="f_vencimiento" value="format_date($r/DATOS/RECLAMO/@f_vencimiento, 'dd/mm/yyyy')"/>
				<qry:attribute name="diff" value="normalize_space(format_number(ceiling(datetime($r/DATOS/RECLAMO/@f_vencimiento))-floor(now()), '##0'))"/>
				<qry:attribute name="diff" value="iif(starts_with(@diff, '-'), 0, @diff)"/>
				<qry:insert-select doc-path="" name="GET_FECHA"/>
				<qry:attribute name="valor_param" value="@d_valor"/>
				<qry:attribute name="background" value="'#84F464'"/>
				<qry:attribute name="background" value="iif(@diff &lt; @d_valor, '#FFFF60', @background )"/>
				<qry:attribute name="background" value="iif(@diff = 0, '#FF6060', @background )"/>
				<qry:attribute name="oi_tipo_problema" value="$r/DATOS/RECLAMO/@oi_tipo_problema"/>
				<qry:attribute name="oi_modulo" value="$r/DATOS/RECLAMO/@oi_modulo"/>
				<qry:switch test="$r/DATOS/RECLAMO/@n_criticidad">
					<qry:default>
						<qry:attribute name="n_criticidad" value="'-'"/>
					</qry:default>
					<qry:case value="1">
						<qry:attribute name="n_criticidad" value="'Muy Baja'"/>
					</qry:case>
					<qry:case value="2">
						<qry:attribute name="n_criticidad" value="'Baja'"/>
					</qry:case>
					<qry:case value="3">
						<qry:attribute name="n_criticidad" value="'Normal'"/>
					</qry:case>
					<qry:case value="4">
						<qry:attribute name="n_criticidad" value="'Alta'"/>
					</qry:case>
					<qry:case value="5">
						<qry:attribute name="n_criticidad" value="'Muy Alta'"/>
					</qry:case>
				</qry:switch>
				<qry:attribute name="c_asunto" value="$r/DATOS/RECLAMO/@c_asunto"/>
				<qry:insert-select name="resolve_etapa" doc-path="$r/HISTETAPAS/HISTETAPA[@ACTIVO = '1']"/>
				<qry:attribute name="f_reclamo" value="format_date($r/@F_INICIO, 'dd/mm/yyyy HH:MM')"/>
				<qry:attribute name="f_order" value="$r/@F_INICIO"/>
				<qry:insert-select name="ENTIDAD" doc-path="$r/DUENO"/>
			</qry:out>
		</qry:select>
		<qry:select name="CONFIG" doc="DOC">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Workflow\\WorkflowConfig\\{%=#PROXY:@app%}.NucleusRH.Base.QuejasyReclamos.Reclamo.WF.XML')/WF
			</qry:xquery>
			<qry:out>
				<qry:append-doc name="CONF" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="resolve_etapa" doc="DOC">
			<qry:out>
				<qry:attribute name="cod" value="#DOC:@COD"/>
				<qry:attribute name="f_ult_estado" value="format_date(#DOC:@F_INICIO, 'dd/mm/yyyy HH:MM')"/>
				<qry:insert-select name="get_desc_etapa" doc-path="#CONF:ETAPAS/ETAPA[@COD=#DOC:@cod]"/>
			</qry:out>
		</qry:select>
		<qry:select name="get_desc_etapa" doc="DOC">
			<qry:out>
				<qry:attribute name="cod" value="#DOC:@DES"/>
			</qry:out>
		</qry:select>
		<qry:select name="ENTIDAD" doc="DOC">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Login\\Entidades\\{%=#DOC:@VALUE %}.ENTIDAD.XML')/ENTIDAD
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_usuario" value="$r/@DES"/>
				<qry:attribute name="usuario" value="#DOC:@VALUE"/>
			</qry:out>
		</qry:select>
		<qry:select name="sql5" doc="DOC">
			<qry:xquery>
				for $r in #DOC:TAREA[1=1
			{%? (string(#ENTRADA:@oi_reclamo) !='') 
				{% AND @oi_reclamo = #ENTRADA:@oi_reclamo %} 
				{%  %} 
			%} 
			{%? (string(#ENTRADA:@n_criticidad) !='') 
				{% AND @criticidad = #ENTRADA:@n_criticidad %} 
				{%  %} 
			%} 
			{%? (string(#ENTRADA:@oi_tipo_problema) !='') 
				{% AND @oi_tipo_problema = #ENTRADA:@oi_tipo_problema %} 
				{%  %} 
			%} 
			{%? (string(#ENTRADA:@oi_modulo) !='') 
				{% AND @oi_modulo =  #ENTRADA:@oi_modulo %} 
				{%  %} 
			%}
			{%? (string(#ENTRADA:@c_estado) !='') 
				{% AND @c_estado = #ENTRADA:@c_estado %} 
				{%  %} 
			%} 
			{%? (string(#ENTRADA:@f_desde) !='') 
				{% AND @f_order &gt; #ENTRADA:@f_desde %} 
				{%  %} 
			%}
			{%? (string(#ENTRADA:@f_hasta) !='') 
				{% AND @f_order &lt; #ENTRADA:@f_hasta %} 
				{%  %} 
			%}         
			{%? (string(#ENTRADA:@d_usuario) !='') 
				{% AND @usuario = #ENTRADA:@d_usuario %} 
				{%  %} 
			%}
			{%? (string(#ENTRADA:@c_asunto) !='') 
				{% AND contains(upper_case(@c_asunto), upper_case(#ENTRADA:@c_asunto)) %} 
				{%  %} 
			%}
						
			{%? (string(#ENTRADA:@t_reclamo) !='') 
				{% AND contains(upper_case(@t_reclamo), upper_case(#ENTRADA:@t_reclamo))  %} 
				{%  %} 
			%}]
			ORDERBY $r/@f_order DESC
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="GET_FECHA">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ORG26_PARAMETROS.d_valor 
				FROM 
					ORG26_PARAMETROS 
				WHERE 
					ORG26_PARAMETROS.c_modulo = \'QYR\' 
					AND ORG26_PARAMETROS.c_parametro = \'PROX_VTO\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_valor" value="$r/@d_valor"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="/TAREAS_ASIGNADAS">
			<html>
				<head>
					<script languaje="javascript">
						function openReclamo(url, entrada, wfid, etapa, app) {    
						if(entrada != "flow")
							window.open(url, '', 'channelmode=no,directories=no,fullscreen=no,location=no,menubar=no,resizable=yes,scrollbars=yes,status=no,titlebar=no,toolbar=no,left=0,top=0,width='+(screen.width-12)+',height='+(screen.height-60)); 
						else    
						  parent.openNewFlow("NucleusRH.Base.QuejasyReclamos.Workflow.Reclamo.autoflow","GET-WF",String.fromCharCode(60)+'DATA WFI="'+wfid+'" Etapa="' +etapa+ '" WF="'+app+'.NucleusRH.Base.QuejasyReclamos.Reclamo" /'+String.fromCharCode(62),new ObjetoActualizador(),"L");
					} 
				 	function ObjetoActualizador() {
				 		this.processResult = function(){
				 			parent.Ctrl('REFRESH').DoEvent('onclick');
				 		}
				 	}
					</script>
					<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
					<style media="screen">
						body {
          font-family:verdana;
          font-weight:normal;
          background-color:#FFFFFF;
          font-size:11px;
          margin:30px;   
          cursor:default;
          PADDING-RIGHT: 0px; 
          PADDING-LEFT: 0px; 
          PADDING-BOTTOM: 0px; 
          MARGIN: 0px; 
          BORDER-TOP-STYLE: none; 
          PADDING-TOP: 0px; 
          BORDER-RIGHT-STYLE: none; 
          BORDER-LEFT-STYLE: none; 
          BORDER-BOTTOM-STYLE: none;
          }

          .title {
          font-size:15px;
          font-weight:bold;}

          .table_table_style {
          border: none;
          border-collapse: collapse;
          background-color:#FFFFFF;
          font-size: 11px;
          font-family: verdana;
          width:100%;}

          .table_title_style {
          
          font-family:verdana;
          background-color:#FFFFFF;
          font-size:14px;
          font-weight:normal;
          text-align:center;
          width:100%;}

          .group_td {
          padding-left:30px; }

          .coll_img {
          padding:0px; margin:0px;
          font-weight:bold;
          text-align:center;
          cursor:pointer;
          
          font-size:8px;
          width:12px;
          height:12px;}

          .table_span_style {
          font-weight:bold;

          }

          tfoot {
          font-weight:bold;
          }

          .stitle {
          width:100%;
          background-color:#FFFFFF;
          }
          
          .divmarco {
          
          
          
          background-color:white;
          margin:0px; 
          padding:20px;
          width:100%;
          height:100%}
 
          .scontent {
          width:100%;
          aheight:100%;
          background-color:#FFFFFF; }
					</style>
					<style media="print">
						body {
					font-family:verdana;
					font-weight:normal; 
					background-color:white; 
					font-size:8pt;
					width:20cm;}
					
					.titulo {
					font-size:11pt;
					font-weight:bold;}
					
					.table_table_style {
					border: none; 
					border-collapse: collapse; 
					font-size: 8pt; 
					font-family: verdana;
					width:100%;}
					
					.table_title_style {
					
					font-family:verdana;
					font-size:9pt;
					font-weight:normal;
					width:100%;}
					</style>
					<style media="all">
						.table_table_style td {
					border: solid 1px black; 
					padding-left: 3px; 
					padding-right: 3px;
					text-align: left;}
					
					.table_table_style td#num{
					mso-number-format:0.00;
					text-align:right;}
					
					.table_table_style th {
					border:solid 1px black;
					background-color:#BBBBBB; 
					border-bottom:solid 2px black;
					padding-left: 3px; 
					padding-right: 3px;
					text-align: center;}
					</style>
				</head>
				<body style="PADDING-RIGHT: 0px; PADDING-LEFT: 0px; PADDING-BOTTOM: 0px; MARGIN: 0px; BORDER-TOP-STYLE: none; PADDING-TOP: 0px; BORDER-RIGHT-STYLE: none; BORDER-LEFT-STYLE: none; BORDER-BOTTOM-STYLE: none;" scroll="yes">
					<xsl:if test="TAREA">
						<table class="table_title_style" border="0">
							<tr>
								<td colspan="2">
									<table VALIGN="top" class="table_table_style" cellspacing="0" cellpadding="0" border="0" style="width:100%">
										<thead style="display: table-header-group;">
											<span class="table_span_style"/>
											<tr>
												<th>
													Nro. Reclamo
												</th>
												<th>
													Asunto
												</th>
												<th>
													Usuario
												</th>
												<th>
													Fecha - Hora Creaci&#243;n
												</th>
												<th>
													Fecha de Vencimiento
												</th>
												<th>
													D&#237;as para Resolver
												</th>
												<th>
													Estado
												</th>
												<th>
													Fecha - Hora Ultimo Estado
												</th>
												<th>
													Criticidad
												</th>
											</tr>
										</thead>
										<tbody>
											<xsl:apply-templates select="TAREA"/>
										</tbody>
									</table>
								</td>
							</tr>
						</table>
						<br/>
					</xsl:if>
					<xsl:if test="NO_TAREA">
						<tr>
							<td colspan="2">
								<br/>
								<h3 align="center">
									No tiene Reclamos Pendientes
								</h3>
							</td>
						</tr>
						<br/>
					</xsl:if>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="TAREA">
			<tr>
				<xsl:attribute name="onclick">
					<xsl:value-of select="concat('javascript:openReclamo(&quot;', @url, '&quot;,&quot;', @entrada,'&quot;,&quot;', @wfid,'&quot;,&quot;', @etapa,'&quot;,&quot;', @app,'&quot;)')"/>
				</xsl:attribute>
				<td style="cursor:pointer;">
					<xsl:value-of select="@oi_reclamo"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@c_asunto"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@d_usuario"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@f_reclamo"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@f_vencimiento"/>
				</td>
				<td style="cursor:pointer;text-align:right;">
					<xsl:attribute name="bgcolor">
						<xsl:value-of select="@background"/>
					</xsl:attribute>
					<xsl:value-of select="@diff"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@cod"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@f_ult_estado"/>
				</td>
				<td style="cursor:pointer;">
					<xsl:value-of select="@n_criticidad"/>
				</td>
			</tr>
		</xsl:template>
	</html:xslt>
</html:html>
