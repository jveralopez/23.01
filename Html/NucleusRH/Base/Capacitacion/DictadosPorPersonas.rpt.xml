		<qry:main doc="PARAM">
			<qry:append-doc name="PARAMIN" doc-path="#PARAM:FILTRO"/>
			<REPORT label="Capacitaciones otorgadas al Personal">
				<qry:attribute value="format_date(now(),'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP style="width:100%" tag="DATOS" type="title">
						<COLS>
							<qry:if test="#PARAM:FILTRO/@oi_empresa!=''">
								<qry:then>
									<COL name="d_empresa" label="Empresa"/>
								</qry:then>
							</qry:if>
							<qry:if test="#PARAM:FILTRO/@oi_area!=''">
								<qry:then>
									<COL name="area" label="&#193;rea de Curso"/>
								</qry:then>
							</qry:if>
							<COL name="f_desde" label="Fecha Desde" type="date"/>
							<COL name="f_hasta" label="Fecha Hasta" type="date"/>
						</COLS>
						<GROUP tag="DICTADO" type="table">
							<COLS>
								<qry:if test="#PARAM:FILTRO/@oi_empresa=''">
									<qry:then>
										<COL name="empresa" label="Empresa" nowrap="1"/>
									</qry:then>
								</qry:if>
								<COL name="legajo" label="Legajo" nowrap="1"/>
								<COL name="d_ape_y_nom" label="Apellido y Nombre" nowrap="1"/>
								<COL name="area" label="&#193;rea de Curso" nowrap="1"/>
								<COL name="c_curso" label="C&#243;digo de Curso" nowrap="1"/>
								<COL name="d_curso" label="T&#237;tulo de Curso" nowrap="1"/>
								<COL name="c_dictado" label="C&#243;digo Dictado" nowrap="1"/>
								<COL name="d_dictado" label="Nombre Dictado" nowrap="1"/>
								<COL name="docente" label="Instructor/es" nowrap="1"/>
								<COL name="f_inicio" label="Fecha Inicio" style="text-align:center" nowrap="1" type="date"/>
								<COL name="f_fin" label="Fecha Fin" style="text-align:center" nowrap="1" type="date"/>
								<COL name="horas" label="Horas" style="text-align:right"/>
								<qry:if test="#PARAM:FILTRO/@chkPuestoActual = '1'">
									<qry:then>
										<COL name="d_puesto" label="Puesto Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<qry:if test="#PARAM:FILTRO/@chkPosicionActual = '1'">
									<qry:then>
										<COL name="d_posicion" label="Posici&#243;n Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<qry:if test="#PARAM:FILTRO/@chkCtroCostoActual = '1'">
									<qry:then>
										<COL name="d_centro_costo" label="Centro de Costo Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<qry:if test="#PARAM:FILTRO/@chkUbicacionActual = '1'">
									<qry:then>
										<COL name="d_ubicacion" label="Ubicaci&#243;n Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<qry:if test="#PARAM:FILTRO/@chkSectorActual = '1'">
									<qry:then>
										<COL name="d_sector" label="Sector Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<qry:if test="#PARAM:FILTRO/@chkDepartamentoActual = '1'">
									<qry:then>
										<COL name="d_departamento" label="Departamento Actual" style="text-align:center" nowrap="1"/>
									</qry:then>
								</qry:if>
								<COL name="e_min_asistencia" label="Porcentaje Asistencia M&#237;nimo" style="text-align:center" nowrap="1"/>
								<COL name="n_asistencia" label="Porcentaje de asistencia" style="text-align:center" nowrap="1"/>
								<COL name="estado" label="Estado" style="text-align:center" nowrap="1"/>
								<COL name="evaluacion" label="Evaluaci&#243;n" style="width:80px;">
									<OPT id="NE" value="No Evaluado"/>
									<OPT id="A" value="Aprobado"/>
									<OPT id="R" value="Reprobado"/>
								</COL>
								<COL name="eval_dictado" label="Evaluaci&#243;n del dictado" style="text-align:center" nowrap="1"/>
								<COL name="n_hs_activas" label="Total de Horas Activas" style="text-align:center" nowrap="1"/>
								<COL name="c_estructura" label="Estructura Organizativa Solicitante" style="text-align:center" nowrap="1"/>
								<COL name="n_costo_uni" label="Costo Unitario" style="text-align:center" nowrap="1"/>
								<COL name="n_costo_total" label="Costo Total" style="text-align:center" nowrap="1"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="DATOS">
						<qry:attribute name="qry-orderby" value="'ord'"/>
						<qry:attribute name="oi_empresa" value="#PARAM:FILTRO/@oi_empresa"/>
						<qry:attribute name="oi_area" value="#PARAM:FILTRO/@oi_area"/>
						<qry:attribute name="f_desde" value="format_date(#PARAM:FILTRO/@f_desde,'dd/mm/yyyy')"/>
						<qry:attribute name="f_hasta" value="format_date(#PARAM:FILTRO/@f_hasta,'dd/mm/yyyy')"/>
						<qry:attribute value="format_date(now(),'dd/mm/yyyy')" name="f_informe"/>
						<qry:insert-select doc-path="#PARAM:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_EMPRESA"/>
						<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_AREA"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<FILTRO>
						<qry:attribute name="chkPuestoActual" value="#PARAMIN:@chkPuestoActual"/>
						<qry:attribute name="chkPosicionActual" value="#PARAMIN:@chkPosicionActual"/>
						<qry:attribute name="chkDepartamentoActual" value="#PARAMIN:@chkDepartamentoActual"/>
						<qry:attribute name="chkSectorActual" value="#PARAMIN:@chkSectorActual"/>
						<qry:attribute name="chkCtroCostoActual" value="#PARAMIN:@chkCtroCostoActual"/>
						<qry:attribute name="chkUbicacionActual" value="#PARAMIN:@chkUbicacionActual"/>
						<qry:attribute name="oi_empresa" value="#PARAMIN:@oi_empresa"/>
						<qry:attribute name="oi_area" value="#PARAMIN:@oi_area"/>
						<qry:attribute name="orden" value="#PARAMIN:@orden"/>
						<qry:attribute name="f_desde" value="#PARAMIN:@f_desde"/>
						<qry:attribute name="f_hasta" value="#PARAMIN:@f_hasta"/>
						<qry:attribute name="l_asistencia" value="#PARAMIN:@l_asistencia"/>
						<qry:attribute value="#PARAM:@values" name="values"/>
					</FILTRO>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_EMPRESA">
			<qry:xquery>
				for $r in sql('
			SELECT 
				ORG03_EMPRESAS.d_empresa
			FROM 
				ORG03_EMPRESAS
			WHERE	
				ORG03_EMPRESAS.oi_empresa = {#PARAM:@oi_empresa}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_AREA">
			<qry:xquery>
				for $r in sql('		
			SELECT 
				P.c_curso, 
				P.d_curso
			FROM 
				ORG06_CURSOS as P
			WHERE 
				P.oi_curso = {#PARAM:@oi_area}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="area" value="$r/@c_curso + ' - ' + $r/@d_curso"/>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;FILTRO values=&quot;1436,1437,8,41,33,27,46,15,1426,29,11,74,20,10,78,86,1424,42,63,40,31,69,95,73,35,98,28,94,66,89,5,81,2,32,1429,39,61,50,47,72,1428,45,97,161,49,48,1430,4,88,210,25,58,190,77,134,113,203,236,7,14,212,34,175,137,140,145,186,64,30,24,214,157,149,213,195,12,119,106,122,120,142,144,1438,141,129,201,90,57,21,121,196,248,132,111,199,155,1427,93,208,1&quot; f_hasta=&quot;20241119&quot; f_desde=&quot;20230101&quot; oi_empresa=&quot;1&quot;/&gt;&#13;&#10;">
		<qry:main doc="PARAM">
			<qry:no-show>
				<qry:attribute name="hts:delete" value="1"/>
				<qry:append-doc name="FILTRO" doc-path="#PARAM:FILTRO"/>
				<qry:insert-select doc-path="#PARAM:FILTRO" name="QRY_DICTADOS"/>
			</qry:no-show>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_DICTADOS">
			<qry:xquery>
				for $r in sql('
				SELECT                    
					CYD02_DICTADOS.oi_dictado as oi_dictado,
					{%?(#FILTRO:@chkPosicionActual ='1') {% max(ORG04_POSICIONES.oi_sector) as oi_sector, %} {% %} %}				
					max(CYD02_DICTADOS.c_dictado) as c_dictado,
					max(CYD02_DICTADOS.d_dictado) as d_dictado, 
					max(CYD02_DICTADOS.f_inicio) as f_inicio,  
					max(CYD02_DICTADOS.f_fin) as f_fin,
					max(CYD02_DICTADOS.n_duracion_hs) as n_duracion_hs, 				 
					max(PER01_PERSONAL.d_ape_y_nom) as d_ape_y_nom, 
					max(PER02_PERSONAL_EMP.e_numero_legajo) as e_numero_legajo,
				    PER02_PERSONAL_EMP.oi_personal_emp as oi_personal_emp,
					max(ORG03_EMPRESAS.c_empresa) as c_empresa,
					max(ORG03_EMPRESAS.d_empresa) as d_empresa,
					max(CYD01_CURSOS.c_curso) as c_curso,
					max(CYD01_CURSOS.d_curso) as d_curso,
					max(ORG06_CURSOS.d_curso) as area,
					max(CYD02_DICTADOS.e_min_asistencia) as e_min_asistencia,
					max(CYD02_INSCRIPTOS.n_asistencia) as n_asistencia,
					max(CYD02_INSCRIPTOS.oi_inscripto) as oi_inscripto,
					max(CYD02_INSCRIPTOS.n_hs_activas) as n_hs_activas,
					max(ORG01_UNI_ORG.c_unidad_org) as c_unidad_org,
					max(ORG01_UNI_ORG.d_unidad_org) as d_unidad_org,
					max(CYD14_VALORES.c_valor) as eval_dictado,
					max(CYD14_VALORES.d_valor) as desc_eval,
					max(CYD02_INSCRIPTOS.c_estado_aprob) as c_estado_aprob,
					{%?(#FILTRO:@chkPuestoActual ='1') {% max(ORG04_PUESTOS.d_puesto) as d_puesto, %} {% %} %}	
					{%?(#FILTRO:@chkPosicionActual ='1') {% max(ORG04_POSICIONES.d_posicion) as d_posicion, %} {% %} %}
					{%?(#FILTRO:@chkCtroCostoActual ='1') {% max(ORG08_CS_COSTO.d_centro_costo) as d_centro_costo, %} {% %} %}					
					{%?(#FILTRO:@chkUbicacionActual ='1') {% max(ORG03_UBICACIONES.d_ubicacion) as d_ubicacion, %} {% %} %}					
					{%?(#FILTRO:@chkSectorActual ='1') {% max(ORG51_SECTORES.d_sector) as d_sector, %} {% %} %}					
					{%?(#FILTRO:@chkDepartamentoActual ='1') {% max(ORG51_DEPARTAMENTOS.d_departamento) as d_departamento, %} {% %} %}
					max(CYD02_CTOS_DICTADO.n_costo_total) as n_costo_total,
					max(CYD02_CTOS_DICTADO.n_costo_uni) as n_costo_uni
				FROM 
					CYD02_INSCRIPTOS, 
					CYD02_DICTADOS,
					PER01_PERSONAL, 
					PER02_PERSONAL_EMP,
					ORG03_EMPRESAS,
					CYD01_CURSOS,
					ORG06_CURSOS,
					ORG02_ESTRUCTURAS,
					ORG01_UNI_ORG,
					CYD02_CTOS_DICTADO,
					CYD02_EVAL_DICT,
					CYD14_VALORES,
					ORG04_POSICIONES
					{%? (#FILTRO:@chkPuestoActual ='1'){%  ,ORG04_PUESTOS %} {%  %} %}                    
					{%? (#FILTRO:@chkCtroCostoActual ='1'){%  ,ORG08_CS_COSTO %} {%  %} %}
					{%? (#FILTRO:@chkUbicacionActual ='1'){%  ,ORG03_UBICACIONES %} {%  %} %}
					{%? (#FILTRO:@chkSectorActual ='1'){%  ,ORG51_SECTORES %} {%  %} %}
					{%? (#FILTRO:@chkDepartamentoActual ='1'){%  ,ORG51_DEPARTAMENTOS %} {%  %} %}		
				JOIN 
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
					PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
					CYD02_INSCRIPTOS.oi_dictado INNER CYD02_DICTADOS.oi_dictado,
					PER02_PERSONAL_EMP.oi_personal_emp INNER CYD02_INSCRIPTOS.oi_personal_emp,
					CYD01_CURSOS.oi_curso INNER CYD02_DICTADOS.oi_curso,
					CYD01_CURSOS.oi_area INNER ORG06_CURSOS.oi_curso,
					CYD02_DICTADOS.oi_estructura LEFT OUTER ORG02_ESTRUCTURAS.oi_estructura,
					ORG02_ESTRUCTURAS.oi_unidad_org LEFT OUTER ORG01_UNI_ORG.oi_unidad_org,  
				    CYD02_DICTADOS.oi_dictado LEFT OUTER CYD02_CTOS_DICTADO.oi_dictado,
				    CYD02_DICTADOS.oi_dictado LEFT OUTER CYD02_EVAL_DICT.oi_dictado,
				    CYD14_VALORES.oi_valor RIGHT OUTER CYD02_EVAL_DICT.oi_valor	    
				    {%? (#FILTRO:@chkPuestoActual ='1'){%  ,PER02_PERSONAL_EMP.oi_puesto_ult LEFT OUTER ORG04_PUESTOS.oi_puesto %} {%  %} %}
				    {%? (#FILTRO:@chkCtroCostoActual ='1'){%  ,PER02_PERSONAL_EMP.oi_ctro_costo_ult LEFT OUTER ORG08_CS_COSTO.oi_centro_costo %} {%  %} %}
				    {%? (#FILTRO:@chkUbicacionActual ='1'){%  ,PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER ORG03_UBICACIONES.oi_ubicacion %} {%  %} %}
				    
				    {%? (#FILTRO:@chkPosicionActual ='1' OR #FILTRO:@chkDepartamentoActual ='1' OR #FILTRO:@chkSectorActual ='1' ){%   ,PER02_PERSONAL_EMP.oi_posicion_ult LEFT OUTER ORG04_POSICIONES.oi_posicion %} {%  %} %}
				     
				    {%? (#FILTRO:@chkSectorActual ='1'){%   ,ORG04_POSICIONES.oi_sector LEFT OUTER ORG51_SECTORES.oi_sector %} {%  %} %} 
				       
				    {%? (#FILTRO:@chkDepartamentoActual ='1'){%  ,ORG04_POSICIONES.oi_departamento LEFT OUTER ORG51_DEPARTAMENTOS.oi_departamento %} {%  %} %}  
				WHERE     
					PER02_PERSONAL_EMP.oi_personal_emp in ({%=#FILTRO:@values%})
					AND PER02_PERSONAL_EMP.oi_personal_emp = CYD02_INSCRIPTOS.oi_personal_emp
					AND CYD02_DICTADOS.f_inicio &lt; {Datetime(#FILTRO:@f_hasta)}
  					AND CYD02_DICTADOS.f_fin &gt;= {Datetime(#FILTRO:@f_desde)}
  				{%? (#FILTRO:@oi_empresa!='')        
  					{% 	AND ORG03_EMPRESAS.oi_empresa = {#FILTRO:@oi_empresa} %}
  					{%  %}                     
 					%}
 					{%? (#FILTRO:@oi_area!='')        
  					{% 	AND CYD01_CURSOS.oi_area = {#FILTRO:@oi_area} %}
  					{%  %}                     
 					%}
 				GROUP BY CYD02_DICTADOS.oi_dictado, PER02_PERSONAL_EMP.oi_personal_emp
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DICTADO">
					<qry:attribute name="ord" value="nmd_right('0000000000' + $r/@c_empresa, 10) + nmd_right('0000000000' + $r/@e_numero_legajo, 10) + format_date($r/@f_inicio,'yyyymmdd')"/>
					<qry:attribute name="legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="empresa" value="$r/@c_empresa + ' - ' + $r/@d_empresa"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="c_dictado" value="$r/@c_dictado"/>
					<qry:attribute name="d_dictado" value="$r/@d_dictado"/>
					<qry:attribute name="c_curso" value="$r/@c_curso"/>
					<qry:attribute name="d_curso" value="$r/@d_curso"/>
					<qry:attribute name="area" value="$r/@area"/>
					<qry:attribute name="oi_dictado" value="$r/@oi_dictado"/>
					<qry:attribute name="f_fin" value="format_date($r/@f_fin,'dd/mm/yyyy')"/>
					<qry:attribute name="f_inicio" value="format_date($r/@f_inicio,'dd/mm/yyyy')"/>
					<qry:attribute name="horas" value="iif($r/@n_duracion_hs !='', format_number($r/@n_duracion_hs, '#####.00'), '')"/>
					<qry:attribute name="c_estructura" value="iif($r/@c_unidad_org != '' and $r/@d_unidad_org != '',concat('[',$r/@c_unidad_org,'] ',$r/@d_unidad_org),'')"/>
					<qry:attribute name="n_costo_total" value="iif($r/@n_costo_total != '', format-number($r/@n_costo_total,0,2,',','.',''),'')"/>
					<qry:attribute name="n_costo_uni" value="iif($r/@n_costo_uni != '', format-number($r/@n_costo_uni,0,2,',','.',''),'')"/>
					<qry:insert-select name="QRY_DOCENTES" doc-path="$r"/>
					<qry:attribute name="e_min_asistencia" value="$r/@e_min_asistencia"/>
					<qry:attribute name="eval_dictado" value="$r/@eval_dictado+ '-' + $r/@desc_eval"/>
					<qry:attribute name="evaluacion" value="$r/@c_estado_aprob"/>
					<qry:attribute name="d_puesto" value="$r/@d_puesto"/>
					<qry:attribute name="d_posicion" value="$r/@d_posicion"/>
					<qry:attribute name="d_centro_costo" value="$r/@d_centro_costo"/>
					<qry:attribute name="d_ubicacion" value="$r/@d_ubicacion"/>
					<qry:attribute name="d_sector" value="$r/@d_sector"/>
					<qry:attribute name="d_departamento" value="$r/@d_departamento"/>
					<qry:attribute name="oi_sector" value="$r/@oi_sector"/>
					<!-- Query para saber la cantidad de clases asignadas del dictado-->
					<qry:insert-select name="QRY_CLASES_DICTADO" doc-path="$r"/>
					<!-- Para el valor de las hs_activas y n_asistencia -->
					<!-- Si el dictado no tiene clases; se considera que asistio, por lo tanto el porcentaje de asistencia es 100% -->
					<qry:if test="@cantidad!='0'">
						<qry:then>
							<qry:attribute name="n_asistencia" value="$r/@n_asistencia"/>
							<qry:attribute name="n_hs_activas" value="iif($r/@n_hs_activas ='' or $r/@n_hs_activas ='0','0.00',format_number($r/@n_hs_activas, '#####.00'))"/>
						</qry:then>
						<qry:else>
							<!-- Solo si el dictado no tiene clases, la cantidad = cero -->
							<!-- No se puede evaluar asistencia si el dictado no tiene clases - n_asistencia es null -->
							<qry:attribute name="n_asistencia" value="iif($r/@n_asistencia ='','100', $r/@n_asistencia)"/>
							<qry:attribute name="n_hs_activas" value="iif($r/@n_duracion_hs !='', format_number($r/@n_duracion_hs, '#####.00'), '')"/>
						</qry:else>
					</qry:if>
					<qry:if test="$r/@e_min_asistencia!=''">
						<!--Pregunto si el minimo esta definido-->
						<qry:then>
							<!--<qry:attribute name="estado" value="iif(number(@n_asistencia) &gt;= number($r/@e_min_asistencia), 'Asisti&#243;', 'No Asisti&#243;')"/>-->
							<qry:attribute name="estado" value="iif(number(@n_asistencia) &gt; '0' , iif(number(@n_asistencia) &lt;= '99' and number(@n_asistencia) &gt; '0' , 'Parcial', 'Asisti&#243;'), 'No Asisti&#243;')"/>
						</qry:then>
						<qry:else>
							<!--si no esta definido el minimo, pregunto si el dictado tiene clases-->
							<qry:if test="@cantidad!='0'">
								<!--si tiene clases, pregunto si el inscripto asistio o no a alguna clase-->
								<qry:then>
									<qry:insert-select name="QRY_ASISTENCIA" doc-path="$r"/>
									<qry:attribute name="estado" value="iif(number(@n_asistencia) &gt; '0' , iif(number(@n_asistencia) &lt;= '99' and number(@n_asistencia) &gt; '0' , 'Parcial', 'Asisti&#243;'), 'No Asisti&#243;')"/>
								</qry:then>
								<qry:else>
									<qry:attribute name="estado" value="'Asisti&#243;'"/>
								</qry:else>
							</qry:if>
						</qry:else>
					</qry:if>
					<qry:if test="#FILTRO:@l_asistencia='1'">
						<qry:then>
							<qry:attribute name="hts:delete" value="iif(./@estado='Asisti&#243;','0', '1')"/>
						</qry:then>
						<qry:else/>
					</qry:if>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_DOCENTES">
			<qry:xquery>
				for $r in sql('
				SELECT 
					CYD04_DOCENTES.d_ape_y_nom
				FROM 					        
					CYD02_DOC_DICTADO,
					CYD04_DOCENTES,
					CYD02_DICTADOS
				JOIN                  
					CYD02_DICTADOS.oi_dictado INNER CYD02_DOC_DICTADO.oi_dictado, 
					CYD02_DOC_DICTADO.oi_docente INNER CYD04_DOCENTES.oi_docente
				WHERE	
					CYD02_DICTADOS.oi_dictado = {#PARAM:@oi_dictado} 
					AND CYD02_DICTADOS.f_inicio &lt; {Datetime(#FILTRO:@f_hasta)}
  				AND CYD02_DICTADOS.f_fin &gt;= {Datetime(#FILTRO:@f_desde)}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="docente" value="@docente + iif(@docente != '', ' / ','') + $r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CLASES_DICTADO" doc="PARAM">
			<qry:xquery>
				for $r in sql('
			SELECT COUNT(CYD02_CLASES_DICT.oi_clase_dictado) as CantidadClases
			FROM CYD02_CLASES_DICT
			WHERE CYD02_CLASES_DICT.oi_dictado = {#PARAM:@oi_dictado}
			')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cantidad" value="$r/@CantidadClases"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_ASISTENCIA" doc="PARAM">
			<qry:xquery>
				for $r in sql('
		
			SELECT 
				COUNT(CYD02_ASIST_CLASE.oi_asist_clase) as c_asistencia   				
			FROM 
				CYD02_CLASES_DICT,
				CYD02_ASIST_CLASE
			JOIN 
				CYD02_CLASES_DICT.oi_clase_dictado INNER CYD02_ASIST_CLASE.oi_clase_dictado
			WHERE 
				CYD02_CLASES_DICT.oi_dictado={#PARAM:@oi_dictado} 
				and CYD02_ASIST_CLASE.oi_inscripto={#PARAM:@oi_inscripto}
			
			')ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="asistencia" value="$r/@c_asistencia"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
