<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" extends="Nomad.base.basereport.rpt" doc="source" name="NucleusRH.Base.Personal.Dictados_personal">
	<html:query declare="&lt;DATOS oi_personal_emp=&quot;233&quot;/&gt;">
		<qry:main doc="SOURCE">
			<REPORT label="Cursos Realizados">
				<qry:attribute value="format_date(now(), 'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="EMP" type="title">
						<COLS>
							<COL name="d_empresa" label="Empresa"/>
							<COL name="legajo" label="Legajo"/>
						</COLS>
						<GROUP tag="DIC" label="Dictados" type="table">
							<COLS>
								<COL name="d_dictado" label="Curso" style="width:35%;"/>
								<COL name="d_curso" label="&#193;rea o Tema" style="width:25%;"/>
								<COL name="f_inicio" label="Inicio" style="text-align:center; width:10%;" type="date"/>
								<COL name="f_fin" label="Fin" style="text-align:center; width:10%;" type="date"/>
								<COL name="c_estado" label="Estado" style="text-align:center; width:12%;">
									<OPT id="NE" value="No Evaluado"/>
									<OPT id="A" value="Aprobado"/>
									<OPT id="R" value="Reprobado"/>
								</COL>
								<COL name="n_asistencia" label="Asistencia" style="text-align:center; width:8%;"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<EMP>
						<qry:insert-select name="qry_persona" doc-path="#SOURCE:DATOS"/>
						<qry:insert-select name="qry_dictado" doc-path="#SOURCE:DATOS"/>
					</EMP>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_persona">
			<qry:xquery>
				for $r in sql('
				SELECT PER01_PERSONAL.d_ape_y_nom, PER02_PERSONAL_EMP.e_numero_legajo,
				ORG03_EMPRESAS.d_empresa, {%=string(Now())%} as f_emision
				FROM PER01_PERSONAL, PER02_PERSONAL_EMP, ORG03_EMPRESAS
				JOIN 
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
				PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_emision" value="format_date($r/@f_emision, 'dd/mm/yyyy')"/>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="legajo" value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_dictado">
			<qry:xquery>
				for $r in sql('
				SELECT CYD02_DICTADOS.d_dictado, CYD02_INSCRIPTOS.c_estado_aprob,
				CYD02_INSCRIPTOS.n_asistencia,
				CYD02_DICTADOS.f_fin,CYD02_DICTADOS.f_inicio, ORG06_CURSOS.d_curso
				FROM CYD02_INSCRIPTOS, CYD02_DICTADOS, ORG06_CURSOS, CYD01_CURSOS				
				JOIN CYD02_INSCRIPTOS.oi_dictado INNER CYD02_DICTADOS.oi_dictado,
				CYD01_CURSOS.oi_curso INNER CYD02_DICTADOS.oi_curso,
				ORG06_CURSOS.oi_curso INNER CYD01_CURSOS.oi_area
				WHERE CYD02_INSCRIPTOS.oi_personal_emp = {#SOURCE:@oi_personal_emp}
				ORDER BY f_fin ASC
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="DIC">
					<qry:attribute name="d_dictado" value="$r/@d_dictado"/>
					<qry:attribute name="c_estado" value="$r/@c_estado_aprob"/>
					<qry:attribute name="d_curso" value="$r/@d_curso"/>
					<qry:attribute name="f_fin" value="format_date($r/@f_fin,'dd/mm/yyyy')"/>
					<qry:attribute name="f_inicio" value="format_date($r/@f_inicio,'dd/mm/yyyy')"/>
					<qry:attribute name="n_asistencia" value="format_number($r/@n_asistencia, '##0%')"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
