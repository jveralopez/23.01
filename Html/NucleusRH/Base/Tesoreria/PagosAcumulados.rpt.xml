<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tesoreria.PagosAcumulados" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:query declare="&lt;DATOS e_periodo_des=&quot;201201&quot; e_periodo_has=&quot;201212&quot; oi_empresa=&quot;164&quot;/&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATOS"/>
			<REPORT label="Listado de Pagos Acumulados" style="width:90%;">
				<qry:attribute name="date" value="format_date(now(), 'dd/mm/yyyy')"/>
				<GROUPS>
					<GROUP tag="CAB" type="title">
						<COLS>
							<COL name="e_periodo" label="Per&#237;odos"/>
							<COL name="d_empresa" label="Empresa"/>
						</COLS>
						<GROUP tag="ORD" type="table" style="width:100%;" noreg="No se encontraron &#211;rdenes de Pago para los filtros ingresados.">
							<COLS>
								<COL name="empresa" label="Empresa" style="width:25%;"/>
								<COL name="orden_pago" label="Orden de Pago" style="width:28%;"/>
								<COL name="titulo" label="Liquidaci&#243;n" style="width:25%;"/>
								<COL name="f_pago" label="Fecha de Pago" style="width:8%;" type="date"/>
								<COL name="n_monto" label="Monto" style="width:14%;" type="num"/>
							</COLS>
							<FCOLS>
								<COL label="Total $" style="text-align:RIGHT; font-weight: bold" colspan="4"/>
								<COL name="total" style="text-align:right; font-weight: bold" type="num"/>
							</FCOLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<qry:element name="DATA">
					<qry:element name="CAB">
						<qry:attribute name="e_periodo" value="format_date($PARAMIN/@e_periodo_des + '01', 'mm/yyyy') + ' - ' + format_date($PARAMIN/@e_periodo_has + '01', 'mm/yyyy')"/>
						<qry:attribute name="d_empresa" value="'Todas'"/>
						<qry:insert-select name="qry_cab" doc-path="$PARAMIN/.[@oi_empresa!='']"/>
						<qry:insert-select name="qry_detalle"/>
						<qry:attribute name="total" value="sum(ORD/@n_monto)"/>
					</qry:element>
				</qry:element>
			</REPORT>
		</qry:main>
		<qry:select doc="SOURCE" name="qry_cab">
			<qry:xquery>
				for $r in sql('
			SELECT e.d_empresa
			FROM ORG03_EMPRESAS as e
			WHERE e.oi_empresa = {$PARAMIN/@oi_empresa}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="qry_detalle">
			<qry:xquery>
				for $r in sql('
			SELECT
				o.c_orden_pago,
				o.d_orden_pago,
				o.f_pago,
				o.n_total_original,
				o.n_total_modificado,
				e.d_empresa,
				l.c_liquidacion,
				l.d_titulo
			FROM
				TES01_ORD_PAGO as o, LIQ99_LIQUIDACION as l, ORG03_EMPRESAS as e
			JOIN
				o.oi_liquidacion_ddo INNER l.oi_liquidacion_ddo,
				l.c_empresa LEFT OUTER e.c_empresa
			WHERE
				l.e_periodo &gt;= {$PARAMIN/@e_periodo_des} AND
				l.e_periodo &lt;= {$PARAMIN/@e_periodo_has} AND
				o.l_anulada = \'0\'
				{%? ($PARAMIN/@oi_empresa != '') {% AND e.oi_empresa = {$PARAMIN/@oi_empresa} %} {% %} %}
				')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="ORD">
					<qry:attribute name="orden_pago" value="$r/@c_orden_pago + ' - ' + $r/@d_orden_pago"/>
					<qry:attribute name="empresa" value="$r/@d_empresa"/>
					<qry:attribute name="titulo" value="$r/@c_liquidacion + ' - ' + $r/@d_titulo"/>
					<qry:attribute name="f_pago" value="format_date($r/@f_pago, 'dd/mm/yyyy')"/>
					<qry:attribute name="n_monto" value="iif($r/@n_total_modificado != '', $r/@n_total_modificado, $r/@n_total_original)"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
