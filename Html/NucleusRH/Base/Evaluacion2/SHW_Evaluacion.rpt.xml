				<tr>
					<th class="PLANTILLA_SUBTITLE" colspan="3" style="text-align:right;">
						Total
					</th>
					<th class="PLANTILLA_SUBTITLE">
						<xsl:call-template name="START-EVALUACION">
							<xsl:with-param name="VAL" select="round(100 * ../@n_resultado div ../@ESC_max_val)"/>
						</xsl:call-template>
					</th>
				</tr>
				<tr>
					<td colspan="4">
						<textarea readonly="1">
							<xsl:value-of select="../@o_evaluador"/>
							&#160;
						</textarea>
					</td>
				</tr>
			</table>
		</xsl:template>
		<xsl:template name="SEPARATOR">
			<table class="SEPARACION" CELLPADDING="0" CELLSPACING="0">
				<tr>
					<td>
						&#160;
					</td>
				</tr>
			</table>
		</xsl:template>
		<xsl:template name="START-ITEMS">
			<xsl:param name="VAL"/>
			<table class="STARTSROOT" CELLPADDING="0" CELLSPACING="0">
				<col width="80px"/>
				<col/>
				<tr>
					<td>
						<table class="STARTS" CELLPADDING="0" CELLSPACING="0">
							<tr>
								<td style="background-image:url(./Images/Reports/estrellas.gif);">
									<xsl:attribute name="width">
										<xsl:value-of select="concat($VAL,'%')"/>
									</xsl:attribute>
									&#160;
								</td>
								<td>
									&#160;
								</td>
							</tr>
						</table>
					</td>
					<td>
						<xsl:value-of select="concat($VAL,'%')"/>
					</td>
				</tr>
			</table>
		</xsl:template>
		<xsl:template name="START-PLANTILLAS">
			<xsl:param name="VAL"/>
			<table class="STARTSROOT" CELLPADDING="0" CELLSPACING="0">
				<col width="80px"/>
				<col/>
				<tr>
					<td>
						<table class="STARTS" CELLPADDING="0" CELLSPACING="0">
							<tr>
								<td style="background-image:url(./Images/Reports/estrellas.gif);">
									<xsl:attribute name="width">
										<xsl:value-of select="concat($VAL,'%')"/>
									</xsl:attribute>
									&#160;
								</td>
								<td>
									&#160;
								</td>
							</tr>
						</table>
					</td>
					<td>
						<b>
							<xsl:value-of select="concat($VAL,'%')"/>
						</b>
					</td>
				</tr>
			</table>
		</xsl:template>
		<xsl:template name="START-EVALUACION">
			<xsl:param name="VAL"/>
			<table class="STARTSROOT" CELLPADDING="0" CELLSPACING="0">
				<col width="80px"/>
				<col/>
				<tr>
					<td>
						<table class="STARTS" CELLPADDING="0" CELLSPACING="0">
							<tr>
								<td style="background-image:url(./Images/Reports/estrellas.gif);">
									<xsl:attribute name="width">
										<xsl:value-of select="concat($VAL,'%')"/>
									</xsl:attribute>
									&#160;
								</td>
								<td>
									&#160;
								</td>
							</tr>
						</table>
					</td>
					<td style="font-size:120%;">
						<b>
							<xsl:value-of select="concat($VAL,'%')"/>
						</b>
					</td>
				</tr>
			</table>
		</xsl:template>
	</html:xslt>
</html:html>
