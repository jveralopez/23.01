		<xsl:template name="ADICIONALES_TH">
			<xsl:param name="cols"/>
			<xsl:param name="edit"/>
			<xsl:param name="eva"/>
			<xsl:if test="$cols!=''">
				<xsl:if test="(starts-with($cols,'@') and ($edit='1')) or (starts-with($cols,'$') and ($eva!='0'))">
					<xsl:variable name="value" select="substring-before($cols, ';')"/>
					<th class="col_value">
						<xsl:if test="contains($value,':')">
							<xsl:value-of select="substring-after($value, ':')"/>
						</xsl:if>
						<xsl:if test="not(contains($value,':'))">
							<xsl:value-of select="substring($value,2)"/>
						</xsl:if>
					</th>
				</xsl:if>
				<xsl:call-template name="ADICIONALES_TH">
					<xsl:with-param name="cols" select="substring-after($cols, ';')"/>
					<xsl:with-param name="edit" select="$edit"/>
					<xsl:with-param name="eva" select="$eva"/>
				</xsl:call-template>
			</xsl:if>
		</xsl:template>
		<xsl:template name="ADICIONALES_TD">
			<xsl:param name="cols"/>
			<xsl:param name="edit"/>
			<xsl:param name="eva"/>
			<xsl:param name="suf"/>
			<xsl:param name="oi"/>
			<xsl:param name="editable"/>
			<xsl:if test="$cols!=''">
				<xsl:if test="(starts-with($cols,'$') and ($eva!='0'))">
					<xsl:variable name="var" select="substring(substring-before(concat(substring-before($cols, ';'),':'), ':'),2)"/>
					<td class="col_value">
						<xsl:choose>
							<xsl:when test="$editable = '0'">
								<div class="input" id="DIV_OX_{$suf}_{$var}_{$oi}">
									&#160;
								</div>
							</xsl:when>
							<xsl:when test="$eva='2'">
								<div class="input EDIT" id="DIV_OX_{$suf}_{$var}_{$oi}">
									<input onblur="REFRESH();" type="text" value="@" maxlength="8" id="OX_{$suf}_{$var}_{$oi}"/>
								</div>
							</xsl:when>
							<xsl:when test="$eva!='2'">
								<div class="input" id="DIV_OX_{$suf}_{$var}_{$oi}">
									&#160;
								</div>
							</xsl:when>
						</xsl:choose>
					</td>
				</xsl:if>
				<xsl:if test="(starts-with($cols,'@') and ($edit!='2'))">
					<xsl:variable name="var" select="substring(substring-before(concat(substring-before($cols, ';'),':'), ':'),2)"/>
					<td class="col_value">
						<xsl:choose>
							<xsl:when test="$editable = '0'">
								<div class="input" id="DIV_OX_EDT_{$var}_{$oi}">
									&#160;
								</div>
							</xsl:when>
							<xsl:when test="$edit!='0'">
								<div class="input EDIT" id="DIV_OX_EDT_{$var}_{$oi}">
									<input onblur="REFRESH();" type="text" value="@" maxlength="8" id="OX_EDT_{$var}_{$oi}"/>
								</div>
							</xsl:when>
							<xsl:when test="$edit='0'">
								<div class="input" id="DIV_OX_EDT_{$var}_{$oi}">
									&#160;
								</div>
							</xsl:when>
						</xsl:choose>
					</td>
				</xsl:if>
				<xsl:call-template name="ADICIONALES_TD">
					<xsl:with-param name="cols" select="substring-after($cols, ';')"/>
					<xsl:with-param name="edit" select="$edit"/>
					<xsl:with-param name="eva" select="$eva"/>
					<xsl:with-param name="suf" select="$suf"/>
					<xsl:with-param name="oi" select="$oi"/>
				</xsl:call-template>
			</xsl:if>
		</xsl:template>
