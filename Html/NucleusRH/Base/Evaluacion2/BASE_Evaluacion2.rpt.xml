		</xsl:template>
		<xsl:template name="TD_ITEM_COMMENT">
			<xsl:param name="ID"/>
			<xsl:param name="LABEL"/>
			<xsl:param name="TEXT"/>
			<xsl:param name="TOOLTIP"/>
			<xsl:param name="EDIT"/>
			<xsl:param name="EDITABLE"/>
			<td class="col_coment" onmouseover="ShowTooltip(this);" onmouseout="HideTooltip(this);">
				<xsl:choose>
					<xsl:when test="$EDITABLE = '0'">
						<div class="textarea">
							<xsl:call-template name="innerMultiline">
								<xsl:with-param name="stringIn" select="concat($TEXT, '&#10;')"/>
							</xsl:call-template>
						</div>
						<xsl:if test="$TOOLTIP and $TOOLTIP!=''">
							<div class="tooltip">
								<xsl:call-template name="innerMultiline">
									<xsl:with-param name="stringIn" select="concat($TOOLTIP, '&#10;')"/>
								</xsl:call-template>
							</div>
						</xsl:if>
					</xsl:when>
					<xsl:when test="$LABEL">
						<div class="label">
							<xsl:value-of select="$LABEL"/>
						</div>
					</xsl:when>
					<xsl:when test="$EDIT!='2'">
						<div class="textarea">
							<xsl:call-template name="innerMultiline">
								<xsl:with-param name="stringIn" select="concat($TEXT, '&#10;')"/>
							</xsl:call-template>
						</div>
						<xsl:if test="$TOOLTIP and $TOOLTIP!=''">
							<div class="tooltip">
								<xsl:call-template name="innerMultiline">
									<xsl:with-param name="stringIn" select="concat($TOOLTIP, '&#10;')"/>
								</xsl:call-template>
							</div>
						</xsl:if>
					</xsl:when>
					<xsl:when test="$EDIT='2'">
						<div class="textarea EDIT">
							<textarea id="{$ID}">
								<xsl:value-of select="concat($TEXT,' ')"/>
							</textarea>
						</div>
					</xsl:when>
				</xsl:choose>
			</td>
		</xsl:template>
		<xsl:template name="SEPARATOR">
			<div class="SEPARACION">
				&#160;
			</div>
		</xsl:template>
		<xsl:template name="TD_ITEM_VALUE_TEXT">
			<xsl:param name="ESCALA"/>
			<xsl:param name="VALUE"/>
			<xsl:param name="ID"/>
			<xsl:param name="DEC"/>
			<xsl:param name="SPAN"/>
			<td class="col_value" id="{$ID}">
				<xsl:if test="$SPAN">
					<xsl:attribute name="colspan">
						<xsl:value-of select="$SPAN"/>
					</xsl:attribute>
				</xsl:if>
				<xsl:choose>
					<xsl:when test="$ESCALA and $VALUE and $VALUE!='' and $VALUE!='null'">
						<xsl:choose>
							<xsl:when test="count($ESCALA/VAL)=0">
								<xsl:if test="$VALUE&lt;0">
									N/A
								</xsl:if>
								<xsl:if test="$VALUE&gt;=0">
									<xsl:value-of select="concat(format-number($VALUE,concat('0.',substring('000',1,$DEC))),'%')"/>
								</xsl:if>
							</xsl:when>
							<xsl:when test="count($ESCALA/VAL)=1">
								<xsl:if test="$VALUE&lt;0">
									N/A
								</xsl:if>
								<xsl:if test="$VALUE&gt;=0">
									<xsl:value-of select="concat(format-number($VALUE,concat('0.',substring('000',1,$DEC))),'/',format-number($ESCALA/@max,concat('0.',substring('000',1,$DEC))))"/>
								</xsl:if>
							</xsl:when>
							<xsl:otherwise>
								<xsl:choose>
									<xsl:when test="$VALUE and $VALUE!='' and $ESCALA/VAL[number($VALUE)&gt;@VAL_desde and number($VALUE)&lt;=@VAL_hasta]">
										<xsl:if test="$VALUE&lt;0">
											<xsl:value-of select="$ESCALA/VAL[number($VALUE)&gt;@VAL_desde and number($VALUE)&lt;=@VAL_hasta]/@VAL_des"/>
										</xsl:if>
										<xsl:if test="$VALUE&gt;=0">
											<xsl:value-of select="concat('(',format-number($VALUE,concat('0.',substring('000',1,$DEC))),'/',format-number($ESCALA/@max,concat('0.',substring('000',1,$DEC))),') ',$ESCALA/VAL[number($VALUE)&gt;@VAL_desde and number($VALUE)&lt;=@VAL_hasta]/@VAL_des)"/>
										</xsl:if>
									</xsl:when>
									<xsl:otherwise>
										<xsl:if test="$VALUE&lt;0">
											N/A
										</xsl:if>
										<xsl:if test="$VALUE&gt;=0">
											--
										</xsl:if>
									</xsl:otherwise>
								</xsl:choose>
							</xsl:otherwise>
						</xsl:choose>
					</xsl:when>
					<xsl:otherwise>
						<xsl:if test="$VALUE&lt;0">
							N/A
						</xsl:if>
						<xsl:if test="$VALUE&gt;=0">
							--
						</xsl:if>
					</xsl:otherwise>
				</xsl:choose>
			</td>
		</xsl:template>
