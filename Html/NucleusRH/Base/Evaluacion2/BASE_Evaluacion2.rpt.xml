		<xsl:template name="PLANTILLA_HEAD">
			<xsl:param name="PLANTILLA"/>
			<xsl:param name="EVALUADORES"/>
			<xsl:param name="POND"/>
			<xsl:param name="COLS"/>
			<xsl:param name="LABEL"/>
			<xsl:param name="ITEM"/>
			<xsl:param name="DATOS"/>
			<xsl:if test="$PLANTILLA/@DEF_Edit='1'">
				<xsl:if test="$ITEM">
					<th class="col_action">
						<img src="./Skins/_Default/Images/Buttons/table_delete_n.gif" style="cursor:pointer;" title="Eliminar Item" width="16px" onclick="EVA.GetPlantilla({$PLANTILLA/@oi_plantilla}).DelItem('{$ITEM}');"/>
					</th>
				</xsl:if>
				<xsl:if test="not($ITEM)">
					<th class="col_action">
						&#160;
					</th>
				</xsl:if>
			</xsl:if>
			<xsl:if test="$ITEM">
				<xsl:call-template name="TD_ITEM_LABEL">
					<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
					<xsl:with-param name="ID" select="concat('MSG_',$ITEM)"/>
					<xsl:with-param name="TEXT" select="$LABEL"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="not($ITEM)">
				<th class="col_label">
					<xsl:if test="$LABEL">
						<xsl:value-of select="$LABEL"/>
					</xsl:if>
					<xsl:if test="not($LABEL)">
						<xsl:value-of select="$PLANTILLA/@DEF_d_plantilla"/>
					</xsl:if>
				</th>
			</xsl:if>
			<xsl:if test="$POND='1'">
				<th class="col_pond">
					Ponderaci&#243;n
				</th>
			</xsl:if>
			<xsl:if test="$DATOS='1' and ($PLANTILLA/@DEF_d_reporte='ITEM_ESC_FOR_POND' or $PLANTILLA/@DEF_d_reporte='ITEM_ESC_FOR')">
				<th class="col_label">
					Datos
				</th>
			</xsl:if>
			<xsl:if test="$COLS">
				<xsl:call-template name="ADICIONALES_TH">
					<xsl:with-param name="cols" select="concat($COLS,';')"/>
					<xsl:with-param name="edit" select="1"/>
					<xsl:with-param name="eva" select="0"/>
				</xsl:call-template>
			</xsl:if>
			<xsl:if test="$PLANTILLA/@DEF_Evaluador!='0'">
				<xsl:if test="$COLS">
					<xsl:call-template name="ADICIONALES_TH">
						<xsl:with-param name="cols" select="concat($COLS,';')"/>
						<xsl:with-param name="edit" select="0"/>
						<xsl:with-param name="eva" select="1"/>
					</xsl:call-template>
				</xsl:if>
				<th class="col_value">
					<xsl:text>
						Resultado
					</xsl:text>
					<br/>
					<xsl:text>
						Evaluador
					</xsl:text>
				</th>
			</xsl:if>
			<xsl:choose>
				<xsl:when test="$PLANTILLA/@DEF_Evaluador360='1'">
					<xsl:if test="$COLS">
