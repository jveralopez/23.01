						<div class="input" id="DIV_{$ID}">
							<xsl:choose>
								<xsl:when test="not($VALUE) or $VALUE='' or $VALUE='null'">
									&#160;
								</xsl:when>
								<xsl:when test="$VALUE&lt;0">
									N/A
								</xsl:when>
								<xsl:otherwise>
									<xsl:value-of select="format-number($VALUE,concat('0.',substring('000',1,$DEC)))"/>
								</xsl:otherwise>
							</xsl:choose>
						</div>
					</td>
				</xsl:when>
			</xsl:choose>
		</xsl:template>
		<xsl:template name="TD_ITEM_VALUE_LABEL">
			<xsl:param name="STATUS"/>
			<xsl:param name="ID"/>
			<xsl:param name="VALUE"/>
			<xsl:param name="DEC"/>
			<xsl:if test="$STATUS!='0'">
				<td class="col_value_text">
					<div class="input" id="DIV_{$ID}">
						<xsl:choose>
							<xsl:when test="not($VALUE) or $VALUE='' or $VALUE='null'">
