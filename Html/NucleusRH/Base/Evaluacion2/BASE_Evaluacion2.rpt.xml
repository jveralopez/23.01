			</xsl:if>
		</xsl:template>
		<xsl:template name="ADICIONALES_TD_RES">
			<xsl:param name="cols"/>
			<xsl:param name="edit"/>
			<xsl:param name="eva"/>
			<xsl:if test="$cols!=''">
				<xsl:if test="(starts-with($cols,'@') and ($edit='1')) or (starts-with($cols,'$') and ($eva!='0'))">
					<th class="col_value">
						&#160;
					</th>
				</xsl:if>
				<xsl:call-template name="ADICIONALES_TD_RES">
					<xsl:with-param name="cols" select="substring-after($cols, ';')"/>
					<xsl:with-param name="edit" select="$edit"/>
					<xsl:with-param name="eva" select="$eva"/>
				</xsl:call-template>
			</xsl:if>
