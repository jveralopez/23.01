						<tr id="TR_O_{@oi_objetivo}">
							<xsl:call-template name="TD_ITEM_ACTION_DEL">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ITEM" select="$ITEM/@oi_objetivo"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_LABEL">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="TEXT" select="$ITEM/@d_objetivo"/>
								<xsl:with-param name="TOOLTIP" select="$ITEM/@o_objetivo"/>
							</xsl:call-template>
							<xsl:if test="$POND">
								<xsl:call-template name="TD_ITEM_POND">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('POND_',$ITEM/@oi_objetivo)"/>
									<xsl:with-param name="VALUE" select="$ITEM/@n_ponderacion"/>
									<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus3"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluador"/>
								<xsl:with-param name="ID" select="concat('OE_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluado"/>
								<xsl:with-param name="ID" select="concat('OA_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado2"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Supervisor"/>
								<xsl:with-param name="ID" select="concat('OS_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado3"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
						</tr>
					</xsl:for-each>
					<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$PLANTILLA/@oi_escala]"/>
					<tr class="PLA_FOOT">
						<xsl:call-template name="PLANTILLA_FOOT">
							<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
							<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
							<xsl:with-param name="POND" select="$POND"/>
							<xsl:with-param name="ID" select="$PLANTILLA/@oi_plantilla"/>
							<xsl:with-param name="ESCALA" select="$ESCALA"/>
							<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
						</xsl:call-template>
					</tr>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='SUBITEM_ESC_COMBO']">
			<xsl:variable name="PLANTILLA" select="."/>
			<xsl:variable name="EVALUADORES" select="../EVALUADORES"/>
			<xsl:variable name="ESCALAS" select="../ESCALAS"/>
			<xsl:variable name="POND" select="0"/>
			<xsl:if test="@DEF_Show='1'">
				<xsl:call-template name="SEPARATOR"/>
				<xsl:call-template name="PLANTILLA_TITLE"/>
				<table class="PLA" id="TBL_{@oi_plantilla}">
					<xsl:for-each select="ITEM">
						<xsl:variable name="ITEM" select="."/>
						<tr id="TR_O_{@oi_objetivo}" class="PLA_HEAD">
							<xsl:call-template name="PLANTILLA_HEAD">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
								<xsl:with-param name="POND" select="$POND"/>
								<xsl:with-param name="LABEL" select="$ITEM/@d_objetivo"/>
								<xsl:with-param name="ITEM" select="$ITEM/@oi_objetivo"/>
							</xsl:call-template>
						</tr>
						<xsl:for-each select="SUBITEM">
							<xsl:variable name="SUBITEM" select="."/>
							<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$SUBITEM/@oi_escala]"/>
							<tr id="TR_S_{$ITEM/@oi_objetivo}_{$SUBITEM/@oi_subobjetivo}">
								<xsl:call-template name="TD_ITEM_ACTION_DEL">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ITEM" select="$ITEM/@oi_objetivo"/>
									<xsl:with-param name="SUBITEM" select="$SUBITEM/@oi_subobjetivo"/>
								</xsl:call-template>
								<xsl:call-template name="TD_ITEM_LABEL">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo)"/>
									<xsl:with-param name="TEXT" select="$SUBITEM/@d_subobjetivo"/>
									<xsl:with-param name="TOOLTIP" select="$SUBITEM/@o_subobjetivo"/>
								</xsl:call-template>
								<xsl:call-template name="TD_ITEM_VALUE_COMBO">
									<xsl:with-param name="ESCALA" select="$ESCALA"/>
									<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluador"/>
									<xsl:with-param name="ID" select="concat('OE_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo)"/>
									<xsl:with-param name="VALUE" select="$SUBITEM/@n_resultado"/>
								</xsl:call-template>
								<xsl:choose>
									<xsl:when test="$PLANTILLA/@DEF_Evaluador360='1'">
										<xsl:variable name="n_resultado" select="$SUBITEM/attribute::*[name() = concat('EVA_n_res_',$EVALUADORES/@oi_evaluador_360)]"/>
										<xsl:call-template name="TD_ITEM_VALUE_COMBO">
											<xsl:with-param name="ESCALA" select="$ESCALA"/>
											<xsl:with-param name="STATUS" select="1"/>
											<xsl:with-param name="ID" select="concat('O3_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo,'_',$EVALUADORES/@oi_evaluador_360)"/>
											<xsl:with-param name="VALUE" select="$n_resultado"/>
										</xsl:call-template>
									</xsl:when>
									<xsl:when test="$PLANTILLA/@DEF_Evaluador360='2'">
										<xsl:for-each select="$EVALUADORES/EVALUADOR">
											<xsl:variable name="EVALUADOR" select="."/>
											<xsl:variable name="n_resultado" select="$SUBITEM/attribute::*[name() = concat('EVA_n_res_',$EVALUADOR/@oi_personal_emp)]"/>
											<xsl:call-template name="TD_ITEM_VALUE_COMBO">
												<xsl:with-param name="ESCALA" select="$ESCALA"/>
												<xsl:with-param name="STATUS" select="1"/>
												<xsl:with-param name="ID" select="concat('O3_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo,'_',@oi_personal_emp)"/>
												<xsl:with-param name="VALUE" select="$n_resultado"/>
											</xsl:call-template>
										</xsl:for-each>
									</xsl:when>
									<xsl:when test="$PLANTILLA/@DEF_Evaluador360='3'">
										<xsl:variable name="n_resultado" select="$SUBITEM/attribute::*[name() = concat('EVA_n_res_',$EVALUADORES/@oi_evaluador_360)]"/>
										<xsl:call-template name="TD_ITEM_VALUE_COMBO">
											<xsl:with-param name="ESCALA" select="$ESCALA"/>
											<xsl:with-param name="STATUS" select="2"/>
											<xsl:with-param name="ID" select="concat('O3_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo,'_',$EVALUADORES/@oi_evaluador_360)"/>
											<xsl:with-param name="VALUE" select="$n_resultado"/>
										</xsl:call-template>
									</xsl:when>
								</xsl:choose>
								<xsl:call-template name="TD_ITEM_VALUE_COMBO">
									<xsl:with-param name="ESCALA" select="$ESCALA"/>
									<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluado"/>
									<xsl:with-param name="ID" select="concat('OA_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo)"/>
									<xsl:with-param name="VALUE" select="$SUBITEM/@n_resultado2"/>
								</xsl:call-template>
								<xsl:call-template name="TD_ITEM_VALUE_COMBO">
									<xsl:with-param name="ESCALA" select="$ESCALA"/>
									<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Supervisor"/>
									<xsl:with-param name="ID" select="concat('OS_',$ITEM/@oi_objetivo,'_',$SUBITEM/@oi_subobjetivo)"/>
									<xsl:with-param name="VALUE" select="$SUBITEM/@n_resultado3"/>
								</xsl:call-template>
							</tr>
						</xsl:for-each>
						<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$ITEM/@oi_escala]"/>
						<tr class="PLA_FOOT" id="TR_OR_{@oi_objetivo}">
							<xsl:call-template name="PLANTILLA_FOOT">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
								<xsl:with-param name="POND" select="$POND"/>
								<xsl:with-param name="ID" select="concat($PLANTILLA/@oi_plantilla,'_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="LABEL" select="'&#160;'"/>
								<xsl:with-param name="ESCALA" select="$ESCALA"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
								<xsl:with-param name="ITEM" select="$ITEM"/>
							</xsl:call-template>
						</tr>
					</xsl:for-each>
					<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$PLANTILLA/@oi_escala]"/>
					<tr class="PLA_FOOT">
						<xsl:call-template name="PLANTILLA_FOOT">
							<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
							<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
							<xsl:with-param name="POND" select="$POND"/>
							<xsl:with-param name="ID" select="$PLANTILLA/@oi_plantilla"/>
							<xsl:with-param name="ESCALA" select="$ESCALA"/>
							<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
						</xsl:call-template>
					</tr>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='COMENT']">
			<xsl:if test="@DEF_Show='1' and @DEF_Comentarios!='0'">
				<xsl:call-template name="SEPARATOR"/>
				<xsl:call-template name="PLANTILLA_TITLE"/>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='COMENT_360']">
			<xsl:variable name="EVALUACION" select=".."/>
			<xsl:variable name="PLANTILLA" select="."/>
			<xsl:variable name="EVALUADORES" select="../EVALUADORES"/>
			<xsl:if test="@DEF_Show='1'">
				<xsl:call-template name="SEPARATOR"/>
				<xsl:call-template name="PLANTILLA_TITLE"/>
				<xsl:choose>
					<xsl:when test="$PLANTILLA/@DEF_Evaluador360='1'">
						<table class="PLA_COMENT">
							<tr>
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="ID" select="concat('COMENT_',$PLANTILLA/@oi_plantilla,'_',$EVALUADORES/@oi_evaluador_360)"/>
									<xsl:with-param name="TEXT" select="@EVA_o_plantilla"/>
									<xsl:with-param name="EDIT" select="1"/>
								</xsl:call-template>
							</tr>
						</table>
					</xsl:when>
					<xsl:when test="$PLANTILLA/@DEF_Evaluador360='2'">
						<table class="PLA_COMENT">
							<xsl:for-each select="$PLANTILLA/attribute::*[starts-with(name(),'EVA_o_com_')]">
								<xsl:variable name="COMENT" select="."/>
								<xsl:variable name="OI" select="substring(name(),11)"/>
								<tr>
									<xsl:choose>
										<xsl:when test="$OI=$EVALUACION/@J_oi_personal_emp">
											<xsl:if test="$PLANTILLA/@DEF_d_cus1">
												<xsl:call-template name="TD_ITEM_COMMENT">
													<xsl:with-param name="ID" select="concat('COMMENT_',$PLANTILLA/@oi_plantilla,'_',$OI)"/>
													<xsl:with-param name="LABEL" select="'SUPERVISOR'"/>
													<xsl:with-param name="TEXT" select="$PLANTILLA/@DEF_d_cus1"/>
													<xsl:with-param name="EDIT" select="1"/>
												</xsl:call-template>
											</xsl:if>
											<xsl:if test="not($PLANTILLA/@DEF_d_cus1)">
												<xsl:call-template name="TD_ITEM_COMMENT">
													<xsl:with-param name="ID" select="concat('COMMENT_',$PLANTILLA/@oi_plantilla,'_',$OI)"/>
													<xsl:with-param name="LABEL" select="'EVALUADOR'"/>
													<xsl:with-param name="TEXT" select="$COMENT"/>
													<xsl:with-param name="EDIT" select="1"/>
												</xsl:call-template>
