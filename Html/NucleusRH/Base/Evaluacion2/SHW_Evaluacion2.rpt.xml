<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doctype="HTML5" extends="NucleusRH.Base.Evaluacion2.BASE_Evaluacion2.rpt" name="Evaluacion Base 2.0" doc="source">
	<html:for-each declare="&lt;FILTRO gcustom=&quot;&quot; evento=&quot;611&quot; oi_posicion_new=&quot;&quot; gpers=&quot;&quot; empresa=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; supervisor=&quot;&quot; evaluador=&quot;&quot; estado=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS&gt;&lt;ROW VALUES=&quot;14&quot; /&gt;&lt;/PERSONAS&gt;&lt;EVENTOS /&gt;&lt;/FILTRO&gt;">
		<qry:main doc="SOURCE">
			<ROWS>
				<qry:attribute name="timestamp" value="Now()"/>
				<qry:insert-select name="SQL1" doc-path="#SOURCE:/FILTRO"/>
			</ROWS>
		</qry:main>
		<qry:select doc="SOURCE" name="SQL1">
			<qry:xquery>
				for $r in SQL('
	SELECT
		E.oi_evaluacion as oi_evaluacion,
		E.oi_personal_emp as oi_personal_emp  
	FROM
		EDD03_EVALUACION as E
	WHERE                  
		E.oi_evento = {#SOURCE:@evento} AND  
		E.oi_personal_emp in ({%=string(#SOURCE:PERSONAS/ROW/@VALUES) %}) 
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="pos" value="number(@pos)+1"/>
				<qry:call>
					<param>
						<qry:attribute name="oi_evaluacion" value="$r/@oi_evaluacion"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="pos" value="../../@pos"/>
						<qry:attribute name="mode" value="'SHOW'"/>
					</param>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:xslt>
		<xsl:template match="ROWS">
			<html>
				<xsl:attribute name="nmd_timestamp">
					<xsl:value-of select="@timestamp"/>
				</xsl:attribute>
				<head>
					<xsl:call-template name="STYLE"/>
				</head>
				<script>
					function ShowTooltip(obj)
{                       
	var xxx=obj.getElementsByTagName("div");
	if (xxx)
	if (xxx.length!=0)
	if (xxx[0].className=="tooltip")
	xxx[0].style.display="block";
}
function HideTooltip(obj)
{
	var xxx=obj.getElementsByTagName("div");
	if (xxx)
	if (xxx.length!=0)           
	if (xxx[0].className=="tooltip")
	xxx[0].style.display="none";
}
				</script>
				<body>
					<xsl:apply-templates select="REPORT"/>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="REPORT">
			<xsl:if test="preceding-sibling::*">
				<p style="page-break-after:always;">
					<br/>
					<hr class="screen" style="border:1px dotted black;" noshade="true" color="#000000" size="1px" align="center"/>
				</p>
			</xsl:if>
			<div class="PAGE">
				<xsl:call-template name="HEAD"/>
				<xsl:apply-templates select="PLANTILLA"/>
			</div>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='ITEM_ESC_COMBO_POND' or @DEF_d_reporte='ITEM_ESC_COMBO']">
			<xsl:variable name="PLANTILLA" select="."/>
			<xsl:variable name="EVALUADORES" select="../EVALUADORES"/>
			<xsl:variable name="ESCALAS" select="../ESCALAS"/>
			<xsl:variable name="POND" select="@DEF_d_reporte='ITEM_ESC_COMBO_POND'"/>
