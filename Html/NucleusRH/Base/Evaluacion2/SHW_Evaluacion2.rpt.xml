									<xsl:with-param name="ESCALA" select="$ESCALA_THIS"/>
									<xsl:with-param name="VALUE" select="$THIS/../@n_resultado2"/>
									<xsl:with-param name="DEC" select="$THIS/@DEF_d_cus1"/>
									<xsl:with-param name="ID" select="concat('TRA_',$THIS/@oi_plantilla)"/>
								</xsl:call-template>
							</xsl:if>
						</xsl:if>
						<xsl:if test="@DEF_Supervisor!='0'">
							<xsl:if test="$THIS/@DEF_Evaluador!='0'">
								<xsl:call-template name="TD_ITEM_VALUE_TEXT">
									<xsl:with-param name="ESCALA" select="$ESCALA_THIS"/>
									<xsl:with-param name="VALUE" select="$THIS/../@n_resultado3"/>
									<xsl:with-param name="DEC" select="$THIS/@DEF_d_cus1"/>
									<xsl:with-param name="ID" select="concat('TRS_',$THIS/@oi_plantilla)"/>
								</xsl:call-template>
							</xsl:if>
						</xsl:if>
					</tr>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='FIRMA']">
			<xsl:if test="@DEF_Show='1'">
				<xsl:call-template name="SEPARATOR"/>
				<xsl:call-template name="PLANTILLA_TITLE"/>
				<table class="PLA_BODY" CELLPADDING="0" CELLSPACING="0">
					<tr class="PLA_HEAD">
						<th>
							<xsl:if test="@DEF_d_cus1">
								<xsl:value-of select="@DEF_d_cus1"/>
							</xsl:if>
							<xsl:if test="not(@DEF_d_cus1)">
								EVALUADOR
							</xsl:if>
						</th>
						<th>
							<xsl:if test="@DEF_d_cus2">
								<xsl:value-of select="@DEF_d_cus2"/>
							</xsl:if>
							<xsl:if test="not(@DEF_d_cus2)">
								SUPERVISOR
							</xsl:if>
						</th>
						<th>
							<xsl:if test="@DEF_d_cus3">
								<xsl:value-of select="@DEF_d_cus3"/>
							</xsl:if>
							<xsl:if test="not(@DEF_d_cus3)">
								EVALUADO
							</xsl:if>
						</th>
					</tr>
					<tr class="FIRMA">
						<td>
							&#160;
						</td>
						<td>
							&#160;
						</td>
						<td>
							&#160;
						</td>
					</tr>
					<tr>
						<td>
							<xsl:value-of select="concat('Aclaraci&#243;n: ',../@J_nombre)"/>
						</td>
						<td>
							<xsl:value-of select="concat('Aclaraci&#243;n: ',../@S_nombre)"/>
						</td>
						<td>
							<xsl:value-of select="concat('Aclaraci&#243;n: ',../@E_nombre)"/>
						</td>
					</tr>
					<tr>
						<td>
							Fecha:
						</td>
						<td>
							Fecha:
						</td>
						<td>
							Fecha:
						</td>
					</tr>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='ITEM_NOESCALA']">
			<xsl:variable name="PLANTILLA" select="."/>
			<xsl:if test="@DEF_Show='1'">
				<xsl:call-template name="SEPARATOR"/>
				<xsl:call-template name="PLANTILLA_TITLE"/>
				<table class="PLA_BODY" id="TBL_{@oi_plantilla}" style="table-layout: fixed;">
					<tr class="PLA_HEAD">
						<xsl:if test="@DEF_Edit='1'">
							<th class="col_action">
								&#160;
							</th>
						</xsl:if>
						<xsl:if test="@DEF_d_cus1">
							<th class="col_label">
								<xsl:value-of select="@DEF_d_cus1"/>
							</th>
						</xsl:if>
						<xsl:if test="@DEF_d_cus2">
							<th class="col_label">
								<xsl:value-of select="@DEF_d_cus2"/>
							</th>
						</xsl:if>
						<xsl:if test="@DEF_d_cus3">
							<th class="col_label">
								<xsl:value-of select="@DEF_d_cus3"/>
							</th>
						</xsl:if>
						<xsl:if test="@DEF_d_cus4">
							<th class="col_label">
								<xsl:value-of select="@DEF_d_cus4"/>
							</th>
						</xsl:if>
						<xsl:if test="@DEF_d_cus5">
							<th class="col_label">
								<xsl:value-of select="@DEF_d_cus5"/>
							</th>
						</xsl:if>
					</tr>
					<xsl:for-each select="ITEM">
						<xsl:variable name="ITEM" select="."/>
						<tr id="TR_O_{@oi_objetivo}">
							<xsl:call-template name="TD_ITEM_ACTION_DEL">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ITEM" select="$ITEM/@oi_objetivo"/>
							</xsl:call-template>
							<xsl:if test="$PLANTILLA/@DEF_d_cus1">
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_1')"/>
									<xsl:with-param name="TEXT" select="$ITEM/@d_cus1"/>
									<xsl:with-param name="EDIT" select="0"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:if test="$PLANTILLA/@DEF_d_cus2">
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_2')"/>
									<xsl:with-param name="TEXT" select="$ITEM/@d_cus2"/>
									<xsl:with-param name="EDIT" select="0"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:if test="$PLANTILLA/@DEF_d_cus3">
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_3')"/>
									<xsl:with-param name="TEXT" select="$ITEM/@d_cus3"/>
									<xsl:with-param name="EDIT" select="0"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:if test="$PLANTILLA/@DEF_d_cus4">
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_4')"/>
									<xsl:with-param name="TEXT" select="$ITEM/@d_cus4"/>
									<xsl:with-param name="EDIT" select="0"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:if test="$PLANTILLA/@DEF_d_cus5">
								<xsl:call-template name="TD_ITEM_COMMENT">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo,'_5')"/>
									<xsl:with-param name="TEXT" select="$ITEM/@d_cus5"/>
									<xsl:with-param name="EDIT" select="0"/>
								</xsl:call-template>
							</xsl:if>
						</tr>
					</xsl:for-each>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
		<xsl:template match="PLANTILLA[@DEF_d_reporte='ITEM_ESC_FOR_POND' or @DEF_d_reporte='ITEM_ESC_FOR']">
			<xsl:variable name="PLANTILLA" select="."/>
			<xsl:variable name="EVALUADORES" select="../EVALUADORES"/>
			<xsl:variable name="ESCALAS" select="../ESCALAS"/>
			<xsl:variable name="POND" select="@DEF_d_reporte='ITEM_ESC_FOR_POND'"/>
			<xsl:if test="@DEF_Show='1'">
				<xsl:call-template name="SEPARATOR"/>
				<table class="PLA" id="TBL_{@oi_plantilla}">
					<tr class="PLA_HEAD">
						<xsl:call-template name="PLANTILLA_HEAD">
							<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
							<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
							<xsl:with-param name="POND" select="$POND"/>
							<xsl:with-param name="DATOS" select="'1'"/>
						</xsl:call-template>
					</tr>
					<xsl:for-each select="ITEM">
						<xsl:variable name="ITEM" select="."/>
						<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$ITEM/@oi_escala]"/>
						<tr id="TR_O_{@oi_objetivo}">
							<xsl:call-template name="TD_ITEM_ACTION_DEL">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ITEM" select="$ITEM/@oi_objetivo"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_LABEL">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ID" select="concat('MSG_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="TEXT" select="$ITEM/@d_objetivo"/>
								<xsl:with-param name="TOOLTIP" select="$ITEM/@o_objetivo"/>
							</xsl:call-template>
							<xsl:if test="$POND">
								<xsl:call-template name="TD_ITEM_POND">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('POND_',$ITEM/@oi_objetivo)"/>
									<xsl:with-param name="VALUE" select="$ITEM/@n_ponderacion"/>
									<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus3"/>
								</xsl:call-template>
							</xsl:if>
							<xsl:call-template name="TD_TEXT">
								<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
								<xsl:with-param name="ID" select="$ITEM/@oi_objetivo"/>
								<xsl:with-param name="VALUE" select="concat($ITEM/@d_cus1, $ITEM/@d_cus2)"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluador"/>
								<xsl:with-param name="ID" select="concat('OE_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluado"/>
								<xsl:with-param name="ID" select="concat('OA_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado2"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_INPUT">
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Supervisor"/>
								<xsl:with-param name="ID" select="concat('OS_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado3"/>
								<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							</xsl:call-template>
						</tr>
					</xsl:for-each>
					<xsl:variable name="ESCALA" select="$ESCALAS/ESCALA[@oi_escala=$PLANTILLA/@oi_escala]"/>
					<tr class="PLA_FOOT">
						<xsl:call-template name="PLANTILLA_FOOT">
							<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
							<xsl:with-param name="EVALUADORES" select="$EVALUADORES"/>
							<xsl:with-param name="POND" select="$POND"/>
							<xsl:with-param name="ID" select="$PLANTILLA/@oi_plantilla"/>
							<xsl:with-param name="ESCALA" select="$ESCALA"/>
							<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus2"/>
							<xsl:with-param name="DATOS" select="'1'"/>
						</xsl:call-template>
					</tr>
				</table>
				<xsl:call-template name="PLANTILLA_COMENT"/>
			</xsl:if>
		</xsl:template>
	</html:xslt>
</html:html>
