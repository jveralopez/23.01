								<xsl:with-param name="TEXT" select="$ITEM/@d_objetivo"/>
								<xsl:with-param name="TOOLTIP" select="$ITEM/@o_objetivo"/>
							</xsl:call-template>
							<xsl:if test="$POND">
								<xsl:call-template name="TD_ITEM_POND">
									<xsl:with-param name="PLANTILLA" select="$PLANTILLA"/>
									<xsl:with-param name="ID" select="concat('POND_',$ITEM/@oi_objetivo)"/>
									<xsl:with-param name="VALUE" select="$ITEM/@n_ponderacion"/>
									<xsl:with-param name="DEC" select="$PLANTILLA/@DEF_d_cus3"/>
