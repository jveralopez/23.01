								<xsl:with-param name="ID" select="concat('OE_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_COMBO">
								<xsl:with-param name="ESCALA" select="$ESCALA"/>
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Evaluado"/>
								<xsl:with-param name="ID" select="concat('OA_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado2"/>
							</xsl:call-template>
							<xsl:call-template name="TD_ITEM_VALUE_COMBO">
								<xsl:with-param name="ESCALA" select="$ESCALA"/>
								<xsl:with-param name="STATUS" select="$PLANTILLA/@DEF_Supervisor"/>
								<xsl:with-param name="ID" select="concat('OS_',$ITEM/@oi_objetivo)"/>
								<xsl:with-param name="VALUE" select="$ITEM/@n_resultado3"/>
							</xsl:call-template>
						</tr>
