<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:QRY="nomad_engine.QRY" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="Nomad.Base.BaseReport.rpt" name="Lista de Evaluaciones Evaluacion" doc="source">
	<html:for-each declare="&lt;FILTRO gcustom=&quot;&quot; evento=&quot;2&quot; gpers=&quot;&quot; empresa=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; cb_confidenciales=&quot;&quot; oi_grupo_ccosto=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; oi_departamento=&quot;&quot; oi_sector=&quot;&quot; supervisor=&quot;&quot; evaluador=&quot;&quot; estado=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS&gt;&lt;ROW VALUES=&quot;1431,1432,1429,1326&quot; /&gt;&lt;/PERSONAS&gt;&lt;EVENTOS /&gt;&lt;/FILTRO&gt;">
		<qry:main doc="SOURCE">
			<ROWS>
				<qry:append-doc name="PARAMIN" doc-path="#SOURCE:FILTRO"/>
				<qry:insert-select name="SQL_EVENTO" doc-path="#SOURCE:FILTRO"/>
				<qry:insert-select name="SQL_PLANTILLA" doc-path="#SOURCE:FILTRO"/>
				<qry:insert-select doc-path="#SOURCE:FILTRO/PERSONAS/ROW" name="QRY_PERSONAS"/>
			</ROWS>
		</qry:main>
		<qry:select doc="SOURCE" name="SQL_EVENTO">
			<qry:xquery>
				for $r in SQL('
		SELECT
			EV.c_evento,
			EV.d_evento,
			EV.c_estado
		FROM
			EDD02_EVENTOS as EV
		WHERE                  
			EV.oi_evento = {#SOURCE:@evento}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_evento" value="$r/@d_evento"/>
				<qry:attribute name="c_evento" value="$r/@c_evento"/>
				<qry:attribute name="d_estado" value="iif($r/@c_estado='A','Abierto',@d_estado)"/>
				<qry:attribute name="d_estado" value="iif($r/@c_estado='H','Habilitado',@d_estado)"/>
				<qry:attribute name="d_estado" value="iif($r/@c_estado='C','Cerrado',@d_estado)"/>
			</qry:out>
		</qry:select>
		<qry:select name="SQL_PLANTILLA" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
select 
	DEF.oi_plantilla,                    
	DEF.d_plantilla,
	DEF.d_cus1,
	DEF.e_orden
from 
	EDD02_EVENTOS    as EVE,  
	EDD01_PLANTILLAS as DEF
where
	DEF.l_mostrar_res=1 and
	DEF.oi_tipo_eval=EVE.oi_tipo_eval and
	EVE.oi_evento = {#SOURCE:@evento}
order by    
	e_orden ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<PLA>
					<qry:attribute name="oi_plantilla" value="$r/@oi_plantilla"/>
					<!--qry:attribute name="d_plantilla" value="iif($r/@d_cus1='',$r/@d_plantilla,$r/@d_cus1)"/-->
					<qry:attribute name="d_plantilla" value="$r/@d_plantilla"/>
				</PLA>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<param>
						<qry:attribute value="#PARAM:@values" name="values"/>
						<qry:attribute value="#PARAMIN:@evento" name="oi_evento"/>
					</param>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;param oi_evento=&quot;8&quot; values=&quot;11437,11446,11443,11445,11441,11436,11438,11460,11440,11444,11447,11429,11461,11508,11552&quot;/&gt;&#13;&#10;" name="qry_report">
		<qry:main doc="SOURCE">
			<QRY:NO-SHOW>
				<qry:insert-select name="REPORT" doc-path="#SOURCE:param"/>
			</QRY:NO-SHOW>
		</qry:main>
		<qry:select doc="SOURCE" name="REPORT">
			<qry:xquery>
				for $r in SQL('
				SELECT           
					EV.c_evento as EV_c_evento,
					EV.d_evento as EV_d_evento,
					EV.f_desde as EV_f_desde,
					EV.f_desde as EV_f_hasta,
					EV.o_evento as EV_o_evento,
					EV.d_cus1 as EV_a,
					EV.d_cus2 as EV_d_cus2,
					EV.d_cus3 as EV_d_cus3,
					EV.d_cus4 as EV_d_cus4,
					EV.d_cus5 as EV_d_cus5,
					EV.oi_escala,
					
					E.oi_evaluacion,
					E.c_estado,
					E.o_evaluado,
					E.o_evaluador,
					E.f_evaluacion,
					E.n_resultado,
					E.n_resultado2,
					E.n_resultado3,
					E.d_cus1,
					E.d_cus2,
					E.d_cus3,
					E.d_cus4,
					E.d_cus5,    
					
					LE.fingreso as E_fingreso,
					LE.foto as E_foto,
					LE.codemp as E_codemp,
					LE.empresa as E_empresa,
					LE.legajo as E_legajo,
					LE.nombre as E_nombre,
					LU.d_unidad_org as E_unidad,
					LP.d_posicion as E_posicion,    
					
					EE.fingreso as J_fingreso,
					EE.foto as J_foto,
					EE.codemp as J_codemp,
					EE.empresa as J_empresa,
					EE.legajo as J_legajo,
					EE.nombre as J_nombre,
					EU.d_unidad_org as J_unidad,
					EP.d_posicion as J_posicion,    
					
					SE.fingreso as S_fingreso,
					SE.foto as S_foto,
					SE.codemp as S_codemp,
					SE.empresa as S_empresa,
					SE.legajo as S_legajo,
					SE.nombre as S_nombre,
					SU.d_unidad_org as S_unidad,
					SP.d_posicion as S_posicion
				FROM             
					EDD02_EVENTOS as EV,
					EDD03_EVALUACION as E,   
					
					ORG01_UNI_ORG as LU,
					ORG01_UNI_ORG as EU,
					ORG01_UNI_ORG as SU,    
					
					ORG04_POSICIONES as LP,
					ORG04_POSICIONES as EP,
					ORG04_POSICIONES as SP,

					(select
						L1.oi_personal_emp as oi_personal_emp,
						H1.oi_foto         as foto,
						L1.f_ingreso       as fingreso,
						E1.c_empresa       as codemp,
						E1.d_empresa       as empresa,
						L1.e_numero_legajo as legajo,
						H1.d_ape_y_nom     as nombre
					from
						ORG03_EMPRESAS     as E1,
						PER02_PERSONAL_EMP as L1,
						PER01_PERSONAL     as H1
					join
						L1.oi_personal inner H1.oi_personal,
						L1.oi_empresa inner E1.oi_empresa) as LE,
					(select
						L1.oi_personal_emp as oi_personal_emp,
						H1.oi_foto         as foto,
						L1.f_ingreso       as fingreso,
						E1.c_empresa       as codemp,
						E1.d_empresa       as empresa,
						L1.e_numero_legajo as legajo,
						H1.d_ape_y_nom     as nombre
					from
						ORG03_EMPRESAS     as E1,
						PER02_PERSONAL_EMP as L1,
						PER01_PERSONAL     as H1
					join
						L1.oi_personal inner H1.oi_personal,
						L1.oi_empresa inner E1.oi_empresa) as EE,
					(select
						L1.oi_personal_emp as oi_personal_emp,
						H1.oi_foto         as foto,
						L1.f_ingreso       as fingreso,
						E1.c_empresa       as codemp,
						E1.d_empresa       as empresa,
						L1.e_numero_legajo as legajo,
						H1.d_ape_y_nom     as nombre
					from
						ORG03_EMPRESAS     as E1,
						PER02_PERSONAL_EMP as L1,
						PER01_PERSONAL     as H1
					join
						L1.oi_personal inner H1.oi_personal,
						L1.oi_empresa inner E1.oi_empresa) as SE

				join
					EV.oi_evento inner E.oi_evento,
					E.oi_personal_emp inner LE.oi_personal_emp,
					E.oi_evaluador inner EE.oi_personal_emp,
					E.oi_supervisor left outer SE.oi_personal_emp,
					E.oi_uni_evaluado left outer LU.oi_unidad_org,
					E.oi_uni_evaluador left outer EU.oi_unidad_org,
					E.oi_uni_supervisor left outer SU.oi_unidad_org,
					E.oi_pos_evaluado left outer LP.oi_posicion,
					E.oi_pos_evaluador left outer EP.oi_posicion,
					E.oi_pos_supervisor left outer SP.oi_posicion
				WHERE            
					E.oi_evento = {#SOURCE:@oi_evento} AND
					E.oi_personal_emp in ({%= #SOURCE:@values %})
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<REPORT>
					<qry:attribute name="EV_c_evento" value="$r/@EV_c_evento"/>
					<qry:attribute name="EV_d_evento" value="$r/@EV_d_evento"/>
					<qry:attribute value="format_date($r/@EV_f_desde,'dd/mm/yyyy')" name="EV_f_desde"/>
					<qry:attribute value="format_date($r/@EV_f_hasta,'dd/mm/yyyy')" name="EV_f_hasta"/>
					<qry:attribute name="EV_o_evento" value="$r/@EV_o_evento"/>
					<qry:attribute name="EV_d_cus1" value="$r/@EV_d_cus1"/>
					<qry:attribute name="EV_d_cus2" value="$r/@EV_d_cus2"/>
					<qry:attribute name="EV_d_cus3" value="$r/@EV_d_cus3"/>
					<qry:attribute name="EV_d_cus4" value="$r/@EV_d_cus4"/>
					<qry:attribute name="EV_d_cus5" value="$r/@EV_d_cus5"/>
					<qry:attribute name="oi_evaluacion" value="$r/@oi_evaluacion"/>
					<qry:attribute value="format_date($r/@E_ingreso,'dd/mm/yyyy')" name="E_ingreso"/>
					<qry:attribute name="E_text" value="iif($r/@E_nombre='','','['+$r/@E_legajo+'] '+$r/@E_nombre)"/>
					<qry:attribute name="E_unidad" value="$r/@E_unidad"/>
					<qry:attribute name="E_posicion" value="$r/@E_posicion"/>
					<qry:attribute name="J_text" value="iif($r/@J_nombre='','','['+$r/@J_legajo+'] '+$r/@J_nombre)"/>
					<qry:attribute name="J_unidad" value="$r/@J_unidad"/>
					<qry:attribute name="J_posicion" value="$r/@J_posicion"/>
					<qry:attribute name="S_text" value="iif($r/@S_nombre='','','['+$r/@S_legajo+'] '+$r/@S_nombre)"/>
					<qry:attribute name="S_unidad" value="$r/@S_unidad"/>
					<qry:attribute name="S_posicion" value="$r/@S_posicion"/>
					<qry:attribute name="c_estado" value="$r/@c_estado"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="AB">
							<qry:attribute name="d_estado" value="'Abierta'"/>
						</qry:case>
						<qry:case value="HA">
							<qry:attribute name="d_estado" value="'Habilitada'"/>
						</qry:case>
						<qry:case value="EV">
							<qry:attribute name="d_estado" value="'Evaluada'"/>
						</qry:case>
						<qry:case value="CO">
							<qry:attribute name="d_estado" value="'Confirmada'"/>
						</qry:case>
						<qry:case value="AP">
							<qry:attribute name="d_estado" value="'Aprobada'"/>
						</qry:case>
						<qry:case value="RZ">
							<qry:attribute name="d_estado" value="'Rechazada'"/>
						</qry:case>
						<qry:case value="AN">
							<qry:attribute name="d_estado" value="'Anulada'"/>
						</qry:case>
						<qry:case value="PU">
							<qry:attribute name="d_estado" value="'Publicada'"/>
						</qry:case>
						<qry:case value="CE">
							<qry:attribute name="d_estado" value="'Cerrada'"/>
						</qry:case>
					</qry:switch>
					<qry:attribute name="o_evaluado" value="$r/@o_evaluado"/>
					<qry:attribute name="o_evaluador" value="$r/@o_evaluador"/>
					<qry:attribute value="format_date($r/@f_evaluacion,'dd/mm/yyyy')" name="f_evaluacion"/>
					<qry:attribute name="n_resultado" value="$r/@n_resultado"/>
					<qry:attribute name="n_resultado2" value="$r/@n_resultado2"/>
					<qry:attribute name="n_resultado3" value="$r/@n_resultado3"/>
					<qry:attribute name="d_cus1" value="$r/@d_cus1"/>
					<qry:attribute name="d_cus2" value="$r/@d_cus2"/>
					<qry:attribute name="d_cus3" value="$r/@d_cus3"/>
					<qry:attribute name="d_cus4" value="$r/@d_cus4"/>
					<qry:attribute name="d_cus5" value="$r/@d_cus5"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="EM_c_empresa" value="$r/@EM_c_empresa"/>
					<qry:attribute name="EM_d_empresa" value="$r/@EM_d_empresa"/>
					<qry:attribute name="EM_oi_logotipo" value="$r/@EM_oi_logotipo"/>
					<qry:insert-select name="SQL3" doc-path="$r"/>
					<qry:insert-select name="SQL2" doc-path="$r"/>
				</REPORT>
			</qry:out>
		</qry:select>
		<qry:select name="SQL2" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
select 
	EVA.n_ponderacion as EVA_n_ponderacion,
	EVA.n_resultado as EVA_n_resultado,
	EVA.n_resultado2 as EVA_n_resultado2,
	EVA.n_resultado3 as EVA_n_resultado3,
	EVE.n_ponderacion as EVE_n_ponderacion,
	EVE.oi_escala,                    
	DEF.oi_plantilla,
	DEF.e_orden,
	DEF.l_mostrar_res as DEF_l_mostrar_res,
	max(VAL.n_val_hasta) as EVE_MAX_VAL
from 
	ORG29_VAL_ESCALAS as VAL,
	EDD03_PLANTILLAS as EVA,  
	EDD02_PLANTILLAS as EVE,
	EDD01_PLANTILLAS as DEF
where
	DEF.l_mostrar_res=1 and
	EVE.oi_escala=VAL.oi_escala and
	EVA.oi_plantilla_eve=EVE.oi_plantilla and
	EVE.oi_plantilla_def=DEF.oi_plantilla and
	EVA.oi_evaluacion={#SOURCE:@oi_evaluacion}
group by
	DEF.oi_plantilla, EVA.n_ponderacion, EVA.n_resultado,
	EVA.n_resultado2,EVA.n_resultado3, EVE.n_ponderacion, 
	EVE.oi_escala, DEF.l_mostrar_res, DEF.e_orden
order by
	e_orden ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<VAL>
					<qry:attribute name="POND" value="iif($r/@EVA_n_resultado!='',substring_before(Round(100 * number($r/@EVA_n_ponderacion) * number($r/@EVA_n_resultado) div number($r/@EVE_MAX_VAL) div number(../@MAX)),'.')+'%','')"/>
					<qry:attribute name="POND2" value="iif($r/@EVA_n_resultado2!='',substring_before(Round(100 * number($r/@EVA_n_ponderacion) * number($r/@EVA_n_resultado2) div number($r/@EVE_MAX_VAL) div number(../@MAX)),'.')+'%','')"/>
					<qry:attribute name="POND3" value="iif($r/@EVA_n_resultado3!='',substring_before(Round(100 * number($r/@EVA_n_ponderacion) * number($r/@EVA_n_resultado3) div number($r/@EVE_MAX_VAL) div number(../@MAX)),'.')+'%','')"/>
				</VAL>
			</qry:out>
		</qry:select>
		<qry:select name="SQL3" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
		SELECT 
			SUM(EVA.n_ponderacion) as mx
		FROM 
			EDD03_PLANTILLAS as EVA,  
			EDD02_PLANTILLAS as EVE,
			EDD01_PLANTILLAS as DEF
		JOIN
			EVA.oi_plantilla_eve INNER EVE.oi_plantilla,
			EVE.oi_plantilla_def INNER DEF.oi_plantilla
		WHERE
			DEF.l_mostrar_res=1 and
			EVA.oi_evaluacion={#SOURCE:@oi_evaluacion}
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="MAX" value="$r/@mx"/>
			</qry:out>
		</qry:select>
	</html:query>
