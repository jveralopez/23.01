					<qry:attribute name="oi_evaluacion" value="../@oi_evaluacion"/>
					<qry:attribute name="oi_evento" value="../@oi_evento"/>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="legajo" value="$r/@legajo"/>
					<qry:attribute name="nombre" value="$r/@nombre"/>
					<qry:attribute name="empresa" value="$r/@empresa"/>
					<qry:attribute name="rol" value="$r/@rol"/>
