						<qry:if test="$r/@n_resultado='0' or not($r/@n_resultado!='')">
							<qry:then>
								<qry:attribute name="resultado" value="'-'"/>
							</qry:then>
							<qry:else>
								<qry:if test="../@d_cus1 != '' and ../@d_cus1 != '0'">
									<qry:then>
										<qry:attribute name="resultado" value="format_number($r/@n_resultado,0,number(#DECIMAL:@d_cus1),'.','','')"/>
									</qry:then>
									<qry:else>
										<qry:attribute name="resultado" value="round($r/@n_resultado)"/>
									</qry:else>
								</qry:if>
							</qry:else>
						</qry:if>
					</qry:element>
					+
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PLANTILLAS_EVA_360" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
			SELECT 
				E1.oi_plantilla as oi_plantilla_ori, 
				E3.oi_plantilla as oi_plantilla_eva,
				E3.n_ponderacion, 
				E1.d_cus2,
				E1.e_orden,
				EVA.oi_personal_emp
			FROM
				EDD03_PLANTILLAS as E3,
				EDD02_PLANTILLAS as E2,			
				EDD01_PLANTILLAS as E1,
				EDD03_EVALUACION as EVA
			JOIN
				E2.oi_plantilla INNER E3.oi_plantilla_eve,
				E1.oi_plantilla INNER E2.oi_plantilla_def,
				EVA.oi_evaluacion INNER E3.oi_evaluacion
			WHERE
				E1.l_mostrar_res=1 
				AND EVA.oi_evaluacion= {#SOURCE:@oi_evaluacion}											
			ORDER BY
				e_orden asc
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="VAL">
					<qry:attribute name="oi_plantilla" value="$r/@oi_plantilla_ori"/>
					<qry:attribute name="oi_plantilla_eva" value="$r/@oi_plantilla_eva"/>
					<qry:attribute name="oi_personal_emp" value="../@oi_personal_emp"/>
					<qry:attribute name="resultado_aux" value="'0'"/>
					<qry:insert-select name="QRY_VALOR_360" doc-path="."/>
