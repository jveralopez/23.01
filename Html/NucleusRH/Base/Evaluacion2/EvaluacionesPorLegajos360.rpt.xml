<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:QRY="nomad_engine.QRY" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" extends="Nomad.Base.BaseReport.rpt" name="Lista de Evaluaciones por Legajo" doc="source">
	<html:for-each declare="&lt;FILTRO evento=&quot;501&quot;&gt;&#13;&#10;&#9;&lt;PERSONAS&gt;&#13;&#10;&#9;&#9;&lt;ROW VALUES=&quot;10&quot; /&gt;&#13;&#10;&#9;&lt;/PERSONAS&gt;&#13;&#10;&#9;&lt;EVENTOS /&gt;&#13;&#10;&lt;/FILTRO&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="DOC_FILTRO" doc-path="#SOURCE:FILTRO"/>
			<ROWS>
				<qry:if test="#SOURCE:FILTRO/@evento != '' ">
					<qry:then>
						<qry:insert-select name="SQL_EVENTO" doc-path="#SOURCE:/FILTRO"/>
					</qry:then>
					<qry:else>
						<qry:element name="EVENTO">
							<qry:attribute name="evento" value="' - '"/>
							<qry:append-doc name="EVE" doc-path="."/>
						</qry:element>
					</qry:else>
				</qry:if>
				<qry:insert-select name="qry_personas_split" doc-path="#DOC_FILTRO:PERSONAS/ROW"/>
			</ROWS>
		</qry:main>
		<qry:select doc="SOURCE" name="SQL_EVENTO">
			<qry:xquery>
				for $r in SQL('
		SELECT
			EV.oi_evento,
			EV.c_evento,
			EV.d_evento,
			EV.c_estado
		FROM
			EDD02_EVENTOS as EV
		WHERE  
			EV.oi_evento = {#DOC_FILTRO:@evento} 
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EVENTO">
					<qry:attribute name="oi_evento" value="$r/@oi_evento"/>
					<qry:attribute name="c_evento" value="$r/@c_evento"/>
					<qry:attribute name="d_evento" value="$r/@d_evento"/>
					<qry:attribute name="evento" value="'['+$r/@c_evento+'] '+$r/@d_evento"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='A','Abierto',@d_estado)"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='H','Habilitado',@d_estado)"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='C','Cerrado',@d_estado)"/>
					<qry:append-doc name="EVE" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PERSONAS">
			<qry:out>
				<qry:call>
					<param>
						<qry:attribute value="#PARAM:@values" name="values"/>
					</param>
				</qry:call>
			</qry:out>
		</qry:select>
		<qry:select name="qry_personas_split" doc="PARAM">
			<qry:xquery>
				for $r in split('1;{%= string(#PARAM:@values) %}')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:call>
					<ROW>
						<qry:attribute name="value" value="$r/@value"/>
						<qry:attribute name="oi_evento" value="#EVE:@oi_evento"/>
					</ROW>
				</qry:call>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;ROW value=&quot;10&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;11&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;12&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;13&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;14&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;16&quot; oi_evento=&quot;501&quot;/&gt;&#13;&#10;&lt;ROW value=&quot;451&quot; oi_evento=&quot;501&quot;/&gt;" name="qry_report">
		<qry:main doc="SOURCE">
