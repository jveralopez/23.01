			<!--qry:insert-select name="SQL_EVENTO" doc-path="#SOURCE:/EVENTO"/-->
			<QRY:NO-SHOW>
				<qry:insert-select name="SQL_eva360" doc-path="#SOURCE:ROW"/>
			</QRY:NO-SHOW>
		</qry:main>
		<qry:select name="SQL_EVENTO" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
		SELECT
			EV.oi_evento,
			EV.c_evento,
			EV.d_evento,
			EV.c_estado
		FROM
			EDD02_EVENTOS as EV
		WHERE  
			EV.oi_evento = ({%= #SOURCE:@oi_evento %})
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EVENTO">
					<qry:attribute name="oi_evento" value="$r/@oi_evento"/>
					<qry:attribute name="c_evento" value="$r/@c_evento"/>
					<qry:attribute name="d_evento" value="$r/@d_evento"/>
					<qry:attribute name="evento" value="'['+$r/@c_evento+'] '+$r/@d_evento"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='A','Abierto',@d_estado)"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='H','Habilitado',@d_estado)"/>
					<qry:attribute name="d_estado" value="iif($r/@c_estado='C','Cerrado',@d_estado)"/>
					<!--qry:insert-select name="SQL_eva360" doc-path="#SOURCE:EVENTO/ROW"/-->
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="SQL_eva360" doc="SOURCE">
			<qry:xquery>
				for $r in SQL('
		SELECT 
			EVA.e_numero_legajo as eva_legajo
			,P_EVA.d_ape_y_nom as eva_apeynom
			,E_EVA.d_empresa as eva_empresa
			,P.d_ape_y_nom
			,PE.e_numero_legajo 
			,E.d_empresa
			,R.d_rol
		FROM  			
			PER02_PERSONAL_EMP as PE
			,PER01_PERSONAL as P
			,ORG03_EMPRESAS as E			
			,EDD05_ROLES as R			
			,PER02_PERSONAL_EMP as EVA
			,PER01_PERSONAL as P_EVA
			,ORG03_EMPRESAS as E_EVA
			{%? (string(#SOURCE:@oi_evento)!='') 
				{% ,EDD03_EVALUACION as EVAL, EDD03_EVA_EVALUAD AS EVAL360 %} 
				{% ,EDD06_EVALUADORES as E360 %}
			%}
		JOIN
			{%? (string(#SOURCE:@oi_evento)!='') 
				{% 	EVAL360.oi_personal_emp inner EVA.oi_personal_emp
					,EVA.oi_personal inner P_EVA.oi_personal
					,EVA.oi_empresa inner E_EVA.oi_empresa
					,EVAL360.oi_evaluacion INNER EVAL.oi_evaluacion			
					,EVAL.oi_evaluador inner PE.oi_personal_emp
					,PE.oi_personal inner P.oi_personal
					,PE.oi_empresa inner E.oi_empresa
					,R.oi_rol inner EVAL360.oi_rol
				%} 
				{% 	E360.oi_personal_emp inner EVA.oi_personal_emp
					,EVA.oi_personal inner P_EVA.oi_personal
					,EVA.oi_empresa inner E_EVA.oi_empresa			
					,E360.oi_evaluador inner PE.oi_personal_emp
					,PE.oi_personal inner P.oi_personal
					,PE.oi_empresa inner E.oi_empresa
					,R.oi_rol inner E360.oi_rol	 
				%}
			%}	
		WHERE
			{%? (string(#SOURCE:@oi_evento)!='') 
				{% EVAL.oi_personal_emp =  ({%= #SOURCE:@value %}) AND EVAL.oi_evento =  ({%= #SOURCE:@oi_evento %})  %} 
				{% E360.oi_personal_emp =  ({%= #SOURCE:@value %}) %}
			%}  
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<ROW>
					<qry:if test="string(#SOURCE:@oi_evento)!=''">
						<qry:then>
							<!--<qry:attribute name="eva_legajo" value="$r/@eva_legajo"/>
			<qry:attribute name="eva_ape_y_nom" value="$r/@eva_apeynom"/>
			<qry:attribute name="eva_empresa" value="$r/@eva_empresa"/>
					
			<qry:attribute name="e360_legajo" value="$r/@e_numero_legajo"/>										
			<qry:attribute name="e360_ape_y_nom" value="$r/@d_ape_y_nom"/>
			<qry:attribute name="e360_empresa" value="$r/@d_empresa"/>-->
							<qry:attribute name="eva_legajo" value="$r/@e_numero_legajo"/>
							<qry:attribute name="eva_ape_y_nom" value="$r/@d_ape_y_nom"/>
							<qry:attribute name="eva_empresa" value="$r/@d_empresa"/>
							<qry:attribute name="e360_legajo" value="$r/@eva_legajo"/>
							<qry:attribute name="e360_ape_y_nom" value="$r/@eva_apeynom"/>
							<qry:attribute name="e360_empresa" value="$r/@eva_empresa"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="eva_legajo" value="$r/@eva_legajo"/>
							<qry:attribute name="eva_ape_y_nom" value="$r/@eva_apeynom"/>
							<qry:attribute name="eva_empresa" value="$r/@eva_empresa"/>
							<qry:attribute name="e360_empresa" value="$r/@d_empresa"/>
							<qry:attribute name="e360_legajo" value="$r/@e_numero_legajo"/>
							<qry:attribute name="e360_ape_y_nom" value="$r/@d_ape_y_nom"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="e360_rol" value="$r/@d_rol"/>
				</ROW>
			</qry:out>
		</qry:select>
	</html:query>
