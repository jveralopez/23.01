					<script>
						function amp()
{
	return String.fromCharCode(38);
}

function SetHTML(txt)
{
	var obj;
	var aux;
	
	//Arreglo el Titulo
	obj=document.getElementById("table_log");
	obj.innerHTML=txt;        
}

function AutoRefresh() 
{ 
	var oi_instance=document.getElementById("AUX_IFRAME").getAttribute("nmd-instance");
	var ut         =document.getElementById("AUX_IFRAME").getAttribute("nmd-ut");
    
    var crc = parent.CRC32("PARAMS:file=NucleusWF.Base.Ejecucion.WaitProcess.rpt|oi_instance="+oi_instance+"|mode=refresh");    

	document.getElementById("AUX_IFRAME").src="ReportViewer.aspx?ut="+ut+amp()+"file=NucleusWF.Base.Ejecucion.WaitProcess.rpt"+amp()+"oi_instance="+oi_instance+amp()+"mode=refresh"+amp()+"crc="+crc;
	window.setTimeout("AutoRefresh();",3000);
}

