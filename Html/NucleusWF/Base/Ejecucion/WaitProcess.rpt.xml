<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="Evaluacion Base" doc="source">
	<html:query declare="&lt;PARAMS oi_instance=&quot;407&quot; /&gt;" name="qry_report">
		<qry:main doc="SOURCE">
			<LOGS>
				<qry:attribute name="etty" value="$PROXY/@ETTY"/>
				<qry:attribute name="ut" value="$PROXY/@TOKEN"/>
				<qry:attribute name="mode" value="$SOURCE/PARAMS/@mode"/>
				<qry:attribute name="oi_instance" value="$SOURCE/PARAMS/@oi_instance"/>
				<qry:attribute name="oi_thread" value="0"/>
				<qry:attribute name="oi_node" value="0"/>
				<qry:insert-select name="LOAD_LOGS" doc-path="."/>
				<qry:insert-select name="TEST_THREAD" doc-path="."/>
			</LOGS>
		</qry:main>
		<qry:select doc="SOURCE" name="LOAD_LOGS">
			<qry:xquery>
				for $r in SQL('
select           
	L.oi_log,
	L.e_paso,
	L.c_tipo,
	L.f_accion,
	L.o_comentario
from
	WRK02_LOGS as L
where
	L.oi_instance={$SOURCE/@oi_instance}
order by
	e_paso ASC
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<LOG>
					<qry:attribute name="e_paso" value="$r/@e_paso"/>
					<qry:attribute name="c_tipo" value="$r/@c_tipo"/>
					<qry:attribute name="f_accion" value="format-date($r/@f_accion,'dd/mm/yyyy HH:MM:SS')"/>
					<qry:attribute name="o_comentario" value="$r/@o_comentario"/>
				</LOG>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="TEST_THREAD">
			<qry:xquery>
				for $r in SQL('
select           
	T.oi_thread,
	T.oi_node
from
	WRK02_THREADS as T
where       
  T.c_estado=\'WP\' and
	T.oi_instance={$SOURCE/@oi_instance}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_thread" value="$r/@oi_thread"/>
				<qry:attribute name="oi_node" value="$r/@oi_node"/>
			</qry:out>
		</qry:select>
	</html:query>
