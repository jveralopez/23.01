function FinishWait(oi_thread, oi_node) 
{ 
	parent.FinishWait(oi_thread, oi_node);
}

function HTMLOnLoad()
{
	var mode     =document.getElementById("AUX_IFRAME").getAttribute("nmd-mode");
	var oi_thread=document.getElementById("AUX_IFRAME").getAttribute("nmd-thread");
	var oi_node  =document.getElementById("AUX_IFRAME").getAttribute("nmd-node");
	
	if (oi_thread!="0") 
		parent.FinishWait(oi_thread, oi_node);
	else
	if (mode=="") 
		window.setTimeout("AutoRefresh();",2000);
	else 
		parent.SetHTML(""+document.getElementById("table_log").innerHTML);
}
					</script>
				</head>
				<body onload="HTMLOnLoad();" scroll="no">
					<div id="table_log" name="table_log">
						<table CELLPADDING="0" CELLSPACING="0" class="TABLE_LOG" border="1">
							<col width="30px"/>
							<col width="100px"/>
							<col/>
							<tr height="20px">
								<th class="TABLE_LOG_TH">
									Tipo
								</th>
								<th class="TABLE_LOG_TH" style="text-align:center;">
									Fecha Hora
								</th>
								<th class="TABLE_LOG_TH" style="text-align:center;">
									Mensaje
								</th>
							</tr>
							<xsl:for-each select="LOG">
								<tr>
									<td class="TABLE_LOG_TD" align="center">
										<xsl:choose>
											<xsl:when test="@c_tipo='IFO'">
												<img src="Skins/_Default/Images/Workflow/Logs/IFO.gif"/>
											</xsl:when>
											<xsl:when test="@c_tipo='WRN'">
												<img src="Skins/_Default/Images/Workflow/Logs/WRN.gif"/>
											</xsl:when>
											<xsl:when test="@c_tipo='ERR'">
												<img src="Skins/_Default/Images/Workflow/Logs/ERR.gif"/>
											</xsl:when>
											<xsl:when test="@c_tipo='EXE'">
												<img src="Skins/_Default/Images/Workflow/Logs/EXE.gif"/>
											</xsl:when>
										</xsl:choose>
									</td>
									<td class="TABLE_LOG_TD" style="text-align:center;">
										<xsl:value-of select="@f_accion"/>
									</td>
									<td class="TABLE_LOG_TD">
										<xsl:value-of select="@o_comentario"/>
									</td>
								</tr>
							</xsl:for-each>
						</table>
