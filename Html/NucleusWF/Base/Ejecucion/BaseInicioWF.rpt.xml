<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doctype="HTML5" doc="source" name="NucleusWF.Base.Ejecucion.BaseInicioWF.rpt">
	<html:query declare="&lt;PARAMS oi_usuario_sistema=&quot;pvaldez&quot; workflow=&quot;licencia&quot;/&gt;">
		<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.QRY_INICIO_WFs"/>
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTER" doc-path="#SOURCE:PARAMS"/>
			<qry:element name="REPORTE">
				<qry:element name="PERSONAS">
					<qry:insert-select name="qry_DatosPersonales" doc-path="#FILTER:."/>
				</qry:element>
			</qry:element>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="/REPORTE">
			<html>
				<head>
					<meta http-equiv="X-UA-Compatible" content="IE=edge"/>
					<script type="text/javascript" src="Styles/jQuery/jquery.js">
						//comentario
					</script>
					<script type="text/javascript" src="Styles/bootstrap/js/bootstrap.min.js">
						//comentario
					</script>
					<link href="Styles/bootstrap/css/bootstrap.min.css" rel="stylesheet"/>
					<xsl:call-template name="LINKCSS_CUSTOM"/>
					<STYLE>
						<xsl:call-template name="CSS_BASE"/>
						<xsl:call-template name="CSS_CUSTOM"/>
					</STYLE>
				</head>
				<body>
					<div class="container">
						<div class="row">
							<div id="panel-datos-persona" class="panel panel-default">
								<div id="body-datos-persona" class="panel-body">
									<xsl:apply-templates select="PERSONAS/PERSONA"/>
								</div>
							</div>
						</div>
						<xsl:call-template name="BODY_CUSTOM"/>
					</div>
					<xsl:call-template name="JAVASCRIPT_CUSTOM"/>
				</body>
			</html>
		</xsl:template>
		<xsl:template match="PERSONA">
			<div class="img-persona" style="float:left">
				<img id="foto-persona" class="img-responsive img-thumbnail" alt="Responsive image">
					<xsl:choose>
						<xsl:when test="@oi_foto = -1">
							<xsl:attribute name="src">
								Images/Reports/nophoto.jpg
							</xsl:attribute>
						</xsl:when>
						<xsl:otherwise>
							<xsl:attribute name="src">
								<xsl:value-of select="concat('NomadFile.aspx?mode=DB&amp;class=NucleusRH.Base.Personal.Imagenes.HEAD&amp;height=120&amp;id=', @oi_foto, '&amp;crc=', @crc32)"/>
							</xsl:attribute>
						</xsl:otherwise>
					</xsl:choose>
				</img>
			</div>
			<form id="form-datos-persona" class="form-horizontal">
				<div class="form-group sin-margen-negativo">
					<label class="col-sm-2 control-label label-datos-persona">
						Nombre:
					</label>
					<div class="col-sm-10 div-inputs-datos">
						<p class="form-control-static">
							<xsl:value-of select="@nombre_persona"/>
						</p>
					</div>
				</div>
				<div class="form-group sin-margen-negativo">
					<label class="col-sm-2 control-label label-datos-persona">
						Apellido:
					</label>
					<div class="col-sm-10 div-inputs-datos">
						<p class="form-control-static">
							<xsl:value-of select="@apellido_persona"/>
						</p>
					</div>
				</div>
				<div class="form-group sin-margen-negativo">
					<label class="col-sm-2 control-label label-datos-persona">
						DNI:
					</label>
					<div class="col-sm-10 div-inputs-datos">
						<p class="form-control-static">
							<xsl:value-of select="@dni_persona"/>
						</p>
					</div>
				</div>
			</form>
		</xsl:template>
		<xsl:template name="BODY_CUSTOM">
			<p>
				Aqu&#237; va la informaci&#243;n de cada uno de los distintos wf
			</p>
		</xsl:template>
		<xsl:template name="JAVASCRIPT_CUSTOM"/>
		<xsl:template name="CSS_CUSTOM"/>
		<xsl:template name="CSS_BASE">
			#panel-datos-persona{
		margin-bottom: 0px;
	}
	
	#body-datos-persona{
		padding: 5px;
	}
	
	#foto-persona{
		max-width:100px;
	}
	.label-datos-persona{
		text-align: left;
		width: auto;
		padding-right: 0px;
		font-size: 16px;
		margin-left: 10px;
		padding-top: 5px;
	}
	
	.div-inputs-datos{
		width: auto;
		padding-left: 10px;
		font-size: 15px;
		padding-top: 0px;
	}
	
	.form-group.sin-margen-negativo{
		margin-left: 0px;
		margin-bottom: 0px!important;
	}
	
	#form-datos-persona{
		width: auto;
		max-width: 80%;
		float: left;
		margin-bottom: 0px;
	}
		</xsl:template>
		<xsl:template name="LINKCSS_CUSTOM"/>
	</html:xslt>
</html:html>
