		margin-top: 10px;
	}
	
	.btns-datos-personales{
		width: 100%;
	    text-align: left;
		font-weight: 600;
		margin-top: 1px;
	}
	
	.divContent-datos-personales{
		margin-bottom: 2px!important;
		padding: 0px 19px;
	
	}
	
	form.form-datos-personales div label{
