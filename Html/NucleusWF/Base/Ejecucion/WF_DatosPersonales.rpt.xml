		</xsl:template>
		<xsl:template match="DATOS_PERSONALES">
			<a id="btn-personales" class="btn btn-primary btns-datos-personales" role="button" data-toggle="collapse" href="#collapsePersonales" aria-expanded="true" aria-controls="collapsePersonales">
				Personales
			</a>
			<div class="collapse in" id="collapsePersonales">
				<div class="well divContent-datos-personales">
					<xsl:apply-templates select="PERSONALES"/>
				</div>
			</div>
			<a class="btn btn-primary btns-datos-personales" role="button" data-toggle="collapse" href="#collapseReferenciales" aria-expanded="true" aria-controls="collapseReferenciales">
				Referenciales
			</a>
