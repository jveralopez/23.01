<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusWF.Base.Ejecucion.WF_Domi_Fis.rpt" doc="source" extends="NucleusWF.Base.Ejecucion.BaseInicioWF.rpt">
	<html:query declare="&lt;PARAMS oi_usuario_sistema=&quot;masosa&quot; workflow=&quot;datos_personales&quot;/&gt;">
		<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.QRY_INICIO_WFs"/>
		<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.Get_DomicilioFiscal"/>
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTER" doc-path="#SOURCE:PARAMS"/>
			<qry:element name="REPORTE">
				<qry:attribute name="workflow" value="#FILTER:@workflow"/>
				<qry:element name="PERSONAS">
					<qry:insert-select name="qry_DatosPersonales" doc-path="#SOURCE:PARAMS"/>
					<qry:element name="DOMICILIOS">
						<qry:attribute name="fiscal" value="0"/>
						<qry:insert-select name="sql1" doc-path="#SOURCE:PARAMS" to-element="."/>
						<qry:if test="ROW/@OI_DOM != null">
							<qry:then>
								<qry:attribute name="fiscal" value="1"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:element>
			</qry:element>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="ROW">
			<div class="row">
				<div class="col-md-6">
					<form class="form-horizontal form-fiscal">
						<div class="form-group">
							<label class="control-label">
								Tipo Domicilio:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@TIPO_DES"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Calle:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@CALLE"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Nro:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@NUMERO"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Piso:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@PISO"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Departamento:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@DEPTO"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Entre Calles:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@ENTRE_1"/>
									<xsl:if test="@ENTRE_1 != ''">
										<xsl:if test="@ENTRE_2 != ''">
											<xsl:text>
												&#160;y&#160;
											</xsl:text>
										</xsl:if>
									</xsl:if>
									<xsl:value-of select="@ENTRE_2"/>
								</p>
							</div>
						</div>
					</form>
				</div>
				<div class="col-md-6">
					<form class="form-horizontal form-fiscal">
						<div class="form-group">
							<label class="control-label">
								Pais/Prov/Loc:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@DES_PAIS"/>
									<xsl:text>
										&#160;-&#160;
									</xsl:text>
									<xsl:value-of select="@DES_PRO"/>
									<xsl:text>
										&#160;- &#160;
									</xsl:text>
									<xsl:value-of select="@DES_LOC"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								CP:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@C_POSTAL"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								TE particular:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@TE_1"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								TE Alternativo:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@TE_2"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Celular:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@CEL"/>
								</p>
							</div>
						</div>
						<div class="form-group">
							<label class="control-label">
								Partido:
							</label>
							<div>
								<p class="form-control-static">
									<xsl:value-of select="@PARTIDO"/>
								</p>
							</div>
						</div>
					</form>
				</div>
			</div>
		</xsl:template>
		<xsl:template match="DOMICILIOS">
			<a id="btn-fiscal" class="btn btn-primary btns-Domicilios" role="button" data-toggle="collapse" href="#collapseFiscal" aria-expanded="true" aria-controls="collapseFiscal">
				Domicilio Fiscal
			</a>
			<div class="collapse in" id="collapseFiscal">
				<div class="well divContent-fiscal">
					<xsl:apply-templates select="ROW"/>
				</div>
			</div>
		</xsl:template>
		<xsl:template name="BODY_CUSTOM">
			<input type="hidden" id="fiscal">
				<xsl:choose>
					<xsl:when test="PERSONAS/DOMICILIOS/@fiscal = 0">
						<xsl:attribute name="value">
							<xsl:text>
								-1
							</xsl:text>
						</xsl:attribute>
					</xsl:when>
					<xsl:otherwise>
						<xsl:attribute name="value">
							<xsl:value-of select="PERSONAS/DOMICILIOS/ROW/@OI_DOM"/>
						</xsl:attribute>
					</xsl:otherwise>
				</xsl:choose>
			</input>
			<xsl:choose>
				<xsl:when test="PERSONAS/DOMICILIOS/@fiscal = 0">
					<div class="sinFiscal">
						<h2>
							No se encontr&#243; un domicilio fiscal
						</h2>
						<h4>
							Si desea agregarlo elija la opci&#243;n correspondiente abajo e inicie la solicitud
						</h4>
					</div>
					<p class="warning text-center">
						<xsl:text>
							Aclaraci&#243;n: Por favor seleccione la opci&#243;n para
						</xsl:text>
						<span>
							&#160;AGREGAR un domicilio fiscal.
						</span>
					</p>
				</xsl:when>
				<xsl:otherwise>
					<div class="row wfDomicilios">
						<xsl:apply-templates select="PERSONAS/DOMICILIOS"/>
					</div>
					<p class="warning">
						<xsl:text>
							Aclaraci&#243;n: Por favor seleccione la opci&#243;n para
						</xsl:text>
						<span>
							&#160;EDITAR el domicilio fiscal.
						</span>
					</p>
				</xsl:otherwise>
			</xsl:choose>
		</xsl:template>
		<xsl:template name="JAVASCRIPT_CUSTOM">
			<script type="text/javascript">
				function SetParam(param,valor){
this.parent.SetParam(param,valor);
}

function SetMsgError(id_wf,msgError){
this.parent.SetMsgError(id_wf,msgError);
}

$(document).ready(function(){
var oi_domicilio_per = $("#fiscal").attr("value");
if(oi_domicilio_per != -1){
SetParam("oi_domicilio_per",oi_domicilio_per);
SetMsgError("DIRE_ALTA_DOMICILIO","No puede dar de alta un nuevo domicilio fiscal ya que tiene asignado uno");
}else{
SetMsgError("DIRE_PEDIDO_DIRECCION","No puede editar el domicilio fiscal ya que no tiene ninguno asignado");
}
});
			</script>
		</xsl:template>
		<xsl:template name="CSS_CUSTOM">
			#btn-fiscal{
margin-top: 10px;
}

.btns-domicilios{
width: 100%;
    text-align: left;
font-weight: 600;
margin-top: 1px;
}

.divContent-fiscal{
margin-bottom: 2px!important;
padding: 0px 19px;

}

form.form-fiscal div label{
margin-right: 7px;
float: left;
}

form.form-fiscal div.form-group{
margin-bottom: 0px;
margin-left: 0px;
}

.form-horizontal.form-fiscal{
margin-bottom: 0px;
}

.sinFiscal{
text-align: center;
color: #004A5F;
}

.sinFiscal h2{
font-weight: 600;
}

p.warning{
	color: red;
margin-top: 10px;
font-size: 16px;
}

p.warning span{
	font-weight: 600;
}
		</xsl:template>
	</html:xslt>
</html:html>
