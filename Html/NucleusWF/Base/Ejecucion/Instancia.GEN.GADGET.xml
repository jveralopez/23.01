<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doctype="HTML5" name="Texto de Instancia" doc="source">
	<html:query declare="&lt;PARAMS instance=&quot;5013&quot; text=&quot;Textos&quot; /&gt;" name="qry_report">
		<qry:main doc="SOURCE">
			<INSTANCE>
				<qry:attribute name="instance" value="#SOURCE:./@instance"/>
				<qry:attribute name="text" value="#SOURCE:./@text"/>
				<qry:insert-select name="INSTANCE" doc-path="."/>
			</INSTANCE>
		</qry:main>
		<qry:select doc="SOURCE" name="INSTANCE">
			<qry:xquery>
				for $r in method('NucleusWF.Base.Ejecucion.Instancias.INSTANCE:GenerateReportXML({$SOURCE/@instance},{\'\'},{$SOURCE/@text})')/REPORT
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="INSTANCE">
			<html>
				<head>
					<script src="../../../Scripts/generalFunctions.js" type="text/javascript">
						matias
					</script>
					<script src="../../../Scripts/nmdXML.js" type="text/javascript">
						matias
					</script>
					<script src="../../../Scripts/nmdWF.js" type="text/javascript">
						matias
					</script>
					<link rel="stylesheet" media="all" type="text/css" href="../../../Skins/_Default/styles/WIKI-common.css"/>
					<link rel="stylesheet" media="screen" type="text/css" href="../../../Skins/_Default/styles/WIKI-all.css"/>
					<link rel="stylesheet" media="print" type="text/css" href="../../../Skins/_Default/styles/WIKI-print.css"/>
					<script type="text/javascript">
						//
function Refresh()
{
	
	document.getElementById("dokuwiki").innerHTML=WikiToHTML(document.getElementById("wiki").value);
}
					</script>
				</head>
				<body scroll="no" style="height:100%;width:100%;">
					<xsl:choose>
						<xsl:when test="REPORT/@type='WIKI'">
							<xsl:attribute name="OnLoad">
								Refresh();
							</xsl:attribute>
							<div class="dokuwiki" id="dokuwiki">
								Cargando...
							</div>
							<textarea id="wiki" style="position:absolute;display:none;">
								<xsl:value-of select="REPORT"/>
							</textarea>
						</xsl:when>
						<xsl:otherwise>
							<pre class="TEXT">
								<xsl:value-of select="REPORT"/>
							</pre>
						</xsl:otherwise>
					</xsl:choose>
				</body>
			</html>
		</xsl:template>
		<xsl:template name="GADGET_PARAM">
			<param name="instance" label="Numero de Solicitud" type="STRING"/>
			<param name="text" label="Codigo de Texto " type="STRING"/>
		</xsl:template>
	</html:xslt>
</html:html>
