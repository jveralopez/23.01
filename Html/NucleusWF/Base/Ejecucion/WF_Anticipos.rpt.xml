<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusWF.Base.Ejecucion.WF_Anticipos.rpt" extends="NucleusWF.Base.Ejecucion.BaseInicioWF.rpt" doc="source">
	<html:query declare="&lt;PARAMS oi_usuario_sistema=&quot;acenci&quot;/&gt;">
		<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.QRY_INICIO_WFs"/>
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTER" doc-path="#SOURCE:PARAMS"/>
			<qry:element name="REPORTE">
				<qry:element name="PERSONAS">
					<qry:insert-select name="qry_DatosPersonales" doc-path="#SOURCE:PARAMS"/>
				</qry:element>
				<qry:element name="LEGAJOS">
					<qry:attribute name="cant_leg" value="0"/>
					<qry:insert-select name="qry_Legajos" doc-path=""/>
				</qry:element>
			</qry:element>
		</qry:main>
		<qry:select name="qry_Legajos" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
SELECT
LEG.e_numero_legajo,EMP.d_empresa,LEG.oi_personal_emp,EMP.oi_empresa

FROM
PER01_PERSONAL as PER,
PER02_PERSONAL_EMP as LEG,
ORG03_EMPRESAS as EMP

JOIN
PER.oi_personal INNER LEG.oi_personal,
LEG.oi_empresa INNER EMP.oi_empresa

WHERE
PER.oi_usuario_sistema = {#FILTER:@oi_usuario_sistema}

')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant_leg" value="@cant_leg + 1"/>
				<LEGAJO>
					<qry:attribute name="n_leg" value="../@cant_leg"/>
					<qry:attribute name="id_legajo" value="$r/@oi_personal_emp"/>
					<qry:attribute name="nombre_empresa" value="'Empresa ' + $r/@d_empresa"/>
					<qry:attribute name="num_legajo" value="'Leg. ' + $r/@e_numero_legajo"/>
					<qry:attribute name="empresa_legajo" value="@nombre_empresa + ' - ' + @num_legajo "/>
					<qry:attribute name="id_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="href" value="'#'+@id_empresa"/>
					<qry:attribute name="id_input_radio" value="'legajo_'+@id_legajo"/>
					<qry:attribute name="id_div_collapse" value="'heading_'+@id_legajo"/>
					<ANTICIPOS cant="0">
						<qry:insert-select name="qry_anticipos" doc-path="$r"/>
					</ANTICIPOS>
				</LEGAJO>
			</qry:out>
		</qry:select>
		<qry:select name="qry_anticipos" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
	MAXSIZE 5
        SELECT
        ANT.oi_anticipo,
        	ANT.c_estado,
        	ANT.n_importe,
ANT.e_cant_cuotas,
ANT.f_anticipo as  f_anticipo
FROM
LIQ07_ANTICIPOS as ANT
WHERE
ANT.oi_personal_emp = {%= #PARAM:@oi_personal_emp %}
ORDER BY
	f_anticipo ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant" value="@cant + 1"/>
				<ANTICIPO>
					<qry:attribute name="oi_anticipo" value="$r/@oi_anticipo"/>
					<qry:attribute name="importe" value="$r/@n_importe"/>
					<qry:attribute name="cuotas" value="$r/@e_cant_cuotas"/>
					<qry:attribute name="fecha" value="format_date($r/@f_anticipo,'dd/mm/yyyy')"/>
					<qry:switch test="$r/@c_estado">
						<qry:case value="S">
							<qry:attribute name="estado" value="'Solicitado'"/>
						</qry:case>
						<qry:case value="O">
							<qry:attribute name="estado" value="'Otorgado'"/>
						</qry:case>
						<qry:case value="L">
							<qry:attribute name="estado" value="'Liquidado'"/>
						</qry:case>
						<qry:case value="D">
							<qry:attribute name="estado" value="'Descontado'"/>
						</qry:case>
						<qry:case value="F">
							<qry:attribute name="estado" value="'Finalizado'"/>
						</qry:case>
						<qry:case value="C">
							<qry:attribute name="estado" value="'Cerrado'"/>
						</qry:case>
						<qry:case value="R">
							<qry:attribute name="estado" value="'Rechazado'"/>
						</qry:case>
					</qry:switch>
					<DETALLES cant="0">
						<qry:insert-select name="qry_detalle_anticipo" doc-path="$r"/>
					</DETALLES>
				</ANTICIPO>
			</qry:out>
		</qry:select>
		<qry:select name="qry_detalle_anticipo" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
SELECT
DET.e_cuota,
DET.f_descuento,
DET.n_importe
FROM 
LIQ07_DESC_ANTI as DET
WHERE
DET.oi_anticipo = {%= #PARAM:@oi_anticipo %}           			
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="cant" value="@cant + 1"/>
				<DETALLE>
					<qry:attribute name="cuota" value="$r/@e_cuota"/>
					<qry:attribute name="fecha" value="format_date($r/@f_descuento,'dd/mm/yyyy')"/>
					<qry:attribute name="importe" value="$r/@n_importe"/>
				</DETALLE>
			</qry:out>
		</qry:select>
	</html:query>
	<html:xslt>
		<xsl:template match="LEGAJO">
			<xsl:if test="@n_leg = 1">
				<input type="hidden" id="oi_personal_emp">
					<xsl:attribute name="value">
						<xsl:value-of select="@id_legajo"/>
					</xsl:attribute>
				</input>
			</xsl:if>
			<div class="panel panel-default">
				<div class="panel-heading pointer" role="button" data-toggle="collapse" data-parent="#accordion" aria-expanded="true" aria-controls="collapseOne" onclick="BlanquearParam2(this.id)">
					<xsl:attribute name="id">
						<xsl:value-of select="@id_div_collapse"/>
					</xsl:attribute>
					<xsl:attribute name="href">
						<xsl:value-of select="@href"/>
					</xsl:attribute>
					<h4 class="panel-title">
						<a>
							<xsl:attribute name="name">
								<xsl:value-of select="@id_input_radio"/>
							</xsl:attribute>
							<xsl:value-of select="@empresa_legajo"/>
						</a>
						<div class="radio-legajo">
							<input name="legajo" type="radio">
								<xsl:attribute name="id">
									<xsl:value-of select="@id_input_radio"/>
								</xsl:attribute>
								<xsl:choose>
									<xsl:when test="@n_leg = 1">
										<xsl:attribute name="checked">
											true
										</xsl:attribute>
									</xsl:when>
									<xsl:otherwise>
										<xsl:attribute name="disabled">
											true
										</xsl:attribute>
									</xsl:otherwise>
								</xsl:choose>
							</input>
						</div>
					</h4>
				</div>
				<div role="tabpanel" aria-expanded="false">
					<xsl:attribute name="id">
						<xsl:value-of select="@id_empresa"/>
					</xsl:attribute>
					<xsl:attribute name="aria-labelledby">
						<xsl:value-of select="@id_div_collapse"/>
					</xsl:attribute>
					<xsl:choose>
						<xsl:when test="@n_leg = 1">
							<xsl:attribute name="class">
								panel-collapse collapse in
							</xsl:attribute>
						</xsl:when>
						<xsl:otherwise>
							<xsl:attribute name="class">
								panel-collapse collapse
							</xsl:attribute>
						</xsl:otherwise>
					</xsl:choose>
					<div class="panel-body">
						<div id="panel-mis-anticipos" class="panel panel-primary">
							<div class="panel-heading">
								Anticipos
							</div>
							<xsl:choose>
								<xsl:when test="ANTICIPOS/@cant &gt; 0">
									<xsl:apply-templates select="ANTICIPOS/ANTICIPO"/>
								</xsl:when>
								<xsl:otherwise>
									<p class="sin-anticipo">
										No tiene anticipos
									</p>
								</xsl:otherwise>
							</xsl:choose>
						</div>
					</div>
				</div>
			</div>
		</xsl:template>
		<xsl:template name="BODY_CUSTOM">
			<div class="row wfAnticipos">
				<div class="panel-group" id="accordion" role="tablist" aria-multiselectable="false">
					<xsl:apply-templates select="LEGAJOS/LEGAJO"/>
				</div>
			</div>
		</xsl:template>
		<xsl:template name="JAVASCRIPT_CUSTOM">
			<script type="text/javascript">
				function SetParam(param,valor){
this.parent.SetParam(param,valor);
}

function BlanquearParam2(id){
var legajo = id.substr(8);

//Desabilito todos los radio y habilito solamente el que tengo seleccioanado
$("input[type=radio]").prop("disabled", true);
$("#legajo_"+legajo).prop("disabled", false);

//Selecciono el radio del legajo.
$("#legajo_"+legajo).prop("checked", true); 

//Seteo el valor del legajo que iniciara el WF
this.SetParam("oi_legajo",legajo);
}

$(document).ready(function(){
var oi_legajo = $("#oi_personal_emp").attr("value");
SetParam("oi_legajo",oi_legajo);
});
			</script>
		</xsl:template>
		<xsl:template name="CSS_CUSTOM">
			.wfAnticipos{
margin-top: 10px;
}

.radio-legajo{
float:right!important;
}

#panel-mis-anticipos{
width: 70%;
margin: auto;
} 

.table-anticipos .panel-heading {
font-weight: 600;
}

.table-anticipos thead tr  th, .table-anticipos tbody tr  td{
text-align: center;
}

.pointer{
cursor: pointer;
}

.table-responsive {
    overflow-x: unset;
    padding: 6px;
}

.table-anticipos thead tr{
background-color: #94C452;
}
.table-anticipos{
border: 1px solid #000!important;
}

.table-anticipos tbody tr{
background-color: #F5F5F5;
}

.table-anticipos td,.table-anticipos th{
    border: 1px solid #000!important;
    padding: 0px!important;
}

p.sin-anticipo{
text-align: center;
font-size: 20px;
color: #004A5F;
font-weight: bold;
padding: 9px 0px;
background-color: #f9f9f9;
margin-bottom: 0px;
}
		</xsl:template>
		<xsl:template match="ANTICIPO">
			<div class="table-responsive">
				<table class="table table-sm table-bordered table-anticipos">
					<thead>
						<tr>
							<th>
								Fecha
							</th>
							<th>
								Monto
							</th>
							<th>
								Estado
							</th>
							<th>
								Cuotas
							</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td>
								<xsl:value-of select="@fecha"/>
							</td>
							<td>
								<xsl:text>
									$
								</xsl:text>
								<xsl:value-of select="@importe"/>
							</td>
							<td>
								<xsl:value-of select="@estado"/>
							</td>
							<td>
								<xsl:value-of select="@cuotas"/>
							</td>
						</tr>
					</tbody>
					<thead>
						<tr>
							<th>
								Nro. Cuota
							</th>
							<th>
								Importe
							</th>
							<th>
								Fecha Desc.
							</th>
						</tr>
					</thead>
					<xsl:choose>
						<xsl:when test="DETALLES/@cant &gt; 0">
							<tbody>
								<xsl:apply-templates select="DETALLES/DETALLE"/>
							</tbody>
						</xsl:when>
						<xsl:otherwise>
							<tfoot>
								<tr>
									<td style="text-align:center;" colspan="3">
										No hay detalles del anticipo
									</td>
								</tr>
							</tfoot>
						</xsl:otherwise>
					</xsl:choose>
				</table>
			</div>
		</xsl:template>
		<xsl:template match="DETALLE">
			<tr>
				<td>
					<xsl:value-of select="@cuota"/>
				</td>
				<td>
					<xsl:text>
						$
					</xsl:text>
					<xsl:value-of select="@importe"/>
				</td>
				<td>
					<xsl:value-of select="@fecha"/>
				</td>
			</tr>
		</xsl:template>
	</html:xslt>
</html:html>
