<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" name="NucleusWF.Base.InstanciasPorVersionWF" extends="Nomad.Base.BaseReport.rpt" doc="source">
	<html:for-each declare="&lt;DATA oi_wf=&quot;303&quot; l_activas=&quot;0&quot; /&gt;">
		<qry:main doc="SOURCE">
			<qry:append-doc name="FILTRO" doc-path="$SOURCE/DATA"/>
			<REPORT>
				<qry:insert-select name="qry_WF_name" doc-path="$SOURCE/DATA"/>
				<qry:attribute value="format_date(now(), 'dd/mm/yyyy HH:MM')" name="date"/>
				<GROUPS>
					<GROUP tag="version" type="title">
						<COLS>
							<COL name="e_version" label="Versi&#243;n"/>
							<COL name="c_estado" label="Estado">
								<OPT value="Solo Depuraci&#243;n" id="D"/>
								<OPT value="Habilitado" id="R"/>
								<OPT value="Detenido" id="S"/>
								<OPT value="Pausado" id="P"/>
							</COL>
						</COLS>
						<GROUP tag="instancia" type="table">
							<COLS>
								<COL name="d_instance" label="Instancia"/>
								<COL name="c_estado_ej" label="Estado">
									<OPT value="Ejecutandose" id="R"/>
									<OPT value="Pausado" id="P"/>
									<OPT value="Detenido" id="S"/>
									<OPT value="Finalizado" id="F"/>
									<OPT value="Detenido por Error" id="E"/>
								</COL>
								<COL name="c_estado_wf" label="Estado WF">
									<qry:insert-select name="qry_dinamic_states" doc-path="$SOURCE/DATA"/>
									<!--OPT value="Iniciado" id="I"/>
									<OPT value="Solicitado" id="S"/>
									<OPT value="Detenido" id="A"/>
									<OPT value="rendisdfasd f" id="REN_DIF"/-->
								</COL>
								<COL name="f_inicio" label="Fecha de Inicio" style="text-align:center;"/>
								<COL name="f_fin" label="Fecha Fin" style="text-align:center;"/>
								<COL name="d_owner_ayn" label="Usuario de Inicio"/>
								<qry:insert-select name="qry_dinamic_columns" doc-path="$SOURCE/DATA"/>
							</COLS>
						</GROUP>
					</GROUP>
				</GROUPS>
				<DATA>
					<qry:insert-select name="qry_WKF" doc-path="$SOURCE/DATA"/>
				</DATA>
			</REPORT>
		</qry:main>
		<qry:select name="qry_WKF" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			     SELECT 
			     	WF.oi_wf,
			     	WF.e_version,
			     	WF.c_estado
			     FROM 
			     	WRK01_WF AS WF
			     WHERE 
			     	WF.c_wf in (SELECT WF2.c_wf FROM WRK01_WF AS WF2 WHERE WF2.oi_wf = {%=$PARAM/@oi_wf%}) 
					 ORDER BY e_version ASC 								 
		  ')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<version qry-delete-child="1">
					<qry:attribute name="e_version" value="$r/@e_version"/>
					<qry:attribute name="c_estado" value="$r/@c_estado"/>
					<qry:call>
						<PARAM>
							<qry:attribute name="oi_wf" value="$r/@oi_wf"/>
							<qry:attribute name="l_activas" value="$FILTRO/@l_activas"/>
						</PARAM>
					</qry:call>
				</version>
			</qry:out>
		</qry:select>
		<qry:select name="qry_WF_name" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			     SELECT 
			     	WF.c_wf,
			     	WF.d_wf
			     FROM 
			     	WRK01_WF AS WF
			     WHERE 
			     	WF.oi_wf = {$PARAM/@oi_wf}
		  ')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="label" value="Concat('Instancias del Workflow [', $r/@c_wf, '] ',$r/@d_wf)"/>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dinamic_columns" doc="PARAM">
			<qry:xquery>
				for $r in SQL('SELECT 
												V.oi_var,
												V.c_type,
												V.d_var,
												V.c_column,
												V.c_column_desc
										FROM WRK01_GROUPS as G,
												 WRK01_VARS as V
										JOIN G.oi_var_group INNER V.oi_var_group
										WHERE G.oi_wf = {$PARAM/@oi_wf}	
													AND G.c_mode = \'MAIN\'
													AND V.l_show_console = 1 
													
		 ')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<COL>
					<qry:attribute name="label" value="$r/@d_var"/>
					<qry:switch test="$r/@c_type">
						<qry:case value="fk">
							<qry:attribute name="name" value="$r/@c_column_desc"/>
							<qry:attribute name="style" value="'text-align:left;'"/>
						</qry:case>
						<qry:case value="date">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:center;'"/>
						</qry:case>
						<qry:case value="bool">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:center;'"/>
							<OPT id="0" value="No"/>
							<OPT id="1" value="Si"/>
						</qry:case>
						<qry:case value="int">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:right;'"/>
						</qry:case>
						<qry:case value="double">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:right;'"/>
						</qry:case>
						<qry:case value="string">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:left;'"/>
						</qry:case>
						<qry:case value="text">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:left;'"/>
						</qry:case>
						<qry:case value="file">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:center;'"/>
						</qry:case>
						<qry:case value="enum">
							<qry:attribute name="name" value="$r/@c_column"/>
							<qry:attribute name="style" value="'text-align:left;'"/>
							<qry:insert-select name="qry_enum_dinamic_colums" doc-path="$r"/>
						</qry:case>
					</qry:switch>
				</COL>
			</qry:out>
		</qry:select>
		<qry:select name="qry_dinamic_states" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('   
			SELECT E.c_estado,
						 E.d_estado
			FROM 
			WRK01_ESTADOS AS E
			WHERE E.oi_wf = {$PARAM/@oi_wf}
			 
			 ')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<OPT>
					<qry:attribute name="value" value="$r/@d_estado"/>
					<qry:attribute name="id" value="$r/@c_estado"/>
				</OPT>
			</qry:out>
		</qry:select>
		<qry:select name="qry_enum_dinamic_colums" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('   
			SELECT VC.c_var_combo,
						 VC.d_var_combo
			FROM WRK01_VARS_COMBO  AS VC
			WHERE  VC.oi_var = {$PARAM/@oi_var}
			 
			 ')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<OPT>
					<qry:attribute name="value" value="$r/@d_var_combo"/>
					<qry:attribute name="id" value="$r/@c_var_combo"/>
				</OPT>
			</qry:out>
		</qry:select>
	</html:for-each>
	<html:query declare="&lt;PARAM oi_wf=&quot;303&quot;/&gt;&#13;&#10;">
		<qry:main name="" doc="PARAM">
			<qry:no-show>
				<qry:insert-select name="QRY_Instancias" doc-path="#PARAM:PARAM"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="QRY_Instancias" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			SELECT 
						 I.oi_instance,
						 I.oi_wf,
						 I.d_instance,
						 I.c_estado_ej,
						 I.f_inicio,
						 I.f_fin,
						 I.d_owner_ayn,
						 G.c_var_group,
						 I.c_estado_wf
						 
			FROM WRK02_INSTANCES AS I,
   				 WRK01_GROUPS as G
   				 
   				 
 			JOIN
 			I.oi_wf INNER G.oi_wf
 			
			WHERE 1=1
			AND  I.oi_wf = {$PARAM/@oi_wf} 
			{%? ($PARAM/@l_activas=1)
				{%AND I.c_estado_ej = \'R\'  %}
				{% %}
			%}
			AND G.c_mode = \'MAIN\'
			')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="instancia">
					<qry:attribute name="d_instance" value="$r/@d_instance"/>
					<qry:attribute name="c_estado_ej" value="$r/@c_estado_ej"/>
					<qry:switch test="$r/@c_estado_ej">
						<qry:case value="R">
							<OPT id="R" value="Ejecutandose"/>
						</qry:case>
						<qry:case value="P">
							<OPT value="Pausado" id="P"/>
						</qry:case>
						<qry:case value="S">
							<OPT value="Detenido" id="S"/>
						</qry:case>
						<qry:case value="F">
							<OPT value="Finalizado" id="F"/>
						</qry:case>
						<qry:case value="E">
							<OPT value="Detenido por Error" id="E"/>
						</qry:case>
					</qry:switch>
					<!--Estados condicionales  >
				<qry:if test="$r/@c_estado_ej='R'">
					<qry:then>
						<qry:attribute name="c_estado_ej" value="'Ejecuci&#243;n'"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@c_estado_ej='P'">
					<qry:then>
						<qry:attribute name="c_estado_ej" value="'Pausado'"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@c_estado_ej='S'">
					<qry:then>
						<qry:attribute name="c_estado_ej" value="'Detenido'"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@c_estado_ej='F'">
					<qry:then>
						<qry:attribute name="c_estado_ej" value="'Finalizado'"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@c_estado_ej='E'">
					<qry:then>
						<qry:attribute name="c_estado_ej" value="'Detenido por Error'"/>
					</qry:then>
				</qry:if-->
					<qry:attribute name="f_inicio" value="format_date($r/@f_inicio,'dd/mm/yyyy')"/>
					<qry:attribute name="f_fin" value="format_date($r/@f_fin,'dd/mm/yyyy')"/>
					<qry:attribute name="d_owner_ayn" value="$r/@d_owner_ayn"/>
					<qry:attribute name="c_estado_wf" value="$r/@c_estado_wf"/>
					<qry:insert-select name="qry_Value_Instance" doc-path="$r"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="qry_Value_Instance" doc="PARAM">
			<qry:xquery>
				for $r in SQL
			('
			SELECT 	
					 V.oi_value,
					 V.e_valor_1,
					 V.e_valor_2,
					 V.e_valor_3,
					 V.e_valor_4,
					 V.e_valor_5,
					 V.c_valor_1,
					 V.c_valor_2,
					 V.c_valor_3,
					 V.c_valor_4,
					 V.c_valor_5,
					 V.n_valor_1,
					 V.n_valor_2,
					 V.n_valor_3,
					 V.d_valor_1,
					 V.d_valor_2,
					 V.d_valor_3,
					 V.o_valor_1,
					 V.o_valor_2,
					 V.oi_file_valor_1,
					 V.oi_file_valor_2,
					 V.c_valor_6,
					 V.c_valor_7,
					 V.c_valor_8,
					 V.c_valor_9,
			 		 V.c_valor_10
			 
	FROM WRK02_VALS AS V,
		 WRK02_INSTANCES AS I,
		 WRK01_GROUPS AS G
		  
		 
	JOIN
			V.oi_instance INNER I.oi_instance,
			V.c_var_group INNER G.c_var_group
			
			  
	WHERE G.c_mode = \'MAIN\'
				AND I.oi_instance = {$PARAM/@oi_instance}    
			')
			/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_value" value="$r/@oi_value"/>
				<qry:attribute name="e_valor_1" value="$r/@e_valor_1"/>
				<qry:attribute name="e_valor_2" value="$r/@e_valor_2"/>
				<qry:attribute name="e_valor_3" value="$r/@e_valor_3"/>
				<qry:attribute name="e_valor_4" value="$r/@e_valor_4"/>
				<qry:attribute name="e_valor_5" value="$r/@e_valor_5"/>
				<qry:attribute name="c_valor_1" value="$r/@c_valor_1"/>
				<qry:attribute name="c_valor_2" value="$r/@c_valor_2"/>
				<qry:attribute name="c_valor_3" value="$r/@c_valor_3"/>
				<qry:attribute name="c_valor_4" value="$r/@c_valor_4"/>
				<qry:attribute name="c_valor_5" value="$r/@c_valor_5"/>
				<qry:if test="$r/@n_valor_1!=''">
					<qry:then>
						<qry:attribute name="n_valor_1" value="format-number($r/@n_valor_1,0,2,',','','')"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@n_valor_2!=''">
					<qry:then>
						<qry:attribute name="n_valor_2" value="format-number($r/@n_valor_2,0,2,',','','')"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@n_valor_3!=''">
					<qry:then>
						<qry:attribute name="n_valor_3" value="format-number($r/@n_valor_3,0,2,',','','')"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@d_valor_1!=''">
					<qry:then>
						<qry:attribute name="d_valor_1" value="format-date($r/@d_valor_1,'dd/mm/yyyy')"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@d_valor_2!=''">
					<qry:then>
						<qry:attribute name="d_valor_2" value="format-date($r/@d_valor_2,'dd/mm/yyyy')"/>
					</qry:then>
				</qry:if>
				<qry:if test="$r/@d_valor_3!=''">
					<qry:then>
						<qry:attribute name="d_valor_3" value="format-date($r/@d_valor_3,'dd/mm/yyyy')"/>
					</qry:then>
				</qry:if>
				<qry:attribute name="o_valor_1" value="$r/@o_valor_1"/>
				<qry:attribute name="o_valor_2" value="$r/@o_valor_2"/>
				<qry:if test="$r/@oi_file_valor_1!=''">
					<qry:then>
						<qry:attribute name="oi_file_valor_1" value="'SI'"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="oi_file_valor_1" value="'NO'"/>
					</qry:else>
				</qry:if>
				<qry:if test="$r/@oi_file_valor_2!=''">
					<qry:then>
						<qry:attribute name="oi_file_valor_2" value="'SI'"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="oi_file_valor_2" value="'NO'"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="c_valor_6" value="$r/@c_valor_6"/>
				<qry:attribute name="c_valor_7" value="$r/@c_valor_7"/>
				<qry:attribute name="c_valor_8" value="$r/@c_valor_8"/>
				<qry:attribute name="c_valor_9" value="$r/@c_valor_9"/>
				<qry:attribute name="c_valor_10" value="$r/@c_valor_10"/>
			</qry:out>
		</qry:select>
	</html:query>
</html:html>
