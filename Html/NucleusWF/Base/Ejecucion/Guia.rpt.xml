					</style>
					<script languaje="javascript">
						function accept(val)
					{
							parent.Ctrl('hid_val').SetXValue(val.getAttribute('nmd-val'));
							parent.Ctrl('main').DoEvent('ACCEPT');							
				 	}
				 	
				 	var lastTR=null;
					function overTR(ele)
					{
							if (lastTR!=null)
								lastTR.className="TABLE_LOG_TR";
								
							lastTR=ele;
							
							lastTR.className="TABLE_LOG_TR_HI";
				 	}
					</script>
				</head>
				<body>
					<div id="table_log" name="table_log">
						<table CELLPADDING="0" CELLSPACING="0" class="TABLE_LOG" border="1">
							<xsl:for-each select="CAB">
								<col>
									<xsl:attribute name="width">
										<xsl:value-of select="@width"/>
									</xsl:attribute>
								</col>
							</xsl:for-each>
							<tr height="20px">
								<xsl:for-each select="CAB">
									<th class="TABLE_LOG_TH" style="text-align:center;">
										<xsl:value-of select="@label"/>
									</th>
								</xsl:for-each>
							</tr>
							<xsl:for-each select="ROW">
								<xsl:variable name="current_row" select="."/>
								<tr class="TABLE_LOG_TR" onmouseover="overTR(this);">
									<xsl:for-each select="../CAB">
										<xsl:variable name="current_col" select="."/>
										<td class="TABLE_LOG_TD" onclick="accept(this);" style="cursor:pointer;">
											<xsl:attribute name="nmd-val">
												<xsl:value-of select="$current_row/@VAL"/>
											</xsl:attribute>
											<xsl:attribute name="style">
												<xsl:value-of select="$current_col/@style"/>
											</xsl:attribute>
											<xsl:if test="$current_col/@type='datetime'">
												<xsl:call-template name="FormatDate">
													<xsl:with-param name="DateTime" select="$current_row/attribute::*[name() = $current_col/@name]"/>
												</xsl:call-template>
											</xsl:if>
											<xsl:if test="$current_col/@type='bool'">
												<xsl:call-template name="Boolean">
													<xsl:with-param name="bool" select="$current_row/attribute::*[name() = $current_col/@name]"/>
												</xsl:call-template>
											</xsl:if>
											<xsl:if test="$current_col/@type='int'">
												<xsl:value-of select="$current_row/attribute::*[name() = $current_col/@name]"/>
											</xsl:if>
											<xsl:if test="$current_col/@type='string'">
												<xsl:value-of select="$current_row/attribute::*[name() = $current_col/@name]"/>
											</xsl:if>
											<xsl:if test="$current_col/@type='num'">
												<xsl:call-template name="Double">
													<xsl:with-param name="num" select="$current_row/attribute::*[name() = $current_col/@name]"/>
												</xsl:call-template>
											</xsl:if>
										</td>
									</xsl:for-each>
								</tr>
							</xsl:for-each>
						</table>
					</div>
				</body>
			</html>
		</xsl:template>
		<xsl:template name="FormatDate">
			<xsl:param name="DateTime"/>
			<xsl:variable name="year">
				<xsl:value-of select="substring($DateTime,1,4)"/>
			</xsl:variable>
			<xsl:variable name="month">
				<xsl:value-of select="substring($DateTime,5,2)"/>
			</xsl:variable>
			<xsl:variable name="day">
				<xsl:value-of select="substring($DateTime,7,2)"/>
			</xsl:variable>
			<xsl:variable name="time">
				<xsl:value-of select="substring-after($DateTime,' ')"/>
			</xsl:variable>
			<xsl:variable name="hour">
				<xsl:value-of select="substring($time,1,2)"/>
			</xsl:variable>
			<xsl:variable name="min">
				<xsl:value-of select="substring($time,4,2)"/>
			</xsl:variable>
			<xsl:variable name="sec">
				<xsl:value-of select="substring($time,7,2)"/>
			</xsl:variable>
			<xsl:value-of select="$day"/>
			<xsl:value-of select="'/'"/>
			<xsl:value-of select="$month"/>
			<xsl:value-of select="'/'"/>
			<xsl:value-of select="$year"/>
			<xsl:if test="$time!=''">
				<xsl:value-of select="' '"/>
				<xsl:value-of select="$hour"/>
				<xsl:value-of select="':'"/>
				<xsl:value-of select="$min"/>
				<xsl:value-of select="':'"/>
				<xsl:value-of select="$sec"/>
			</xsl:if>
		</xsl:template>
		<xsl:template name="Boolean">
			<xsl:param name="bool"/>
			<xsl:if test="$bool='0'">
				No
			</xsl:if>
			<xsl:if test="$bool='1'">
				Si
			</xsl:if>
		</xsl:template>
		<xsl:template name="Double">
			<xsl:param name="num"/>
			<xsl:variable name="entero">
				<xsl:if test="not(contains($num,'.'))">
					<xsl:value-of select="$num"/>
				</xsl:if>
				<xsl:if test="contains($num,'.')">
					<xsl:value-of select="substring-before($num,'.')"/>
				</xsl:if>
			</xsl:variable>
			<xsl:variable name="decimal">
				<xsl:if test="not(contains($num,'.'))">
					<xsl:value-of select="substring('00',1,2)"/>
				</xsl:if>
				<xsl:if test="contains($num,'.')">
					<xsl:value-of select="substring(concat(substring-after($num,'.'),'00'),1,2)"/>
				</xsl:if>
			</xsl:variable>
			<xsl:if test="$entero!=''">
				<xsl:value-of select="concat($entero,'.',$decimal)"/>
			</xsl:if>
			<xsl:if test="$entero=''">
				<xsl:value-of select="concat('0.',$decimal)"/>
			</xsl:if>
		</xsl:template>
	</html:xslt>
</html:html>
