	<html:query declare="&lt;GUIA search=&quot;2008&quot;&gt;&#13;&#10;&#9;&lt;COLUMNS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;COLUMN name=&quot;VAL&quot; label=&quot;Valor&quot; type=&quot;int&quot; /&gt;&#13;&#10;&#9;&#9;&lt;COLUMN name=&quot;DES&quot; label=&quot;Empresa&quot; type=&quot;string&quot; show=&quot;1&quot; /&gt;&#13;&#10;&#9;&#9;&lt;COLUMN name=&quot;FECHA&quot; label=&quot;Fecha&quot; type=&quot;datetime&quot; show=&quot;1&quot;/&gt;&#13;&#10;&#9;&#9;&lt;COLUMN name=&quot;IMP&quot; label=&quot;Importe&quot; type=&quot;double&quot; show=&quot;1&quot;/&gt;&#13;&#10;&#9;&lt;/COLUMNS&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;25994&quot; DES=&quot;FV(A) 0001-00000005&quot; FECHA=&quot;20060328&quot; IMP=&quot;463.43&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;51630&quot; DES=&quot;FV(A) 0001-00000122&quot; FECHA=&quot;20071221&quot; IMP=&quot;544.5&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;52716&quot; DES=&quot;FV(A) 0001-00000130&quot; FECHA=&quot;20080114&quot; IMP=&quot;544&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;55975&quot; DES=&quot;FV(A) 0001-00000155&quot; FECHA=&quot;20080328&quot; IMP=&quot;272.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;57411&quot; DES=&quot;NC(A) 0001-00000057&quot; FECHA=&quot;20080331&quot; IMP=&quot;272.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;57426&quot; DES=&quot;FV(A) 0001-00000067&quot; FECHA=&quot;20080331&quot; IMP=&quot;272.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;61349&quot; DES=&quot;FV(A) 0001-00000106&quot; FECHA=&quot;20080731&quot; IMP=&quot;635.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;62245&quot; DES=&quot;FV(A) 0001-00000114&quot; FECHA=&quot;20080829&quot; IMP=&quot;635.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;63646&quot; DES=&quot;FV(A) 0001-00000125&quot; FECHA=&quot;20080930&quot; IMP=&quot;635.25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW VAL=&quot;83729&quot; DES=&quot;FV(A) 0002-00000204&quot; FECHA=&quo