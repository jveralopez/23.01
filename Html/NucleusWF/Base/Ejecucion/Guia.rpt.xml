		<qry:main doc="SOURCE">
			<ROWS>
				<qry:append-doc name="SEARCH" doc-path="#SOURCE:"/>
				<qry:insert-select name="CABECERA" doc-path="#SOURCE:GUIA/COLUMNS"/>
				<qry:insert-select name="QUERY" doc-path="."/>
				<qry:append-doc name="COLUMNAS" doc-path="."/>
				<qry:insert-select name="DATOS" doc-path="#SOURCE:GUIA/ROWS"/>
			</ROWS>
		</qry:main>
		<qry:select doc="SOURCE" name="CABECERA">
			<qry:xquery>
				for $r in #SOURCE:COLUMN[@show=1]
			</qry:xquery>
			<qry:out>
				<CAB>
					<qry:attribute name="label" value="$r/@label"/>
					<qry:attribute name="name" value="$r/@name"/>
					<qry:attribute name="width" value="iif($r/@type='int','30px','250px' )"/>
					<qry:switch test="$r/@type">
						<qry:case value="int">
							<qry:attribute name="width" value="'50px'"/>
							<qry:attribute name="style" value="'text-align:right;cursor:pointer;'"/>
							<qry:attribute name="type" value="'int'"/>
						</qry:case>
						<qry:case value="string">
							<qry:attribute name="width" value="'300px'"/>
							<qry:attribute name="style" value="'text-align:left;cursor:pointer;'"/>
							<qry:attribute name="type" value="'string'"/>
						</qry:case>
						<qry:case value="bool">
							<qry:attribute name="width" value="'50px'"/>
							<qry:attribute name="style" value="'text-align:center;cursor:pointer;'"/>
							<qry:attribute name="type" value="'bool'"/>
						</qry:case>
						<qry:case value="double">
							<qry:attribute name="width" value="'150px'"/>
							<qry:attribute name="style" value="'text-align:right;cursor:pointer;'"/>
							<qry:attribute name="type" value="'num'"/>
						</qry:case>
						<qry:case value="datetime">
							<qry:attribute name="width" value="'100px'"/>
							<qry:attribute name="style" value="'text-align:center;cursor:pointer;'"/>
							<qry:attribute name="type" value="'datetime'"/>
						</qry:case>
					</qry:switch>
				</CAB>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="DATOS">
			<qry:xquery>
				for $r in #SOURCE:ROW[1=1
			{%? (string(#SEARCH:GUIA/@search) !='') 
				{% AND ({%=substring(#COLUMNAS:@query, 4)%}) %} 
				{%  %} 
			%}]
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="SOURCE" name="QUERY">
			<qry:xquery>
				for $r in #SOURCE:CAB
			</qry:xquery>
			<qry:out>
				<qry:attribute name="name" value="$r/@name"/>
				<qry:attribute name="type" value="' OR contains(upper_case(@'+@name+'), upper_case(#SEARCH:GUIA/@search))'"/>
				<qry:attribute name="query" value="@type+@query"/>
			</qry:out>
		</qry:select>
	</html:query>
