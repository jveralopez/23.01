<html:html xmlns:html="nomad_engine.html" xmlns:qry="nomad_engine.qry" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Organizacion.Organigrama.rpt" doc="source">
	<html:query declare="&lt;PARAMS Gwidth=&quot;250&quot; Gheight=&quot;240&quot; Gcut=&quot;1&quot; Gcolor=&quot;FF0000&quot; /&gt;">
		<qry:main doc="PARAM">
			<IMG>
				<qry:attribute name="width" value="#PARAM:/PARAMS/@Gwidth"/>
				<qry:attribute name="height" value="#PARAM:/PARAMS/@Gheight"/>
				<qry:attribute name="color" value="#PARAM:/PARAMS/@Gcolor"/>
				<qry:attribute name="cut" value="#PARAM:/PARAMS/@Gcut"/>
			</IMG>
		</qry:main>
	</html:query>
	<html:xslt>
		<xsl:template match="IMG">
			<graph>
				<xsl:attribute name="height">
					<xsl:value-of select="@height"/>
				</xsl:attribute>
				<xsl:attribute name="width">
					<xsl:value-of select="@width"/>
				</xsl:attribute>
				<functions>
					<function id="DrawNode">
						<shape>
							<start-point top="10" left="0"/>
							<line top="5" left="2"/>
							<line top="2" left="5"/>
							<line top="0" left="10"/>
							<line top="0" right="10"/>
							<line top="2" right="5"/>
							<line top="5" right="2"/>
							<line top="10" right="0"/>
							<line bottom="10" right="0"/>
							<line bottom="5" right="2"/>
							<line bottom="2" right="5"/>
							<line bottom="0" right="10"/>
							<line bottom="0" left="10"/>
							<line bottom="2" left="5"/>
							<line bottom="5" left="2"/>
							<line bottom="10" left="0"/>
							<line/>
						</shape>
					</function>
				</functions>
				<palettes>
					<palette id="default">
						<xsl:choose>
							<xsl:when test="@cut='1'">
								<style id="default" pen-width="2" pen-color="#888888" pen-type="Dot" brush-type="gradient" brush-color2="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="-10" brush-right="-10">
									<xsl:attribute name="brush-color">
										<xsl:value-of select="concat('#',@color)"/>
									</xsl:attribute>
								</style>
							</xsl:when>
							<xsl:otherwise>
								<style id="default" pen-width="1" pen-color="#888888" pen-type="Solid" brush-type="gradient" brush-color2="#FFFFFF" brush-top="-10" brush-bottom="-10" brush-left="-10" brush-right="-10">
									<xsl:attribute name="brush-color">
										<xsl:value-of select="concat('#',@color)"/>
									</xsl:attribute>
								</style>
							</xsl:otherwise>
						</xsl:choose>
					</palette>
				</palettes>
				<main-area palette="default" style="default">
					<function id="DrawNode" left="1" right="1" top="1" bottom="1"/>
				</main-area>
			</graph>
		</xsl:template>
	</html:xslt>
</html:html>
