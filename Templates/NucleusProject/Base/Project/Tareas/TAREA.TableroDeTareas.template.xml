<templates name="TableroDeTareas" DEFAULT_ACTION="FILTER">
	<template file="TableroDeTareas.STD_REP" type="flow" template="Nomad.STD_REP.template.flow" name="STD_REP">
		<cfg type="HTML" report="NucleusProject.Base.Project.PizarraScrumTarea.rpt" fform="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.autoform" title="Pizarra Scrum de Tareas">
			<DATA oi_proyecto=""/>
		</cfg>
	</template>
	<template-STD_FIL name="TableroDeTareas" type="form" template="Nomad.STD_FIL.template.form">
		<cfg title="Filtrar Tareas de la Pizarra Scrum">
			<ctrl label="Recurso:" resource="NucleusProject.Base.Project.Recursos.RECURSO.INFO" req="0" show="scombo" nvalue="#source:@oi_recurso" name="oi_recurso"/>
			<ctrl resource="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO_TIPO_PROYECTO" label="Proyecto:" req="0" show="scombo" nvalue="#source:@oi_proyecto" name="oi_proyecto"/>
			<ctrl label="Fecha Desde:" req="0" show="date" nvalue="#source:@fecha_desde" name="fecha_desde"/>
			<ctrl label="Fecha Hasta:" req="0" show="date" nvalue="#source:@fecha_hasta" name="fecha_hasta"/>
		</cfg>
		<scripts/>
	</template-STD_FIL>
</templates>
