<templates name="MAIN">
	<template-STD_REP name="MAIN" type="flow" template="Nomad.STD_REP.template.flow">
		<cfg type="HTML" report="NucleusProject.Base.Project.TareasPorPerfil.rpt">
			<DATA/>
		</cfg>
	</template-STD_REP>
	<template-STD_FIL name="MAIN">
		<cfg>
			<ctrl label="Fecha desde" req="1" show="date" name="f_desde"/>
			<ctrl label="Fecha hasta" req="1" show="date" name="f_hasta"/>
			<ctrl nvalue="#source:@oi_perfil" req="0" resource="NucleusProject.Base.Project.Perfiles.PERFIL.INFO" label="Perfil" show="scombo" name="oi_perfil"/>
			<ctrl label="Mostrar detalles de tareas" show="check" name="detalle_tarea"/>
		</cfg>
		<scripts/>
	</template-STD_FIL>
</templates>
