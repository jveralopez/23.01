<templates DEFAULT_ACTION="LIST" name="MAIN">
	<template-STD_LIST name="MAIN">
		<cfg lock="0" maxreg="100" autoload="1" search="2" seg="0" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col show="string_short" name="c_evento"/>
			<col show="string_med" name="d_evento"/>
			<col show="string_med" name="oi_escala"/>
			<col name="oi_tipo_eval" show="string_med"/>
			<col show="string_med" name="oi_clase_org"/>
			<col name="c_estado" show="enum"/>
			<col name="f_desde" show="date"/>
			<col name="f_hasta" show="date"/>
			<col name="f_cierre" show="date"/>
			<child flow="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.MAIN.STD.flow:ADMINISTRAR" label="Administrar Legajos" name="ADMINISTRAR" flags="2"/>
			<child flow="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.MAIN.STD.flow:DESHABILITAR" mess="&#191;Esta seguro que desea Deshabilitar el Evento Evaluativo?" label="Deshabilitar" name="DESHABILITAR" flags="2"/>
			<child mess="&#191;Esta seguro que desea Habilitar el Evento Evaluativo?" flow="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.MAIN.STD.flow:HABILITAR" label="Habilitar" name="HABILITAR" flags="2"/>
			<child flow="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.MAIN.STD.flow:CERRAR" label="Cerrar" name="CERRAR" flags="2"/>
			<group name="FILTER" type="none">
				<ctrl label="C&#243;digo/Descripci&#243;n" descr="Buscar en c&#243;digo o descripci&#243;n" req="0" show="string_med" nvalue="#source:@text" name="d_text"/>
				<ctrl req="0" nvalue="#source:@c_estado" show="enum" name="c_estado"/>
				<ctrl nvalue="#source:@oi_tipo_eval" req="0" show="scombo" name="oi_tipo_eval"/>
			</group>
			<child name="PLANTILLAS" flow="NucleusRH.Base.Evaluacion2.Eventos.PLANTILLA.MAIN.STD.autoflow" flags="2"/>
			<child name="ETAPAS" flow="NucleusRH.Base.Evaluacion2.Eventos.ETAPA.MAIN.STD.autoflow" flags="2"/>
		</cfg>
		<scripts>
			function CheckEnabledButton(name)
{
	switch(name)
	{
		case "EDIT":   
		case "ADMINISTRAR":  
			return Ctrl("LIST").GetSelectAttrValue("c_estado")!="C";
			
		case "DESHABILITAR":                                     
			return Ctrl("LIST").GetSelectAttrValue("c_estado")=="H";

		case "HABILITAR":                                     
			return Ctrl("LIST").GetSelectAttrValue("c_estado")=="I";

		case "CERRAR":                                     
			return Ctrl("LIST").GetSelectAttrValue("c_estado")=="H" &amp;&amp; Ctrl("LIST").GetSelectAttrValue("c_estado")!="C";

		case "DELETE":
			return Ctrl("LIST").GetSelectAttrValue("c_estado")=="A";
	}

	return true;
}
		</scripts>
	</template-STD_LIST>
	<template-STD name="MAIN">
		<cfg eve-save="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.SAVE" data-resource="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.INFO_DATA" load-ddo-full="0" add="1" filter="0">
			<attach new="0" doc="PLANTILLAS" show="1" edit="0" list="0"/>
			<attach new="0" doc="ETAPAS" show="1" edit="0" list="0"/>
		</cfg>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg object-resource="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.INFO_IDS_LIST" seg="0" del="1" edit="1" add="1" refresh="1">
			<ctrl enable="1" show="string_short" name="c_evento"/>
			<ctrl enable="1" show="string_med" name="d_evento"/>
			<ctrl enable="1" show="scombo" name="oi_escala"/>
			<ctrl enable="2" show="scombo" name="oi_tipo_eval"/>
			<ctrl enable="1" show="scombo" name="oi_clase_org"/>
			<ctrl name="c_estado" enable="0" show="enum"/>
			<ctrl name="f_desde" enable="1" show="date"/>
			<ctrl name="f_hasta" enable="1" show="date"/>
			<ctrl name="f_cierre" enable="0" show="date"/>
			<ctrl enable="1" show="string_large" name="o_evento"/>
			<group width="90%" label="Plantillas Definidas" visible="SHOW" name="PLANTILLAS" type="tab">
				<list del="0" edit="1" add="0" list-resource="NucleusRH.Base.Evaluacion2.Eventos.PLANTILLA.INFO_IDS_LIST" label="Plantillas" visible="SHOW" name="PLANTILLAS" width="100%">
					<col label="Plantilla" order="1" show="string_med" name="oi_plantilla_def"/>
					<col label="Escala" order="1" show="string_med" name="oi_escala"/>
					<col label="Escala Items" name="oi_escala_item" order="1" show="string_med"/>
					<col label="Escala Subitems" name="oi_escala_subitem" order="1" show="string_med"/>
					<col label="Ponderaci&#243;n" order="1" show="number_2" name="n_ponderacion"/>
					<col label="Habilitada" order="0" show="check" name="l_habilitada"/>
					<button flag="1" flow="NucleusRH.Base.Evaluacion2.Eventos.PLANTILLA.MAIN.STD.autoflow:EDIT" img="application_edit.gif" name="EDT_PLANTILLA" label="Modificar" descr="Modificar la Plantilla"/>
				</list>
			</group>
			<group width="90%" label="Etapas Definidas" visible="SHOW" name="ETAPAS" type="tab">
				<list del="1" edit="1" add="1" list-resource="NucleusRH.Base.Evaluacion2.Eventos.ETAPA.INFO_IDS_LIST" lock="0" label="Etapas" visible="SHOW" name="ETAPAS" width="100%">
					<col label="C&#243;digo" show="string_short" name="c_etapa"/>
					<col label="Descripci&#243;n" show="string_med" name="d_etapa"/>
					<col label="Estado Evento" name="c_estado_evento" show="enum">
						<enum-value value="A" label="Abierto"/>
						<enum-value value="I" label="Inicializado"/>
						<enum-value value="H" label="Habilitado"/>
						<enum-value value="C" label="Cerrado"/>
					</col>
					<col label="Estado Evaluacion" name="c_estado_eval" show="enum">
						<enum-value label="Abierta" value="AB"/>
						<enum-value label="Habilitada" value="HA"/>
						<enum-value label="Evaluada" value="EV"/>
						<enum-value label="Confirmada" value="CO"/>
						<enum-value label="Anulada" value="AN"/>
						<enum-value label="Aprobada" value="AP"/>
						<enum-value label="Rechazada" value="RZ"/>
						<enum-value label="Cerrada" value="CE"/>
					</col>
					<col label="Habilitado" show="check" name="l_habilitado"/>
					<col label="Fecha Inicio" show="date" name="f_inicio"/>
					<col label="Rol Habilitado" show="enum" name="c_rol_habilitado">
						<enum-value value="E" label="Evaluador"/>
						<enum-value value="S" label="Supervisor"/>
						<enum-value value="O" label="Legajo"/>
						<enum-value value="F" label="Evaluador 360"/>
					</col>
					<col label="Estado al Aceptar" name="c_estado_aceptar" show="enum">
						<enum-value label="Abierta" value="AB"/>
						<enum-value label="Habilitada" value="HA"/>
						<enum-value label="Evaluada" value="EV"/>
						<enum-value label="Confirmada" value="CO"/>
						<enum-value label="Aprobada" value="AP"/>
						<enum-value label="Cerrada" value="CE"/>
						<enum-value label="Aprobaci&#243;n/Rechazo" value="AR"/>
					</col>
					<button flag="2" flow="NucleusRH.Base.Evaluacion2.Eventos.ETAPA.MAIN.STD.autoflow:ADD" img="application_add.gif" name="NEW_ETAPA" label="Agregar" descr="Agregar una Etapa"/>
					<button flag="1" flow="NucleusRH.Base.Evaluacion2.Eventos.ETAPA.MAIN.STD.autoflow:EDIT" img="application_edit.gif" name="EDT_ETAPA" label="Modificar" descr="Modificar la Etapa"/>
					<button img="application_delete.gif" flow="NucleusRH.Base.Evaluacion2.Eventos.ETAPA.MAIN.STD.autoflow:DELETE" flag="1" name="DEL_ETAPA" label="Eliminar" descr="Eliminar la Etapa"/>
				</list>
			</group>
		</cfg>
		<scripts>
			function CheckEnabledButton(name)
{
	switch(name)
	{
		case "EDIT":   
		case "ADMINISTRAR":  
		case "PLANTILLAS_EDT_PLANTILLA":
		case "ETAPAS_EDT_ETAPA":
		case "ETAPAS_DEL_ETAPA":
			return Ctrl("c_estado").GetXValue()!="C";
			
		case "DESHABILITAR":                                     
			return Ctrl("c_estado").GetXValue()=="H";

		case "HABILITAR":                                     
			return Ctrl("c_estado").GetXValue()=="I";

		case "CERRAR":                                     
			return Ctrl("c_estado").GetXValue()=="H" &amp;&amp; Ctrl("c_estado").GetXValue()!="C";

		case "DELETE":
			return Ctrl("c_estado").GetXValue()=="A";
	}

	return true;
}
		</scripts>
	</template-STD_REG>
</templates>
