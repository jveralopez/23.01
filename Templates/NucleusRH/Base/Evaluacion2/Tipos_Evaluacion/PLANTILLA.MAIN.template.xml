<templates DEFAULT_ACTION="LIST" name="MAIN">
	<template-STD_LIST name="MAIN">
		<cfg parent-resource="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.INFO_IDS_LIST" autoload="1" search="0" seg="0" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col show="string_short" name="c_plantilla"/>
			<col show="string_med" name="d_plantilla"/>
			<col show="number_0" name="e_orden"/>
			<col name="c_tipo_plantilla" show="string_med"/>
			<col show="string_med" name="d_reporte"/>
			<col show="string_med" name="oi_escala"/>
			<col name="oi_escala_item" show="string_med"/>
			<col name="oi_escala_subitem" show="string_med"/>
			<col show="check" name="l_habilitada"/>
			<col show="check" name="l_mostrar_res"/>
			<col show="number_2" name="n_ponderacion"/>
			<child flow="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.MAIN.STD.autoflow" flags="2" name="OBJETIVOS"/>
			<child flow="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.QUERY_ITEM.flow:LIST" descr="Seleccinoar los Items de una Lista" label="Lista de Items" flags="2" name="LST_QUERY"/>
		</cfg>
		<scripts>
			function CheckEnabledButton(name)
{
	switch(name)
	{
		case "OBJETIVOS":   
			return Ctrl("LIST").GetSelectAttrValue("c_tipo")=="F";
			
		case "LST_QUERY":   
			return Ctrl("LIST").GetSelectAttrValue("c_tipo").substr(0,4)=="LST_";
	}

	return true;
}
		</scripts>
	</template-STD_LIST>
	<template-STD name="MAIN">
		<cfg parent-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL:PLANTILLAS" data-resource="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.ADIC" fform-edit="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.MAIN.STD_REG.form" fform-add="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.MAIN.STD_REG.form" fform-show="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.MAIN.STD_REG.form" add="1" filter="0">
			<attach query="TIPOS_PLANTILLA" doc="c_tipo_plantilla" show="1" edit="1" new="1"/>
			<attach query="TIPOS_REPORTES" doc="d_reporte" show="1" edit="1" new="1"/>
		</cfg>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg parent-resource="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.INFO_IDS_LIST" object-resource="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.INFO_IDS_LIST" seg="0" del="1" edit="1" add="1">
			<ctrl enable="1" show="string_short" name="c_plantilla"/>
			<ctrl enable="1" show="string_med" name="d_plantilla"/>
			<ctrl enable="1" show="number_0" name="e_orden"/>
			<ctrl enable="1" show="dcombo" name="c_tipo_plantilla"/>
			<ctrl onchange="EnabledControls" enable="2" show="dcombo" name="d_reporte"/>
			<ctrl enable="1" show="scombo" name="oi_escala"/>
			<ctrl name="oi_escala_item" enable="1" show="scombo"/>
			<ctrl name="oi_escala_subitem" enable="1" show="scombo"/>
			<ctrl enable="1" show="check" name="l_habilitada"/>
			<ctrl enable="0" show="check" name="l_mostrar_res"/>
			<ctrl enable="1" show="number_2" name="n_ponderacion"/>
			<ctrl enable="1" show="string_large" name="o_plantilla"/>
		</cfg>
		<scripts/>
	</template-STD_REG>
</templates>
