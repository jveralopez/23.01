<templates DEFAULT_ACTION="NEW" name="MAIN">
	<template-STD name="MAIN">
		<cfg parent-class="NucleusRH.Base.Liquidacion.Grupos.GRUPO:GRUPO_VAR" add="1" filter="1">
			<attach list="0" query="QRY_COLUMNAS" doc="c_columna" show="0" edit="1" new="1"/>
		</cfg>
	</template-STD>
	<template-STD_LIST name="MAIN">
		<cfg maxreg="100" parent-resource="NucleusRH.Base.Liquidacion.Grupos.GRUPO.INFO_IDS_LIST" seg="1" autoload="1" search="1" lock="0" del="0" edit="0" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col label="Grupo" show="string_short" name="oi_grupo"/>
			<col label="Variable" show="string_short" name="oi_variable"/>
			<col label="Columna" show="string_short" name="c_columna"/>
		</cfg>
		<scripts/>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg parent-resource="NucleusRH.Base.Liquidacion.Grupos.GRUPO.INFO_IDS_LIST" object-resource="NucleusRH.Base.Liquidacion.Grupos.GRUPO_VAR.INFO_IDS_LIST" seg="1" del="0" edit="0" add="1">
			<ctrl enable="!SHOW" req="1" label="Variable" resource="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" show="scombo" name="oi_variable"/>
			<ctrl enable="!SHOW" req="1" label="Columna" show="dcombo" name="c_columna"/>
		</cfg>
		<scripts/>
	</template-STD_REG>
</templates>
