<templates name="MAIN">
	<template-STD name="MAIN">
		<cfg load-ddo-full="1" add="1" filter="1"/>
	</template-STD>
	<template-STD_LIST name="MAIN">
		<cfg parent-resource="NucleusRH.Base.Liquidacion.Consumos.CONSUMO.INFO_IDS_LIST" seg="1" maxreg="50" autoload="1" search="1" lock="0" del="1" edit="0" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col label="Codigo" show="string_short" name="c_consumo"/>
			<col label="Descripcion" show="string_short" name="d_consumo"/>
			<col label="Tipo de Consumo" show="string_short" name="oi_tipo_consumo"/>
		</cfg>
		<scripts/>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg seg="1" del="1" edit="0" add="1">
			<ctrl label="Codigo" enable="NEW" req="1" show="string_short" name="c_consumo"/>
			<ctrl enable="!SHOW" label="Descripcion" req="1" show="string_med" name="d_consumo"/>
			<ctrl enable="!SHOW" show="scombo" resource="NucleusRH.Base.Liquidacion.Tipo_Consumo.TIPO_CONSUMO.INFO" label="Tipo de Consumo" req="1" name="oi_tipo_consumo"/>
		</cfg>
		<scripts/>
	</template-STD_REG>
</templates>
