<templates name="REPORT1">
	<template template="Nomad.STD_FIL.template.form" type="form" name="STD_FIL" file="REPORT1.STD_FIL">
		<cfg title="Reportes de programas" doc="source">
			<ctrl req="0" show="enum" nvalue="#source:@tipo" xsize="30" mode="OPT" label="Tipo" name="tipo">
				<enum-value value="A" label="Alertas"/>
				<enum-value value="T" label="Tareas Programadas"/>
			</ctrl>
			<ctrl req="0" show="enum" nvalue="#source:@c_estado" mode="OPT" xsize="30" label="Estado" name="c_estado">
				<enum-value value="A" label="Activo"/>
				<enum-value value="I" label="Inactivo"/>
			</ctrl>
		</cfg>
	</template>
	<template type="flow" template="Nomad.STD_REP.template.flow" file="REPORT1.STD_REP" name="STD_REP">
		<cfg title="Reporte de programaciones" type="XLS" report="NucleusRH.Base.Configuracion.Programaciones.rpt" fform="">
			<DATA tipo="" c_estado=""/>
		</cfg>
	</template>
</templates>
