<templates name="MAIN">
	<template-STD name="MAIN">
		<cfg eve-save="NucleusRH.Base.Configuracion.Progs.PROG.Save" add="0"/>
	</template-STD>
	<template-STD_LIST name="MAIN">
		<cfg list-resource="NucleusRH.Base.Configuracion.Progs.PROG.INFO_IDS_LIST" id-resource="NucleusRH.Base.Configuracion.Progs.PROG.INFO_IDS" del="0" edit="1" add="0">
			<col show="enum_image" name="c_estado">
				<enum-value value="A" img="NORMAL/control_play_blue.gif"/>
				<enum-value value="I" img="NORMAL/control_stop.gif"/>
			</col>
			<col name="d_descr" show="string_med"/>
			<col show="string_large" name="d_prog"/>
			<col show="date" name="f_inicio"/>
			<col show="date" name="f_fin"/>
			<col show="datetime" name="f_ult_ejecucion"/>
			<col show="datetime" name="f_pro_ejecucion"/>
			<child flow="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD.flow:LIST" descr="Detalle de la programaci&#243;n" label="Detalle de la programaci&#243;n" flags="2" name="DETALLES"/>
			<button flow="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.flow:ACTIVAR" name="ACTIVAR" label="Activar" img="control_play_blue.gif" flag="1" descr="Activar la Alerta" mess="&#191;Esta seguro que desea ACTIVAR esta Tarea?"/>
			<button flow="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.flow:DETENER" name="DETENER" label="Detener" img="control_stop_blue.gif" flag="1" descr="Desactivar la Alerta" mess="&#191;Esta seguro que desea DETENER esta Tarea?"/>
			<button flow="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.flow:TEST" name="TEST" label="Ejecutar" img="lightning.gif" flag="1" descr="Ejecutar Ahora" mess="&#191;Esta seguro que desea EJECUTAR esta Tarea ahora?"/>
			<button img="printer.gif" flag="2" flow="NucleusRH.Base.Configuracion.Progs.PROG.REPORT1.STD_REP.autoflow:FILTER" name="REPORT" label="Reporte" descr="Generar reporte" mess="&#191;Esta seguro que desea generar el reporte?"/>
		</cfg>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg del="0" edit="1" add="0">
			<ctrl enable="0" show="string_med" name="d_descr"/>
			<ctrl enable="0" show="string_med" name="d_prog"/>
			<ctrl enable="0" show="enum" name="c_estado"/>
			<ctrl enable="1" show="date" name="f_inicio"/>
			<ctrl enable="1" show="date" name="f_fin"/>
			<ctrl enable="4" show="datetime" name="f_ult_ejecucion"/>
			<ctrl enable="4" show="datetime" name="f_pro_ejecucion"/>
		</cfg>
	</template-STD_REG>
</templates>
