<templates name="NOVEDAD">
	<template-STD name="MAIN">
		<cfg fform-edit="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD_REG.form" fform-show="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD_REG.form" eve-save="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.AltaNovedadCustom" fform-add="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD_REG.form" filter="0" eve-delete="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.BajaNovedad" add="1"/>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg seg="0" del="1" edit="0" add="1">
			<ctrl name="oi_estructura" show="hidden"/>
			<ctrl visible="NEW" onchange="terminal_onchange" resource="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.INFO" name="oi_terminal" label="Terminal" req="1" show="scombo"/>
			<ctrl visible="NEW" show="scombo" resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa" req="1" name="oi_empresa"/>
			<ctrl visible="NEW" show="scombo" resource="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" label="Legajo" parent="oi_empresa" req="1" name="oi_personal_emp"/>
			<ctrl resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" enable="0" visible="SHOW|EDIT" show="scombo" label="Empresa" req="1" name="oi_empresa"/>
			<ctrl visible="SHOW|EDIT" show="scombo" resource="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" label="Legajo" enable="0" req="1" name="oi_personal_emp"/>
			<ctrl resource="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO" enable="NEW|EDIT" name="oi_tipohora" label="Tipo de Hora" req="1" show="scombo"/>
			<ctrl label="Fecha" name="f_fecha" show="date" enable="NEW|EDIT" req="1"/>
			<ctrl onchange="horainicio_onchange" label="Hora Inicio" enable="NEW|EDIT" req="1" show="time" name="horainicio"/>
			<ctrl onchange="horafin_onchange" label="Hora Fin" enable="NEW|EDIT" req="1" show="time" name="horafin"/>
			<ctrl req="1" label="Descripci&#243;n" enable="NEW|EDIT" name="d_novedad" length="100" show="string_med"/>
			<ctrl label="Observaciones" enable="NEW|EDIT" name="o_novedad" length="1000" show="string_large"/>
			<ctrl name="e_horainicio" show="hidden"/>
			<ctrl name="e_horafin" show="hidden"/>
		</cfg>
		<scripts>
			function horainicio_onchange()
{
	if (Ctrl('main').GetMode()=='NEW' || Ctrl('main').GetMode()=='EDIT')
	{
		//Conversion del formato HHMMSS en cantidad de minutos
		var minutos = Number(Ctrl('horainicio').GetXValue().substr(0,2))*60 + Number(Ctrl('horainicio').GetXValue().substr(2,2));
		Ctrl('e_horainicio').SetXValue(minutos);		
	}
	refresh_horafin();
}

function horafin_onchange()
{
	if (Ctrl('main').GetMode()=='NEW' || Ctrl('main').GetMode()=='EDIT')
	{
		//Conversion del formato HHMMSS en cantidad de minutos
		var minutos = Number(Ctrl('horafin').GetXValue().substr(0,2))*60 + Number(Ctrl('horafin').GetXValue().substr(2,2));		
		Ctrl('e_horafin').SetXValue(minutos);
	}
	refresh_horafin();
}

function refresh_horafin()
{
	if (Ctrl('e_horainicio').GetXValue()!='' &amp;&amp; Ctrl('e_horafin').GetXValue()!='')
  {
		var e_horainicio = Number(Ctrl('e_horainicio').GetXValue());
		var e_horafin = Number(Ctrl('e_horafin').GetXValue());

		//Si la hora fin es menor o igual a la hora de inicio corresponde al siguiente dia
		if (e_horafin &lt;= e_horainicio)
			Ctrl('e_horafin').SetXValue(1440+e_horafin);
	}	
}
		</scripts>
	</template-STD_REG>
	<template-STD_LIST name="MAIN">
		<cfg seg="0" list-resource="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.INFO_IDS_LIST" id-resource="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.INFO_IDS" autoload="1" search="1" del="1" edit="0" add="1">
			<col label="Empresa" show="string_med" name="oi_empresa" order="1"/>
			<col label="Legajo" show="string_med" name="oi_personal_emp" order="1"/>
			<col order="0" label="Tipo de Hora" show="string_med" name="oi_tipohora"/>
			<col order="1" name="f_fecha" show="date" label="Fecha"/>
			<col name="e_horainicio" label="Hora Inicio" order="1" show="time"/>
			<col order="1" show="time" name="e_horafin" label="Hora Fin"/>
			<col order="1" show="string_med" name="d_novedad" label="Descripci&#243;n"/>
		</cfg>
	</template-STD_LIST>
</templates>
