	<template-STD_REG name="MAIN">
		<cfg del="0" edit="0" add="1">
			<ctrl resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" name="oi_empresa" enable="NEW|EDIT" label="Empresa" req="1" show="scombo"/>
			<ctrl parent="oi_empresa" resource="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" name="oi_personal_emp" enable="NEW|EDIT" label="Legajo" req="1" show="scombo"/>
			<ctrl visible="NEW|EDIT" resource="NucleusRH.Base.Tiempos_Trabajados.LicenciasRol.LICENCIA_ROL.INFO" name="oi_licencia_rol" label="Tipo de Licencia" req="1" show="scombo"/>
			<ctrl resource="NucleusRH.Base.Tiempos_Trabajados.LicenciasRol.LICENCIA_ROL.INFO_SIN_SEG" visible="SHOW" name="oi_licencia_rol" enable="0" label="Tipo de Licencia" req="1" show="scombo"/>
			<ctrl onchange="f_inicio_onchange" label="Fecha Inicio" enable="NEW|EDIT" req="1" show="date" name="f_inicio"/>
			<ctrl onchange="cant_dias_update" label="Fecha Fin" enable="NEW|EDIT" req="1" show="date" name="f_fin"/>
			<ctrl label="Cantidad D&#237;as" enable="0" show="number_0" name="e_cant_dias"/>
			<ctrl max="2500" min="1900" label="A&#241;o Correspondiente" name="e_anio_corresp" enable="0" show="number_0"/>
			<ctrl label="Observaciones" enable="NEW|EDIT" name="o_licencia" length="1000" show="string_large"/>
		</cfg>
		<scripts>
			function f_inicio_onchange()
{
	if (Ctrl('main').GetMode()=='NEW')
	{
		Ctrl('e_anio_corresp').SetCValue('');	
		
		if (Ctrl('f_inicio').GetXValue()!='')	
			Ctrl('e_anio_corresp').SetCValue(str2date(Ctrl("f_inicio").GetXValue()).getFullYear());
		
		cant_dias_update();
	}
}

function cant_dias_update()
{
	if (Ctrl('main').GetMode()=='NEW')
	{	
		Ctrl('e_cant_dias').SetCValue('');
	
		if (Ctrl('f_inicio').GetXValue()!='' &amp;&amp; Ctrl('f_fin').GetXValue()!='')
		{
			if (Ctrl('f_inicio').GetXValue() &gt; Ctrl('f_fin').GetXValue())
			{
				alert("La fecha de fin debe ser mayor o igual a la fecha de inicio.");
			}
			else
			{
				var dateDiff = str2date(Ctrl("f_fin").GetXValue())-str2date(Ctrl("f_inicio").GetXValue());
				dateDiff = (dateDiff/86400000) + 1;
				Ctrl("e_cant_dias").SetCValue(dateDiff);
			}		
		}	
	}
}
		</scripts>
	</template-STD_REG>
