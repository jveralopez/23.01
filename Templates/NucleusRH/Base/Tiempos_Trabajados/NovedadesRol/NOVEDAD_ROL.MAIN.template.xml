	<template-STD_REG name="MAIN">
		<cfg del="1" edit="1" add="1">
			<ctrl onchange="oi_tipohora_onchange" resource="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO" enable="NEW" label="Tipo de Hora" req="1" show="scombo" name="oi_tipohora"/>
			<ctrl length="100" enable="NEW|EDIT" label="Descripci&#243;n" req="1" show="string_med" name="d_novedad_rol"/>
			<ctrl enable="NEW|EDIT" resource="Nomad.Base.Security.Roles.ROL.INFO" req="1" show="scombo" name="d_rol"/>
			<ctrl resource="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.INFO" enable="NEW|EDIT" label="Terminal" req="1" show="scombo" name="oi_terminal"/>
			<ctrl enable="NEW|EDIT" label="Habilitar" req="1" show="check" name="l_habilitar"/>
			<ctrl label="Eliminar 1" name="l_eliminar_1" enable="NEW|EDIT" req="1" show="check"/>
			<ctrl label="Eliminar 2" name="l_eliminar_2" enable="NEW|EDIT" req="1" show="check"/>
		</cfg>
		<scripts>
			function OnLoad()
{
	if (Ctrl('main').GetMode()=='NEW')
 	{
 		Ctrl('l_habilitar').SetXValue(1);	
 	}
}

function oi_tipohora_onchange()
{
	var strDesc = Ctrl('oi_tipohora').GetCValue();	
	
	if(strDesc!='')
	{
		var intIndex = strDesc.indexOf(' - ');
		if(intIndex!=-1)
		{
			strDesc = strDesc.substring(intIndex+3);
		}
	}
	
	Ctrl('d_novedad_rol').SetXValue(strDesc);
}
		</scripts>
	</template-STD_REG>
	<template-STD_LIST name="MAIN">
		<cfg maxreg="16" autoload="1" search="1" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col label="Tipo de Hora" name="oi_tipohora" show="string_med"/>
			<col label="Descripci&#243;n" show="string_med" name="d_novedad_rol"/>
			<col label="Rol" show="string_med" name="d_rol"/>
			<col label="Habilitado" show="combo_SN" name="l_habilitar"/>
		</cfg>
	</template-STD_LIST>
