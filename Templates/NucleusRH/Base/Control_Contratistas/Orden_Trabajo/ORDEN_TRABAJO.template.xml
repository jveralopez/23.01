<templates name="MAIN">
	<template-STD_LIST name="MAIN">
		<cfg maxreg="1000" lock="0" autoload="1" search="1" seg="0" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col show="string_short" label="Orden de Trabajo" name="descr"/>
			<col name="oi_empresa" show="string_med" label="Empresa" order="1"/>
			<col name="oi_tipo_trabajo" label="Tipo Trabajo" show="string_med" order="1"/>
			<col name="oi_obra_trabajo" label="Obra Trabajo" show="string_med" order="1"/>
			<col name="oi_unidad_org_ot" label="Unidad Organizativa" show="string_med" order="1"/>
			<col label="Fecha Vigencia Desde" name="f_vigencia_desde" show="date" order="1"/>
			<col label="Fecha Vigencia Hasta" name="f_vigencia_hasta" show="date" order="1"/>
			<child flow="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.PER_CONT_OT.MAIN.STD.autoflow:LIST" name="PER_CONT_OT"/>
			<group type="none">
				<ctrl req="0" show="hidden" nvalue="#SELECT:@oi_empresa" name="oi_empresa"/>
				<ctrl req="0" show="hidden" nvalue="#SELECT:@oi_orden_trabajo" name="oi_orden_trabajo"/>
				<ctrl req="0" resource="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.INFO" show="hidden" nvalue="#SELECT:@oi_tipo_trabajo" name="oi_tipo_trabajo"/>
				<ctrl nvalue="#SELECT:@oi_obra_trabajo" show="hidden" name="oi_obra_trabajo"/>
				<ctrl req="0" resource="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.INFO" show="hidden" nvalue="#SELECT:@oi_unidad_org_ot" name="oi_unidad_org_ot"/>
				<ctrl nvalue="#SELECT:@f_vigencia_desde" req="0" show="hidden" name="f_vigencia_desde"/>
				<ctrl nvalue="#SELECT:@f_vigencia_hasta" req="0" show="hidden" name="f_vigencia_hasta"/>
			</group>
		</cfg>
		<scripts/>
	</template-STD_LIST>
	<template-STD name="MAIN">
		<cfg fform-edit="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.MAIN.STD_REG.form" fform-add="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.MAIN.STD_REG.form" add="1" filter="1">
			<!--attach doc="PER_CONT_OT" new="0" show="1" edit="0" list="0"/-->
		</cfg>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg object-resource="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.INFO_IDS_LIST" del="1" edit="1" add="1">
			<ctrl enable="1" req="1" show="string_short" name="c_orden_trabajo"/>
			<ctrl enable="1" req="1" show="string_med" name="d_orden_trabajo"/>
			<ctrl enable="1" req="1" show="scombo" name="oi_empresa"/>
			<ctrl show="scombo" name="oi_tipo_trabajo" enable="1" req="1"/>
			<ctrl show="scombo" name="oi_obra_trabajo" enable="1" req="1"/>
			<ctrl show="scombo" name="oi_unidad_org_ot" enable="1" req="1"/>
			<ctrl name="f_vigencia_desde" enable="1" req="1" show="date"/>
			<ctrl name="f_vigencia_hasta" enable="1" req="1" show="date"/>
			<!--group enable="EDIT|NEW" visible="SHOW|EDIT|NEW" type="separator" width="90%" label="Personal Contratista" name="PLANTILLAS">
		<list list-resource="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.PER_CONT_OT.INFO_IDS_LIST" lock="1" name="PER_CONT_OT" label="Personal Contratista" del="1" edit="0" add="1" visible="SHOW" width="100%">
			<col order="1" label="Empresa - Legajo" show="string_short" name="oi_personal_emp"/>
			<button flow="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.PER_CONT_OT.MAIN.STD.autoflow:ADD" flags="1" flag="1" img="application_add.gif" name="AGREGAR" label="Agregar" descr="Agregar"/>
		</list>
	</group-->
		</cfg>
		<scripts/>
	</template-STD_REG>
	<template-STD_FIL name="MAIN">
		<cfg title="Filtrar Ordenes de Trabajo">
			<ctrl nvalue="#SELECT:@oi_empresa" label="Empresa Contratista" req="0" show="scombo" name="oi_empresa"/>
			<ctrl nvalue="#SELECT:@oi_orden_trabajo" resource="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.INFO" label="Orden de Trabajo" name="oi_orden_trabajo" req="0" show="scombo"/>
			<ctrl nvalue="#SELECT:@oi_tipo_trabajo" label="Tipo de Trabajo" show="scombo" name="oi_tipo_trabajo" req="0"/>
			<ctrl nvalue="#SELECT:@oi_unidad_org_ot" resource="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.INFO" label="Unidad Organizativa" show="scombo" name="oi_unidad_org_ot" req="0"/>
			<ctrl label="Fecha Vigencia Desde" req="0" show="date" name="f_vigencia_desde"/>
			<ctrl req="0" label="Fecha Vigencia Hasta" show="date" name="f_vigencia_hasta"/>
		</cfg>
		<scripts/>
	</template-STD_FIL>
</templates>
