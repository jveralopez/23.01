<templates DEFAULT_ACTION="LIST" name="MAIN">
	<template-STD_LIST name="MAIN">
		<cfg maxreg="1000" lock="0" autoload="1" search="1" seg="0" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col label="Tipo Veh&#237;culo" name="tipo_vehiculo" show="string_med" order="1"/>
			<col label="Dominio" name="c_dominio" show="string_short" order="1"/>
			<col name="c_marca" show="string_med" label="Marca" order="1"/>
			<col name="d_modelo" label="Modelo" show="string_med" order="1"/>
			<col label="A&#241;o Modelo" name="e_anio" show="string_med" order="1"/>
			<col name="empresa" show="string_med" label="Empresa" order="1"/>
			<col name="d_poliza" show="string_med" label="P&#243;liza" order="1"/>
			<!--child flow="NucleusRH.Base.Control_Contratistas.Vehiculos.ATRIB_VEHIC.MAIN.STD.flow:LIST" name="ATRIB_VEHIC"/-->
			<child flow="NucleusRH.Base.Control_Contratistas.Vehiculos.ATRIB_VEHIC.MAIN.STD.flow:LIST" label="Informaci&#243;n a Controlar" name="ATRIB_VEHIC"/>
		</cfg>
		<scripts/>
	</template-STD_LIST>
	<template-STD name="MAIN">
		<cfg load-ddo-full="0" add="1" filter="0"/>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg object-resource="NucleusRH.Base.Control_Contratistas.Vehiculos.VEHICULO.INFO_IDS_LIST" del="1" edit="1" add="1">
			<ctrl name="oi_tipo_vehiculo" show="scombo" enable="1" req="1"/>
			<ctrl name="c_dominio" enable="1" req="1" show="string_short"/>
			<ctrl enable="1" req="1" show="string_med" name="c_marca"/>
			<ctrl name="d_modelo" label="Modelo" show="string_short" enable="1" req="1"/>
			<ctrl label="A&#241;o Modelo" enable="1" show="string_short" name="e_anio"/>
			<ctrl enable="1" req="1" show="scombo" name="oi_empresa"/>
			<ctrl enable="1" label="P&#243;liza" show="string_short" name="d_poliza"/>
			<ctrl label="Observaciones" enable="1" show="string_large" name="o_vehiculo"/>
		</cfg>
		<scripts/>
	</template-STD_REG>
</templates>
