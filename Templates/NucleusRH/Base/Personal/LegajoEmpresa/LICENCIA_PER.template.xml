<templates name="LICENCIA_PER">
	<template-STD name="MAIN">
		<cfg fform-add="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.MAIN.STD_REG.form" fform-edit="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.MAIN.STD_REG.form" fform-show="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.MAIN.STD_REG.form" filter="0" eve-delete="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.BajaLicencia" eve-save="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.AltaLicencia" add="1"/>
	</template-STD>
	<template-STD_REG name="MAIN">
		<cfg seg="0" del="1" edit="0" add="1">
			<ctrl visible="NEW" show="scombo" resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa" req="1" name="oi_empresa"/>
			<ctrl visible="NEW" show="scombo" resource="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" label="Legajo" parent="oi_empresa" req="1" name="oi_personal_emp"/>
			<ctrl resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" enable="0" visible="SHOW|EDIT" show="scombo" label="Empresa" req="1" name="oi_empresa"/>
			<ctrl visible="SHOW|EDIT" show="scombo" resource="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" label="Legajo" enable="0" req="1" name="oi_personal_emp"/>
			<ctrl enable="NEW|EDIT" resource="NucleusRH.Base.Personal.Licencias.LICENCIA.INFO" name="oi_licencia" label="Tipo de Licencia" req="1" show="scombo"/>
			<ctrl onchange="f_inicio_onchange" label="Fecha Inicio" enable="NEW|EDIT" req="1" show="date" name="f_inicio"/>
			<ctrl onchange="cant_dias_update" label="Fecha Fin" enable="NEW|EDIT" req="1" show="date" name="f_fin"/>
			<ctrl label="Cantidad D&#237;as" enable="0" show="number_0" name="e_cant_dias"/>
			<ctrl max="2500" min="1900" label="A&#241;o Correspondiente" name="e_anio_corresp" enable="0" show="number_0"/>
			<ctrl name="o_licencia_per" label="Observaciones" enable="NEW|EDIT" length="1000" show="string_large"/>
		</cfg>
		<scripts>
			function f_inicio_onchange()
{
	if (Ctrl('main').GetMode()=='NEW' || Ctrl('main').GetMode()=='EDIT')
	{
		Ctrl('e_anio_corresp').SetCValue('');	
		
		if (Ctrl('f_inicio').GetXValue()!='')	
			Ctrl('e_anio_corresp').SetCValue(str2date(Ctrl("f_inicio").GetXValue()).getFullYear());
		
		cant_dias_update();
	}
}

function cant_dias_update()
{
	if (Ctrl('main').GetMode()=='NEW' || Ctrl('main').GetMode()=='EDIT')
	{	
		Ctrl('e_cant_dias').SetCValue('');
	
		if (Ctrl('f_inicio').GetXValue()!='' &amp;&amp; Ctrl('f_fin').GetXValue()!='')
		{
			if (Ctrl('f_inicio').GetXValue() &gt; Ctrl('f_fin').GetXValue())
			{
				alert("La fecha de fin debe ser mayor o igual a la fecha de inicio.");
			}
			else
			{
				var dateDiff = str2date(Ctrl("f_fin").GetXValue())-str2date(Ctrl("f_inicio").GetXValue());
				dateDiff = (dateDiff/86400000) + 1;
				Ctrl("e_cant_dias").SetCValue(dateDiff);
			}		
		}	
	}
}
		</scripts>
	</template-STD_REG>
	<template-STD_LIST name="MAIN">
		<cfg maxreg="500" seg="0" list-resource="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.INFO_IDS_LIST" id-resource="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER.INFO_IDS" autoload="0" search="1" del="1" edit="0" add="1">
			<col label="Empresa" show="string_med" name="oi_empresa" order="1"/>
			<col label="Legajo" show="string_med" name="oi_personal_emp" order="1"/>
			<col order="0" label="Tipo de Licencia" show="string_med" name="oi_licencia"/>
			<col order="1" label="Fecha Inicio" name="f_inicio" show="date"/>
			<col order="1" label="Fecha Fin" show="date" name="f_fin"/>
			<col order="1" label="Cantidad D&#237;as" name="e_cant_dias" show="number_0"/>
			<col order="1" label="A&#241;o Correspondiente" show="number_0" name="e_anio_corresp"/>
		</cfg>
	</template-STD_LIST>
</templates>
