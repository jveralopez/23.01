<templates name="MAIN">
	<template-STD_LIST name="MAIN">
		<cfg maxreg="1000" autoload="1" search="1" lock="0" seg="1" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col name="c_departamento" order="1" label="Codigo" show="string_short"/>
			<col name="d_departamento" order="1" label="Descripcion" show="string_short"/>
			<col label="Empresa" order="1" name="oi_empresa" show="string_short"/>
			<child flow="NucleusRH.Base.Organizacion.Departamentos.SECTOR.MAIN.STD.autoflow:LIST" flags="2" label="Sectores" name="SECTOR"/>
		</cfg>
		<scripts/>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg object-resource="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.INFO_IDS_LIST" seg="1" del="1" edit="1" add="1">
			<ctrl nvalue="#source:@PARENT" resource="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" enable="0" label="Empresa" show="scombo" req="1" name="oi_empresa"/>
			<ctrl enable="!SHOW" name="c_departamento" show="string_short" label="Codigo" req="1"/>
			<ctrl enable="!SHOW" name="d_departamento" show="string_short" label="Descripcion" req="1"/>
			<ctrl nvalue="#DDO:oi_empresa/@value" show="hidden" name="empresa"/>
		</cfg>
		<scripts>
			function PosOnLoad()
{
	Ctrl('empresa').SetXValue(Ctrl('oi_empresa').GetXValue());
}
		</scripts>
	</template-STD_REG>
	<template-STD name="MAIN">
		<cfg eve-delete="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.Borrar_Departamento" eve-save="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.Crear_Departamento" fform-filter="NucleusRH.Base.Organizacion.Departamentos.filter.form" load-ddo-full="0" add="1" filter="1"/>
	</template-STD>
</templates>
