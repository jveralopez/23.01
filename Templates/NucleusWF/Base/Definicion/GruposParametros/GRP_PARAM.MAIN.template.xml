<templates name="MAIN" type="LoadWizardSTDList">
	<template-STD_LIST name="MAIN">
		<cfg parent-resource="NucleusWF.Base.Definicion.GruposParametros.GROUP.INFO_IDS_LIST" del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col name="oi_param" show="string_med"/>
			<col name="d_value" show="string_med"/>
			<col name="d_value_debug" show="string_med"/>
		</cfg>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg del="1" edit="1" add="1">
			<ctrl enable="NEW" name="oi_param" show="scombo"/>
			<ctrl name="d_value" enable="1" show="string_med"/>
			<ctrl name="d_value_debug" enable="1" show="string_med"/>
		</cfg>
	</template-STD_REG>
	<template-STD name="MAIN">
		<cfg parent-class="NucleusWF.Base.Definicion.GruposParametros.GROUP:PARAMS" add="1"/>
	</template-STD>
</templates>
