<templates name="MAIN" type="LoadWizardSTDList">
	<template-STD_LIST name="MAIN">
		<cfg del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
			<col show="string_short" name="c_group"/>
			<col name="d_group" show="string_med"/>
			<child flow="NucleusWF.Base.Definicion.GruposParametros.GRP_PARAM.MAIN.STD.autoflow:LIST" name="PARAMS"/>
		</cfg>
	</template-STD_LIST>
	<template-STD_REG name="MAIN">
		<cfg del="1" edit="1" add="1">
			<ctrl show="string_short" name="c_group" enable="1"/>
			<ctrl name="d_group" enable="1" show="string_med"/>
		</cfg>
	</template-STD_REG>
	<template-STD name="MAIN">
		<cfg add="1"/>
	</template-STD>
</templates>
