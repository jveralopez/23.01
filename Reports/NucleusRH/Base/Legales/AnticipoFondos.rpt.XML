quot;202&quot;&gt;&#13;&#10;&#9;&#9;&#9;&lt;DETALLE nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;DETALLE descr=&quot;[401] 401 - [2] 202 - [302] 302&quot; n_importe=&quot;5000&quot; oi_modo_de_pago=&quot;202&quot; id=&quot;302&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&lt;oi_concepto value=&quot;4&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;/DETALLE&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;DETALLE descr=&quot;[401] 401 - [2] 202 - [303] 303&quot; n_importe=&quot;40250&quot; oi_modo_de_pago=&quot;202&quot; id=&quot;303&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&lt;oi_concepto value=&quot;3&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;/DETALLE&gt;&#13;&#10;&#9;&#9;&#9;&lt;/DETALLE&gt;&#13;&#10;&#9;&#9;&lt;/MODO_DE_PAGO&gt;&#13;&#10;&#9;&lt;/MODO_PAGO&gt;&#13;&#10;&lt;/ADELANTO&gt;">
		<qry:main doc="PARAM">
			<qry:element name="ROW">
				<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy')"/>
				<qry:attribute name="ruta" value="#PARAM:ADELANTO/@ruta"/>
				<qry:append-doc name="APPEND" doc-path="#PARAM:ADELANTO"/>
				<qry:insert-select name="sql1" doc-path="#PARAM:ADELANTO"/>
				<!--qry:insert-select name="PARAMETRO"/-->
				<!--qry:insert-select name="qryImage" doc-path="#PARAM:ADELANTO"/-->
			</qry:element>
		</qry:main>
		<qry:select name="sql1" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					CAR.c_carpeta,
					CAR.d_carpeta,
					ADE.oi_adelanto,
					 
					SUJ.c_sujeto,
					SUJ.d_sujeto,
					UBI_ADE.c_ubicacion as c_ubi_ade,
					UBI_ADE.d_ubicacion as d_ubi_ade,			 
					EMP_ADE.c_empresa as c_emp_ade,
					EMP_ADE.d_empresa as d_emp_ade,
					ADE.o_descripcion,
					UBI_CAR.c_ubicacion as c_ubi_car,
					UBI_CAR.d_ubicacion as d_ubi_car,
					EMP_CAR.c_empresa as c_emp_car,
					EMP_CAR.d_empresa as d_emp_car,
					CLI.c_sujeto as c_cli,
					CLI.d_sujeto as d_cli,     
					ADE.n_monto_adel,
					ADE.n_criticidad,
					ADE.d_destino,
					ADE.d_orden_cheque,
					ADE.o_adelanto,
					ADE.f_necesidad_fondos
				FROM                                    
					LEG04_ADELANTOS as ADE,
					LEG40_CLASIF_SUJ as LCS,
					LEG40_SUJETOS as SUJ,
					LEG01_CARPETAS as CAR,
					ORG03_UBICACIONES as UBI_ADE,
					ORG03_EMPRESAS as EMP_ADE,
					ORG03_UBICACIONES as UBI_CAR,
					ORG03_EMPRESAS as EMP_CAR,
					LEG40_SUJETOS as CLI
				JOIN
					ADE.oi_carpeta INNER CAR.oi_carpeta, 
					ADE.oi_clasif_sujeto INNER LCS.oi_clasif_sujeto,
					LCS.oi_sujeto INNER SUJ.oi_sujeto,
					ADE.oi_ubicacion LEFT OUTER UBI_ADE.oi_ubicacion,
					UBI_ADE.oi_empresa LEFT OUTER EMP_ADE.oi_empresa,
					CAR.oi_ubicacion LEFT OUTER UBI_CAR.oi_ubicacion,
					UBI_CAR.oi_empresa LEFT OUTER EMP_CAR.oi_empresa,
					CAR.oi_sujeto INNER CLI.oi_sujeto
				WHERE
					ADE.oi_adelanto = {#PARAM:@id}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="carpeta" value="'['+$r/@c_carpeta+'] -'+$r/@d_carpeta"/>
				<qry:attribute name="adelanto" value="'['+$r/@oi_adelanto+'] '+'-'+$r/@o_descripcion"/>
				<qry:attribute name="f_necesidad_fondos" value="format_date($r/@f_necesidad_fondos,'dd/mm/yyyy')"/>
				<qry:attribute name="solicitante" value="'['+$r/@c_sujeto+'] '+$r/@d_sujeto"/>
				<qry:attribute name="sucursal_solicitante" value="'['+$r/@c_emp_ade+'] '+$r/@d_emp_ade+' - ['+$r/@c_ubi_ade+'] '+$r/@d_ubi_ade"/>
				<qry:attribute name="desc" value="$r/@o_descripcion"/>
				<qry:attribute name="sucursal_carpeta" value="iif($r/@c_emp_car!='','['+$r/@c_emp_car+'] '+$r/@d_emp_car+' - ['+$r/@c_ubi_car+'] '+$r/@d_ubi_car,'')"/>
				<qry:attribute name="cliente" value="$r/@c_cli+'-'+$r/@d_cli"/>
				<qry:attribute name="n_monto_adel_letras" value="format_number($r/@n_monto_adel, '.00')*100"/>
				<qry:attribute name="imp_letra" value="iif(@n_monto_adel_letras!='0',nmd-num2text($r/@n_monto_adel) + ' con ' + @n_monto_adel_letras +'/'+ '100',nmd-num2text($r/@n_monto_adel))"/>
				<qry:attribute name="n_monto_adel" value="format-number($r/@n_monto_adel,5,2,',','.','')"/>
				<qry:attribute name="total_importe" value="'$ ' + format-number($r/@n_monto_adel,5,2,',','.','')"/>
				<qry:switch test="$r/@n_criticidad">
					<qry:case value="MB">
						<qry:attribute name="criticidad" value="'Muy baja'"/>
					</qry:case>
					<qry:case value="B">
						<qry:attribute name="criticidad" value="'Baja'"/>
					</qry:case>
					<qry:case value="N">
						<qry:attribute name="criticidad" value="'Normal'"/>
					</qry:case>
					<qry:case value="A">
						<qry:attribute name="criticidad" value="'Alta'"/>
					</qry:case>
					<qry:case value="MA">
						<qry:attribute name="criticidad" value="'Muy alta'"/>
					</qry:case>
				</qry:switch>
				<qry:attribute name="destino_cheque" value="$r/@d_destino"/>
				<qry:attribute name="cheque_orden" value="$r/@d_orden_cheque"/>
				<qry:attribute name="observaciones" value="$r/@o_adelanto"/>
				<MODOS>
					<qry:insert-select name="sql-MODOPAGO"/>
				</MODOS>
				nmd-num2text
			</qry:out>
		</qry:select>
		<qry:select name="sql-MODOPAGO" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					PAGO.oi_modo_de_pago,
					PAGO.c_modo_de_pago,
					PAGO.o_modo_de_pago,
					PAGO.n_importe_pago
				FROM                                    
					LEG04_ADELANTOS as ADE,
					LEG04_MODO_PAGO as PAGO
				JOIN
					ADE.oi_adelanto LEFT OUTER PAGO.oi_adelanto					
				WHERE
					ADE.oi_adelanto = {#APPEND:@id}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<MODO>
					<qry:attribute name="oi_modo_de_pago" value="$r/@oi_modo_de_pago"/>
					<qry:attribute name="c_modo_de_pago" value="$r/@c_modo_de_pago"/>
					<qry:attribute name="o_modo_de_pago" value="$r/@o_modo_de_pago"/>
					<qry:attribute name="n_importe_pago" value="'$ ' + format-number($r/@n_importe_pago,5,2,',','.','')"/>
					<DETALLES>
						<qry:insert-select name="sql-DETALLE" doc-path="$r"/>
					</DETALLES>
				</MODO>
			</qry:out>
		</qry:select>
		<qry:select name="sql-DETALLE" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					DET.oi_detalle,
					DET.n_importe,
					CON.d_concepto,
					LEG04_MODO_PAGO.c_modo_de_pago
				FROM                                    
					LEG04_DETALLE as DET,
					LEG53_CONCEPTOS as CON,
					LEG04_MODO_PAGO
				JOIN
					DET.oi_concepto INNER CON.oi_concepto,
					DET.oi_modo_de_pago INNER LEG04_MODO_PAGO.oi_modo_de_pago
				WHERE
					DET.oi_modo_de_pago = {#PARAM:@oi_modo_de_pago}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<DETALLE>
					<qry:attribute name="c_modo_de_pago" value="$r/@c_modo_de_pago"/>
					<qry:attribute name="oi_detalle" value="$r/@oi_detalle"/>
					<qry:attribute name="n_importe" value="'$ '+format-number($r/@n_importe,5,2,',','.','')"/>
					<qry:attribute name="concepto" value="$r/@d_concepto"/>
				</DETALLE>
				<qry:attribute name="cant" value="./@cant + 1"/>
			</qry:out>
		</qry:select>
		<qry:select name="PARAMETRO" doc="DOC">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					ORG26_PARAMETROS.d_valor
				FROM                                    
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_modulo = \'LEG\'
					AND ORG26_PARAMETROS.c_parametro = \'IMG_FONDOS\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<!--qry:attribute name="d_valor" value="'C:/bayton.jpg'"/-->
				<qry:attribute name="d_valor" value="$r/@d_valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="qryImage" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					IMG.o_imagen,
					E.oi_logotipo
				FROM                                    
					LEG04_ADELANTOS as A,
					LEG01_CARPETAS as C,
					ORG03_EMPRESAS as E,
					PER19_IMAGENES as IMG
				JOIN				
				A.oi_carpeta INNER C.oi_carpeta,
				C.oi_empresa INNER E.oi_empresa,
				E.oi_logotipo INNER IMG.oi_imagen_per
				WHERE
				A.oi_adelanto = {#PARAM:@id}	
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<!--qry:attribute name="d_valor" value="'C:/bayton.jpg'"/-->
				<qry:attribute name="oi_logo" value="'C:\\NOMAD\\INSTANCES\\Desa185\\Web\\Images\\'+$r/@o_imagen"/>
				<!--qry:attribute name="oi_logo" value="iif($r/@oi_logotipo!='','../NomadFile.aspx?mode=DB&amp;class=NucleusRH.Base.Personal.Imagenes.HEAD&amp;height=110&amp;id='+$r/@oi_logotipo,'no')"/-->
			</qry:out>
		</qry:select>
	</report:query>
