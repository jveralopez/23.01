<report:report xmlns:report="nomad_engine.report" xmlns:qry="nomad_engine.qry" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" doc="source" name="NucleusRH.Base.Capacitacion.Certificados">
	<report:query>
		<qry:main doc="SOURCE">
			<qry:insert-element doc-path="#SOURCE:DATOS"/>
		</qry:main>
	</report:query>
	<report:page-layout>
		<fo:layout-master-set>
			<fo:simple-page-master master-name="A4" page-height="210mm" page-width="297mm" margin-top="10mm" margin-bottom="10mm" margin-left="10mm" margin-right="7mm">
				<fo:region-body margin="1mm"/>
				<fo:region-before extent="1mm"/>
				<fo:region-after extent="1mm"/>
				<fo:region-start extent="1mm"/>
				<fo:region-end extent="1mm"/>
			</fo:simple-page-master>
		</fo:layout-master-set>
	</report:page-layout>
	<report:page>
		<xsl:template match="DATOS/INSCRIPTOS">
			<xsl:for-each select="INSCRIPTO">
				<fo:page-sequence master-reference="A4">
					<fo:flow flow-name="xsl-region-body">
						<fo:table table-layout="fixed" width="280mm" height="180mm">
							<fo:table-column column-width="280mm"/>
							<fo:table-body border="0">
								<fo:table-row>
									<fo:table-cell>
										<fo:block text-align="center" margin="1mm" font-family="serif" font-size="22pt" space-before="30mm">
											<xsl:text>
												CERTIFICADO
											</xsl:text>
										</fo:block>
									</fo:table-cell>
								</fo:table-row>
								<fo:table-row>
									<fo:table-cell display-align="center">
										<fo:block white-space-collapse="false" white-space-treatment="preserve" margin="1mm" text-align="justify" padding-left="45pt" padding-right="45pt" line-height="45pt" font-family="serif" font-size="18pt" space-before="20mm">
											<xsl:text>
												Certifico que&#160;
											</xsl:text>
											<xsl:value-of select="@d_ape_y_nom"/>
											<xsl:text>
												, D.N.I. N&#186;&#160;
											</xsl:text>
											<xsl:value-of select="@c_dni"/>
											<xsl:text>
												&#160;asisti&#243; al curso&#160;&#160;
											</xsl:text>
											<xsl:value-of select="../../@d_dictado"/>
											<xsl:text>
												&#160;con una carga horaria de&#160;&#160;
											</xsl:text>
											<xsl:value-of select="../../@n_duracion_hs"/>
											<xsl:text>
												&#160;hs. reloj, desde el&#160;
											</xsl:text>
											<xsl:value-of select="../../@f_inicio"/>
											<xsl:text>
												&#160;al&#160;
											</xsl:text>
											<xsl:value-of select="../../@f_fin"/>
										</fo:block>
									</fo:table-cell>
								</fo:table-row>
								<fo:table-row>
									<fo:table-cell>
										<fo:block margin="1mm" padding-left="45pt" font-family="serif" font-size="16pt" space-before="20mm">
											<xsl:value-of select="../../@f_hoy"/>
										</fo:block>
									</fo:table-cell>
								</fo:table-row>
								<fo:table-row>
									<fo:table-cell>
										<fo:block text-align="right" padding-right="60pt" margin="1mm" font-family="serif" font-size="16pt" space-before="50mm">
											<xsl:text>
												Firma Docente/Coordinador
											</xsl:text>
										</fo:block>
									</fo:table-cell>
								</fo:table-row>
							</fo:table-body>
						</fo:table>
					</fo:flow>
				</fo:page-sequence>
			</xsl:for-each>
		</xsl:template>
	</report:page>
</report:report>
