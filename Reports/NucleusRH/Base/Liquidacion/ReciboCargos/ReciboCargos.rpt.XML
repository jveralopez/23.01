								</xsl:if>
							</fo:block>
							<xsl:if test="$page='right'">
								<fo:block space-before="1mm">
									En concepto de mis haberes, correspondiente al periodo arriba indicado y segun la presente liquidacion dejando constancia de haber recibido un duplicado de este recibo
								</fo:block>
							</xsl:if>
						</fo:table-cell>
						<fo:table-cell margin-left="1mm" text-align="left" border-width="thin" border-style="solid" border-right-style="none" border-left-style="none" border-bottom-style="none" border-top-style="none">
							<fo:table table-layout="fixed">
								<fo:table-column column-width="18mm" border-width="thin" border-top-style="solid" border-bottom-style="none"/>
								<fo:table-column column-width="18mm" border-width="thin" border-top-style="solid"/>
								<fo:table-column column-width="18mm" border-width="thin" border-right-style="none" border-top-style="solid"/>
								<fo:table-body>
									<fo:table-row>
										<fo:table-cell border-width="thin" border-bottom-style="solid" border-left-style="solid" border-right-style="solid">
											<fo:block margin-right="1mm" text-align="right" font-weight="bold" font-size="8pt" space-before="1mm">
												<xsl:value-of select="@sret"/>
											</fo:block>
										</fo:table-cell>
										<fo:table-cell border-width="thin" border-bottom-style="solid">
											<fo:block margin-right="1mm" text-align="right" font-weight="bold" font-size="8pt" space-before="1mm">
												<xsl:value-of select="@nsret"/>
											</fo:block>
										</fo:table-cell>
										<fo:table-cell border-width="thin" border-bottom-style="solid" border-left-style="solid" border-right-style="solid">
											<fo:block margin-right="1mm" text-align="right" font-weight="bold" font-size="8pt" space-before="1mm">
												<xsl:value-of select="@ded"/>
											</fo:block>
										</fo:table-cell>
									</fo:table-row>
									<fo:table-row>
										<fo:table-cell border-width="thin" border-style="none" border-top-style="solid" border-right-style="solid" background-color="white">
											<fo:block text-align="right" font-size="9pt" space-before="0.8mm"/>
										</fo:table-cell>
										<fo:table-cell border-width="0.5mm" border-right-style="none" border-left-style="solid" border-bottom-style="solid" border-top-style="solid">
											<fo:block text-align="right" font-weight="bold" font-size="9pt" margin-right="1mm" space-before="0.8mm">
												<xsl:text>
													Neto $
												</xsl:text>
											</fo:block>
										</fo:table-cell>
										<fo:table-cell border-width="0.5mm" border-bottom-style="solid" border-top-style="solid" border-right-style="solid" border-right-width="thin">
											<fo:block text-align="right" font-weight="bold" font-size="9pt" margin-right="1mm" space-before="0.8mm">
												<xsl:value-of select="@neto"/>
											</fo:block>
										</fo:table-cell>
									</fo:table-row>
									<fo:table-row height="18mm">
										<fo:table-cell border-width="thin" border-style="none" display-align="center" number-columns-spanned="3" border-right-style="solid">
											<fo:block text-align="center">
												<xsl:if test="$page='left' and /RECIBOS/@oi_firma_emp!=''">
													<fo:external-graphic display-align="center" height="18mm">
														<xsl:attribute name="src">
															<xsl:value-of select="concat('url(data:image/jpg;base64,(#IMAGE.DB(x150;NucleusRH.Base.Personal.Imagenes.HEAD;',/RECIBOS/@oi_firma_emp,')#)',')')"/>
														</xsl:attribute>
													</fo:external-graphic>
												</xsl:if>
											</fo:block>
										</fo:table-cell>
									</fo:table-row>
									<fo:table-row>
										<fo:table-cell text-align="left" border-width="thin" border-style="none" border-bottom-style="solid" number-columns-spanned="3" border-right-style="solid">
											<fo:block font-size="9pt" text-align="center">
												<xsl:text>
													-----------------------------------------------
												</xsl:text>
											</fo:block>
											<fo:block font-size="8pt" space-before="0.2mm" text-align="center">
												<xsl:if test="$page='left'">
													<xsl:text>
														Firma Empleador
													</xsl:text>
												</xsl:if>
												<xsl:if test="$page='right'">
													<xsl:text>
														Firma Empleado
													</xsl:text>
												</xsl:if>
											</fo:block>
										</fo:table-cell>
									</fo:table-row>
								</fo:table-body>
							</fo:table>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</xsl:template>
		<xsl:template name="Body">
			<xsl:param name="page"/>
			<fo:table table-layout="fixed">
				<fo:table-column column-width="11mm"/>
				<fo:table-column column-width="56mm"/>
				<fo:table-column column-width="13mm"/>
				<fo:table-column column-width="18mm"/>
				<fo:table-column column-width="18mm"/>
				<fo:table-column column-width="18mm"/>
				<fo:table-body>
					<xsl:for-each select="CA">
						<fo:table-row height="3mm" border-style="none" space-before="1mm">
							<fo:table-cell number-columns-spanned="6" margin-left="1mm" border-width="thin" border-style="none" display-align="center" border-bottom-style="none" border-top-style="solid">
								<fo:block text-align="left" font-size="7pt" space-before="0.5mm" font-weight="bold">
									<xsl:value-of select="@cargo"/>
								</fo:block>
							</fo:table-cell>
						</fo:table-row>
						<xsl:call-template name="Conceptos">
							<xsl:with-param name="page" select="$page"/>
						</xsl:call-template>
					</xsl:for-each>
					<fo:table-row height="3mm" border-style="none" space-before="1mm">
						<fo:table-cell number-columns-spanned="6" margin-left="1mm" border-width="thin" border-style="none" display-align="center" border-bottom-style="none" border-top-style="solid">
							<fo:block text-align="left" font-size="7pt" space-before="0.5mm" font-weight="bold">
								Conceptos de Legajo
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<xsl:for-each select="L">
						<xsl:call-template name="Conceptos">
							<xsl:with-param name="page" select="$page"/>
						</xsl:call-template>
					</xsl:for-each>
				</fo:table-body>
			</fo:table>
		</xsl:template>
		<xsl:template name="Conceptos">
			<xsl:param name="page"/>
			<xsl:for-each select="C">
				<fo:table-row height="3mm" page-break-inside="avoid" font-size="7pt">
					<fo:table-cell>
						<xsl:if test="$page='left' and not(following-sibling::*) and name(parent::*)='L'">
							<xsl:attribute name="id">
								<xsl:value-of select="../../@e_numero_legajo"/>
							</xsl:attribute>
						</xsl:if>
						<fo:block margin-left="1mm" space-before="0.5mm">
							<xsl:value-of select="@c"/>
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block margin-left="1mm" space-before="0.5mm">
							<xsl:value-of select="@t"/>
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block margin-right="1mm" text-align="right" space-before="0.5mm">
							<xsl:value-of select="@q"/>
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block margin-right="1mm" text-align="right" space-before="0.5mm">
							<xsl:value-of select="@r"/>
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block margin-right="1mm" text-align="right" space-before="0.5mm">
							<xsl:value-of select="@n"/>
						</fo:block>
					</fo:table-cell>
					<fo:table-cell>
						<fo:block margin-right="1mm" text-align="right" space-before="0.5mm">
							<xsl:value-of select="@d"/>
						</fo:block>
					</fo:table-cell>
				</fo:table-row>
			</xsl:for-each>
			<xsl:if test="$page='left' and not(C) and name(.)='L'">
				<fo:table-row>
					<xsl:attribute name="id">
						<xsl:value-of select="../@e_numero_legajo"/>
					</xsl:attribute>
					<fo:table-cell colspan="13"/>
				</fo:table-row>
			</xsl:if>
		</xsl:template>
	</report:page>
</report:report>
