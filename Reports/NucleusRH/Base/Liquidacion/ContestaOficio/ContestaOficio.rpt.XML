<report:report xmlns:report="nomad_engine.report" xmlns:qry="nomad_engine.qry" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="NucleusRH.Base.Liquidacion.ContestaOficio.rpt" doc="source">
	<report:query declare="&lt;DATOS oi_personal_emp=&quot;415&quot; oi_embargo=&quot;2&quot; /&gt;">
		<qry:main doc="PARAM">
			<qry:element name="DATOS">
				<qry:attribute value="format_date(now(),'dd') + ' de ' + format_date(now(),'mmm') + ' de ' + format_date(now(),'yyyy')" name="date"/>
				<qry:attribute value="format_date(now(),'dd/mm/yyyy')" name="date1"/>
				<qry:append-doc name="EMBARGO" doc-path="#PARAM:DATOS"/>
				<qry:insert-select doc-path="#PARAM:DATOS" name="QRY_DATOS_EMP"/>
				<qry:insert-select doc-path="#PARAM:DATOS" name="QRY_EMBARGOS"/>
			</qry:element>
		</qry:main>
		<qry:select name="QRY_DATOS_EMP" doc="PARAM">
			<qry:xquery>
				for $r in sql('
				SELECT 
					ORG03_EMPRESAS.oi_logotipo,
					ORG03_EMPRESAS.oi_firma_emp,
					ORG03_EMPRESAS.te_telefono, 
					ORG03_EMPRESAS.d_empresa, 
					ORG03_EMPRESAS.c_cuit, 
					ORG03_EMPRESAS.d_calle, 
					ORG03_EMPRESAS.e_numero, 
					ORG03_EMPRESAS.d_domicilio, 
       		ORG03_EMPRESAS.f_inicio_act,
       		ORG19_LOCALIDADES.d_localidad
				FROM 
					ORG03_EMPRESAS,
					PER02_PERSONAL_EMP,
					ORG19_LOCALIDADES
				JOIN
					ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
					ORG03_EMPRESAS.oi_localidad INNER ORG19_LOCALIDADES.oi_localidad
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="oi_logotipo" value="iif($r/@oi_logotipo!='',$r/@oi_logotipo,'0')"/>
				<qry:attribute name="te_telefono" value="$r/@te_telefono"/>
				<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				<qry:attribute name="oi_firma_emp" value="iif($r/@oi_firma_emp!='',$r/@oi_firma_emp,'0')"/>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="c_cuit" value="$r/@c_cuit"/>
				<qry:attribute name="d_localidad" value="$r/@d_localidad"/>
				<qry:attribute name="d_domicilio" value="$r/@d_domicilio"/>
				<qry:attribute name="f_inicio_act" value="$r/@f_inicio_act"/>
				<qry:attribute name="te_telefono" value="$r/@te_telefono"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_EMBARGOS">
			<qry:xquery>
				for $r in SQL(' 
	SELECT 
		LIQ07.oi_personal_emp,
		LIQ07.f_recepcion,
		LIQ07.c_estado, 
		LIQ07.oi_embargo,
		LIQ07.n_monto_pend,
		LIQ07.c_nro_expediente,
		LIQ07.d_juzgado,
		LIQ07.o_caratula,
		LIQ07.e_nro_oficio,
		LIQ07.n_monto_total,
		BANCO.d_banco, 
		PER01.d_ape_y_nom
	FROM
		LIQ07_EMBARGOS AS LIQ07,
		LIQ22_BANCOS_SUCUR AS BAN_SUC,
		LIQ22_BANCOS AS BANCO,
		PER02_PERSONAL_EMP AS PER02,
		PER01_PERSONAL AS PER01
	JOIN	
		LIQ07.oi_sucursal LEFT OUTER BAN_SUC.oi_sucursal,
		BAN_SUC.oi_banco LEFT OUTER BANCO.oi_banco,
		LIQ07.oi_personal_emp INNER PER02.oi_personal_emp,
		PER02.oi_personal INNER PER01.oi_personal
	WHERE
		LIQ07.oi_embargo = {#PARAM:@oi_embargo}
	')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="f_recepcion" value="format_date($r/@f_recepcion,'dd/mm/yyyy')"/>
				<qry:attribute name="o_embargo" value="$r/@o_caratula"/>
				<qry:attribute name="e_nro_oficio" value="$r/@e_nro_oficio"/>
				<qry:attribute name="oi_embargo" value="$r/@oi_embargo"/>
				<qry:attribute name="d_juzgado" value="$r/@d_juzgado"/>
				<qry:attribute name="c_nro_expediente" value="$r/@c_nro_expediente"/>
				<qry:attribute name="o_caratula" value="$r/@o_caratula"/>
				<qry:attribute name="caratula" value="$r/@c_nro_expediente + ' ' + $r/@d_banco + ' ' + $r/@o_caratula"/>
				<qry:attribute name="d_banco" value="$r/@d_banco"/>
				<qry:attribute name="n_monto_total" value="Concat('$', FORMAT_NUMBER($r/@n_monto_total, 10, 2, '.', '', ''))"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:switch test="$r/@c_estado">
					<qry:case value="I">
						<qry:attribute name="c_estado" value="'Iniciado'"/>
					</qry:case>
					<qry:case value="A">
						<qry:attribute name="c_estado" value="'Activo'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="c_estado" value="'Finalizado'"/>
					</qry:default>
				</qry:switch>
				<qry:insert-select name="QRY_PEND" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_PARAMETRO" doc="PARAM">
			<qry:xquery>
				for $r in sql('
			SELECT 
				ORG26_PARAMETROS.d_valor 
			FROM 
				ORG26_PARAMETROS
			WHERE 
				ORG26_PARAMETROS.c_parametro = \'AdmNumRec\'
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_valor" value="$r/@d_valor"/>
			</qry:out>
		</qry:select>
		<qry:select name="PARAMETRO" doc="PARAM">
			<qry:xquery>
				for $r in SQL('
				SELECT        
					ORG26_PARAMETROS.d_valor
				FROM                                    
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_modulo = \'ORG\'
					AND ORG26_PARAMETROS.c_parametro = \'IMG\'
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="d_valor1" value="'file://' + $r/@d_valor"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PEND">
			<qry:xquery>
				for $r in SQL(' 
		SELECT 
			LIQ07.f_recepcion,
			LIQ07.c_estado, 
			LIQ07.oi_embargo,
			LIQ07.c_nro_expediente,
			LIQ07.d_juzgado,
			LIQ07.o_caratula,
			LIQ07.n_monto_total,
			LIQ07.n_monto_pend
		FROM
			LIQ07_EMBARGOS AS LIQ07
		WHERE          
		  (LIQ07.f_recepcion &lt; {DateTime(#PARAM:@f_recepcion)} or 
		   (LIQ07.f_recepcion = {DateTime(#PARAM:@f_recepcion)} AND
		    LIQ07.e_nro_oficio &gt; {#PARAM:@e_nro_oficio})) AND
		  LIQ07.oi_personal_emp = {#PARAM:@oi_personal_emp} AND
			LIQ07.c_tipo_embargo = \'OC\' AND
		 	LIQ07.c_estado != \'N\' AND
		 	LIQ07.n_monto_pend &gt; 0
		ORDER BY
			f_recepcion ASC
		')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="EMB">
					<qry:attribute name="f_recep_pend" value="format_date($r/@f_recepcion,'dd/mm/yyyy')"/>
					<qry:attribute name="o_embargo_pend" value="$r/@o_caratula"/>
					<qry:attribute name="oi_embargo" value="$r/@oi_embargo"/>
					<qry:attribute name="d_juzgado_pend" value="$r/@d_juzgado"/>
					<qry:attribute name="c_nro_expediente_pend" value="$r/@c_nro_expediente"/>
					<qry:attribute name="o_caratula_pend" value="$r/@o_caratula"/>
					<qry:attribute name="caratula_pend" value="$r/@c_nro_expediente + ' ' + $r/@d_banco + ' ' + $r/@o_caratula"/>
					<qry:attribute name="d_banco_pend" value="$r/@d_banco"/>
					<qry:attribute name="n_monto_pend" value="Concat('$', FORMAT_NUMBER($r/@n_monto_pend, 10, 2, '.', '', ''))"/>
				</qry:element>
			</qry:out>
		</qry:select>
	</report:query>
