						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Total Neto
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<xsl:value-of select="translate(format-number(@SUMtotalrem + @SUMtotalnorem - @SUMretenciones,'###,##0.00'), '.,', ',.')"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</xsl:template>
	</report:page>
</report:report>
