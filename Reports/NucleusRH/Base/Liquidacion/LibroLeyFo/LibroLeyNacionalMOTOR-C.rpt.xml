								<xsl:value-of select="translate(format-number(Totales/@SUMtotalrem + Totales/@SUMtotalnorem - Totales/@SUMretenciones,'###,##0.00'), '.,', ',.')"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
				</fo:table-body>
			</fo:table>
		</xsl:template>
	</report:page>
