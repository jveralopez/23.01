		<xsl:template name="FOOT">
			<fo:table table-layout="fixed" font-size="7pt" font-weight="bold" space-before="10mm">
				<fo:table-column column-width="70mm"/>
				<fo:table-column column-width="40mm"/>
				<fo:table-column column-width="15mm"/>
				<fo:table-body>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell number-columns-spanned="2">
							<fo:block text-decoration="underline">
								Resumen:
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Cantidad de Recibos
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<xsl:value-of select="count(R[@max!='0'])"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Total Remunerativo
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<xsl:value-of select="translate(format-number(Totales/@SUMtotalrem,'###,##0.00'), '.,', ',.')"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Total No Remunerativo
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<xsl:value-of select="translate(format-number(Totales/@SUMtotalnorem,'###,##0.00'), '.,', ',.')"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Total Descuentos
							</fo:block>
						</fo:table-cell>
						<fo:table-cell>
							<fo:block text-align="right">
								<xsl:value-of select="translate(format-number(Totales/@SUMretenciones,'###,##0.00'), '.,', ',.')"/>
							</fo:block>
						</fo:table-cell>
					</fo:table-row>
					<fo:table-row height="3mm">
						<fo:table-cell/>
						<fo:table-cell>
							<fo:block>
								Total Neto
