<report:report xmlns:report="nomad_engine.report" xmlns:qry="nomad_engine.qry" xmlns:fo="http://www.w3.org/1999/XSL/Format" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" name="LibroLeyFo">
	<report:for-each declare="&lt;FILTRO FormatRPT=&quot;PDF&quot; oi_empresa=&quot;1&quot; modelo=&quot;2&quot; e_periodo=&quot;202510&quot;  mostrarDomicilio=&quot;1&quot; fam=&quot;1&quot;  nro_hoja=&quot;&quot; orden1=&quot;1&quot; orden2=&quot;2&quot; parent=&quot;1_202510&quot; where=&quot;&quot; chkOcultarLeyenda=&quot;&quot; chkInvertir=&quot;&quot; batch-id=&quot;&quot;&gt;&lt;LIQUIDACIONES&gt;&lt;LIQUIDACION id=&quot;2008&quot;/&gt;&lt;/LIQUIDACIONES&gt;&lt;/FILTRO&gt;&#13;&#10;&lt;!--&lt;FILTRO FormatRPT=&quot;PDF&quot; oi_empresa=&quot;1&quot; modelo=&quot;2&quot; e_periodo=&quot;202505&quot; nro_hoja=&quot;&quot; orden1=&quot;L97.e_numero_legajo&quot; orden2=&quot;&quot; parent=&quot;1_202505&quot; chkOcultarLeyenda=&quot;&quot; chkInvertir=&quot;&quot; batch-id=&quot;&quot;&gt;&lt;LIQUIDACIONES /&gt;&lt;/FILTRO&gt;--&gt;">
		<qry:main doc="PARAM" engine="C#">
			<ROOT>
				<qry:append-doc name="FILTRO" doc-path="$PARAM/FILTRO"/>
				<qry:append-doc doc-path="." name="VAL"/>
				<qry:insert-select name="qry_encabezado" doc-path="$PARAM"/>
				<qry:insert-select name="qry_cerrada" doc-path="$PARAM"/>
				<qry:insert-select name="qry_domicilio" doc-path="$PARAM"/>
				<qry:attribute value="iif($PARAM/FILTRO/@e_periodo != '',format-datetime(concat(string($PARAM/FILTRO/@e_periodo), '01'), 'MM/yyyy'),'')" name="periodo"/>
				<qry:attribute value="format-datetime(current-dateTime(), 'dd/MM/yyyy')" name="f_informe"/>
				<qry:attribute value="iif(string($PARAM/FILTRO/LIQUIDACIONES/LIQUIDACION/@id)!='', 'Si', 'No')" name="liquidaciones"/>
				<qry:insert-select doc-path="$PARAM/FILTRO" name="QRY_PARAM_EMPRESA"/>
				<qry:insert-select doc-path="$PARAM/FILTRO" name="QRY_RECIBOS"/>
				<qry:attribute value="$PARAM/FILTRO/@nro_hoja" name="nro_hoja"/>
				<qry:if test="@nro_hoja=''">
					<qry:then>
						<qry:attribute name="nro_hoja" value="'1'"/>
					</qry:then>
				</qry:if>
			</ROOT>
		</qry:main>
		<qry:select name="qry_encabezado" doc="PARAM">
			<qry:xquery>
				for $r in SQL(" 
				SELECT ORG26_PARAMETROS.d_valor 
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = 'PlantillaLibroLey'
			")/ROWS
			</qry:xquery>
			<qry:out>
				<qry:attribute name="plantilla" value="iif($r/ROW/@d_valor!='',$r/ROW/@d_valor,'0')"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_cerrada">
			<qry:xquery>
				for $r in sql("
				SELECT ORG26_PARAMETROS.d_valor FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = 'noValidarCerradas'")/ROWS
			</qry:xquery>
			<qry:out>
				<qry:attribute name="noValidarCerradas" value="iif($r/ROW/@d_valor!='',$r/ROW/@d_valor,'0')"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="qry_domicilio">
			<qry:xquery>
				for $r in sql("
				SELECT ORG26_PARAMETROS.d_valor FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = 'DomicilioLibroLey'")/ROWS
			</qry:xquery>
			<qry:out>
				<qry:attribute name="mostrarDomicilio" value="iif($r/ROW/@d_valor!='',$r/ROW/@d_valor,'0')"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PARAM_EMPRESA">
			<qry:xquery>
				for $r in sql("
				SELECT 
				ORG03_EMPRESAS.oi_empresa, 
				ORG03_EMPRESAS.c_empresa, 
				ORG03_EMPRESAS.d_empresa,
				ORG03_EMPRESAS.d_domicilio,
				ORG03_EMPRESAS.c_cuit,
				ORG34_ACTIVIDADES.d_actividad,
				ORG03_EMPRESAS.oi_localidad,
				ORG03_EMPRESAS.c_numero_registro
				FROM ORG03_EMPRESAS 
				INNER JOIN ORG34_ACTIVIDADES ON ORG03_EMPRESAS.oi_actividad = ORG34_ACTIVIDADES.oi_actividad
				WHERE ORG03_EMPRESAS.oi_empresa = {$PARAM/@oi_empresa}   					
					")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
				<qry:attribute value="$r/@d_empresa" name="empresa"/>
				<qry:attribute value="$r/@d_actividad" name="actividad"/>
				<qry:attribute value="$r/@d_domicilio" name="domicilio"/>
				<qry:attribute value="$r/@c_cuit" name="cuit"/>
				<qry:attribute value="$r/@c_numero_registro" name="c_numero_registro"/>
				<qry:insert-select name="qry_localidad" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_RECIBOS" doc="SOURCE">
			<qry:xquery>
				for $rs in SQL("
			SELECT 
        TLP.oi_tot_liq_per
    FROM 
        LIQ19_LIQUIDACION L19
        INNER JOIN LIQ19_EJECUCIONES EJE19 ON L19.oi_liquidacion = EJE19.oi_liquidacion
        INNER JOIN LIQ99_LIQUIDACION L99 ON EJE19.oi_liquidacion_ddo = L99.oi_liquidacion_ddo
        INNER JOIN LIQ99_RECIBOS REC99 ON L99.oi_liquidacion_ddo = REC99.oi_liquidacion_ddo
        INNER JOIN LIQ20_TOT_LIQ_PER TLP ON REC99.oi_tot_liq_per = TLP.oi_tot_liq_per
        WHERE
        L19.e_periodo = { $SOURCE/@e_periodo }
        AND L19.oi_empresa = { $SOURCE/@oi_empresa }
        {%? (string($SOURCE/LIQUIDACIONES/LIQUIDACION/@id)!='')         
            {% AND L19.oi_liquidacion 
                {%? ($SOURCE/@excluir='1')     
                    {% NOT IN ({%= string($SOURCE/LIQUIDACIONES/LIQUIDACION/@id) %}) %} 
                    {% IN     ({%= string($SOURCE/LIQUIDACIONES/LIQUIDACION/@id) %}) %} 
                %}
            %}
            {% %}                    
        %}
				")/ROWS
			</qry:xquery>
			<qry:out>
				<qry:create-doc name="CONTADOR">
					<qry:attribute name="count" value="0"/>
					<qry:attribute name="ois" value="''"/>
				</qry:create-doc>
				<qry:each xquery="for $r in $rs/ROW">
					<qry:if test="$CONTADOR/@count &gt;= 100">
						<qry:then>
							<qry:call>
								<CABECERA>
									<qry:attribute name="oi_empresa" value="$FILTRO/@oi_empresa"/>
									<qry:attribute name="orden1" value="$FILTRO/@orden1"/>
									<qry:attribute name="orden2" value="$FILTRO/@orden2"/>
									<qry:attribute name="dom" value="$VAL/@mostrarDomicilio"/>
									<qry:attribute name="fam" value="'0'"/>
									<qry:attribute name="value" value="substring($CONTADOR/@ois,2)"/>
								</CABECERA>
							</qry:call>
							<qry:with doc-path="$CONTADOR">
								<qry:attribute name="count" value="0"/>
								<qry:attribute name="ois" value="''"/>
							</qry:with>
						</qry:then>
					</qry:if>
					<qry:with doc-path="$CONTADOR">
						<qry:attribute name="count" value="number($CONTADOR/@count)+1"/>
						<qry:attribute name="ois" value="concat($CONTADOR/@ois, ',', $r/@oi_tot_liq_per)"/>
					</qry:with>
				</qry:each>
				<qry:if test="$CONTADOR/@count &gt; 0">
					<qry:then>
						<qry:call>
							<CABECERA>
								<qry:attribute name="oi_empresa" value="$FILTRO/@oi_empresa"/>
								<qry:attribute name="orden1" value="$FILTRO/@orden1"/>
								<qry:attribute name="orden2" value="$FILTRO/@orden2"/>
								<qry:attribute name="dom" value="$VAL/@mostrarDomicilio"/>
								<qry:attribute name="fam" value="'0'"/>
								<qry:attribute name="value" value="substring($CONTADOR/@ois,2)"/>
							</CABECERA>
						</qry:call>
					</qry:then>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="qry_localidad" doc="SOURCE">
			<qry:xquery>
				for $r in SQL("
				SELECT
				    org19_localidades.d_localidad, 
				    org35_provincias.d_provincia, 
				    org35_paises.d_pais
				FROM org19_localidades 
				INNER JOIN org35_provincias ON org19_localidades.oi_provincia = org35_provincias.oi_provincia 
				INNER JOIN org35_paises ON org35_provincias.oi_pais = org35_paises.oi_pais
				WHERE org19_localidades.oi_localidad = {$SOURCE/@oi_localidad}
				")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@d_localidad != ''">
					<qry:then>
						<qry:attribute name="domicilio" value="concat(@domicilio, ' - ', $r/@d_localidad, ', ', $r/@d_provincia, ', ', $r/@d_pais)"/>
					</qry:then>
				</qry:if>
			</qry:out>
		</qry:select>
	</report:for-each>
	<report:query declare="&lt;CABECERA oi_empresa=&quot;1&quot; orden1=&quot;&quot; orden2=&quot;&quot; dom=&quot;0&quot; fam=&quot;0&quot; value=&quot;7430,7431,7432,7433,7434,7435&quot;/&gt;&#13;&#10;">
		<qry:main doc="PARAM" engine="C#">
			<qry:no-show>
				<qry:append-doc name="PARAMIN" doc-path="$PARAM/CABECERA"/>
				<qry:append-doc name="RECIBOS" doc-path="."/>
				<Totales>
					<qry:attribute value="0" name="SUMtotal"/>
					<qry:attribute value="0" name="SUMtotalrem"/>
					<qry:attribute value="0" name="SUMtotalnorem"/>
					<qry:attribute value="0" name="SUMretenciones"/>
				</Totales>
				<qry:insert-select name="QRY_RECIBO" doc-path="$RECIBOS"/>
			</qry:no-show>
		</qry:main>
		<qry:select name="QRY_RECIBO" doc="PARAM">
			<qry:xquery>
				for $r in sql("
SELECT 
    TLP.oi_tot_liq_per,
    {%? ($PARAMIN/@orden1!=''){% {%= $PARAMIN/@orden1 %} orden1,%}{% %} %}
    {%? ($PARAMIN/@orden2!=''){% {%= $PARAMIN/@orden2 %} orden2,%}{% %} %}
    L97.oi_per_emp_ddo, 
    L97.e_numero_legajo,
    L97.c_empresa,  
    L97.c_personal,
    L97.d_ape_y_nom, 								
    L97.f_ingreso, 
    L97.f_egreso,								
    L97.c_nro_cuil nro_cuil,
    L97.c_convenio,
    L97.c_categoria_ult c_categoria,
    L97.f_nacim,
    ORG22_EST_CIVIL.d_estado_civil,
    L97.c_nro_documento,
    L97.c_tipo_documento,
    TLP.oi_liquidacion_ddo,
    TLP.n_totpag total,
    TLP.n_totsret rem,
    (TLP.n_totnsret + TLP.n_totasig) norem,
    (TLP.n_totdesc + TLP.n_totemb) retenciones
FROM                 
    LIQ20_TOT_LIQ_PER TLP
    INNER JOIN LIQ97_PERSONAL_EMP L97 ON TLP.oi_per_emp_ddo = L97.oi_per_emp_ddo
    LEFT JOIN ORG22_EST_CIVIL ON L97.c_estado_civil = ORG22_EST_CIVIL.c_estado_civil
    LEFT JOIN ORG03_UBICACIONES ON L97.c_ubicacion = ORG03_UBICACIONES.c_ubicacion AND ORG03_UBICACIONES.oi_empresa = {%= $PARAMIN/@oi_empresa %}
WHERE
    TLP.oi_tot_liq_per IN ({%= $PARAMIN/@value %})
			")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="R">
					<qry:append-doc name="RDOC" doc-path="."/>
					<qry:attribute value="$r/@oi_tot_liq_per" name="id"/>
					<qry:attribute value="$r/@oi_per_emp_ddo" name="oi_per_emp_ddo"/>
					<qry:attribute name="oi_per_emp_ddo" value="$r/@oi_per_emp_ddo"/>
					<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
					<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="c_personal" value="$r/@c_personal"/>
					<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion"/>
					<qry:attribute name="d_titulo" value="$r/@d_titulo"/>
					<qry:attribute name="f_ingreso" value="iif($r/@f_ingreso != '',format-datetime($r/@f_ingreso,'dd/MM/yyyy'),'')"/>
					<qry:attribute name="f_egreso" value="iif($r/@f_egreso != '',format-datetime($r/@f_egreso,'dd/MM/yyyy'),'')"/>
					<qry:attribute name="nro_cuil" value="$r/@nro_cuil"/>
					<qry:attribute name="d_estado_civil" value="$r/@d_estado_civil"/>
					<qry:attribute name="c_nro_documento" value="concat($r/@c_tipo_documento, ' ', $r/@c_nro_documento)"/>
					<qry:attribute name="f_nacim" value="iif($r/@f_nacim != '', format-datetime($r/@f_nacim,'dd/MM/yyyy'), '' )"/>
					<qry:attribute name="posicion" value="1"/>
					<DET1>
						<qry:append-doc name="detalle1" doc-path="."/>
						<qry:attribute name="tot1" value="0"/>
						<qry:attribute name="conc" value="1"/>
						<qry:insert-select name="QRY_DETALLE" doc-path="$r"/>
						<qry:attribute value="format-number(@tot1, '#########0.00')" name="tot1"/>
					</DET1>
					<qry:attribute name="posicion" value="2"/>
					<DET2>
						<qry:append-doc name="detalle2" doc-path="."/>
						<qry:attribute name="tot2" value="0"/>
						<qry:attribute name="conc" value="'0,2'"/>
						<qry:insert-select name="QRY_DETALLE" doc-path="$r"/>
					</DET2>
					<qry:attribute name="posicion" value="3"/>
					<DET3>
						<qry:append-doc name="detalle3" doc-path="."/>
						<qry:attribute name="tot3" value="0"/>
						<qry:attribute name="conc" value="'3,7'"/>
						<qry:insert-select name="QRY_DETALLE" doc-path="$r"/>
					</DET3>
					<qry:attribute value="format-number($r/@total, '##############0.00')" name="total"/>
					<qry:attribute value="format-number($r/@rem, '##############0.00')" name="totalrem"/>
					<qry:attribute value="format-number($r/@norem, '##############0.00')" name="totalnorem"/>
					<qry:attribute value="format-number(0 - $r/@retenciones, '##############0.00')" name="retenciones"/>
					<qry:attribute value="$RECIBOS/Totales/@SUMtotal + $r/@total" name="SUMtotal" to-element="$RECIBOS/Totales"/>
					<qry:attribute value="$RECIBOS/Totales/@SUMtotalrem + $r/@rem" name="SUMtotalrem" to-element="$RECIBOS/Totales"/>
					<qry:attribute value="$RECIBOS/Totales/@SUMtotalnorem + $r/@norem" name="SUMtotalnorem" to-element="$RECIBOS/Totales"/>
					<qry:attribute value="$RECIBOS/Totales/@SUMretenciones + (0 - $r/@retenciones)" name="SUMretenciones" to-element="$RECIBOS/Totales"/>
					<qry:attribute value="concat(@order, iif($PARAMIN/@orden1!='' and $PARAMIN/@orden1!='0', fill-right($r/@orden1, ' ', 50), ''))" name="order"/>
					<qry:attribute value="concat(@order, iif($PARAMIN/@orden2!='' and $PARAMIN/@orden2!='0', fill-right($r/@orden2, ' ', 50), ''))" name="order"/>
					<qry:attribute value="concat(@order, fill-left($r/@e_numero_legajo, '0', 10))" name="order"/>
					<qry:insert-select name="QRY_CATEGORIA" doc-path="$r"/>
					<qry:insert-select name="QRY_DOMICILIO" doc-path="$r"/>
					<qry:insert-select name="QRY_ORDENAR" doc-path="."/>
					<qry:attribute name="contador" value="1"/>
					<qry:insert-select name="QRY_DETALLES" doc-path="."/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_DOMICILIO" doc="PARAM">
			<qry:xquery>
				for $r in sql('
SELECT
    TLP.oi_tot_liq_per,
    PDM.d_calle,
    PDM.e_numero,
    PDM.d_piso,
    PDM.d_departamento,
    PDM.c_postal,
    PDM.oi_localidad,
    LOC.d_localidad,
    LOC.d_provincia
FROM 
    LIQ20_TOT_LIQ_PER TLP
    INNER JOIN LIQ97_PERSONAL_EMP L97 ON TLP.oi_per_emp_ddo = L97.oi_per_emp_ddo
    INNER JOIN PER01_PERSONAL ON L97.c_personal = PER01_PERSONAL.c_personal
    INNER JOIN PER01_DOMIC_PER PDM ON PER01_PERSONAL.oi_personal = PDM.oi_personal
    LEFT JOIN (
        SELECT 
            ORG19_LOCALIDADES.oi_localidad, 
            ORG19_LOCALIDADES.d_localidad, 
            ORG35_PROVINCIAS.d_provincia
        FROM ORG19_LOCALIDADES 
        INNER JOIN ORG35_PROVINCIAS ON ORG19_LOCALIDADES.oi_provincia = ORG35_PROVINCIAS.oi_provincia
    ) LOC ON PDM.oi_localidad = LOC.oi_localidad
WHERE
    PDM.l_domic_fiscal = 1
    AND TLP.oi_tot_liq_per = {%= $PARAM/@oi_tot_liq_per %}
			')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="pegar_dom" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_CATEGORIA" doc="PARAM">
			<qry:xquery>
				for $r in sql("
SELECT
    TLP.oi_tot_liq_per, 
    LIQ94_CATEG.d_categoria
FROM 
    LIQ19_LIQUIDACION L19
    INNER JOIN LIQ19_EJECUCIONES EJE19 ON L19.oi_liquidacion = EJE19.oi_liquidacion
    INNER JOIN LIQ99_LIQUIDACION L99 ON EJE19.oi_liquidacion_ddo = L99.oi_liquidacion_ddo
    INNER JOIN LIQ99_RECIBOS REC99 ON L99.oi_liquidacion_ddo = REC99.oi_liquidacion_ddo
    INNER JOIN LIQ20_TOT_LIQ_PER TLP ON REC99.oi_tot_liq_per = TLP.oi_tot_liq_per
    INNER JOIN LIQ97_PERSONAL_EMP L97 ON TLP.oi_per_emp_ddo = L97.oi_per_emp_ddo
    INNER JOIN LIQ94_CONVENIOS ON L97.c_convenio = LIQ94_CONVENIOS.c_convenio
    INNER JOIN LIQ94_CATEG ON L97.c_categoria_ult = LIQ94_CATEG.c_categoria 
        AND LIQ94_CONVENIOS.oi_convenio_ddo = LIQ94_CATEG.oi_convenio_ddo
    INNER JOIN LIQ94_CONVENIOS LIQ94_CONVENIOS2 ON L99.oi_codif_ddo = LIQ94_CONVENIOS2.oi_codif_ddo
WHERE
    TLP.oi_tot_liq_per = {%= $PARAM/@oi_tot_liq_per %}
")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:insert-select name="pegar_cat" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_DETALLE">
			<qry:xquery>
				for $r in sql("
SELECT
   	TLP.oi_tot_liq_per,
	TLP.e_secuencia,
	CLP.oi_conc_liq_per, 
	CON.c_concepto, 
	CON.d_concepto, 
	CLP.n_valor,
	CLP.n_cantidad,
	CON.c_tipo_concepto,
	CON.ca_fig_recibo
FROM
    LIQ20_TOT_LIQ_PER TLP
    INNER JOIN liq20_conc_liq_per CLP ON TLP.oi_tot_liq_per = CLP.oi_tot_liq_per
    INNER JOIN liq96_conceptos CON ON CON.oi_concepto_ddo = CLP.oi_concepto_ddo
    INNER JOIN LIQ12_TIPOS_CONC TC ON TC.c_tipo_concepto = CON.c_tipo_concepto
WHERE 
    CON.ca_fig_recibo != 'N' 
    AND (CON.e_etapa IS NULL OR CON.e_etapa != 1) 
    AND CLP.n_valor != 0 
    AND TC.l_nolistado = 0 
    AND TLP.oi_tot_liq_per = {%= $PARAM/@oi_tot_liq_per %}
    {%? (string($RDOC/@posicion) = '1') 
    {%AND TC.c_tipo_concepto = 1 %} {% %}
    %}
    {%? (string($RDOC/@posicion) = '2') 
    {%AND TC.c_tipo_concepto in(0,2)%} {% %}
    %}
    {%? (string($RDOC/@posicion) = '3') 
    {%AND TC.c_tipo_concepto in(3,7)%} {% %}
    %}
ORDER BY c_concepto ASC
		")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$RDOC/@posicion ='1'">
					<qry:then>
						<qry:attribute name="pos" value="$RDOC/@posicion"/>
						<qry:attribute name="tot1" value="number($detalle1/@tot1) + number($r/@n_valor)" to-element="$detalle1"/>
						<qry:insert-select name="pegar_detalle" doc-path="$r"/>
					</qry:then>
				</qry:if>
				<qry:if test="$RDOC/@posicion ='2'">
					<qry:then>
						<qry:attribute name="pos" value="$RDOC/@posicion"/>
						<qry:attribute name="tot2" value="number($detalle2/@tot2) + number($r/@n_valor)" to-element="$detalle2"/>
						<qry:insert-select name="pegar_detalle" doc-path="$r"/>
					</qry:then>
				</qry:if>
				<qry:if test="$RDOC/@posicion ='3'">
					<qry:then>
						<qry:attribute name="pos" value="$RDOC/@posicion"/>
						<qry:attribute name="tot3" value="number($detalle3/@tot3) + number($r/@n_valor)" to-element="$detalle3"/>
						<qry:insert-select name="pegar_detalle" doc-path="$r"/>
					</qry:then>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_dom" doc="r">
			<qry:out>
				<qry:attribute name="domicilio" value="concat($r/@d_calle, ' ' , $r/@e_numero , ' ' , $r/@d_piso , ' ' , $r/@d_departamento)"/>
				<qry:attribute name="domicilio" value="iif($r/@c_postal!='', concat(@domicilio, ' - (', $r/@c_postal, ')'), @domicilio)"/>
				<qry:attribute name="domicilio" value="iif($r/@c_postal!='', concat(@domicilio, ' ', $r/@d_localidad, ', ', $r/@d_provincia), @domicilio)"/>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_cat" doc="r">
			<qry:out>
				<qry:attribute name="d_categoria" value="$r/@d_categoria"/>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_detalle" doc="r">
			<qry:out>
				<qry:element name="DET">
					<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
					<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
					<qry:attribute value="iif($r/@ca_fig_recibo='S', format-number($r/@n_cantidad, '##########0.00'), '')" name="cant"/>
					<qry:attribute value="format-number($r/@n_valor, '###############0.00')" name="val"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select name="pegar_fam" doc="r">
			<qry:out>
				<F>
					<qry:attribute value="$r/@d_tipo_familiar" name="d_tipo_familiar"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="d_familiar"/>
					<qry:attribute value="$r/@c_tipo_documento + ' ' + $r/@c_nro_documento" name="doc_familiar"/>
					<qry:attribute value="iif($r/@f_nacimiento != '',format_date($r/@f_nacimiento,'dd/mm/yyyy'),'')" name="f_nacim_familiar"/>
				</F>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_ORDENAR" doc="r">
			<qry:out>
				<qry:attribute name="tr" value="iif(number($r/DET1/@tot1)!=0, format-number($r/DET1/@tot1,'#########0.00'), '')"/>
				<qry:attribute name="tn" value="iif(number($r/DET2/@tot2)!=0, format-number($r/DET2/@tot2,'#########0.00'), '')"/>
				<qry:attribute name="td" value="iif(number($r/DET3/@tot3)!=0, format-number($r/DET3/@tot3,'#########0.00'), '')"/>
				<qry:attribute name="max" value="iif(count($r/DET1/DET)&gt;count($r/DET2/DET), count($r/DET1/DET), count($r/DET2/DET))"/>
				<qry:attribute name="max" value="iif(count($r/DET3/DET) &gt; @max, count($r/DET3/DET), @max)"/>
			</qry:out>
		</qry:select>
		<qry:select name="QRY_DETALLES" doc="r">
			<qry:xquery>
				for $r in sql("
					SELECT rn 
FROM (
    SELECT oi_parametro,
           ROW_NUMBER() OVER (ORDER BY oi_parametro) AS rn
    FROM ORG26_PARAMETROS
) nombre
WHERE rn &lt;= {%= $R/@max %}
    		")/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:element name="D">
					<qry:if test="number($RDOC/@contador) &lt;= count($RDOC/DET1/DET)">
						<qry:then>
							<qry:attribute name="i1" value="$RDOC/DET1/DET[(number($RDOC/@contador))]/@c_concepto"/>
							<qry:attribute name="d1" value="$RDOC/DET1/DET[(number($RDOC/@contador))]/@d_concepto"/>
							<qry:attribute name="c1" value="$RDOC/DET1/DET[(number($RDOC/@contador))]/@cant"/>
							<qry:attribute name="v1" value="$RDOC/DET1/DET[(number($RDOC/@contador))]/@val"/>
						</qry:then>
					</qry:if>
					<qry:if test="number($RDOC/@contador) &lt;= count($RDOC/DET2/DET)">
						<qry:then>
							<qry:attribute name="i2" value="$RDOC/DET2/DET[(number($RDOC/@contador))]/@c_concepto"/>
							<qry:attribute name="d2" value="$RDOC/DET2/DET[(number($RDOC/@contador))]/@d_concepto"/>
							<qry:attribute name="c2" value="$RDOC/DET2/DET[(number($RDOC/@contador))]/@cant"/>
							<qry:attribute name="v2" value="$RDOC/DET2/DET[(number($RDOC/@contador))]/@val"/>
						</qry:then>
					</qry:if>
					<qry:if test="number($RDOC/@contador) &lt;= count($RDOC/DET3/DET)">
						<qry:then>
							<qry:attribute name="i3" value="$RDOC/DET3/DET[(number($RDOC/@contador))]/@c_concepto"/>
							<qry:attribute name="d3" value="$RDOC/DET3/DET[(number($RDOC/@contador))]/@d_concepto"/>
							<qry:attribute name="c3" value="$RDOC/DET3/DET[(number($RDOC/@contador))]/@cant"/>
							<qry:attribute name="v3" value="$RDOC/DET3/DET[(number($RDOC/@contador))]/@val"/>
						</qry:then>
					</qry:if>
				</qry:element>
				<qry:attribute name="contador" value="$RDOC/@contador + 1" to-element="$RDOC"/>
			</qry:out>
		</qry:select>
	</report:query>
