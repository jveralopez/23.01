<qry:define xmlns:qry="nomad_engine.qry" declare="&lt;DATOS batch-id=&quot;&quot;&gt;&lt;ROWS /&gt;&lt;DATOS oi_empresa=&quot;&quot; salida=&quot;HTML&quot; oi_liquidacion=&quot;&quot; oi_variable=&quot;&quot; report=&quot;&quot; gpers=&quot;1&quot; gcustom=&quot;&quot; oi_empresaFIL=&quot;1&quot; oi_liquidacionFIL=&quot;239&quot; l_anioAnterior=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; /&gt;&lt;/DATOS&gt;" name="QUERY_CRYSTAL">
	<qry:main doc="SOURCE">
		<qry:append-doc doc-path="#SOURCE:DATOS/DATOS" name="PARAM"/>
		<qry:append-doc doc-path="#SOURCE:DATOS" name="PARAM2"/>
		<qry:element name="DATOS">
			<qry:insert-select doc-path="#PARAM:" name="qry_cabecera"/>
		</qry:element>
	</qry:main>
	<qry:select name="qry_cabecera" doc="SOURCE">
		<qry:xquery>
			for $r in sql('
SELECT 
	O.c_empresa
	, O.d_empresa
	, O.c_cuit
	, E.d_dependencia_emp
	, E.d_encargado_F649
	, E.d_puesto_enc_F649
	, E.d_lugar_F649
	, E.oi_firma_f649
	, L.f_pago
	, getyear(L.f_pago) as anio
	, getmonth(L.f_pago) as mes
	, L.f_f649
	, L.oi_liquidacion
FROM 
	ORG03_EMPRESAS AS O
	, LIQ19_LIQUIDACION AS L
	, LIQ15_EMPRESAS AS E
JOIN
	O.oi_empresa INNER L.oi_empresa
	, O.oi_empresa INNER E.oi_empresa
WHERE
	O.oi_empresa = {#PARAM:@oi_empresaFIL}
	AND L.oi_liquidacion = {#PARAM:@oi_liquidacionFIL}
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="d_encargado_F649" value="$r/@d_encargado_F649"/>
			<qry:attribute name="d_puesto_enc_F649" value="$r/@d_puesto_enc_F649"/>
			<qry:attribute name="d_lugar_F649" value="$r/@d_lugar_F649"/>
			<qry:attribute name="oi_firma_F649" value="$r/@oi_firma_f649"/>
			<qry:attribute name="f_emision_F649" value="$r/@f_f649"/>
			<qry:attribute name="f_f649" value="$r/@f_f649"/>
			<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
			<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
			<qry:attribute name="f_pago" value="$r/@f_pago"/>
			<qry:attribute name="c_cuit_emp" value="$r/@c_cuit"/>
			<qry:attribute name="c_cuit" value="$r/@c_cuit"/>
			<qry:attribute name="d_dependencia_emp" value="$r/@d_dependencia_emp"/>
			<qry:insert-select doc-path="$r" name="qry_personas"/>
		</qry:out>
	</qry:select>
	<qry:select name="qry_personas" doc="SOURCE">
		<qry:xquery>
			for $r in sql('
SELECT
	P.oi_per_emp_ddo
	, P.e_numero_legajo
	, P.d_ape_y_nom
	, P.c_nro_cuil	
	, PS.d_dependencia_per
	, PS.o_F649
	, PE.oi_personal_emp 
	, T.oi_tot_liq_per
	, GetYear(L.f_pago) as anio
FROM 
	LIQ19_EJECUCIONES AS E
	, LIQ99_LIQUIDACION AS L
	, LIQ99_RECIBOS AS R
	, LIQ20_TOT_LIQ_PER AS T
	, LIQ97_PERSONAL_EMP AS P
	, LIQ25_PERSONAL_LIQ AS PL
	, PER02_PERSONAL_EMP AS PE
	, LIQ07_PERSONAL AS PS
JOIN
	E.oi_liquidacion_ddo INNER L.oi_liquidacion_ddo
	, L.oi_liquidacion_ddo INNER R.oi_liquidacion_ddo
	, R.oi_tot_liq_per INNER T.oi_tot_liq_per
	, T.oi_per_emp_ddo INNER P.oi_per_emp_ddo
	, E.oi_liquidacion INNER PL.oi_liquidacion
	, PL.oi_personal_emp INNER PE.oi_personal_emp
	, PL.oi_personal_emp INNER PS.oi_personal_emp
	, PE.e_numero_legajo INNER P.e_numero_legajo

WHERE	
	E.oi_liquidacion = {%= #SOURCE:@oi_liquidacion %}	
	{%? (string(#PARAM2:ROWS/ROW/@id)!='') {% AND PE.oi_personal_emp in ({%=string(#PARAM2:ROWS/ROW/@id) %}) %} {% %} %}
	AND L.c_estado = \'F\'

ORDER BY
	e_numero_legajo ASC
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<PERSONA>
				<!-- INICIAR VARIABLES -->
				<qry:insert-select doc-path="." name="QRY_INI_VAR"/>
				<!-- DATOS GENERALES -->
				<qry:attribute name="oi_per_emp_ddo" value="$r/@oi_per_emp_ddo"/>
				<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
				<qry:attribute name="d_encargado_F649" value="#SOURCE:@d_encargado_F649"/>
				<qry:attribute name="d_puesto_enc_F649" value="#SOURCE:@d_puesto_enc_F649"/>
				<qry:attribute name="d_lugar_F649" value="#SOURCE:@d_lugar_F649 + ' - ' + format_date(#SOURCE:@f_f649,'dd/mm/yyyy')"/>
				<qry:attribute name="oi_firma_F649" value="#SOURCE:@oi_firma_f649"/>
				<qry:attribute name="d_empresa" value="#SOURCE:@d_empresa"/>
				<qry:attribute name="temp" value="substring_after(#SOURCE:@c_cuit,'-')"/>
				<qry:if test="@temp!=''">
					<qry:then>
						<qry:attribute name="c_cuit_emp" value="#SOURCE:@c_cuit"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="c_cuit_emp" value="substring(#SOURCE:@c_cuit,0,2) + '-' + substring(#SOURCE:@c_cuit, 2, (string_length(#SOURCE:@c_cuit)-3))  + '-' + substring(#SOURCE:@c_cuit, (string_length(#SOURCE:@c_cuit)-1),1)"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="d_dependencia_emp" value="#SOURCE:@d_dependencia_emp"/>
				<!-- DATOS PERSONALES -->
				<qry:attribute name="temp" value="substring_after($r/@c_nro_cuil,'-')"/>
				<qry:if test="@temp!=''">
					<qry:then>
						<qry:attribute name="c_cuil" value="$r/@c_nro_cuil"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="c_cuil" value="substring($r/@c_nro_cuil,0,2) + '-' + substring($r/@c_nro_cuil, 2, (string_length($r/@c_nro_cuil)-3))  + '-' + substring($r/@c_nro_cuil, (string_length($r/@c_nro_cuil)-1),1)"/>
					</qry:else>
				</qry:if>
				<qry:attribute name="c_cuit" value="' '"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="d_dependencia_per" value="$r/@d_dependencia_per"/>
				<qry:attribute name="o_observaciones_F649" value="$r/@o_F649"/>
				<qry:insert-select doc-path="$r" name="QRY_DOMICILIOS"/>
				<qry:if test="#PARAM:@l_anioAnterior!=1">
					<qry:then>
						<qry:attribute name="e_anio" value="$r/@anio"/>
						<qry:insert-select doc-path="." name="QRY_BUSCAR_VAR"/>
						<qry:attribute name="f_desde" value="'01/01/'+@e_anio"/>
						<qry:attribute name="f_hasta" value="datetime(number(datetime(substring_before(number(substring(#SOURCE:@f_pago,0,6)) + 1,'.') + '01'))-1)"/>
						<qry:attribute name="f_hasta" value="format_date(@f_hasta,'dd/mm/yyyy')"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="e_anio" value="number($r/@anio) - 1"/>
						<qry:insert-select doc-path="$r" name="QRY_DATOS_ANIO_ANTERIOR"/>
						<qry:attribute name="f_desde" value="'01/01/'+@e_anio"/>
						<qry:attribute name="f_hasta" value="'31/12/'+@e_anio"/>
					</qry:else>
				</qry:if>
				<qry:insert-select doc-path="$r" name="QRY_CALCULAR_TOTALES"/>
				<qry:attribute name="n_tot10a" value="0"/>
				<qry:attribute name="n_tot10b" value="0"/>
				<qry:if test="number(@n_tot8) &gt; number(@n_tot9)">
					<qry:then>
						<qry:attribute name="n_tot10a" value="number(@n_tot8) - number(@n_tot9)"/>
					</qry:then>
				</qry:if>
				<qry:if test="number(@n_tot9) &gt; number(@n_tot8)">
					<qry:then>
						<qry:attribute name="n_tot10b" value="number(@n_tot9) - number(@n_tot8)"/>
					</qry:then>
				</qry:if>
				<qry:insert-select doc-path="$r" name="QRY_DATOS_GENERICOS"/>
				<qry:insert-select doc-path="$r" name="QRY_FORMATEAR"/>
			</PERSONA>
		</qry:out>
	</qry:select>
	<qry:select name="QRY_DOMICILIOS" doc="SOURCE">
		<qry:xquery>
