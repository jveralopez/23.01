			<qry:element name="LEG">
				<qry:attribute value="format_date(now(),'ddd') + ' de ' + format_date(now(),'mmm') + ' de ' + format_date(now(),'yyyyy')" name="date"/>
				<qry:attribute value="format_date(now(),'dd')" name="date1"/>
				<qry:attribute value="format_date(now(),'mmm')" name="mes"/>
				<qry:attribute value="format_date(now(),'yyyy')" name="date3"/>
				<qry:attribute name="dia" value="nmd-num2text(@date1)"/>
				<qry:attribute name="anio" value="nmd-num2text(@date3)"/>
				<qry:attribute name="logo" value="#SOURCE:PARAMS/@logo"/>
				<qry:append-doc name="FILTRO" doc-path="#SOURCE:PARAMS"/>
				<qry:attribute name="logo" value="#SOURCE:PARAMS/@logo"/>
				<qry:insert-select name="QRY_EMPLEADOR" doc-path="#SOURCE:PARAMS"/>
				<qry:insert-select name="QRY_EMPLEADO" doc-path="#SOURCE:PARAMS"/>
			</qry:element>
		</qry:main>
		<qry:select doc="PARAM" name="QRY_EMPLEADOR">
			<qry:xquery>
				for $r in SQL('
SELECT 
    	ORG03_EMPRESAS.d_empresa,
    	ORG03_EMPRESAS.c_cuit,
    	ORG03_EMPRESAS.d_ingreso_bruto,
    	ORG03_EMPRESAS.d_imp_gan,
    	ORG03_EMPRESAS.d_calle,
    	ORG03_EMPRESAS.e_numero,
    	ORG03_EMPRESAS.te_telefono,
 					ORG03_EMPRESAS.f_inicio_act,
 					ORG03_EMPRESAS.oi_localidad,
 					ORG34_ACTIVIDADES.d_actividad,
 					ORG19_LOCALIDADES.d_localidad
FROM
	ORG03_EMPRESAS,
	PER02_PERSONAL_EMP,
	ORG34_ACTIVIDADES,
	ORG19_LOCALIDADES
JOIN                    
  ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
  ORG03_EMPRESAS.oi_actividad LEFT OUTER ORG34_ACTIVIDADES.oi_actividad,
  ORG03_EMPRESAS.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad
    		WHERE 
	PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute name="domic_emp" value="$r/@d_calle +' '+ $r/@e_numero + ' '+ $r/@d_localidad"/>
				<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
				<qry:attribute name="c_cuit" value="$r/@c_cuit"/>
				<qry:attribute name="d_ingreso_bruto" value="$r/@d_ingreso_bruto"/>
				<qry:switch test="$r/@d_imp_gan">
					<qry:case value="1">
						<qry:attribute name="d_imp_gan" value="'Responsable Inscripto'"/>
					</qry:case>
					<qry:case value="2">
						<qry:attribute name="d_imp_gan" value="'Exento'"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="d_imp_gan" value="'No Inscripto'"/>
					</qry:default>
				</qry:switch>
				<qry:attribute name="f_inicio_act" value="format_date($r/@f_inicio_act,'dd/mm/yyyy')"/>
				<qry:attribute name="te_telefono" value="$r/@te_telefono"/>
				<qry:attribute name="d_localidad" value="substring-before($r/@d_localidad,' (')"/>
				<qry:attribute name="d_actividad" value="$r/@d_actividad"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_EMPLEADO">
			<qry:xquery>
				for $r in SQL('
SELECT
PER02_PERSONAL_EMP.oi_personal_emp, 
PER02_PERSONAL_EMP.e_numero_legajo,
PER02_PERSONAL_EMP.c_alta_afip,
PER02_PERSONAL_EMP.f_ingreso,
PER02_PERSONAL_EMP.f_egreso,
PER01_PERSONAL.d_ape_y_nom,
PER01_PERSONAL.c_nro_cuil,
PER01_PERSONAL.f_nacim,
PER01_PERSONAL.c_nro_documento,
PER20_TIPOS_DOC.c_tipo_documento,
ORG19_LOCALIDADES.d_localidad,
ORG03_FUNCIONES.d_funcion,
ORG18_CATEGORIAS.d_categoria,
PER01_DOMIC_PER.d_calle,
PER01_DOMIC_PER.e_numero,
PER01_DOMIC_PER.d_piso,
PER01_DOMIC_PER.d_departamento,
ORG03_UBICACIONES.d_ubicacion
FROM
ORG03_EMPRESAS,
PER02_PERSONAL_EMP,
PER01_PERSONAL,
PER20_TIPOS_DOC,
ORG19_LOCALIDADES,
ORG03_FUNCIONES,
ORG18_CATEGORIAS,
PER01_DOMIC_PER(PER01_DOMIC_PER.l_domic_fiscal = 1),
ORG03_UBICACIONES
JOIN                    
ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
PER01_PERSONAL.oi_tipo_documento INNER PER20_TIPOS_DOC.oi_tipo_documento,
PER01_PERSONAL.oi_personal LEFT OUTER PER01_DOMIC_PER.oi_personal,
PER01_DOMIC_PER.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad,
PER02_PERSONAL_EMP.oi_categoria_ult LEFT OUTER ORG18_CATEGORIAS.oi_categoria,
PER02_PERSONAL_EMP.oi_funcion LEFT OUTER ORG03_FUNCIONES.oi_funcion,
PER02_PERSONAL_EMP.oi_ubicacion LEFT OUTER ORG03_UBICACIONES.oi_ubicacion
WHERE 
PER02_PERSONAL_EMP.oi_personal_emp = {#PARAM:@oi_personal_emp}
')/ROWS/ROW
