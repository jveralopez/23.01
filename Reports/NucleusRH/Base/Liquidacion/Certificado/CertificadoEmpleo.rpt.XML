				<qry:attribute name="d_area" value="$r/@d_ubicacion"/>
				<qry:attribute name="f_nacim" value="format_date($r/@f_nacim, 'dd/mm/yyyy')"/>
				<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso, 'dd/mm/yyyy')"/>
				<qry:attribute name="f_egreso" value="format_date($r/@f_egreso, 'dd/mm/yyyy')"/>
				<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
				<qry:attribute name="c_alta_afip" value="$r/@c_alta_afip"/>
				<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
				<qry:attribute name="c_nro_cuil" value="$r/@c_nro_cuil"/>
				<qry:attribute name="domic_per" value="$r/@c_nro_cuil"/>
				<qry:attribute name="domic_per" value="$r/@d_calle + ' ' + $r/@e_numero"/>
				<qry:attribute name="domic_per" value="@domic_per + iif($r/@d_piso !='', ' piso ' + $r/@d_piso, '')"/>
				<qry:attribute name="domic_per" value="@domic_per + iif($r/@d_departamento !='', ' dpto. ' + $r/@d_departamento, '') + ' ' +$r/@d_localidad"/>
				<qry:attribute name="documento" value="$r/@c_tipo_documento + ' ' +$r/@c_nro_documento"/>
				<qry:attribute name="respuesta" value="'NO SE CONOCEN'"/>
				<qry:insert-select name="QRY_PEND" doc-path="$r"/>
				<qry:insert-select name="QRY_REMUN" doc-path="$r"/>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_PEND">
			<qry:xquery>
				for $r in SQL(' 
SELECT 
LIQ07.f_recepcion,
LIQ07.c_estado, 
LIQ07.oi_embargo,
LIQ07.c_nro_expediente,
LIQ07.d_juzgado,
LIQ07.o_caratula,
LIQ07.n_monto_total,
LIQ07.n_monto_pend
FROM
LIQ07_EMBARGOS AS LIQ07
WHERE                 
  LIQ07.oi_personal_emp = {#PARAM:@oi_personal_emp} AND
LIQ07.c_estado != \'N\' AND
 	LIQ07.n_monto_pend &gt; 0
ORDER BY
f_recepcion ASC
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:if test="$r/@oi_embargo!=''">
					<qry:then>
						<qry:attribute name="respuesta" value="''"/>
					</qry:then>
				</qry:if>
				<qry:element name="EMB">
					<qry:attribute name="f_recep_pend" value="format_date($r/@f_recepcion,'dd/mm/yyyy')"/>
					<qry:attribute name="o_embargo_pend" value="$r/@o_caratula"/>
					<qry:attribute name="d_juzgado_pend" value="$r/@d_juzgado"/>
					<qry:attribute name="c_nro_expediente_pend" value="$r/@c_nro_expediente"/>
					<qry:attribute name="o_caratula_pend" value="$r/@o_caratula"/>
					<qry:attribute name="caratula_pend" value="$r/@c_nro_expediente + ' ' + $r/@d_banco + ' ' + $r/@o_caratula"/>
					<qry:attribute name="d_banco_pend" value="$r/@d_banco"/>
					<qry:attribute name="n_monto_pend" value="Concat('$', FORMAT_NUMBER($r/@n_monto_pend, 10, 2, '.', ',', ''))"/>
				</qry:element>
			</qry:out>
		</qry:select>
		<qry:select doc="PARAM" name="QRY_REMUN">
			<qry:xquery>
				for $r in sql('
maxsize 1		
SELECT                                          
  SUM(LIQ07_VAL_VARPA.n_valor) as remuneracion,
  LIQ07_VAL_VARPA.e_periodo
FROM 
LIQ07_VAL_VARPA,
LIQ09_VARIABLES
JOIN            
LIQ07_VAL_VARPA.oi_variable INNER LIQ09_VARIABLES.oi_variable
WHERE
LIQ07_VAL_VARPA.oi_personal_emp = {#PARAM:@oi_personal_emp} AND
LIQ09_VARIABLES.c_variable in (\'aa_totsret\',\'aa_totnsret\')
GROUP BY 
LIQ07_VAL_VARPA.e_periodo
ORDER BY 
e_periodo DESC                 
')/ROWS/ROW
			</qry:xquery>
			<qry:out>
				<qry:attribute value="$r/@e_periodo" name="periodo1"/>
				<qry:attribute value="iif($r/@e_periodo!='',format_date($r/@e_periodo+'01','MMM \\DE yyyy'),'')" name="periodo"/>
				<qry:attribute name="remun" value="FORMAT_NUMBER($r/@remuneracion, 10, 2, '.', ',', '')"/>
			</qry:out>
		</qry:select>
	</report:query>
