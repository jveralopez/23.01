			<VAR c_tipo_parametro="IN" c_variable="vs_afipsueldomasadic"/>
			<VAR c_tipo_parametro="OUT" c_variable="vs_afipzonadesfavorable"/>
			double topeSueldo = 8711.82;
double topeSac = 4355.91;
double topeVac = 8711.82;
if (Liquidacion.Periodo &gt;= 200909 &amp;&amp; Liquidacion.Periodo&lt;201003)
{
	topeSueldo = 9351.30;
	topeVac = 9351.30;
	topeSac = 4675.65;
}
if (Liquidacion.Periodo &gt;= 201003)
{
	topeSueldo = 10119.08;
	topeVac = 10119.08;
	topeSac = 5059.54;
}

double ST = 0d;
double SST = 0d;
double sacTopeado = 0d;
double vacTopeado = 0d;
double STCN = 0d;
double SSTCN = 0d;

SST = Round(aa_totsret,2) - Round(aa_totsac,2) - Round(ac_afipvacaciones,2);
SSTCN = Round(aa_totsret,2) - Round(aa_totsac,2) - Round(ac_afipvacaciones,2) + Round(aa_noremcondesc,2);

if (Legajo.TipoPersonal == "3")
{
	SST = Round(aa_totnsret,2);
	SSTCN = Round(aa_totnsret,2);
}

/* Aplica los topes */
ST = SST;
ST = LiqUtilBase.Min(topeSueldo, SST);
STCN = SSTCN;
STCN = LiqUtilBase.Min(topeSueldo, SSTCN);

sacTopeado = aa_totsac;
sacTopeado = LiqUtilBase.Min(topeSac, aa_totsac);

vacTopeado = ac_afipvacaciones;
vacTopeado = LiqUtilBase.Min(topeVac, ac_afipvacaciones);

vs_afipremunimpo1 = Round(ST,2) + Round(vacTopeado,2) + Round(sacTopeado,2);
vs_afipremunimpo2 = Round(SST,2) + Round(ac_afipvacaciones,2) + Round(aa_totsac,2);
vs_afipremunimpo3 = Round(SST,2) + Round(ac_afipvacaciones,2) + Round(aa_totsac,2);
vs_afipremunimpo4 = Round(STCN,2) + Round(vacTopeado,2) + Round(sacTopeado,2);
vs_afipremunimpo5 = Round(ST,2) + Round(vacTopeado,2) + Round(sacTopeado,2);
vs_afipremunimpo6 = Round(SST,2) + Round(ac_afipvacaciones,2) + Round(aa_totsac,2);
vs_afipremunimpo7 = Round(SST,2) + Round(ac_afipvacaciones,2) + Round(aa_totsac,2);
vs_afipremunimpo8 = Round(SSTCN,2) + Round(ac_afipvacaciones,2) + Round(aa_totsac,2); //alias remun 8

if (vs_afipsueldomasadic == 0)
	vs_afipsueldomasadic = Round(SST,2) - Round(vs_afipsueldoadic,2) - Round(vs_afippremios,2) - Round(vs_afiphextras,2) - Round(vs_afipzonadesfavorable,2);
		</CON>
		<CON c_concepto="70000300" c_grupo_tliq="100" c_tipo_concepto="6" ca_acum_ganancia="N" ca_fig_recibo="N" d_concepto="SICOSS - Situaciones de Revista" e_secuencia="300300" l_activo="1" l_ej_ajuste="1" l_retroactivo="0">
			<VAR c_tipo_parametro="OUT" c_variable="vs_afipdiasiturev1"/>
			<VAR c_tipo_parametro="OUT" c_variable="vs_afipdiasiturev2"/>
			<VAR c_tipo_parametro="OUT" c_variable="vs_afipdiasiturev3"/>
