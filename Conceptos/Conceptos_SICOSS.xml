			<VAR c_tipo_parametro="OUT" c_variable="vs_afipsiturev3"/>
			System.Collections.ArrayList arrRevistas = new System.Collections.ArrayList();
int intContador = 0;

DateTime dteLastFecha = LastDateMonth(Liquidacion.Fecha);
DateTime dteFecha = FirstDateMonth(Liquidacion.Fecha);

if (dteFecha &lt; Legajo.FechaIngreso) {
 dteFecha = Legajo.FechaIngreso;
}
arrRevistas.Add("01:" + dteFecha.Day.ToString()); //(TipoLic:Dia)

//Recorre las licencias para el per&#237;odo actual
foreach(NucleusRH.Base.Liquidacion.LegajoEmpresaDDO.LICEN_PER_DDO licencia in Adic.ObtenerLicencias(Liquidacion.Periodo)) {
    //Warning(" Licencia: " + licencia.CodSIJP.ToString() + ":" + licencia.FechaInicio.ToString());
    if (licencia.CodSIJPNull || licencia.CodSIJP == "" || licencia.CodSIJP == "9999") continue;
    intContador++;

    if (intContador == 1) {
        if (licencia.FechaInicio &lt;= dteFecha) {
            arrRevistas[arrRevistas.Count - 1] = licencia.CodSIJP + ":1";
        } else {
            arrRevistas.Add(licencia.CodSIJP + ":" + licencia.FechaInicio.Day.ToString());
        }

    } else {
        if (licencia.FechaInicio.Date == dteFecha.Date)
        {   //Agrega la situacion de la licencia
            if (((string) arrRevistas[arrRevistas.Count - 1]).Split(':')[0] != licencia.CodSIJP)
              arrRevistas.Add(licencia.CodSIJP + ":" + licencia.FechaInicio.Day.ToString());
        } else {
            //Agrega una situacion de activo y despu&#233;s la de la licencia
            arrRevistas.Add("01:" + dteFecha.Day.ToString());
            arrRevistas.Add(licencia.CodSIJP + ":" + licencia.FechaInicio.Day.ToString());
        }
    }
    dteFecha = licencia.FechaFin.AddDays(1d);
    if (arrRevistas.Count &gt;= 3) //La lista debe venir ordenada
        break;
}

if (arrRevistas.Count &lt; 3) {
  //Agrega el &#250;ltimo activo
    if (arrRevistas.Count == 1)
       arrRevistas.Add("0:" + dteFecha.Day.ToString());
  else
   {
        arrRevistas.Add((dteFecha &gt; dteLastFecha ? "0:" : "1:") + dteFecha.Day.ToString());
  }
    arrRevistas.Add("0:0");
    arrRevistas.Add("0:0");
}

string[] arrSitRevista;
for (int x = 0; x &lt; 3; x++) {
    arrSitRevista = ((string) arrRevistas[x]).Split(':');
    switch (x) {
        case 0:
            vs_afipsiturev = int.Parse(arrSitRevista[0]);
            vs_afipsiturev1 = int.Parse(arrSitRevista[0]);
            vs_afipdiasiturev1 = int.Parse(arrSitRevista[1]);
            break;
        case 1:
            if ((string) arrSitRevista[0] != "0") {
                vs_afipsiturev = int.Parse(arrSitRevista[0]);
                vs_afipsiturev2 = int.Parse(arrSitRevista[0]);
                vs_afipdiasiturev2 = int.Parse(arrSitRevista[1]);
            }
            break;
        case 2:
            if ((string) arrSitRevista[0] != "0") {
                vs_afipsiturev = int.Parse(arrSitRevista[0]);
                vs_afipsiturev3 = int.Parse(arrSitRevista[0]);
                vs_afipdiasiturev3 = int.Parse(arrSitRevista[1]);
            }
            break;
    }
}
if (vs_afipsiturev1!=0)
 vs_afipsituacion = vs_afipsiturev1;
if (vs_afipsiturev2!=0)
 vs_afipsituacion = vs_afipsiturev2;
if (vs_afipsiturev3!=0)
 vs_afipsituacion = vs_afipsiturev3;
		</CON>
