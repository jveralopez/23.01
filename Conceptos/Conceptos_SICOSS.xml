			int tempCant = 0;  //Temporal para hijos
int tempCant1 = 0; //Temporal para conyuge
int tempAdhe = ax_famasigos; // Temporal para Adherentes

if ((Legajo.EstadoCivil == "CAS")||(Legajo.EstadoCivil == "CON"))
{
  tempCant1 = 1;
}

foreach(NucleusRH.Base.Liquidacion.LegajoEmpresaDDO.FAM_PER_DDO familiar in Legajo.Familiares)
{
  //Es Hijo?
  if (familiar.Vive &amp;&amp; (familiar.TipoFamiliar == "2"||
  familiar.TipoFamiliar == "3"||familiar.TipoFamiliar == "18"||
  familiar.TipoFamiliar == "19")&amp;&amp; familiar.ACargoObraSocial)
  {
    tempCant = tempCant + 1;
  }

}

// Codigo de Conyuge
if (Adic.ExisteValorParametro("vs_afipconyuge"))
{
  //Usa el valor del par&#225;metro
  vs_afipconyuge = (int)Adic.ObtenerValorParametro("vs_afipconyuge");
} else
  {
    vs_afipconyuge = tempCant1;
  }

// Cantidad de Hijos
if (Adic.ExisteValorParametro("vs_afipcantidadhijos"))
{
  //Usa el valor del par&#225;metro
  vs_afipcantidadhijos = (int)Adic.ObtenerValorParametro("vs_afipcantidadhijos");
} else
  {
    vs_afipcantidadhijos = tempCant;
  }

// Cantidad de Adherentes
if (Adic.ExisteValorParametro("vs_afipcantadherentes"))
{
  //Usa el valor del par&#225;metro
  vs_afipcantadherentes = (int)Adic.ObtenerValorParametro("vs_afipcantadherentes");
} else
  {
    vs_afipcantadherentes = tempAdhe;
  }

/*
