			<VAR c_tipo_parametro="IN" c_variable="aa_totnsret"/>
			<VAR c_tipo_parametro="IN" c_variable="aa_totsac"/>
			<VAR c_tipo_parametro="IN" c_variable="aa_totsret"/>
