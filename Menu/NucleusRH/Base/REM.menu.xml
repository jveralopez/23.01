<APP-MENU label="Sistema Integral para la Gesti&#243;n del Capital Humano">
	<MODULE name="rem" descr="Analisis de Remuneraciones" label="Remuneraciones" image="rem">
		<SECTION name="MAIN" label="Operaciones Principales en Analisis de Remuneraciones" descr="Acciones mas comunes del modulo" type="MAIN" image="MAIN" enabled="1">
			<GROUP name="LEGA" base="ME.REM.PROCESS.LEGA" copyattr="1"/>
			<GROUP descr="Principales reportes del modulo" label="Reportes" copyattr="1">
				<ITEM name="001" base="ME.REM.REPORT.GRALES.001" copyattr="1"/>
				<ITEM name="101" base="ME.REM.REPORT.PPUPOS.101" copyattr="1"/>
				<ITEM name="102" base="ME.REM.REPORT.PPUPOS.102" copyattr="1"/>
				<ITEM name="201" base="ME.REM.REPORT.PCONCA.201" copyattr="1"/>
				<ITEM name="202" base="ME.REM.REPORT.PCONCA.202" copyattr="1"/>
				<ITEM name="203" base="ME.REM.REPORT.PCONCA.203" copyattr="1"/>
				<ITEM name="301" base="ME.REM.REPORT.PLEGA.301" copyattr="1"/>
			</GROUP>
		</SECTION>
		<SECTION name="PROCESS" label="Procesos para Analisis de Remuneraciones" type="PROCESS" image="PROCESS" enabled="1">
			<GROUP name="LEGA" descr="Datos de analisis de remuneraciones por legajo" label="Legajos" copyattr="1">
				<ITEM name="LEGANA" action="NucleusRH.Base.AnalisisRemun.Legajo_Analisis.flow:initialize" label="Legajos Analisis" copyattr="1"/>
			</GROUP>
			<GROUP name="INTER" label="Interface" copyattr="1">
				<ITEM name="ENAYR" action="NucleusRH.Base.AnalisisRemun.Interface.flow_Entrada:initialize" label="Entrada Analisis y Remun" copyattr="1"/>
				<ITEM name="SAAYR" action="NucleusRH.Base.AnalisisRemun.Interface.flow_Salida:initialize" label="Salida Analisis y Remun" copyattr="1"/>
			</GROUP>
		</SECTION>
		<SECTION name="REPORT" label="Reportes de Analisis de Remuneraciones" type="REPORT" image="REPORT" enabled="1">
			<GROUP name="GRALES" descr="Reportes genericos" label="Generales" copyattr="1">
				<ITEM name="001" label="001 - Asignacion de Puestos" action="NucleusRH.Base.AnalisisRemun.Reportes.AsignacionPuestos.flow:initialize" copyattr="1"/>
			</GROUP>
			<GROUP name="PPUPOS" descr="Reportes para analisis jerarquico" label="Por Puesto/Posicion" copyattr="1">
				<ITEM name="101" label="101 - Desvios por Puestos/Posicion" action="NucleusRH.Base.AnalisisRemun.Reportes.DesviosPosicion.flow:initialize" copyattr="1"/>
				<ITEM name="102" label="102 - Costo Laboral por Posicion" action="NucleusRH.Base.AnalisisRemun.Reportes.CostoLaboralPosicion.flow:initialize" copyattr="1"/>
			</GROUP>
			<GROUP name="PCONCA" descr="Reportes para analisis por categorias" label="Por Convenio / Categoria" copyattr="1">
				<ITEM name="201" label="201 - Desvios por Convenios/Categorias" action="NucleusRH.Base.AnalisisRemun.Reportes.DesviosConvenio.flow:initialize" copyattr="1"/>
				<ITEM name="202" label="202 - Desvios por Convenios Mercado" action="NucleusRH.Base.AnalisisRemun.Reportes.DesviosConvenioMercado.flow:initialize" copyattr="1"/>
				<ITEM name="203" label="203 - Costo Laboral" action="NucleusRH.Base.AnalisisRemun.Reportes.CostoLaboral.flow:initialize" copyattr="1"/>
			</GROUP>
			<GROUP name="PLEGA" descr="Reportes por legajos" label="Por Legajo" copyattr="1">
				<ITEM name="301" label="301 - Historico de Remuneraciones" action="NucleusRH.Base.AnalisisRemun.Reportes.HistoricoPeriodos.flow:initialize" copyattr="1"/>
			</GROUP>
		</SECTION>
		<SECTION name="CONFIG" label="Configuracion y ABMs de Analisis de Remuneraciones" type="CONFIG" image="CONFIG" enabled="1">
			<GROUP name="DTMERC" descr="Datos externos de Convenios y Categorias" label="Datos del Mercado" copyattr="1">
				<ITEM name="CONV" action="NucleusRH.Base.AnalisisRemun.Convenios.autoflow:initialize" label="Convenios - Categorias" copyattr="1"/>
			</GROUP>
		</SECTION>
	</MODULE>
</APP-MENU>
