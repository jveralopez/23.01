<CUBO name="CODIFICADORAS.cube" label="Codificadoras">
	<DIM SQL_ORDER="LABEL" NULL="0" GRP="1" GROUP="Tiempos Trabajados" DES="Perfiles" SQL_FROM="PRY06_PERFILES as RP" SQL_LABEL="RP.d_perfil" SQL_CODE="RP.c_perfil" SQL_ID="RP.oi_perfil" COD="RP" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_ORDER="LABEL" NULL="0" GRP="1" SQL_FROM="PRY05_RECURSOS as RN, PER01_PERSONAL as RN_1" SQL_WHERE="RN.oi_personal=RN_1.oi_personal" SQL_LABEL="RN_1.d_ape_y_nom" SQL_CODE="RN.c_recurso" SQL_ID="RN.oi_recurso" GROUP="Tiempos Trabajados" DES="Recursos" COD="RN" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_ORDER="ID" REF="IMG" NULL="0" GRP="1" GROUP="Organizaci&#243;n" DES="A&#241;os" IMG_DEFAULT="date.gif" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='ANO') as ANO" SQL_LABEL="ANO.c_auxiliar" SQL_ID="ANO.oi_auxiliar" COD="ANO" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM REF="IMG" NULL="0" GRP="1" GROUP="Organizaci&#243;n" DES="Meses" SQL_ORDER="ID" IMG_DEFAULT="date.gif" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='MES') as MES" SQL_LABEL="MES.d_auxiliar" SQL_ID="MES.oi_auxiliar" COD="MES" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM REF="IMG" NULL="0" GRP="0" GROUP="Organizaci&#243;n" DES="Periodos" SQL_ORDER="ID" IMG_DEFAULT="date.gif" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='PER') as PERI" SQL_LABEL="PERI.d_auxiliar" SQL_ID="PERI.oi_auxiliar" COD="PERI" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="ANO.oi_auxiliar" DIM_TO="ANO" COL_FROM="PERI.oi_auxi_join_1"/>
		<JOIN COL_TO="MES.oi_auxiliar" DIM_TO="MES" COL_FROM="PERI.oi_auxi_join_2"/>
	</DIM>
	<DIM SQL_ORDER="LABEL" REF="IMG" NULL="0" GRP="1" SQL_PARENT="PRO.oi_proyecto_parent" GROUP="Organizaci&#243;n" DES="Proyectos" SQL_CODE="PRO.c_proyecto" SQL_FROM="PRY01_PROYECTOS as PRO" IMG_DEFAULT="organigrama.gif" SQL_LABEL="PRO.d_proyecto" SQL_ID="PRO.oi_proyecto" COD="PRO" SUM="0" FIL="0" AGR="1" TRE="1" SQL=""/>
	<DIM SQL_ORDER="LABEL" NULL="0" GRP="1" SQL_FROM="PRY02_TAREAS as TP" DES="Tareas por Proyetos" GROUP="Tiempos Trabajados" SQL_LABEL="TP.d_tarea" SQL_CODE="TP.c_tarea" SQL_ID="TP.oi_tarea" COD="TP" SUM="0" FIL="0" AGR="1" TRE="0" SQL="">
		<JOIN EXPLORE="1" show="1" COL_TO="PRO.oi_proyecto" DIM_TO="PRO" COL_FROM="TP.oi_proyecto"/>
	</DIM>
	<DIM NULL="0" GRP="1" SQL_FROM="PRY02_TAREAS as TV" SQL_ORDER="LABEL" DES="Tareas Imputada" GROUP="Tiempos Trabajados" SQL_LABEL="TV.d_tarea" SQL_CODE="TV.c_tarea" SQL_ID="TV.oi_tarea" COD="TV" SUM="0" FIL="0" AGR="1" TRE="0" SQL="">
		<JOIN EXPLORE="1" show="1" COL_FROM="TV.oi_pry_imputa" COL_TO="PRO.oi_proyecto" DIM_TO="PRO"/>
	</DIM>
</CUBO>
