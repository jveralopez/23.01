<CUBO DEBUG="1" base="NucleusProject.Base.Project.DIMS.cube" name="HORAS.cube" label="Horas">
	<DIM SQL_ORDER="ID" NULL="0" GRP="0" SQL_VALUE="(TRA.e_duracion*TRA_1.e_minutos)/60.0" DES="Horas por Proyecto" SQL_WHERE="TRA.oi_unidad_tiempo = TRA_1.oi_unidad_tiempo" SQL_FROM="PRY04_TRABAJOS as TRA, PRY03_UND_TIEMPO as TRA_1" GROUP="Tiempos Trabajados" SQL_ID="TRA.oi_trabajo" COD="TRA" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN EXPLORE="1" show="1" COL_TO="TP.oi_tarea" DIM_TO="TP" COL_FROM="TRA.oi_tarea"/>
		<JOIN EXPLORE="1" show="1" COL_TO="RN.oi_recurso" DIM_TO="RN" COL_FROM="TRA.oi_recurso"/>
		<JOIN EXPLORE="1" show="1" COL_TO="RP.oi_perfil" DIM_TO="RP" COL_FROM="TRA.oi_perfil"/>
		<JOIN EXPLORE="0" show="0" COL_FROM="GETYEAR(TRA.f_fecha)*100+GETMONTH(TRA.f_fecha)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<COL TYPE="DATE" LABEL="Fecha" NAME="TRA.f_fecha"/>
		<COL NAME="TRA.e_revision" LABEL="Revision" TYPE="INT"/>
		<COL TYPE="TEXT" LABEL="Mensaje" NAME="TRA.o_mensaje"/>
		<COL TYPE="TEXT" LABEL="Archivos" NAME="TRA.o_archivos"/>
	</DIM>
	<DIM SQL_ORDER="ID" NULL="0" GRP="0" SQL_VALUE="(TRV.e_duracion*TRV_1.e_minutos)/60.0" DES="Horas Imputadas" SQL_WHERE="TRV.oi_unidad_tiempo = TRV_1.oi_unidad_tiempo" SQL_FROM="PRY04_TRABAJOS as TRV, PRY03_UND_TIEMPO as TRV_1" GROUP="Tiempos Trabajados" SQL_ID="TRV.oi_trabajo" COD="TRV" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN EXPLORE="1" IGNORE="0" show="1" COL_TO="TV.oi_tarea" DIM_TO="TV" COL_FROM="TRV.oi_tarea"/>
		<JOIN EXPLORE="1" show="1" COL_TO="RN.oi_recurso" DIM_TO="RN" COL_FROM="TRV.oi_recurso"/>
		<JOIN EXPLORE="1" show="1" COL_TO="RP.oi_perfil" DIM_TO="RP" COL_FROM="TRV.oi_perfil"/>
		<JOIN EXPLORE="0" show="0" COL_FROM="GETYEAR(TRV.f_fecha)*100+GETMONTH(TRV.f_fecha)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<COL TYPE="DATE" LABEL="Fecha" NAME="TRV.f_fecha"/>
		<COL NAME="TRV.e_revision" LABEL="Revision" TYPE="INT"/>
		<COL TYPE="TEXT" LABEL="Mesaje" NAME="TRV.o_mensaje"/>
		<COL LABEL="Archivos" NAME="TRV.o_archivos" TYPE="TEXT"/>
	</DIM>
	<DIM SQL_ORDER="ID" NULL="0" GRP="0" SQL_VALUE="(TPE.e_estimado*TPE_1.e_minutos)/60.0" SQL_WHERE="TPE.oi_unidad_tiempo=TPE_1.oi_unidad_tiempo" SQL_FROM="PRY02_TAREAS as TPE, PRY03_UND_TIEMPO as TPE_1" SQL_ID="TPE.oi_tarea" COD="TPE" DES="Estimadas por Proyetos" GROUP="Tiempos Trabajados" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN show="1" COL_TO="TP.oi_tarea" DIM_TO="TP" COL_FROM="TPE.oi_tarea"/>
	</DIM>
	<DIM NULL="0" GRP="0" SQL_VALUE="(TVE.e_estimado*TVE_1.e_minutos)/60.0" SQL_WHERE="TVE.oi_unidad_tiempo=TVE_1.oi_unidad_tiempo" SQL_FROM="PRY02_TAREAS as TVE, PRY03_UND_TIEMPO as TVE_1" SQL_ID="TVE.oi_tarea" COD="TVE" DES="Estimadas por Imputacion" SQL_ORDER="ID" GROUP="Tiempos Trabajados" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN show="1" COL_FROM="TVE.oi_tarea" COL_TO="TV.oi_tarea" DIM_TO="TV"/>
	</DIM>
	<DIM SQL_ORDER="ID" GROUP="Tiempos Trabajados" NULL="0" GRP="0" SQL_FORMULA="DIF:TVE,TRV" DES="Exedentes Imputadas" COD="EXV" SUM="1" FIL="0" AGR="0" TRE="0" SQL=""/>
</CUBO>
