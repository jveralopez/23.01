	<DIM SQL_WHERE="EVACOM.oi_evaluacion = EVACOM_1.oi_evaluacion" SQL_FROM="EVA02_COM_EVALU AS EVACOM, EVA02_EVALUACION AS EVACOM_1" SQL_VALUE="EVACOM.n_resultado" DES="Resultado Competencias" GROUP="Tiempos Trabajados" IMG_DEFAULT="table.gif" SQL_ID="EVACOM.oi_com_evalu" COD="EVACOM" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="EVACOM_1.oi_evento" COL_TO="EVE.oi_evento" DIM_TO="EVE"/>
		<JOIN COL_FROM="EVACOM_1.oi_personal_emp" COL_TO="LEG.oi_personal_emp" DIM_TO="LEG"/>
		<JOIN COL_TO="COM.oi_competencia" DIM_TO="COM" COL_FROM="EVACOM.oi_competencia"/>
	</DIM>
