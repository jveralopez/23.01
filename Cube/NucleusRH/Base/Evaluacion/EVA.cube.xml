<CUBO label="Evaluaci&#243;n del Desempe&#241;o" base="NucleusRH.Base.Organizacion.TIEMPOS.cube;NucleusRH.Base.Organizacion.DIMS.cube;NucleusRH.Base.Personal.DIMS.cube;NucleusRH.Base.Tiempos_Trabajados.DIMS.cube" name="CODIFICADORAS.cube">
	<DIM SQL_ORDER="ID" DES="Eventos Evaluativos" SQL_FROM="EVA01_EVENTOS as EVE" SQL_LABEL="EVE.d_evento" SQL_CODE="EVE.c_evento" SQL_ID="EVE.oi_evento" COD="EVE" GROUP="Evaluaci&#243;n" IMG_DEFAULT="list.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="ORG21_COMPETENCIAS as COM" SQL_LABEL="COM.d_competencia" SQL_CODE="COM.c_competencia" SQL_ID="COM.oi_competencia" DES="Competencias" COD="COM" GROUP="Evaluaci&#243;n" IMG_DEFAULT="list.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_LABEL="APT.d_aptitud" SQL_CODE="APT.c_aptitud" SQL_FROM="ORG28_APTITUDES as APT" GROUP="Tiempos Trabajados" IMG_DEFAULT="list.gif" DES="Aptitudes" REF="IMG" SQL_ID="APT.oi_aptitud" COD="APT" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN TBL_FROM="ORG21_APTIT_COMP.oi_aptitud" TBL_TO="ORG21_APTIT_COMP.oi_competencia" TBL="ORG21_APTIT_COMP" COL_TO="COM.oi_competencia" COL_FROM="APT.oi_aptitud" DIM_TO="COM"/>
	</DIM>
	<DIM SQL_VALUE="LEGEVA.n_resultado" SQL_ID="LEGEVA.oi_evaluacion" DES="Legajos Evaluados" SQL_FROM="EVA02_EVALUACION AS LEGEVA" GROUP="Tiempos Trabajados" IMG_DEFAULT="table.gif" COD="LEGEVA" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
