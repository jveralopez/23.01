<CUBO label="Codificadoras" name="CONCEPTOS.cube">
	<DIM SQL_ORDER="ID" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='EDADRANGO') as RNGEDAD" SQL_LABEL="RNGEDAD.d_auxiliar" SQL_ID="RNGEDAD.e_auxiliar" DES="Rango de Edades" COD="RNGEDAD" GROUP="Organizaci&#243;n" IMG_DEFAULT="date.gif" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM DES="Rango de Edades para Jubilacion" SQL_ORDER="ID" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='EDADJUBI') as RNGJUBI" SQL_LABEL="RNGJUBI.d_auxiliar" SQL_ID="RNGJUBI.e_auxiliar" COD="RNGJUBI" GROUP="Organizaci&#243;n" IMG_DEFAULT="date.gif" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_ORDER="ID" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='EDAD') as EDAD" SQL_LABEL="EDAD.d_auxiliar" SQL_ID="EDAD.e_auxiliar" DES="Edades" COD="EDAD" GROUP="Organizaci&#243;n" IMG_DEFAULT="date.gif" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="RNGEDAD.e_auxiliar" DIM_TO="RNGEDAD" COL_FROM="EDAD.oi_auxi_join_1"/>
		<JOIN COL_TO="RNGJUBI.e_auxiliar" DIM_TO="RNGJUBI" COL_FROM="EDAD.oi_auxi_join_2"/>
	</DIM>
	<DIM IMG_DEFAULT="user.gif" SQL_ID="SEXO.oi_auxiliar" SQL_FROM="ORG50_AUXILIARES(ORG50_AUXILIARES.c_tipo='SEXO') as SEXO" SQL_LABEL="SEXO.d_auxiliar" DES="Sexo" COD="SEXO" GROUP="Organizaci&#243;n" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM GROUP="Personal" SQL_CODE="LEG.e_numero_legajo" SQL_FROM="PER02_PERSONAL_EMP as LEG, PER01_PERSONAL as LEG_1" SQL_LABEL="LEG_1.d_ape_y_nom" REF="IMG" IMG_DEFAULT="user.gif" SQL_WHERE="LEG.oi_personal=LEG_1.oi_personal" SQL_ID="LEG.oi_personal_emp" DES="Legajos" COD="LEG" SUM="0" FIL="0" AGR="1" TRE="0" IMG="">
		<JOIN COL_TO="EST.oi_estructura" TBL_TO="ORG02_ESTRUC_PERS.oi_estructura" TBL_FROM="ORG02_ESTRUC_PERS.oi_personal_emp" TBL="ORG02_ESTRUC_PERS" DIM_TO="EST" COL_FROM="LEG.oi_personal_emp"/>
		<JOIN COL_TO="EMP.oi_empresa" COL_FROM="LEG.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_TO="OBR_SOC.oi_obra_social" COL_FROM="LEG.oi_obra_social" DIM_TO="OBR_SOC"/>
		<JOIN TBL_FROM="ORG18_CATEGORIAS.oi_categoria" TBL_TO="ORG18_CATEGORIAS.oi_convenio" TBL="ORG18_CATEGORIAS" COL_FROM="LEG.oi_categoria_ult" COL_TO="CON.oi_convenio" DIM_TO="CON"/>
		<JOIN COL_TO="CC.oi_centro_costo" COL_FROM="LEG.oi_ctro_costo_ult" DIM_TO="CC"/>
		<JOIN COL_TO="TIPO_PER.oi_tipo_personal" DIM_TO="TIPO_PER" COL_FROM="LEG.oi_tipo_personal"/>
		<JOIN COL_TO="IND_ACT.oi_indic_activo" DIM_TO="IND_ACT" COL_FROM="LEG.oi_indic_activo"/>
		<JOIN COL_TO="SIND.oi_sindicato" DIM_TO="SIND" COL_FROM="LEG.oi_sindicato"/>
		<JOIN COL_FROM="FLOOR( (GETYEAR(Now())*12+GETMONTH(Now())-GETYEAR(LEG_1.f_nacim)*12+GETMONTH(LEG_1.f_nacim)) / 12 )" COL_TO="EDAD.e_auxiliar" DIM_TO="EDAD"/>
		<JOIN COL_TO="SEXO.c_auxiliar" DIM_TO="SEXO" COL_FROM="LEG_1.c_sexo"/>
		<JOIN COL_TO="ESTCIV.oi_estado_civil" DIM_TO="ESTCIV" COL_FROM="LEG_1.oi_estado_civil"/>
		<JOIN TBL_FROM="PER02_LICEN_PER.oi_personal_emp" DIM_TO="LIC" TBL_TO="PER02_LICEN_PER.oi_licencia" TBL="PER02_LICEN_PER" COL_FROM="LEG.oi_personal_emp" COL_TO="LIC.oi_licencia"/>
	</DIM>
	<DIM GROUP="Personal" IMG_DEFAULT="creditcards.gif" SQL_CODE="FPAG.c_forma_pago" REF="IMG" SQL_FROM="PER31_FORMAS_PAGO as FPAG" DES="Forma de Pago" SQL_LABEL="FPAG.d_forma_pago" SQL_ID="FPAG.oi_forma_pago" COD="FORMA_PAGO" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="PER11_TIPOS_PERS as TIPO_PER" SQL_LABEL="TIPO_PER.d_tipo_personal" SQL_CODE="TIPO_PER.c_tipo_personal" SQL_ID="TIPO_PER.oi_tipo_personal" DES="Tipo de Personal" GROUP="Personal" IMG_DEFAULT="creditcards.gif" REF="IMG" COD="TIPO_PER" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="PER21_INDIC_ACTIVO as IND_ACT" DES="Indicador de Activo" SQL_LABEL="IND_ACT.d_indic_activo" SQL_CODE="IND_ACT.c_indic_activo" SQL_ID="IND_ACT.oi_indic_activo" GROUP="Personal" IMG_DEFAULT="creditcards.gif" REF="IMG" COD="IND_ACT" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="PER30_SINDICATOS as SIND" SQL_LABEL="SIND.d_sindicato" SQL_CODE="SIND.c_sindicato" SQL_ID="SIND.oi_sindicato" DES="Sindicato" GROUP="Personal" IMG_DEFAULT="creditcards.gif" REF="IMG" COD="SIND" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="PER06_OBRAS_SOC as OBR_SOC" DES="Obra Social" SQL_LABEL="OBR_SOC.d_obra_social" SQL_CODE="OBR_SOC.c_obra_social" SQL_ID="OBR_SOC.oi_obra_social" COD="OBR_SOC" GROUP="Personal" IMG_DEFAULT="creditcards.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_FROM="PER16_LICENCIAS as LIC" DES="Licencias" SQL_LABEL="LIC.d_licencia" SQL_CODE="LIC.c_licencia" SQL_ID="LIC.oi_licencia" COD="LIC" GROUP="Personal" IMG_DEFAULT="user.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_LABEL="ESTCIV.d_estado_civil" SQL_CODE="ESTCIV.c_estado_civil" SQL_ID="ESTCIV.oi_estado_civil" COD="ESTCIV" DES="Estado Civil" SQL_FROM="ORG22_EST_CIVIL as ESTCIV" GROUP="Personal" IMG_DEFAULT="user.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0"/>
</CUBO>
