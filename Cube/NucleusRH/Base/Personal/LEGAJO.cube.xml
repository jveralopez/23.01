<CUBO label="Administraci&#243;n del Personal" base="NucleusRH.Base.Organizacion.TIEMPOS.cube;NucleusRH.Base.Organizacion.DIMS.cube;NucleusRH.Base.Personal.DIMS.cube" name="LEGAJO.cube">
	<DIM GROUP="Personal" DES="Legajos" SQL_CODE="LEG.e_numero_legajo" SQL_FROM="PER02_PERSONAL_EMP as LEG, PER01_PERSONAL as LEG_1" SQL_LABEL="LEG_1.d_ape_y_nom" REF="IMG" IMG_DEFAULT="user.gif" SQL_WHERE="LEG.oi_personal=LEG_1.oi_personal" SQL_ID="LEG.oi_personal_emp" COD="LEG" SUM="1" FIL="0" AGR="1" TRE="0" IMG=""/>
	<DIM SQL_VALUE="FLOOR( (GETYEAR(Now())*12+GETMONTH(Now())-GETYEAR(LEG_EDAD_1.f_nacim)*12+GETMONTH(LEG_EDAD_1.f_nacim)) / 12 )" SQL_WHERE="LEG_EDAD.oi_personal=LEG_EDAD_1.oi_personal" SQL_FROM="PER02_PERSONAL_EMP as LEG_EDAD, PER01_PERSONAL as LEG_EDAD_1" SQL_LABEL="LEG_EDAD_1.d_ape_y_nom" SQL_CODE="LEG_EDAD.e_numero_legajo" SQL_ID="LEG_EDAD.oi_personal_emp" DES="Edad Legajos" COD="LEG_EDAD" GROUP="Personal" REF="IMG" IMG_DEFAULT="user.gif" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="LEG_EDAD.oi_personal_emp" COL_TO="EST.oi_estructura" TBL_TO="ORG02_ESTRUC_PERS.oi_estructura" TBL_FROM="ORG02_ESTRUC_PERS.oi_personal_emp" TBL="ORG02_ESTRUC_PERS" DIM_TO="EST"/>
		<JOIN COL_FROM="LEG_EDAD.oi_empresa" COL_TO="EMP.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_FROM="LEG_EDAD_1.c_sexo" COL_TO="SEXO.c_auxiliar" DIM_TO="SEXO"/>
	</DIM>
	<DIM SQL_WHERE="LEG_ANTIG.oi_personal=LEG_ANTIG_1.oi_personal" SQL_FROM="PER02_PERSONAL_EMP as LEG_ANTIG, PER01_PERSONAL as LEG_ANTIG_1" SQL_VALUE="FLOOR( (GETYEAR(Now())*12+GETMONTH(Now())-GETYEAR(LEG_ANTIG.f_ingreso)*12+GETMONTH(LEG_ANTIG.f_ingreso)) / 12 )" SQL_LABEL="LEG_ANTIG_1.d_ape_y_nom" SQL_CODE="LEG_ANTIG.e_numero_legajo" SQL_ID="LEG_ANTIG.oi_personal_emp" DES="Legajo Antiguedad" COD="LEG_ANTIG" GROUP="Personal" REF="IMG" IMG_DEFAULT="user.gif" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="LEG_ANTIG.oi_personal_emp" COL_TO="EST.oi_estructura" TBL_TO="ORG02_ESTRUC_PERS.oi_estructura" TBL_FROM="ORG02_ESTRUC_PERS.oi_personal_emp" TBL="ORG02_ESTRUC_PERS" DIM_TO="EST"/>
		<JOIN COL_FROM="LEG_ANTIG.oi_empresa" COL_TO="EMP.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_FROM="LEG_ANTIG_1.c_sexo" COL_TO="SEXO.c_auxiliar" DIM_TO="SEXO"/>
	</DIM>
	<DIM SQL_WHERE="LEG_EGRESO.oi_personal=LEG_EGRESO_1.oi_personal" SQL_FROM="PER02_PERSONAL_EMP as LEG_EGRESO, PER01_PERSONAL as LEG_EGRESO_1" SQL_LABEL="LEG_EGRESO_1.d_ape_y_nom" SQL_CODE="LEG_EGRESO.e_numero_legajo" SQL_ID="LEG_EGRESO.oi_personal_emp" COD="LEG_EGRESO" DES="Legajo Egresos" GROUP="Personal" REF="IMG" IMG_DEFAULT="user.gif" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="LEG_EGRESO.oi_personal_emp" COL_TO="EST.oi_estructura" TBL_TO="ORG02_ESTRUC_PERS.oi_estructura" TBL_FROM="ORG02_ESTRUC_PERS.oi_personal_emp" TBL="ORG02_ESTRUC_PERS" DIM_TO="EST"/>
		<JOIN COL_FROM="LEG_EGRESO.oi_empresa" COL_TO="EMP.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_FROM="LEG_EGRESO_1.c_sexo" COL_TO="SEXO.c_auxiliar" DIM_TO="SEXO"/>
		<JOIN COL_FROM="GETYEAR(LEG_EGRESO.f_egreso)*100+GETMONTH(LEG_EGRESO.f_egreso)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_FROM="LEG_EGRESO.oi_tipo_personal" COL_TO="TIPO_PER.oi_tipo_personal" DIM_TO="TIPO_PER"/>
	</DIM>
	<DIM SQL_WHERE="LEG_INGRESO.oi_personal=LEG_INGRESO_1.oi_personal" SQL_FROM="PER02_PERSONAL_EMP as LEG_INGRESO, PER01_PERSONAL as LEG_INGRESO_1" SQL_LABEL="LEG_INGRESO_1.d_ape_y_nom" SQL_CODE="LEG_INGRESO.e_numero_legajo" SQL_ID="LEG_INGRESO.oi_personal_emp" COD="LEG_INGRESO" DES="Legajo Ingreso" GROUP="Personal" REF="IMG" IMG_DEFAULT="user.gif" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="LEG_INGRESO.oi_personal_emp" COL_TO="EST.oi_estructura" TBL_TO="ORG02_ESTRUC_PERS.oi_estructura" TBL_FROM="ORG02_ESTRUC_PERS.oi_personal_emp" TBL="ORG02_ESTRUC_PERS" DIM_TO="EST"/>
		<JOIN COL_FROM="LEG_INGRESO.oi_empresa" COL_TO="EMP.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_FROM="LEG_INGRESO_1.c_sexo" COL_TO="SEXO.c_auxiliar" DIM_TO="SEXO"/>
		<JOIN COL_FROM="GETYEAR(LEG_INGRESO.f_ingreso)*100+GETMONTH(LEG_INGRESO.f_ingreso)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_FROM="LEG_INGRESO.oi_tipo_personal" COL_TO="TIPO_PER.oi_tipo_personal" DIM_TO="TIPO_PER"/>
	</DIM>
	<DIM SQL_VALUE="DIASLIC.e_cant_dias" DES="D&#237;as de Licencias" SQL_FROM="PER02_LICEN_PER as DIASLIC" SQL_ID="DIASLIC.oi_licencia_per" COD="DIASLIC" GROUP="Personal" REF="IMG" IMG_DEFAULT="user.gif" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_TO="LIC.oi_licencia" DIM_TO="LIC" COL_FROM="DIASLIC.oi_licencia"/>
		<JOIN COL_FROM="GETYEAR(DIASLIC.f_inicio)*100+GETMONTH(DIASLIC.f_inicio)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_FROM="DIASLIC.oi_personal_emp" COL_TO="LEG.oi_personal_emp" DIM_TO="LEG"/>
	</DIM>
</CUBO>
