<CUBO label="Capacitaci&#243;n y Desarrollo" base="NucleusRH.Base.Organizacion.TIEMPOS.cube;NucleusRH.Base.Organizacion.DIMS.cube;NucleusRH.Base.Personal.DIMS.cube" name="CODIFICADORAS.cube">
	<DIM SQL_ID="ACUR.oi_curso" SQL_CODE="ACUR.c_curso" SQL_LABEL="ACUR.d_curso" SQL_FROM="ORG06_CURSOS as ACUR" DES="&#193;reas de Curso" COD="ACUR" GROUP="Capacitaci&#243;n" IMG_DEFAULT="table.gif" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM GROUP="Capacitaci&#243;n" IMG_DEFAULT="table.gif" DES="Cursos" SQL_FROM="CYD01_CURSOS as CUR" SQL_LABEL="CUR.d_curso" SQL_CODE="CUR.c_curso" SQL_ID="CUR.oi_curso" COD="CUR" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="ACUR.oi_curso" DIM_TO="ACUR" COL_FROM="CUR.oi_area"/>
	</DIM>
	<DIM SQL_LABEL="DIC.d_dictado" SQL_CODE="DIC.c_dictado" SQL_ID="DIC.oi_dictado" GROUP="Tiempos Trabajados" IMG_DEFAULT="table.gif" DES="Dictados" REF="IMG" SQL_FROM="CYD02_DICTADOS AS DIC" COD="DIC" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="CUR.oi_curso" DIM_TO="CUR" COL_FROM="DIC.oi_curso"/>
	</DIM>
	<DIM SQL_WHERE="LEGCUR.c_estado = 'CUR'" SQL_FROM="CYD02_INSCRIPTOS AS LEGCUR" GROUP="Tiempos Trabajados" IMG_DEFAULT="table.gif" SQL_ID="LEGCUR.oi_inscripto" DES="Legajos Cursados" COD="LEGCUR" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_TO="DIC.oi_dictado" DIM_TO="DIC" COL_FROM="LEGCUR.oi_dictado"/>
		<JOIN COL_TO="LEG.oi_personal_emp" DIM_TO="LEG" COL_FROM="LEGCUR.oi_personal_emp"/>
	</DIM>
	<DIM SQL_WHERE="HOR.oi_dictado = HOR_1.oi_dictado&#13;&#10;AND HOR.c_estado = 'CUR'" SQL_VALUE="HOR_1.e_duracion_hs" DES="Horas de Capacitaci&#243;n" GROUP="Tiempos Trabajados" IMG_DEFAULT="table.gif" SQL_FROM="CYD02_INSCRIPTOS as HOR, CYD02_DICTADOS as HOR_1" SQL_ID="HOR.oi_inscripto" REF="IMG" COD="HOR" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_TO="DIC.oi_dictado" DIM_TO="DIC" COL_FROM="HOR.oi_dictado"/>
		<JOIN COL_FROM="GETYEAR(HOR_1.f_inicio)*100+GETMONTH(HOR_1.f_inicio)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_TO="LEGCUR.oi_inscripto" DIM_TO="LEGCUR" COL_FROM="HOR.oi_inscripto"/>
	</DIM>
</CUBO>
