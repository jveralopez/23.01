<CUBO label="Tiempos Trabajados" base="NucleusRH.Base.Organizacion.TIEMPOS.cube;NucleusRH.Base.Organizacion.DIMS.cube;NucleusRH.Base.Personal.DIMS.cube;NucleusRH.Base.Tiempos_Trabajados.DIMS.cube" name="HORAS.cube">
	<DIM SQL_VALUE="VCON_TTA.n_valor" COD="VCON_TTA" SQL_ID="VCON_TTA.oi_conc_val" DES="Conceptos Calculados" GROUP="Tiempos Trabajados" IMG_DEFAULT="clock.gif" SQL_FROM="TTA10_CONC_PER as VCON_TTA" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_TO="CONC_TTA.oi_concepto" DIM_TO="CONC_TTA" COL_FROM="VCON_TTA.oi_concepto"/>
		<JOIN COL_FROM="VCON_TTA.oi_liquidacionpers" COL_TO="LEGPRO.oi_liquidacionpers" DIM_TO="LEGPRO"/>
	</DIM>
	<DIM GROUP="Tiempos Trabajados" IMG_DEFAULT="clock.gif" SQL_WHERE="HOR.oi_liquidacjor = HOR_1.oi_liquidacjor" SQL_FROM="TTA10_LIQUIDACPROC as HOR, TTA10_LIQUIDACJOR as HOR_1" SQL_ID="HOR.oi_liquidacionproc" SQL_VALUE="HOR.n_cantidadhs" REF="IMG" DES="Horas" COD="HOR" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_TO="TH.oi_tipohora" DIM_TO="THORAS" COL_FROM="HOR.oi_tipohora"/>
		<JOIN COL_FROM="GETYEAR(HOR_1.f_fecjornada)*100+GETMONTH(HOR_1.f_fecjornada)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_TO="LEGPRO.oi_liquidacionpers" DIM_TO="LEGPRO" COL_FROM="HOR_1.oi_liquidacionpers"/>
	</DIM>
	<DIM SQL_VALUE="AUS.oi_liquidacjor" DES="Ausencias" SQL_WHERE="AUS.l_esperado = 1&#13;&#10;AND AUS.l_presente = 0" SQL_FROM="TTA10_LIQUIDACJOR as AUS" COD="AUS" GROUP="Tiempos Trabajados" IMG_DEFAULT="clock.gif" SQL_ID="AUS.oi_liquidacjor" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" IMG="">
		<JOIN COL_FROM="GETYEAR(AUS.f_fecjornada)*100+GETMONTH(AUS.f_fecjornada)" COL_TO="PERI.oi_auxiliar" DIM_TO="PERI"/>
		<JOIN COL_TO="LEGPRO.oi_liquidacionpers" DIM_TO="LEGPRO" COL_FROM="AUS.oi_liquidacionpers"/>
	</DIM>
</CUBO>
