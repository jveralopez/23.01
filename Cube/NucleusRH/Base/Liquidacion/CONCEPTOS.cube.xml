<CUBO label="Liquidaci&#243;n de Haberes" base="NucleusRH.Base.Personal.LEGAJO.cube" name="CONCEPTOS.cube">
	<DIM SQL_ORDER="CODE" GROUP="Liquidacion" SQL_CODE="CONC.c_concepto" REF="IMG" IMG_DEFAULT="sum_gear.gif" SQL_LABEL="CONC.d_concepto" SQL_ID="CONC.oi_concepto" SQL_FROM="LIQ14_CONCEPTOS as CONC" DES="Conceptos" COD="CONC" SUM="0" FIL="1" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="TCONC.oi_tipo_concepto" DIM_TO="TIPOS_CONC" COL_FROM="CONC.oi_tipo_concepto"/>
		<JOIN COL_TO="CCONC.oi_clase_concepto" COL_FROM="CONC.oi_clase_concepto" DIM_TO="CLASES_CONC"/>
	</DIM>
	<DIM GROUP="Liquidacion" SQL_CODE="CONV_1.c_concepto" SQL_VALUE="CONV.n_valor" SQL_FROM="LIQ20_CONC_LIQ_PER as CONV, LIQ96_CONCEPTOS as CONV_1, LIQ14_CONCEPTOS as CONV_2" REF="IMG" COD="CONCEPTO_VALOR" SQL_WHERE="CONV.oi_concepto_ddo=CONV_1.oi_concepto_ddo and CONV_1.c_concepto=CONV_2.c_concepto" IMG_DEFAULT="sum.gif" DES="Concepto Valor" SQL_LABEL="CONV_1.d_concepto" SQL_ID="CONV.oi_conc_liq_per" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="CONC.oi_concepto" DIM_TO="CONC" COL_FROM="CONV_2.oi_concepto"/>
		<JOIN COL_TO="TCONC.oi_tipo_concepto" DIM_TO="TIPOS_CONC" COL_FROM="CONV_2.oi_tipo_concepto"/>
		<JOIN COL_TO="CCONC.oi_clase_concepto" COL_FROM="CONV_2.oi_clase_concepto" DIM_TO="CLASES_CONC"/>
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="CONV.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
	<DIM SQL_ORDER="CODE" SQL_WHERE="TCONC.l_nolistado = 0" GROUP="Liquidacion" SQL_CODE="TCONC.c_tipo_concepto" REF="IMG" IMG_DEFAULT="sum_gear.gif" SQL_LABEL="TCONC.d_tipo_concepto" SQL_ID="TCONC.oi_tipo_concepto" SQL_FROM="LIQ12_TIPOS_CONC as TCONC" DES="Tipos de Concepto" COD="TIPOS_CONC" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM GROUP="Liquidacion" SQL_CODE="CCONC.c_clase_concepto" REF="IMG" IMG_DEFAULT="sum_star.gif" DES="Clases de Conceptos" SQL_LABEL="CCONC.d_clase_concepto" SQL_ID="CCONC.oi_clase_concepto" SQL_FROM="LIQ13_CLASES_CONC as CCONC" COD="CLASES_CONC" SUM="0" FIL="1" AGR="1" TRE="0" SQL=""/>
	<DIM SQL_WHERE="REC_1.oi_liquidacion_ddo=REC_3.oi_liquidacion_ddo and &#13;&#10;REC.oi_per_emp_ddo=REC_2.oi_per_emp_ddo and    &#13;&#10;REC.oi_tot_liq_per=REC_3.oi_tot_liq_per and   &#13;&#10;REC_1.c_estado='F'" SQL_FROM="LIQ20_TOT_LIQ_PER as REC, &#13;&#10;LIQ99_LIQUIDACION as REC_1, &#13;&#10;LIQ97_PERSONAL_EMP as REC_2, &#13;&#10;LIQ99_RECIBOS as REC_3" GROUP="Liquidacion" SQL_LABEL="(REC_1.d_titulo || '/' || REC_2.d_ape_y_nom)" SQL_CODE="(REC_1.c_liquidacion || '/' || REC_2.e_numero_legajo)" REF="IMG" COD="RECIBOS" IMG_DEFAULT="cheque.gif" DES="Recibos" SQL_VALUE="REC.n_totpag" SQL_ID="REC.oi_tot_liq_per" SUM="1" FIL="0" AGR="1" TRE="0" SQL="">
		<JOIN COL_TO="OBR_SOC.c_obra_social" COL_FROM="REC_2.c_obra_social" DIM_TO="OBR_SOC"/>
		<JOIN COL_FROM="REC_2.c_tipo_personal" COL_TO="TIPO_PER.c_tipo_personal" DIM_TO="TIPO_PER"/>
		<JOIN COL_FROM="REC_2.c_sindicato" COL_TO="SIND.c_sindicato" DIM_TO="SIND"/>
		<JOIN COL_FROM="REC_2.c_centro_costo_ult" COL_TO="CC.c_centro_costo" DIM_TO="CC"/>
		<JOIN COL_TO="FPAG.c_forma_pago" DIM_TO="FORMA_PAGO" COL_FROM="REC.c_forma_pago"/>
		<JOIN COL_FROM="REC_1.c_empresa" COL_TO="EMP.c_empresa" DIM_TO="EMP"/>
		<JOIN COL_FROM="REC_2.e_numero_legajo" COL_TO="LEG.e_numero_legajo" DIM_TO="LEG"/>
		<JOIN COL_TO="LIQ_1.oi_liquidacion_ddo" DIM_TO="LIQ" COL_FROM="REC_3.oi_liquidacion_ddo"/>
	</DIM>
	<DIM SQL_WHERE="CONCLIQ.oi_concepto_ddo = CONCLIQ_1.oi_concepto_ddo &#13;&#10;AND CONCLIQ_1.c_concepto = CONCLIQ_2.c_concepto" SQL_FROM="LIQ20_CONC_LIQ_PER AS CONCLIQ,&#13;&#10;LIQ96_CONCEPTOS AS CONCLIQ_1,&#13;&#10;LIQ14_CONCEPTOS AS CONCLIQ_2" SQL_VALUE="CONCLIQ.n_valor" SQL_CODE="CONCLIQ_1.c_concepto" SQL_ID="CONCLIQ.oi_conc_liq_per" COD="CONCLIQ" DES="Conceptos Liquidados" GROUP="Liquidacion" SQL_LABEL="CONCLIQ_1.d_concepto" REF="IMG" IMG_DEFAULT="cheque.gif" SUM="1" FIL="0" AGR="1" TRE="0" SQL="">
		<JOIN COL_FROM="CONCLIQ_2.oi_concepto" COL_TO="CONC.oi_concepto" DIM_TO="CONC"/>
		<JOIN DIM_TO="RECIBOS" COL_TO="REC.oi_tot_liq_per" COL_FROM="CONCLIQ.oi_tot_liq_per"/>
	</DIM>
	<DIM DES="Liquidaci&#243;n" SQL_WHERE="LIQ.oi_liquidacion=LIQ_2.oi_liquidacion and &#13;&#10;LIQ_2.oi_liquidacion_ddo=LIQ_1.oi_liquidacion_ddo and&#13;&#10;LIQ_1.c_estado='F' &#13;&#10;" SQL_ORDER="ID" GROUP="Liquidacion" IMG_DEFAULT="calculator.gif" SQL_CODE="LIQ.c_liquidacion" SQL_FROM="LIQ19_LIQUIDACION as LIQ, LIQ99_LIQUIDACION as LIQ_1, LIQ19_EJECUCIONES as LIQ_2" SQL_LABEL="LIQ.d_titulo" SQL_ID="LIQ.oi_liquidacion" REF="IMG" SUM="0" FIL="1" AGR="1" TRE="0" COD="LIQ" IMG="">
		<JOIN COL_TO="EMP.oi_empresa" COL_FROM="LIQ.oi_empresa" DIM_TO="EMP"/>
		<JOIN COL_TO="PERI.oi_auxiliar" DIM_TO="PERI" COL_FROM="LIQ.e_periodo"/>
	</DIM>
	<DIM GROUP="Liquidacion" SQL_VALUE="COSTO_LAB.n_totsret + COSTO_LAB.n_totnsret + COSTO_LAB.n_totcont" SQL_FROM="LIQ20_TOT_LIQ_PER as COSTO_LAB" SQL_ID="COSTO_LAB.oi_tot_liq_per" COD="COSTO_LAB" IMG_DEFAULT="sum.gif" REF="IMG" DES="Costo Laboral" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="COSTO_LAB.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
	<DIM SQL_VALUE="NETPROM.n_totpag" SQL_ID="NETPROM.oi_tot_liq_per" COD="NETPROM" GROUP="Liquidacion" IMG_DEFAULT="sum.gif" SQL_FROM="LIQ20_TOT_LIQ_PER as NETPROM&#13;&#10;" REF="IMG" DES="Sueldos Promedios Netos" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="NETPROM.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
	<DIM SQL_VALUE="SUECONF.n_sconformado" SQL_ID="SUECONF.oi_tot_liq_per" COD="SUECONF" GROUP="Liquidacion" IMG_DEFAULT="sum.gif" SQL_FROM="LIQ20_TOT_LIQ_PER as SUECONF" REF="IMG" DES="Sueldos Conformados" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="NETPROM.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
	<DIM DES="Total Sujeto a Retenci&#243;n" SQL_VALUE="SRET.n_totsret" SQL_ID="SRET.oi_tot_liq_per" COD="SRET" GROUP="Liquidacion" IMG_DEFAULT="sum.gif" SQL_FROM="LIQ20_TOT_LIQ_PER as SRET" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="SRET.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
	<DIM DES="Total No Sujeto a Retenci&#243;n" SQL_VALUE="NSRET.n_totnsret" SQL_ID="NSRET.oi_tot_liq_per" COD="NSRET" GROUP="Liquidacion" IMG_DEFAULT="sum.gif" SQL_FROM="LIQ20_TOT_LIQ_PER as NSRET" REF="IMG" SUM="1" FIL="0" AGR="0" TRE="0" SQL="">
		<JOIN COL_TO="REC.oi_tot_liq_per" COL_FROM="NSRET.oi_tot_liq_per" DIM_TO="RECIBOS"/>
	</DIM>
</CUBO>
