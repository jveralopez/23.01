<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Reportes.CtaCteVacaciones.CtaCteVac.filter.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" doc="source">
	<form:Title>
		<form:Label label="Consulta de Cuenta Corriente" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Reportes/CtaCteVacaciones/CtaCteVac/filter/form/empresa">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Reportes/CtaCteVacaciones/CtaCteVac/filter/form/empresa/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Reportes/CtaCteVacaciones/CtaCteVac/filter/form/empresa"/>
						</form:Policies>
					</form:ComboBox>
					<form:FKInput enabled="0" visible="0" nvalue="#FILTERDATA:@oi_periodo" required="1" xsize="15" length="30" name="oi_periodo" label="Per&#237;odo">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Vacaciones.Periodos.PERIODO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
					<form:NumberBox label="Per&#237;odo desde" required="1" name="anio_desde" nvalue="#source:@anio_desde" min="1990" max="2099"/>
					<form:NumberBox label="Per&#237;odo hasta" required="1" name="anio_hasta" nvalue="#source:@anio_hasta" min="1990" max="2099"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left"/>
			</form:Columns>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="aceptar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function aceptar()
{               
	if (validarPeriodos()) {
		Guardar();	 		
	} else {
		return false;
	}
}

function validarPeriodos()
{	
	if (Ctrl("anio_desde").GetCValue() &gt; Ctrl("anio_hasta").GetCValue())
	{
		alert("El per&#237;odo desde debe ser menor o igual al per&#237;odo hasta.");
		return false;
	}
	return true;
}


function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
