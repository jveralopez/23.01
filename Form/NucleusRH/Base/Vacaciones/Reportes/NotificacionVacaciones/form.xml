<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Reportes.NotificacionVacaciones.form" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Notificaci&#243;n Vacaciones" nowrap="1" align="center" visible="SHOW" style="S3 LCol_w" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="bln1"/>
		<form:RowAligner name="rowaligner1"/>
		<form:Blank name="bln2"/>
		<form:Grid idvalue="#source:@oi_notif" nvalue="#source:PERSONAS" rows="10" allowdel="0" allownew="0" paging="1" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn>
					<form:CheckBox nvalue="#source:@chk_seleccion" name="chk_seleccion"/>
				</form:GColumn>
				<form:GColumn>
					<form:FKInput label="Empresa - Legajo" required="0" enabled="0" xsize="15" length="30" nvalue="#source:@oi_personal_emp" name="oi_personal_emp">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn>
					<form:Combo name="oi_estado_solic" nvalue="#source:@oi_estado_solic" flow="NucleusRH.Base.Vacaciones.Estados_Solicitud.ESTADO_SOLIC.combo.autoflow" action="COMBO" required="1" enabled="0" label="Estado"/>
				</form:GColumn>
				<form:GColumn>
					<form:TextBox required="1" nvalue="#source:@c_periodo" label="Periodo" enabled="0" name="c_periodo"/>
				</form:GColumn>
				<form:GColumn>
					<form:DateTime name="f_desde_solicitud" nvalue="#source:@f_desde_solicitud" enabled="0" label="Fecha Desde" pattern="YYYYMMDD" required="1" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton visible="0" descrip="Fecha Desde" img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn>
					<form:DateTime nvalue="#source:@f_hasta_solicitud" name="f_hasta_solicitud" enabled="0" label="Fecha Hasta" pattern="YYYYMMDD" required="1" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton visible="0" descrip="Fecha Desde" img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn>
					<form:CheckBox label="Notificada" name="l_notificada" nvalue="#source:@l_notificada" enabled="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Hidden nvalue="#source:@l_reimprime" name="l_reimprime"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operaci&#243;n" note="Acepta la operacion sobre el formulario">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
