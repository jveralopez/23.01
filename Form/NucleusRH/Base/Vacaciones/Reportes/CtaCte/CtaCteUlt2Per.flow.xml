<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="CtaCteUlt2Per">
	<flow:info label="Flow para NucleusRH.Base.Vacaciones.LegajoVacaciones"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA TIPO_PER="" oi_empresa="">
				<PERSONAS/>
			</DATA>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Vacaciones.Reportes.CtaCte.CtaCteUlt2Per.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Vacaciones.Reportes.CtaCte.CtaCteUlt2Per.filter.form:FILTER" form-class="NucleusRH.Base.Vacaciones.Reportes.CtaCte.CtaCteUlt2Per.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="FILTER">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="javier"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Vacaciones.CtaCteVacaciones2UltPer.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Consulta de Cuenta Corriente por legajo" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-CtaCteVacaciones"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-CtaCteVacaciones"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
