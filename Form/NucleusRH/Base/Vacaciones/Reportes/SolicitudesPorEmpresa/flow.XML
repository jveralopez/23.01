<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa.flow" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa.filter.form" name="NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method priority="6" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" method="ExecReportHTML">
				<flow:param value="NucleusRH.Base.Vacaciones.SolicitudesPorEmpresa.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Solicitudes por Empresa" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Vacaciones.Reportes.SolicitudesPorEmpresa" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
</flow:flow>
