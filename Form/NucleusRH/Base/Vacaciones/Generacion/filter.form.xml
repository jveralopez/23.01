<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" name="NucleusRH.Base.Vacaciones.Generacion.filter.form" doc="source">
	<form:Title>
		<form:Label name="lbl_titulo" label="Generaci&#243;n de Vacaciones" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup width="90%" nvalue="#source:@gcustom" border="1" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="col2">
				<form:Column valign="middle" name="2" separation="2" align="left">
					<form:FKInput nvalue="#FILTERDATA:@oi_periodo" required="1" enabled="" xsize="15" length="30" name="oi_periodo" label="Per&#237;odo">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Vacaciones.Periodos.PERIODO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
					<form:CheckBox nvalue="#FILTERDATA:@l_sobreescribe" name="l_sobreescribe" label="Sobreescribe Existentes"/>
					<form:CheckBox nvalue="#FILTERDATA:@l_notifica" visible="0" name="notifica" label="Emite Notificaci&#243;n"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button descrip="Ejecuta la generaci&#243;n de vacaciones para los legajos seleccionados." label="Ejecutar" img="ok" name="btnFILTER" note="Consultar los Legajos seleccionados" X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnFILTER">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnFILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnFILTER"/>
					</form:Policies>
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button visible="0" name="AGREGAR" label="Agregar" img="add" descrip="Agregar un Legajo" note="Volver al Menu princial" X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/AGREGAR">
					<form:Event action="ADD" runat="server" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/AGREGAR/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/AGREGAR"/>
					</form:Policies>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial" X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnBACK">
					<form:Event action="BACK" runat="server" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnBACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Vacaciones/Generacion/filter/form/btnBACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
</form:Form>
