<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" doc="source" name="NucleusRH.Base.Vacaciones.Consulta.form">
	<form:Scripts/>
	<form:Title>
		<form:Label style="S3 LCol_w" name="lbl1" label="Consulta Cuenta Corriente Vacaciones" descrip="Consulta Cuenta Corriente Vacaciones" align="center"/>
	</form:Title>
	<form:Center height="100%" width="100%">
		<form:Blank name="blka"/>
		<form:Columns height="80px" name="cols" width="100%">
			<form:Column height="100px" name="col1">
				<form:Combo enabled="0" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:DateTime enabled="0" name="f_ingreso" nvalue="#source:@f_ingreso" pattern="YYYYMMDD" required="0" descr="Fecha de Nacimiento Desde" mask="dd/mm/yyyy" label="Fecha Ingreso">
					<form:SButtons>
						<form:SButton visible="0" descrip="Fecha de Nacimiento" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox label="Antig&#252;edad" name="e_antiguedad" nvalue="#source:@e_antiguedad" enabled="0" length="30" xsize="30" ysize="1" required="0"/>
			</form:Column>
			<form:Column height="100px" name="col2">
				<form:FKInput enabled="0" nvalue="#source:@oi_personal_emp" name="oi_personal_emp" label="Personal" length="30" xsize="15" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput enabled="0" label="Convenio" name="oi_convenio" length="30" xsize="15" required="0" nvalue="#source:@oi_convenio">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.Guia.autoflow">
						<helper-mess code="{oi_convenio.CVal}" id="{oi_convenio.XVal}" text="{oi_convenio.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox label="Saldo Vacaciones (D&#237;as)" name="e_saldo" nvalue="#source:@e_saldo" length="30" xsize="30" ysize="1" enabled="0" required="0"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bln50"/>
		<form:UrlControl height="400px" width="75%" border="0" name="report" nvalue="#source:@report" direct="1"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila6">
				<form:Button img="new" name="btnSolicitar" label="Solicitar">
					<form:Event runat="server" action="SOLICITAR" name="onclick"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl9"/>
				<form:Button descrip="Volver a la pantalla anterior" note="Agregar un nuevo registro" label="Volver" name="btnVolver" visible="" enabled="" img="back">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
