<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Autorizacion.form" doc="source" default_mode="NEW">
	<form:Title>
		<form:Label label="Autorizaci&#243;n de Vacaciones" descrip="Autorizaci&#243;n Vacaciones" style="S3 LCol_w" align="center" name="lbl1"/>
	</form:Title>
	<form:Center>
		<form:Columns name="cols" width="100%">
			<form:Column name="col1">
				<form:Combo name="oi_empresa" nvalue="#source:@oi_empresa" label="Empresa" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO" enabled="0"/>
				<form:DateTime label="Fecha Ingreso" mask="dd/mm/yyyy" descr="Fecha de Nacimiento Desde" required="0" pattern="YYYYMMDD" nvalue="#source:@f_ingreso" name="f_ingreso" enabled="0">
					<form:SButtons>
						<form:SButton visible="0" name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" ysize="1" xsize="30" length="30" enabled="0" nvalue="#source:@e_antiguedad" name="e_antiguedad" label="Antiguedad"/>
			</form:Column>
			<form:Column name="col2">
				<form:FKInput required="0" xsize="15" length="30" label="Personal" name="oi_personal_emp" nvalue="#source:@oi_personal_emp" enabled="0">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput nvalue="#source:@oi_convenio" required="0" xsize="15" length="30" name="oi_convenio" label="Convenio" enabled="0">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_convenio.Text.1}" id="{oi_convenio.XVal}" code="{oi_convenio.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="0" ysize="1" xsize="30" length="30" nvalue="#source:@e_saldo" name="e_saldo" label="Saldo Vacaciones"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bln1"/>
		<form:Line name="line1"/>
		<form:Blank name="bln2"/>
		<form:Columns name="cols2">
			<form:Column name="col21">
				<form:DateTime pattern="YYYYMMDD" nvalue="#source:@f_desde_solicitud" required="1" enabled="0" label="Fecha Inicio" name="f_desde_solicitud">
					<form:SButtons>
						<form:SButton visible="0" name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" nvalue="#source:@f_hasta_solicitud" enabled="0" label="Fecha Fin" required="1" name="f_hasta_solicitud">
					<form:SButtons>
						<form:SButton visible="0" name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event runat="server" name="onchange" action="CALCULAR_DIAS"/>
				</form:DateTime>
				<form:NumberBox nvalue="#source:@e_dias_solicitud" required="1" label="Cantidad D&#237;as" enabled="0" name="e_dias_solicitud">
					<form:Event action="CALCULAR_F_HASTA" name="onchange" runat="server"/>
				</form:NumberBox>
				<form:TextBox nvalue="#source:@d_motivo_solic" label="Motivo Solicitud" length="100" required="0" enabled="0" name="d_motivo_solic"/>
				<form:TextBox nvalue="#source:@o_solicitud" ysize="4" xsize="50" required="0" length="1000" label="Observaciones" enabled="0" name="o_solicitud"/>
				<form:Hidden nvalue="#source:@oi_solicitud" name="oi_solicitud" descrip="oi_solicitud"/>
				<form:Hidden name="l_aprobada" nvalue="#source:@l_aprobada"/>
				<form:Blank name="blanco"/>
				<form:NumberBox label="D&#237;as Anticipados Excedidos" nvalue="#source:@dias_ant_exced" name="dias_ant_exced" enabled="0" descrip="D&#237;as excedidos del l&#237;mite de vacaciones anticipadas"/>
				<form:NumberBox enabled="0" label="D&#237;as Solicitud Excedidos" name="dias_sol_exced" nvalue="#source:@dias_sol_exced"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button img="ok" label="Autorizar" descrip="Autoriza la solicitud de vacaciones fuera de l&#237;mites" name="btnAutorizar" enabled="" visible="" note="Agregar un nuevo registro" startvalidate="1">
					<form:Event action="AUTORIZAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button name="btnCancelar" label="Cancelar" img="back" enabled="" visible="" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
