<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.flow" default_action="HELP" extends="Nomad.parent.guia.flow">
	<flow:info label="NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.flow"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<flow:log text-path="#SOURCE:" text="kkf"/>
			<flow:open-form form-class="NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="outDOC">
			<DATOS/>
		</doc:define>
		<doc:define class="NucleusRH.Base.Vacaciones.LegajoVacaciones.PERSONAL_EMP" name="DDO"/>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.form:SHOW" form-class="NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.form" extends="nomad.parent.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-object id-path="#SOURCE:@oi_personal_emp" doc="DDO" class="NucleusRH.Base.Vacaciones.LegajoVacaciones.PERSONAL_EMP"/>
			<flow:exec-method method="Interrumpir_vac" this-doc="DDO">
				<flow:param attr-path="#SOURCE:@oi_solicitud" type="Nomad.NSystem.String" mode="in" name="oi_solicitud"/>
				<flow:param attr-path="#SOURCE:@f_int" type="Nomad.NSystem.DateTime" mode="in" name="fecha_interrupcion"/>
				<flow:param attr-path="#SOURCE:@e_dias_solicitud" name="e_cant_dias" mode="in" type="Nomad.NSystem.Int"/>
			</flow:exec-method>
			<flow:exit-flow next-action="CANCEL" return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow next-action="CANCEL" return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="RECALCULAR_DIAS">
			<doc:set-attribute to-attr-path="#outDOC:@cant_dias" from-value=""/>
			<flow:exec-method out-doc="outDOC" out-type="Nomad.NSystem.Proxy.NomadXML" class="NucleusRH.Base.Vacaciones.LegajoVacaciones.PERSONAL_EMP" method="RecalcularFechas">
				<flow:param attr-path="#SOURCE:@oi_personal_emp" type="Nomad.NSystem.String" mode="in" name="oi_personal_emp"/>
				<flow:param name="fecha_desde" attr-path="#SOURCE:@f_desde_solicitud" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="fecha_hasta" attr-path="#SOURCE:@f_int" type="Nomad.NSystem.String" mode="in"/>
				<flow:param attr-path="#outDOC:@cant_dias" type="Nomad.NSystem.String" mode="in" name="cant_dias"/>
			</flow:exec-method>
			<doc:set-attribute to-attr-path="#SOURCE:@e_dias_solicitud" from-attr-path="#outDOC:@cant_dias"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_int" from-attr-path="#outDOC:@fecha_hasta"/>
		</flow:action>
		<flow:action name="RECALCULAR_FECHA">
			<doc:set-attribute to-attr-path="#outDOC:@f_hasta_solicitud" from-value=""/>
			<flow:exec-method out-doc="outDOC" out-type="Nomad.NSystem.Proxy.NomadXML" class="NucleusRH.Base.Vacaciones.LegajoVacaciones.PERSONAL_EMP" method="RecalcularFechas">
				<flow:param attr-path="#SOURCE:@oi_personal_emp" type="Nomad.NSystem.String" mode="in" name="oi_personal_emp"/>
				<flow:param name="fecha_desde" attr-path="#SOURCE:@f_desde_solicitud" type="Nomad.NSystem.String" mode="in"/>
				<flow:param attr-path="#outDOC:@f_int" name="fecha_hasta" type="Nomad.NSystem.String" mode="in"/>
				<flow:param attr-path="#SOURCE:@e_dias_solicitud" type="Nomad.NSystem.String" mode="in" name="cant_dias"/>
			</flow:exec-method>
			<doc:set-attribute to-attr-path="#SOURCE:@e_dias_solicitud" from-attr-path="#outDOC:@cant_dias"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_int" from-attr-path="#outDOC:@fecha_hasta"/>
		</flow:action>
	</flow:form>
</flow:flow>
