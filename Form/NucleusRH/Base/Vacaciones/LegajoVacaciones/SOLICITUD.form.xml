		function ListClick()
{
	EnableButtons();
}


function EnableButtons()
{
	var oi_estado;
	
	if (Ctrl('LIST'))                      
	{
		oi_estado=Ctrl("LIST").GetSelectAttrValue("oi_estado_solic");
		oi_estado=oi_estado.split("]")[0].substr(1);
	} else           
	{
		oi_estado=Ctrl('oi_estado_solic').GetCValue();
		oi_estado=oi_estado.split(" - ")[0];
	}
	
	
	switch(oi_estado)
	{	 	
	 	case 'S': //Solicitada    	 		
 			CtrlEnabled('APROBAR'    , true);	 			
 			CtrlEnabled('AUTORIZAR'  , true);
 			CtrlEnabled('CANCELAR'   , false);
 			CtrlEnabled('INTERRUMPIR', false);
		break;
	 	case 'A': //Aprobada	 		
 			CtrlEnabled('APROBAR'    , false);	 			
 			CtrlEnabled('AUTORIZAR'  , false);
 			CtrlEnabled('CANCELAR'   , true);
 			CtrlEnabled('INTERRUMPIR', false);
		break;
	 	case 'L': //Liquidada	 		
 			CtrlEnabled('APROBAR'    , false);	 			
 			CtrlEnabled('AUTORIZAR'  , false);
 			CtrlEnabled('CANCELAR'   , false);
 			CtrlEnabled('INTERRUMPIR', true);
		break;
		default:	 		
 			CtrlEnabled('APROBAR'    , false);	 			
 			CtrlEnabled('AUTORIZAR'  , false);
 			CtrlEnabled('CANCELAR'   , false);
 			CtrlEnabled('INTERRUMPIR', false);
		break;
	}
	
	if(oi_estado=="S")
	{					
		CtrlEnabled('f_desde_solicitud', true);
		CtrlEnabled('f_hasta_solicitud', true);
		CtrlEnabled('f_solicitud', true);
		CtrlEnabled('oi_estado_solic', true);
		CtrlEnabled('d_motivo_solic', true);
		CtrlEnabled('f_estado_solic', true);
		CtrlEnabled('e_dias_solicitud', true);
		CtrlEnabled('e_dias_bonif', true);
		CtrlEnabled('o_solicitud', true);
	} else {
		CtrlEnabled('f_desde_solicitud', false);
		CtrlEnabled('f_hasta_solicitud', false);
		CtrlEnabled('f_solicitud', false);
		CtrlEnabled('oi_estado_solic', false);
		CtrlEnabled('d_motivo_solic', false);
		CtrlEnabled('f_estado_solic', false);
		CtrlEnabled('e_dias_solicitud', false);
		CtrlEnabled('e_dias_bonif', false);
		CtrlEnabled('o_solicitud', false);		
	}					
}

function onshow(me)
{
	EnableButtons();
} 

function ReCall()
{
	this.processResult = function()
	{
		Ctrl('main').DoEvent('RECALL');
	}
}

function interrumpir()
{
	var MyPARAM=new NomadXML("MSG");
	if (Ctrl('LIST'))                      
	{
		MyPARAM.SetAttr("oi_solicitud"     , Ctrl("LIST").GetXValue());
		MyPARAM.SetAttr("f_desde_solicitud", Ctrl("LIST").GetSelectAttrValue("f_desde_solicitud"));
		MyPARAM.SetAttr("f_hasta_solicitud", Ctrl("LIST").GetSelectAttrValue("f_hasta_solicitud"));
	} else           
	{
		MyPARAM.SetAttr("oi_solicitud"     , Ctrl("oi_solicitud").GetXValue());
		MyPARAM.SetAttr("f_desde_solicitud", Ctrl("f_desde_solicitud").GetXValue());
		MyPARAM.SetAttr("f_hasta_solicitud", Ctrl("f_hasta_solicitud").GetXValue());
	}
	MyPARAM.SetAttr("oi_personal_emp"  , Ctrl("oi_personal_emp"  ).GetXValue());
	  
	openNewFlowWait("NucleusRH.Base.Vacaciones.LegajoVacaciones.f_interrupcion.guia.flow","HELP",MyPARAM.ToString(),new ReCall(),"N");
}
	</form:Scripts>
