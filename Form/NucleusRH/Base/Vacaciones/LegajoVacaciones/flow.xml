				<qry:element name="PERSONAS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT
				PER01_PERSONAL.d_ape_y_nom, 
				PER02_PERSONAL_EMP.oi_personal_emp, 
				PER02_PERSONAL_EMP.e_numero_legajo, 
				PER02_PERSONAL_EMP.f_ingreso,
				PER11_TIPOS_PERS.d_tipo_personal, 
				ORG03_EMPRESAS.c_empresa,
				ORG08_CS_COSTO.c_centro_costo,
				ORG08_CS_COSTO.d_centro_costo				
			FROM
				PER02_PERSONAL_EMP, 
				ORG03_EMPRESAS, 
				PER01_PERSONAL, 
				PER11_TIPOS_PERS, 
				ORG08_CS_COSTO
      JOIN
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
        PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
        PER02_PERSONAL_EMP.oi_tipo_personal INNER PER11_TIPOS_PERS.oi_tipo_personal,
        PER02_PERSONAL_EMP.oi_ctro_costo_ult INNER ORG08_CS_COSTO.oi_centro_costo
      WHERE	1=1
				{%? (#SOURCE:@EMPRESA!='')	{% AND PER02_PERSONAL_EMP.oi_empresa ={#SOURCE:@EMPRESA} %} {% %} %}
				{%? (#SOURCE:@TIPO_PER!='')	{% AND PER02_PERSONAL_EMP.oi_tipo_personal ={#SOURCE:@TIPO_PER} %} {% %} %}
				{%? (string(#SOURCE:LEGAJOS/LEGAJO/@id)!='') {% AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=string(#SOURCE:LEGAJOS/LEGAJO/@id) %}) %} {%  %} %}
    		{%? (#SOURCE:@F_HASTA!='') {% AND PER02_PERSONAL_EMP.f_ingreso &lt; {#SOURCE:@F_HASTA} %} {% %} %}
    		{%? (#SOURCE:@F_DESDE!='') {% AND PER02_PERSONAL_EMP.f_ingreso &gt; {#SOURCE:@F_DESDE} %} {% %} %} 
    		{%? (#SOURCE:@oi_indic_activo!='') {% AND PER02_PERSONAL_EMP.oi_indic_activo = {#SOURCE:@oi_indic_activo} %} {% %} %}
    	  {%? (#SOURCE:@oi_ctro_costo!='')	{% AND PER02_PERSONAL_EMP.oi_ctro_costo_ult ={#SOURCE:@oi_ctro_costo} %} {% %} %} 
			ORDER BY 
      	{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
				{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
				{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
				{%? (#SOURCE:@ATRIB_ORDEN4!='')	{% {%=#SOURCE:@ATRIB_ORDEN4%} {%? (#SOURCE:@ORDEN4!='') {% {%=#SOURCE:@ORDEN4%}, %} {% ASC, %}	%} %} {% %} %}
				{%? (#SOURCE:@ATRIB_ORDEN5!='')	{% {%=#SOURCE:@ATRIB_ORDEN5%} {%? (#SOURCE:@ORDEN5!='') {% {%=#SOURCE:@ORDEN5%}, %} {% ASC, %}	%} %} {% %} %}
				oi_personal_emp ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_personal_emp" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_personal_emp" name="value"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@e_numero_legajo" name="e_numero_legajo"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@c_empresa" name="c_empresa"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_empresa" name="oi_empresa"/>
						<qry:insert-select doc-path="." name="FIND-PER-DESCR"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="FIND-PER-DESCR">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.e_numero_legajo AS COD, 
					PER01_PERSONAL.d_ape_y_nom AS DES 
				FROM 
					PER02_PERSONAL_EMP, PER01_PERSONAL			
				JOIN 
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp ={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="'[' + $r/@COD + '] ' + $r/@DES" name="descr"/>
					<qry:attribute value="$r/@DES" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
			SELECT
				s.policy
			FROM
				NMD_SECURITY AS s 
			WHERE 
				s.class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\' AND
				s.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
