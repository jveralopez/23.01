						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:insert-select doc-path="." name="FIND-PER-DESCR"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
