<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.form" doc="SOURCE" name="NucleusRH.Base.Vacaciones.Solicitudes.guia">
	<form:Scripts>
		function FilterGrid()
		{
			Ctrl("GRID").FilterElements("","");
			if (Ctrl("buscar").GetCValue()!="") Ctrl("GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
		}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" label="Seleccion de Personal Empresa" style="S3 LCol_w" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead"/>
		</form:Columns>
		<form:FKInput name="PARENTID" nvalue="#SOURCE:@PARENTID" label="Empresas" length="30" xsize="15" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.guia.autoflow">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="EDIT|NEW|SHOW">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event name="onReceiveData" action="RELOAD_QUERY" runat="server"/>
		</form:FKInput>
		<form:Blank name="blank_iter01"/>
		<form:RowAligner name="buttonlinks" visible="SHOW">
			<form:Row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blank_iter02"/>
		<form:Grid name="GRID" nvalue="#SOURCE:ROWS" idvalue="#ROW:@id" doc="ROW" rows="8" paging="1" allownew="0" allowdel="0">
			<form:GColumns>
				<form:GColumn name="Col1">
					<form:Link name="LINK" label="" img="link2" descrip="Codigo" allowimg="1"/>
				</form:GColumn>
				<form:GColumn name="Col2">
					<form:TextBox name="CODE" nvalue="#ROW:@code1" label="Codigo" length="8" xsize="8" ysize="1" descr="Codigo" note="Codigo" enabled="0"/>
				</form:GColumn>
				<form:GColumn name="Col3">
					<form:TextBox name="TEXT" nvalue="#ROW:@text1" label="Descripcion" length="40" xsize="40" ysize="1" descr="Descripcion" note="Descripcion" enabled="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
