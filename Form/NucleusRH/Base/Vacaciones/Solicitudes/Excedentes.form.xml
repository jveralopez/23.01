<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Solicitudes.Excedentes.form" doc="source" parent-doc="PARENTsource" default_mode="SHOW">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Solicitudes Vacaciones TTA - Excedentes" nowrap="1" name="lblTitulo" visible="EDIT" style="S3 LCol_w"/>
				<form:Label label="Solicitudes Vacaciones TTA - Excedentes" nowrap="1" name="lblTitulo" visible="SHOW" style="S3 LCol_w"/>
				<form:Label nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
				<form:Label dynamic="1" nvalue="#TITULOLIQ19:@codigo" nowrap="1" align="center" style="S3 LCol_w" name="ti_02"/>
				<form:Label nowrap="1" align="center" style="S3 LCol_w" name="ti_03"/>
				<form:Label dynamic="1" nvalue="#TITULOLIQ19:@desc" nowrap="1" align="center" style="S3 LCol_w" name="ti_04"/>
				<form:Label nowrap="1" align="left" style="S3 LCol_w" name="ti_05"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bldd" width="100%" visible=""/>
		<form:RowAligner name="GRILLAS">
			<form:Row name="row3">
				<form:Grid nvalue="#source:PERSONAS" name="grdDatosPersonaInicializadas" note="" descrip="" rows="8" allowhelper="0" allowdelall="0" allownew="0" allowdel="0" paging="1" enabled="" idvalue="#source:@id" doc="source">
					<form:GColumns>
						<form:GColumn name="grdSel">
							<form:CheckBox nvalue="#source:@chk_seleccion" name="chk_seleccion" label="Sel"/>
						</form:GColumn>
						<form:GColumn name="grdPersonal">
							<form:FKInput nvalue="#source:@oi_personal_emp" enabled="0" label="Empresa - Legajo" required="1" xsize="15" length="30" name="oi_personal_emp">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH" enabled="">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn name="grdFDesde">
							<form:DateTime name="f_desde_solicitud" nvalue="#source:@f_desde_solicitud" xsize="12" pattern="YYYYMMDD" label="Fecha Desde" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="grdFHasta">
							<form:DateTime name="f_hasta_solicitud" nvalue="#source:@f_hasta_solicitud" xsize="12" pattern="YYYYMMDD" label="Fecha Hasta" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="grdDias">
							<form:TextBox name="e_dias_solicitud" nvalue="#source:@e_dias_solicitud" xsize="15" label="Dias Solicitados" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="grdMotivo">
							<form:TextBox name="d_motivo_solic" nvalue="#source:@d_motivo_solic" xsize="45" label="Motivo Solicitud" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="grdEstado">
							<form:Combo enabled="0" name="oi_estado_solic" nvalue="#source:@oi_estado_solic" label="Estado" flow="NucleusRH.Base.Vacaciones.Estados_Solicitud.ESTADO_SOLIC.Combo.autoflow" action="COMBO"/>
						</form:GColumn>
						<form:GColumn name="grdMaxDiasSol">
							<form:TextBox label="Excede Dias Solicitud" enabled="0" name="MaxDiasSol" nvalue="#source:@MaxDiasSol"/>
						</form:GColumn>
						<form:GColumn name="grdMaxDiasAnt">
							<form:TextBox label="Excede Dias Anticipados" xsize="0" enabled="0" name="MaxDiasAnt" nvalue="#source:@MaxDiasAnt"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="2">
			<form:Row name="filaBotones">
				<form:Button note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="save" label="Aceptar" name="SAVE">
					<form:Event action="ACEPTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
