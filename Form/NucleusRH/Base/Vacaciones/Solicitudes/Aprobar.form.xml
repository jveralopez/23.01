<form:Form xmlns:form="nomad_engine.form" extends="nomad.childIter.form" doc="source" name="NucleusRH.Base.Vacaciones.Solicitudes.Aprobar">
	<form:Title>
		<form:Label visible="" style="S3 LCol_w" align="center" label="Generaci&#243;n de Vacaciones" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
		<form:Blank visible="" width="100%" name="bl5"/>
		<form:FKInput name="oi_estructura" label="Unidades Organizativas" length="30" xsize="15" enabled="" required="0">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="bl51" visible="" width="100%"/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdSolicitudes">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput name="oi_solicitud" label="Solicitudes" length="30" xsize="15" enabled="" required="0">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Vacaciones.Solicitudes.guia.flow">
							<helper-mess code="{this.CVal}" id="{this.XVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank visible="" width="100%" name="bl6"/>
		<form:Blank visible="" width="100%" name="bl7"/>
		<form:Blank visible="" width="100%" name="bl8"/>
		<form:Blank name="bl9" width="100%"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila6">
				<form:Button note="Ejecuta la busqueda" img="play" label="Generar" name="btnAceptar" visible="" startvalidate="1" descrip="Genera las vacaciones de las personas que cumplen con los filtros ingresados">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button descrip="Volver a la pantalla anterior" note="Agregar un nuevo registro" label="Volver" name="btnVolver" visible="" enabled="" img="back">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
