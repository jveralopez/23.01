<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Solicitudes.FiltroAprobar" doc="source" extends="nomad.childIter.form">
	<form:Title>
		<form:Label name="lbl" label="Generaci&#243;n de Vacaciones" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Combo name="oi_empresa" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:FKInput label="Clase Organizativa - Unidad Organizativa" required="0" enabled="" xsize="15" length="30" name="oi_estructura">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank width="100%" visible="" name="bl51"/>
		<form:Grid name="grdSolicitudes" note="" descrip="" rows="3" allowhelper="0" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput required="0" enabled="" xsize="15" length="30" label="Solicitudes" name="oi_solicitud">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Vacaciones.Solicitudes.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:Blank name="bl7" width="100%" visible=""/>
		<form:Blank name="bl8" width="100%" visible=""/>
		<form:Blank width="100%" name="bl9"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button descrip="Genera las vacaciones de las personas que cumplen con los filtros ingresados" startvalidate="1" visible="" name="btnAceptar" label="Generar" img="play" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
