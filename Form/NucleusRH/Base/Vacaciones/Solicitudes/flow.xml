						<qry:attribute name="hasta" value="$r/@f_hasta_solicitud" type="Nomad.NSystem.String"/>
						<qry:attribute name="dias" value="$r/@e_dias_solicitud" type="Nomad.NSystem.String"/>
						<qry:attribute name="estado" value="$r/@d_estado_solic" type="Nomad.NSystem.String"/>
