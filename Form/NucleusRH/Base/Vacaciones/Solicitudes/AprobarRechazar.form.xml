<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Solicitudes.AprobarRechazar.form" doc="source" parent-doc="PARENTsource">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Solicitudes Vacaciones - Aprobar / Rechazar" nowrap="1" name="lblTitulo" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center height="100%" width="100%">
		<form:HiddenArr proto="&lt;ROW /&gt;" nvalue="#source:SELECT" name="SELECT">
			<form:Attr name="id"/>
			<form:Event action="EnableButtons" name="onpostadd" runat="client"/>
			<form:Event action="EnableButtons" name="onpostdel" runat="client"/>
		</form:HiddenArr>
		<form:HTMLPaste name="PASTE">
			<span height="20px">
				&#160;
			</span>
		</form:HTMLPaste>
		<form:ListView arr-control="SELECT" rows="-250" width="90%" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn sorteable="1" descrip="Empresa" attrname="empresa" label="Empresa" align="left" type="string" width="200px" name="EMP"/>
				<form:LVColumn sorteable="1" attrname="legajo" descrip="Legajo" align="left" type="string" width="200px" label="Legajo" name="LEG"/>
				<form:LVColumn sorteable="1" align="center" label="Fecha Desde" width="70px" type="datetime" additional="dd/mm/yyyy" attrname="desde" name="DESDE"/>
				<form:LVColumn sorteable="1" align="center" label="Fecha Hasta" width="70px" type="datetime" additional="dd/mm/yyyy" attrname="hasta" name="HASTA"/>
				<form:LVColumn sorteable="1" align="right" attrname="dias" additional="##0" type="number" width="50px" label="Dias Solicitados" name="DIAS"/>
				<form:LVColumn sorteable="1" align="center" attrname="estado" width="100px" type="string" label="Estado" name="EST"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" label="Auto" name="AUTO" attrname="auto" sorteable="0" align="center" type="bool"/>
				<form:LVColumn sorteable="1" descrip="Mensaje" attrname="MSG" label="Mensaje" align="left" type="string" width="200px" name="MSG"/>
			</form:LVColumns>
			<form:SButtons>
				<form:SButton descrip="Marcar todas las Solicitudes" label="Marcar todas las Solicitudes" img="table_check" name="Mark">
					<form:Event action="MarkAll" name="OnClick" runat="client"/>
				</form:SButton>
				<form:SButton label="Desmarcar todas las Solicitudes" img="table_uncheck" descrip="Desmarcar todas las Solicitudes" name="UnMark">
					<form:Event action="UnmarkAll" name="OnClick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event action="EnableButtons" name="OnClick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="2">
			<form:Row name="filaBotones">
				<form:Button policy="NucleusRH/Base/Vacaciones/LegajoVacaciones/SOLICITUD/EDIT" visible="NEW|EDIT" note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="ok" label="Aprobar" name="SAVE">
					<form:Event action="ACEPTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="La solicitud se aprobar&#225; aunque no tenga d&#237;as disponibles, est&#225; seguro que desea continuar?" img="key_go" descrip="Autoriza la solicitud de vacaciones" label="Autorizar" name="AUTORIZAR" policy="NucleusRH/Base/Vacaciones/LegajoVacaciones/SOLICITUD/EDIT" visible="NEW|EDIT" note="Guardar los Cambios en la Base de Datos">
					<form:Event action="AUTORIZAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Vacaciones/LegajoVacaciones/SOLICITUD/EDIT" visible="NEW|EDIT" note="" descrip="" img="group_del" label="Rechazar" name="RECHAZAR">
					<form:Event action="RECHAZAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function MarkAll()
{
	Ctrl("SELECT").DelAllRow();
	
	for (t=0; t&lt;Ctrl("LIST").TotalRowsCount(); t++)
		Ctrl("SELECT").AddRow().SetAttr("id",Ctrl("LIST").GetAttrValue(t, "id"));
	
	Ctrl("LIST").Refresh();
}

function UnmarkAll()
{      
	Ctrl("SELECT").DelAllRow();
	Ctrl("LIST").Refresh();
}

function Validar()
{               
	if (Ctrl("SELECT").CountRow()==0)
	{             
		alert("No se selecciono ninguna Solicitud");
		return false;
	}
	
	return true;
}

function EnableButtons()
{               
	if (Ctrl("SELECT").CountRow()==0)
	{             
		CtrlEnabled("SAVE",false);
		CtrlEnabled("AUTORIZAR",false);
		CtrlEnabled("RECHAZAR",false);
	} else
	{
		CtrlEnabled("SAVE",true);
		CtrlEnabled("AUTORIZAR",true);
		CtrlEnabled("RECHAZAR",true);
	}
}
	</form:Scripts>
	<form:Event action="EnableButtons" name="OnLoad" runat="client"/>
</form:Form>
