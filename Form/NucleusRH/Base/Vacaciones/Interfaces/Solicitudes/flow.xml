<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.flow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.filter.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.filter.form" name="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.filter.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method out-attr-path="#SOURCE:@batch-id" method="Importar" class="NucleusRH.Base.Vacaciones.InterfaceSolicitud.SOLICITUD" priority="4">
				<flow:param type="Nomad.NSystem.String" mode="in" name="oi_empresa" attr-path="#SOURCE:@oi_empresa"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes" doc="SOURCE"/>
		</flow:action>
	</flow:form>
</flow:flow>
