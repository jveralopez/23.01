<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.filter.form" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="Importar Solicitudes de Vacaciones" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="680px">
		<form:Blank name="blank01"/>
		<form:Columns name="tabla1" height="75%">
			<form:Column width="50%" name="fgfgsaas">
				<form:Blank name="blank02"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:Blank name="blank03"/>
				<form:File filename="solicitudes.dat" descrip="Selecciona el archivo a subir" name="file" label="Archivo" note="" required="1" class="INTERFACES" source="1">
					<form:SButtons>
						<form:SButton descrip="Selecciona el archivo a subir" enabled="" visible="" name="sbHelper" label="Buscar archivo" img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Blank name="blank031"/>
				<form:Container height="400px" width="680px" rheight="400px" rwidth="700px" label="Aclaraciones" name="aa" borderwidth="1">
					<form:Blank name="blank031"/>
					<form:RowAligner name="dddd">
						<form:Row name="a1">
							<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="rowBlank1">
							<form:Blank name="blank1"/>
						</form:Row>
						<form:Row name="a2">
							<form:Blank name="blank031"/>
							<form:Label name="formato1" label="NumeroLegajo;FechaDesdeSolicitud;FechaHastaSolicitud;Motivo;Observacion"/>
						</form:Row>
						<form:Row name="rowBlank2">
							<form:Blank name="blank2"/>
						</form:Row>
						<form:Row name="a3">
							<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="rowBlank3">
							<form:Blank name="blank3"/>
						</form:Row>
						<form:Row name="a4">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- El legajo debe estar activo en la empresa."/>
						</form:Row>
						<form:Row name="a5">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- El formato de la fecha es 'dd/mm/yyyy'."/>
						</form:Row>
						<form:Row name="a6">
							<form:Blank name="blank034"/>
							<form:Label name="validacion2" label="- Los 3 primeros campos son obligatorios, debe completarlos."/>
						</form:Row>
						<form:Row name="a7">
							<form:Blank name="blank034"/>
							<form:Label name="validacion2" label="- La Fecha Hasta Solicitud debe ser menor o igual a la Fecha Desde Solicitud."/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank034"/>
							<form:Label name="validacion2" label="- No se deben superponer las fechas de las solicitudes para un mismo legajo."/>
						</form:Row>
						<form:Row name="rowBlank4">
							<form:Blank name="blank4"/>
						</form:Row>
						<form:Row name="a9">
							<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="rowBlank5">
							<form:Blank name="blank5"/>
						</form:Row>
						<form:Row name="a10">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="1000;15/05/2015;22/05/2015"/>
						</form:Row>
						<form:Row name="a11">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="1001;15/05/2015;22/05/2015;Motivo"/>
						</form:Row>
						<form:Row name="a12">
							<form:Blank name="blank038"/>
							<form:Label name="ejemplo3" label="1002;15/05/2015;22/05/2015;;Observacion"/>
						</form:Row>
						<form:Row name="a13">
							<form:Blank name="blank039"/>
							<form:Label name="ejemplo4" label="1003;15/05/2015;22/05/2015;Motivo;Observacion"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
