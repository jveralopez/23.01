<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Vacaciones.Interfaces.Solicitudes.flow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" form-class="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente.form" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente.form:FILTER" form-class="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente.form" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="NucleusRH.Base.Vacaciones.LegajoVacaciones.PERSONAL_EMP" method="ImportarCuentaCorriente" out-attr-path="#SOURCE:@batch-id" priority="4">
				<flow:param attr-path="#SOURCE:@oi_personal_emp_origen" name="oi_personal_emp_origen" type="Nomad.NSystem.String" mode="in"/>
				<flow:param attr-path="#SOURCE:@oi_personal_emp_destino" name="oi_personal_emp_destino" type="Nomad.NSystem.String" mode="in"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Vacaciones.Interfaces.CuentaCorriente" doc="SOURCE"/>
		</flow:action>
	</flow:form>
</flow:flow>
