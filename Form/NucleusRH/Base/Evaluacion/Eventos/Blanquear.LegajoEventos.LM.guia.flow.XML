<flow:flow name="NucleusRH.Base.Evaluacion.Eventos.Blanquear.LegajoEventos.LM.guia" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry qry="HELP" input-doc-path="#SOURCE:" output-doc="RS"/>
			<flow:open-form form-class="NucleusRH.Base.Evaluacion.Eventos.Blanquear.LegajoEventos.LM.guia.form" mode="SHOW" doc-path="#RS:" parent-doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define declare=" &lt;helper-mess ID=&quot;2&quot;&gt;&#13;&#10;  &lt;rows nmd-col=&quot;1&quot;&gt;&#13;&#10;    &lt;row oi_personal_emp=&quot;234&quot; /&gt;&#13;&#10;    &lt;row oi_personal_emp=&quot;235&quot; /&gt;&#13;&#10;  &lt;/rows&gt;&#13;&#10;&lt;/helper-mess&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="ID" value="#SOURCE:helper-mess/@ID" type="Nomad.NSystem.String"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS1"/>
						<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS2"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT PER02_PERSONAL_EMP.oi_personal_emp, PER02_PERSONAL_EMP.e_numero_legajo, PER01_PERSONAL.d_ape_y_nom
			FROM PER02_PERSONAL_EMP, PER01_PERSONAL, EVA02_EVALUACION 
			JOIN 
			EVA02_EVALUACION.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
			PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal 
			WHERE
			EVA02_EVALUACION.oi_evento = {%=#SOURCE:@ID %} AND
			{%? (string(#SOURCE:rows/row/@oi_personal_emp)!='') {%  PER02_PERSONAL_EMP.oi_personal_emp IN ({%=string(#SOURCE:rows/row/@oi_personal_emp) %}) %} {% 1 = 2 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_personal_emp" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@e_numero_legajo" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
						<qry:attribute name="codEmpresa" value="$r/@c_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="dscEmpresa" value="$r/@D_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT
			PER02_PERSONAL_EMP.oi_personal_emp, PER02_PERSONAL_EMP.e_numero_legajo, PER01_PERSONAL.d_ape_y_nom
			FROM EVA02_EVALUACION, PER02_PERSONAL_EMP, PER01_PERSONAL
			JOIN
			EVA02_EVALUACION.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
			PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal 
			WHERE
			EVA02_EVALUACION.oi_evento = {%=#SOURCE:@ID %} AND
			{%? (string(#SOURCE:rows/row/@oi_personal_emp)!='') {%  PER02_PERSONAL_EMP.oi_personal_emp NOT IN ({%=string(#SOURCE:rows/row/@oi_personal_emp) %}) %} {% 1 = 1 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_personal_emp" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@e_numero_legajo" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
						<qry:attribute name="codEmpresa" value="$r/@c_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="dscEmpresa" value="$r/@D_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:attribute name="ID" value="#SOURCE:DATOS/@ID" type="Nomad.NSystem.Int"/>
					<qry:element name="rows">
						<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:DATOS/ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute name="oi_personal_emp" value="$r/@id" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Evaluacion.Eventos.Blanquear.LegajoEventos.LM.guia.form" name="NucleusRH.Base.Evaluacion.Eventos.Blanquear.LegajoEventos.guia.flow:SHOW" mode="SHOW" doc="SOURCE" parent-doc="INVAL">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry qry="PRUEBA" input-doc-path="#SOURCE:" output-doc="OUT"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
