<form:Form extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR.form" default_mode="LIST" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.ADMINISTRAR.form" xmlns:form="nomad_engine.form" doc="source" parent-doc="PARENTSOURCE">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" label="Administraci&#243;n de Legajos a Evaluar" name="lbl_titulo"/>
				<form:Label nvalue="#PARENTSOURCE:@descr" style="S3 LCol_w" nowrap="1" dynamic="1" name="evento"/>
			</form:Row>
		</form:RowAligner>
		<form:Label visible="0" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup width="98%" nvalue="#source:@gcustom" border="1" label="Selecci&#243;n de Empresa" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="cols2">
				<form:Column align="left" valign="top" name="col21">
					<form:Combo enabled="0" nvalue="#source:@oi_empresa" required="1" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" label="Empresa" name="empresa"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup width="98%" nvalue="#source:@gpers" border="1" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%"/>
			<form:Columns width="100%" name="columns1">
				<form:Column valign="top" align="center" name="col1">
					<form:ListView arr-control="list1arr" width="480px" rows="6" name="list1">
						<form:LVColumns>
							<form:LVColumn visible="0" width="70px" type="string" attrname="d_empresa" label="Empresa" name="d_empresa"/>
							<form:LVColumn additional="########" attrname="e_numero_legajo" width="80px" sorteable="1" type="number" label="Legajo" name="e_numero_legajo"/>
							<form:LVColumn width="300px" type="string" sorteable="1" attrname="d_ape_y_nom" label="Apellido y Nombre" name="d_ape_y_nom"/>
						</form:LVColumns>
					</form:ListView>
				</form:Column>
				<form:Column valign="top" align="center" name="col2">
					<form:ListView arr-control="list2arr" width="480px" rows="6" name="list2">
						<form:LVColumns>
							<form:LVColumn visible="0" width="70px" type="string" attrname="d_empresa" label="Empresa" name="d_empresa1"/>
							<form:LVColumn additional="########" attrname="e_numero_legajo" width="80px" sorteable="1" type="number" label="Legajo" name="e_numero_legajo1"/>
							<form:LVColumn width="300px" type="string" sorteable="1" attrname="d_ape_y_nom" label="Apellido y Nombre" name="d_ape_y_nom1"/>
						</form:LVColumns>
					</form:ListView>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:HiddenArr nvalue="#source:ROWS" proto="&lt;ROW id=&quot;&quot;/&gt;" name="legajos">
			<form:Attr name="id"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button img="save" descrip="Guarda los cambios realizados" label="Guardar" name="SAVE" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources/>
	<form:Scripts>
		function Guardar()
{  	
 	Ctrl('legajos').DelAllRow();
 	for (key in arrA)
 	{ 
 		var rowLeg = Ctrl('legajos').AddRow();
 		rowLeg.SetAttr('id', key.substr(1));
 		rowLeg.SetAttr('persona', arrA[key].associatedELE.getAttribute("e_numero_legajo") + " - " + arrA[key].associatedELE.getAttribute("d_ape_y_nom"));
 	}
 	
	Ctrl("main").DoEvent("SAVE");
}
	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
</form:Form>
