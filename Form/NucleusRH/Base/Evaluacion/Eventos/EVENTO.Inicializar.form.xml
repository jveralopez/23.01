<form:Form name="NucleusRH.Base.Evaluacion.Eventos.EVENTO.Inicializar.form" default_mode="SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" visible="EDIT" label="Inicializar Personas a un Evento" name="lblTitulo" nowrap="1"/>
				<form:Label dynamic="1" visible="EDIT" style="S3 LCol_w" nvalue="#SOURCE:@descr" name="ssss" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Hidden nvalue="#SOURCE:@id" name="oi_evento"/>
		<form:Blank visible="" width="100%" name="bldd"/>
		<form:RowAligner name="GRILLAS">
			<form:Row name="GRILLASROWS2">
				<form:Blank visible="" width="100%" name="bl0024d"/>
				<form:RowAligner visible="EDIT" columns="3" name="datos">
					<form:Row name="dato">
						<form:CheckBox name="todos" nvalue="" label="Todos" enabled="" required="0"/>
						<form:CheckBox name="excluir" nvalue="" label="Excluir" enabled="" required="0"/>
					</form:Row>
				</form:RowAligner>
			</form:Row>
			<form:Row name="row2">
				<form:Label style="M1" align="center" visible="EDIT" label="Personas Inicializadas" name="lbS"/>
				<form:Label style="M1" align="center" label="Personas a Incluir/Excluir" visible="EDIT" name="lblS"/>
			</form:Row>
			<form:Row name="row3">
				<form:Grid nvalue="#INI_DOC:EVALUADOS" doc="SOURCE" idvalue="#SOURCE:@oi_evaluacion" enabled="" paging="1" allowdel="0" allownew="0" allowdelall="0" allowhelper="0" rows="8" descrip="" name="grdDatosPersonaInicializadas">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput name="oi_personal_emp" nvalue="#SOURCE:@oi_personal_emp" label="Personal" length="30" xsize="10" enabled="" required="0">
								<form:STexts>
									<form:SText xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Grid idvalue="#SOURCEGRILLA:oi_personal_emp" doc="SOURCEGRILLA" nvalue="" enabled="" paging="1" allowdel="0" allownew="0" allowdelall="1" allowhelper="1" rows="8" note="" name="grdDatosPersona">
					<form:Helper name="NucleusRH.Base.Evaluacion.Eventos.Inicializar.LegajoEventos.LM.guia.flow" xmlns:form="nomad_engine.form" action="HELP">
						<helper-mess ID="{oi_evento.XValue}">
							{grdDatosPersona.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput enabled="0" name="oi_personal_emp" nvalue="" label="Personal" length="30" xsize="10" required="0">
								<form:STexts>
									<form:SText xsize="50"/>
								</form:STexts>
								<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Evaluacion.Evaluacion.EVALUACION.Inicializar.guia.flow">
									<helper-mess oi_evento="{oi_evento.ReadXValue}" code1="{this.CVal}" id="{this.XVal}" text1="{this.Text.1}"/>
								</form:Helper>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="2" name="botones">
			<form:Row name="filaBotones">
				<form:Button mess="Desea Guardar los Cambios?" name="SAVE" label="Guardar" img="save" descrip="Guardar los Cambios en la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="NEW|EDIT">
					<form:Event runat="server" name="onclick" action="SAVE"/>
				</form:Button>
				<form:Button name="VISTAPREVIA" label="Vista Previa" img="search" descrip="" note="" visible="NEW|EDIT">
					<form:Event runat="server" name="onclick" action="VISTAPREVIA"/>
				</form:Button>
				<form:Button name="Volver" label="Volver" img="back" descrip="" note="" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function gg()
{
alert(Ctrl('oi_evento').GetCValue());
}
	</form:Scripts>
</form:Form>
