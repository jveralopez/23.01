<form:Form extends="Nomad.multiple.guia.form" name="NucleusRH.Base.Evaluacion.Eventos.Blanquear.LegajoEventos.LM.guia" doc="SOURCE" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label nowrap="1" style="S3 LCol_w" label="Selecci&#243;n de Personal a Blanquear" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:RowAligner visible="0" name="RADD">
			<form:Row name="RLiq">
				<form:Blank name="blk2"/>
				<form:FKInput nvalue="#SOURCE:@ID" enabled="0" required="1" xsize="15" length="30" label="Evento" name="oi_evento">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Evaluacion.Eventos.EVENTO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:Blank name="blk3"/>
			</form:Row>
		</form:RowAligner>
		<form:Grid allowdel="0" allownew="0" paging="1" rows="8" doc="SOURCE" idvalue="#SOURCE:@id" nvalue="#SOURCE:ROWS" name="GRID">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:CheckBox required="0" enabled="" label="" nvalue="#SOURCE:@check" name="seleccionados"/>
				</form:GColumn>
				<form:GColumn allow_order="0" name="col2">
					<form:TextBox required="0" enabled="EDIT" ysize="1" xsize="15" length="30" label="N&#250;mero de Legajo" nvalue="#SOURCE:@code" name="e_numero_legajo"/>
				</form:GColumn>
				<form:GColumn allow_order="0" name="col3">
					<form:TextBox required="0" enabled="EDIT" descr="Titulo de la liquidacion" ysize="1" xsize="40" length="100" label="Apellido y Nombre" nvalue="#SOURCE:@text" name="d_ape_y_nom"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
