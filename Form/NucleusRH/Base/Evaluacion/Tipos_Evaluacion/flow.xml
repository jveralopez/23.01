<flow:flow name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.flow" extends="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.autoflow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow">
	<flow:declare>
		<doc:define name="AUXDOC"/>
		<qry:define declare="&lt;TIPO_EVAL descr=&quot;[PRO] Produccion&quot; d_tipo_eval=&quot;Produccion&quot; c_tipo_eval=&quot;PRO&quot; id=&quot;4&quot;&gt;&lt;TPO_EVA_COM nmd-col=&quot;1&quot;&gt;&lt;TPO_EVA_COM descr=&quot;[PRO] Produccion - [] &quot; n_ponderacion=&quot;50.000000&quot; oi_tipo_eval=&quot;3&quot; id=&quot;8&quot;&gt;&lt;oi_competencia value=&quot;5&quot; nmd-agr=&quot;1&quot; /&gt;&lt;/TPO_EVA_COM&gt;&lt;TPO_EVA_COM descr=&quot;[PRO] Produccion - [] &quot; n_ponderacion=&quot;50.000000&quot; oi_tipo_eval=&quot;3&quot; id=&quot;9&quot;&gt;&lt;oi_competencia value=&quot;6&quot; nmd-agr=&quot;1&quot; /&gt;&lt;/TPO_EVA_COM&gt;&lt;/TPO_EVA_COM&gt;&lt;TPO_EVA_OBJ nmd-col=&quot;1&quot; /&gt;&lt;/TIPO_EVAL&gt;" name="ValidateDelete">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:attribute name="bandera" value="0" type="Nomad.NSystem.Int"/>
					<qry:insert-select name="sql1" doc-path="#SOURCE:TIPO_EVAL"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT EVA01_EVENTOS.c_clase_eval
				FROM EVA01_EVENTOS
				WHERE EVA01_EVENTOS.c_clase_eval NOT IN (1, 2)
				AND EVA01_EVENTOS.c_clase_eval = {#PARAM:@id}				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="bandera" value="1" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:group Name="TIPO_EVAL">
		<flow:form extends="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.noreg.form:EDIT" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form:SHOW" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:load-qry output-doc="AUXDOC" input-doc-path="#SOURCE:" qry="ValidateDelete"/>
				<flow:call-action else="DEL_ERR" eq="0" if="#AUXDOC:@bandera" action="DEL_OK"/>
			</flow:action>
			<flow:action name="DEL_OK">
				<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
				<doc:save-object class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
			</flow:action>
			<flow:action name="DEL_ERR">
				<flow:message message="No se puede eliminar el Tipo de Evaluaci&#243;n ya que est&#225; asignado a un Evento Evaluativo"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form:LIST" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
				<doc:save-object class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form:EDIT" form-class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.form" mode="EDIT">
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
				<doc:save-object class="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL" doc="DDO"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
