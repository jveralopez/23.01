<flow:flow name="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.combo.flow" extends="Nomad.combo.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO_EVENTO">
			<doc:load-qry qry="COMBO_EVENTO" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="COMBO_EVALUACION">
			<doc:load-qry qry="COMBO_EVALUACION" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="COMBO_EVENTO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="0" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="0" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="'POS'" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="'Puesto/Posici&#243;n'" name="text"/>
					</qry:element>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="1" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="1" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="'TPO'" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="'Gerencial/Individual'" name="text"/>
					</qry:element>
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT EVA04_TIPOS_EVA.oi_tipo_eval, EVA04_TIPOS_EVA.c_tipo_eval, EVA04_TIPOS_EVA.d_tipo_eval 
			FROM EVA04_TIPOS_EVA
      WHERE EVA04_TIPOS_EVA.c_tipo_eval NOT IN (\'GER\',\'IND\')
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipo_eval" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipo_eval" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_tipo_eval" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_tipo_eval" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_TIPO_EVAL"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_TIPO_EVAL">
				<qry:xquery>
					for $r in sql('
			SELECT NMD_SECURITY.policy 
			FROM NMD_SECURITY 
			WHERE NMD_SECURITY.class=\'NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL\' 
			AND NMD_SECURITY.id={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="COMBO_EVALUACION">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="0" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="0" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="'POS'" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="'Puesto/Posici&#243;n'" name="text"/>
					</qry:element>
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT EVA04_TIPOS_EVA.oi_tipo_eval, EVA04_TIPOS_EVA.c_tipo_eval, EVA04_TIPOS_EVA.d_tipo_eval 
			FROM EVA04_TIPOS_EVA      
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipo_eval" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipo_eval" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_tipo_eval" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_tipo_eval" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_TIPO_EVAL"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_TIPO_EVAL">
				<qry:xquery>
					for $r in sql('
			SELECT NMD_SECURITY.policy 
			FROM NMD_SECURITY 
			WHERE NMD_SECURITY.class=\'NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL\' 
			AND NMD_SECURITY.id={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
