<form:Form name="NucleusRH.Base.Evaluacion.Competencias.POSICION.filter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Seleccionar Posici&#243;n" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bk1"/>
		<form:FKInput nvalue="#source:@oi_posicion" label="Empresa - Puesto - Posici&#243;n" required="1" enabled="FILTER" xsize="15" length="30" name="oi_posicion">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{oi_posicion.Text.1}" id="{oi_posicion.XVal}" code="{oi_posicion.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" enabled="" visible="" name="FILTER" label="Filtrar" img="ok" note="Ejecuta la busqueda" descrip="Acepta los datos ingresados y ejecuta el formulario">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="BACK" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
