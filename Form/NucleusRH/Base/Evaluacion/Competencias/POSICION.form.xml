<form:Form name="NucleusRH.Base.Evaluacion.Competencias.POSICION.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Ponderaci&#243;n de Competencias" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bk1"/>
		<form:FKInput label="Empresa - Puesto - Posici&#243;n" required="1" enabled="0" xsize="15" length="30" nvalue="#source:@oi_posicion" name="oi_posicion">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
		</form:FKInput>
		<form:Blank name="bk2"/>
		<form:Columns name="COMPETENCIAS">
			<form:Column name="COMPETENCIA">
				<form:Grid rows="10" width="600px" idvalue="#source:@oi_competencia" nvalue="#source:ROWS" name="grdCOMPETENCIAS" allowdel="0" allownew="0" paging="1" doc="source">
					<form:GColumns>
						<form:GColumn allow_order="0" name="OI_COMPETENCIA" visible="SHOW|EDIT">
							<form:FKInput length="100" nvalue="#source:@oi_competencia" name="oi_competencia" label="Competencia" required="1" enabled="0" xsize="15">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Organizacion.Competencias.COMPETENCIA.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn name="N_PONDERACION" visible="SHOW|EDIT" allow_order="0">
							<form:NumberBox name="n_ponderacion" precision="2" required="1" nvalue="#source:@n_ponderacion" label="Ponderaci&#243;n" min="0"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks" columns="7">
			<form:Row name="row1">
				<form:Button visible="EDIT" startvalidate="1" note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Cancelar" img="cancel" name="CANCEL" visible="EDIT" note="Vuelve a la pantalla anterior del formulario" descrip="Volver a la pantalla anterior">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
