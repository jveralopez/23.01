<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Evaluacion.EvaluacionesPorEvento.flow">
	<flow:info label="NucleusRH.Base.Evaluacion.ResultadoEvaluacion"/>
	<flow:declare>
		<doc:define name="QRY"/>
		<doc:define name="PARAMETERS">
			<DATOS/>
		</doc:define>
		<doc:define name="REPORT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Evaluacion.Reportes.EvaluacionesPorEvento.filter.form" mode="FILTER" doc-path="#PARAMETERS:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Evaluacion.Reportes.EvaluacionesPorEvento.filter.form" name="NucleusRH.Base.Evaluacion.Reportes.EvaluacionesPorEvento.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:log text-path="#PARAMETERS:" text="asdf2"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Evaluacion.EvaluacionesPorEvento.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#PARAMETERS:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Listado de Evaluaciones por Evento" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="SOURCE" name="FILTER-NucleusRH.Base.Evaluacion.Reportes.EvaluacionesPorEvento"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#SOURCE:" name="FILTER-NucleusRH.Base.Evaluacion.Reportes.EvaluacionesPorEvento"/>
		</flow:action>
	</flow:form>
</flow:flow>
