<form:Form default_mode="EDIT" extends="Nomad.parent.guia.form" doc="SOURCE" name="NucleusRH.Base.Evaluacion.Evaluacion.EVALUACION" xmlns:form="nomad_engine.form">
	<form:Center>
		<form:FKInput nvalue="#SOURCE:@OI_EVENTO" enabled="0" required="1" xsize="15" length="30" label="Evento Evaluativo" name="PARENTID">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Evaluacion.Eventos.EVENTO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
</form:Form>
