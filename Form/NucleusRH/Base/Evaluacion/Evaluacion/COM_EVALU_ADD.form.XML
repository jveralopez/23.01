<form:Form mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Evaluacion.Evaluacion.COM_EVALU" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Agregar Competencias a Evaluar" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="blnk01"/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Competencia" nvalue="#source:oi_competencia/@value" name="oi_competencia">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Competencias.COMPETENCIA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" policy="NucleusRH/Base/Evaluacion/Evaluacion/COM_EVALU/NEW" descrip="Agregar un Registro" img="ok" label="Aceptar">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la operaci&#243;n" img="cancel" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" policy="NucleusRH/Base/Evaluacion/Evaluacion/COM_EVALU/DELETE" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
