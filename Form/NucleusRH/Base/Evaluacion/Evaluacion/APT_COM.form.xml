<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Evaluacion.Evaluacion.APT_COM.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Evaluacion.Evaluacion.APT_COM">
	<form:Center width="95%">
		<form:Columns name="clsSuperior">
			<form:Column visible="0" name="colBuscar"/>
			<form:Column name="blnk">
				<form:Blank name="blnk1"/>
			</form:Column>
		</form:Columns>
		<form:Grid idvalue="#source:@id" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcoloi_aptitud1">
					<form:FKInput enabled="0" length="80" xsize="80" label="Aptitud" nvalue="#source:oi_aptit_comp/@value" name="oi_aptit_comp">
						<form:Helper name="NucleusRH.Base.Organizacion.Competencias.APTIT_COMP.Guia.flow" help="HELP" x2c="X2C" c2x="C2X" cache="no">
							<helper-mess text="{this.CVal}" id="{this.XVal}" oi_competencia="{oi_competencia.ReadXValue}"/>
						</form:Helper>
						<form:Event name="onProcessResult" action="setOptions" runat="client"/>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn name="gcoloi_val_escala1">
					<form:Combo enabled="NEW|EDIT" label="Resultado" name="oi_val_escala" nvalue="#source:oi_val_escala/@value"/>
				</form:GColumn>
				<form:GColumn visible="0" name="gcoloi_val_escala"/>
				<form:GColumn visible="0" name="gcoloi_aptit_comp"/>
				<form:GColumn visible="0" name="gcoln_ponderacion"/>
				<form:GColumn visible="0" name="gcoln_resultado"/>
			</form:GColumns>
		</form:Grid>
		<form:Hidden nvalue="#PARENTSOURCE:../oi_competencia/@value" name="oi_competencia"/>
		<form:Blank name="blank0001"/>
		<form:Columns name="cosl232">
			<form:Column name="col007">
				<form:TextBox required="0" ysize="4" xsize="50" length="1000" enabled="EDIT" label="Observaciones" nvalue="#source:../@o_com_evalu" name="o_com_evalu"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="0" policy="NucleusRH/Base/Evaluacion/Evaluacion/APT_COM/NEW" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Evaluacion/Evaluacion/APT_COM/DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		var escalas = null;

function loadEscalas()//as XmlDocument
{
	if (escalas ==null)
		escalas = Ctrl('main').GetLastDoc('ESCALAS');
	return escalas;
}

function setOptions(me)
{
	var opts = SearchById(loadEscalas().childNodes, me.GetXValue());//as XmlElement
	var cbo = me.m_Parent.m_Children[2];
	if (opts != null)
		cbo.setOptions(opts);
	cbo.SyncHTML();
}
	</form:Scripts>
</form:Form>
