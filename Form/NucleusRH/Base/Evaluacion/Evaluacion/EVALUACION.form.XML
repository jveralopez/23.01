<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Evaluacion.Evaluacion.EVALUACION.form" extends="NucleusRH.Base.Evaluacion.Evaluacion.EVALUACION.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Event action="OnLoad" name="onload" runat="client"/>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsEVALUACION">
			<form:Column visible="0" name="main_columnsEVALUACIONcolumn1"/>
			<form:Column name="main_columnsEVALUACIONcolumn2">
				<form:ComboBox enabled="0" nvalue="#EMPRESA:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="60" mode="QRY" required="1" label="Empresa" name="oi_empresa"/>
				<form:ComboBox label="Evento" prev="oi_empresa" queryname1="NucleusRH.Base.Evaluacion.Eventos.EVENTO.INFO" xsize="60" mode="QRY" required="1" enabled="0" nvalue="#source:oi_evento/@value" name="oi_evento"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="60" mode="QRY" required="1" enabled="0" label="Personal Evaluado" nvalue="#source:oi_personal_emp/@value" name="oi_personal_emp"/>
				<form:FKInput required="1" enabled="0" xsize="15" length="30" label="Posici&#243;n Evaluado" nvalue="#source:oi_pos_evaluado/@value" name="oi_pos_evaluado">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_NOSEC" prev="oi_empresa" xsize="60" mode="QRY" required="1" enabled="0" label="Evaluador" nvalue="#source:oi_evaluador/@value" name="oi_evaluador"/>
				<form:FKInput required="1" enabled="0" xsize="15" length="30" label="Posici&#243;n Evaluador" nvalue="#source:oi_pos_evaluador/@value" name="oi_pos_evaluador">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_NOSEC" prev="oi_empresa" xsize="60" mode="QRY" required="0" enabled="0" label="Supervisor" nvalue="#source:oi_supervisor/@value" name="oi_supervisor"/>
				<form:FKInput required="0" enabled="0" xsize="15" length="30" label="Posici&#243;n Supervisor" nvalue="#source:oi_pos_supervisor/@value" name="oi_pos_supervisor">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Combo action="COMBO_EVALUACION" flow="NucleusRH.Base.Evaluacion.Tipos_Evaluacion.TIPO_EVAL.Combo.flow" required="1" enabled="0" label="Tipo de Evaluaci&#243;n" nvalue="#source:@c_tipo_evaluacion" name="c_tipo_evaluacion"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado">
					<options>
						<option text="Abierta" value="AB"/>
						<option text="Evaluada" value="EV"/>
						<option text="Anulada" value="AN"/>
						<option text="Cerrada" value="CE"/>
					</options>
				</form:ComboBox>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Evaluaci&#243;n" nvalue="#source:@f_evaluacion" name="f_evaluacion">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaci&#243;n del Evaluado" nvalue="#source:@o_evaluado" name="o_evaluado"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaci&#243;n del Evaluador" nvalue="#source:@o_evaluador" name="o_evaluador"/>
				<form:NumberBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" label="Resultado Final (Num&#233;rico)" required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" nvalue="#source:@n_resultado" name="n_resultado"/>
				<form:NumberBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" label="Resultado Competencias (Num&#233;rico)" required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" nvalue="#source:@n_res_comp" name="n_res_comp"/>
				<form:NumberBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" label="Resultado Objetivos (Num&#233;rico)" required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" nvalue="#source:@n_res_objetivos" name="n_res_objetivos"/>
				<form:TextBox enabled="NEW|EDIT" required="0" ysize="1" xsize="30" length="30" label="Resultado Final" nvalue="#source:@c_resultado" name="c_resultado"/>
				<form:CheckBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" enabled="NEW|EDIT" required="0" label="Aprobado" nvalue="#source:@l_aprobado" name="l_aprobado"/>
				<form:TextBox enabled="NEW|EDIT" required="0" ysize="1" xsize="30" length="30" label="Resultado Competencias" nvalue="#source:@c_res_comp" name="c_res_comp"/>
				<form:CheckBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" enabled="NEW|EDIT" required="0" label="Aprueba Competencias" nvalue="#source:@l_aprobado_comp" name="l_aprobado_comp"/>
				<form:TextBox enabled="NEW|EDIT" required="0" ysize="1" xsize="30" length="30" label="Resultado Objetivos" nvalue="#source:@c_res_objetivos" name="c_res_objetivos"/>
				<form:CheckBox policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" enabled="NEW|EDIT" required="0" label="Aprueba Objetivos" nvalue="#source:@l_aprobado_obj" name="l_aprobado_obj"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Confirmaci&#243;n/Anulaci&#243;n" nvalue="#source:@f_confirmacion" name="f_confirmacion">
					<form:SButtons>
						<form:SButton visible="0" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Cierre" nvalue="#source:@f_cierre" name="f_cierre">
					<form:SButtons>
						<form:SButton visible="0" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Personal Evaluado" attrname="oi_personal_emp_descr" name="oi_personal_emp"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Evento" attrname="oi_evento_descr" name="oi_evento"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="50px" type="string" label="Evaluador" attrname="oi_evaluador_descr" name="oi_evaluador"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="50px" type="string" label="Supervisor" attrname="oi_supervisor_descr" name="oi_supervisor"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="50px" type="string" label="Posici&#243;n Supervisor" attrname="oi_pos_supervisor_descr" name="oi_pos_supervisor"/>
				<form:LVColumn additional="&lt;combo action=&quot;COMBO&quot; flow=&quot;NucleusRH.Base.Evaluacion.Evaluacion.EVALUACION.c_estado.Combo.autoflow&quot; /&gt;" align="left" sorteable="1" width="100px" type="combo" label="Estado" attrname="c_estado" name="c_estado"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Resultado Final" attrname="c_resultado" name="c_resultado"/>
				<form:LVColumn visible="0" additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Resultado Final de la Evaluaci&#243;n" attrname="n_resultado" name="n_resultado"/>
				<form:LVColumn visible="0" additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Resultado" attrname="n_res_comp" name="n_res_comp"/>
				<form:LVColumn attrname="n_res_objetivos" name="n_res_objetivos" visible="0" additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Resultado"/>
				<form:LVColumn visible="0" additional="ifo.ico|err.ico" align="center" sorteable="1" width="20px" type="bool" label="Aprobado" attrname="l_aprobado" name="l_aprobado"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Resultado Competencias" attrname="c_res_comp" name="c_res_comp"/>
				<form:LVColumn visible="0" additional="ifo.ico|err.ico" align="center" sorteable="1" width="20px" type="bool" label="Aprueba Competencias" attrname="l_aprobado_comp" name="l_aprobado_comp"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Resultado Objetivos" attrname="c_res_objetivos" name="c_res_objetivos"/>
				<form:LVColumn visible="0" additional="ifo.ico|err.ico" align="center" sorteable="1" width="20px" type="bool" label="Aprueba Objetivos" attrname="l_aprobado_obj" name="l_aprobado_obj"/>
			</form:LVColumns>
			<form:Event action="onload" name="onclick" runat="client"/>
		</form:ListView>
		<form:Hidden name="f_hoy"/>
	</form:Center>
	<form:Right width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsEVALUACION">
			<form:Link allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/COM_EVALU/READ" descrip="Registra las competencias evaluadas o a evaluar de un evaluado para un evento en particular." label="Competencias" name="COM_EVALU">
				<form:Event policy="NucleusRH/Base/Evaluacion/Evaluacion/COM_EVALU/EDIT" action="CALL:COM_EVALU" name="onclick" runat="server"/>
			</form:Link>
			<form:Link allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/OBJ_EVALU/READ" descrip="Tabla codificadora de Objetivos Generales por Evaluacion." label="Objetivos" name="OBJ_EVALU">
				<form:Event policy="NucleusRH/Base/Evaluacion/Evaluacion/OBJ_EVALU/EDIT" action="CALL:OBJ_EVALU" name="onclick" runat="server"/>
			</form:Link>
			<form:Link visible="0" label="Cargar Objetivos Propuestos" allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/OBJ_PROP/READ" descrip="Objetivos propuestos para el per&#237;odo pr&#243;ximo" name="OBJ_PROP"/>
		</form:VGroup>
		<form:Blank name="bl1"/>
		<form:VGroup background="1" label="Acciones" collapse="1" width="100%" name="vgActionsEVALUACION">
			<form:Link label="Cargar Objetivos Propuestos" allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/OBJ_PROP/READ" descrip="Objetivos propuestos para el per&#237;odo pr&#243;ximo" name="OBJ_PROP">
				<form:Event policy="NucleusRH/Base/Evaluacion/Evaluacion/OBJ_PROP/EDIT" action="CALL:OBJ_PROP" name="onclick" runat="server"/>
			</form:Link>
			<form:Link allowimg="1" visible="SHOW" policy="NucleusRH/Base/Evaluacion/Evaluacion/Admin-Editar" name="CONFIRMAR" mess="Est&#225; seguro que desea confirmar la Evaluaci&#243;n? Una vez confirmada no podr&#225; ser modificada" descrip="Confirma la Evaluaci&#243;n" label="Confirmar">
				<form:Event action="CONFIRMAR" runat="server" name="onclick"/>
			</form:Link>
			<form:Link allowimg="1" visible="SHOW" policy="NucleusRH/Base/Evaluacion/Evaluacion/Admin-Editar" mess="Est&#225; seguro que desea anular la Evaluaci&#243;n? Una vez anulada la misma no se podr&#225; modificar." name="ANULAR" descrip="Anula la Evaluaci&#243;n" label="Anular">
				<form:Event action="ANULAR" runat="server" name="onclick"/>
			</form:Link>
			<form:Link visible="SHOW" allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/Admin-Cerrar" name="CERRAR" mess="Est&#225; seguro que desea cerrar la Evaluaci&#243;n? Una vez cerrada no podr&#225; ser modificada." descrip="Cierra la Evaluaci&#243;n" label="Cerrar">
				<form:Event action="CERRAR" runat="server" name="onclick"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="SHOW|LIST" policy="NucleusRH/Base/Evaluacion/Evaluacion/Admin-Editar" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" policy="NucleusRH/Base/Evaluacion/Evaluacion/NEW" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Evaluacion/Evaluacion/DELETE" visible="SHOW|LIST" mess="&#191;Est&#225; seguro que desa eliminar el registro?" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Evaluacion/Evaluacion/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function OnLoad(me)
{
	// Setea la fecha de hoy
	Ctrl('f_hoy').SetXValue(date2str(NowDate()));
	
	//Validaci&#243;n de botones en modo LIST y SHOW
	var estado;
	if (Ctrl('main').GetMode()=="LIST")
		estado = Ctrl('LIST').GetSelectAttrValue('c_estado');
	else
		estado = Ctrl('c_estado').GetXValue()
	
	switch(estado)
	{
		case 'AB':
			CtrlEnabled('EDIT',true);
			CtrlEnabled('CONFIRMAR',true);
			CtrlEnabled('ANULAR',true);
			CtrlEnabled('CERRAR',false);
			break;
		case 'EV':
			CtrlEnabled('EDIT',false);
			CtrlEnabled('CONFIRMAR',false);
			CtrlEnabled('ANULAR',false);
			CtrlEnabled('CERRAR',true);
			break;
		default:
			CtrlEnabled('EDIT',false);
			CtrlEnabled('CONFIRMAR',false);
			CtrlEnabled('ANULAR',false);
			CtrlEnabled('CERRAR',false);
			break;
	}
}
	</form:Scripts>
</form:Form>
