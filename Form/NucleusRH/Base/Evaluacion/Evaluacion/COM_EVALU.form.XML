<form:Form extends="NucleusRH.Base.Evaluacion.Evaluacion.COM_EVALU.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Evaluacion.Evaluacion.COM_EVALU" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:Columns visible="" name="clsSuperior">
			<form:Column name="colBuscar" visible="0">
				<form:TextBox descrip="Busca el texto en la grilla." note="Busca el texto en la grilla." xsize="15" length="100" label="Buscar" nvalue="" name="txtSearch">
					<form:SButtons>
						<form:SButton img="search" label="Buscar" name="sbSearch">
							<form:Event action="FindMainGrid" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Column>
			<form:Column name="blnk">
				<form:Blank name="blnk1"/>
			</form:Column>
		</form:Columns>
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_competencia">
					<form:FKInput required="1" enabled="0" xsize="80" length="80" label="Competencia" nvalue="#source:oi_competencia/@value" name="oi_competencia">
						<form:Helper name="NucleusRH.Base.Organizacion.Competencias.COMPETENCIA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.CVal}" id="{this.XVal}"/>
						</form:Helper>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" name="gcoln_ponderacion">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Ponderaci&#243;n" nvalue="#source:@n_ponderacion" name="n_ponderacion"/>
				</form:GColumn>
				<form:GColumn policy="NucleusRH/Base/Evaluacion/Evaluacion/Eval-num" name="gcoln_resultado">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Resultado Num&#233;rico" nvalue="#source:@n_resultado" name="n_resultado"/>
				</form:GColumn>
				<form:GColumn name="gcolc_nivel_resultado">
					<form:TextBox required="0" enabled="NEW|EDIT" descr="C&#243;digo de Nivel de competencia requerido." ysize="1" xsize="30" length="30" label="Nivel Resultado" nvalue="#source:@c_nivel_resultado" name="c_nivel_resultado"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Right width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsCOM_EVALU">
			<form:Link allowimg="1" policy="NucleusRH/Base/Evaluacion/Evaluacion/APT_COM/READ" visible="EDIT|SHOW|DELETE" descrip="Registra las Aptitudes evaluadas de un evaluado para una Competencia en particular." label="Aptitudes" name="APT_COM">
				<form:Event policy="NucleusRH/Base/Evaluacion/Evaluacion/APT_COM/EDIT" action="CALL:APT_COM" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
</form:Form>
