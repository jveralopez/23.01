<form:Form xmlns:form="nomad_engine.form" default_mode="FILTRO" doc="source" name="Nomad.Base.RecordCard.RecordCard.form">
	<form:Scripts>
		function Find()
{
	Ctrl("Registros").filter("",Ctrl("iter_search").GetCValue());
}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Label nowrap="1" label="Record Card de" style="S3 LCol_w" name="lbl_titulo"/>
				<form:Label nvalue="#FILTRO:@classDesc" nowrap="1" dynamic="1" style="S3 LCol_w" name="lbl_clase"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="90%">
		<form:Blank name="blank1"/>
		<form:RowAligner visible="0" name="sa22">
			<form:Row name="asdsadsad">
				<form:DateTime name="event-start-date" nvalue="#FILTRO:@eventStartDate" pattern="YYYYMMDD" required="1" enabled="FILTER" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton visible="FILTER" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#FILTRO:@eventEndDate" name="event-end-date" pattern="YYYYMMDD" required="1" enabled="FILTER" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton visible="FILTER" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Button startvalidate="1" label="Filtrar" name="FILTRAR" img="OK" descrip="Aplica el Filtro">
					<form:Event name="onclick" action="FILTRAR" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blank2"/>
		<form:Columns name="columns1a">
			<form:Column name="column1a" separation="2" align="center" valign="top">
				<form:TextBox label="Buscar" xsize="35" length="100" name="iter_search" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Column>
		</form:Columns>
		<form:Blank name="blank3"/>
		<form:ListView rows="-250" docname="RS" name="Registros" paging="1">
			<form:LVColumns>
				<form:LVColumn additional="dd/mm/yyyy HH:MM:SS" type="datetime" sorteable="1" name="f_evento" label="Fecha y Hora" attrname="f_evento"/>
				<form:LVColumn name="d_accion" attrname="d_accion" type="string" sorteable="1" label="Nombre"/>
				<form:LVColumn name="d_evento" attrname="d_evento" type="string" sorteable="1" label="Descripcion"/>
				<form:LVColumn name="d_motivo" attrname="d_motivo" type="string" sorteable="1" label="Motivo"/>
				<form:LVColumn name="d_usuario" attrname="d_usuario" type="string" sorteable="1" label="Usuario"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner2">
			<form:Row name="rowbottom">
				<form:Button name="Volver" label="Volver" img="BACK" descrip="Volver" note="Cancelar">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
