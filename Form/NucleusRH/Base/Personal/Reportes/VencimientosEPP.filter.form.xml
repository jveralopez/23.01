<form:Form xmlns:form="nomad_engine.form" doc="source" name="VencimientoEPP">
	<form:Title>
		<form:Label label="105 - Vencimientos de Elementos de Protecci&#243;n Personal" visible="" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo nvalue="#FILTERDATA:@oi_empresa" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:DateTime nvalue="#FILTERDATA:@f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#FILTERDATA:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl4123"/>
		<form:Grid width="480px" proto="&lt;PERSONA/&gt;" nvalue="#FILTERDATA:PERSONAS" idvalue="#SOURCEGRILLA:@id" doc="SOURCEGRILLA" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="4" descrip="" note="" name="grdPersonal">
			<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.LM.guia.flow" action="HELP">
				<helper-mess oi_empresa="{oi_empresa.ReadXValue}">
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Legajo" name="oi_personal_emp" nvalue="#SOURCEGRILLA:@id" length="30" xsize="15" enabled="" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess oi_empresa="{oi_empresa.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttons2" visible="FILTER">
			<form:Row name="row_top2">
				<form:Button startvalidate="1" img="ok" descrip="Generar Reporte" note="" label="Aceptar" name="btnAceptar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="Vuelve al menu principal sin ejecutar el formulario" note="Vuelve a la pantalla anterior" img="back" label="Volver" name="btnCAncelar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
