<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Personal.Reportes.Legajo">
	<flow:info label="Flow para NucleusRH.Base.Personal.Reportes.Legajo"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY"/>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_personal_emp="" chkDatosPersonales="1" chkDatosPrincipales="1" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#PARAMETERS:" mode="FILTER" form-class="NucleusRH.Base.Personal.Reportes.Legajo.filter.form"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<doc:set-attribute from-attr-path="#SOURCE:@VALUE" to-attr-path="#PARAMETERS:@oi_personal_emp"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="FILTER" form-class="NucleusRH.Base.Personal.Reportes.Legajo.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.Legajo.filter.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Personal.Reportes.Legajo.filter.form" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="PARAMETROS" text-path="#PARAMETERS:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Personal.Legajo.rpt" input-doc-path="#PARAMETERS:" out-file-path="#PARAMETERS:@report"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="REPORT" form-class="NucleusRH.Base.Personal.Reportes.Legajo.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action eq="" if="#PARAMETERS:@oi_personal_emp" action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.Legajo" doc-path="#PARAMETERS:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.Legajo" doc="PARAMETERS"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Personal.Reportes.Legajo.form:REPORT" doc="SOURCE" form-class="NucleusRH.Base.Personal.Reportes.Legajo.form" mode="REPORT">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
