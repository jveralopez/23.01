<form:Form xmlns:form="nomad_engine.form" name="LegajosClasesfilter" doc="source">
	<form:Title>
		<form:Label label="103 - Legajos por Organigrama" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl40" width="100%" visible=""/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="0" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl4123" width="100%" visible=""/>
		<form:Grid proto="&lt;PERSONA/&gt;" nvalue="#FILTERDATA:PERSONAS" width="480px" idvalue="#SOURCEGRILLA:@id" doc="SOURCEGRILLA" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="8" descrip="" note="" name="grdPersonal">
			<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.LM.guia.flow" action="HELP">
				<helper-mess oi_empresa="{oi_empresa.ReadXValue}">
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Empresa - Legajo" name="oi_personal_emp" nvalue="#SOURCEGRILLA:@id" length="30" xsize="15" enabled="" required="0">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess oi_empresa="{oi_empresa.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
