	<form:Scripts>
		function toggleAll(me)
{
	var col = me.m_Parent.m_Parent;
	
	if (me.GetXValue()=="0")
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("0");
			} catch(err){}
		}
	}
	else
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("1");
			} catch(err){}
		}
	}
}    

function onload()
{  
	if(Ctrl('img_ojo') != undefined)
	{
		if(!Ctrl('img_ojo').GetEnabled())
		{
			Ctrl('l_confidencial').SetXValue('0');
		} 
		else
		{
	 	   Ctrl('l_confidencial').SetXValue('1');
		}
	}
	
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
