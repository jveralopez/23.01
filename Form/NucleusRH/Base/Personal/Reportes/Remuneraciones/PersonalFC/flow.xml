<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.report.Crystal.flow" default_action="initialize" name="ReporteRemuneraciones_FC">
	<flow:info label="ReporteLicencias"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="" oi_estructura="" oi_empresa="" file-name="" batch-id="" f_des="" f_has="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="DDO_RESUL"/>
		<qry:define declare="&lt;FILTRO oi_clase_org=&quot;&quot; oi_estructura=&quot;&quot; oi_empresa=&quot;1&quot; file-name=&quot;&quot; batch-id=&quot;&quot; f_des=&quot;&quot; f_has=&quot;&quot; oi_categoria=&quot;&quot;&gt;&lt;PERSONAS /&gt;&lt;/FILTRO&gt;" name="PersonalFC">
			<qry:main doc="PARAM">
				<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
				<qry:insert-select name="filtro_empresa" doc-path="#FILTRO:"/>
			</qry:main>
			<qry:select doc="PARAM" name="filtro_empresa">
				<qry:xquery>
					for $r in table('
						select d_empresa from org03_empresas where oi_empresa= {#FILTRO:@oi_empresa}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="DATOS">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_empresa" name="d_empresa"/>
						<qry:insert-select name="QRY_DatosPersonas" doc-path="#FILTRO:"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_DatosPersonas" doc="PARAM" value="$r/@">
				<qry:xquery>
					for $r in table('


select 	PER02_PERSONAL_EMP.oi_empresa
	, e_numero_legajo 
	, d_ape_y_nom 
	, f_ingreso 
	, n_ult_remun
	, ORG04_PUESTOS.c_puesto
	, ORG04_PUESTOS.d_puesto
	, ORG04_POSICIONES.c_posicion
	, ORG04_POSICIONES.d_posicion
	, oi_posicion 
	, ORG04_PUESTOS.oi_puesto 
,n_sal_minimo_NS = ORG17_NIVELES_SAL.n_sal_minimo
,n_sal_maximo_NS = ORG17_NIVELES_SAL.n_sal_maximo
,n_sal_minimo_BS = ORG17_BANDAS_SAL.n_sal_minimo
,n_sal_maximo_BS = ORG17_BANDAS_SAL.n_sal_maximo
,n_Prom_BS = ORG17_BANDAS_SAL.n_sal_minimo + ORG17_BANDAS_SAL.n_sal_maximo / 2
, n_Prom_NS = ORG17_NIVELES_SAL.n_sal_minimo + ORG17_NIVELES_SAL.n_sal_maximo / 2
from PER02_PERSONAL_EMP ,
PER01_PERSONAL ,
ORG04_POSICIONES,
ORG04_PUESTOS, ORG17_NIVELES_SAL, ORG17_BANDAS_SAL
where PER01_PERSONAL.oi_personal = PER02_PERSONAL_EMP.oi_personal_emp
and   oi_posicion_ult  = ORG04_POSICIONES.oi_posicion
and   ORG17_NIVELES_SAL.oi_nivel_sal = ORG04_POSICIONES.oi_nivel_sal
and   oi_puesto_ult = ORG04_PUESTOS.oi_puesto 
and   ORG04_PUESTOS.l_convenio =1 
and   ORG04_PUESTOS.oi_banda_sal = ORG17_BANDAS_SAL.oi_banda_sal


{%? (string(#FILTRO:PERSONAS/PERSONA/@id)!='') 
																		{% AND PER02_PERSONAL_EMP.oi_personal_emp in ({%=string(#FILTRO:PERSONAS/PERSONA/@id) %}) 
																		%}
																  {% %}
																		%}


and		PER02_PERSONAL_EMP.oi_empresa = {%=#FILTRO:@oi_empresa%}    

')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PERSONAS_FC" value="#PARAM_P:@">
						<qry:attribute type="Nomad.NSystem.String" value="'pp'" name="pp"/>
						<qry:attribute type="Nomad.NSystem.String" value="#FILTRO:@oi_empresa" name="oi_empresa"/>
						<qry:attribute value="$r/@e_numero_legajo" name="e_numero_legajo" type="Nomad.NSystem.String"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
						<qry:attribute value="format_date($r/@f_ingreso,'dd/mm/yyyy')" type="Nomad.NSystem.String" name="f_ingreso"/>
						<qry:attribute value="$r/@n_ult_remun" name="n_ult_remun" type="Nomad.NSystem.String"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_posicion" name="oi_posicion"/>
						<qry:attribute value="$r/@n_sal_minimo_NS" name="n_sal_minimo_NS" type="Nomad.NSystem.String"/>
						<qry:attribute value="$r/@n_sal_maximo_NS" type="Nomad.NSystem.String" name="n_sal_maximo_NS"/>
						<qry:attribute value="$r/@n_sal_minimo_BS" name="n_sal_minimo_BS" type="Nomad.NSystem.String"/>
						<qry:attribute value="$r/@n_sal_maximo_BS" name="n_sal_maximo_BS" type="Nomad.NSystem.String"/>
						<qry:attribute value="$r/@n_Prom_BS" type="Nomad.NSystem.String" name="n_Prom_BS"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_puesto" name="oi_puesto"/>
						<qry:attribute name="c_puesto" value="$r/@c_puesto" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_posicion" value="$r/@c_posicion" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_posicion" value="$r/@d_posicion" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.Remuneraciones.PersonalFC.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.Remuneraciones.PersonalFC.filter.form:FILTER" form-class="NucleusRH.Base.Personal.Reportes.Remuneraciones.PersonalFC.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<submap path-docB="#B:PERSONAS" path-docA="#A:ctrl[@id='grdPersonal']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_personal_emp']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<PERSONA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTpdf" eq="PDF"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTxls" eq="XLS"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTrtf" eq="RTF"/>
		</flow:action>
		<flow:action name="ACCEPTpdf">
			<flow:log text-path="#FILTERDATA:" text="ppfilterdata"/>
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Personal.RemuneracionesFC\RemuneracionesFC.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTxls">
			<flow:log text-path="#FILTERDATA:" text="ppfilterdata"/>
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Personal.RemuneracionesFC\RemuneracionesFCXLS.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTrtf">
			<flow:log text-path="#FILTERDATA:" text="ppfilterdata"/>
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Personal.RemuneracionesFC\RemuneracionesFCRTF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
