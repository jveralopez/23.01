<form:Form xmlns:form="nomad_engine.form" extends="" name="NucleusRH.Base.Personal.Reportes.Remuneraciones.PersonalDC.filte" doc="source">
	<form:Title>
		<form:Label label="Seleccionar Filtro Reporte Remuneraciones Dentro de Convenio" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="85%">
		<form:Label name="lbl" label="Criterios de Busqueda" align="center" style="S3 LCol_g" visible=""/>
		<form:Blank name="bl1111" width="100px" visible=""/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
				<form:FKInput label="Convenio-Categoria" nvalue="#FILTERDATA:@oi_categoria" required="1" enabled="" xsize="15" length="30" name="oi_categoria">
					<form:STexts>
						<form:SText xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_categoria.Text.1}" id="{oi_categoria.XVal}" code="{oi_categoria.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Combo visible="211" nvalue="#FILTERDATA:@oi_convenio" flow="NucleusRH.Base.Organizacion.Convenios.CONVENIO.Combo.autoflow" label="Convenio" name="oi_convenio" action="COMBO" required="0" enabled=""/>
			</form:Column>
		</form:Columns>
		<form:Grid name="grdPersonal" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.GUIA_COMPLEJO.FLOW" action="HELP">
				<helper-mess>
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput required="0" enabled="" xsize="15" length="30" label="Personal" nvalue="#SOURCEGRILLA:oi_personal_emp/@value" name="oi_personal_emp">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Combo nvalue="#FILTERDATA:@FormatRPT" action="COMBO" required="1" flow="Nomad.Base.report.cboFormatRpt.enum" name="Formato" label="Formato del Reporte"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
