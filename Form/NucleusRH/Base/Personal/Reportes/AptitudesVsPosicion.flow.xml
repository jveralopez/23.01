<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Personal.Reportes.AptitudesVsPuesto">
	<flow:info label="Aptitudes vs Posici&#243;n"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMETERS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion" doc-path="#SOURCE:"/>
			<flow:call-action action="initialize"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion.filter.form:FILTER" form-class="NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion.filter.form" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Personal.AptitudesVsPosicion.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="002 - Aptitudes Personales Vs. Requisitos Posici&#243;n Laboral" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.AptitudesVsPosicion" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
</flow:flow>
