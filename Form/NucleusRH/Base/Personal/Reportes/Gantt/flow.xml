			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="f_desde" value="#SOURCE:FILTRO/@f_desde" type="Nomad.NSystem.Int"/>
					<qry:attribute name="f_hasta" value="#SOURCE:FILTRO/@f_hasta" type="Nomad.NSystem.Int"/>
					<qry:attribute name="oi_calendario" value="#SOURCE:FILTRO/@oi_calendario" type="Nomad.NSystem.Int"/>
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:FILTRO"/>
					<qry:element name="LICENCIAS">
						<qry:insert-select name="qry_split" doc-path="#SOURCE:FILTRO"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="qry_split" doc="PARAM">
				<qry:xquery>
					for $r in #PARAM:PERSONAS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="RS1" doc-path="$r"/>
					<!--qry:insert-element doc-path="$r"/-->
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="RS1">
				<qry:xquery>
					for $r in sql('		
		SELECT 
			PER02_PERSONAL_EMP.oi_personal_emp, 
			PER02_LICEN_PER.oi_licencia_per,			
			PER01_PERSONAL.d_ape_y_nom,
			PER02_PERSONAL_EMP.e_numero_legajo, 
			PER02_LICEN_PER.f_inicio,
			PER02_LICEN_PER.f_fin,
			PER16_LICENCIAS.c_licencia,
			ORG03_EMPRESAS.c_empresa			
		FROM 
			PER02_PERSONAL_EMP
			, PER01_PERSONAL
			, PER02_LICEN_PER
			, PER16_LICENCIAS
			, ORG03_EMPRESAS
		JOIN 
			PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
			, PER02_LICEN_PER.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp
			, PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
			, PER16_LICENCIAS.oi_licencia INNER PER02_LICEN_PER.oi_licencia
		WHERE        
			PER02_PERSONAL_EMP.oi_empresa = {#FILTRO:@empresa}   						
			AND PER02_LICEN_PER.f_inicio &gt;= {Datetime(#FILTRO:@f_desde)}
			AND PER02_LICEN_PER.f_fin &lt;= {Datetime(#FILTRO:@f_hasta)}									
			{%? (string(#PARAM:@VALUES)!='') {% AND PER02_LICEN_PER.oi_personal_emp in ({%=string(#PARAM:@VALUES) %}) %} {%  %} %}
			{%? (string(#FILTRO:CONC/C/@id)!='') {% AND PER02_LICEN_PER.oi_licencia in ({%=string(#FILTRO:CONC/C/@id) %}) %} {% %} %}	
			AND PER02_PERSONAL_EMP.oi_calendario_ult = {#FILTRO:@oi_calendario}
		 ORDER BY 
		 	c_empresa ASC, e_numero_legajo ASC,f_inicio DESC
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="LIC">
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="oi_licencia_per" value="$r/@oi_licencia_per"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="f_fin" value="$r/@f_fin"/>
						<qry:attribute name="c_licencia" value="$r/@c_licencia"/>
						<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="LICENCIAS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry qry="QRY_CONC" output-doc="CONC"/>
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.Gantt.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.Gantt.filter.form:FILTER" form-class="NucleusRH.Base.Personal.Reportes.Gantt.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:attach-doc attach-id="CONC" doc-path="#CONC:"/>
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.Gantt.form" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.Gantt.form" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:load-qry output-doc="LICENCIAS" input-doc-path="#SOURCE:" qry="LICENCIAS"/>
			<flow:log text="log_LICENCIAS" text-path="#LICENCIAS:"/>
			<flow:exec-method class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" priority="9" out-attr-path="#BATCHDOC:@batch-id" method="Datos_Gantt">
				<flow:param doc="LICENCIAS" mode="in" type="Nomad.NSystem.Object" name="licencias"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Gantt de Licencias" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
