<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" name="NucleusRH.Base.Personal.Reportes.Gantt.filter.form" doc="source">
	<form:Title>
		<form:Label label="Gantt de Licencias" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Combo name="oi_calendario" nvalue="#source:@oi_calendario" label="Calendario" required="1" flow="NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO.Combo.autoflow" action="COMBO"/>
				</form:Column>
				<form:Column label="Informaci&#243;n a mostrar" name="col2ext" valign="top" align="left">
					<form:TextBox xsize="35" length="100" name="iter_search" ysize="1" descr="Busca." X-POLICY="./FORM/NucleusRH/Base/Organizacion/Escalas/ESCALA/autoform/iter_search">
						<form:Event runat="client" name="onpressenter" action="Find"/>
						<form:SButtons>
							<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
								<form:Event runat="client" name="onclick" action="Find"/>
							</form:SButton>
						</form:SButtons>
					</form:TextBox>
					<form:ListView name="tipos_licencias" label="Tipos de Licencias" docname="CONC" arr-control="CONC" nvalue="#source:@selected" rows="4" width="300px">
						<form:LVColumns>
							<form:LVColumn visible="1" sorteable="1" label="coleccion" width="50%" name="coleccion" type="string" attrname="coleccion"/>
							<form:LVColumn label="Tipo de Licencia" width="50%" attrname="des" type="string" sorteable="1" name="des"/>
						</form:LVColumns>
						<form:SButtons>
							<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
								<form:Event action="FullCONC" name="OnClick" runat="client"/>
							</form:SButton>
							<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
								<form:Event action="ClearCONC" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:ListView>
					<form:HiddenArr nvalue="#source:CONC" proto="&lt;C /&gt;" name="CONC">
						<form:Attr name="id"/>
					</form:HiddenArr>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Find()
{        
Ctrl("tipos_licencias").filter("",Ctrl("iter_search").GetCValue());
}

function ClearCONC()
{
Ctrl("CONC").DelAllRow();
Ctrl("tipos_licencias").Refresh();
}

function FullCONC()
{            
Ctrl("CONC").DelAllRow();     
for (var t=0; t&lt;Ctrl("tipos_licencias").TotalRowsCount(); t++)
{
   Ctrl("CONC").AddRow().SetAttr("id", Ctrl("tipos_licencias").GetAttrValue(t, "id"));

}
	
Ctrl("tipos_licencias").Refresh();
}

function Ejecutar()
{	 
 	if (arrFILTER.length==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}
 	
 	if (Ctrl("CONC").CountRow()==0)
 	{		
 		alert("Debe seleccionar al menos un Concepto");
 	   	return false; 
 	}   
 
 FillArray(100);
 Ctrl("main").DoEvent("FILTER");	
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
