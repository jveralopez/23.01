<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Personal.Reportes.CredencialEmpleado.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.SJdeDios.Personal.Reportes.CredencialEmpleado"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.CredencialEmpleado.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.CredencialEmpleado.filter.form:FILTER" form-class="NucleusRH.Base.Personal.Reportes.CredencialEmpleado.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text-path="#SOURCE:" text="DENIS"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method priority="6" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" method="ExecReportFO">
				<flow:param value="NucleusRH.Base.Personal.CredencialEmpleado.CredencialEmpleado.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="010C - Credencial del Empleado" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="Nomad.base.batch.report.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-LegajoTrayectoria" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-LegajoTrayectoria" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
</flow:flow>
