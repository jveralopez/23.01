<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Personal.Reportes.CertificadoEmpleo.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Personal.Reportes.CertificadoEmpleo"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMS oi_personal_emp=""/>
		</doc:define>
		<doc:define name="DATOS">
			<FILTER oi_personal_emp="" oi_empresa="" f_constancia="" suscribe="" const_cargo=""/>
		</doc:define>
		<doc:define name="REPORT">
			<DATA empty-attr=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.ConstanciaCargo.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Personal.Reportes.ConstanciaCargo.filter.form" name="NucleusRH.Base.Personal.Reportes.ConstanciaCargo.filter.form:FILTER" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportFO" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param value="NucleusRH.Base.Personal.ConstanciaCargo.ConstanciaCargo.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Constancia de Cargo" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.ConstanciaCargo" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reportes.ConstanciaCargo" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
</flow:flow>
