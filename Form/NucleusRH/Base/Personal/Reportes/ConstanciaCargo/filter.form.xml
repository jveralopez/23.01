<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.Reportes.ConstanciaCargo.filter.form" doc="source">
	<form:Title>
		<form:Label label="Constancia de Cargo" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1"/>
		<form:Blank name="bl2"/>
		<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="35" mode="QRY" required="1" label="Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
		<form:TextBox required="1" xsize="60" label="Suscribe:" name="suscribe" nvalue="#source:@suscribe"/>
		<form:DateTime label="Fecha Constancia" name="f_constancia" nvalue="#source:@f_constancia" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:CheckBox label="Constancia Docente" name="const_cargo" nvalue="#source:@const_cargo">
			<form:Event action="valCargo" name="onClick" runat="client"/>
		</form:CheckBox>
		<form:CheckBox nvalue="#source:@const_empleo" name="const_empleo" label="Constancia de Empleo">
			<form:Event action="valEmpleo" name="onClick" runat="client"/>
		</form:CheckBox>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button label="Ejecutar" descrip="Ejecuta el Filtro" startvalidate="1" visible="" name="btnAceptar" img="play" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onLoad()
{
	if (Ctrl('const_cargo').GetXValue() == 0 &amp;&amp; Ctrl('const_empleo').GetXValue() == 0)
	{
		Ctrl('const_cargo').SetXValue(1)	
	}
}

function valCargo()
{
	if (Ctrl('const_cargo').GetXValue() == 1)
	{
		Ctrl('const_empleo').SetXValue(0);
	}
} 

function valEmpleo()
{
	if (Ctrl('const_empleo').GetXValue() == 1)
	{
		Ctrl('const_cargo').SetXValue(0);
	}
} 

	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
</form:Form>
