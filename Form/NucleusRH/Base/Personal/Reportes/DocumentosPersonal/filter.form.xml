<form:Form xmlns:form="nomad_engine.form" name="DocumentosPersonas" doc="source">
	<form:Title>
		<form:Label label="006 - Listado de Documentos" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center height="100%" width="100%">
		<form:Columns height="50%" width="40%" name="cols">
			<form:Column height="100%" width="100%" name="col" separation="2" align="center" valign="top">
				<form:Blank visible="" width="100%" name="bl1"/>
				<form:Label label="Criterios de B&#250;squeda" style="M1 LCol_g" align="center" visible="" name="lbl2"/>
				<form:Blank visible="" width="100%" name="bl1510"/>
				<form:Columns height="100%" width="100%" name="cols1">
					<form:Column name="col1" height="100%" width="100%" separation="2" align="right" valign="top">
						<form:ComboBox xsize="40" label="Empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" name="oi_empresa" mode="QRY"/>
						<form:CheckBox label="Solo Activos?" nvalue="#source:@l_incluir" name="l_incluir"/>
						<form:Blank name="bl151011" visible="" width="100%"/>
						<form:ListView label="Tipos de Documentos" name="Documentos" docname="DOC" arr-control="DOC" nvalue="#source:@selected" rows="8" width="450px">
							<form:LVColumns>
								<form:LVColumn label="Tipo Documento" width="100%" attrname="des" type="string" sorteable="1" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
									<form:Event action="FullDOC" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
									<form:Event action="ClearDOC" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr nvalue="#source:DOC" proto="&lt;C /&gt;" name="DOC">
							<form:Attr name="id"/>
						</form:HiddenArr>
					</form:Column>
				</form:Columns>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Documentos seleccionados">
					<form:Event action="Validar" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu principal" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		/*function Find()
{
	Ctrl("Documentos").filter("",Ctrl("iter_search").GetCValue());
}
*/
function ClearDOC()
{
	Ctrl("DOC").DelAllRow();
	Ctrl("Documentos").Refresh();
}

function FullDOC()
{
	Ctrl("DOC").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Documentos").TotalRowsCount(); t++)
		Ctrl("DOC").AddRow().SetAttr("id", Ctrl("Documentos").GetAttrValue(t, "id"));
	
	Ctrl("Documentos").Refresh();
} 

function Validar()
{
   if (Ctrl("DOC").CountRow()==0)
   		alert("Debe seleccionar al menos un Tipo de Documento");
   else  
   		return true;    
}
	</form:Scripts>
</form:Form>
