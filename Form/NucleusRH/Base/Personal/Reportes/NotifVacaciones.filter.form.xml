<form:Form xmlns:form="nomad_engine.form" name="vacac">
	<form:Title>
		<form:Label name="lbl" label="Notificaciones de Vacaciones" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:FKInput name="fkiEmpresa" nvalue="#source:@tipoDoc" value="#source/@tipoDoc_txt" required="1" label="Empresa" note="" descrip="" guia="" xsize="4" length="4">
			<form:STexts>
				<form:SText name="txt1" xsize="40"/>
			</form:STexts>
			<form:SButtons>
				<form:SButton enabled="" visible="" name="sbuscar" img="search" note="" descrip="Abre un formulario para selleccionar una determinada cantidad de liquidaciones"/>
			</form:SButtons>
		</form:FKInput>
		<form:TextBox name="txtPeriodo" nvalue="#source:@direcion" label="Periodo" length="100" xsize="15" ysize="1" note="" descrip="" enabled="" visible="" required="0">
			<form:SButtons/>
		</form:TextBox>
		<form:CheckBox name="chkReimprimir" nvalue="#persona/@activo" label="Reimprimir Notificaciones" note="" descrip="Indica si se desea mostrar pantallas ya impresas para reimprimir.">
			<form:SButtons/>
		</form:CheckBox>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" enabled="" visible="" img="ok" name="btnEjecutar" label="Aceptar" note="Ejecuta" descrip="">
					<form:Event action="EJECUTAR_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="">
					<form:Event action="VOLVER_CLICK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
