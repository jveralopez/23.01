<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="ListadoLicenciasfilter" doc="source">
	<form:Title>
		<form:Label label="107 - Licencias" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:ComboBox xsize="40" required="1" label="Empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" name="oi_empresa" mode="QRY"/>
				<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox mode="OPT" nvalue="#source:@notif" xsize="10" required="1" label="Notificadas" name="cbxNotificaciones">
					<options>
						<option text="Si" value="1"/>
						<option text="No" value="2"/>
						<option text="Todas" value="3"/>
					</options>
					<form:Opts/>
					<form:Opts/>
					<form:Opts/>
				</form:ComboBox>
				<form:CheckBox name="boolEnPeriodo" label="Ver s&#243;lo licencias inclu&#237;das dentro del periodo" required="1" nvalue="#source:@boolEnPeriodo"/>
				<form:Grid name="grdLicencias" proto="&lt;ROW/&gt;" nvalue="#DOC:ROWS" width="480px" idvalue="#SOURCEGRILLA:@id" doc="SOURCEGRILLA" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="8" descrip="" note="">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput label="Licencia" name="oi_licencia" nvalue="#SOURCEGRILLA:@id" length="30" xsize="15" enabled="" required="0">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Personal.Licencias.LICENCIA.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess oi_empresa="{oi_empresa.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="validarFechas" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function validarFechas()
{
	if(Ctrl("f_des").GetXValue()!="" &amp;&amp; Ctrl("f_has").GetXValue()!="" &amp;&amp; Ctrl("f_has").GetXValue()&lt;Ctrl("f_des").GetXValue())
		{
			Ctrl("f_des").SetFocus();
			alert("La Fecha Desde ingresada debe ser menor o igual a la Fecha Hasta.");
			return false;
		}		                  
	else
		return true;
}
	</form:Scripts>
</form:Form>
