<form:Form xmlns:form="nomad_engine.form" name="AptitudesVsPuesto" doc="source">
	<form:Title>
		<form:Label label="001 - Aptitudes Personales Vs. Requisitos Puesto" style="S3 LCol_w" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:FKInput name="oi_personal_emp" nvalue="#source:@oi_personal_emp" label="Empresa - Legajo" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.flow">
						<helper-mess code="{oi_personal_emp.CVal}" id="{oi_personal_emp.XVal}" text="{oi_personal_emp.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput label="Empresa - Puesto" name="oi_puesto" nvalue="#source:@oi_puesto" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.guia.autoflow">
						<helper-mess code="{oi_puesto.CVal}" id="{oi_puesto.XVal}" text="{oi_puesto.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
