<form:form xmlns:form="nomad_engine.form">

		<form:title>
			<form:label name="lbl" label="Panel de Ausentismos"  style="S3 LCol_w"/>
		</form:title>
<form:comment> INICIO CRITERIO DE BUSQUEDA </form:comment>

			<form:center>
					
				<form:Blank name="bl3" width="100%" visible=""/>

				<form:Grid name="grdPersonal"  				
								    note="" descrip="" 
								    rows="3"
								    allownew="FILTER" allowdel="FILTER" paging="1" enabled="">
								    
								  	<form:sbuttons>
												<form:sbutton 
													enabled="" visible=""
									        name="sbuscar" img="search"
									        note="" descrip="Abre un formulario para selleccionar una determinada cantidad de liquidaciones" >
								    		</form:sbutton>								    		
								    		<form:sbutton 
													enabled="" visible=""
									        name="sbuVaciar" img="eliminate"
									        note="" descrip="Elimina todos los registro" >
								    		</form:sbutton>
								  	</form:sbuttons>
											
								    <form:GColumns>
					
					    				<form:GColumn allow_order="0">
											<form:FKInput required="0" enabled="" xsize="15" length="30" label="Personal Empresa" nvalue="#source:oi_personal_emp/@value" name="oi_personal_emp">
										          <form:STexts>
										            	<form:SText xsize="50" />
										          </form:STexts>
										          <form:helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
										            <helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
										          </form:helper>
										          <form:sbuttons>
										            <form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
										              <form:event action="SHOW_HELPER" name="onclick" runat="client"/>
										            </form:SButton>
										          </form:sbuttons>
									       	 </form:FKInput>			        
					    				</form:GColumn>
								   	</form:GColumns>
						</form:Grid>

				<form:Blank name="b150" width="100%" visible=""/>

				<form:Columns name="rows1">
					<form:Column name="row1">

							<form:DateTime pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Desde" mask="dd/mm/yyyy" label="Fecha Desde" name="fecDesde">
			          <form:sbuttons>
			            <form:SButton descrip="" img="Calendar" label="Calendar" name="Calendar">
			              <form:event action="SHOW_HELPER" name="onclick" runat="client"/>
			            </form:SButton>
			          </form:sbuttons>
			        </form:DateTime>																									


							<form:DateTime pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Hasta" mask="dd/mm/yyyy" label="Fecha Hasta" name="fecHasta">
				          <form:sbuttons>
				            <form:SButton descrip="" img="Calendar" label="Calendar" name="Calendar">
				              <form:event action="SHOW_HELPER" name="onclick" runat="client"/>
				            </form:SButton>
				          </form:sbuttons>
				      </form:DateTime>							

					</form:Column>
				</form:Columns>

			</form:center>

<form:comment> MARCO INFERIOR DE LA PANTALLA - BOTONES </form:comment>
		<form:bottom>
			<form:RowAligner name="botonera" columns="3">
				<form:row name="fila6">
					<form:button enabled="" visible="" img="play"
    						name="btnEjecutar" label="Ejecutar" 
  						note="Ejecuta" descrip="" >
  						<form:event action="EJECUTAR_CLICK" name="onclick" runat="server"/>
					</form:button>	
	
					<form:Blank name="bl8" width="50%" visible=""/>
	
					<form:button enabled="" visible=""
    						name="btnVolver" label="Volver" img="back"
  						note="" descrip=""  >
  						<form:event action="BACK" name="onclick" runat="server"/>
					</form:button>
				</form:row>
			</form:RowAligner>
		</form:bottom>
	</form:form>	