<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.ConceptosSegunIG" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="106 - Beneficios de los Legajos" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="60%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Columns name="columns1">
			<form:Column name="col1">
				<form:Combo nvalue="#FILTERDATA:@oi_tipo_benef" action="COMBO" flow="NucleusRH.Base.Organizacion.Tipos_de_Beneficios.TIPO_BENEF.Combo.autoflow" required="0" enabled="" descr="Tipo de Beneficio al cual pertenece el Beneficio." label="Tipo Beneficio" name="oi_tipo_benef"/>
				<form:FKInput nvalue="#FILTERDATA:@oi_beneficio" required="0" enabled="" xsize="15" length="30" label="Beneficio" name="oi_beneficio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Beneficios.BENEFICIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime label="Fecha Desde" name="f_desde" nvalue="#FILTERDATA:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy hh:mm:ss">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#FILTERDATA:@f_hasta" label="Fecha Hasta" name="f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy hh:mm:ss">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
