<form:Form name="NucleusRH.Base.Personal.Reportes.Licencias.filter.form" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Seleccionar Filtro Reporte Licencias del Personal" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="85%">
		<form:Label name="lbl" label="Criterios de Busqueda" align="center" style="S3 LCol_g" visible=""/>
		<form:Blank name="bl1111" width="100px" visible=""/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy hh:mm:ss" label="Desde" nvalue="#FILTERDATA:@f_des" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy hh:mm:ss" label="Hasta" nvalue="#FILTERDATA:@f_has" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" required="1" enabled="" label="Clase" nvalue="#FILTERDATA:@oi_clase_org" name="oi_clase_org"/>
				<form:FKInput required="0" enabled="" xsize="15" length="30" label="Unidad Organizativa" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura">
					<form:STexts>
						<form:SText xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Grid name="grdPersonal" note="" descrip="" rows="8" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.ProcesarFichadas.PERSONAL_EMP.LM.guia.flow" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput required="0" enabled="" xsize="15" length="30" label="Personal" nvalue="#SOURCEGRILLA:oi_personal_emp/@value" name="oi_personal_emp">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:helper name="NucleusRH.Base.Tiempos_Trabajados.PERSONAL.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:helper>
						<form:sbuttons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:sbuttons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
