<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="CCLicenciasfilter" doc="source">
	<form:Title>
		<form:Label label="111 - Cuenta Corriente Licencias" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns width="650px" name="colums">
			<form:Column name="col43">
				<form:DateTime visible="0" nvalue="#source:@f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime visible="0" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="30" mode="QRY" required="1" label="Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="colums1">
			<form:Column width="100%" name="col2">
				<form:TextBox xsize="35" length="100" name="iter_search" ysize="1" descr="Busca." X-POLICY="./FORM/NucleusRH/Base/Organizacion/Escalas/ESCALA/autoform/iter_search">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Escalas/ESCALA/autoform/iter_search/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Escalas/ESCALA/autoform/iter_search"/>
					</form:Policies>
				</form:TextBox>
				<form:ListView rows="10" docname="LIC" arr-control="LIC" nvalue="#source:@selected" width="450px" label="Licencias" name="Licencias">
					<form:LVColumns>
						<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Licencia" name="des"/>
					</form:LVColumns>
					<form:SButtons>
						<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
							<form:Event action="FullLIC" name="OnClick" runat="client"/>
						</form:SButton>
						<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
							<form:Event action="ClearLIC" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:ListView>
				<form:HiddenArr nvalue="#source:LIC" proto="&lt;L /&gt;" name="LIC">
					<form:Attr name="id"/>
				</form:HiddenArr>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="Validar" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Find()
{
	Ctrl("Licencias").filter("",Ctrl("iter_search").GetCValue());
}

function ClearLIC()
{
	Ctrl("LIC").DelAllRow();
	Ctrl("Licencias").Refresh();
}

function FullLIC()
{
	Ctrl("LIC").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Licencias").TotalRowsCount(); t++)
		Ctrl("LIC").AddRow().SetAttr("id", Ctrl("Licencias").GetAttrValue(t, "id"));
	
	Ctrl("Licencias").Refresh();
}         

function Validar()
{
   if (Ctrl("LIC").CountRow()==0)
   		alert("Debe seleccionar al menos una Licencia");
   else  
   		return true;    
}
	</form:Scripts>
</form:Form>
