<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" name="NucleusRH.Base.Personal.Reportes.ListadoCursos.filter.form" doc="source">
	<form:Help/>
	<form:Title>
		<form:Label name="lbl_titulo" align="center" style="S3 LCol_w" label="008 - Listado de Cursos"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup collapse="1" width="90%" label="Criterios de selecci&#243;n particulares" nvalue="#source:@gcustom" name="vgroupDatosCustom">
			<form:Columns width="100%" name="colsext">
				<form:Column valign="top" align="left" name="col1ext" separation="1">
					<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:ComboBox label="Area de curso" required="0" xsize="40" nvalue="#source:@oi_curso" queryname1="NucleusRH.Base.Organizacion.Cursos.CURSO.INFO" name="oi_curso" mode="QRY"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup collapse="1" width="90%" nvalue="#source:@gpers" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT">
					<form:Event action="Guardar" runat="client" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT"/>
					</form:Policies>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK">
					<form:Event action="BACK" runat="server" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
