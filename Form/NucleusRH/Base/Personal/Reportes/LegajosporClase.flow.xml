<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Personal.Reportes.LegajosPorClase">
	<flow:info label="Legajos por Organigrama"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="" oi_empresa="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.LegajosporClase.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<flow:html-gen template-file="NucleusRH.Base.Personal.LegajosOrganigrama.rpt" input-doc-path="#SOURCE:" out-file-path="#SOURCE:@report"/>
			<flow:open-form form-class="NucleusRH.Base.Personal.Reportes.LegajosporClaseReport.form" mode="REPORT" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.LegajosporClase.filter.form:FILTER" form-class="NucleusRH.Base.Personal.Reportes.LegajosporClase.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Personal.LegajosOrganigrama.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="103 - Legajos por Organigrama" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosporClase" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosporClase" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Personal.Reportes.LegajosporClaseReport.form:REPORT" form-class="NucleusRH.Base.Personal.Reportes.LegajosporClaseReport.form" mode="REPORT" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form next-action="BACK"/>
		</flow:action>
	</flow:form>
</flow:flow>
