<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa">
	<flow:info label="Flow para NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMETERS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa.filter.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa.filter.form" mode="FILTER">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosPorEmpresa" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosPorEmpresa" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="emifilter"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Personal.LegajosPorEmpresa.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="102 - Listado de Legajos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
