function DescheckearTodos()
{
	marcar(0);
}
function CheckearTodos()
{
    marcar(1);
}
function marcar(marca)
{  
	Ctrl("chkCategoria").SetXValue(marca);
	Ctrl("chkCentroDeCosto").SetXValue(marca);
	Ctrl("chkContrato").SetXValue(marca);
	Ctrl("chkPuesto").SetXValue(marca);
	Ctrl("chkPosicion").SetXValue(marca);
	Ctrl("chkRemuneracion").SetXValue(marca);
	Ctrl("chkTipoPersonal").SetXValue(marca);
	Ctrl("chkCalendarios").SetXValue(marca);
	Ctrl("chkReingresos").SetXValue(marca);
	Ctrl("chkEquipoMovil").SetXValue(marca);  
	Ctrl("chkCargos").SetXValue(marca);      
	Ctrl("chkUbicaciones").SetXValue(marca);
}
                   
