<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Personal.EntregaUniforme.flow">
	<flow:info label="NucleusRH.Base.Personal.EntregaUniforme"/>
	<flow:declare>
		<doc:define name="PARAMS">
			<DATOS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.EntregaUniforme.CONSULTA.form" mode="NEW" doc-path="#PARAMS:"/>
		</flow:action>
	</flow:main>
	<flow:form doc="SOURCE" parent-doc="PARENTSOURCE" name="NucleusRH.Base.Personal.EntregaUniforme.CONSULTA.form:NEW" form-class="NucleusRH.Base.Personal.EntregaUniforme.CONSULTA.form" mode="NEW">
		<flow:action name="SAVE">
			<flow:exec-method class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" method="EntregaUniforme">
				<flow:param doc="PARAMS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
			</flow:exec-method>
			<flow:call-action action="cleanDOC"/>
			<flow:call-action action="msg"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="msg">
			<flow:log text-path="#PARAMS:" text="EMIPARAMS"/>
			<flow:message message="La entrega fue registrada correctamente"/>
		</flow:action>
		<flow:action name="cleanDOC">
			<doc:set-attribute to-attr-path="#SOURCE:@oi_personal_emp"/>
			<doc:set-attribute to-attr-path="#SOURCE:@oi_uniforme"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_desde"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_hasta"/>
			<doc:set-attribute to-attr-path="#SOURCE:@e_cantidad"/>
			<doc:set-attribute to-attr-path="#SOURCE:@oi_mot_entrega"/>
		</flow:action>
	</flow:form>
</flow:flow>
