<flow:flow extends="NucleusRH.Base.Personal.AFJP.AFJP.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Personal.AFJP.AFJP.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Personal.AFJP.AFJP"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define declare="&lt;helper-mess code=&quot;00&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER03_AFJP.oi_afjp as ID, PER03_AFJP.c_afjp AS CODE, PER03_AFJP.d_afjp AS TEXT,
				PER03_AFJP.d_interfaz
				FROM PER03_AFJP 
				WHERE PER03_AFJP.c_afjp ={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}
        AND ISNULL(PER03_AFJP.f_inactivo)
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@d_interfaz" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER03_AFJP.oi_afjp as ID, PER03_AFJP.c_afjp AS CODE, PER03_AFJP.d_afjp AS TEXT,
				PER03_AFJP.d_interfaz
				FROM PER03_AFJP 
				WHERE ISNULL(PER03_AFJP.f_inactivo)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_interfaz" name="interface"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="X2C" declare="&lt;helper-mess id=&quot;1&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT t.oi_afjp as ID, t.c_afjp as CODE, t.d_afjp as TEXT, SEC.policy,
			t.d_interfaz
			FROM PER03_AFJP as t, NMD_SECURITY(class=\'NucleusRH.Base.Personal.AFJP.AFJP\') as SEC JOIN t.oi_afjp LEFT OUTER SEC.id  
			WHERE t.oi_afjp={#SOURCE:helper-mess/@ID} ORDER BY CODE asc'
			)/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@d_interfaz" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
