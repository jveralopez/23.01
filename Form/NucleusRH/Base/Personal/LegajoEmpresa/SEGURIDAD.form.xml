<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.LegajoEmpresa.SEGURIDAD.form" extends="nomad.childIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Asignar Estructura de Seguridad" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
				<form:Label label="Asignar Estructura de Seguridad" nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT"/>
				<form:Label label="Eliminar Estructura de Seguridad" nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" name="GEN_DEL"/>
				<form:Label label="Consultar Estructura de Seguridad" nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#source:../../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="blank_rowList"/>
		<form:RowAligner visible="0" name="buttonlinks"/>
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsRESPONSABLE">
			<form:Column name="main_columnsRESPONSABLEcolumn1">
				<form:FKInput enabled="EDIT|NEW" nvalue="#ESTRSEG:@oi_estructura" name="oi_estructura" required="0" xsize="15" length="30" label="Estructura Organizativa">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" oi_clase_org="{oi_clase_org.XVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#ORGSEG:@oi_clase_org" name="oi_clase_org"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row2">
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
			<form:Row visible="0" name="row1"/>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
