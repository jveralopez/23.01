<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.UBICACION_PER.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.LegajoEmpresa.UBICACION_PER">
	<form:Help>
		<form:Help-title text="Trayectoria Ubicaciones Por Legajo" name="TITLE"/>
		<form:Help-descr text="Contiene las trayectorias de los legajos por distintas ubicaciones" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Center width="95%">
		<form:Columns visible="0" name="main_columnsUBICACION_PER"/>
		<form:Columns name="main_columnsUBICACION_PER2" visible="SHOW|EDIT|DELETE|NEW">
			<form:Column name="main_columnsUBICACION_PERcolumn1">
				<form:Hidden descrip="" note="" nvalue="#DDO:oi_empresa/@value" name="oi_empresa"/>
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
				<form:ComboBox enabled="NEW" prev="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" xsize="40" mode="QRY" required="1" label="Ubicaci&#243;n" nvalue="#source:oi_ubicacion/@value" name="oi_ubicacion"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW" mask="dd/mm/yyyy" label="Fecha Desde" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Hasta" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Motivo Cambio" nvalue="#source:oi_motivo_cambio/@value" name="oi_motivo_cambio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.Motivos_Cambio.MOTIVO_CAMBIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_cambio_ubic" name="o_cambio_ubic"/>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event name="onclick" action="ONLOAD" runat="client"/>
			<form:LVColumns>
				<form:LVColumn visible="0" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.Motivos_Cambio.MOTIVO_CAMBIO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Motivo Cambio" attrname="oi_motivo_cambio" name="oi_motivo_cambio"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Event name="onload" action="ONLOAD" runat="client"/>
	<form:Scripts>
		function ONLOAD()
{
	if (Ctrl('main').GetMode() == 'NEW')
		return;
	
	var ult = 0;
	if (Ctrl('LIST'))
	{
		if (Ctrl('LIST').GetXValue() == Ctrl('LIST').GetAttrValue(Ctrl('LIST').TotalRowsCount()-1, 'id'))
		{
			ult = 1;
		}
	}	
	else
	{
		if (Ctrl('iter-position').GetXValue() == Ctrl('iter-size').GetXValue())
		{
			ult = 1;
		}
	}
	
	
	CtrlEnabled('f_hasta', false);
	CtrlEnabled('oi_motivo_cambio', false);
	CtrlEnabled('o_cambio_ubic', false);
	CtrlEnabled('DELETE', false);
	
	if (ult == 1)
	{
		CtrlEnabled('f_hasta', true);
		CtrlEnabled('oi_motivo_cambio', true);
		CtrlEnabled('o_cambio_ubic', true);
		CtrlEnabled('DELETE', true);
	}
}
	</form:Scripts>
</form:Form>
