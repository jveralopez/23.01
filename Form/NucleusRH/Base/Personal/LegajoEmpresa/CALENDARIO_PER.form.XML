<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.LegajoEmpresa.CALENDARIO_PER.form" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="NucleusRH.Base.Personal.LegajoEmpresa.CALENDARIO_PER.autoform">
	<form:Center width="95%">
		<form:Columns name="main_columnsCALENDARIO_PER" visible="0"/>
		<form:Columns name="main_columnsCALENDARIO_PER1" visible="SHOW|EDIT|NEW">
			<form:Column name="main_columnsCALENDARIO_PERcolumn2">
				<form:FKInput name="oi_calendario1" nvalue="#source:oi_calendario/@value" label="Calendario" length="30" xsize="15" enabled="NEW|REINGRESAR" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO.Guia.flow">
						<helper-mess oi_empresa="{oi_empresa.XValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" visible="NEW|REINGRESAR" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime name="f_desde" nvalue="#source:@f_desde" label="Fecha Desde" mask="dd/mm/yyyy" enabled="NEW" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="NEW" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo name="oi_calendario" nvalue="#source:oi_calendario/@value" label="Calendario" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO.Combo.autoflow" visible="NUNCA" action="COMBO"/>
				<form:Hidden descrip="" note="" nvalue="#DDO:oi_empresa/@value" name="oi_empresa"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Hasta" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Motivo Cambio" nvalue="#source:oi_motivo_cambio/@value" name="oi_motivo_cambio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.Motivos_Cambio.MOTIVO_CAMBIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_cambio_calend" name="o_cambio_calend"/>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ONLOAD" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1" visible="NEW">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Personal/LegajoEmpresa/CALENDARIO_PER/NEW" visible="EDIT|LIST_EDIT" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro" note="Agregar el Registro">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Personal/LegajoEmpresa/CALENDARIO_PER/DELETE" visible="EDIT|LIST_EDIT" mess="&#191;Est&#225; seguro que desae eliminar el registro?" name="DELETE" label="Eliminar" img="del" descrip="Eliminar el Registro" note="Eliminar el Registro">
					<form:Event runat="server" name="onclick" action="DELETE"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario" visible="NEW">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|DELETE|EDIT|LIST_EDIT" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|DELETE|EDIT|LIST_EDIT" name="PARENT" label="Ir al Raiz" img="back" descrip="Volver a la pantalla Raiz" note="Vuelve a la pantalla raiz del formulario" startvalidate="1">
					<form:Event action="PARENT" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ONLOAD()
{
	if (Ctrl('main').GetMode() == 'NEW')
		return;
	
	var ult = 0;
	if (Ctrl('LIST'))
	{
		if (Ctrl('LIST').GetXValue() == Ctrl('LIST').GetAttrValue(Ctrl('LIST').TotalRowsCount()-1, 'id'))
		{
			ult = 1;
		}
	}	
	else
	{
		if (Ctrl('iter-position').GetXValue() == Ctrl('iter-size').GetXValue())
		{
			ult = 1;
		}
	}
	
	
	CtrlEnabled('oi_motivo_cambio', false);
	CtrlEnabled('f_hasta', false);
	CtrlEnabled('o_cambio_calend', false);
	CtrlEnabled('DELETE', false);
	
	if (ult == 1)
	{
		CtrlEnabled('oi_motivo_cambio', true);
		CtrlEnabled('f_hasta', true);
		CtrlEnabled('o_cambio_calend', true);
		CtrlEnabled('DELETE', true);
	}
}
	</form:Scripts>
	<form:Event name="onload" action="ONLOAD" runat="client"/>
</form:Form>
