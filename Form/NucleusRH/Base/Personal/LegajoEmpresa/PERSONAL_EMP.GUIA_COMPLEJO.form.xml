<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.LM.guia" doc="SOURCE">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label label="Selecci&#243;n de Legajos" nowrap="1" name="GEN" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo nvalue="#SOURCE:@oi_empresa" name="oi_empresa" label="Empresa" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO">
					<form:Event action="DisableControls" runat="client" name="onchange"/>
				</form:Combo>
				<form:Blank name="blnk1"/>
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Column>
		</form:Columns>
		<form:Grid rows="10" name="GRID" nvalue="#RS:" idvalue="#SOURCE:@id" doc="SOURCE" paging="1" allownew="0" allowdel="0">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:CheckBox name="check" nvalue="#SOURCE:@check" label="" enabled="" required="0"/>
				</form:GColumn>
				<form:GColumn name="col2" allow_order="1">
					<form:TextBox name="e_numero_legajo" nvalue="#SOURCE:@code" label="Legajo" length="30" xsize="15" ysize="1" enabled="NEW|EDIT" required="1"/>
				</form:GColumn>
				<form:GColumn name="col3" allow_order="1">
					<form:TextBox name="d_ape_y_nom" nvalue="#SOURCE:@text" label="Apellido y Nombre" length="100" xsize="40" ysize="1" enabled="NEW|EDIT" required="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}

function LoadForm()
{	
	if (Ctrl('oi_empresa').GetXValue() !='')
	{		
		CtrlEnabled('oi_empresa', false);				
	}
	/*else
	{
		if (Ctrl('GRID').TotalRowsCount() &gt; 0)
		{
			Ctrl('GRID').Clear();
		}
	} */
}

function DisableControls()
{	
	if (Ctrl('oi_empresa').GetXValue() !='')
	{		
		CtrlEnabled('oi_empresa', false);
		Ctrl('main').DoEvent('QryServer');
	}
}
	</form:Scripts>
	<form:Event action="QRY" name="QryServer" runat="server"/>
	<form:Event action="LoadForm" name="onload" runat="client"/>
</form:Form>
