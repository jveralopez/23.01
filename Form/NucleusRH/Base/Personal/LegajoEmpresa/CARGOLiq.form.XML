<form:Form xmlns:form="nomad_engine.form" default_mode="new" doc="source" extends="NucleusRH.Base.Personal.LegajoEmpresa.CARGO.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" name="NucleusRH.Base.Personal.LegajoEmpresa.CARGOLiq">
	<form:Help/>
	<form:Scripts>
		function CALL_VAREF_CARGO()
{
	set_oi();
	Ctrl('main').DoEvent('CALL:VAREF_CARGO');
}

function CALL_VARPA_CARGO()
{
	set_oi();
	Ctrl('main').DoEvent('CALL:VARPA_CARGO');
}   

function set_oi()
{
	if (Ctrl('LIST'))
		Ctrl('oi').SetXValue(Ctrl('LIST').GetXValue());
	else
		Ctrl('oi').SetXValue(Ctrl('oi_cargo').GetXValue());
}          

function Guardar()
{
	if(Ctrl("f_ingreso_ant").GetXValue() &gt;= Ctrl("f_ingreso").GetXValue())
	{
		alert("La fecha de ingreso del nuevo cargo, debe ser posterior a la fecha de ingreso del cargo seleccionado");
		return false;
	}             
	else
	{
		return true;
	}
}

function onLoadCus()
{
	if(Ctrl("main").GetMode() == "NEW")
	{
		Ctrl("f_ingreso").SetXValue("");
		Ctrl("e_cargo").SetXValue("");
		Ctrl("f_egreso").SetXValue("");
	}
}
	</form:Scripts>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Cargo" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Cargo" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Cargo" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Cargo" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right width="200px">
		<form:VGroup visible="SHOW|LIST" name="vgChildsCARGOdep" label="Dependencias" background="1" collapse="1" width="100%">
			<form:Link visible="SHOW|LIST" name="VAL_VAREF" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/VAL_VAREF/EDIT" descrip="Valores de Variables Fijas del Cargo" label="Datos Fijos">
				<form:Event action="CALL:VAREF_CARGO" runat="server" name="onclick"/>
			</form:Link>
			<form:Link label="Acumuladores por Periodo" visible="SHOW|LIST" name="VAL_VARPA" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/VAL_VAREA/EDIT" descrip="Valores de Acumuladores del Cargo">
				<form:Event action="CALL:VARPA_CARGO" runat="server" name="onclick"/>
			</form:Link>
		</form:VGroup>
		<form:VGroup name="vgChildsCARGO" background="1" label="Acciones" collapse="1" width="100%" order-change="POST:vg_ChildsCARGOdep">
			<form:Link visible="SHOW|LIST" name="VAL_VAREF_EDIT" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/VAL_VAREF/EDIT" descrip="Valores de Variables Fijas del Cargo" label="Editar Datos Fijos">
				<form:Event action="CALL_VAREF_CARGO" runat="client" name="onclick"/>
			</form:Link>
			<form:Link visible="SHOW|LIST" name="VAL_VARPA_EDIT" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/VAL_VAREA/EDIT" descrip="Valores de Acumuladores del Cargo" label="Editar Acum. Periodo">
				<form:Event action="CALL_VARPA_CARGO" runat="client" name="onclick"/>
			</form:Link>
			<form:Link visible="SHOW|LIST" name="CAMBIO_CARGO" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/VAL_VAREF/EDIT" descrip="Cambio de Cargo" label="Cambio de Cargo">
				<form:Event action="CHANGE" runat="server" name="onclick"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCARGO">
			<form:Column name="main_columnsCARGOcolumn1"/>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns/>
		</form:ListView>
		<form:Hidden visible="EDIT|SHOW|LIST_EDIT" nvalue="#source:@id" name="oi_cargo"/>
		<form:Hidden name="oi"/>
		<form:Hidden name="oi_personal_emp" nvalue="#DDO:@id"/>
		<form:Hidden name="id_ant" nvalue="#CARGO_ANT:@id" order-change="PREV:main_columnsCARGO"/>
		<form:Hidden nvalue="#CARGO_ANT:@f_ingreso" name="f_ingreso_ant" order-change="PREV:main_columnsCARGO"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="NEW" startvalidate="1" descrip="Guardar" img="save" label="Guardar" name="GUARDAR" order-change="PREV:CANCEL">
					<form:Event action="Guardar" name="onClick" runat="client"/>
					<form:Event action="GUARDAR" name="onClick" runat="server"/>
				</form:Button>
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1" visible="0">
					<form:Event action="ACCEPT" name="onClick" runat="client"/>
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="CALL:VAREF_CARGO" name="CALL:VAREF_CARGO" runat="extern">
		<form:helpper action="initialize" name="NucleusRH.Base.Liquidacion.Variables.VariablesFiCargo.flow" clientaction="refresh">
			<DATA oi="{oi.XValue}" oi_personal_emp="{oi_personal_emp.XValue}"/>
		</form:helpper>
	</form:Event>
	<form:Event action="CALL:VARPA_CARGO" name="CALL:VARPA_CARGO" runat="extern">
		<form:helpper action="initialize" name="NucleusRH.Base.Liquidacion.Variables.VariablesAPCargo.flow" clientaction="refresh">
			<DATA oi="{oi.XValue}" oi_personal_emp="{oi_personal_emp.XValue}"/>
		</form:helpper>
	</form:Event>
	<form:Event action="onLoadCus" name="onLoad" runat="client"/>
</form:Form>
