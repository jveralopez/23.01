<form:Form default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.LegajoEmpresa.LICENCIA_PER" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Interrumpir Licencia del Personal" name="GEN_NEW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsLICENCIA_PER">
			<form:Column name="main_columnsLICENCIA_PERcolumn1">
				<form:FKInput enabled="0" required="1" xsize="15" length="30" label="Licencia" nvalue="#source:oi_licencia/@value" name="oi_licencia">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.Licencias.LICENCIA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" descr="Fecha de Inicio de Licencia." mask="dd/mm/yyyy" label="Fecha Inicio" nvalue="#source:@f_inicio" name="f_inicio">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha de Inicio de Licencia." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" descr="Fecha de Finalizaci&#243;n de la Licencia." mask="dd/mm/yyyy" label="Fecha Fin" nvalue="#source:@f_fin" name="f_fin">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha de Finalizaci&#243;n de la Licencia." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox required="0" enabled="0" descr="Cantidad de D&#237;as de Licencia." mask="###.###.##0" xsize="12" label="Cantidad D&#237;as" nvalue="#source:@e_cant_dias" name="e_cant_dias"/>
				<form:Line width="100%" name="linea1"/>
				<form:DateTime pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Interrupci&#243;n" nvalue="#source:@f_interrupcion" name="f_interrupcion">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="f_interr_validate" name="onValidate" runat="client"/>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Aceptar la Fecha de Interrupcion" img="OK" name="ACCEPT" visible="SHOW" label="Aceptar">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la Operacion" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function f_interr_validate(myThis)
{
	if (myThis.GetXValue() &lt; Ctrl('f_inicio').GetXValue())
	{
		myThis.SetError("La fecha de Interrupcion debe ser mayor o igual a la fecha de Inicio.");
		return false;
	}
	if (myThis.GetXValue() &gt;= Ctrl('f_fin').GetXValue())
	{
		myThis.SetError("La fecha de Interrupcion debe ser menor a la fecha de Fin.");
		return false;
	}

	return true;
}
	</form:Scripts>
</form:Form>
