<form:Form xmlns:form="nomad_engine.form" default_mode="EDIT" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="NucleusRH.Base.Personal.LegajoEmpresa.CARGO.autoform" doc="source" name="NucleusRH.Base.Personal.LegajoEmpresa.CARGO">
	<form:Help/>
	<form:Scripts>
		function calc_hspago() {
	var valor = Ctrl('n_hscatedra').GetXValue() != '' ? str2number(Ctrl('n_hscatedra').GetXValue()) : 0;
	if (Ctrl('l_anualizada').GetCValue() == '1' &amp;&amp; Ctrl('c_cuatrimestre').GetXValue() != 'A')
		valor /= 2;
	Ctrl('n_hspago').SetCValue(valor != 0 ? valor : '');
}
	</form:Scripts>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Cargo" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Cargo" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Cargo" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Cargo" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsCARGO">
			<form:Link visible="EDIT|SHOW|LIST|LIST_EDIT|DELETE" allowimg="1" policy="NucleusRH/Base/Personal/LegajoEmpresa/LICENCIA_CARGO/READ" label="Licencia de Cargo" name="LICEN_CARGO">
				<form:Event policy="NucleusRH/Base/Personal/LegajoEmpresa/LICENCIA_CARGO/EDIT" action="CALL:LICENCIA_CARGO" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Hidden nvalue="#DDO:oi_empresa/@value" name="oi_empresa" order-change="PREV:main_columnsCARGO"/>
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCARGO">
			<form:Column name="main_columnsCARGOcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
				<form:NumberBox required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Nro de Cargo" nvalue="#source:@e_cargo" name="e_cargo"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Ingreso" nvalue="#source:@f_ingreso" name="f_ingreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Egreso" nvalue="#source:@f_egreso" name="f_egreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO" queryname1="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO" xsize="30" mode="QRY" required="1" enabled="NEW|EDIT" label="Convenio - Categor&#237;a" nvalue="#source:oi_categoria/@value" name="oi_categoria"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.GruposCosto.GRUPO_COSTO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Grupo Costo" nvalue="#source:oi_grupo_costo/@value" name="oi_grupo_costo"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" xsize="30" mode="QRY" required="1" enabled="NEW|EDIT" label="Ubicaci&#243;n" nvalue="#source:oi_ubicacion/@value" name="oi_ubicacion"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Horas Trabajo" nvalue="#source:@n_hstrabajo" name="n_hstrabajo"/>
				<form:NumberBox label="Horas Pago (C&#225;lculo autom&#225;tico)" required="0" enabled="0" mask="###.###.##0.00" xsize="15" precision="3" nvalue="#source:@n_hspago" name="n_hspago"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Sueldo B&#225;sico" nvalue="#source:@n_basico" name="n_basico"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.Sindicatos.SINDICATO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Sindicato" nvalue="#source:oi_sindicato/@value" name="oi_sindicato"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Afiliado al sindicato?" nvalue="#source:@l_afiliado_sind" name="l_afiliado_sind"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Orden" nvalue="#source:@e_orden" name="e_orden"/>
				<form:Line order-change="PREV:oi_materia" name="line_materia"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.Materias.MATERIA.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Materia" nvalue="#source:oi_materia/@value" name="oi_materia"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" enabled="NEW|EDIT" label="Cuatrimestre" nvalue="#source:@c_cuatrimestre" name="c_cuatrimestre">
					<options>
						<option text="1er Cuatrimestre" value="1"/>
						<option text="2do Cuatrimestre" value="2"/>
						<option text="Anual" value="A"/>
					</options>
					<form:Event action="calc_hspago" name="onchange" runat="client"/>
				</form:ComboBox>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="Comisi&#243;n" nvalue="#source:@c_comision" name="c_comision"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" enabled="NEW|EDIT" label="A&#241;o de Estudios" nvalue="#source:@e_anio" name="e_anio">
					<options>
						<option text="1&#176;" value="1"/>
						<option text="2&#176;" value="2"/>
						<option text="3&#176;" value="3"/>
						<option text="4&#176;" value="4"/>
						<option text="5&#176;" value="5"/>
					</options>
				</form:ComboBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Horas C&#225;tedra" nvalue="#source:@n_hscatedra" name="n_hscatedra">
					<form:Event action="calc_hspago" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Anualizada?" nvalue="#source:@l_anualizada" name="l_anualizada">
					<form:Event action="calc_hspago" name="onclick" runat="client"/>
				</form:CheckBox>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_cargo" name="o_cargo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Ingreso" attrname="f_ingreso" name="f_ingreso"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Egreso" attrname="f_egreso" name="f_egreso"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Convenio - Categor&#237;a" attrname="oi_categoria" name="oi_categoria"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Materia" attrname="oi_materia" name="oi_materia"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Ubicaci&#243;n" attrname="oi_ubicacion" name="oi_ubicacion"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Grupo Costo" attrname="oi_grupo_costo" name="oi_grupo_costo"/>
				<form:LVColumn additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Horas Trabajo" attrname="n_hstrabajo" name="n_hstrabajo"/>
				<form:LVColumn additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Horas C&#225;tedra" attrname="n_hscatedra" name="n_hscatedra"/>
				<form:LVColumn additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Sueldo B&#225;sico" attrname="n_basico" name="n_basico"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="40px" type="string" label="Sindicato" attrname="oi_sindicato" name="oi_sindicato"/>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Afiliado al sindicato?" attrname="l_afiliado_sind" name="l_afiliado_sind"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Orden" attrname="e_orden" name="e_orden"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="EDIT|LIST_EDIT" policy="NucleusRH/Base/Personal/LegajoEmpresa/CARGO/NEW" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="EDIT|LIST_EDIT" mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Personal/LegajoEmpresa/CARGO/DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
