<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.LegajoEmpresa.LM" extends="Nomad.multiple.guia.form" doc="SOURCE">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" nowrap="1" label="Seleccion de Multiples Legajos" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Grid name="GRID" nvalue="#SOURCE:" idvalue="#SOURCE:@id" doc="SOURCE" rows="8" paging="1" allownew="0" allowdel="0">
			<form:GColumns>
				<form:GColumn allow_order="1" name="col2">
					<form:TextBox name="e_numero_legajo" nvalue="#SOURCE:@code" label="Legajo" length="30" xsize="15" ysize="1" enabled="NEW|EDIT" required="1"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col3">
					<form:TextBox name="d_ape_y_nom" nvalue="#SOURCE:@text" label="Apellido y Nombre" length="100" xsize="40" ysize="1" enabled="NEW|EDIT" required="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
</form:Form>
