<flow:flow extends="Nomad.Base.flow" name="NucleusRH.Base.Personal.LegajoEmpresa.interface.flow" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow">
	<flow:info label="Flow para NucleusRH.Base.Personal.LegajoEmpresa"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAM EMPRESA=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="NucleusRH.Base.Personal.LegajoEmpresa.Interface" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Personal.LegajoEmpresa.Interface.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.LegajoEmpresa.Interface.form:SHOW" mode="SHOW" form-class="NucleusRH.Base.Personal.LegajoEmpresa.Interface.form" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EXECUTE">
			<flow:save-user-data name="NucleusRH.Base.Personal.LegajoEmpresa.Interface" doc-path="#FILTERDATA:"/>
			<flow:exec-method class="NucleusRH.Base.Personal.InterfacePersonal.PERSONAL" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id" method="ImportarLegajos">
				<flow:param attr-path="#SOURCE:@EMPRESA" mode="in" name="oi_empresa" type="Nomad.NSystem.Int"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
