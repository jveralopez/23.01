<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.Legajo_Empresa.PERSONAL_EMP.guia" doc="SOURCE" extends="Nomad.parent.guia.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" label="Seleccion de Legajos por Empresa" style="S3 LCol_w" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo name="oi_empresa" nvalue="#SOURCE:@PARENTID" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO">
					<form:Event name="onchange" action="RELOAD_QUERY" runat="server"/>
				</form:Combo>
			</form:Column>
		</form:Columns>
		<form:FKInput name="PARENTID" nvalue="" label="Empresa" length="30" xsize="15" visible="NUNCA" required="0">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.flow">
				<helper-mess code="{PARENTID.CVal}" id="{PARENTID.XVal}" text="{PARENTID.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event name="onReceiveData" action="RELOAD_QUERY" runat="server"/>
		</form:FKInput>
	</form:Center>
</form:Form>
