<form:Form extends="NucleusRH.Base.Personal.Legajo.AFJP_PER.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.Legajo.AFJP_PER" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:Columns name="main_columnsAFJP_PER">
			<form:Column name="main_columnsAFJP_PERcolumn1">
				<form:NumberBox name="oi_personal" nvalue="#source:@oi_personal" label="OID Personal" xsize="12" mask="###.###.##0" enabled="NEW|EDIT" required="1" visible="0"/>
				<form:DateTime name="f_ingreso" nvalue="#source:@f_ingreso" label="Fecha Ingreso" mask="dd/mm/yyyy" descr="Fecha de Ingreso a la AFJP." enabled="NEW" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Ingreso a la AFJP." visible="EDIT|NEW">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime visible="EDIT|SHOW" enabled="0" name="f_egreso" nvalue="#source:@f_egreso" label="Fecha Egreso" mask="dd/mm/yyyy" descr="Fecha de Egreso de la AFJP." required="0" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Egreso de la AFJP." visible="EDIT|NEW">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:FKInput required="1" enabled="NEW" xsize="15" length="30" label="AFJP" nvalue="#source:oi_afjp/@value" name="oi_afjp">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.AFJP.AFJP.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_afjp.Text.1}" id="{oi_afjp.XVal}" code="{oi_afjp.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox name="c_jubilacion" nvalue="#source:@c_jubilacion" label="N&#250;mero Jubilaci&#243;n" length="30" xsize="30" ysize="1" descr="N&#250;mero de Jubilaci&#243;n." enabled="NEW|EDIT" required="0"/>
				<form:TextBox name="o_egreso_afjp" nvalue="#source:@o_egreso_afjp" label="Observaci&#243;n Egreso AFJP" length="1000" xsize="50" ysize="4" descr="Observaciones de Egreso de AFJP. Puede ser alfanum&#233;rico de hasta 1000 caracteres." enabled="NEW|EDIT" required="0"/>
			</form:Column>
		</form:Columns>
	</form:Center>
</form:Form>
