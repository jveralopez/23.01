<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.Legajo.DOCUMENTO_PER.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.Legajo.DOCUMENTO_PER">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsDOCUMENTO_PER">
			<form:Column name="main_columnsDOCUMENTO_PERcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Personal" nvalue="#source:@oi_personal" name="oi_personal"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.Combo.autoflow" required="1" enabled="NEW|EDIT" label="Tipo Documento" nvalue="#source:oi_tipo_documento/@value" name="oi_tipo_documento"/>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="N&#250;mero de Documento personal." ysize="1" xsize="30" length="30" label="N&#250;mero Documento" nvalue="#source:@c_documento" name="c_documento"/>
				<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Pa&#237;s - Provincia" nvalue="#source:oi_provincia/@value" name="oi_provincia">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime label="Fecha de Entrega" required="0" pattern="YYYYMMDD" enabled="NEW|EDIT" name="f_entrega" nvalue="#source:@f_entrega">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha de vencimiento del Documento." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Nombre del Organismo que otorg&#243; el documento." ysize="1" xsize="50" length="100" label="Responsable Expedici&#243;n" nvalue="#source:@d_resp_expedicion" name="d_resp_expedicion"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Pa&#237;s - Provincia donde se solicit&#243; el Documento." ysize="1" xsize="50" length="100" label="Origen Documento" nvalue="#source:@d_origen_documento" name="d_origen_documento"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" descr="Fecha de vencimiento del Documento." mask="dd/mm/yyyy" label="Fecha Vencimiento" nvalue="#source:@f_vencimiento_doc" name="f_vencimiento_doc">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha de vencimiento del Documento." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_documento_per" name="o_documento_per"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:Hidden nvalue="#source:../../oi_tipo_documento/@value" name="oi_tipo_doc"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Personal/Legajo/DOCUMENTO_PER/NEW" visible="EDIT|LIST_EDIT" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Personal/Legajo/DOCUMENTO_PER/DELETE" visible="EDIT|LIST_EDIT" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Scripts>
		&#13;&#10;function ONLOAD()
{
	if (Ctrl('oi_tipo_doc') &amp;&amp; Ctrl('oi_tipo_documento'))
	{
		if (Ctrl('oi_tipo_doc').GetXValue() == Ctrl('oi_tipo_documento').GetXValue())
		{
			if (Ctrl('main').GetMode() == 'EDIT')
			{		
				if (Ctrl("oi_tipo_documento"))
					CtrlEnabled('oi_tipo_documento', false);					
				if (Ctrl("c_documento"))
					CtrlEnabled('c_documento', false);						
			}			
		}		
	}
}
	</form:Scripts>
</form:Form>
