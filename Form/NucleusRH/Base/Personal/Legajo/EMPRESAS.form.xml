	<form:Scripts>
		function CallReporte()
{	
	openNewFlowWait("NucleusRH.Base.Personal.Reportes.Legajo.flow","ORGANIGRAMA",'&lt;ID VALUE="'+Ctrl("LIST").GetSelectAttrValue("oi_personal_emp")+'" /&gt;',new ObjtectResult(),"L");
}

function ObjtectResult() 
{ 
	this.processResult = function(xmlin) { } 
}                              

function CallEmpresa()
{         
	if(Ctrl("main").GetMode()=="LIST") 
	{
		var np = new NomadProxy("", ut);
		var nSQL = np.SQLService();
		var empresa = nSQL.GetOBJ(Ctrl("main").getResource("QRY_EMPRESA"), "&lt;PARAM oi_personal_emp=\""+Ctrl("LIST").GetSelectAttrValue("oi_personal_emp")+"\" /&gt;"); 
		getFormInMain("NucleusRH.Base.Organizacion.Empresas.NAV.flow", "filter",  "&lt;EMPRESA VALUE=\""+empresa.oi_empresa.toString()+"\" /&gt;", false);
	}
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_personal_emp=&quot;1&quot;/&gt;" name="QRY_EMPRESA">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_empresa
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
