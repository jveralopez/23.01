		function ToList()
{                
	if (parseInt(Ctrl("iter-size").GetXValue(),10)&lt;=400)
		Ctrl("LISTA").DoEvent("showList");
	else
		alert("Demasiados registros para ser mostrados en una lista.");
}

function Trim(strin)
{
	var strout="", strprev=" ", strnew="", t, c;
	
	for (t=0; t&lt;strin.length; t++)
	{
		c=strin.charCodeAt(t);
		strnew=(c&lt;32 &amp;&amp; c&gt;0)?" ":strin.charAt(t);
		if ((strprev!=strnew) || (strnew!=" "))
		{
			strout+=strnew;
			strprev=strnew;
		}
	}
	if ((strout.length!=0) &amp;&amp; (strnew==" ")) strout=strout.substr(0,strout.length-1);
	
	return strout;
}

