	<form:Resources>
		<form:Resource declare="&lt;PARAM id=&quot;4&quot;/&gt;" name="qry:TIPODOC">
			<qry:main doc="PARAM">
				<qry:element name="DATO">
					<qry:insert-select doc-path="#PARAM:/PARAM" name="qry_tipo_doc"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_tipo_doc">
				<qry:xquery>
					for $r in sql('
					SELECT PER20_TIPOS_DOC.c_tipo_documento
					FROM PER20_TIPOS_DOC WHERE PER20_TIPOS_DOC.oi_tipo_documento = {#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cod" value="$r/@c_tipo_documento" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM cuit1=&quot;20068019181&quot; cuit2=&quot;20-06801918-1&quot; oi=&quot;19233&quot; /&gt;" name="qry_REPETIDO_CUIT">
			<qry:main doc="PARAM">
				<qry:element name="DATO">
					<qry:attribute name="repetido" value="'0'"/>
					<qry:insert-select doc-path="#PARAM:/PARAM" name="qry_existe"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_existe">
				<qry:xquery>
					for $r in sql('
					SELECT 
						PER01_PERSONAL.c_nro_cuil
					FROM 
						PER01_PERSONAL
					WHERE 
					(
						contain(PER01_PERSONAL.c_nro_cuil, {#PARAM:@cuit1})
						OR contain(PER01_PERSONAL.c_nro_cuil, {#PARAM:@cuit2})
					)					
					{%?(#PARAM:@oi!='') {% AND PER01_PERSONAL.oi_personal != {#PARAM:@oi} %} {% %} %}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="repetido" value="'1'"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
