	function val_doc(me)
	{
	 
	  if (Ctrl('main').GetMode()=="NEW" || Ctrl('main').GetMode()=="EDIT")
	  {
	    //Si el tipo de documento es DNI saca los puntos y controla que sean solo numeros
	    var dni = Ctrl('c_nro_documento').GetXValue();
	    dni = Replace(dni, '.', "");
	    Ctrl('c_nro_documento').SetXValue(dni);
	    if (Ctrl('oi_tipo_documento').GetXValue() == 1) 
	    {
	      if (Ctrl('c_nro_documento').GetXValue().length != 7 &amp;&amp; Ctrl('c_nro_documento').GetXValue().length != 8) {
	        me.SetError("El Documento es incorrecto");
	        return false;
	      }
	      if (parseInt(dni, 10).toString() != Ctrl('c_nro_documento').GetXValue()) {
	        me.SetError("El Documento debe ser num&#233;rico");
	        return false;
	      }
	    }
	  }
	  return true;
	}
      

	function val_cuil( me )
	{
	    var pstrCuil = me.GetXValue();
	    var lngSexo;
	    	    
	    if (me.GetXValue() == "")
	    	return true;
	    if (Ctrl('c_sexo').GetXValue() == "M")
	    	pblnMasculino = true;
	    else if (Ctrl('c_sexo').GetXValue() == "F") 
	    	pblnMasculino = false;
	    else return true;
	    
	    var strSexoyDocumento;
	    var lngVerificador;
	    
	    var regexNumero = /^([0-9])*$/;
	    if(!regexNumero.test(pstrCuil))
	   	{
	   		me.SetError("El CUIT/CUIL no puede contener caracteres especiales, solo n&#250;meros");
	   		return false;
	   	}
	    
			/*var re = /-/g;
	    pstrCuil = pstrCuil.replace( re, "" );*/
		 
	    if ( pstrCuil.length != 11 ) 
	   	{
	   		me.SetError('El largo del CUIT/CUIL es incorrecto');
	   		return false;
	   	}
	    
	    lngSexo = parseInt( pstrCuil.substr( 0, 2 ) );
	    strSexoyDocumento = pstrCuil.substr( 0, 10 );
	    lngVerificador = parseInt( pstrCuil.substr( pstrCuil.length - 1, 1 ) ); 
	    
	    if ( intDigVerificador(strSexoyDocumento) == lngVerificador )
      { 
      	var cuit2 = lngSexo + "-" + pstrCuil.substr( 2, 8 ) + "-" + lngVerificador;
      	
      	var np = new NomadProxy("", ut);
				var nSQL = np.SQLService();
				
				if(Ctrl('main').GetMode()=="EDIT")				  
					var docPar = nSQL.GetOBJ(Ctrl("main").getResource("qry_REPETIDO_CUIT"), "&lt;PARAM cuit1=\""+pstrCuil+"\" cuit2=\""+cuit2+"\" oi=\""+Ctrl("oi_personal_emp").GetXValue()+"\" /&gt;");
				else
					var docPar = nSQL.GetOBJ(Ctrl("main").getResource("qry_REPETIDO_CUIT"), "&lt;PARAM cuit1=\""+pstrCuil+"\" cuit2=\""+cuit2+"\" /&gt;");
				
				var repetido = docPar.repetido;
								
				if(repetido=="1")
				{
					me.SetError('El CUIT/CUIL ingresado ya se encuentra registrado en otra Persona');
					return false;
				}
				else
				{
					return true;
				}
				      
      }
	    else
			{
				me.SetError('El d&#237;gito verificador del CUIT/CUIL es incorrecto');			
				return false;
			}
	}				
     
    
    function intDigVerificador( pstrCuil )
    {
	    var dblSuma;
	    var lngResto;
	    var intDigVerificador;
	        
	    dblSuma = parseInt(pstrCuil.substr(0, 1)) * 5;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(1, 1)) * 4;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(2, 1)) * 3;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(3, 1)) * 2;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(4, 1)) * 7;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(5, 1)) * 6;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(6, 1)) * 5;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(7, 1)) * 4;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(8, 1)) * 3;
	    dblSuma = dblSuma + parseInt(pstrCuil.substr(9, 1)) * 2;
	
	    lngResto = dblSuma % 11;
	    if (lngResto == 0)
	    {
	    	return 0;
	    }   
	    else
	    {
	    	return parseInt(11 - lngResto);
	    }
    }
