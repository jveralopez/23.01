<flow:flow extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Personal.Legajo.PERSONAL.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Personal.Legajo.PERSONAL"/>
	<flow:main doc="SOURCE">
		<flow:action name="C2X">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="C2X"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Personal.Legajo.PERSONAL.guia.autoform"/>
		</flow:action>
		<flow:action name="X2C">
			<flow:log text="ALGO_RARO" text-path="#FILTER_DATA:"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="X2C"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot; code=&quot;dni30169169&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER01_PERSONAL.oi_personal AS ID, PER01_PERSONAL.c_personal AS CODE,
				PER01_PERSONAL.d_ape_y_nom AS TEXT 
				FROM PER01_PERSONAL 
				WHERE PER01_PERSONAL.c_personal={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}  ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					<qry:insert-select doc-path="." name="SECURITY_PERSONAL"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_PERSONAL">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Personal.Legajo.PERSONAL\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER01_PERSONAL.oi_personal AS ID, PER01_PERSONAL.c_personal AS CODE,
				PER01_PERSONAL.d_ape_y_nom AS TEXT 
				FROM PER01_PERSONAL
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:insert-select doc-path="." name="SECURITY_PERSONAL"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_PERSONAL">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Personal.Legajo.PERSONAL\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot; code=&quot;01&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER01_PERSONAL.oi_personal AS ID, PER01_PERSONAL.c_personal AS CODE,
				PER01_PERSONAL.d_ape_y_nom AS TEXT 
				FROM PER01_PERSONAL
				WHERE PER01_PERSONAL.oi_personal={#SOURCE:helper-mess/@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Personal.Legajo.PERSONAL.guia.autoform:show" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Personal.Legajo.PERSONAL.guia.autoform">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:exit-flow return-path="#RS:ROW[@id={#FORM:ctrl[@id='GRID']/@selectedRow}]"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
