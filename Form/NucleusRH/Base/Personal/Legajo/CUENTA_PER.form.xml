<form:Form extends="nomad.childGrid.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.Legajo.CUENTA_PER" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Cuentas de Usuario" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Cuentas de Usuario" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Cuentas de Usuario" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW" style="S3 LCol_w" label="Consultar Cuentas de Usuario" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#source:../../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn>
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label=" " name="sel"/>
				</form:GColumn>
				<form:GColumn>
					<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Cuenta" nvalue="#source:@oi_cuenta" name="oi_cuenta">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="Nomad.Base.Login.Cuentas.Cuenta.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom/>
</form:Form>

