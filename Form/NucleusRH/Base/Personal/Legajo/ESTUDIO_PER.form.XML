<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="NucleusRH.Base.Personal.Legajo.ESTUDIO_PER.form" extends="NucleusRH.Base.Personal.Legajo.ESTUDIO_PER.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Columns name="main_columnsESTUDIO_PER">
			<form:Column name="main_columnsESTUDIO_PERcolumn1">
				<form:ComboBox prev="oi_area_est" queryname1="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Estudio" nvalue="#source:oi_estudio/@value" name="oi_estudio" X-POLICY="./FORM/NucleusRH/Base/Personal/Legajo/ESTUDIO_PER/form/oi_estudio">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Personal/Legajo/ESTUDIO_PER/form/oi_estudio/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Personal/Legajo/ESTUDIO_PER/form/oi_estudio"/>
					</form:Policies>
				</form:ComboBox>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" descr="Fecha de Inicio del Estudio." mask="dd/mm/yyyy" label="Fecha Inicio" nvalue="#source:@f_ini_estudio" name="f_ini_estudio">
					<form:Event runat="client" name="onvalidate" action="val_f_ini_estudio"/>
					<form:SButtons>
						<form:SButton descrip="Fecha de Inicio del Estudio." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" descr="Fecha de Finalizaci&#243;n del Estudio." mask="dd/mm/yyyy" label="Fecha Fin" nvalue="#source:@f_fin_estudio" name="f_fin_estudio">
					<form:Event runat="client" name="onvalidate" action="val_f_fin_estudio"/>
					<form:SButtons>
						<form:SButton descrip="Fecha de Finalizaci&#243;n del Estudio." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime enabled="NEW|EDIT" order-change="NEXT:n_promedio" pattern="YYYYMM" required="0" mask="dd/mm/yyyy" label="Mes - A&#241;o de Obtenci&#243;n del T&#237;tulo" nvalue="#source:@e_ptitulo" name="e_ptitulo">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:CheckBox enabled="NEW|EDIT" order-change="NEXT:e_ptitulo" required="0" label="Empresa Abona Adicional por T&#237;tulo" nvalue="#source:@l_adicional" name="l_adicional"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function val_f_ini_estudio(Me)
{
	if (Me.TypedValue() != null)
	{
		if (Me.TypedValue() &gt; NowDate())
		{
			Me.SetError('La fecha de Inicio de Curso debe ser anterior o igual a la fecha Actual');
			return false;								
		}	
		else
			return true;
	}				
	else
		return true;
}

function val_f_fin_estudio(Me)
{
	if (Me.TypedValue() != null)
	{
		if (Me.TypedValue() &gt; NowDate())
		{
			Me.SetError('La fecha de Fin de Curso debe ser anterior o igual a la Fecha Actual');
			return false;
		}						
		else 
		if (Ctrl('f_ini_estudio').TypedValue() != null)
			{if (Ctrl('f_ini_estudio').TypedValue() &gt;= Me.TypedValue())
					{Me.SetError('La fecha de Fin debe ser posterior a la fecha de Inicio de Estudio');
					return false}
			else return true}
		else return true
	}
	else return true;
}
	</form:Scripts>
</form:Form>
