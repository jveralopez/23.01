<form:Form xmlns:form="nomad_engine.form" extends="nomad.childIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.Legajo.DOMIC_PER">
	<form:Center width="95%">
		<form:Columns name="main_columnsDOMIC_PER">
			<form:Column name="main_columnsDOMIC_PERcolumn1">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Personal.Tipos_Domicilio.TIPO_DOMICILIO.Combo.autoflow" required="1" enabled="NEW|EDIT" label="Tipo Domicilio" nvalue="#source:oi_tipo_domicilio/@value" name="oi_tipo_domicilio">
					<form:Event runat="client" name="onvalidate" action="asig_oi_tipo_domicilio"/>
				</form:Combo>
				<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Localidad" nvalue="#source:oi_localidad/@value" name="oi_localidad">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_localidad.Text.1}" id="{oi_localidad.XVal}" code="{oi_localidad.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="Calle correspondiente al Domicilio." ysize="1" xsize="50" length="100" label="Calle" nvalue="#source:@d_calle" name="d_calle"/>
				<form:NumberBox required="1" enabled="NEW|EDIT" descr="N&#250;mero correspondiente al Domicilio." mask="###.###.##0" xsize="12" label="N&#250;mero" nvalue="#source:@e_numero" name="e_numero"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Piso correspondiente al Domicilio." ysize="1" xsize="50" length="100" label="Piso" nvalue="#source:@d_piso" name="d_piso"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Departamento correspondiente al Domicilio." ysize="1" xsize="50" length="100" label="Departamento" nvalue="#source:@d_departamento" name="d_departamento"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="El Domicilio se encuentra ubicado entre la calle:" ysize="1" xsize="50" length="100" label="Entre Calle 1" nvalue="#source:@d_entre_calle_1" name="d_entre_calle_1"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="El Domicilio se encuentra ubicado entre la calle:" ysize="1" xsize="50" length="100" label="Entre Calle 2" nvalue="#source:@d_entre_calle_2" name="d_entre_calle_2"/>
				<form:TextBox label="C&#243;digo Postal 1111" required="0" enabled="NEW|EDIT" descr="C&#243;digo Postal correspondiente al Domicilio. Puede ser alfanum&#233;rico de hasta 30 caracteres." ysize="1" xsize="30" length="30" nvalue="#source:@c_postal" name="c_postal"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Tel&#233;fono correspondiente al Domicilio" ysize="1" xsize="50" length="50" label="Tel&#233;fono" nvalue="#source:@te_1" name="te_1"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Tel&#233;fono alternativo correspondiente al Domicilio." ysize="1" xsize="50" length="50" label="Tel&#233;fono alternativo" nvalue="#source:@te_2" name="te_2"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Celular del Empleado." ysize="1" xsize="50" length="50" label="Celular" nvalue="#source:@te_celular" name="te_celular"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="E-Mail del empleado." ysize="1" xsize="50" length="100" label="E-Mail" nvalue="#source:@d_email" name="d_email"/>
				<form:TextBox label="E-Mail Alternativo" name="d_email_alt" nvalue="#source:@d_email_alt" required="0" enabled="NEW|EDIT" descr="E-Mail del empleado." ysize="1" xsize="50" length="100"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Partido correspondiente al Domicilio." ysize="1" xsize="50" length="100" label="Partido" nvalue="#source:@d_partido" name="d_partido"/>
				<form:CheckBox required="0" enabled="NEW|EDIT" label="Domicilio Fiscal" nvalue="#source:@l_domic_fiscal" name="l_domic_fiscal"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Observaciones de Domicilio. Puede ser alfanum&#233;rico de hasta 1000 caracteres." ysize="1" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_domicilio" name="o_domicilio"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom/>
</form:Form>
