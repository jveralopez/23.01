<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Personal.RegistroLicencia.flow">
	<flow:info label="Registro de Licencias"/>
	<flow:declare>
		<doc:define name="PARAMS">
			<DATOS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.RegistroLicencia.CONSULTA.form" mode="NEW" doc-path="#PARAMS:"/>
		</flow:action>
	</flow:main>
	<flow:form doc="SOURCE" parent-doc="PARENTSOURCE" name="NucleusRH.Base.Personal.RegistroLicencia.CONSULTA.form:NEW" form-class="NucleusRH.Base.Personal.RegistroLicencia.CONSULTA.form" mode="NEW">
		<flow:action name="SAVE">
			<flow:exec-method class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" method="RegistrarLicencia">
				<flow:param doc="PARAMS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
				<!--flow:param attr-path="#FORM:ctrl[@id='licvalue']/@xval" type="Nomad.NSystem.Boolean" mode="in" name="genlic"/-->
			</flow:exec-method>
			<!--flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/-->
			<flow:call-action action="cleanDOC"/>
			<flow:call-action action="msg"/>
			<flow:log text="EMISOURCE" text-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="msg">
			<flow:log text-path="#PARAMS:" text="EMIPARAMS"/>
			<flow:message message="La licencia fue registrada correctamente"/>
		</flow:action>
		<flow:action name="cleanDOC">
			<doc:set-attribute to-attr-path="#SOURCE:@oi_personal_emp"/>
			<doc:set-attribute to-attr-path="#SOURCE:@oi_licencia"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_inicio"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_fin"/>
			<doc:set-attribute to-attr-path="#SOURCE:@e_cant_dias"/>
			<doc:set-attribute to-attr-path="#SOURCE:@e_anio_corresp"/>
			<doc:set-attribute to-attr-path="#SOURCE:@e_saldo"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_interrupcion"/>
			<doc:set-attribute to-attr-path="#SOURCE:@f_notificacion"/>
			<doc:set-attribute to-attr-path="#SOURCE:@o_licencia_per"/>
			<doc:set-attribute to-attr-path="#SOURCE:@oi_familiar_per"/>
		</flow:action>
	</flow:form>
	<flow:form extends="Nomad.base.HTML_XLS.form:SHOW" form-class="Nomad.base.HTML_XLS.form" name="Nomad.base.HTML_XLS:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="BACK">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
