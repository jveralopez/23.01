<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Personal.TiposPersonal.autoflow" default_action="initialize" name="NucleusRH.Base.Personal.TiposPersonal">
	<flow:declare>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_tipo_personal as oi_tipo_personal, 
					t0.c_tipo_personal as c_tipo_personal, 
					t0.d_tipo_personal as d_tipo_personal, 
					t0.l_bloqueo as l_bloqueo, 
					SEC.policy, 
					t0.c_tipo_personal as CODE, 
					t0.d_tipo_personal as TEXT 
				FROM 
					PER11_TIPOS_PERS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL\') as SEC 
				JOIN 
					t0.oi_tipo_personal LEFT OUTER SEC.id  
				ORDER BY 
					oi_tipo_personal asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_tipo_personal"/>
						<qry:attribute name="c_tipo_personal" value="$r/@c_tipo_personal"/>
						<qry:attribute name="d_tipo_personal" value="$r/@d_tipo_personal"/>
						<qry:attribute name="l_bloqueo" value="$r/@l_bloqueo"/>
						<qry:insert-select name="qry_bloqueo_0" doc-path="$r/.[@l_bloqueo=0]"/>
						<qry:insert-select name="qry_bloqueo_1" doc-path="$r/.[@l_bloqueo=1]"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_0">
				<qry:out>
					<qry:attribute name="img" value=""/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_1">
				<qry:out>
					<qry:attribute name="img" value="'Listas/LOCK.ICO'"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:group Name="TIPO_PERSONAL">
		<flow:form extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.noreg.form:EDIT" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form:SHOW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form:LIST" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
				<flow:log text-path="#SOURCE:" text="emisource"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form:EDIT" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form:NEW" form-class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.form" mode="NEW"/>
	</flow:group>
</flow:flow>
