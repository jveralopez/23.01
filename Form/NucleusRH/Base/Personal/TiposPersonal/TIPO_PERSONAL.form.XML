<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsTIPO_PERSONAL">
			<form:Column name="main_columnsTIPO_PERSONALcolumn1">
				<form:TextBox enabled="NEW" required="1" descr="C&#243;digo de Tipo de Personal." ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_tipo_personal" name="c_tipo_personal"/>
				<form:TextBox enabled="NEW|EDIT" required="1" descr="Descripci&#243;n de Tipo de Personal." ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_tipo_personal" name="d_tipo_personal"/>
				<form:CheckBox visible="0" required="0" label="Bloqueo" nvalue="#source:@l_bloqueo" name="l_bloqueo"/>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" descr="C&#243;digo de Tipo de Personal." width="100px" type="string" label="C&#243;digo" attrname="c_tipo_personal" name="c_tipo_personal" X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/c_tipo_personal">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/c_tipo_personal/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/c_tipo_personal"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn align="left" sorteable="1" descr="Descripci&#243;n de Tipo de Personal." width="100px" type="string" label="Descripci&#243;n" attrname="d_tipo_personal" name="d_tipo_personal" X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/d_tipo_personal">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/d_tipo_personal/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Personal/TiposPersonal/TIPO_PERSONAL/form/d_tipo_personal"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Bloqueo" attrname="l_bloqueo" name="l_bloqueo"/>
			</form:LVColumns>
			<form:Event action="ChangeSelect" name="onclick" runat="client"/>
		</form:ListView>
		<form:Hidden nvalue="#source:@l_bloqueo" name="l_bloqueo"/>
	</form:Center>
	<form:Event action="LoadForm" name="onload" runat="client"/>
	<form:Event action="load-DDO" name="LoadDDO" runat="server"/>
	<form:Scripts>
		function LoadForm()
{   
if (Ctrl('main').GetMode() !='LIST')	                        
   {
   CtrlEnabled("EDIT", !(parseInt(Ctrl('l_bloqueo').GetXValue())&amp;1)); 
   CtrlEnabled("DELETE", !(parseInt(Ctrl('l_bloqueo').GetXValue())&amp;1));		
   }
else
   {
   CtrlEnabled("EDIT", !(parseInt(Ctrl('LIST').GetSelectAttrValue('l_bloqueo'))&amp;1));
   CtrlEnabled("DELETE", !(parseInt(Ctrl('LIST').GetSelectAttrValue('l_bloqueo'))&amp;1));		
   }
}	
	  
function ChangeSelect(lvObj)
{
  CtrlEnabled("EDIT", !(parseInt(lvObj.GetSelectAttrValue('l_bloqueo'))&amp;1));
  CtrlEnabled("DELETE", !(parseInt(lvObj.GetSelectAttrValue('l_bloqueo'))&amp;1));
  
}
	</form:Scripts>
</form:Form>
