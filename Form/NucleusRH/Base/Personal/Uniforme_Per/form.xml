<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.Uniforme_Per.form" doc="source">
	<form:Title>
		<form:Label label="Devoluci&#243;n de Uniforme" name="lbl_titulo" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="500px">
		<form:Blank name="bl1"/>
		<form:Columns width="500px" name="main_columnsUNIFORME_PER">
			<form:Column width="500px" name="main_columnsUNIFORME_PERcolumn1">
				<form:ComboBox enabled="0" queryname1="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.INFO" xsize="40" mode="QRY" required="1" label="Uniforme" nvalue="#source:@oi_uniforme" name="oi_uniforme"/>
				<form:DateTime enabled="0" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" label="Fecha Desde" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Devoluci&#243;n" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.Mot_Devolucion.MOT_DEVOLUCION.INFO" xsize="40" mode="QRY" required="1" label="Motivo Devoluci&#243;n" nvalue="#source:@oi_mot_devolucion" name="oi_mot_devolucion"/>
				<form:CheckBox label="Repone Stock?" nvalue="#source:@l_repone_stock" name="l_repone_stock" order-change="PREV:o_uniforme_per"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button img="save" descrip="Guarda los inscriptos seleccionados" label="Guardar" name="btnSAVE" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
