<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Personal.CreacionEntidades.flow" extends="Nomad.Base.flow">
	<flow:info label="flow creacion entidades"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.CreacionEntidades.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Personal.CreacionEntidades.form" name="NucleusRH.Base.Personal.CreacionEntidades.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method method="ProcesarEntidades" class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" priority="9" out-attr-path="#BATCHDOC:@batch-id"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
