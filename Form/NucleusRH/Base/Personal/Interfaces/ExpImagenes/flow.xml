<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" description="Flow para la Exportacion de fotos del personal" name="NucleusRH.Base.Personal.Interfaces.ExpImagenes.flow" default_action="initialize">
	<flow:info label="Flow para la carga de Fotos del Personal."/>
	<flow:declare>
		<doc:define name="FILTERDATA"/>
		<doc:define name="QRY"/>
		<doc:define name="FOTOS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<!--doc:load-qry qry="QRY_Parametros" output-doc="DATOSQRY"/-->
			<!--flow:call-action if="#DATOSQRY:" eq="&quot;&quot;" else="iniEntradaFotos" action="message"/-->
			<!--doc:set-attribute from-attr-path="#DATOSQRY:PARAMETRO[@c_parametro='pathFotos']/@d_valor" to-attr-path="#DATOS:@path"/-->
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Personal.Interfaces.ExpImagenes.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Interfaces.ExpImagenes.form" form-class="NucleusRH.Base.Personal.Interfaces.ExpImagenes.form" mode="FILTER" doc="SOURCE">
		<flow:action name="FILTER">
			<flow:load-user-data name="PER_IDsExportar" doc="QRY"/>
			<flow:exec-method method="ExportarImagenes" class="NucleusRH.Base.Personal.ExpImagenes.EXPORTAR" out-attr-path="#SOURCE:@batch-id" priority="8">
				<flow:param doc-path="#QRY:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlIds"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
	</flow:form>
</flow:flow>
