<form:Form xmlns:form="nomad_engine.form" doc="SOURCE" name="NucleusRH.Base.Personal.Interfaces.Fotos.EntradaFotos.form" default_mode="EDIT">
	<form:Title>
		<form:Label label="Interfaz de Migracion de Fotos" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="60%">
		<form:Columns width="100%" name="ColsCenter">
			<form:Column width="100%" name="col01">
				<form:Blank name="blank02"/>
				<form:TextBox xsize="80" help-stop="0" enabled="0" nvalue="#SOURCE:@path" label="Directorio origen" name="txtPath"/>
				<form:Blank name="blank03"/>
				<form:CheckBox enabled="EDIT" nvalue="#SOURCE:@reemplaza" label="Reemplazar fotos existentes" name="chkRemplazar"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button enabled="EDIT" label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
