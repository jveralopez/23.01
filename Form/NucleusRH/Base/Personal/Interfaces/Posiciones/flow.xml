<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Personal.Interfaces.Posiciones.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Personal.Interfaces.Posiciones.flow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Personal.Interfaces.Posiciones.filter.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Personal.Interfaces.Posiciones.filter.form" name="NucleusRH.Base.Personal.Interfaces.Posiciones.filter.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="EMISOURCE" text-path="#SOURCE:"/>
			<flow:exec-method method="ImportarPosiciones" class="NucleusRH.Base.Personal.InterfacePosiciones.POSIC_PER" out-attr-path="#SOURCE:@batch-id" priority="8"/>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Personal.Interfaces.Posiciones" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Personal.Interfaces.Posiciones" doc="SOURCE"/>
		</flow:action>
	</flow:form>
</flow:flow>
