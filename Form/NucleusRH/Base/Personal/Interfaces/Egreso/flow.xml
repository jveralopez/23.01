<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Personal.Interfaces.Egreso.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Personal.Interfaces.Egreso.flow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" doc-path="#SOURCE:" form-class="NucleusRH.Base.Personal.Interfaces.Egreso.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" form-class="NucleusRH.Base.Personal.Interfaces.Egreso.filter.form" name="NucleusRH.Base.Personal.Interfaces.Egreso.filter.form:FILTER" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="Egreso" class="NucleusRH.Base.Personal.InterfaceEgreso.EgresoLegajos" out-attr-path="#SOURCE:@batch-id" priority="8">
				<flow:param attr-path="#SOURCE:@oi_empresa" type="Nomad.NSystem.String" mode="in" name="id_empresa"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Personal.Interfaces.Egreso" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Personal.Interfaces.Egreso" doc="SOURCE"/>
		</flow:action>
	</flow:form>
</flow:flow>
