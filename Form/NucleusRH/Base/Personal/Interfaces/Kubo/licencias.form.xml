<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Personal.Interfaces.Kubo.form">
	<form:Title>
		<form:Label label="Interfaz de Obtencion de Licencias Nucleus Doc" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="60%">
		<form:Columns width="10%" name="ColsCenter">
			<form:Column valign="top" separation="0" align="center" width="10%" name="col01">
				<form:Blank name="blank02"/>
				<form:DateTime required="1" pattern="YYYYMMDD" nvalue="#source:@fecha" label="Fecha desde" name="fecha">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento.">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
