<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Personal.Interfaces.Kubo.flow" extends="Nomad.Base.flow" description="Flow para la carga de Fotos del Personal." default_action="initialize">
	<flow:info label="Flow para la carga de empleados a ndoc"/>
	<flow:main doc="SOURCE">
		<flow:action name="EMPLEADOS">
			<!--doc:load-qry qry="QRY_Parametros" output-doc="DATOSQRY"/-->
			<!--flow:call-action if="#DATOSQRY:" eq="&quot;&quot;" else="iniEntradaFotos" action="message"/-->
			<!--doc:set-attribute from-attr-path="#DATOSQRY:PARAMETRO[@c_parametro='pathFotos']/@d_valor" to-attr-path="#DATOS:@path"/-->
			<flow:open-form doc-path="#SOURCE:" mode="EMPLEADOS" form-class="NucleusRH.Base.Personal.Interfaces.Kubo.form"/>
		</flow:action>
		<flow:action name="LICENCIAS">
			<flow:open-form form-class="NucleusRH.Base.Personal.Interfaces.Kubo.licencias.form" doc-path="#SOURCE:" mode="LICENCIA"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Personal.Interfaces.Kubo.form:EMPLEADOS" mode="EMPLEADOS" form-class="NucleusRH.Base.Personal.Interfaces.Kubo.form" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:exec-method class="NucleusRH.Base.Configuracion.Kubo.ApiKubo" method="EnviarEmpleados" out-attr-path="#SOURCE:@batch-id" priority="5"/>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Personal.Interfaces.Kubo.licencias.form" name="NucleusRH.Base.Personal.Interfaces.Kubo.licencias.form:LICENCIA" mode="LICENCIA" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:exec-method method="ObtenerLicencias" class="NucleusRH.Base.Configuracion.Kubo.ApiKubo" out-attr-path="#SOURCE:@batch-id" priority="5">
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" name="xmlParam" mode="in"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
	</flow:form>
</flow:flow>
