<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Personal.Categorias.Categoria.form" doc="source">
	<form:Title>
		<form:Label label="Planilla de carga de categor&#237;as" name="lbl_titulo" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="bl2"/>
		<form:Grid width="1020px" proto="&lt;ROW/&gt;" doc="DATAGRID" allowdelall="1" allowdel="1" allownew="1" nvalue="#source:" paging="1" rows="10" name="grdCategorias">
			<form:GColumns>
				<form:GColumn name="colEmpresa">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="25" mode="QRY" required="1" label="Empresa" nvalue="#DATAGRID:@oi_empresa" name="oi_empresa">
						<form:Event action="SetLegajo" name="onchange" runat="client"/>
					</form:ComboBox>
				</form:GColumn>
				<form:GColumn name="colLegajo">
					<form:ComboBox where1="PER02_PERSONAL_EMP.oi_indic_activo = 1" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" name="oi_personal_emp" nvalue="#DATAGRID:@oi_personal_emp" xsize="35" mode="QRY" required="1" label="Legajo"/>
				</form:GColumn>
				<form:GColumn name="colConvenio">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO" label="Convenio" name="oi_convenio" nvalue="#DATAGRID:@oi_convenio" xsize="30" mode="QRY" required="1">
						<form:Event action="SetCategoria" name="onchange" runat="client"/>
					</form:ComboBox>
				</form:GColumn>
				<form:GColumn name="colCategoria">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO" nvalue="#DATAGRID:@oi_categoria" label="Categor&#237;a" name="oi_categoria" xsize="30" mode="QRY" required="1"/>
				</form:GColumn>
				<form:GColumn name="colFechaIngreso">
					<form:DateTime nvalue="#DATAGRID:@f_desde" name="f_desde" xsize="17" pattern="YYYYMMDD" label="Fecha Desde" required="1" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
			</form:GColumns>
			<form:SButtons>
				<form:SButton descrip="Duplicar un registro" label="Duplicar" img="duplicate" name="duplicate">
					<form:Event action="duplicate" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el Proceso de Verificaci&#243;n de Fichadas para el rango de fechas y los Legajos seleccionados" label="Ejecutar" img="ok" name="EXECUTE" note="Consultar los Legajos seleccionados">
					<form:Event action="EXECUTE" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		&#13;&#10;function duplicate()
{
	if (Ctrl('grdCategorias').TotalRowsCount() !=0)
	{
	  var empresa = Ctrl('grdCategorias').GetCellSelectedXValue('oi_empresa'); 
		var per = Ctrl('grdCategorias').GetCellSelectedXValue('oi_personal_emp'); 
		var convenio = Ctrl('grdCategorias').GetCellSelectedXValue('oi_convenio');
		var categoria = Ctrl('grdCategorias').GetCellSelectedXValue('oi_categoria');
		var f_ingreso = Ctrl('grdCategorias').GetCellSelectedXValue('f_desde');
		
		Ctrl('grdCategorias').AddNew();
		
		var objctrl = Ctrl('grdCategorias').GetCellSelectedControl('oi_empresa');
		objctrl.SetXValue(empresa);
		var objctrl = Ctrl('grdCategorias').GetCellSelectedControl('oi_personal_emp');
		objctrl.SetXValue(per);		   
		var objctrl = Ctrl('grdCategorias').GetCellSelectedControl('oi_convenio');
		objctrl.SetXValue(convenio);		
		objctrl = Ctrl('grdCategorias').GetCellSelectedControl('oi_categoria');
		objctrl.SetXValue(categoria);
		objctrl = Ctrl('grdCategorias').GetCellSelectedControl('f_desde');
		objctrl.SetXValue(f_ingreso);
	}	
}

function SetLegajo()
{ 
  var empresa = Ctrl('grdCategorias').GetCellSelectedXValue('oi_empresa');
	
	Ctrl('grdCategorias').GetCellSelectedControl('oi_personal_emp').SetEnabled(true);
	Ctrl('grdCategorias').GetCellSelectedControl('oi_personal_emp').SetWhere("PER02_PERSONAL_EMP.oi_empresa = "+ empresa+" AND PER02_PERSONAL_EMP.oi_indic_activo = 1");
	Ctrl('grdCategorias').GetCellSelectedControl('oi_personal_emp').m_cacheQuery = new Array();
}

function SetCategoria()                                                          
{ 
	var convenio = Ctrl('grdCategorias').GetCellSelectedXValue('oi_convenio');
	
	Ctrl('grdCategorias').GetCellSelectedControl('oi_categoria').SetEnabled(true);		
	Ctrl('grdCategorias').GetCellSelectedControl('oi_categoria').m_cacheQuery = new Array();
	Ctrl('grdCategorias').GetCellSelectedControl('oi_categoria').SetWhere("ORG18_CATEGORIAS.oi_convenio = "+ convenio);			
	
}
	</form:Scripts>
