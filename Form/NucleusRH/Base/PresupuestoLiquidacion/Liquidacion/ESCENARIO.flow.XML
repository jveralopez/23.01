			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.ESCENARIO.form" name="NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.ESCENARIO.form:SHOW" extends="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
			<flow:action name="INCORPORAR_LIQ">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@oi_escenario"/>
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
