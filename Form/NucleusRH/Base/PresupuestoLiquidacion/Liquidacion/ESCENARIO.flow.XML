			<flow:action name="open-flow-SHOW">
				<flow:open-form form-class="NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.ESCENARIO.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
