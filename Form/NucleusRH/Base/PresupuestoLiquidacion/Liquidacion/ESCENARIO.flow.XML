				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="S" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
