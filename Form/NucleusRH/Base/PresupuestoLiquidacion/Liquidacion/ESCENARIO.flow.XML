<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Presupuesto.Escenarios.flow" name="NucleusRH.Base.Presupuesto.Escenarios">
	<flow:info label="Flow para NucleusRH.Base.Presupuesto.Escenarios"/>
	<flow:declare/>
	<flow:main doc="SOURCE"/>
