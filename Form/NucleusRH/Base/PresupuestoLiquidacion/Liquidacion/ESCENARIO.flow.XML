			<flow:action name="INCORPORAR_LIQ">
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@oi_escenario"/>
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="L" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:exit-flow next-flow="NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.LIQUIDACION.flow" return-path="#PRESUPUESTO:" next-action="initialize"/>
			</flow:action>
			<flow:action name="INCORPORAR_NOV">
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@oi_escenario"/>
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="L" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:exit-flow next-flow="NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.LIQUIDACION.flow" return-path="#PRESUPUESTO:" next-action="novedades"/>
			</flow:action>
			<flow:action name="RECALCULAR">
				<flow:log text-path="#FILTERDATA:" text="DENIS_LOG"/>
				<flow:exec-method class="NucleusRH.Base.PresupuestoLiquidacion.Conceptos.CONCEPTO" method="Recalcular" out-attr-path="#BATCHDOC:@batch-id" priority="8">
					<flow:param attr-path="#FILTERDATA:@oi_escenario" name="oiEscenario" type="Nomad.NSystem.Int" mode="in"/>
				</flow:exec-method>
				<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" parent-doc-path="#SOURCE:" doc-path="#BATCHDOC:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="nomad.base.batchtolist.form:BATCH" mode="BATCH" name="nomad.base.batchtolist.form:XXXX" form-class="nomad.base.batchtolist.form" doc="SOURCE">
			<flow:action name="EXIT">
				<flow:close-form/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
