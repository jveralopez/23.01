	<flow:info label="Flow para NucleusRH.Base.PresupuestoLiquidacion.Liquidacion.LIQUIDACION"/>
	<flow:declare>
		<doc:define name="DATA">
			<DATA>
				<LIQS/>
				<LEGS/>
				<ASIGS/>
				<EGRS/>
			</DATA>
		</doc:define>
		<doc:define name="RS"/>
		<doc:define name="NOMINA"/>
		<doc:define name="INGRESOS"/>
		<qry:define declare="&lt;DATA oi_escenario=&quot;1&quot; oi_empresa=&quot;164&quot; oi_detalle_pres=&quot;5&quot; leg=&quot;23&quot; paso=&quot;4&quot;&gt;&#13;&#10;&#9;&lt;LIQS&gt;&#13;&#10;&#9;&#9;&lt;LIQ oi_liquidacion=&quot;47&quot;/&gt;&#13;&#10;&#9;&lt;/LIQS&gt;&#13;&#10;&#9;&lt;LEGS&gt; &#13;&#10;&#9;&#9;&lt;LEG id=&quot;23&quot; /&gt;&#13;&#10;&#9;&#9;&lt;LEG id=&quot;25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;LEG id=&quot;3&quot; /&gt;&#13;&#10;&#9;&lt;/LEGS&gt;&#13;&#10;&#9;&lt;ASIGS/&gt;&#13;&#10;&#9;&lt;EGRS&gt; &#13;&#10;&#9;&#9;&lt;LEG id=&quot;1&quot; /&gt;&#13;&#10;&#9;&#9;&lt;LEG id=&quot;3&quot; /&gt;&#13;&#10;&#9;&lt;/EGRS&gt;&#13;&#10;&lt;/DATA&gt;" name="NOMINA">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:."/>
					<qry:insert-select name="SQL5" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL4" doc="SOURCE">
				<qry:out>
					<qry:attribute value="''" name="hts:delete"/>
				</qry:out>
			</qry:select>
			<qry:select name="SQL5" doc="SOURCE">
				<qry:xquery>
					for $r in SQL(' 
SELECT          
	LEG.e_numero_legajo as id,
	LEG.d_legajo as des
FROM
	PRE05_LEGAJOS as LEG
WHERE			     
	LEG.oi_escenario={#PARAMIN:@oi_escenario} AND
	isNull(LEG.f_egreso)
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="option">
						<qry:attribute name="value" value="$r/@id"/>
						<qry:attribute name="text" value="$r/@des"/>
						<qry:attribute value="'1'" name="hts:delete"/>
						<qry:insert-select name="SQL4" doc-path="#PARAMIN:EGRS/LEG[@id=$r/@id]"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA oi_escenario=&quot;1&quot; oi_empresa=&quot;164&quot; oi_detalle_pres=&quot;5&quot; leg=&quot;23&quot; paso=&quot;4&quot;&gt;&#13;&#10;&#9;&lt;LIQS&gt;&#13;&#10;&#9;&#9;&lt;LIQ oi_liquidacion=&quot;47&quot;/&gt;&#13;&#10;&#9;&lt;/LIQS&gt;&#13;&#10;&#9;&lt;LEGS&gt; &#13;&#10;&#9;&#9;&lt;LEG id=&quot;23&quot; /&gt;&#13;&#10;&#9;&#9;&lt;LEG id=&quot;25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;LEG id=&quot;3&quot; /&gt;&#13;&#10;&#9;&lt;/LEGS&gt;&#13;&#10;&#9;&lt;ASIGS&gt;&#13;&#10;&#9;&#9;&lt;ASIG id=&quot;23&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ASIG id=&quot;25&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ASIG id=&quot;3&quot; /&gt;&#13;&#10;&#9;&lt;/ASIGS&gt;&#13;&#10;&lt;/DATA&gt;" name="INGRESOS">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:."/>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL(' 
SELECT 
	LEG.e_numero_legajo as id,
	LEG.d_ape_y_nom as des,
	COUNT(REC.oi_tot_liq_per) as cnt
FROM
	LIQ19_EJECUCIONES as EJE, 
	LIQ99_LIQUIDACION as LIQ,
	LIQ99_RECIBOS as LIQREC,
	LIQ20_TOT_LIQ_PER as REC,
	LIQ97_PERSONAL_EMP as LEG
JOIN
	EJE.oi_liquidacion_ddo inner LIQ.oi_liquidacion_ddo,
	LIQ.oi_liquidacion_ddo inner LIQREC.oi_liquidacion_ddo,
	LIQREC.oi_tot_liq_per inner REC.oi_tot_liq_per,
	REC.oi_per_emp_ddo inner LEG.oi_per_emp_ddo
WHERE			     
	EJE.oi_liquidacion in ({%=String(#SOURCE:LIQS/LIQ/@oi_liquidacion)%} ) AND
	LIQ.c_estado=\'F\'       
GROUP BY
	LEG.e_numero_legajo, LEG.d_ape_y_nom
ORDER BY
	des ASC	
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="option">
						<qry:attribute name="value" value="$r/@id"/>
						<qry:attribute name="text" value="$r/@des"/>
						<qry:attribute value="'1'" name="hts:delete"/>
						<qry:insert-select name="SQL4" doc-path="#PARAMIN:ASIGS/ASIG[@id=$r/@id]"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="SQL4" doc="SOURCE">
				<qry:out>
					<qry:attribute value="''" name="hts:delete"/>
				</qry:out>
			</qry:select>
		</qry:define>
