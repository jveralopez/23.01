		<qry:define declare="&lt;DATA oi_escenario=&quot;102&quot; oi_empresa=&quot;1&quot; oi_detalle_pres=&quot;106&quot; paso=&quot;3&quot; leg=&quot;731&quot;&gt;&lt;LIQS&gt;&lt;LIQ oi_liquidacion=&quot;606&quot; /&gt;&lt;/LIQS&gt;&lt;LEGS nmd-col=&quot;1&quot;&gt;&lt;LEG id=&quot;1050&quot; /&gt;&lt;LEG id=&quot;731&quot; /&gt;&lt;LEG id=&quot;500160&quot; /&gt;&lt;/LEGS&gt;&lt;ASIGS nmd-col=&quot;1&quot;&gt;&lt;ASIG id=&quot;500160&quot; oi_grupo=&quot;1&quot; /&gt;&lt;ASIG id=&quot;731&quot; oi_grupo=&quot;1&quot; /&gt;&lt;/ASIGS&gt;&lt;EGRS /&gt;&lt;/DATA&gt;" name="LEGLIST">
