			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:out>
					<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
				</qry:out>
				<qry:xquery>
					for $r in SQL(' 
SELECT 
	PRE12_PRESUPUESTO.oi_empresa
FROM                      
	PRE03_ESCENARIOS, 
	PRE12_PRESUPUESTO
JOIN
	PRE03_ESCENARIOS.oi_presupuesto inner PRE12_PRESUPUESTO.oi_presupuesto
WHERE			     
	PRE03_ESCENARIOS.oi_escenario={#SOURCE:@oi_escenario}
')/ROWS/ROW
				</qry:xquery>
			</qry:select>
		</qry:define>
