<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" description="indicador Evaluacion" default_action="initialize" extends="Nomad.Base.flow" name="NucleusRH.Base.Indicadores.Evaluacion">
	<flow:info label="Flow para NucleusRH.Base.Indicadores.Evaluacion">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute from-value="Init" to-attr-path="#FILTERDATA:@action"/>
			<flow:html-gen input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@URL" template-file="NucleusRH.Base.Indicadores.JPivot.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Indicadores.Evaluacion.AnalisisResultado.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Indicadores.Evaluacion.AnalisisResultado.form" name="NucleusRH.Base.Indicadores.Evaluacion.AnalisisResultado.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:attach-doc doc-path="#FILTERDATA:" attach-id="filterdata"/>
			<doc:set-attribute from-value="JPivot" to-attr-path="#FILTERDATA:@action"/>
			<flow:exec-method out-type="Nomad.NSystem.String" out-attr-path="#FILTERDATA:@serverOLAP" class="NucleusRH.Base.Indicadores.Ejecuciones.EJECUCION" method="svr_jPivotHtml"/>
			<flow:html-gen input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@URL" template-file="NucleusRH.Base.Indicadores.JPivot.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Indicadores.Evaluacion.AnalisisResultado.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
