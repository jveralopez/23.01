<flow:flow description="indicador RemunConc de sueldos" default_action="initialize" extends="Nomad.Base.flow" name="NucleusRH.Base.Indicadores.Sueldos" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow para NucleusRH.Base.Indicadores.Sueldos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute from-value="Init" to-attr-path="#FILTERDATA:@action"/>
			<flow:html-gen input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@URL" template-file="NucleusRH.Base.Indicadores.JPivot.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Indicadores.Sueldos_Conc.RemunConc.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Indicadores.Sueldos_Conc.RemunConc.form" name="NucleusRH.Base.Indicadores.Sueldos_Conc.RemunConc.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:attach-doc doc-path="#FILTERDATA:" attach-id="filterdata"/>
			<doc:set-attribute from-value="JPivot" to-attr-path="#FILTERDATA:@action"/>
			<flow:html-gen input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@URL" template-file="NucleusRH.Base.Indicadores.JPivot.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Indicadores.Sueldos_Conc.RemunConc.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
