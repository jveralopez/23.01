<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Indicadores.EmpOperativas.Horas" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="Gesti&#243;n de RR.HH. (Horas - Empresas Operativas)" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Columns name="colActualiza">
			<form:Column name="ejecuciones" separation="2" align="center" valign="top">
				<form:DateTime pattern="YYYYMMDDHHMMSS" xsize="0" enabled="aaaaa" name="Fecha_Max" nvalue="#SOURCE:@Fecha_Max" label="Ultima Actualizacion"/>
			</form:Column>
			<form:Column name="ejecuciones2" separation="2" align="center" valign="top">
				<form:TextBox enabled="aa" label="Estado" name="Estado" nvalue="#SOURCE:@c_estado"/>
			</form:Column>
			<form:Column name="ejecuciones3" separation="2" align="center" valign="top">
				<form:SButton img="SEARCH" name="btn_logTCO">
					<form:Event name="onclick" action="showLogTCO" runat="client"/>
				</form:SButton>
			</form:Column>
		</form:Columns>
		<form:Columns name="Filters">
			<form:Column name="Filter">
				<form:FKInput label="Per&#237;odo" nvalue="#source:@oi_aniomes" name="oi_aniomes" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="Nomad.Base.Codificadora.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" table="TCO_MESESANIOS" col-id="OI_ANIOMES" col-code="C_ANIOMES" col-text="D_ANIOMES"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" visible="" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput label="Empresa Operativa" nvalue="#source:@oi_empresa" name="oi_empresa" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="Nomad.Base.Codificadora.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" table="TCO_EMPRESAS_VINC" col-id="OI_EMPRESA_VINC" col-code="C_EMPRESA_VINC" col-text="D_EMPRESA_VINC"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" visible="" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="ClearPuesto" name="onchange" runat="client"/>
				</form:FKInput>
				<form:Combo name="oi_estructura_f55" enabled="oi_estructura_f" visible="oi_estructura_f" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupami" label="Organigrama" nvalue="#source:@oi_clase_org" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
				<form:FKInput name="oi_estructura_f" nvalue="#source:@oi_estructura_f" label="Organigrama" length="30" xsize="15" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper action="helper" name="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" table="TCO_ESTRUC_FUNC" col-id="OI_ESTRUCTURA_F" col-code="C_UNIDAD_ORG" col-text="D_UNIDAD_ORG"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" visible="" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput visible="false" nvalue="#source:@oi_puesto" name="oi_puesto" label="Puesto" length="30" xsize="15" enabled="" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="Nomad.Base.Codificadora.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" table="TCO_Puestos" col-id="oi_puesto" col-code="c_puesto" col-text="d_puesto" col-parent-id="oi_empresa" parent-id="{oi_empresa.ReadXValue}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="ClearPosicion" name="onchange" runat="client"/>
				</form:FKInput>
				<form:FKInput visible="false" nvalue="#source:@oi_posicion" name="oi_posicion" label="Posicion" length="30" xsize="15" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="Nomad.Base.Codificadora.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" table="TCO_Posiciones" col-id="oi_posicion" col-code="c_posicion" col-text="d_posicion" col-parent-id="oi_puesto" parent-id="{oi_puesto.ReadXValue}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl3"/>
		<form:UrlControl nvalue="#SOURCE:@URL" width="99%" height="60%" direct="1" name="JPivot"/>
		<form:Hidden nvalue="#SOURCE:@MDX" name="mdx"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ClearEmpresa()
{
	Ctrl("oi_empresa").SetCValue("");                     
	ClearPuesto();
}

function ClearPuesto()
{                     
	Ctrl("oi_puesto").SetCValue("");
	ClearPosicion();
}
	
function ClearPosicion()
{                     
	Ctrl("oi_posicion").SetCValue("");
}

          
                             
function EJECUTAR_CLICK()
{                             
	if (Ctrl("oi_empresa").GetXValue()=="") { alert("La Empresa es Requerida."); return false; }      
	if (Ctrl("oi_aniomes").GetXValue()=="") { alert("Periodo es Requerido."); return false; }
	if (Ctrl("oi_estructura_f").GetXValue()=="") { alert("Organigrama es Requerido."); return false; }	
	
	if (!Ctrl("main").Validate()){ return false;}

	
 var mdx = "";
       
                      
 
 mdx += " select NON EMPTY {[Grupos Tipos Horas].[Todos los Grupos Tipos Horas].[Extras 100%], ";
 mdx += " [Grupos Tipos Horas].[Todos los Grupos Tipos Horas].[Extras 50%],     ";
 mdx += " [Grupos Tipos Horas].[Todos los Grupos Tipos Horas].[Normales]} ON COLUMNS, ";
 
 mdx += " NON EMPTY {([Empresas].[Todas las empresas], ";
 mdx += " [Organigrama].[" + Ctrl("oi_estructura_f").GetText(1) + "], [Measures].[Horas])} ON ROWS    ";
  mdx += " from [HORAS]                                                                                     ";
 mdx += " where ([Empresas Operativas].[Todas las empresas].[" +Ctrl("oi_empresa").GetText(1) + "],        ";
 mdx += " [Tiempo].[Todas las fechas].[" + Ctrl("oi_aniomes").GetCValue().split("/")[1]+"].[" + Ctrl("oi_aniomes").GetCValue() + "])";
 
 
 
 
                

	Ctrl("mdx").SetXValue(mdx);
	
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}

function showLogTCO()
{
	openNewFlowWait("NucleusRH.Base.Indicadores.logTCO.flow","initialize","&lt;param modulo=\"personal\" /&gt;",new ObjtectResult(),"L");
}

function ObjtectResult()
{        
	this.processResult= function(xmlin){}
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
</form:Form>
