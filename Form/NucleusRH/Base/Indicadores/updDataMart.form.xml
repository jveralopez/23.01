<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Indicadores.updDataMart" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="Gesti&#243;n de RR.HH. (Actualizaciones de Datos)" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Columns name="Filters">
			<form:Column name="Filter">
				<form:CheckBox help-stop="1" label="Evaluaciones" name="chkEvaluaciones">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:CheckBox>
				<form:CheckBox label="Personal" name="chkPersonal">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:CheckBox>
				<form:CheckBox help-stop="1" label="Horas" name="chkHoras">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:CheckBox>
				<form:CheckBox label="Sueldos" name="chkSueldos">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:CheckBox>
				<form:CheckBox name="chkProyectos" label="Proyectos">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:CheckBox>
				<form:Hidden help-stop="1" name="Tablas_Upd"/>
				<form:DateTime name="date_AnioMes" xsize="0" max="0" required="1" descrip="mes y a&#241;o de actualizacion de datos" label="Mes_A&#241;o" pattern="YYYYMM" min="0" help-stop="0">
					<form:SButtons>
						<form:SButton visible="" descrip="A&#241;o y mes de procesamiento" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl3"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_UPD" runat="server" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function EJECUTAR_CLICK()
{                             
	
	var strTablas = " ";   

 
	if (Ctrl("chkEvaluaciones").GetXValue()!="") { strTablas +="TCO_Fact_Eval ," ;}
	if (Ctrl("chkPersonal").GetXValue()!="") { strTablas +="TCO_Fact_Personal ,"; }      
	if (Ctrl("chkHoras").GetXValue()!="") { strTablas +="TCO_Fact_Horas ,"; }      
	if (Ctrl("chkSueldos").GetXValue()!="") { strTablas +="TCO_fact_sueldos ,"; }
	if (Ctrl("chkProyectos").GetXValue()!="") { strTablas +="Fact_Proyectos ,"; }                        
                                   
	Ctrl("Tablas_Upd").SetXValue(strTablas);
	
	
 
	return true;
}
	</form:Scripts>
</form:Form>
