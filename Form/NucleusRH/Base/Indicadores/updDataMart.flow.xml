<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.flow" name="NucleusRH.Base.Indicadores.updDataMart">
	<flow:info label="Flow para NucleusRH.Base.Indicadores.updDataMart.">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute from-value="Init" to-attr-path="#FILTERDATA:@action"/>
			<flow:html-gen input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@URL" template-file="NucleusRH.Base.Indicadores.JPivot.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Indicadores.updDataMart.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Indicadores.updDataMart.form" name="NucleusRH.Base.Indicadores.updDataMart.form:EDIT" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_DIM">
			<flow:exec-method method="updDimensiones" priority="6" class="NucleusRH.Base.Indicadores.Ejecuciones.EJECUCION"/>
		</flow:action>
		<flow:action name="EJECUTAR_UPD">
			<flow:exec-method out-attr-path="#BATCHDOC:@batch-id" priority="6" class="NucleusRH.Base.Indicadores.Ejecuciones.EJECUCION" method="updTablasFact">
				<flow:param attr-path="#FORM:ctrl[@id='Tablas_Upd']/@xval" type="Nomad.NSystem.String" mode="in" name="str_Tablas"/>
				<flow:param attr-path="#FORM:ctrl[@id='date_AnioMes']/@xval" type="Nomad.NSystem.String" name="date_AnioMes" mode="in"/>
			</flow:exec-method>
			<flow:call-action action="open-flow-BATCH"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="open-flow-BATCH">
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
