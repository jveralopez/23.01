function codigo()
{
	var mp, nSQL, docPar;
	np = new NomadProxy("", ut);
	nSQL = np.SQLService();  
	docPar = nSQL.GetOBJ(Ctrl("main").getResource("qry:TIPODOC"), "&lt;PARAM id=\""+Ctrl("oi_tipo_documento").GetXValue()+"\" /&gt;");	
