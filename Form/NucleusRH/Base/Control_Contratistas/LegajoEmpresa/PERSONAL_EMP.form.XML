	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_empresa=&quot;9&quot;/&gt;" name="QRY_NRO_LEGAJO">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					MAX(PER02_PERSONAL_EMP.e_numero_legajo) AS e_numero_legajo
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_empresa = {#SOURCE:@oi_empresa}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="e_numero_legajo" value="Number($r/@e_numero_legajo) + 1"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG03_EMPRESAS.oi_art
				FROM 
					ORG03_EMPRESAS
				WHERE	
					ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_art" value="$r/@oi_art"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_empresa=&quot;9&quot; oi_personal=&quot;100&quot;/&gt;" name="QRY_ACTIVA">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:attribute name="existe" value="'0'"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.e_numero_legajo
				FROM 
					PER02_PERSONAL_EMP,
					PER01_PERSONAL
				JOIN
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal	
				WHERE 
					PER02_PERSONAL_EMP.oi_empresa = {#SOURCE:@oi_empresa} and
					PER01_PERSONAL.oi_personal = {#SOURCE:@oi_personal}				
					
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="existe" value="'1'"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM id=&quot;4&quot;/&gt;" name="qry:TIPODOC">
			<qry:main doc="PARAM">
				<qry:element name="DATO">
					<qry:insert-select doc-path="#PARAM:/PARAM" name="qry_tipo_doc"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_tipo_doc">
				<qry:xquery>
					for $r in sql('
					SELECT PER20_TIPOS_DOC.c_tipo_documento
					FROM PER20_TIPOS_DOC WHERE PER20_TIPOS_DOC.oi_tipo_documento = {#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cod" value="$r/@c_tipo_documento" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_personal_emp=&quot;1&quot;/&gt;" name="QRY_PERSONAL">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_personal
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="OnLoadCus" name="onload" runat="client"/>
</form:Form>
