}

function Guardar()
{
 	if(Ctrl('f_ingreso_planta').GetXValue() != "")
 		if(Ctrl('f_ingreso_planta').GetXValue() &lt; Ctrl('f_ingreso').GetXValue())
 		{
 			alert("La fecha de ingreso a la planta debe ser mayor o igual a la fecha de ingreso");
      return false;
 		} 	
 	if(Ctrl('main').GetMode() != "NEW" &amp;&amp; Ctrl('main').GetMode() != "REINGRESAR")
 	{
	 	if(Ctrl('f_egreso_planta').GetXValue() != "")
	 	{	
	 	  if(Ctrl('f_egreso_planta').GetXValue() &lt; Ctrl('f_ingreso_planta').GetXValue())
	 		{
	 			alert("La fecha de egreso a la planta debe ser mayor o igual a la fecha de ingreso a la planta");
	      return false;
	 		}
	 	
	 	  if((Ctrl('f_egreso').GetXValue()!="" ) &amp;&amp; (Ctrl('f_egreso_planta').GetXValue() &gt; Ctrl('f_egreso').GetXValue()))
	 		{
	 			alert("La fecha de egreso a la planta debe ser menor o igual a la fecha de egreso");
	      return false;
	 		}
	  }
	}

	Ctrl("main").DoEvent("SAVE");
}   

function LoadEmpresa(me)
{
	var legajo;	
	
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();

	if (me.GetCValue() != "")
	{
		
		legajo = nSQL.GetOBJ(Ctrl("main").getResource("QRY_NRO_LEGAJO"), "&lt;PARAM oi_empresa=\""+Ctrl("oi_empresa").GetXValue()+"\" /&gt;"); 		
		Ctrl("e_numero_legajo").SetXValue(legajo.e_numero_legajo);
		
		if (legajo.oi_art != null)
			Ctrl("oi_art").SetXValue(legajo.oi_art);				
		else
		 Ctrl("oi_art").SetXValue("");				
	}
	else
	{		
		
		
		Ctrl('e_numero_legajo').SetCValue("");
		Ctrl('oi_art').SetCValue("");
		
	}
 
