function val_f_nacim (myThis)
{		
	if (myThis.GetXValue() != "")
	{
		if (myThis.GetXValue() &gt;= date2str(NowDate()))
		{
		  myThis.SetError('La fecha de Nacimiento debe ser anterior a Hoy');
			return false;
		}
		else return true;
	}
	else return true;
}

