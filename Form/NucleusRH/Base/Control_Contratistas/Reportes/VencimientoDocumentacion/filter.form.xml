<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Control_Contratistas.Reportes.VencimientoDocumentacion.filter.form" doc="source">
	<form:Title>
		<form:Label label="Vencimiento de Documentaci&#243;n" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:Blank name="bc1"/>
				<form:ComboBox xsize="50" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" nvalue="#FILTERDATA:@oi_empresa" where1="ORG03_EMPRESAS.l_contratista=1" mode="QRY" label="Empresa Contratista" name="oi_empresa"/>
				<form:DateTime label="Fecha de Vencimiento Desde" name="f_des" nvalue="#FILTERDATA:@f_des" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha de Vencimiento Hasta" name="f_has" nvalue="#FILTERDATA:@f_has" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:CheckBox nvalue="#FILTERDATA:@l_emp" label="Documentaci&#243;n de la Empresa" name="l_emp"/>
				<form:CheckBox nvalue="#FILTERDATA:@l_leg" label="Documentaci&#243;n de Empleados" name="l_leg"/>
				<form:CheckBox nvalue="#FILTERDATA:@l_veh" label="Documentaci&#243;n de Veh&#237;culos" name="l_veh"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
	<form:Scripts>
		function ACCEPT ()
{
	if (Ctrl("l_emp").GetXValue()!="1" &amp;&amp; Ctrl("l_leg").GetXValue()!="1" &amp;&amp; Ctrl("l_veh").GetXValue()!="1")
	{
		alert("Seleccione alguna documentaci&#243;n a mostrar");
		return false;
	}
	Ctrl("main").DoEvent("ACCEPT");
}
	</form:Scripts>
</form:Form>
