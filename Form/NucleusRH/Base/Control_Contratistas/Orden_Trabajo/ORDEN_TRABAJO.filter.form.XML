<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Ordenes de Trabajo" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_columnsORDEN_TRABAJO">
			<form:Column name="main_columnsORDEN_TRABAJOcolumn1">
				<form:Blank name="bk1"/>
				<form:ComboBox label="Empresa Contratista" queryname1="NucleusRH.Base.Control_Contratistas.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.INFO" label="Orden de Trabajo" nvalue="#source:@oi_orden_trabajo" name="oi_orden_trabajo" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox label="Tipo de Trabajo" queryname1="NucleusRH.Base.Control_Contratistas.Tipos_Trabajo.TIPO_TRABAJO.INFO" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_tipo_trabajo" name="oi_tipo_trabajo"/>
				<form:FKInput required="0" xsize="15" length="30" label="Unidad Organizativa OT" nvalue="#source:@oi_unidad_org_ot" name="oi_unidad_org_ot">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha Vigencia Desde" nvalue="#source:@f_vigencia_desde" name="f_vigencia_desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha Vigencia Hasta" nvalue="#source:@f_vigencia_hasta" name="f_vigencia_hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
</form:Form>
