<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.autoflow" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo">
	<flow:info label="Flow para NucleusRH.Base.Control_Contratistas.Orden_Trabajo"/>
	<flow:declare>
		<qry:define declare="&lt;DATOS oi_empresa=&quot;&quot; oi_orden_trabajo=&quot;&quot; oi_tipo_trabajo=&quot;&quot; f_vigencia_desde=&quot;&quot; f_vigencia_hasta=&quot;&quot; oi_unidad_org_ot=&quot;&quot; /&gt;" name="FILTER">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_orden_trabajo as oi_orden_trabajo, 
					SEC.policy 
				FROM 
					CCO03_ORDENES_TRAB as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO\') as SEC 
				JOIN 
					t0.oi_orden_trabajo LEFT OUTER SEC.id  
				WHERE
					{%? 
						(#SOURCE:@oi_empresa!='')	
						{% t0.oi_empresa = {#SOURCE:@oi_empresa} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_orden_trabajo!='')	
						{% t0.oi_orden_trabajo = {#SOURCE:@oi_orden_trabajo} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_tipo_trabajo!='')	
						{% t0.oi_tipo_trabajo = {#SOURCE:@oi_tipo_trabajo} AND %} 
						{% %} 
						%}       
					{%? 
						(#SOURCE:@f_vigencia_desde!='')	
						{% t0.f_vigencia_desde &gt;= {#SOURCE:@f_vigencia_desde} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@f_vigencia_hasta!='')	
						{% t0.f_vigencia_hasta &lt;= {#SOURCE:@f_vigencia_hasta} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_unidad_org_ot!='')	
						{% t0.oi_unidad_org_ot = {#SOURCE:@oi_unidad_org_ot} AND %} 
					{% %} 
					%}
					1 = 1  
				ORDER BY 
					oi_orden_trabajo asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_orden_trabajo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_empresa=&quot;&quot; oi_orden_trabajo=&quot;&quot; oi_tipo_trabajo=&quot;&quot; f_vigencia_desde=&quot;&quot; f_vigencia_hasta=&quot;&quot; oi_unidad_org_ot=&quot;&quot; /&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.Control_Contratistas.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Control_Contratistas.Tipos_Trabajo.TIPO_TRABAJO.INFO"/>
			<qry:include name="NucleusRH.Base.Control_Contratistas.Obras_Trabajo.OBRA_TRABAJO.INFO"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_orden_trabajo as oi_orden_trabajo, 
					t0.c_orden_trabajo as c_orden_trabajo, 
					t0.d_orden_trabajo as d_orden_trabajo, 
					t0.f_vigencia_desde as f_vigencia_desde, 
					t0.f_vigencia_hasta as f_vigencia_hasta, 
					SEC.policy, 
					t0.c_orden_trabajo as CODE, 
					t0.d_orden_trabajo as TEXT, 
					t0.oi_empresa as oi_empresa, 
					t0.oi_tipo_trabajo as oi_tipo_trabajo, 
					t0.oi_obra_trabajo as oi_obra_trabajo, 
					t0.oi_unidad_org_ot as oi_unidad_org_ot 
				FROM 
					CCO03_ORDENES_TRAB as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO\') as SEC 
				JOIN 
					t0.oi_orden_trabajo LEFT OUTER SEC.id  
				WHERE
					{%? 
						(#SOURCE:@oi_empresa!='')	
						{% t0.oi_empresa = {#SOURCE:@oi_empresa} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_orden_trabajo!='')	
						{% t0.oi_orden_trabajo = {#SOURCE:@oi_orden_trabajo} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_tipo_trabajo!='')	
						{% t0.oi_tipo_trabajo = {#SOURCE:@oi_tipo_trabajo} AND %} 
						{% %} 
						%}       
					{%? 
						(#SOURCE:@f_vigencia_desde!='')	
						{% t0.f_vigencia_desde &gt;= {#SOURCE:@f_vigencia_desde} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@f_vigencia_hasta!='')	
						{% t0.f_vigencia_hasta &lt;= {#SOURCE:@f_vigencia_hasta} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_unidad_org_ot!='')	
						{% t0.oi_unidad_org_ot = {#SOURCE:@oi_unidad_org_ot} AND %} 
					{% %} 
					%}
					1 = 1 
				ORDER BY 
					oi_orden_trabajo asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_orden_trabajo"/>
						<qry:attribute name="c_orden_trabajo" value="$r/@c_orden_trabajo"/>
						<qry:attribute name="d_orden_trabajo" value="$r/@d_orden_trabajo"/>
						<qry:attribute name="f_vigencia_desde" value="$r/@f_vigencia_desde"/>
						<qry:attribute name="f_vigencia_hasta" value="$r/@f_vigencia_hasta"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Control_Contratistas.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_tipo_trabajo!=''">
							<qry:then>
								<qry:element name="oi_tipo_trabajo">
									<qry:attribute name="OI_FIND" value="$r/@oi_tipo_trabajo"/>
									<qry:insert-select name="NucleusRH.Base.Control_Contratistas.Tipos_Trabajo.TIPO_TRABAJO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_trabajo" value="'['+oi_tipo_trabajo/ROW/@COD+'] '+oi_tipo_trabajo/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_obra_trabajo!=''">
							<qry:then>
								<qry:element name="oi_obra_trabajo">
									<qry:attribute name="OI_FIND" value="$r/@oi_obra_trabajo"/>
									<qry:insert-select name="NucleusRH.Base.Control_Contratistas.Obras_Trabajo.OBRA_TRABAJO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_obra_trabajo" value="'['+oi_obra_trabajo/ROW/@COD+'] '+oi_obra_trabajo/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:attribute name="oi_unidad_org_ot" value="$r/@oi_unidad_org_ot"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<DATOS oi_orden_trabajo="" oi_empresa="" f_vigencia_desde="" f_vigencia_hasta="" oi_tipo_trabajo="" oi_unidad_org_ot="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="" ATRIB_ORDEN4="" ORDEN4=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="ORDEN_TRABAJO">
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.filter.form:FILTER" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.filter.form" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.noreg.form:EDIT" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form:SHOW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form:LIST" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form:EDIT" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form:NEW" form-class="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.form" mode="NEW"/>
	</flow:group>
</flow:flow>
