<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.ORDEN_TRABAJO">
	<form:Right width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsORDEN_TRABAJO">
			<form:Link allowimg="1" policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/PER_CONT_OT/READ" label="Legajos Asignados" name="PER_CONT_OT">
				<form:Event policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/PER_CONT_OT/EDIT" action="CALL:PER_CONT_OT" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsORDEN_TRABAJO">
			<form:Column name="main_columnsORDEN_TRABAJOcolumn1">
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_orden_trabajo" name="c_orden_trabajo"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_orden_trabajo" name="d_orden_trabajo"/>
				<form:ComboBox queryname1="NucleusRH.Base.Control_Contratistas.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Empresa" nvalue="#source:oi_empresa/@value" name="oi_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.Control_Contratistas.Tipos_Trabajo.TIPO_TRABAJO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Tipo Trabajo" nvalue="#source:oi_tipo_trabajo/@value" name="oi_tipo_trabajo"/>
				<form:ComboBox queryname1="NucleusRH.Base.Control_Contratistas.Obras_Trabajo.OBRA_TRABAJO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Obra Trabajo" nvalue="#source:oi_obra_trabajo/@value" name="oi_obra_trabajo"/>
				<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Unidad Organizativa OT" nvalue="#source:oi_unidad_org_ot/@value" name="oi_unidad_org_ot">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Vigencia Desde" nvalue="#source:@f_vigencia_desde" name="f_vigencia_desde">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Vigencia Hasta" nvalue="#source:@f_vigencia_hasta" name="f_vigencia_hasta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_orden_trabajo" name="o_orden_trabajo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_orden_trabajo" name="c_orden_trabajo"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_orden_trabajo" name="d_orden_trabajo"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Empresa" attrname="oi_empresa" name="oi_empresa"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Tipo Trabajo" attrname="oi_tipo_trabajo" name="oi_tipo_trabajo"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Obra Trabajo" attrname="oi_obra_trabajo" name="oi_obra_trabajo"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Unidad Organizativa OT" attrname="oi_unidad_org_ot" name="oi_unidad_org_ot"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Vigencia Desde" attrname="f_vigencia_desde" name="f_vigencia_desde"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Vigencia Hasta" attrname="f_vigencia_hasta" name="f_vigencia_hasta"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Control_Contratistas/Orden_Trabajo/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
