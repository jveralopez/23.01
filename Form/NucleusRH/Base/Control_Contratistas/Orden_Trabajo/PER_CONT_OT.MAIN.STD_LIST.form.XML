<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.PER_CONT_OT.MAIN.STD_LIST.autoform" name="NucleusRH.Base.Control_Contratistas.Orden_Trabajo.PER_CONT_OT.MAIN.STD_LIST.form" default_mode="LIST" doc="source">
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Mostrar el Registro" img="search" label="Consultar" name="SHOW" visible="0">
					<form:Event action="RegShow" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Agregar un Registro" img="application_add.gif" label="Agregar" name="ADD" visible="!SELECT">
					<form:Event action="RegAdd" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Eliminar un Registro" img="application_delete.gif" label="Eliminar" name="DELETE" visible="!SELECT">
					<form:Event action="RegDelete" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Aceptar" img="accept.gif" label="Aceptar" name="ACCEPT" visible="SELECT">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="BB2" width="20px"/>
				<form:Button descrip="Cancelar" img="cancel.gif" label="Cancelar" name="CANCEL" visible="SELECT">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Volver" img="arrow_undo.gif" label="Salir" name="BACK" visible="LIST">
					<form:Event action="ActionBACK" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Anterior" img="arrow_left.gif" label="Anterior" name="PREV" visible="WIZARD">
					<form:Event action="ActionPREV" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Proximo" img="arrow_right.gif" label="Proximo" name="NEXT" visible="WIZARD">
					<form:Event action="ActionNEXT" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Finalizar" img="ok" label="Finalizar" name="END" visible="WIZARD">
					<form:Event action="ActionBACK" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
