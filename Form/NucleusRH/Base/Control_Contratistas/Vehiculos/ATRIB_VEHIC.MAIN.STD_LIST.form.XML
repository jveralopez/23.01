<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Control_Contratistas.Vehiculos.ATRIB_VEHIC.MAIN.STD_LIST.form" default_mode="LIST" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" name="GEN" label="Lista de Informaci&#243;n a Controlar"/>
				<form:Label nowrap="1" align="center" style="S2 LCol_w" dynamic="1" name="PAR"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center height="100%" width="95%">
		<form:Blank name="BLK1"/>
		<form:Grid visible="LIST" nvalue="#ATRIBUTO:" idvalue="#ATRIBUTO:@id" rows="10" doc="ATRIBUTO" name="MAIN_GRID" allowdel="0" allownew="0" paging="1">
			<form:GColumns>
				<form:GColumn name="gcoloi_atributo_ctrol">
					<form:TextBox enabled="0" nvalue="#ATRIBUTO:@descr" xsize="40" label="Atributo de Control" name="oi_atributo_ctrol"/>
				</form:GColumn>
				<form:GColumn name="gcolf_vencimiento">
					<form:DateTime nvalue="#ATRIBUTO:@f_vencimiento" name="f_vencimiento" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Vencimiento">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="gcolobservaciones">
					<form:TextBox ysize="0" xsize="50" nvalue="#ATRIBUTO:@o_atrib_vehic" label="Observaciones" name="o_atrib_vehic"/>
				</form:GColumn>
				<form:GColumn name="gcolrequerido">
					<form:TextBox label="Aplica a Veh&#237;culo" enabled="0" xsize="10" nvalue="#ATRIBUTO:@c_aplica_veh" name="c_aplica_veh"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Aceptar" label="Aceptar" name="ACCEPT" img="OK" visible="LIST">
					<form:Event action="ACCEPT" name="onClick" runat="server"/>
				</form:Button>
				<form:Button label="Cancelar" descrip="Cancelar" name="CANCEL" img="CANCEL" visible="LIST">
					<form:Event action="CANCEL" name="onClick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
