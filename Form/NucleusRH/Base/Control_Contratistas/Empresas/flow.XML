		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t1.oi_empresa as oi_empresa, 
				t1.c_empresa as B_c_empresa, 
				t1.d_empresa as B_d_empresa, 
				SEC.policy, 
				t1.c_empresa as CODE, 
				t1.d_empresa as TEXT,
				t0.f_alta as f_alta, 
				t0.f_baja as f_baja
			FROM 
				CCO01_EMPRESAS_CONT as t0,
				ORG03_EMPRESAS as t1,
				NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC 
			JOIN 
				t0.oi_empresa RIGHT OUTER t1.oi_empresa,
				t1.oi_empresa LEFT OUTER SEC.id  
			WHERE 
				t1.l_contratista = 1 
			ORDER BY 
				oi_empresa asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_empresa"/>
						<qry:attribute name="c_empresa" value="$r/@B_c_empresa"/>
						<qry:attribute name="d_empresa" value="$r/@B_d_empresa"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="f_alta" value="$r/@f_alta"/>
						<qry:attribute name="f_baja" value="$r/@f_baja"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_empresa as oi_empresa, 
					t1.oi_empresa as B_oi_empresa, 
					SEC.policy FROM CCO01_EMPRESAS_CONT as t0,
					ORG03_EMPRESAS as t1,
					NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC 
				JOIN 
					t0.oi_empresa RIGHT OUTER t1.oi_empresa,
					t1.oi_empresa LEFT OUTER SEC.id 
				WHERE 
					t1.l_contratista = 1 
				ORDER BY 
					oi_empresa asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="ID-CCO01_EMPRESAS_CONT" value="$r/@oi_empresa"/>
						<qry:attribute name="id" value="$r/@B_oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;SOURCE id=&quot;8&quot; /&gt;" name="GetAtributosControl">
			<qry:main doc="SOURCE">
				<qry:element name="ATRIBUTOS">
					<qry:insert-select name="qry_atributos_emp" doc-path="#SOURCE:."/>
					<qry:insert-select name="qry_atributos" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_atributos">
				<qry:xquery>
					for $r in SQL('          
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_emp as c_aplica_emp
from
  CCO05_ATRIB_CTROL
WHERE 
CCO05_ATRIB_CTROL.c_aplica_emp != \'N\'
AND 
   CCO05_ATRIB_CTROL.oi_atributo_ctrol not in
    (   
     select
     CCO05_ATRIB_CTROL.oi_atributo_ctrol
     from
     CCO05_ATRIB_CTROL,  CCO01_ATRIB_EMP_CON
     JOIN
     CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO01_ATRIB_EMP_CON.oi_atributo_ctrol
     WHERE 
     CCO01_ATRIB_EMP_CON.oi_empresa={%=#PARAM:@id%}
    )
 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ATRIBUTO">
						<qry:attribute name="oi_atrib_emp_con" value=""/>
						<qry:attribute name="id" value="$r/@ID"/>
						<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
						<qry:attribute name="c_aplica_emp" value="iif($r/@c_aplica_emp='S', 'Obligatorio', 'Opcional')"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_atributos_emp">
				<qry:xquery>
					for $r in SQL('          
select
  CCO05_ATRIB_CTROL.oi_atributo_ctrol as ID,
  CCO01_ATRIB_EMP_CON.oi_atrib_emp_con as oi_atrib_emp_con,
  CCO05_ATRIB_CTROL.c_atributo_ctrol as COD,
  CCO05_ATRIB_CTROL.d_atributo_ctrol as DES,
  CCO05_ATRIB_CTROL.c_aplica_emp as c_aplica_emp,
  CCO01_ATRIB_EMP_CON.oi_empresa,
  CCO01_ATRIB_EMP_CON.f_vencimiento,
  CCO01_ATRIB_EMP_CON.o_atrib_emp_con
from
  CCO05_ATRIB_CTROL,
  CCO01_ATRIB_EMP_CON
JOIN
  CCO05_ATRIB_CTROL.oi_atributo_ctrol inner CCO01_ATRIB_EMP_CON.oi_atributo_ctrol
WHERE 
 CCO01_ATRIB_EMP_CON.oi_empresa={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ATRIBUTO">
						<qry:attribute name="oi_atrib_emp_con" value="$r/@oi_atrib_emp_con"/>
						<qry:attribute name="id" value="$r/@ID"/>
						<qry:attribute name="descr" value="'['+$r/@COD+'] '+$r/@DES"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
						<qry:attribute name="f_vencimiento" value="$r/@f_vencimiento"/>
						<qry:attribute name="o_atrib_emp_con" value="$r/@o_atrib_emp_con"/>
						<qry:attribute name="c_aplica_emp" value="iif($r/@c_aplica_emp='S', 'Obligatorio', 'Opcional')"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="ATRIBUTO">
			<ATRIBUTOS/>
		</doc:define>
	</flow:declare>
