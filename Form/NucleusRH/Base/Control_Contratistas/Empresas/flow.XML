			<qry:xquery>
				for $r in sql('SELECT t0.oi_empresa as oi_empresa, t1.oi_empresa as B_oi_empresa, SEC.policy FROM CCO01_EMPRESAS_CONT as t0,ORG03_EMPRESAS as t1,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC JOIN t0.oi_empresa RIGHT OUTER t1.oi_empresa,t1.oi_empresa LEFT OUTER SEC.id  ORDER BY oi_empresa asc')/ROWS/ROW
			</qry:xquery>
