<form:Form xmlns:form="nomad_engine.form" default_mode="EDIT" extends="NucleusRH.Base.Control_Contratistas.Empresas.ATRIB_EMP_CON.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Control_Contratistas.Empresas.ATRIB_EMP_CON">
	<form:Center width="95%">
		<form:Grid nvalue="#ATRIBUTO:" idvalue="#ATRIBUTO:@id" rows="10" doc="ATRIBUTO" name="MAIN_GRID" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1">
			<form:GColumns>
				<form:GColumn name="gcoloi_atributo_ctrol">
					<form:TextBox nvalue="#ATRIBUTO:@descr" xsize="40" label="Atributo de Control" enabled="0" name="oi_atributo_ctrol"/>
				</form:GColumn>
				<form:GColumn name="gcolf_vencimiento">
					<form:DateTime nvalue="#ATRIBUTO:@f_vencimiento" name="f_vencimiento2" pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Vencimiento">
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="gcolo_atrib_emp_con">
					<form:TextBox enabled="NEW|EDIT" ysize="0" xsize="50" nvalue="#ATRIBUTO:@o_atrib_emp_con" label="Observaciones" name="o_atrib_emp_con"/>
				</form:GColumn>
				<form:GColumn name="gcolrequerido">
					<form:TextBox label="Aplica a Empresa" enabled="0" xsize="10" nvalue="#ATRIBUTO:@c_aplica_emp" name="c_aplica_emp"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Control_Contratistas/Empresas/ATRIB_EMP_CON/NEW" visible="0" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Control_Contratistas/Empresas/ATRIB_EMP_CON/DELETE" visible="0" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
