	<form:Scripts>
		&#13;&#10;function Guardar()
{  	
 	
 	if(Ctrl('f_inicio_act').GetXValue() != "")
 		if(Ctrl('f_inicio_act').GetXValue() &gt; Ctrl('f_alta').GetXValue())
 		{
 			alert("La fecha de inicio de la actividad debe ser menor o igual a la Fecha de Alta");
      return false;
 		}
 	if(Ctrl('f_cese_act').GetXValue() != "")
 		if(Ctrl('f_cese_act').GetXValue() &lt; Ctrl('f_baja').GetXValue())
 		{
 			alert("La fecha de cese de la actividad debe ser mayor o igual a la Fecha de Baja");
      return false;
 		}	
	Ctrl("main").DoEvent("SAVE");
}
	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
