<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Control_Contratistas.Interfaces.Importacion_Masiva_Personal_Contratista.flow" extends="Nomad.Base.flow" description="Flow para la carga masiva de personal contratista" default_action="initialize">
	<flow:info label="Flow para la carga de interfaces de variables de novedad para las personas."/>
	<flow:declare>
		<doc:define name="DATOSPER">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute to-attr-path="#DATOSPER:@file_name" from-value=""/>
			<flow:open-form form-class="NucleusRH.Base.Control_Contratistas.Interfaces.Importacion_Masiva_Personal_Contratista.form" doc-path="#DATOSPER:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Control_Contratistas.Interfaces.Importacion_Masiva_Personal_Contratista.form" name="NucleusRH.Base.Control_Contratistas.Interfaces.Importacion_Masiva_Personal_Contratista.form" doc="SOURCE" mode="EDIT">
		<flow:action name="VOLVER">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:exec-method class="NucleusRH.Base.Control_Contratistas.InterfaceImportacionPerCCO.ENTRADA" method="ImportarPersonalContratista" out-attr-path="#SOURCE:@batch-id" priority="5">
				<flow:param attr-path="#SOURCE:@oi_empresa" type="Nomad.NSystem.String" mode="in" name="poi_empresa"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
	</flow:form>
</flow:flow>
