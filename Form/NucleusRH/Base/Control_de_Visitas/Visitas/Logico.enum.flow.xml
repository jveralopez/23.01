<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="vhora">
	<flow:info label="Flow guia para Logico.combo"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry qry="COMBO" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:element name="OPT">
						<qry:attribute name="value" value="'1'" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="'1'" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="'Si'" type="Nomad.NSystem.String"/>
					</qry:element>
					<qry:element name="OPT">
						<qry:attribute name="value" value="'0'" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="'0'" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="'No'" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
</flow:flow>
