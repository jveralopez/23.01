<form:Form xmlns:form="nomad_engine.form" name="Visitas" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Visitas" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:DateTime name="f_des" nvalue="#FILTERDATA:@f_des" label="Fecha Desde" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_has" nvalue="#FILTERDATA:@f_has" label="Fecha Hasta" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox label="Personal Visitante" name="oi_visitante" nvalue="#FILTERDATA:@oi_visitante" queryname1="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.INFO" xsize="50" mode="QRY" required="0">
					<options/>
					<form:SButtons>
						<form:SButton enabled="NEW" visible="NEW" descrip="Crea un nuevo registro" img="new" name="CREATE">
							<form:Event action="CREATE" name="onclick" runat="server"/>
						</form:SButton>
					</form:SButtons>
				</form:ComboBox>
				<form:FKInput visible="0" label="Visitante" required="0" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_visitante" name="oi_visitante">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox label="Personal Visitado" nvalue="#FILTERDATA:@oi_personal_vis" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_CON_EMPRESA" xsize="50" mode="QRY" required="0" name="oi_personal_vis">
					<options/>
				</form:ComboBox>
				<form:ComboBox label="Personal Autorizante" nvalue="#FILTERDATA:@oi_personal_aut" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_CON_EMPRESA" xsize="50" mode="QRY" required="0" name="oi_personal_aut">
					<options/>
				</form:ComboBox>
				<form:Combo required="0" nvalue="#FILTERDATA:@estado_vis" label="Estado" name="estado_vis">
					<form:Opts name="opc">
						<OPT name="1" code="1" text="En curso" value="1"/>
						<OPT code="2" name="2" text="No iniciada" value="2"/>
						<OPT code="3" name="3" text="Vencida" value="3"/>
						<OPT name="4" code="4" value="4" text="Egresada"/>
						<OPT name="5" text="Exedida" code="5" value="5"/>
					</form:Opts>
				</form:Combo>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
