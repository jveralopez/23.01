		<qry:define declare="&lt;FILTRO&gt;&#13;&#10;&#9;&lt;VISITANTES/&gt;&#13;&#10; &#13;&#10;&lt;/FILTRO&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in table('
			SELECT VIS02_VISITANTES.oi_visitante oi_visitante 
			FROM VIS02_VISITANTES
			{%? (string(#PARAM:VISITANTES/VISITANTE/@id)!='') {% WHERE VIS02_VISITANTES.oi_visitante in ({%= string(#PARAM:VISITANTES/VISITANTE/@id) %}) %} {% %} %}
			ORDER BY VIS02_VISITANTES.oi_visitante ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_visitante" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO&gt;&lt;VISITANTES&gt;&lt;VISITANTE id=&quot;3&quot; /&gt;&lt;/VISITANTES&gt;&lt;/FILTRO&gt;" name="LIST">
