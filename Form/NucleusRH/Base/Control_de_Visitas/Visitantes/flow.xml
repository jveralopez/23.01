				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in table('SELECT VIS02_VISITANTES.oi_visitante oi_visitante, VIS02_VISITANTES.c_visitante c_visitante, VIS02_VISITANTES.c_nro_documento c_nro_documento, VIS02_VISITANTES.d_apellido d_apellido, VIS02_VISITANTES.d_nombres d_nombres, VIS02_VISITANTES.d_ape_y_nom d_ape_y_nom, VIS02_VISITANTES.d_empresa d_empresa, VIS02_VISITANTES.oi_tipo_documento oi_tipo_documento, VIS02_VISITANTES.oi_foto oi_foto 
			FROM VIS02_VISITANTES 
			{%? (string(#PARAM:VISITANTES/VISITANTE/@id)!='') {% WHERE VIS02_VISITANTES.oi_visitante in ({%= string(#PARAM:VISITANTES/VISITANTE/@id) %}) %} {% %} %}
			ORDER BY VIS02_VISITANTES.oi_visitante ASC')/ROWS/ROW
				</qry:xquery>
