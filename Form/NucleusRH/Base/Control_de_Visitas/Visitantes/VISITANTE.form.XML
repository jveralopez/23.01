<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.form" extends="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsVISITANTE">
			<form:Column name="main_columnsVISITANTEcolumn1">
				<form:TextBox visible="SHOW" required="1" enabled="0" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_visitante" name="c_visitante"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Apellido" nvalue="#source:@d_apellido" name="d_apellido">
					<form:Event runat="client" name="onchange" action="nombreyapellido"/>
				</form:TextBox>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Nombres" nvalue="#source:@d_nombres" name="d_nombres">
					<form:Event runat="client" name="onchange" action="nombreyapellido"/>
				</form:TextBox>
				<form:TextBox required="1" enabled="0" ysize="1" xsize="50" length="200" label="Apellido y Nombre" nvalue="#source:@d_ape_y_nom" name="d_ape_y_nom"/>
				<form:Image width="96" height="96" required="0" nvalue="#source:oi_foto/@value" name="oi_foto" label="Foto" enabled="NEW|EDIT" class="NucleusRH.Base.Personal.Imagenes.HEAD">
					<form:SButtons>
						<form:SButton descrip="Cargar Foto desde C&#225;mara" img="ok" visible="EDIT|NEW" name="sbLoad">
							<form:Event action="LOAD_PHOTO" name="onclick" runat="server"/>
						</form:SButton>
						<form:SButton descrip="Buscar Foto en Directorio" visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton descrip="Eliminar Foto" visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:Image>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_visitante" name="c_visitante"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Tipo Documento" attrname="oi_tipo_documento" name="oi_tipo_documento"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="N&#250;mero Documento" attrname="c_nro_documento" name="c_nro_documento"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Apellido" attrname="d_apellido" name="d_apellido"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Nombres" attrname="d_nombres" name="d_nombres"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Apellido y Nombre" attrname="d_ape_y_nom" name="d_ape_y_nom"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Empresa" attrname="d_empresa" name="d_empresa"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="50px" type="combo" label="Foto" attrname="oi_foto" name="oi_foto"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Scripts>
		function nombreyapellido ()
	{
		Ctrl('d_ape_y_nom').SetCValue(Ctrl('d_apellido').GetCValue()+', '+Ctrl('d_nombres').GetCValue());		
	}
	
function codigo ()
	{
		Ctrl('c_visitante').SetCValue(Ctrl('oi_tipo_documento').GetCValue()+', '+Ctrl('c_nro_documento').GetCValue());		
	}
	</form:Scripts>
</form:Form>
