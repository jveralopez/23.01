<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Postulantes.Parametros" extends="NucleusRH.Base.Organizacion.Parametros.autoflow">
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
			<doc:assign-value from-path="#QRY:" to-doc="PARAM"/>
			<flow:open-form doc-path="#QRY:" mode="SHOW" form-class="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="PARAM"/>
		<doc:define name="QRY"/>
		<doc:define name="FILTERDATA"/>
		<qry:define name="FILTER">
			<qry:main>
				<qry:element name="DATOS">
					<qry:insert-select name="CantDiasParaDisponible"/>
					<qry:insert-select name="CantDiasParaVencido"/>
					<qry:insert-select name="AcuerdoPrivacidad"/>
					<qry:insert-select name="MailOL"/>
				</qry:element>
			</qry:main>
			<qry:select name="CantDiasParaDisponible">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'CantDiasParaDisponible\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="CantDiasParaDisponibleID" value="$r/@oi_parametro"/>
					<qry:attribute name="CantDiasParaDisponible" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="CantDiasParaVencido">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'CantDiasParaVencido\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="CantDiasParaVencidoID" value="$r/@oi_parametro"/>
					<qry:attribute name="CantDiasParaVencido" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="AcuerdoPrivacidad">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'AcuerdoPrivacidad\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="AcuerdoPrivacidadID" value="$r/@oi_parametro"/>
					<qry:attribute name="AcuerdoPrivacidad" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="MailOL">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'MailOFLAB\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="MailOLID" value="$r/@oi_parametro"/>
					<qry:attribute name="MailOL" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:group Name="PARAMETRO">
		<flow:form form-class="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.form" name="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.form:SHOW" mode="SHOW" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="SAVE">
				<flow:exec-method class="NucleusRH.BaytonRH.Cliente.Clientes.CLIENTE" method="GuardarPOS">
					<flow:param type="Nomad.NSystem.Proxy.NomadXML" name="paramINI" doc="PARAM" mode="in"/>
					<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="SOURCE" name="paramOUT" mode="in"/>
				</flow:exec-method>
				<flow:close-form/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:close-form/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
