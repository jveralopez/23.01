<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Organizacion.Parametros.autoflow" name="NucleusRH.Base.Postulantes.Parametros">
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.filter.autoform"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&#9;&lt;FILTRO c_parametro=&quot;MinMinutosHora&quot;/&gt;" name="FILTER">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = {#PARAM:@c_parametro}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_parametro"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.filter.form:FILTER" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.filter.autoform" mode="FILTER">
		<flow:action name="FILTER">
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#SOURCE:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="open-flow-SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.autoform" mode="EDIT">
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.guia.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform:SHOW" form-class="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.guia.form" name="NucleusRH.Base.Postulantes.Parametros.PARAMETRO.guia.form:SHOW" mode="SHOW" doc="SOURCE" parent-doc="PARENTSOURCE"/>
</flow:flow>
