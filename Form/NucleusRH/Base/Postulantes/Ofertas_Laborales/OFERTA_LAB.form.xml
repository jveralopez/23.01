	<form:Scripts>
		function Validar(myThis) 
	{
		if (Ctrl('f_cierre').GetCValue() != "") 
		{
			if (Ctrl('f_cierre').TypedValue() &lt; new Date()) 
				{	
					myThis.SetError('La Fecha de cierre debe ser posterior a la Fecha de hoy.');
					return false;
				} else 
					return true;
		} else 
			return true;
	}


function CargarFecha()
{                               
	if (Ctrl('main').GetMode() != "LIST")
	{
		if (Ctrl('f_oferta_lab') != null &amp;&amp; Ctrl('f_oferta_lab').GetCValue() == "")
			{                                         
				Ctrl('f_oferta_lab').SetTypedValue(new Date());
			}
		CtrlEnabled('f_oferta_lab', false);
	}
	
	//if (Ctrl('main').GetMode() == "NEW")
	//	Ctrl('o_oferta_lab').SetXValue('TITULO:\nNOMBRE DEL PUESTO:\nEXPERIENCIA REQUERIDA:');
}

function validarCerrada(myThis)
{
 if (Ctrl('main').GetMode() == "SHOW")
 {
	 if (Ctrl('f_cierre').TypedValue() &lt; new Date() &amp;&amp; Ctrl('f_cierre').GetXValue() != "" )
	 {
	   alert('No puede modificar una oferta laboral cerrada.');
	   return false;
	 } 
 } 

 return true;
}              

function val_mail(me)
{
	if((Ctrl('main').getmode = "NEW") || (Ctrl('main').getmode = "EDIT"))
	{
		var mail = me.GetXValue();    
		
		
		if (mail.length!= 0)
		{				
			if (mail.split("@").length != 2)
			{
				me.SetError("El mail es inv&#225;lido");
				return false;
			}
			
			var array_mail = mail.split("@")
			if (array_mail[1].indexOf(".") &lt; 0)
			{
				me.SetError("El mail es inv&#225;lido");
				return false;
			}
			
			/* Verificar la existencia de caracteres. ( ) &lt; &gt; @ , ; : \ " . [ ] */
			var specialChars="\\(\\)&lt;&gt;@,;:\\\\\\\"\\.\\[\\]";
			var validChars="\[^\\s" + specialChars + "\]";
			var quotedUser="(\"[^\"]*\")";
		
			var atom=validChars + '+';
			var word="(" + atom + "|" + quotedUser + ")";
			var userPat=new RegExp("^" + word + "(\\." + word + ")*$");
		
		
			if (array_mail[0].match(userPat)==null)
			{
				me.SetError("El mail es inv&#225;lido");
				return false;
			}
		
			if (array_mail[1].match(userPat)==null)
			{
				me.SetError("El mail es inv&#225;lido");
				return false;
			}
			
			return true;
	  } 
	  else
	  	{
	  	return true;
	  	}
  }
  
}

function UpperCase()
{
	Ctrl("d_oferta_lab").SetXValue(Ctrl("d_oferta_lab").GetXValue().toUpperCase());
}
