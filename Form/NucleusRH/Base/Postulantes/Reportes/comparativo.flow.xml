	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Postulantes.Reportes.comparativo.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Postulantes.Reportes.comparativo.filter.form" form-class="NucleusRH.Base.Postulantes.Reportes.comparativo.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:set-attribute to-attr-path="#FILTERDATA:@id1" from-attr-path="#RS:ROW[@id={#FORM:ctrl[@id='LIST']/@xval}]/@oi_cv_web"/>
			<!--doc:load-qry output-doc="CV_OLD" input-doc-path="#FILTERDATA:" qry="qry_ddo"/-->
			<doc:set-attribute to-attr-path="#FILTERDATA:@id2" from-attr-path="#RS:ROW[@id={#FORM:ctrl[@id='LIST']/@xval}]/@oi_cv_int"/>
			<doc:load-object id-path="#FILTERDATA:@id1" class="NucleusRH.Base.Postulantes.CV.CV" doc="CV_OLD"/>
			<!--doc:load-qry output-doc="CV_NEW" input-doc-path="#FILTERDATA:" qry="qry_ddo"/-->
			<doc:load-object id-path="#FILTERDATA:@id2" class="NucleusRH.Base.Postulantes.CV.CV" doc="CV_NEW"/>
			<flow:exec-method class="NucleusRH.Base.Postulantes.CV.CV" out-doc="RESULTADO" method="Cv_Compare">
				<flow:param doc="CV_OLD" type="Nomad.NSystem.Object" mode="in" name="cv_old"/>
				<flow:param doc="CV_NEW" type="Nomad.NSystem.Object" mode="in" name="cv_new"/>
			</flow:exec-method>
			<flow:html-gen template-file="NucleusRH.Base.Postulantes.Comparativo.rpt" out-file-path="#FILTERDATA:@report" input-doc-path="#RESULTADO:"/>
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Postulantes.Reportes.comparativo.form" mode="REPORT"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<doc:load-qry output-doc="RS" input-doc-path="#FILTERDATA:" qry="cvs_duplicados"/>
			<flow:log text-path="#RS:" text="KKRS"/>
			<flow:attach-doc doc-path="#RS:" attach-id="RS"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Postulantes.Reportes.comparativo.form" form-class="NucleusRH.Base.Postulantes.Reportes.comparativo.form" mode="REPORT" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="MERGE">
			<doc:set-attribute to-attr-path="#AUX_CODE:@c_cv" from-attr-path="#CV_NEW:@c_cv"/>
			<doc:load-qry output-doc="AUX_CODE" input-doc-path="#AUX_CODE:" qry="SET_CODE"/>
			<doc:set-attribute to-attr-path="#CV_NEW:@c_cv" from-attr-path="#AUX_CODE:@c_cv"/>
			<doc:set-attribute from-attr-path="#CV_OLD:@c_nro_doc" to-attr-path="#CV_NEW:@c_nro_doc"/>
			<doc:set-attribute from-attr-path="#CV_OLD:@c_password" to-attr-path="#CV_NEW:@c_password"/>
			<doc:set-attribute from-attr-path="#CV_OLD:@f_actualizacion" to-attr-path="#CV_NEW:@f_actualizacion"/>
			<doc:set-attribute from-attr-path="#CV_OLD:@c_tipo_cv" to-attr-path="#CV_NEW:@c_tipo_cv"/>
			<flow:exec-method class="NucleusRH.Base.Postulantes.CV.CV" method="SincronizarCV">
				<flow:param doc="CV_OLD" mode="in" name="cv_web" type="Nomad.NSystem.Object"/>
				<flow:param doc="CV_NEW" mode="in" name="cv_interno" type="Nomad.NSystem.Object"/>
			</flow:exec-method>
			<flow:call-action action="BACK"/>
		</flow:action>
	</flow:form>
</flow:flow>
