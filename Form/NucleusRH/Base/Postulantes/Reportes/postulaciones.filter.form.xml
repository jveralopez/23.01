		</form:DateTime>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:ComboBox visible="EDIT" queryname1="NucleusRH.Base.Postulantes.Ofertas_Laborales.OFERTA_LAB.INFO" label="Oferta Laboral" nvalue="#source:@oi_oferta_lab" name="oi_oferta_lab" xsize="30" mode="QRY" required="1"/>
		<form:Line visible="EDIT" name="line_2" width="100%"/>
		<form:Tab visible="EDIT" name="ghgh">
			<form:Panels>
				<form:Panel selected="1" label="Datos Personales" name="DatosPersonales">
