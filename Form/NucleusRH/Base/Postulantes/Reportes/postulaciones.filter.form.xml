					<form:CheckBox nvalue="#source:@chkEstadoCivil" name="chkEstadoCivil" label="Estado Civil" note="" descrip=""/>
					<form:CheckBox nvalue="#source:@chkConocimientos" label="Datos de Conocimientos" name="chkConocimientos" note="" descrip=""/>
					<form:CheckBox label="Datos de Idiomas" nvalue="#source:@chkIdiomas" name="chkIdiomas" note="" descrip=""/>
					<form:CheckBox nvalue="#source:@chkEstudios" label="Datos de Estudios" name="chkEstudios" note="" descrip=""/>
					<form:Blank name="bl329230" width="100%" visible=""/>
					<form:RowAligner name="rowalignbtns">
						<form:Row name="rowbtns">
							<form:Button label="Marcar todos" enabled="" visible="" img="" name="btnSelTodos" note="" descrip="">
								<form:Event action="sel1" name="onclick" runat="client"/>
							</form:Button>
							<form:Blank name="bl329231" width="100%" visible=""/>
							<form:Button label="Desmarcar todos" enabled="" visible="" img="" name="btnDelTodos" note="" descrip="">
								<form:Event action="sel2" name="onclick" runat="client"/>
							</form:Button>
						</form:Row>
					</form:RowAligner>
				</form:Panel>
			</form:Panels>
		</form:Tab>
		<form:ComboBox visible="EDIT2" descrip="Formato de salida" label="Formato de salida" name="opcion" xsize="30" mode="OPT" required="1" nvalue="#source:@opcion">
