<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="Base.Postulantes.Reportes.curriculum" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Postulantes.Resportes.curriculum"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMS/>
		</doc:define>
		<doc:define name="PARAMETERS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form" mode="EDIT"/>
		</flow:action>
		<flow:action name="initialize_PDF">
			<flow:open-form mode="EDIT_PDF" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form"/>
		</flow:action>
		<flow:action name="initialize_cv">
			<flow:exec-method method="ExecReportHTMLOnline" out-type="Nomad.NSystem.String" out-attr-path="#SOURCE:@report" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Postulantes.Curriculum.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form" doc-path="#SOURCE:" mode="REPORT"/>
		</flow:action>
		<flow:action name="initialize_cv_PDF">
			<flow:log text="logReportCVExternalLuchoPre" text-path="#SOURCE:"/>
			<flow:exec-method method="GENERATE_XML_REPORT" class="NucleusRH.Base.Postulantes.CV.CV">
				<flow:param name="pXMLRep" type="Nomad.NSystem.Proxy.NomadXML" doc="SOURCE" mode="inout"/>
			</flow:exec-method>
			<flow:log text="logReportCVExternalLuchoPost" text-path="#SOURCE:"/>
			<flow:exec-method method="ExecReportFOOnline" out-type="Nomad.NSystem.String" out-attr-path="#PARAMETERS:@report" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Postulantes.Curriculum.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form mode="REPORT_PDF" form-class="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form" form-class="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Postulantes.Curriculum.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Postulantes.Reportes.curriculum" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Postulantes.Reportes.curriculum" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form mode="EDIT_PDF" name="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form:EDIT_PDF" form-class="NucleusRH.Base.Postulantes.Reportes.curriculum.filter.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@ruta"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@foto"/>
			<flow:log text="logReportCVLuchoPre" text-path="#FILTERDATA:"/>
			<flow:exec-method method="GENERATE_XML_REPORT" class="NucleusRH.Base.Postulantes.CV.CV">
				<flow:param name="pXMLRep" type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="inout"/>
			</flow:exec-method>
			<flow:log text="logReportCVLuchoPost" text-path="#FILTERDATA:"/>
			<flow:exec-method method="ExecReportFOOnline" out-type="Nomad.NSystem.String" out-attr-path="#PARAMETERS:@report" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Postulantes.Curriculum.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<!--flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
		<flow:param value="NucleusRH.Base.Postulantes.Curriculum.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
		<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
	</flow:exec-method>
	<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/-->
			<flow:open-form mode="REPORT_PDF" form-class="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Postulantes.Reportes.curriculum" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Postulantes.Reportes.curriculum" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form" mode="REPORT" name="vistaprevia.reporte" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form:REPORT_PDF" mode="REPORT_PDF" form-class="NucleusRH.Base.Postulantes.Reportes.VistaPrevia.form" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
