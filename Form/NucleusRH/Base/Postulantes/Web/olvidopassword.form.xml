<form:Form xmlns:form="nomad_engine.form" doc="InData" extends="NucleusRH.Base.Postulantes.Web.baseNoLogueado.form" name="formOlvidoPassword">
	<form:Event action="ONLOAD" runat="client" name="onload"/>
	<form:Scripts>
		function refreshUserName()
	{
		Ctrl("hidden_nombreusuario").SetXValue(Ctrl("cmb_tipodoc").GetXValue() + "_" + Ctrl("nrodoc").GetXValue());
	}
	function ONLOAD()
{
	if (Ctrl("f_hoy"))
		Ctrl("f_hoy").SetXValue(date2str(NowDate()));
}
	</form:Scripts>
	<form:Top width="100%">
		<form:Label align="center" nowrap="1" style="M3 LCol_w" name="topLabel" label="Recuperar contrase&#241;a"/>
	</form:Top>
	<form:Center width="50%">
		<form:Blank name="blank2"/>
		<form:Combo flow="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.combo.autoflow" action="COMBO" nvalue="#InData:@oi_tipo_documento" label="Tipo de documento" required="1" name="cmb_tipodoc">
			<form:Event action="refreshUserName" runat="client" name="onchange"/>
		</form:Combo>
		<form:NumberBox nvalue="#InData:@nrodoc" required="1" label="N&#250;mero" name="nrodoc">
			<form:Event action="refreshUserName" name="onchange" runat="client"/>
		</form:NumberBox>
		<form:Blank name="blank5"/>
		<form:Hidden nvalue="#InData:@nombre_usuario" name="hidden_nombreusuario"/>
		<form:Hidden name="f_hoy"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="ra1">
			<form:Row name="r1">
				<form:Button startvalidate="1" img="ok" label="Aceptar" name="aceptar">
					<form:Event runat="server" action="aceptar" name="onclick"/>
				</form:Button>
				<form:Blank name="blank3"/>
				<form:Button img="back" label="Volver" name="volver">
					<form:Event action="cancelar" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
