<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Estudios.ESTUDIO"/>
	<flow:declare>
		<qry:define declare="&lt;helper-mess oi_area_est=&quot;1&quot;/&gt;" name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:helper-mess"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG11_ESTUDIOS.oi_estudio, 
					ORG11_ESTUDIOS.c_estudio, 
					ORG11_ESTUDIOS.d_estudio 
				FROM 
					ORG11_ESTUDIOS
				WHERE
					ORG11_ESTUDIOS.oi_area_est = {#SOURCE:@oi_area_est}
				ORDER BY 
					d_estudio ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_estudio" name="id"/>
						<qry:attribute value="$r/@oi_estudio" name="value"/>
						<qry:attribute value="$r/@c_estudio" name="code"/>
						<qry:attribute value="$r/@d_estudio" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_ESTUDIO"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_ESTUDIO">
				<qry:xquery>
					for $r in sql('
				SELECT
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Estudios.ESTUDIO\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
