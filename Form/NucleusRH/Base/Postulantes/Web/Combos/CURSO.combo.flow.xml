<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Cursos.CURSO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Cursos.CURSO"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						ORG06_CURSOS.oi_curso, 
						ORG06_CURSOS.c_curso, 
						ORG06_CURSOS.d_curso 
					FROM 
						ORG06_CURSOS
					ORDER BY 
						d_curso ASC
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_curso" name="id"/>
						<qry:attribute value="$r/@oi_curso" name="value"/>
						<qry:attribute value="$r/@c_curso" name="code"/>
						<qry:attribute value="$r/@d_curso" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_CURSO"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_CURSO">
				<qry:xquery>
					for $r in sql('
					SELECT 
						NMD_SECURITY.policy 
					FROM
						NMD_SECURITY 
					WHERE 
						NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Cursos.CURSO\' 
						AND NMD_SECURITY.id={#PARAM:@id}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
