<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.guia" extends="Nomad.combo.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Nacionalidades.NACIONALIDAD"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					PER35_MOD_CONTR.oi_mod_contr, 
					PER35_MOD_CONTR.c_mod_contr, 
					PER35_MOD_CONTR.d_mod_contr
				FROM
					PER35_MOD_CONTR
				ORDER BY 
					d_mod_contr ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_mod_contr" name="id"/>
						<qry:attribute value="$r/@oi_mod_contr" name="value"/>
						<qry:attribute value="$r/@c_mod_contr" name="code"/>
						<qry:attribute value="$r/@d_mod_contr" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_MOD_CONTR"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_MOD_CONTR">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
