<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Nacionalidades.NACIONALIDAD.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Nacionalidades.NACIONALIDAD"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					ORG12_NACIONALID.oi_nacionalidad, 
					ORG12_NACIONALID.c_nacionalidad, 
					ORG12_NACIONALID.d_nacionalidad 
				FROM
					ORG12_NACIONALID
				ORDER BY 
					d_nacionalidad ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_nacionalidad" name="id"/>
						<qry:attribute value="$r/@oi_nacionalidad" name="value"/>
						<qry:attribute value="$r/@c_nacionalidad" name="code"/>
						<qry:attribute value="$r/@d_nacionalidad" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_NACIONALIDAD"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_NACIONALIDAD">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Nacionalidades.NACIONALIDAD\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
