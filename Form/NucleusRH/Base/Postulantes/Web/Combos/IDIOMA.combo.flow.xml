<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Idiomas.IDIOMA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Idiomas.IDIOMA"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					ORG20_IDIOMAS.oi_idioma, 
					ORG20_IDIOMAS.c_idioma, 
					ORG20_IDIOMAS.d_idioma 
				FROM 
					ORG20_IDIOMAS
				ORDER BY 
					d_idioma ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_idioma" name="id"/>
						<qry:attribute value="$r/@oi_idioma" name="value"/>
						<qry:attribute value="$r/@c_idioma" name="code"/>
						<qry:attribute value="$r/@d_idioma" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_IDIOMA"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_IDIOMA">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Idiomas.IDIOMA\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
