<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Postulantes.Areas_Laborales.AREA_LAB.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Postulantes.Areas_Laborales.AREA_LAB"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						POS05_AREAS_LAB.oi_area_lab, 
						POS05_AREAS_LAB.c_area_lab, 
						POS05_AREAS_LAB.d_area_lab 
					FROM 
						POS05_AREAS_LAB
					ORDER BY 
						d_area_lab ASC 
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_area_lab" name="id"/>
						<qry:attribute value="$r/@oi_area_lab" name="value"/>
						<qry:attribute value="$r/@c_area_lab" name="code"/>
						<qry:attribute value="$r/@d_area_lab" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_AREA_LAB"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_AREA_LAB">
				<qry:xquery>
					for $r in sql('
					SELECT 
						NMD_SECURITY.policy 
					FROM 
						NMD_SECURITY 
					WHERE 
						NMD_SECURITY.class=\'NucleusRH.Base.Postulantes.Areas_Laborales.AREA_LAB\' 
						AND NMD_SECURITY.id={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
