<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Localidades.ZONA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Localidades.ZONA"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG19_ZONAS.oi_zona, 
					ORG19_ZONAS.c_zona, 
					ORG19_ZONAS.d_zona 
				FROM 	
					ORG19_ZONAS
				ORDER BY 
					d_zona ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_zona" name="id"/>
						<qry:attribute value="$r/@oi_zona" name="value"/>
						<qry:attribute value="$r/@c_zona" name="code"/>
						<qry:attribute value="$r/@d_zona" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
