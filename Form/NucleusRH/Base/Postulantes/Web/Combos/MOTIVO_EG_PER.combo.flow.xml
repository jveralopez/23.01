<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					PER22_MOT_EG_PER.oi_motivo_eg_per, 
					PER22_MOT_EG_PER.c_motivo_eg_per, 
					PER22_MOT_EG_PER.d_motivo_eg_per 
				FROM 
					PER22_MOT_EG_PER
				ORDER BY 
					d_motivo_eg_per ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_motivo_eg_per" name="id"/>
						<qry:attribute value="$r/@oi_motivo_eg_per" name="value"/>
						<qry:attribute value="$r/@c_motivo_eg_per" name="code"/>
						<qry:attribute value="$r/@d_motivo_eg_per" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_MOTIVO_EG_PER"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_MOTIVO_EG_PER">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
