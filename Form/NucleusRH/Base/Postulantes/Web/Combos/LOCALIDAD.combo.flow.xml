<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Localidades.LOCALIDAD"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG19_LOCALIDADES.oi_localidad, 
					ORG19_LOCALIDADES.c_localidad, 
					ORG19_LOCALIDADES.d_localidad 
				FROM 
					ORG19_LOCALIDADES
				ORDER BY 
					d_localidad ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_localidad" name="id"/>
						<qry:attribute value="$r/@oi_localidad" name="value"/>
						<qry:attribute value="$r/@c_localidad" name="code"/>
						<qry:attribute value="$r/@d_localidad" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_LOCALIDAD"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_LOCALIDAD">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Localidades.LOCALIDAD\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
