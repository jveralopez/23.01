<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Postulantes.Seniority.SENIORITY.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Postulantes.Seniority.SENIORITY"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					POS04_SENIORITY.oi_seniority, 
					POS04_SENIORITY.c_seniority, 
					POS04_SENIORITY.d_seniority 
				FROM 
					POS04_SENIORITY
				ORDER BY 
					d_seniority ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_seniority" name="id"/>
						<qry:attribute value="$r/@oi_seniority" name="value"/>
						<qry:attribute value="$r/@c_seniority" name="code"/>
						<qry:attribute value="$r/@d_seniority" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_SENIORITY"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_SENIORITY">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Postulantes.Seniority.SENIORITY\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
