<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Paises.PAIS.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Paises.PAIS"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					ORG35_PAISES.oi_pais, 
					ORG35_PAISES.c_pais, 
					ORG35_PAISES.d_pais 
				FROM 
					ORG35_PAISES
				ORDER BY 
					d_pais ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_pais" name="id"/>
						<qry:attribute value="$r/@oi_pais" name="value"/>
						<qry:attribute value="$r/@c_pais" name="code"/>
						<qry:attribute value="$r/@d_pais" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_PAIS"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_PAIS">
				<qry:xquery>
					for $r in sql('
				SELECT 
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Paises.PAIS\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
