<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Estudios.ESTUDIO"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG43_AREAS_EST.oi_area_est, 
					ORG43_AREAS_EST.c_area_est, 
					ORG43_AREAS_EST.d_area_est 
				FROM 
					ORG43_AREAS_EST				
				ORDER BY 
					d_area_est ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_area_est" name="id"/>
						<qry:attribute value="$r/@oi_area_est" name="value"/>
						<qry:attribute value="$r/@c_area_est" name="code"/>
						<qry:attribute value="$r/@d_area_est" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_AREA_EST"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_AREA_EST">
				<qry:xquery>
					for $r in sql('
				SELECT
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
