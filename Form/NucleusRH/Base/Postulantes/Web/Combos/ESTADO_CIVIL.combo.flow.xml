<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
						SELECT 
							ORG22_EST_CIVIL.oi_estado_civil, 
							ORG22_EST_CIVIL.c_estado_civil, 
							ORG22_EST_CIVIL.d_estado_civil 
						FROM 
							ORG22_EST_CIVIL
						ORDER BY 
							d_estado_civil ASC
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@oi_estado_civil" name="id"/>
						<qry:attribute value="$r/@oi_estado_civil" name="value"/>
						<qry:attribute value="$r/@c_estado_civil" name="code"/>
						<qry:attribute value="$r/@d_estado_civil" name="text"/>
					</qry:element>
					<qry:insert-select doc-path="$r" name="SECURITY_ESTADO_CIVIL"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_ESTADO_CIVIL">
				<qry:xquery>
					for $r in sql('
						SELECT 
							NMD_SECURITY.policy 
						FROM 
							NMD_SECURITY 
						WHERE 
							NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL\' 
							AND NMD_SECURITY.id={#PARAM:@id}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
