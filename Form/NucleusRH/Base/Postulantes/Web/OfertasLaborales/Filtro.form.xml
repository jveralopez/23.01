<form:Form xmlns:form="nomad_engine.form" default_mode="LOGUEADO" doc="source" name="formBuscarOfertas">
	<form:Scripts>
		function countryChange()
{                     
	if (Ctrl("oi_pais").GetXValue() == "1")
	{
		Ctrl("oi_provincia").SetEnabled(true);
	}
	else
	{                              
		Ctrl("oi_provincia").SetCValue("");  
		Ctrl("oi_localidad").SetCValue("");  
		Ctrl("oi_provincia").SetEnabled(false);
		
	}
}

function stateChange()
{
	if (Ctrl("oi_provincia").GetXValue() != "1")
	{                                
		if (Ctrl("hid_oi_provincia").GetXValue() != Ctrl("oi_provincia").GetXValue()) 
			Ctrl("oi_localidad").SetCValue("");		
	}	
}

function ONLOAD()
{
	if (Ctrl("user"))
		Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
    
	  countryChange();
	  Ctrl("hid_oi_provincia").SetXValue(Ctrl("oi_provincia").GetXValue());
		stateChange();   
}

function SEARCH_LOCALIDAD()
{                            
	Ctrl('oi_localidad').ShowHelper();
}

function DEL_LOCALIDAD()
{
	Ctrl('oi_localidad').SetCValue("");
}

function CLEAN()
{
	Ctrl('oi_localidad').SetCValue("");
	Ctrl('palabraclave').SetCValue("");
	Ctrl('oi_pais').SetCValue("");
	Ctrl('oi_provincia').SetCValue("");
	Ctrl('oi_seniority').SetCValue("");
	Ctrl('oi_area_lab').SetCValue("");
	Ctrl('f_desde').SetCValue("");
	Ctrl('f_hasta').SetCValue("");
	Ctrl('combo_sexo').SetCValue("");
	
}

function detalle(oi_oferta)
{	              
	Ctrl('oi_oferta').SetXValue(oi_oferta);
	Ctrl('main').DoEvent('FILTER_DETALLE');
}
	</form:Scripts>
	<form:Title width="100%">
		<form:RowAligner visible="LOGUEADO" name="titleLinks_ra" width="100%">
			<form:Row name="titleLinks_r">
				<form:Blank width="100%" name="blankTitulo"/>
				<form:Label nowrap="1" style="S3 LCol_w" dynamic="1" name="user"/>
				<form:Blank width="40px" name="blk12"/>
				<form:Link startvalidate="1" style="1" name="titleLinks_logout" label="Salir">
					<form:Event action="titleClick_logout" name="onclick" runat="server"/>
				</form:Link>
				<form:Hidden name="nombre" nvalue="#DDO:@d_nombres"/>
				<form:Hidden name="apellido" nvalue="#DDO:@d_apellido"/>
			</form:Row>
		</form:RowAligner>
		<form:RowAligner visible="NOLOGUEADO" name="titleLinks_ra">
			<form:Row name="titleLinks_r">
				<form:Link nowrap="1" name="titleLinks_CV" style="1" label="CV">
					<form:Event action="titleClick_CV" name="onclick" runat="server"/>
				</form:Link>
				<form:Label nowrap="1" label="Ofertas laborales" name="titleLinks_OfertasLaborales" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Top width="100%">
		<form:Label label="Buscar Ofertas Laborales" align="center" nowrap="1" style="M3 LCol_w" name="topLabel"/>
	</form:Top>
	<form:Center height="100%" width="100%">
		<form:Blank name="blank1"/>
		<form:Columns width="100%" height="100%" name="main_columnsOFERTA_LAB">
			<form:Column height="100%" width="50%" name="column_rpt">
				<form:UrlControl height="100%" enabled="false" name="UrlControl02" label="UrlControl" width="100%" descrip="" nvalue="#QRY:@report" direct="1"/>
				<form:Hidden name="oi_oferta"/>
			</form:Column>
			<form:Column height="100%" width="50%" name="main_columnsOFERTA_LABcolumn1">
				<form:Label align="center" descrip="Para ver todas las Ofertas Laborales deje los campos en blanco" label="Para ver todas las Ofertas Laborales deje los campos en blanco" name="lbl_1"/>
				<form:TextBox descrip="Ingrese la palabra clave a buscar" xsize="40" nvalue="#source:@palabraclave" name="palabraclave" label="Buscar"/>
				<form:Label align="center" descrip="Buscar&#225; que el texto aparezca dentro de la Oferta Laboral" label="Buscar&#225; que el texto aparezca dentro de la Oferta Laboral" name="lbl_2"/>
				<form:Line name="aaasfwew" width="95%"/>
				<form:Blank name="a1"/>
				<form:Combo descrip="Ingrese el pa&#237;s a buscar" flow="NucleusRH.Base.Postulantes.Web.Combos.PAIS.combo.flow" nvalue="#source:@oi_pais" action="COMBO" required="0" label="Pa&#237;s" name="oi_pais">
					<form:Event action="countryChange" name="onchange" runat="client"/>
				</form:Combo>
				<form:Combo descrip="Ingrese la provincia a buscar" flow="NucleusRH.Base.Organizacion.Paises.PROVINCIA.combo.autoflow" nvalue="#source:@oi_provincia" action="COMBO" required="0" label="Provincia" name="oi_provincia">
					<form:Event action="stateChange" name="onchange" runat="client"/>
				</form:Combo>
				<form:Rower separation="2" name="rower_localidad" label="Localidad">
					<form:FKInput descrip="Ingrese la localidad a buscar" enabled="0" required="0" xsize="35" length="35" label="Localidad" nvalue="#source:@oi_localidad" name="oi_localidad">
						<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess code="{this.Text.1}" id="{this.XVal}" text="{this.CVal}" PARENTID="{oi_provincia.ReadXValue}"/>
						</form:Helper>
					</form:FKInput>
					<form:Link descrip="Seleccionar Localidad" allowimg="1" name="search_localidad" img="SEARCH">
						<form:Event action="SEARCH_LOCALIDAD" name="onclick" runat="client"/>
					</form:Link>
					<form:Link img="eliminate" allowimg="1" descrip="Borrar la localidad" name="del_localidad">
						<form:Event action="DEL_LOCALIDAD" name="onclick" runat="client"/>
					</form:Link>
				</form:Rower>
				<form:Combo visible="0" flow="NucleusRH.Base.Postulantes.Web.Combos.ZONA.combo.flow" nvalue="#source:@oi_zona" action="COMBO" required="0" label="Zona" name="oi_zona"/>
				<form:Combo visible="0" flow="NucleusRH.Base.Postulantes.Web.Combos.LOCALIDAD.combo.flow" nvalue="#source:@oi_localidad" action="COMBO" required="0" label="Localidad" name="oi_localidad"/>
				<form:Line name="aa23" width="95%"/>
				<form:Blank name="a2"/>
				<form:Combo visible="0" descrip="Ingrese la profesi&#243;n a buscar" label="Profesional" required="0" nvalue="#source:@profesional" name="profesional">
					<form:Opts name="opts">
						<OPT id="1" value="1" code="1" text="Si"/>
						<OPT id="0" value="0" code="0" text="No"/>
						<OPT id="3" value="3" code="3" text="Indistinto"/>
					</form:Opts>
				</form:Combo>
				<form:Combo descrip="Ingrese la jerarqu&#237;a a buscar" action="COMBO" flow="NucleusRH.Base.Postulantes.Web.Combos.SENIORITY.Combo.flow" required="0" label="Seniority" nvalue="#source:@oi_seniority" name="oi_seniority"/>
				<form:Combo descrip="Ingrese el &#225;rea laboral a buscar" action="COMBO" flow="NucleusRH.Base.Postulantes.Web.Combos.AREA_LAB.Combo.flow" required="0" label="Area" nvalue="#source:@oi_area_lab" name="oi_area_lab"/>
				<form:Line width="95%" name="aa2343"/>
				<form:Blank name="a4"/>
				<form:DateTime descrip="Ingrese la fecha desde a buscar" label="Fecha Desde" pattern="YYYYMMDD" required="0" descr="Fecha de Inactivaci&#243;n de la AFJP." mask="dd/mm/yyyy" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Fecha de Inactivaci&#243;n de la AFJP." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime descrip="Ingrese la fecha hasta a buscar" label="Fecha Hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo descrip="Ingrese el sexo a buscar" flow="NucleusRH.Base.Postulantes.CV.CV.c_sexo.combo.autoflow" nvalue="#source:@c_sexo" action="COMBO" required="0" name="combo_sexo" label="Sexo"/>
				<form:Hidden name="hid_oi_provincia"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="ra_buscarvolver">
			<form:Row name="r_buscarvolver">
				<form:Button img="eliminate" descrip="Limpiar los controles" label="Limpiar" name="CLEAN">
					<form:Event action="CLEAN" name="onclick" runat="client"/>
				</form:Button>
				<form:Button img="SEARCH" label="Buscar" name="FILTER">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Button name="volver" img="back" label="Volver">
					<form:Event action="volver" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Event action="FILTER_DETALLE" name="FILTER_DETALLE" runat="server"/>
</form:Form>
