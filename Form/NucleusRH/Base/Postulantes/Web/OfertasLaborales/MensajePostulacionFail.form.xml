<form:Form name="MensajeNoLogueado" doc="InData" xmlns:form="nomad_engine.form">
	<form:Scripts>
		function ONLOAD()
{
	if (Ctrl("user"))
		Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
}
	</form:Scripts>
	<form:Title width="100%">
		<form:RowAligner name="titleLinks_ra" width="100%">
			<form:Row name="titleLinks_r">
				<form:Blank width="100%" name="blankTitulo"/>
				<form:Label nowrap="1" style="S3 LCol_w" dynamic="1" name="user"/>
				<form:Blank width="40px" name="blk12"/>
				<form:Link startvalidate="1" style="1" name="titleLinks_logout" label="Salir">
					<form:Event action="titleClick_logout" name="onclick" runat="server"/>
				</form:Link>
				<form:Hidden name="nombre" nvalue="#DDO:@d_nombres"/>
				<form:Hidden name="apellido" nvalue="#DDO:@d_apellido"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Top width="100%">
		<form:Label label="Ofertas Laborales" align="center" nowrap="1" style="M3 LCol_w" name="topLabel"/>
	</form:Top>
	<form:Center width="100%">
		<form:Blank name="blank2"/>
		<form:Label align="center" label="Ya se encuentra postulado a la Oferta seleccionada" style="M2 LCol_t" name="lbl3"/>
	</form:Center>
	<form:Bottom>
		<form:Button startvalidate="1" img="ok" label="Aceptar" name="ACCEPT">
			<form:Event runat="server" action="ACCEPT" name="onclick"/>
		</form:Button>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
</form:Form>
