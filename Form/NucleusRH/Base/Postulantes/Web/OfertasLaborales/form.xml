<form:Form default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Postulantes.Ofertas_Laborales.OFERTA_LAB" xmlns:form="nomad_engine.form">
	<form:Scripts>
		function Find()
{
	Ctrl("LIST").filter("",Ctrl("iter-search").GetCValue());
}
function Imprimir()
{       
	Ctrl("LIST").toPrinter();
}
function ONLOAD()
{
	if (Ctrl("user"))
		Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
		
	if (Ctrl("LIST") &amp;&amp; Ctrl("LIST").TotalRowsCount() == 0)
	{	
		Ctrl("MOSTRAR").SetEnabled(false);
	}
}
	</form:Scripts>
	<form:Title width="100%">
		<form:RowAligner visible="LOGUEADO|MISPOSTULACIONES" name="titleLinks_ra" width="100%">
			<form:Row name="titleLinks_r">
				<form:Blank width="100%" name="blankTitulo"/>
				<form:Label nowrap="1" style="S3 LCol_w" dynamic="1" name="user"/>
				<form:Blank width="40px" name="blk12"/>
				<form:Link startvalidate="1" style="1" name="titleLinks_logout" label="Salir">
					<form:Event action="titleClick_logout" name="onclick" runat="server"/>
				</form:Link>
				<form:Hidden name="nombre" nvalue="#DDO:@d_nombres"/>
				<form:Hidden name="apellido" nvalue="#DDO:@d_apellido"/>
			</form:Row>
		</form:RowAligner>
		<form:RowAligner visible="NOLOGUEADO" name="titleLinks_ra">
			<form:Row name="titleLinks_r">
				<form:Link nowrap="1" name="titleLinks_CV" style="1" label="CV">
					<form:Event action="titleClick_CV" name="onclick" runat="server"/>
				</form:Link>
				<form:Label nowrap="1" label="Ofertas laborales" name="titleLinks_OfertasLaborales" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Top width="100%">
		<form:Label label="Ofertas Laborales" align="center" nowrap="1" style="M3 LCol_w" name="topLabel"/>
	</form:Top>
	<form:Center width="95%">
		<form:Blank name="blank_iter01"/>
		<form:Columns visible="NOLOGUEADO|LOGUEADO|SHOW|MISPOSTULACIONES" enabled="0" name="main_columnsOFERTA_LAB">
			<form:Column name="main_columnsOFERTA_LABcolumn1">
				<form:Blank name="dsaasdsad"/>
				<form:TextBox label="Referencia" required="0" enabled="0" descr="C&#243;digo de AFJP. Puede ser alfanum&#233;rico de hasta 30 caracteres." ysize="1" xsize="30" length="30" nvalue="#source:@c_oferta_lab" name="c_oferta_lab"/>
				<form:TextBox required="0" enabled="0" descr="Descripci&#243;n de AFJP. Puede ser alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Puesto" nvalue="#source:@d_oferta_lab" name="d_oferta_lab"/>
				<form:Combo enabled="NEW|EDIT" action="COMBO" flow="NucleusRH.Base.Postulantes.Web.Combos.PAIS.combo.flow" required="0" nvalue="#source:oi_pais/@value" name="oi_pais" label="Pais"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Paises.Provincias.combo.flow" required="0" nvalue="#source:oi_provincia/@value" name="oi_provincia" label="Provincia" enabled="0"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Postulantes.Web.Combos.ZONA.combo.flow" required="0" nvalue="#source:oi_zona/@value" name="oi_zona" label="Zona" enabled="NEW|EDIT"/>
				<form:Rower name="rower_localidad" label="Localidad de residencia">
					<form:FKInput nvalue="#source:oi_localidad/@value" enabled="0" required="0" xsize="50" length="50" label="Localidad" name="oi_localidad">
						<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess code="{this.Text.1}" id="{this.XVal}" text="{this.CVal}" PARENTID="{oi_provincia.ReadXValue}"/>
						</form:Helper>
					</form:FKInput>
				</form:Rower>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Postulantes.Web.Combos.SENIORITY.combo.flow" required="0" enabled="NEW|EDIT" label="Seniority" nvalue="#source:oi_seniority/@value" name="oi_seniority"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Postulantes.Areas_Laborales.AREA_LAB.Combo.autoflow" required="0" enabled="NEW|EDIT" label="Area" nvalue="#source:oi_area_lab/@value" name="oi_area_lab"/>
				<form:Combo enabled="NEW|EDIT" nvalue="#source:@c_sexo" flow="NucleusRH.Base.Postulantes.CV.CV.c_sexo.combo.autoflow" action="COMBO" required="0" name="combo_sexo" label="Sexo"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" descr="Fecha de Inactivaci&#243;n de la AFJP." mask="dd/mm/yyyy" label="Fecha Alta" nvalue="#source:@f_oferta_lab" name="f_oferta_lab">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha de Inactivaci&#243;n de la AFJP." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox label="Descripci&#243;n del Puesto" required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" nvalue="#source:@o_oferta_lab" name="o_oferta_lab"/>
				<form:DateTime visible="0" pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Cierre" nvalue="#source:@f_cierre" name="f_cierre">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:ListView visible="NOLOGUEADO_LIST|LOGUEADO_LIST" paging="1" rows="10" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" descr="C&#243;digo de AFJP. Puede ser alfanum&#233;rico de hasta 30 caracteres." width="100px" type="string" label="C&#243;digo" attrname="c_oferta_lab" name="c_oferta_lab"/>
				<form:LVColumn align="left" sorteable="1" descr="Descripci&#243;n de AFJP. Puede ser alfanum&#233;rico de hasta 100 caracteres." width="100px" type="string" label="Descripci&#243;n" attrname="d_oferta_lab" name="d_oferta_lab"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Area" attrname="area_lab" name="oi_area_lab"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Seniority" attrname="seniority" name="oi_seniority"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" descr="Fecha de Inactivaci&#243;n de la AFJP." width="50px" type="datetime" label="Fecha Alta" attrname="f_oferta_lab" name="f_oferta_lab"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Pa&#237;s" attrname="pais" name="oi_pais"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Provincia" attrname="provincia" name="oi_provincia"/>
				<form:LVColumn align="left" sorteable="1" width="50px" type="string" label="Localidad" attrname="localidad" name="oi_localidad"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="NOLOGUEADO_LIST|LOGUEADO_LIST" label="Detalle" descrip="Muestra el registro seleccionado" img="binocular" name="MOSTRAR">
					<form:Event action="SHOW" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea Postularse?" visible="LOGUEADO|LOGUEADO_LIST" img="new" label="Postularse" name="POSTULARSE">
					<form:Event action="POSTULARSE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Vuelve a la pantalla anterior del formulario" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="NOLOGUEADO_LIST|LOGUEADO_LIST" label="Imprimir" descrip="Imprimir la pantalla de lista" img="print" name="PRINT">
					<form:Event action="Imprimir" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
</form:Form>
