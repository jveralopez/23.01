	<form:Scripts>
		function validar()
{
	return Ctrl("main").Validate();
}                     

function ONLOAD()
{
	Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
	Ctrl("ultima_actualizacion").SetXValue("&#218;ltima actualizaci&#243;n: " + formatdatetime2str(Ctrl("f_actualizacion").GetXValue(), "YYYYMMDDHHMM", "/", ":"));
  
  if (Ctrl("LIST"))
  {
		var v = (Ctrl("LIST").shownRegs.length != 0);
		if (Ctrl("DELETE"))
		Ctrl("DELETE").SetEnabled(v);
		if (Ctrl("DETALLE"))
		Ctrl("DETALLE").SetEnabled(v);
	}	
		
	if (Ctrl("oi_provincia") &amp;&amp; Ctrl("oi_localidad") &amp;&amp; Ctrl("oi_pais"))
		if (Ctrl("oi_pais").GetXValue() != "1")
			{
				Ctrl("oi_provincia").SetXValue("");	
				Ctrl("oi_localidad").SetXValue("");	
				Ctrl("oi_provincia").SetEnabled(false);	
				Ctrl("oi_localidad").SetEnabled(false);
			}
			
}

function set_time()
{
	if (Ctrl("f_hoy"))
		Ctrl("f_hoy").SetXValue(datetime2str(Now()));		
	return true;
}
