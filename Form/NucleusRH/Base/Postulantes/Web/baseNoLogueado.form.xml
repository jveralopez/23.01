<form:Form xmlns:form="nomad_engine.form" name="formBaseNoLogueado">
	<form:Scripts>
		function ONLOAD()
{
	if (Ctrl("user"))
		Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
}
	</form:Scripts>
	<form:Title width="100%">
		<form:RowAligner name="titleLinks_ra">
			<form:Row name="titleLinks_r">
				<form:Link nowrap="1" name="titleLinks_CV" style="1" label="CV">
					<form:Event action="titleClick_CV" name="onclick" runat="server"/>
				</form:Link>
				<form:Link nowrap="1" name="titleLinks_OfertasLaborales" label="Ofertas laborales" style="1">
					<form:Event action="titleClick_OfertasLaborales" name="onclick" runat="server"/>
				</form:Link>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Bottom/>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
</form:Form>
