	<form:Event action="ONLOAD" runat="client" name="onload"/>
	<form:Resources>
		<form:Resource declare="&lt;DATA oi_area_est=&quot;1&quot;/&gt;" name="QRY_ESTUDIOS">
			<qry:main doc="SOURCE">
				<qry:element name="OPTS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
        SELECT
          ORG11_ESTUDIOS.oi_estudio,
          ORG11_ESTUDIOS.c_estudio,
          ORG11_ESTUDIOS.d_estudio
        FROM
          ORG11_ESTUDIOS
        WHERE
          ORG11_ESTUDIOS.oi_area_est = {#SOURCE:@oi_area_est}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute name="value" value="$r/@oi_estudio"/>
						<qry:attribute name="text" value="$r/@c_estudio + '-' + $r/@d_estudio"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
