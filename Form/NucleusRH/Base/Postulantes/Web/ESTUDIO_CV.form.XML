	<form:Scripts>
		function validar()
{
	return Ctrl("main").Validate();
}                     

function ONLOAD()
{
	Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
	Ctrl("ultima_actualizacion").SetXValue("&#218;ltima actualizaci&#243;n: " + formatdatetime2str(Ctrl("f_actualizacion").GetXValue(), "YYYYMMDDHHMM", "/", ":"));
  
  if (Ctrl("LIST"))
  {
		var v = (Ctrl("LIST").shownRegs.length != 0);
		if (Ctrl("DELETE"))
		Ctrl("DELETE").SetEnabled(v);
		if (Ctrl("DETALLE"))
		Ctrl("DETALLE").SetEnabled(v);
	}	
	
	if (Ctrl("oi_provincia") &amp;&amp; Ctrl("oi_localidad") &amp;&amp; Ctrl("oi_pais"))
		if (Ctrl("oi_pais").GetXValue() != "1")
			{
				Ctrl("oi_provincia").SetXValue("");	
				Ctrl("oi_localidad").SetXValue("");	
				Ctrl("oi_provincia").SetEnabled(false);	
				Ctrl("oi_localidad").SetEnabled(false);
			}            
	
	if(Ctrl("oi_estudio"))
	{
		CtrlEnabled("oi_area_est", true);
		if(Ctrl('oi_area_est').GetXValue()!= "")
	    {
	      if(Ctrl('oi_estudio').GetXValue()!= "")
	      {
	        var valor = Ctrl('oi_estudio').GetXValue();
	        setEstudio();
	        Ctrl('oi_estudio').SetXValue(valor);
	      }
	    }
	}
}

function val_f_fin_estudio(me)
{	
	if (Ctrl("oi_estado_est").GetXValue() != 1)
	{
		if (Ctrl("f_fin_estudio").GetXValue() == "")
		{
			me.SetError("Debe completar la fecha de Fin del Estudio");
			return false;
		}
	}
	return true;
}                         

function set_time()
{
	if (Ctrl("f_hoy"))
		Ctrl("f_hoy").SetXValue(datetime2str(new Date()));		
	return true;
}

function area_est_change()
{
  setEstudio();
}

function setEstudio()
{
  if (Ctrl("oi_area_est").GetXValue() != "")
  {
    var Param=new NomadXML("DATA");
    Param.SetAttr("oi_area_est", Ctrl("oi_area_est").GetXValue());

    var Data =new NomadXML();
    Data = GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_ESTUDIOS"), Param.ToString())

    Ctrl("oi_estudio").SetEnabled(true);
    Ctrl("oi_estudio").SetXValue("");
    Ctrl("oi_estudio").setOptions(String2DOM(Data.ToString()));
  }
  else
  {
    Ctrl("oi_estudio").SetXValue("");
    CtrlEnabled("oi_estudio", false);
  }
}        

function val_est_educ(Me)
{
	if (Me.GetXValue() == "")
	{
		Me.SetError("Debe especificar el establecimiento educativo");
		return false;
	}
	else return true;
}
