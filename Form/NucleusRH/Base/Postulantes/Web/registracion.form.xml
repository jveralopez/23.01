function ONLOAD()
{
	if (Ctrl("oi_provincia"))
		Ctrl("oi_provincia").SetEnabled(false);
	if (Ctrl("oi_localidad"))
		Ctrl("oi_localidad").SetEnabled(false);	
	if (Ctrl("combo_pais"))
	{		
		Ctrl("combo_pais").SetXValue("1");
	}
	
	countryChange();
	
	Ctrl("f_hoy").SetXValue(date2str(NowDate()));
}

function Capital_letter(me)
{
		var nombre = me.GetXValue()
		nombre = nombre.toLowerCase();
		var array_nombre = nombre.split(" ");
		sep = ""; nombre = "";
		for (var i = 0; i &lt; array_nombre.length; i++)
		{
			if (array_nombre[i] != "")
			{
				nombre += sep + array_nombre[i].substring(0,1).toUpperCase() + array_nombre[i].substring(1);
				sep = " ";
			}
		}
		me.SetXValue(nombre);
}

function val_mail(me)
{
	var mail = me.GetXValue();
					
	if (mail.split("@").length != 2)
	{
		alert("El mail es inv&#225;lido");
		return false;
	}
	
	var array_mail = mail.split("@")
	if (array_mail[1].indexOf(".") &lt; 0)
	{
		alert("El mail es inv&#225;lido");
		return false;
	}
	
	/* Verificar la existencia de caracteres. ( ) &lt; &gt; @ , ; : \ " . [ ] */
	var specialChars="\\(\\)&lt;&gt;@,;:\\\\\\\"\\.\\[\\]";
	var validChars="\[^\\s" + specialChars + "\]";
	var quotedUser="(\"[^\"]*\")";

	var atom=validChars + '+';
	var word="(" + atom + "|" + quotedUser + ")";
	var userPat=new RegExp("^" + word + "(\\." + word + ")*$");


	if (array_mail[0].match(userPat)==null) {
	alert("El mail es inv&#225;lido")
	return false
	}

	if (array_mail[1].match(userPat)==null) {
	alert("El mail es inv&#225;lido")
	return false
	}
	
	return true;
}

