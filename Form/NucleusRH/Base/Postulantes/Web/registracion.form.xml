		function countryChange()
{	
	if(Ctrl("combo_pais"))
	{
		if (Ctrl("combo_pais").GetXValue() == "1")
		{     
			Ctrl("oi_provincia").SetEnabled(true);		
			Ctrl("oi_localidad").SetEnabled(true);  
		}
		else
		{
			Ctrl("oi_provincia").SetCValue("");		
			Ctrl("oi_localidad").SetCValue("");
			Ctrl("oi_provincia").SetEnabled(false);		
			Ctrl("oi_localidad").SetEnabled(false);  
		}
	}
	return;
}              

                          
function aceptar()
{                   
	if (Ctrl("txt_email").GetXValue() != Ctrl("txt_repetiremail").GetXValue())
	{
		alert("El campo \"E-Mail\" no coincide con el campo \"Repetir E-Mail\"");
		Ctrl("txt_email").SetFocus();
		return;
	}
	
	if (Ctrl("txt_pass").GetXValue() != Ctrl("txt_reppass").GetXValue())
	{
		alert("El campo \"Contrase&#241;a\" no coincide con el campo \"Repetir Contrase&#241;a\"");
		Ctrl("txt_pass").SetFocus();
		return;
	}
	
	if (Ctrl("chk_privacidad").GetXValue() == "0" || Ctrl("chk_privacidad").GetXValue() == "")
	{
		alert("Debe aceptar el Acuerdo de Privacidad");
		Ctrl("chk_privacidad").SetFocus();
		return;
	}
	
	if (!val_mail(Ctrl("txt_email")))
	{
		Ctrl("txt_email").SetFocus();
		return false;
	}
	
	Ctrl("c_cv").SetCValue("WEB" + Ctrl("c_nro_doc").GetCValue());
	 
	Ctrl("main").DoEvent("aceptar");
	

}                 

