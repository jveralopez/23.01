			<form:TextBox required="1" enabled="NEW|EDIT" descr="Nombres del Emplado" ysize="1" xsize="50" length="100" label="Nombres" nvalue="#source:@d_nombres" name="d_nombres" X-POLICY="./FORM/NucleusRH/Base/Postulantes/Web/DatosPrincipales/form/d_nombres">
				<form:Event runat="client" name="onchange" action="nombreyapellido"/>
