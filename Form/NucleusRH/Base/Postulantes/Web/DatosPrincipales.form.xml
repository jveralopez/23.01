function Capital_letter(me)
{
    var nombre = me.GetXValue()
    nombre = nombre.toLowerCase();
    var array_nombre = nombre.split(" ");
    sep = ""; nombre = "";
    for (var i = 0; i &lt; array_nombre.length; i++)
    {
      if (array_nombre[i] != "")
      {
        nombre += sep + array_nombre[i].substring(0,1).toUpperCase() + array_nombre[i].substring(1);
        sep = " ";
      }
    }
    me.SetXValue(nombre);
}

