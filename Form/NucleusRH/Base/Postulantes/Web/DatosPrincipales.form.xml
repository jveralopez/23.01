		function validar()
{
  return Ctrl("main").Validate();
}

function ONLOAD()
{
  Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
  Ctrl("ultima_actualizacion").SetXValue("&#218;ltima actualizaci&#243;n: " + formatdatetime2str(Ctrl("f_actualizacion").GetXValue(), "YYYYMMDDHHMM", "/", ":"));
  
  SetEdad();
  if (Ctrl("LIST"))
  {
    var v = (Ctrl("LIST").shownRegs.length != 0);
    if (Ctrl("DELETE"))
    Ctrl("DELETE").SetEnabled(v);
    if (Ctrl("DETALLE"))
    Ctrl("DETALLE").SetEnabled(v);
  }
  else
  {
    if(Ctrl('oi_localidad').GetXValue()!= "")
    {
      if(Ctrl('oi_barrio').GetXValue()!= "")
      {
        var valor = Ctrl('oi_barrio').GetXValue();
        setBarrio();
        Ctrl('oi_barrio').SetXValue(valor);
      }
    } 
  }

 if (Ctrl("oi_provincia") &amp;&amp; Ctrl("oi_localidad") &amp;&amp; Ctrl("oi_pais"))
    if (Ctrl("oi_pais").GetXValue() != "1")
      {
        Ctrl("oi_provincia").SetXValue("");
        Ctrl("oi_localidad").SetXValue("");
        Ctrl("oi_provincia").SetEnabled(false);
        Ctrl("oi_localidad").SetEnabled(false);
      }
  if (Ctrl("oi_provincia").GetXValue() != "")
      Ctrl("hid_oi_provincia").SetCValue = Ctrl("oi_provincia").GetXValue();
  else
    Ctrl("hid_oi_provincia").SetCValue("");
 
  if (Ctrl("oi_provincia_nac") &amp;&amp; Ctrl("oi_localidad_nac") &amp;&amp; Ctrl("oi_pais_nac"))
	{
		if (Ctrl("oi_pais_nac").GetXValue() != "1")
		{
		  Ctrl("oi_provincia_nac").SetXValue("");
		  Ctrl("oi_localidad_nac").SetXValue("");
		  Ctrl("oi_provincia_nac").SetEnabled(false);
		  Ctrl("oi_localidad_nac").SetEnabled(false);
		}
	}  
	if (Ctrl("oi_provincia_nac").GetXValue() != "")
      Ctrl("hid_oi_provincia_nac").SetCValue = Ctrl("oi_provincia_nac").GetXValue();
  else
    Ctrl("hid_oi_provincia_nac").SetCValue("");   
}

function countryChange()
{
  if (Ctrl("oi_pais").GetXValue() == "1")
  {
    Ctrl("oi_provincia").SetEnabled(true);
    Ctrl("oi_localidad").SetEnabled(true);
  }
  else
  {
    Ctrl("oi_provincia").SetCValue("");
    Ctrl("oi_provincia").SetEnabled(false);
    Ctrl("oi_localidad").SetCValue("");
    Ctrl("oi_localidad").SetEnabled(false);
  }
}

function countryChange_nac()
{
  if (Ctrl("oi_pais_nac").GetXValue() == "1")
  {
    Ctrl("oi_provincia_nac").SetEnabled(true);
    Ctrl("oi_localidad_nac").SetEnabled(true);
  }
  else
  {
    Ctrl("oi_provincia_nac").SetCValue("");
    Ctrl("oi_provincia_nac").SetEnabled(false);
    Ctrl("oi_localidad_nac").SetCValue("");
    Ctrl("oi_localidad_nac").SetEnabled(false);
  }
}


