      if ((d&lt;'0') || (d&gt;'9')) return false;
    }
    return true;
  }

function val_mail(me)
{
  var mail = me.GetXValue();

  if (mail == "") return true;

  if (mail.split("@").length != 2)
  {
    me.SetError("El mail es inv&#225;lido");
    return false;
  }

  var array_mail = mail.split("@")
  if (array_mail[1].indexOf(".") &lt; 0)
  {
    me.SetError("El mail es inv&#225;lido");
    return false;
  }

  /* Verificar la existencia de caracteres. ( ) &lt; &gt; @ , ; : \ " . [ ] */
  var specialChars="\\(\\)&lt;&gt;@,;:\\\\\\\"\\.\\[\\]";
  var validChars="\[^\\s" + specialChars + "\]";
  var quotedUser="(\"[^\"]*\")";

  var atom=validChars + '+';
  var word="(" + atom + "|" + quotedUser + ")";
  var userPat=new RegExp("^" + word + "(\\." + word + ")*$");

  if (array_mail[0].match(userPat)==null) {
    me.SetError("El mail es inv&#225;lido");
    return false;
  }

  if (array_mail[1].match(userPat)==null) {
    me.SetError("El mail es inv&#225;lido");
    return false;
  }

  return true;
}

