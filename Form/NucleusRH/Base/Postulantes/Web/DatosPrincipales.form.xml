			<form:Combo visible="0" action="COMBO" flow="NucleusRH.Base.Personal.Grupos_Sanguineos.GRUPO_SANGUINEO.Combo.autoflow" required="0" enabled="NEW|EDIT" label="Grupo Sanguineo" nvalue="#source:oi_grupo_sanguineo/@value" name="oi_grupo_sanguineo" X-POLICY="./FORM/NucleusRH/Base/Postulantes/Web/DatosPrincipales/form/oi_grupo_sanguineo"/>
