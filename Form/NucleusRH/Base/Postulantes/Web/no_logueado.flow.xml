					</qry:element>
					<qry:element name="ROWS">
						<qry:insert-select doc-path="../ROWSSIN" name="PalabraClave"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="Filtrar" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG35_PROVINCIAS.d_provincia,
					ORG19_LOCALIDADES.d_localidad,
					ORG35_PAISES.d_pais,
					ORG19_ZONAS.d_zona,
					POS04_SENIORITY.d_seniority,
					POS05_AREAS_LAB.d_area_lab,
					POS03_OFERTAS_LAB.f_oferta_lab,
					POS03_OFERTAS_LAB.f_cierre,
					POS03_OFERTAS_LAB.oi_oferta_lab,
					POS03_OFERTAS_LAB.c_sexo,
					POS03_OFERTAS_LAB.c_oferta_lab,
					POS03_OFERTAS_LAB.d_oferta_lab,
					POS03_OFERTAS_LAB.o_oferta_lab 
				FROM 
					POS03_OFERTAS_LAB, 
					ORG35_PAISES, 
					ORG35_PROVINCIAS,
					ORG19_LOCALIDADES, 
					ORG19_ZONAS, 
					POS04_SENIORITY, 
					POS05_AREAS_LAB
				JOIN
					POS03_OFERTAS_LAB.oi_pais LEFT OUTER ORG35_PAISES.oi_pais,
				  POS03_OFERTAS_LAB.oi_provincia LEFT OUTER ORG35_PROVINCIAS.oi_provincia,
				  POS03_OFERTAS_LAB.oi_localidad LEFT OUTER ORG19_LOCALIDADES.oi_localidad,
				  POS03_OFERTAS_LAB.oi_zona LEFT OUTER ORG19_ZONAS.oi_zona,
				 	POS03_OFERTAS_LAB.oi_seniority LEFT OUTER POS04_SENIORITY.oi_seniority,
					POS03_OFERTAS_LAB.oi_area_lab LEFT OUTER POS05_AREAS_LAB.oi_area_lab				  
				WHERE 1=1                 
				{%? (#SOURCE:@oi_oferta_lab != '')	
					{% AND POS03_OFERTAS_LAB.oi_oferta_lab = {#SOURCE:@oi_oferta_lab} %} 
					{% %} 
				%}  								
				{%? (#SOURCE:@oi_pais != '')	
					{% AND POS03_OFERTAS_LAB.oi_pais={%=#SOURCE:@oi_pais %} %} 
					{% %} 
				%} 
				{%? (#SOURCE:@oi_provincia != '')	
					{% AND POS03_OFERTAS_LAB.oi_provincia={%=#SOURCE:@oi_provincia %} %} 
					{% %} 
				%}
				{%? (#SOURCE:@oi_localidad != '')	
					{% AND POS03_OFERTAS_LAB.oi_localidad={%=#SOURCE:@oi_localidad %} %} 
					{% %} 
				%}
				{%? (#SOURCE:@oi_zona != '')	
					{% AND POS03_OFERTAS_LAB.oi_zona={%=#SOURCE:@oi_zona %} %} 
					{% %} 
				%}
				{%? (#SOURCE:@oi_seniority != '')	
					{% AND POS03_OFERTAS_LAB.oi_seniority={%=#SOURCE:@oi_seniority %} %} 
					{% %} 
				%}
				{%? (#SOURCE:@oi_area_lab != '')	
					{% AND POS03_OFERTAS_LAB.oi_area_lab={%=#SOURCE:@oi_area_lab %} %} 
					{% %} 
				%}
				{%? (#SOURCE:@f_desde != '')	
					{% AND POS03_OFERTAS_LAB.f_oferta_lab &gt;= {#SOURCE:@f_desde} %} 
					{% %} 
				%}
				{%? (#SOURCE:@f_hasta != '')	
					{% AND POS03_OFERTAS_LAB.f_oferta_lab &lt;= {#SOURCE:@f_hasta} %} 
					{% %} 
				%} 
				{%? (#SOURCE:@c_sexo != '')	
					{% AND POS03_OFERTAS_LAB.c_sexo = {#SOURCE:@c_sexo} %} 
					{% %}
				%}
        AND (ISNULL(POS03_OFERTAS_LAB.f_cierre)
        	OR POS03_OFERTAS_LAB.f_cierre &gt;= now())
        ORDER BY f_oferta_lab DESC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@d_provincia" name="provincia"/>
						<qry:attribute value="$r/@d_localidad" name="localidad"/>
						<qry:attribute value="$r/@d_pais" name="pais"/>
						<qry:attribute value="$r/@d_zona" name="zona"/>
						<qry:attribute value="$r/@d_seniority" name="seniority"/>
						<qry:attribute value="$r/@l_profesional" name="profesional"/>
						<qry:attribute value="$r/@d_area_lab" name="area_lab"/>
						<qry:attribute name="d_oferta_lab" value="$r/@d_oferta_lab"/>
						<qry:attribute value="format_date($r/@f_oferta_lab, 'dd/mm/yyyy')" name="f_oferta_lab"/>
						<qry:attribute value="format_date($r/@f_cierre, 'dd/mm/yyyy')" name="f_cierre"/>
						<qry:attribute value="$r/@oi_oferta_lab" name="oi_oferta_lab"/>
						<qry:attribute value="$r/@c_sexo" name="c_sexo"/>
						<qry:attribute value="$r/@c_oferta_lab" name="c_oferta_lab"/>
						<qry:attribute value="$r/@o_oferta_lab" name="o_oferta_lab"/>
					</qry:element>
				</qry:out>
			</qry:select>
