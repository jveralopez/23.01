	<form:Scripts>
		function validar()
{
	return Ctrl("main").Validate();
}                     

function ONLOAD()
{
	Ctrl("user").SetXValue("Usuario: " + Ctrl("nombre").GetXValue() + " " + Ctrl("apellido").GetXValue());
	Ctrl("ultima_actualizacion").SetXValue("&#218;ltima actualizaci&#243;n: " + formatdatetime2str(Ctrl("f_actualizacion").GetXValue(), "YYYYMMDDHHMM", "/", ":"));
  
  if (Ctrl("LIST"))
  {
		var v = (Ctrl("LIST").shownRegs.length != 0);
		if (Ctrl("DELETE"))
		Ctrl("DELETE").SetEnabled(v);
		if (Ctrl("DETALLE"))
		Ctrl("DETALLE").SetEnabled(v);
	}	
		
	if (Ctrl("oi_provincia") &amp;&amp; Ctrl("oi_localidad") &amp;&amp; Ctrl("oi_pais"))
		if (Ctrl("oi_pais").GetXValue() != "1")
			{
				Ctrl("oi_provincia").SetXValue("");	
				Ctrl("oi_localidad").SetXValue("");	
				Ctrl("oi_provincia").SetEnabled(false);	
				Ctrl("oi_localidad").SetEnabled(false);
			}
			
}


function FilterGrid()
{    
	Ctrl("LIST1").filter("",Ctrl("buscar").GetCValue());
	Ctrl("btn_add").SetEnabled(Ctrl("LIST1").shownRegs.length==0?false:true);
}

function save_page()
{
	// Obtengo el primer row de la pagina	
	var fst_row = Ctrl("LIST1").pageOfSelectedRow() * Ctrl("LIST1").regsPerPage;

	// Obtengo los ids de los rows	
	var sel_value = Ctrl("LIST1").GetXValue();
	var fst_value = Ctrl("LIST1").GetAttrValue(fst_row, "id");

	// Si los ids son iguales esta seleccionado el primer row de la pag
	// Paso al segundo registro de la pag	
	if (sel_value == fst_value)
	{		
		fst_row += 1; 
	}
	
	// Guardo el id en un hidden
	if (fst_row &lt;= Ctrl("LIST1").allRegs.length)
	{
		Ctrl("page_num").SetXValue(Ctrl("LIST1").GetAttrValue(fst_row, "id"));
	}
	
	// Ejecuta la accion del server
	Ctrl("main").DoEvent("ADD_AREA");	
}

function set_time()
{
	if (Ctrl("f_hoy"))
		Ctrl("f_hoy").SetXValue(datetime2str(new Date()));		
	return true;
}
