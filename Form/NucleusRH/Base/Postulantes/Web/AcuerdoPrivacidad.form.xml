<form:Form xmlns:form="nomad_engine.form" doc="SOURCE" default_mode="EDIT" extends="NucleusRH.Base.Postulantes.Web.baseNoLogueado.form" name="formRegistracionExitosa">
	<form:Scripts>
		function onload()
{
	if (Ctrl("acuerdoPrivacidad").GetXValue() != "")
		Ctrl("acuerdoPrivacidadURL").SetURL("../../../NomadFile.aspx?ut="+GetProxy().UserToken()+"&amp;mode=DB&amp;class=NucleusRH.Base.Postulantes.DocumentosDigitales.HEAD&amp;id="+Ctrl("acuerdoPrivacidad").GetXValue());
	return true;
}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="titleLinks_ra" width="100%">
			<form:Row name="titleLinks_r">
				<form:Link nowrap="1" infomess="0" mess="Esta seguro que desea Salir? Considere que se perderan los datos" name="titleLinks_CV" style="1" label="CV">
					<form:Event action="titleClick_CV" name="onclick" runat="server"/>
				</form:Link>
				<form:Link nowrap="1" mess="Esta seguro que desea Salir? Considere que se perderan los datos" infomess="0" name="titleLinks_OfertasLaborales" label="Ofertas laborales" style="1">
					<form:Event action="titleClick_OfertasLaborales" name="onclick" runat="server"/>
				</form:Link>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Top>
		<form:Label label="Acuerdo de Privacidad" align="center" nowrap="1" style="M3 LCol_w" name="topLabel"/>
	</form:Top>
	<form:Center height="100%" width="100%">
		<form:UrlControl width="100%" height="100%" direct="1" name="acuerdoPrivacidadURL"/>
		<form:Hidden name="acuerdoPrivacidad" nvalue="#SOURCE:@oi_documento_digital"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rows">
			<form:Row name="row1">
				<form:Button name="cerrar" label="Cerrar" img="back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
