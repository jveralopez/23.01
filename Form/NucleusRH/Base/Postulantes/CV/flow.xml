					<flow:param value="NucleusRH.Base.RecordCardPostulantes.CambiosPostulantes.ACCION_REAL" type="Nomad.NSystem.String" mode="in" name="claseRC"/>
				</flow:exec-method>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Postulantes.CV.CV.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.form:NEW" form-class="NucleusRH.Base.Postulantes.CV.CV.form" mode="NEW">
			<flow:action name="save-DDO">
				<doc:set-attribute from-value="Nuevo Postulante" to-attr-path="#NEWDDOROOT:@d_mot_cambio"/>
				<doc:set-attribute from-value="INT" to-attr-path="#NEWDDOROOT:@c_origen"/>
				<doc:save-object class="NucleusRH.Base.Postulantes.CV.CV" doc="NEWDDOROOT"/>
				<doc:load-object id-path="#NEWDDOROOT:@id" class="NucleusRH.Base.Postulantes.CV.CV" doc="DDO"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@id" to-attr-path="#RecordCard:@id"/>
				<flow:exec-method class="NucleusRH.Base.RecordCard.AccionesReales.ACCION_REAL" method="GuardarAccion">
					<flow:param value="EstadoPostulantes" mode="in" name="accion" type="Nomad.NSystem.String"/>
					<flow:param doc-path="#RecordCard:" type="Nomad.NSystem.Object" mode="in" name="parametrosQry"/>
					<flow:param value="NucleusRH.Base.RecordCardPostulantes.EstadoPostulantes.ACCION_REAL" type="Nomad.NSystem.String" mode="in" name="claseRC"/>
				</flow:exec-method>
				<flow:call-action action="SaveRecordCard"/>
				<flow:exec-method method="SET_CAMPO_LIKE" class="NucleusRH.Base.Postulantes.CV.CV">
					<flow:param attr-path="#NEWDDOROOT:@id" name="pstrOiCV" type="Nomad.NSystem.String" mode="in"/>
					<flow:param value="A" name="pstriOiNivelEstudio" type="Nomad.NSystem.String" mode="in"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="SaveRecordCard">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#RecordCard:@id"/>
				<doc:set-attribute from-value="Se cre&#243; el CV" to-attr-path="#RecordCard:@o_accion"/>
				<flow:exec-method class="NucleusRH.Base.RecordCard.AccionesReales.ACCION_REAL" method="GuardarAccion">
					<flow:param value="CambiosPostulantes" mode="in" name="accion" type="Nomad.NSystem.String"/>
					<flow:param doc-path="#RecordCard:" type="Nomad.NSystem.Object" mode="in" name="parametrosQry"/>
					<flow:param value="NucleusRH.Base.RecordCardPostulantes.CambiosPostulantes.ACCION_REAL" type="Nomad.NSystem.String" mode="in" name="claseRC"/>
				</flow:exec-method>
