<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="NucleusRH.Base.Postulantes.CV.autoflow" name="NucleusRH.Base.Postulantes.CV.flow">
	<flow:info label="Flow para NucleusRH.Base.Postulantes.CV"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						t0.oi_cv as oi_cv
						, t0.c_cv as CODE
						, SEC.policy 
					FROM 
						POS01_CV as t0
						,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.CV.CV\') as SEC 
					JOIN 
						t0.oi_cv LEFT OUTER SEC.id
					WHERE
						t0.oi_cv in ({%=string(#PARAM:ROWS/ROW/@id) %})
					ORDER BY 
						CODE asc
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_cv"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;  &lt;ROW id=&quot;96&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;97&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;98&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;99&quot; /&gt;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;" name="LIST">
			<qry:include name="NucleusRH.Base.Personal.Grupos_Sanguineos.GRUPO_SANGUINEO.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.ColorDeOjos.COLOR_OJOS.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.ColorDePelo.COLOR_PELO.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.MotivacionBusqueda.MOT_BUSQUEDA.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.TipoDeMovilidad.TIPO_MOVI.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.TipoDeLicencia.TIPO_LICENCIA.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.TipoDeRemuneracion.TIPO_REMUN.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.Contacto_Web.CONT_WEB.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Nacionalidades.NACIONALIDAD.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Localidades.BARRIO.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PAIS.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PAIS.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Idiomas.IDIOMA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.AFJP.AFJP.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.Obras_Sociales.OBRA_SOCIAL.INFO"/>
			<qry:include name="NucleusRH.Base.Postulantes.MotivoCamEstadoCV.MOT_CAMBIO.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.INFO"/>
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_cv as oi_cv
					, t0.d_ape_y_nom as d_ape_y_nom
					, t0.c_nro_doc as c_nro_doc
					, t0.c_estado as c_estado
					, t0.c_sexo as c_sexo
					, t0.f_est_civil as f_est_civil
					, t0.d_tiempo_inc as d_tiempo_inc
					, t0.d_calle_1 as d_calle_1
					, t0.d_calle_2 as d_calle_2
					, t0.c_cpa as c_cpa
					, t0.d_ocupacion as d_ocupacion
					, t0.l_casa as l_casa
					, t0.e_cant_econ as e_cant_econ
					, t0.l_radicarse as l_radicarse
					, t0.d_jor_trabajo as d_jor_trabajo
					, t0.d_conocido_org as d_conocido_org
					, t0.d_familiar_org as d_familiar_org
					, SEC.policy
					, t0.c_cv as CODE
					, t0.d_ape_y_nom as TEXT 
				FROM 
					POS01_CV as t0
					,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.CV.CV\') as SEC
				JOIN 
					t0.oi_cv LEFT OUTER SEC.id  
				WHERE
					t0.oi_cv in ({%=string(#PARAM:ROWS/ROW/@id) %})
				ORDER BY 
					CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_cv"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="c_sexo" value="$r/@c_sexo"/>
						<qry:attribute name="f_est_civil" value="$r/@f_est_civil"/>
						<qry:attribute name="d_tiempo_inc" value="$r/@d_tiempo_inc"/>
						<qry:attribute name="d_calle_1" value="$r/@d_calle_1"/>
						<qry:attribute name="d_calle_2" value="$r/@d_calle_2"/>
						<qry:attribute name="c_cpa" value="$r/@c_cpa"/>
						<qry:attribute name="d_ocupacion" value="$r/@d_ocupacion"/>
						<qry:attribute name="l_casa" value="iif($r/@l_casa='1','1','0')"/>
						<qry:attribute name="e_cant_econ" value="$r/@e_cant_econ"/>
						<qry:attribute name="l_radicarse" value="iif($r/@l_radicarse='1','1','0')"/>
						<qry:attribute name="d_jor_trabajo" value="$r/@d_jor_trabajo"/>
						<qry:attribute name="d_conocido_org" value="$r/@d_conocido_org"/>
						<qry:attribute name="d_familiar_org" value="$r/@d_familiar_org"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="fecha_hoy" declare="&lt;FILTRO c_sexo=&quot;&quot; oi_localidad=&quot;&quot; d_texto_libre=&quot;ka&quot; buscarEn=&quot;d_apellido&quot;&gt;&#13;&#10;&#9;&lt;CVS&gt;&#13;&#10;&#9;&#9;&lt;CV id=&quot;1&quot;/&gt;&#13;&#10;&#9;&#9;&lt;CV id=&quot;2&quot;/&gt;&#13;&#10;&#9;&lt;/CVS&gt; &#13;&#10;&lt;/FILTRO&gt;">
			<qry:main>
				<qry:element name="FECHA">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						POS07_MOT_CAMBIOS.oi_mot_cambio 
					FROM
						POS07_MOT_CAMBIOS 
					WHERE 
						POS07_MOT_CAMBIOS.c_mot_cambio = \'01\'
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="fecha" value="now()"/>
					<qry:attribute name="oi_mot_cambio" value="$r/@oi_mot_cambio"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="RecordCard">
			<param id=""/>
		</doc:define>
		<doc:define name="DATOS_CUENTA">
			<DATOS d_clave="" d_clave_vieja=""/>
		</doc:define>
		<doc:define name="FILTERDATA_CV">
			<ROWS>
				<ROW id=""/>
			</ROWS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Postulantes.CV.CV.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
		<flow:action name="SHOW_CV">
			<doc:set-attribute to-attr-path="#FILTERDATA_CV:ROW/@id" from-attr-path="#SOURCE:@ID"/>
			<doc:load-qry input-doc-path="#FILTERDATA_CV:" qry="FILTER" output-doc="QRY"/>
			<doc:new-object class="NucleusRH.Base.Postulantes.CV.CV" doc="DDO"/>
			<flow:open-form form-class="NucleusRH.Base.Postulantes.CV.CV.noreg.autoform" parent-doc-path="#QRY:" doc-path="#DDO:" iter-index="#QRY:ROW/@id" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group Name="CV">
		<flow:form form-class="NucleusRH.Base.Postulantes.CV.CV.filter.form" extends="NucleusRH.Base.Postulantes.CV.CV.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.filter.form:FILTER" mode="FILTER">
			<flow:action name="FILTER">
				<flow:load-user-data name="IDsCV" doc="QRY"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
			<flow:action name="on-show">
