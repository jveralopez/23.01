				<doc:set-attribute from-value="D" to-attr-path="#DDO:@c_estado"/>
				<doc:set-attribute from-attr-path="#OUT_AUX:@fecha" to-attr-path="#DDO:@f_estado"/>
				<doc:set-attribute from-attr-path="#OUT_AUX:@oi_mot_cambio" to-attr-path="#DDO:oi_mot_cambio/@value"/>
				<flow:call-action action="save1-DDO"/>
			</flow:action>
			<flow:action name="save1-DDO">
