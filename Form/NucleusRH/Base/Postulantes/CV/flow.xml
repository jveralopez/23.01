			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Postulantes.CV.CV.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.noreg.form:EDIT" form-class="NucleusRH.Base.Postulantes.CV.CV.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form parent-doc-path="#FILTERDATA:" iter-index="#QRY:ROW/@id" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:assign-value from-path="#QRY:" to-doc="FILTERDATA"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Postulantes.CV.CV.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.form:SHOW" form-class="NucleusRH.Base.Postulantes.CV.CV.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
			<flow:action name="cambiar_clave">
				<flow:open-form form-class="NucleusRH.Base.Postulantes.CV.cambioclave.form" mode="EDIT" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:"/>
			</flow:action>
			<flow:action name="save1-DDO">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#RecordCard:@id"/>
				<doc:save-object class="NucleusRH.Base.Postulantes.CV.CV" doc="DDO"/>
				<flow:exec-method class="NucleusRH.Base.RecordCard.AccionesReales.ACCION_REAL" method="GuardarAccion">
					<flow:param value="EstadoPostulantes" mode="in" name="accion" type="Nomad.NSystem.String"/>
					<flow:param doc-path="#RecordCard:" type="Nomad.NSystem.Object" mode="in" name="parametrosQry"/>
					<flow:param value="NucleusRH.Base.RecordCardPostulantes.EstadoPostulantes.ACCION_REAL" type="Nomad.NSystem.String" mode="in" name="claseRC"/>
				</flow:exec-method>
				<flow:exec-method method="SET_CAMPO_LIKE" class="NucleusRH.Base.Postulantes.CV.CV">
					<flow:param attr-path="#DDO:@id" name="pstrOiCV" type="Nomad.NSystem.String" mode="in"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="CambioClave">
				<flow:open-form form-class="NucleusRH.Base.Postulantes.CV.cambioclave.form" mode="EDIT" parent-doc-path="#DDO:" doc-path="#DDO:"/>
			</flow:action>
			<flow:action name="After-Change">
