				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Postulantes.CV.CV.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.form:EDIT" form-class="NucleusRH.Base.Postulantes.CV.CV.form" mode="EDIT">
			<flow:action name="save-DDO">
				<flow:call-action eq="V" if="#DDO:@c_estado" action="CAMBIAR_ESTADO"/>
				<doc:save-object class="NucleusRH.Base.Postulantes.CV.CV" doc="DDO"/>
				<flow:call-action action="SaveRecordCard"/>
				<flow:log text-path="#DDO:" text="logDDOCVLuchoCL"/>
				<flow:exec-method method="SET_CAMPO_LIKE" class="NucleusRH.Base.Postulantes.CV.CV">
					<flow:param attr-path="#DDO:@id" name="pstrOiCV" type="Nomad.NSystem.String" mode="in"/>
					<flow:param value="A" name="pstriOiNivelEstudio" type="Nomad.NSystem.String" mode="in"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="CAMBIAR_ESTADO">
				<doc:load-qry qry="fecha_hoy" output-doc="OUT_AUX"/>
