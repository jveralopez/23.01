				<doc:set-attribute from-value="Se modificaron Datos (no principales) del CV" to-attr-path="#RecordCard:@o_accion"/>
				<flow:exec-method class="NucleusRH.Base.RecordCard.AccionesReales.ACCION_REAL" method="GuardarAccion">
