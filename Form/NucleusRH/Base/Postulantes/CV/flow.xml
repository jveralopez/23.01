				<doc:iter-refresh/>
				<doc:iter-move value-path="#DDO:@id"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Postulantes.CV.CV.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Postulantes.CV.CV.form:LIST" form-class="NucleusRH.Base.Postulantes.CV.CV.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Postulantes.CV.CV.form"/>
			</flow:action>
