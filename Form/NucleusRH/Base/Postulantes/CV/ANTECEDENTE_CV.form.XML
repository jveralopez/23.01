<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="NucleusRH.Base.Postulantes.CV.ANTECEDENTE_CV.form" extends="NucleusRH.Base.Postulantes.CV.ANTECEDENTE_CV.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsANTECEDENTE_CV">
			<form:Column name="main_columnsANTECEDENTE_CVcolumn1" visible="0"/>
			<form:Column name="main_columnsANTECEDENTE_CVcolumn2">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID CV" nvalue="#source:@oi_cv" name="oi_cv"/>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="Nombre de la Empresa en que trabaj&#243;." ysize="1" xsize="50" length="100" label="Empresa" nvalue="#source:@d_empresa" name="d_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.Postulantes.Areas_Laborales.AREA_LAB.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Area" nvalue="#source:oi_area_lab/@value" name="oi_area_lab" X-POLICY="./FORM/NucleusRH/Base/Postulantes/CV/ANTECEDENTE_CV/form/oi_area_lab">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Postulantes/CV/ANTECEDENTE_CV/form/oi_area_lab/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Postulantes/CV/ANTECEDENTE_CV/form/oi_area_lab"/>
					</form:Policies>
				</form:ComboBox>
				<form:ComboBox label="Rama de actividad" queryname1="NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" nvalue="#source:oi_actividad/@value" name="oi_actividad"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Domicilio de la Empresa. Es un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Domicilio Empresa" nvalue="#source:@d_dom_empresa" name="d_dom_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Paises.PAIS.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Pa&#237;s" nvalue="#source:oi_pais/@value" name="oi_pais"/>
				<form:ComboBox prev="oi_pais" queryname1="NucleusRH.Base.Organizacion.Paises.PROVINCIA.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Provincia" nvalue="#source:oi_provincia/@value" name="oi_provincia"/>
				<form:ComboBox prev="oi_provincia" queryname1="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Localidad" nvalue="#source:oi_localidad/@value" name="oi_localidad"/>
				<form:Rower name="telefono" label="Telefono Empresa (Pa&#237;s - &#193;rea - Numero)">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo Pa&#237;s Empresa" nvalue="#source:@c_pais_emp" name="c_pais_emp"/>
					<form:Label name="t1" label="-"/>
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo &#193;rea Empresa" nvalue="#source:@c_area_emp" name="c_area_emp"/>
					<form:Label name="t2" label="-"/>
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="N&#250;mero Tel&#233;fono Empresa" nvalue="#source:@c_telefono_emp" name="c_telefono_emp"/>
				</form:Rower>
				<form:TextBox label="Referente Laboral" required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" nvalue="#source:@d_contacto" name="d_contacto"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" descr="Fecha en que ingres&#243; al trabajo." mask="dd/mm/yyyy" label="Fecha Ingreso" nvalue="#source:@f_ingreso" name="f_ingreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha en que ingres&#243; al trabajo." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" descr="Fecha en que egres&#243; del trabajo." mask="dd/mm/yyyy" label="Fecha Egreso" nvalue="#source:@f_egreso" name="f_egreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" descrip="Fecha en que egres&#243; del trabajo." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Motivo Egreso Personal" nvalue="#source:oi_motivo_eg_per/@value" name="oi_motivo_eg_per"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Puesto" nvalue="#source:@d_puesto" name="d_puesto"/>
				<form:Rower separation="20" name="row_experiencia" required="1" label="Experiencia">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Experiencia" nvalue="#source:@e_experiencia" name="e_experiencia"/>
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Unidades_de_Tiempo.UNIDAD_TIEMPO.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Unidad Tiempo" nvalue="#source:oi_unidad_tiempo/@value" name="oi_unidad_tiempo"/>
				</form:Rower>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Descripci&#243;n de Tareas" nvalue="#source:@o_tareas" name="o_tareas"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Modalidad de Contrataci&#243;n" nvalue="#source:oi_mod_contr/@value" name="oi_mod_contr"/>
				<form:NumberBox label="&#218;ltimo Sueldo Bruto" required="0" enabled="NEW|EDIT" descr="Valor del &#250;ltimo sueldo cobrado." mask="###.###.##0.00" xsize="15" precision="3" nvalue="#source:@n_ultimo_sueldo" name="n_ultimo_sueldo"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Personal a Cargo" nvalue="#source:@l_per_cargo" name="l_per_cargo"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Cantidad Personas a Cargo" nvalue="#source:@e_cant_per_cargo" name="e_cant_per_cargo">
					<form:Event action="ValPerCargo" name="onvalidate" runat="client"/>
				</form:NumberBox>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Observaciones de Antecedente." ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_antecedente_cv" name="o_antecedente_cv"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function ValPerCargo(Me)
{
	if (Me.GetXValue() == "" &amp;&amp; Ctrl('l_per_cargo').GetXValue() == "1")
	{
		Me.SetError("Debe especificar la cantidad de Personas a Cargo");
		return false;
	}
	else return true;
}
	</form:Scripts>
</form:Form>
