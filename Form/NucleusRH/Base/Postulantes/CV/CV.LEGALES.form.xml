<form:Form default_mode="EDIT" name="NucleusRH.Base.Postulantes.CV.CV.CAMBIO_ESTADO.form" doc="source" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label label="Mantenimiento Legal del CV" nowrap="1" style="S3 LCol_w" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="blk1"/>
		<form:DateTime pattern="YYYYMMDDHHMMSS" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha del ultimo estado" nvalue="#source:@fecha" name="f_estado">
			<form:SButtons>
				<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Combo label="Estado Actual" action="COMBO" flow="NucleusRH.Base.Postulantes.CV.CV.c_estado.Combo.autoflow" required="1" enabled="0" nvalue="#source:@actual" name="actual"/>
		<form:Combo label="Estado Nuevo" action="COMBO" flow="NucleusRH.Base.Postulantes.CV.CV.c_estado.Combo.autoflow" required="0" enabled="0" nvalue="#source:@nuevo" name="nuevo"/>
		<form:Rower enabled="0" label="Problemas Legales?" name="pepe001">
			<form:CheckBox required="0" enabled="NEW|EDIT" label="Con problemas legales?" nvalue="#source:@l_legales" name="l_legales"/>
			<form:Label name="assaaaaa" label="Carta Documento?"/>
			<form:CheckBox required="0" enabled="NEW|EDIT" label="Con carta documento?" nvalue="#source:@l_carta_doc" name="l_carta_doc"/>
		</form:Rower>
		<form:Blank name="blk2"/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Postulantes.MotivoCamEstadoCV.MOT_CAMBIO.Combo.autoflow" required="1" label="Motivo de Cambio de Estado" nvalue="#source:@motivo" name="oi_mot_cambio"/>
		<form:TextBox required="0" ysize="5" xsize="50" length="100" label="Aclaracion del Cambio de Estado" nvalue="#source:@d_motivo" name="d_mot_cambio"/>
	</form:Center>
	<form:Bottom>
		<form:Columns name="saassa" width="95%">
			<form:Column name="sasasa">
				<form:RowAligner name="bottom" width="95%" align="center">
					<form:Row name="rowbottom">
						<form:Button startvalidate="1" note="Aceptar" descrip="Indicar Inicio/Fin de Problemas Legales" img="OK" label="Problemas Legales" name="PROBLEMAS">
							<form:Event action="PROBLEMAS" name="onclick" runat="client"/>
							<form:Event action="ACCEPT" name="onclick" runat="server"/>
						</form:Button>
						<form:Button startvalidate="1" note="Aceptar" descrip="Indicar Con/Sin Carta/s Documento" img="OK" label="Carta Documento" name="Carta">
							<form:Event action="CARTA" name="onclick" runat="client"/>
							<form:Event action="ACCEPT" name="onclick" runat="server"/>
						</form:Button>
					</form:Row>
				</form:RowAligner>
				<form:RowAligner name="bottom1" width="95%" align="center">
					<form:Row name="rowbottom1">
						<form:Button startvalidate="1" note="Aceptar" descrip="Colocar al CV en Acurdo Seclo" img="OK" label="Acuerdo Seclo" name="seclo">
							<form:Event action="SECLO" name="onclick" runat="client"/>
							<form:Event action="ACCEPT" name="onclick" runat="server"/>
						</form:Button>
						<form:Button startvalidate="1" note="Aceptar" descrip="Colocar al CV en Conflictivo Pendientes" img="OK" label="Conflictivo Pendientes" name="CONFLICTIVO">
							<form:Event action="CONFLICTIVO" name="onclick" runat="client"/>
							<form:Event action="ACCEPT" name="onclick" runat="server"/>
						</form:Button>
						<form:Button startvalidate="1" note="Aceptar" descrip="Colocar al CV en Estado Judicial" img="OK" label="Estado Judicial" name="JUDICIAL">
							<form:Event action="JUDICIAL" name="onclick" runat="client"/>
							<form:Event action="ACCEPT" name="onclick" runat="server"/>
						</form:Button>
						<form:Button note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
							<form:Event action="CANCEL" name="onclick" runat="server"/>
						</form:Button>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
	</form:Bottom>
	<form:Scripts>
		function onload()
{

Ctrl('f_estado').SetXValue(datetime2str(Now()));
}

function PROBLEMAS()
{
if (Ctrl('l_legales').GetXValue() == "1")
{
	Ctrl('l_legales').SetXValue("0");                     
	Ctrl('nuevo').SetXValue(Ctrl('actual').GetXValue());
} else
 	{
 	Ctrl('l_legales').SetXValue("1"); 
 	Ctrl('nuevo').SetXValue(Ctrl('actual').GetXValue());
 	}                       
return true;

}

function CARTA()
{
if (Ctrl('l_carta_doc').GetXValue() == "1")
{
	Ctrl('l_carta_doc').SetXValue("0");
	Ctrl('nuevo').SetXValue(Ctrl('actual').GetXValue());
} else
 	{
 	Ctrl('l_carta_doc').SetXValue("1");
 	Ctrl('nuevo').SetXValue(Ctrl('actual').GetXValue());
 	}         
 	return true;
}

function SECLO()
{

Ctrl('nuevo').SetXValue("S");
return true;
}         

function CONFLICTIVO()
{

Ctrl('nuevo').SetXValue("P");
return true;
}

function JUDICIAL()
{

Ctrl('nuevo').SetXValue("J");
return true;
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
