<flow:flow name="NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO.administrativo.guia" extends="NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO.guia.autoform"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_conocimiento ID, c_conocimiento CODE, d_conocimiento TEXT FROM POS16_CONOCIMIENTOS WHERE oi_conocimiento={#SOURCE:helper-mess/@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_conocimiento ID, c_conocimiento CODE, d_conocimiento TEXT FROM POS16_CONOCIMIENTOS WHERE c_conocimiento={substring_before(#INDOC:@CODE,\'-\')} 
			AND l_administrativo = 1')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:insert-select doc-path="$r" name="SECURITY_CONOCIMIENTO"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_CONOCIMIENTO">
				<qry:xquery>
					for $r in table('select policy from NMD_SECURITY where class=\'NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO\' and id={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_conocimiento ID, c_conocimiento CODE, d_conocimiento TEXT FROM POS16_CONOCIMIENTOS
			WHERE l_administrativo = 1')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:insert-select doc-path="$r" name="SECURITY_CONOCIMIENTO"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_CONOCIMIENTO">
				<qry:xquery>
					for $r in table('select policy from NMD_SECURITY where class=\'NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO\' and id={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
