<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Postulantes.Conocimientos.CONOCIMIENTO">
	<form:Help>
		<form:Help-title text="Conocimientos" name="TITLE"/>
		<form:Help-descr text="Regsitra los Conocimientos" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Conocimientos" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Conocimientos" name="GEN_EDIT"/>
