			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_conocimiento" name="c_conocimiento"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_conocimiento" name="d_conocimiento"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible Administrativo" attrname="l_administrativo" name="l_administrativo"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible Industrial" attrname="l_industrial" name="l_industrial"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible Inform&#225;tico" attrname="l_informatico" name="l_informatico"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible Promotora" attrname="l_promotora" name="l_promotora"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible T&#233;cnico" attrname="l_tecnico" name="l_tecnico"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Visible Merchandiser" attrname="l_merchandiser" name="l_merchandiser"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Postulantes/Conocimientos/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Postulantes/Conocimientos/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Postulantes/Conocimientos/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Postulantes/Conocimientos/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		///////////////////////////////////////////////////////////////////////////
// INICIO DE ITER_SHOW.form

function Find()
{
	Ctrl("LIST").filter("",Ctrl("iter_search").GetCValue());
}
function Imprimir()
{       
	Ctrl("LIST").toPrinter();
}
function ToList()
{                
	if (parseInt(Ctrl("iter_size").GetXValue(),10)&lt;=1000)
		Ctrl("LISTA").DoEvent("showList");
	else
		showMess("Modo Lista", "Demasiados registros para ser mostrados en una lista.");
}

// FIN DE ITER_SHOW.form
///////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////
// INICIO DE ROOTITER.form

function ListClick()
{ 
	var img;
	
	if (Ctrl("LIST"))
	{
		img=Ctrl("LIST").GetSelectAttrValue("img").toUpperCase().split("/");
		img=img[img.length-1].split(".")[0];
		
		switch(img)
		{
			case "LOCK":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKDEL":
				CtrlEnabled("EDIT"  ,true );
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKEDIT":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",true );
			break;
			default:
				CtrlEnabled("EDIT"  ,true);
				CtrlEnabled("DELETE",true);
			break;
		}
	}
	
	if ((Ctrl("LockREG")) &amp;&amp; (Ctrl("HiLockREG"))) 
	{                  
		
		Ctrl("LockREG").SetXValue(Ctrl("HiLockREG").GetXValue());
		CtrlEnabled("EDIT"  ,Ctrl("LockREG").GetXValue()!="1");
		CtrlEnabled("DELETE",Ctrl("LockREG").GetXValue()!="1");
	}
}

function ListDobleClick()
{             
	if (Ctrl("MOSTRAR")) 
		Ctrl("MOSTRAR").DoEvent("OnClick");
}

// FIN DE ROOTITER.form
///////////////////////////////////////////////////////////////////////////
	</form:Scripts>
</form:Form>
