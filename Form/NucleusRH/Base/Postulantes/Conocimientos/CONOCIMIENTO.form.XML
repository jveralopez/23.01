				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_conocimiento" name="d_conocimiento"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible Administrativo" nvalue="#source:@l_administrativo" name="l_administrativo"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible Industrial" nvalue="#source:@l_industrial" name="l_industrial"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible Inform&#225;tico" nvalue="#source:@l_informatico" name="l_informatico"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible Promotora" nvalue="#source:@l_promotora" name="l_promotora"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible T&#233;cnico" nvalue="#source:@l_tecnico" name="l_tecnico"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Visible Merchandiser" nvalue="#source:@l_merchandiser" name="l_merchandiser"/>
