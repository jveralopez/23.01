<flow:flow extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Bandas_Salariales.NIVEL_SAL.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Bandas_Salariales.NIVEL_SAL"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:call-action action="OPEN-GUIA"/>
		</flow:action>
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Bandas_Salariales.NIVEL_SAL.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG17_NIVELES_SAL.oi_nivel_sal AS ID, 
					ORG17_NIVELES_SAL.c_nivel_sal as CODE, 
					ORG17_NIVELES_SAL.d_nivel_sal as TEXT, 
					ORG17_NIVELES_SAL.oi_banda_sal as PID 
					FROM ORG17_NIVELES_SAL 
					WHERE ORG17_NIVELES_SAL.oi_nivel_sal={#SOURCE:helper-mess/@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess CODE=&quot;01&quot; oi_banda_sal=&quot;1&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_banda_sal" name="oi_banda_sal"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG17_NIVELES_SAL.oi_nivel_sal AS ID, 
					ORG17_NIVELES_SAL.c_nivel_sal AS CODE, 
					ORG17_NIVELES_SAL.d_nivel_sal AS TEXT 
					FROM ORG17_NIVELES_SAL 
					WHERE ORG17_NIVELES_SAL.c_nivel_sal = {substring_before(#SOURCE:helper-mess/@CODE,\'-\')}
					AND ORG17_NIVELES_SAL.oi_banda_sal = {#SOURCE:helper-mess/@oi_banda_sal}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess code=&quot;&quot; id=&quot;&quot; text=&quot;&quot; oi_banda_sal=&quot;4&quot; /&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG17_NIVELES_SAL.oi_nivel_sal AS ID, 
					ORG17_NIVELES_SAL.c_nivel_sal AS CODE, 
					ORG17_NIVELES_SAL.d_nivel_sal AS TEXT 
					FROM ORG17_NIVELES_SAL 
					WHERE ORG17_NIVELES_SAL.oi_banda_sal = {#SOURCE:helper-mess/@oi_banda_sal}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_banda_sal" name="oi_banda_sal"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Organizacion.Bandas_Salariales.NIVEL_SAL.guia.form" extends="nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Bandas_Salariales.NIVEL_SAL.guia.form"/>
</flow:flow>
