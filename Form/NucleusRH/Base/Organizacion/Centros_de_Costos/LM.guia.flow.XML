<flow:flow xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Centros_de_Costo.guia">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.LM.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG08_CS_COSTO.oi_centro_costo, ORG08_CS_COSTO.c_centro_costo, 
				ORG08_CS_COSTO.d_centro_costo 
				FROM ORG08_CS_COSTO 
				WHERE  {%? (string(#SOURCE:helper-mess/rows/row/@oi_centro_costo)!='') {%  ORG08_CS_COSTO.oi_centro_costo in ({%=string(#SOURCE:helper-mess/rows/row/@oi_centro_costo) %}) %} {% 1 = 2 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_centro_costo" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_centro_costo" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="1" name="check"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
				SELECT ORG08_CS_COSTO.oi_centro_costo, ORG08_CS_COSTO.c_centro_costo, 
				ORG08_CS_COSTO.d_centro_costo 
				FROM ORG08_CS_COSTO 
				WHERE  {%? (string(#SOURCE:helper-mess/rows/row/@oi_centro_costo)!='') {%  ORG08_CS_COSTO.oi_centro_costo not in ({%=string(#SOURCE:helper-mess/rows/row/@oi_centro_costo) %}) %} {% 1 = 1 %} %} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_centro_costo" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_centro_costo" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@id" name="oi_centro_costo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Organizacion.Centros_de_Costos.LM.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.LM.guia.form">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="OUT" input-doc-path="#SOURCE:" qry="PRUEBA"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
