<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Organizacion.Centros_de_Costos.autoflow" name="NucleusRH.Base.Organizacion.Centros_de_Costos.flow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Centros_de_Costos"/>
	<flow:declare>
		<qry:define declare="&lt;FILTRO ATRIB_ORDEN1=&quot;c_centro_costo&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN2=&quot;d_centro_costo&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN3=&quot;oi_grupo_ccosto&quot; ORDEN3=&quot;Desc&quot;&gt;&#13;&#10; &#13;&#10;&lt;/FILTRO&gt;&#13;&#10;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG08_CS_COSTO.oi_centro_costo
				{%? (#SOURCE:@ATRIB_ORDEN1!='') {% , ORG08_CS_COSTO.{%=#SOURCE:@ATRIB_ORDEN1%} %} {% %} %} 
        {%? (#SOURCE:@ATRIB_ORDEN2!='') {% , ORG08_CS_COSTO.{%=#SOURCE:@ATRIB_ORDEN2%} %} {% %} %} 	
        {%? (#SOURCE:@ATRIB_ORDEN3!='') {% , ORG08_CS_COSTO.{%=#SOURCE:@ATRIB_ORDEN3%} %} {% %} %}         	
				FROM ORG08_CS_COSTO 
        WHERE 1=1 
       	{%? (#SOURCE:@oi_grupo_ccosto!='') {% AND ORG08_CS_COSTO.oi_grupo_ccosto = {#SOURCE:@oi_grupo_ccosto} %} {% %} %}
       	{%? (#SOURCE:@l_activo='1' OR #SOURCE:@l_activo='0') {% AND ORG08_CS_COSTO.l_activo={#SOURCE:@l_activo} %} {% %} %}
       	{%? (string(#SOURCE:CENTROS_COSTO/CENTRO_COSTO/@id)!='') {% AND ORG08_CS_COSTO.oi_centro_costo in ({%=string(#SOURCE:CENTROS_COSTO/CENTRO_COSTO/@id) %}) %} {%  %} %}
        ORDER BY
    		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     	 	{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
     		{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
     		oi_centro_costo Asc
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="value"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_centro_costo" name="id"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('select NMD_SECURITY.policy from NMD_SECURITY where NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO\' and NMD_SECURITY.id={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO&gt;&#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('			
   			SELECT 
   				ORG08_CS_COSTO.oi_centro_costo, 
   				ORG08_CS_COSTO.c_centro_costo,
   				ORG08_CS_COSTO.d_centro_costo, 
   				ORG08_CS_COSTO.oi_grupo_ccosto,
   				ORG08_CS_COSTO.oi_unidad_org,
   				ORG08_CS_COSTO.l_activo, 
   				ORG08_CS_COSTO.o_centro_costo 				
				FROM 
					ORG08_CS_COSTO 
        WHERE 1=1 
	       	{%? (#SOURCE:@oi_grupo_ccosto!='') {% AND ORG08_CS_COSTO.oi_grupo_ccosto = {#SOURCE:@oi_grupo_ccosto} %} {% %} %}
	        {%? (#SOURCE:@l_activo='1' OR #SOURCE:@l_activo='0') {% AND ORG08_CS_COSTO.l_activo={#SOURCE:@l_activo} %} {% %} %}
	       	{%? (string(#SOURCE:CENTROS_COSTO/CENTRO_COSTO/@id)!='') {% AND ORG08_CS_COSTO.oi_centro_costo in ({%=string(#SOURCE:CENTROS_COSTO/CENTRO_COSTO/@id) %}) %} {%  %} %}
        ORDER BY
	    		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
	     	 	{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
	     		{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
     			oi_centro_costo ASC            
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_centro_costo" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_centro_costo" value="$r/@c_centro_costo" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_centro_costo" value="$r/@d_centro_costo" type="Nomad.NSystem.String"/>
						<qry:attribute name="oi_grupo_ccosto" value="$r/@oi_grupo_ccosto"/>
						<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
						<qry:attribute name="l_activo" value="$r/@l_activo"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				select NMD_SECURITY.policy 
				from NMD_SECURITY 
				where NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO\' and NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<FILTRO oi_grupo_ccosto="" l_activo="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="">
				<CENTROS_COSTO/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.filter.form"/>
