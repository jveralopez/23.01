			<doc:iter-refresh/>
		</flow:action>
		<flow:action name="open-flow-EDIT">
			<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form"/>
		</flow:action>
		<flow:action name="open-flow-ADD">
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form"/>
		</flow:action>
		<flow:action name="ACTION">
			<flow:exec-method method="Estado_CCosto" this-doc="DDO">
				<flow:param attr-path="#DDO:@id" type="Nomad.NSystem.String" mode="in" name="id"/>
			</flow:exec-method>
			<doc:load-object id-path="#iter-cursor:@value" class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form:EDIT" extends="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form" mode="EDIT">
		<flow:action name="SAVE">
			<doc:save-object class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
			<flow:comment>
				ESTE METODO ACTUALIZA LA UNIDAD_ORG CORRESPONDIENTE AL CENTRO DE COSTO EDITADO
			</flow:comment>
			<flow:exec-method method="Editar_CCosto" this-doc="DDO"/>
			<flow:close-form next-action="After-Change"/>
		</flow:action>
		<flow:action name="DELETE">
			<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
			<doc:save-object class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
			<flow:comment>
				ESTE METODO BORRA LA UNIDAD_ORG CORRESPONDIENTE AL CENTRO DE COSTO ELIMINADO
