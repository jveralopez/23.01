		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.noreg.autoform" mode="EDIT">
		<flow:action name="open-flow-SHOW">
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form"/>
		</flow:action>
		<flow:action name="open-flow-ADD">
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form:SHOW" extends="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.form" mode="SHOW">
		<flow:action name="DELETE">
			<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
			<doc:save-object class="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO" doc="DDO"/>
