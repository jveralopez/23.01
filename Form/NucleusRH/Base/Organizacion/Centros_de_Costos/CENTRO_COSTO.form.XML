<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" extends="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCENTRO_COSTO">
			<form:Column name="main_columnsCENTRO_COSTOcolumn1">
				<form:FKInput visible="SHOW|EDIT" required="0" enabled="0" xsize="15" length="30" label="Unidad Organizativa" nvalue="#source:oi_unidad_org/@value" name="oi_unidad_org">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:CheckBox required="1" enabled="NEW" label="Activo" nvalue="#source:@l_activo" name="l_activo"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function ToList()
{                
	Ctrl("LISTA").DoEvent("showList");	
}
	</form:Scripts>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Organizacion/Centros_de_Costos/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Organizacion/Centros_de_Costos/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Organizacion/Centros_de_Costos/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|LIST" mess="&#191;Est&#225; seguro que desea Activar/Inactivar el Centro de Costo?" img="execute" descrip="Activar/Inactivar Centro de Costo" label="Activar/Inactivar" name="ACTION" policy="NucleusRH/Base/Organizacion/Centros_de_Costos/SECURITY" order-change="PREV:BACK">
					<form:Event action="ACTION" name="onClick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Organizacion/Centros_de_Costos/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
