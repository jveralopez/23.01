<flow:flow extends="NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Calendario_Feriados.CALENDARIO"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG27_CAL_FERIADOS.oi_calendario AS ID, ORG27_CAL_FERIADOS.c_calendario AS CODE, 
					ORG27_CAL_FERIADOS.d_calendario AS TEXT  
        	FROM ORG27_CAL_FERIADOS 
        	WHERE ORG27_CAL_FERIADOS.oi_calendario={#SOURCE:helper-mess/@ID}
       ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('				
				SELECT ORG27_CAL_FERIADOS.oi_calendario AS ID, ORG27_CAL_FERIADOS.c_calendario AS CODE, 
				ORG27_CAL_FERIADOS.d_calendario AS TEXT  
        FROM ORG27_CAL_FERIADOS, ORG03_FERIADOS_EMP
        JOIN ORG27_CAL_FERIADOS.oi_calendario INNER ORG03_FERIADOS_EMP.oi_calendario
        WHERE ORG27_CAL_FERIADOS.c_calendario={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}        
        AND ORG03_FERIADOS_EMP.oi_empresa= {#SOURCE:helper-mess/@oi_empresa}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_empresa=&quot;1&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG27_CAL_FERIADOS.oi_calendario, ORG27_CAL_FERIADOS.c_calendario, 
				ORG27_CAL_FERIADOS.d_calendario
        FROM ORG27_CAL_FERIADOS,ORG03_FERIADOS_EMP
        JOIN ORG27_CAL_FERIADOS.oi_calendario INNER ORG03_FERIADOS_EMP.oi_calendario
        WHERE ORG03_FERIADOS_EMP.oi_empresa= {#SOURCE:helper-mess/@oi_empresa} 
       ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_calendario" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_calendario" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@C_calendario" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_calendario" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
