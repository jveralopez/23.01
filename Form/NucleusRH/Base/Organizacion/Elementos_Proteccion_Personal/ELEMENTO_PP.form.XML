<form:Form name="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.form" extends="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsELEMENTO_PP">
			<form:Column name="main_columnsELEMENTO_PPcolumn1">
				<form:NumberBox visible="EDIT|SHOW" label="Cantidad en Existencia" required="0" enabled="0" descr="Costo estimado del Elemento de Protecci&#243;n Personal." mask="###.###.##0.00" xsize="15" precision="0" nvalue="#STOCK:@value" name="e_stock"/>
				<form:NumberBox name="e_incorpora" enabled="EDIT" visible="EDIT" label="Cantidad a Incorporar" required="0" descr="Costo estimado del Elemento de Protecci&#243;n Personal." mask="###.###.##0.00" xsize="15" precision="0">
					<form:Event action="IncorporarStock" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:NumberBox nvalue="#source:@e_cant_total" enabled="NEW" name="e_cant_total" visible="NEW" label="Cantidad Inicial" required="0" descr="Costo estimado del Elemento de Protecci&#243;n Personal." mask="###.###.##0.00" xsize="15" precision="0">
					<form:Event action="IncorporarStock" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:Hidden nvalue="#source:@e_cant_total" name="e_cant_total_hid"/>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn label="Cantidad en Existencia" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" attrname="stock" name="stock"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Scripts>
		function IncorporarStock()
{
	if (Ctrl('main').GetMode()=="EDIT")
	{	
		Ctrl('e_cant_total_hid').SetXValue(str2number(Ctrl('e_cant_total_hid').GetXValue()) + str2number(Ctrl('e_incorpora').GetXValue()));				
	}
	if (Ctrl('main').GetMode()=="NEW")
	{
		Ctrl('e_cant_total_hid').SetXValue(Ctrl('e_cant_total').GetXValue());
	}
}
	</form:Scripts>
</form:Form>
