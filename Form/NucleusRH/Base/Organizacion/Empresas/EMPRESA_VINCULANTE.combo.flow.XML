<flow:flow extends="Nomad.combo.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Empresas.EMPRESA"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_empresa as ID, t.c_empresa as CODE, t.d_empresa as TEXT, SEC.policy  
				FROM ORG03_EMPRESAS as t, NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC 
				JOIN t.oi_empresa LEFT OUTER SEC.id  
				WHERE t.l_contratista = \'0\'
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@CODE+'-'+$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
