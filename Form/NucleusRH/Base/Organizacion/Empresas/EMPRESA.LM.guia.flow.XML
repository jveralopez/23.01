<flow:flow name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.LM.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Empresas.EMPRESA.LM.guia.form" parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
        SELECT ORG03_EMPRESAS.oi_empresa, ORG03_EMPRESAS.c_empresa, 
        ORG03_EMPRESAS.d_empresa
        FROM ORG03_EMPRESAS
        WHERE  
        {%? (string(#SOURCE:helper-mess/ROWS/ROW/@oi_empresa)!='') 
		        {%  ORG03_EMPRESAS.oi_empresa in ({%=string(#SOURCE:helper-mess/ROWS/ROW/@oi_empresa) %}) %} 
		        {% 1 = 2 %} 
        %}
        ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_empresa" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_empresa" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_empresa" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_empresa" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="1" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
        SELECT ORG03_EMPRESAS.oi_empresa, ORG03_EMPRESAS.c_empresa, ORG03_EMPRESAS.d_empresa
        FROM ORG03_EMPRESAS
				WHERE
        {%? (string(#SOURCE:helper-mess/ROWS/ROW/@oi_empresa)!='') 
        		{%  ORG03_EMPRESAS.oi_empresa not in ({%=string(#SOURCE:helper-mess/ROWS/ROW/@oi_empresa) %}) %} 
        		{% 1 = 1 %}
        %} 
         ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_empresa" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_empresa" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_empresa" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_empresa" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
			SELECT NMD_SECURITY.policy 
			FROM NMD_SECURITY 
			WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\' 
			AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@id" name="oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.LM.guia.form:SHOW" form-class="NucleusRH.Base.Organizacion.Empresas.EMPRESA.LM.guia.form" parent-doc="INVAL" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="OUT" input-doc-path="#SOURCE:" qry="PRUEBA"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
