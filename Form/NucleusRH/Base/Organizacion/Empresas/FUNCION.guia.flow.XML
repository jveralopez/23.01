<flow:flow extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Empresas.FUNCION.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Empresas.FUNCION"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Empresas.FUNCION.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess id=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG03_FUNCIONES.oi_funcion as ID, 
				ORG03_FUNCIONES.c_funcion as CODE, 
				ORG03_FUNCIONES.d_funcion as TEXT
        FROM ORG03_FUNCIONES 
        WHERE ORG03_FUNCIONES.oi_funcion={#SOURCE:helper-mess/@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess code=&quot;01&quot; oi_empresa=&quot;1&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG03_FUNCIONES.oi_funcion as ID, 
				ORG03_FUNCIONES.c_funcion as CODE, 
				ORG03_FUNCIONES.d_funcion as TEXT  
        FROM ORG03_FUNCIONES 
        WHERE ORG03_FUNCIONES.c_funcion={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}
        AND ORG03_FUNCIONES.oi_empresa={#SOURCE:helper-mess/@oi_empresa} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess  oi_empresa=&quot;1&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT ORG03_FUNCIONES.oi_funcion as ID, 
				ORG03_FUNCIONES.c_funcion as CODE, 
				ORG03_FUNCIONES.d_funcion as TEXT
        FROM ORG03_FUNCIONES 
        WHERE ORG03_FUNCIONES.oi_empresa={#SOURCE:helper-mess/@oi_empresa} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Organizacion.Empresas.FUNCION.guia.form:SHOW" extends="Nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Empresas.FUNCION.guia.form"/>
</flow:flow>
