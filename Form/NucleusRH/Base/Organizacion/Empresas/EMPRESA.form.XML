<form:Form xmlns:form="nomad_engine.form" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="NucleusRH.Base.Organizacion.Empresas.EMPRESA.autoform" name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.form">
	<form:Right width="200px">
		<form:VGroup width="100%" label="Dependencias" collapse="1" name="vgChildsEMPRESA">
			<form:Link allowimg="1" policy="NucleusRH/Base/Organizacion/Empresas/UBICACION/READ" label="Ubicaciones" name="UBICACIONES">
				<form:Event policy="NucleusRH/Base/Organizacion/Empresas/UBICACION/EDIT" action="CALL:UBICACION" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|NEW" name="main_columnsEMPRESA">
			<form:Column name="main_columnsEMPRESAcolumn1">
				<form:Image height="96" required="0" nvalue="#source:oi_logotipo/@value" name="oi_logotipo" label="Logotipo" enabled="NEW|EDIT" class="NucleusRH.Base.Personal.Imagenes.HEAD">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:Image>
				<form:FKInput name="oi_per_autorizado" nvalue="#source:oi_per_autorizado/@value" label="Personal Autorizado" length="30" xsize="15" enabled="NEW|EDIT" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="NEW|EDIT" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Calle en la que se encuentra ubicada la Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Calle" nvalue="#source:@d_calle" name="d_calle">
					<form:Event action="domicilio" name="onchange" runat="client"/>
				</form:TextBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" descr="N&#250;mero correspondiente a la Calle en la que se encuentra ubicada la Empresa. Es un n&#250;mero entero." mask="###.###.##0" xsize="12" label="N&#250;mero" nvalue="#source:@e_numero" name="e_numero">
					<form:Event action="domicilio" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" descr="Piso en el que se encuentra ubicada la Empresa. Es un n&#250;mero entero." mask="###.###.##0" xsize="12" label="Piso" nvalue="#source:@e_piso" name="e_piso">
					<form:Event action="domicilio" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Departamento en el que se encuentra ubicada la Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Departamento" nvalue="#source:@d_departamento" name="d_departamento">
					<form:Event action="domicilio" name="onchange" runat="client"/>
				</form:TextBox>
				<form:FKInput required="0" enabled="0" descr="Unidad Organizativa a la que hace referencia la Emprsea en cuesti&#243;n." xsize="15" length="30" label="Unidad Organizativa" nvalue="#source:oi_unidad_org/@value" name="oi_unidad_org">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" descrip="Unidad Organizativa a la que hace referencia la Emprsea en cuesti&#243;n." img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Hidden name="c_empresa_ant"/>
				<form:ComboBox enabled="NEW|EDIT" xsize="40" name="d_imp_gan" order-change="PREV:f_cese_act" label="Impuesto a las ganancias" mode="OPT" required="0" nvalue="#source:@d_imp_gan">
					<options>
						<option text="Responsable Inscripto" value="1"/>
						<option text="Exento" value="2"/>
						<option text="No Inscripto" value="3"/>
					</options>
				</form:ComboBox>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Requiere &quot;N&#250;mero Alta AFIP&quot; para nuevo empleado" nvalue="#source:@l_alta_afip" name="l_alta_afip"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Requiere &quot;N&#250;mero Egreso AFIP&quot; para egreso de empleado" nvalue="#source:@l_egreso_afip" name="l_egreso_afip"/>
			</form:Column>
		</form:Columns>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" descr="C&#243;digo de Empresa. Puede ser un alfanum&#233;rico de hasta 30 caracteres." width="100px" type="string" label="C&#243;digo" attrname="c_empresa" name="c_empresa" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/c_empresa">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/c_empresa/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/c_empresa"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn align="left" sorteable="1" descr="Descripci&#243;n de Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." width="100px" type="string" label="Descripci&#243;n" attrname="d_empresa" name="d_empresa" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_empresa">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_empresa/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_empresa"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" align="left" sorteable="1" width="40px" type="string" label="Seguro de Vida" attrname="oi_seguro_vida" name="oi_seguro_vida" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/oi_seguro_vida">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/oi_seguro_vida/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/oi_seguro_vida"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Ingresos Brutos" attrname="d_ingreso_bruto" name="d_ingreso_bruto" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_ingreso_bruto">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_ingreso_bruto/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_ingreso_bruto"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Impuesto a las Ganancias" attrname="d_imp_gan" name="d_imp_gan" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_imp_gan">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_imp_gan/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/d_imp_gan"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Requiere &quot;N&#250;mero Alta Afip&quot; para nuevo empleado" attrname="l_alta_afip" name="l_alta_afip" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_alta_afip">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_alta_afip/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_alta_afip"/>
					</form:Policies>
				</form:LVColumn>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Requiere &quot;N&#250;mero Egreso Afip&quot; para egreso de empleado" attrname="l_egreso_afip" name="l_egreso_afip" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_egreso_afip">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_egreso_afip/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Empresas/EMPRESA/form/l_egreso_afip"/>
					</form:Policies>
				</form:LVColumn>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom/>
	<form:Scripts>
		function ToList()
{                
	if (parseInt(Ctrl("iter-size").GetXValue(),10)&lt;=200)
		Ctrl("LISTA").DoEvent("showList");
	else
		alert("Demasiados registros para ser mostrados en una lista.");
}

function domicilio () 
{
		Ctrl('d_domicilio').SetCValue(Ctrl('d_calle').GetCValue() + ' ' + Ctrl('e_numero').GetCValue() + ' ' + Ctrl('e_piso').GetCValue() + ' ' + Ctrl('d_departamento').GetCValue())
}

function SetCode()
{
	if (Ctrl('main').GetMode()=="EDIT")
	{		
		Ctrl('c_empresa_ant').SetXValue(Ctrl('c_empresa').GetXValue());
	}
}
	</form:Scripts>
	<form:Event action="SetCode" name="onload" runat="client"/>
</form:Form>
