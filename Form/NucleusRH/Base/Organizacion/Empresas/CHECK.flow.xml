<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="OPEN-GUIA" name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.check.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Empresas.CHECK"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form doc-path="#DATA:" form-class="NucleusRH.Base.Organizacion.Empresas.CHECK.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RESULT">
			<result/>
		</doc:define>
		<doc:define name="DATA">
			<DATA ids="" action=""/>
		</doc:define>
	</flow:declare>
	<flow:form doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Organizacion.Empresas.CHECK.form:SHOW" form-class="NucleusRH.Base.Organizacion.Empresas.CHECK.form">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="ACCEPT" to-attr-path="#RESULT:@action"/>
			<doc:set-attribute from-attr-path="#DATA:@ids" to-attr-path="#RESULT:@ids"/>
			<flow:exit-flow return-path="#RESULT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#RESULT:@action"/>
			<flow:exit-flow return-path="#RESULT:"/>
		</flow:action>
	</flow:form>
</flow:flow>
