<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Organizacion.Puestos.POSICION.PERSONAL_EMP.guia.form" doc="SOURCE">
	<form:Scripts>
		function OnLoad()
{    
	Ctrl("ACCEPT").SetEnabled(Ctrl("GRID").shownRegs.length==0?false:true);
}

function FilterGrid()
{    
	Ctrl("GRID").filter("",Ctrl("buscar").GetCValue());
	Ctrl("ACCEPT").SetEnabled(Ctrl("GRID").shownRegs.length==0?false:true);
}                    

function ACCEPT()
{
	if (Ctrl("GRID").GetXValue()!="") Ctrl("main").DoEvent("ACCEPT");
}

function EDIT()
{
	if (GetFlowAction()!="")
		openNewFlowWait(GetFlowAction().split(":")[0],GetFlowAction().split(":")[1],'&lt;DATA ID="'+Ctrl("GRID").GetXValue()+'" /&gt;',new ObjtectResult(),"L");
	else
		alert("No Implementado.");
}   

function ObjtectResult()
{
	this.processResult = function()
	{                            
		Ctrl("main").DoEvent("RELOAD");
	}
}

function GetFlowAction()
{
	return "";
}

function ValDateEgr()
{
	if (Ctrl('f_egreso').GetXValue() &gt; date2str(NowDate()))
	{
	 	Ctrl('f_egreso').SetError("La fecha de egreso no puede ser posterior a la fecha actual");
		return false;
	}
	return true;
}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label label="Agregar Legajo a Posici&#243;n" nowrap="1" name="GEN" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="blank_iter02"/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:ComboBox where1="PER02_PERSONAL_EMP.oi_indic_activo = 1" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" prev="empresa" nvalue="#source:@oi_personal_emp" name="oi_personal_emp" label="Legajo" xsize="40" mode="QRY" required="1"/>
				<form:Hidden nvalue="#PARAMIN:@OI_EMPRESA" name="empresa"/>
				<form:DateTime visible="SHOW" name="f_ingreso" nvalue="#source:@f_ingreso" label="Fecha Ingreso" mask="dd/mm/yyyy" descr="Fecha de Ingreso a la Posici&#243;n." required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Ingreso a la Posici&#243;n.">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime visible="SHOW" name="f_egreso" nvalue="#source:@f_egreso" label="Fecha Egreso" mask="dd/mm/yyyy" descr="Fecha en que egres&#243; de la Posici&#243;n." required="0" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha en que egres&#243; de la Posici&#243;n.">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="ValDateEgr" name="onvalidate" runat="client"/>
				</form:DateTime>
				<form:TextBox visible="SHOW" name="te_interno_1" nvalue="#source:@te_interno_1" label="N&#250;mero Tel&#233;fono Int1" length="50" xsize="50" ysize="1" descr="N&#250;mero de Tel&#233;fono Intero 1." required="0"/>
				<form:TextBox visible="SHOW" name="te_interno_2" nvalue="#source:@te_interno_2" label="N&#250;mero Tel&#233;fono Int2" length="50" xsize="50" ysize="1" descr="N&#250;mero de Tel&#233;fono Interno 2." required="0"/>
				<form:FKInput visible="SHOW" name="oi_motivo_cambio" nvalue="#source:@oi_motivo_cambio" label="Motivo Cambio" length="30" xsize="15" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.Motivos_Cambio.MOTIVO_CAMBIO.Guia.autoflow">
						<helper-mess code="{oi_motivo_cambio.CVal}" id="{oi_motivo_cambio.XVal}" text="{oi_motivo_cambio.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox visible="SHOW" name="o_cambio_posic" nvalue="#source:@o_cambio_posic" label="Observaci&#243;n Cambio Posici&#243;n" length="1000" xsize="50" ysize="3" descr="Observaci&#243;n de Cambio de Posici&#243;n. Puede ser alfanum&#233;rico de hasta 1000 caracteres." required="0"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="blank_iter01"/>
		<form:RowAligner name="buttonlinks" visible="0">
			<form:Row name="row_top">
				<form:TextBox label="Filtrar" name="buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton descrip="Filtrar los Registros." name="Search" label="Buscar" img="filter">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:ListView visible="0" rows="10" nvalue="#SOURCE:@id" docname="RS" name="GRID" width="350px">
			<form:LVColumns>
				<form:LVColumn label="N&#250;mero Legajo" attrname="code" width="30%" align="left" type="string" sorteable="1" name="COD" descrip="Codigo"/>
				<form:LVColumn label="Apellido y Nombre" attrname="text" width="70%" align="left" type="string" sorteable="1" name="DES" descrip="Descripcion"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button startvalidate="1" name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="0" descrip="Agregar/Modificar/Eliminar Elementos" label="Agregar" name="NEW" img="NEW" note="Modificar">
					<form:Event runat="client" name="onclick" action="EDIT"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event runat="server" name="ACCEPT" action="ACCEPT"/>
	<form:Event action="RELOAD" name="RELOAD" runat="server"/>
</form:Form>
