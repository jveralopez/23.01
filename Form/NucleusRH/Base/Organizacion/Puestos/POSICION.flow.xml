<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="NucleusRH.Base.Organizacion.Puestos.autoflow" name="NucleusRH.Base.Organizacion.Puestos.POSICION.flow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Puestos.POSICION"/>
	<flow:declare>
		<doc:define name="RS">
			<ROW PARENTID="" CODE="" TEXT="">
				<ROWS/>
			</ROW>
		</doc:define>
		<doc:define name="PARAMIN"/>
		<doc:define name="POSICION"/>
		<doc:define name="ESTRUCTURA">
			<ESTRUCTURA id=""/>
		</doc:define>
		<doc:define name="DESC">
			<DATO d_clase_org=""/>
		</doc:define>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_clase_org=""/>
		</doc:define>
		<doc:define name="EMPRESA">
			<EMPRESA oi_empresa=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<FILTRO/>
		</doc:define>
		<doc:define name="CLASE"/>
		<qry:define declare="&lt;EMPRESA oi_empresa=&quot;196&quot; /&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:EMPRESA" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG02_CLASES_ORG.oi_clase_org as oi_clase_org, 
					ORG02_CLASES_ORG.c_clase_org as c_clase_org, 
					ORG02_CLASES_ORG.d_clase_org as d_clase_org, 
					ORG02_CLASES_ORG.c_estado as c_estado, 
					ORG02_CLASES_ORG.c_clase_org as CODE, 
					ORG02_CLASES_ORG.d_clase_org as TEXT, 
					ORG02_CLASES_ORG.f_desde_vigencia,
					ORG02_CLASES_ORG.f_hasta_vigencia,
					ORG02_CLASES_ORG.e_version,
					ORG02_CLASES_ORG.oi_estructura_org as oi_estructura_org 
			FROM 
				ORG02_CLASES_ORG
			WHERE 
				ORG02_CLASES_ORG.l_automatica = 1 
				AND ORG02_CLASES_ORG.oi_estructura_org in
				(SELECT ORG02_ESTRUCTURAS.oi_estructura
				FROM ORG02_ESTRUCTURAS, ORG03_EMPRESAS, ORG01_UNI_ORG
				JOIN ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org,
				ORG03_EMPRESAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org
				WHERE ORG03_EMPRESAS.oi_empresa = {%=#PARAM:@oi_empresa%})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_clase_org"/>
						<qry:attribute name="c_clase_org" value="$r/@c_clase_org"/>
						<qry:attribute name="d_clase_org" value="$r/@d_clase_org"/>
						<qry:attribute name="e_version" value="$r/@e_version"/>
						<qry:attribute name="f_desde_vigencia" value="$r/@f_desde_vigencia"/>
						<qry:attribute name="f_hasta_vigencia" value="$r/@f_hasta_vigencia"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;EMPRESA oi_empresa=&quot;1&quot;/&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select doc-path="#SOURCE:EMPRESA" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
					SELECT 
						ORG03_EMPRESAS.c_empresa, 
						ORG03_EMPRESAS.d_empresa, 
						ORG03_EMPRESAS.oi_unidad_org 
					FROM 
						ORG03_EMPRESAS 
					WHERE 
						ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="empresa" value="'[' + $r/@c_empresa + '] ' + $r/@d_empresa"/>
					<qry:attribute name="c_clase_org" value="$r/@c_empresa + ' POS'"/>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
					<qry:insert-select doc-path="." name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			    SELECT ORG02_CLASES_ORG.oi_clase_org, ORG02_CLASES_ORG.c_clase_org, 
			    ORG02_CLASES_ORG.d_clase_org, ORG02_CLASES_ORG.oi_estructura_org, 
			    ORG02_CLASES_ORG.o_clase_org
			    FROM ORG02_CLASES_ORG 
			    WHERE ORG02_CLASES_ORG.c_clase_org = \'{%=#SOURCE:@c_clase_org%}\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="empresa" value="#SOURCE:@empresa"/>
					<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
					<qry:attribute name="c_clase_org" value="$r/@c_clase_org"/>
					<qry:attribute name="d_clase_org" value="$r/@d_clase_org"/>
					<qry:attribute name="oi_estructura_org" value="$r/@oi_estructura_org"/>
					<qry:attribute name="o_clase_org" value="$r/@o_clase_org"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="UNI_ORG" declare="&lt;DATO oi_estructura=&quot;3&quot; /&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:DATO" name="RS1"/>
					<qry:insert-select doc-path="#SOURCE:DATO" name="RS3"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('     					
					SELECT ORG02_ESTRUCTURAS.oi_unidad_org 
					FROM ORG02_ESTRUCTURAS 
					WHERE ORG02_ESTRUCTURAS.oi_estructura = {#SOURCE:@oi_estructura}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('     					
				SELECT ORG01_UNI_ORG.oi_tipo_uni_org 
				FROM ORG01_UNI_ORG 
				WHERE ORG01_UNI_ORG.oi_unidad_org = {#SOURCE:@oi_unidad_org}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_tipo_uni_org" value="$r/@oi_tipo_uni_org" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS3" doc="SOURCE">
				<qry:xquery>
					for $r in sql('     	
				SELECT ORG02_ESTRUCTURAS.oi_unidad_org 
				FROM ORG02_ESTRUCTURAS
				WHERE ORG02_ESTRUCTURAS.oi_estructura= {#SOURCE:@oi_estructura}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;PARAMETERS oi_clase_org=&quot;1&quot;/&gt;" name="CLASE_ORG_DESC">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAMETERS"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG02_CLASES_ORG.c_clase_org, 
					ORG02_CLASES_ORG.d_clase_org,
					ORG02_CLASES_ORG.c_estado,
					ORG02_CLASES_ORG.f_desde_vigencia,
					ORG02_CLASES_ORG.f_hasta_vigencia					
				FROM 
					ORG02_CLASES_ORG
				WHERE 
					ORG02_CLASES_ORG.oi_clase_org = {#SOURCE:@oi_clase_org}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="d_clase_org" value="'[' + $r/@c_clase_org + ']' + ' ' +  $r/@d_clase_org"/>
					<qry:attribute name="f_desde_vigencia" value="format_date($r/@f_desde_vigencia, 'dd/mm/yyyy')"/>
					<qry:attribute name="f_hasta_vigencia" value="format_date($r/@f_hasta_vigencia, 'dd/mm/yyyy')"/>
					<qry:attribute name="c_estado" value="$r/@c_estado"/>
					<qry:if test="$r/@c_estado = 'V'">
						<qry:then>
							<qry:attribute name="estado" value="'Vigente'"/>
							<qry:attribute name="d_clase_org" value="@d_clase_org + ': ' + @estado + ' desde el ' + @f_desde_vigencia"/>
						</qry:then>
					</qry:if>
					<qry:if test="$r/@c_estado = 'R'">
						<qry:then>
							<qry:attribute name="estado" value="'Rechazado'"/>
							<qry:attribute name="d_clase_org" value="@d_clase_org + ': ' + @estado"/>
						</qry:then>
					</qry:if>
					<qry:if test="$r/@c_estado = 'P'">
						<qry:then>
							<qry:attribute name="estado" value="'Planificado'"/>
							<qry:attribute name="d_clase_org" value="@d_clase_org + ': ' + @estado"/>
						</qry:then>
					</qry:if>
					<qry:if test="$r/@c_estado = 'D'">
						<qry:then>
							<qry:attribute name="estado" value="'Discontinuado'"/>
							<qry:attribute name="d_clase_org" value="@d_clase_org + ': ' + @estado + ' desde el ' + @f_hasta_vigencia"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELPPER" declare="&lt;ID oi_empresa=&quot;1&quot; /&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:ID"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.e_numero_legajo, PER01_PERSONAL.d_ape_y_nom
				FROM PER02_PERSONAL_EMP, PER01_PERSONAL
				JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE PER02_PERSONAL_EMP.oi_empresa = {#SOURCE:@oi_empresa}				
				AND PER02_PERSONAL_EMP.oi_indic_activo != 4
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_personal_emp" name="id"/>
						<qry:attribute value="$r/@oi_personal_emp" name="value"/>
						<qry:attribute value="$r/@e_numero_legajo" name="code"/>
						<qry:attribute value="$r/@d_ape_y_nom" name="text"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define description="Se fija si una posicion esta asignada como trayectoria en algun legajo" declare="&lt;ESTRUCTURA id=&quot;180&quot;/&gt;" name="QRY_POSICION_PER">
			<qry:main doc="SOURCE">
				<qry:element name="FLAG">
					<qry:attribute name="flag" value="'0'"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:ESTRUCTURA"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_POSICIONES.oi_posicion 
				FROM ORG04_POSICIONES
				WHERE ORG04_POSICIONES.oi_unidad_org in(
				SELECT ORG02_ESTRUCTURAS.oi_unidad_org
				FROM ORG02_ESTRUCTURAS
				WHERE ORG02_ESTRUCTURAS.oi_estructura = {%=#SOURCE:@id%})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_posicion" value="$r/@oi_posicion"/>
					<qry:insert-select name="RS2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_POSIC_PER.oi_posicion_per 
				FROM PER02_POSIC_PER 
				WHERE PER02_POSIC_PER.oi_posicion = {#SOURCE:@oi_posicion}
				AND ISNULL(PER02_POSIC_PER.f_egreso)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="flag" value="'1'"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ESTRUCTURA ID=&quot;1060&quot; OI_EMPRESA=&quot;1&quot; oi_clase_org=&quot;407&quot; VALUE=&quot;11545&quot; /&gt;" name="QRY_POSICION">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:attribute name="flag" value="'0'"/>
					<qry:insert-select name="RS0" doc-path="#SOURCE:ESTRUCTURA"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:ESTRUCTURA"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:ESTRUCTURA"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS0" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG03_EMPRESAS.c_empresa				
				FROM ORG03_EMPRESAS
				WHERE ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG02_ESTRUCTURAS.oi_estructura				
				FROM ORG02_ESTRUCTURAS
				WHERE ORG02_ESTRUCTURAS.oi_estructura = {#SOURCE:@id}
				AND ISNULL(ORG02_ESTRUCTURAS.oi_estr_padre)
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="flag" value="'1'"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG01_UNI_ORG.oi_unidad_org,
				ORG01_UNI_ORG.c_unidad_org
				FROM ORG01_UNI_ORG
				WHERE ORG01_UNI_ORG.oi_unidad_org
				in (SELECT ORG02_ESTRUCTURAS.oi_unidad_org
					FROM ORG02_ESTRUCTURAS
					WHERE ORG02_ESTRUCTURAS.oi_estructura = {%=#SOURCE:@id%})				
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="#SOURCE:@id"/>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
					<qry:attribute name="c_unidad_org" value="$r/@c_unidad_org"/>
					<qry:insert-select name="RS3" doc-path="."/>
				</qry:out>
			</qry:select>
			<qry:select name="RS3" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_PUESTOS.oi_puesto,
				ORG04_POSICIONES.oi_posicion
				FROM ORG04_POSICIONES, ORG04_PUESTOS, ORG03_EMPRESAS
				JOIN ORG04_POSICIONES.oi_puesto INNER ORG04_PUESTOS.oi_puesto,
				ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE ORG03_EMPRESAS.c_empresa = {#SOURCE:@c_empresa}
				AND ORG04_POSICIONES.oi_unidad_org = {#SOURCE:@oi_unidad_org}				
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_posicion" value="$r/@oi_posicion"/>
					<qry:attribute name="oi_puesto" value="$r/@oi_puesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;POSICION c_posicion=&quot;P01812&quot; oi_puesto = &quot;6&quot; /&gt;" name="QRY_POSICION_EDIT">
			<qry:main doc="SOURCE">
				<qry:element name="POS">
					<qry:insert-select name="RS0" doc-path="#SOURCE:POSICION"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS0" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					po.oi_posicion
				FROM
					ORG04_POSICIONES as po
				WHERE 
					po.c_posicion = {#SOURCE:@c_posicion} 
					and po.oi_puesto = {#SOURCE:@oi_puesto}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_posicion" value="$r/@oi_posicion"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="POSICION_EDIT"/>
		<doc:define class="NucleusRH.Base.Organizacion.Puestos.POSICION" name="DDO_POSICION"/>
		<doc:define name="FILTERPOSICION">
			<POSICION/>
		</doc:define>
		<doc:define name="DPTO">
			<DPTO oi_departamento="" oi_sector=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ADDPOSICION">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:set-attribute to-attr-path="#EMPRESA:@oi_empresa" from-attr-path="#SOURCE:@OI_EMPRESA"/>
			<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Organizacion.Puestos.PUESTO"/>
			<doc:new-object doc="DDO" class="NucleusRH.Base.Organizacion.Puestos.POSICION"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#DDO:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.form"/>
		</flow:action>
		<flow:action name="ADDPOSICIONPLANIFICADA">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:set-attribute to-attr-path="#EMPRESA:@oi_empresa" from-attr-path="#SOURCE:@OI_EMPRESA"/>
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.PLANIFICADA.form" doc-path="#SOURCE:" parent-doc-path="#SOURCE:" mode="NEW"/>
		</flow:action>
		<flow:action name="ADDLEGAJO">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.PERSONAL_EMP.guia.form" parent-doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="ADDLEGAJOPLANIFICADO">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<flow:open-form doc-path="#SOURCE:" mode="SHOW_PL" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.PERSONAL_EMP.guia.form" parent-doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DELPOSICION">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<flow:exec-method out-type="Nomad.NSystem.String" out-attr-path="#SOURCE:@error" method="Eliminar_Posicion" class="NucleusRH.Base.Organizacion.Puestos.POSICION">
				<flow:param attr-path="#ESTRUCTURA:@id" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="EGRLEGAJO">
