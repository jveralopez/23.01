<flow:flow name="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.LM.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.LM.guia.form" parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define declare="&lt;helper-mess oi_empresa=&quot;187&quot;&gt;&lt;rows nmd-col=&quot;1&quot;&gt;&lt;row /&gt;&lt;row /&gt;&lt;row /&gt;&lt;/rows&gt;&lt;/helper-mess&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:helper-mess"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:helper-mess"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_PUESTOS.oi_puesto, ORG04_PUESTOS.c_puesto,
				ORG04_PUESTOS.d_puesto
				FROM ORG04_PUESTOS				
				WHERE ORG04_PUESTOS.oi_empresa = {#SOURCE:@oi_empresa} 									
				{%? (string(#SOURCE:rows/row/@oi_puesto)!='') {%  AND ORG04_PUESTOS.oi_puesto in ({%=string(#FILTRO:helper-mess/rows/row/@oi_puesto) %}) %} {% AND 1=2 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_puesto" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_puesto" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_puesto" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_puesto" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="1" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY_SI"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_SI">
				<qry:xquery>
					for $r in sql('
					SELECT NMD_SECURITY.policy 
					FROM NMD_SECURITY 
					WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
					AND NMD_SECURITY.id={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
			 	SELECT ORG04_PUESTOS.oi_puesto, ORG04_PUESTOS.c_puesto,
				ORG04_PUESTOS.d_puesto
				FROM ORG04_PUESTOS				
				WHERE ORG04_PUESTOS.oi_empresa = {#SOURCE:@oi_empresa}				
				{%? (string(#SOURCE:rows/row/@oi_puesto)!='') {% AND ORG04_PUESTOS.oi_puesto not in ({%=string(#FILTRO:helper-mess/rows/row/@oi_puesto) %}) %} {% AND 1=1  %} %} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_puesto" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_puesto" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_puesto" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_puesto" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY_NO"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_NO">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS&gt;&#13;&#10;&#9;&lt;ROW check=&quot;0&quot; text=&quot;Puesto 1&quot; code=&quot;P1&quot; value=&quot;696&quot; id=&quot;696&quot;/&gt;&#13;&#10;&#9;&lt;ROW check=&quot;0&quot; text=&quot;Puesto 2&quot; code=&quot;P2&quot; value=&quot;697&quot; id=&quot;697&quot;/&gt;&#13;&#10;&#9;&lt;ROW check=&quot;1&quot; text=&quot;Puesto 3&quot; code=&quot;P3&quot; value=&quot;698&quot; id=&quot;698&quot;/&gt;&#13;&#10;&#9;&lt;ROW check=&quot;1&quot; text=&quot;Puesto 4&quot; code=&quot;P4&quot; value=&quot;699&quot; id=&quot;699&quot;/&gt;&#13;&#10;&#9;&lt;ROW check=&quot;0&quot; text=&quot;Puesto 5&quot; code=&quot;P5&quot; value=&quot;700&quot; id=&quot;700&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;" name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@id" name="oi_puesto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.LM.guia.form:SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.LM.guia.form" parent-doc="INVAL" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="OUT" input-doc-path="#SOURCE:" qry="PRUEBA"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
