		Ctrl("oi_nivel_sal").SetCValue('');
		Ctrl("oi_categoria").SetCValue('');
		CtrlEnabled('oi_categoria', false);
		CtrlEnabled('oi_nivel_sal', false);		
		}else
	{
		if (Ctrl("l_convenio").GetXValue() == "1")
		{			
			CtrlEnabled('oi_categoria', true);			
			Ctrl("oi_nivel_sal").SetCValue('');			
			CtrlEnabled('oi_nivel_sal', false);
		}else
		{
			CtrlEnabled('oi_nivel_sal', true);			
			Ctrl("oi_categoria").SetCValue('');			
			CtrlEnabled('oi_categoria', false);			
		}
	}
}
	</form:Scripts>
	<form:Event action="set_convenio" name="onload" runat="client"/>
</form:Form>
