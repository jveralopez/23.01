<form:Form name="NucleusRH.Base.Organizacion.Puestos.POSICION.POSICION_PER.guia.form" doc="SOURCE" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label label="Egresar Legajo de Posici&#243;n" nowrap="1" style="S3 LCol_w" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="blnk1"/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:DateTime pattern="YYYYMMDD" required="1" descr="Fecha en que egres&#243; de la Posici&#243;n." mask="dd/mm/yyyy" label="Fecha Egreso" nvalue="#source:@f_egreso" name="f_egreso">
					<form:SButtons>
						<form:SButton descrip="Fecha en que egres&#243; de la Posici&#243;n." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:FKInput required="0" xsize="15" length="30" label="Motivo Cambio" nvalue="#source:@oi_motivo_cambio" name="oi_motivo_cambio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.Motivos_Cambio.MOTIVO_CAMBIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" descr="Observaci&#243;n de Cambio de Posici&#243;n. Puede ser alfanum&#233;rico de hasta 1000 caracteres." ysize="4" xsize="50" length="1000" label="Observaci&#243;n Cambio Posici&#243;n" nvalue="#source:@o_cambio_posic" name="o_cambio_posic"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button startvalidate="1" name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
