<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Organizacion.Puestos.flow" extends="NucleusRH.Base.Organizacion.Puestos.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Puestos"/>
	<flow:declare>
		<doc:define name="PUESTO">
			<PUESTO oi_puesto=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS/>
			</FILTRO>
		</doc:define>
		<doc:define name="FILTERDATA_ORGANIGRAMA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS>
					<PUESTO id=""/>
				</PUESTOS>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;&quot; ID=&quot;x&quot;&gt;&lt;PUESTOS&gt;&lt;PUESTO id=&quot;696&quot; /&gt;&lt;/PUESTOS&gt;&lt;/FILTRO&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_PUESTOS.oi_puesto, ORG04_PUESTOS.c_puesto, 
				ORG04_PUESTOS.d_puesto,	ORG03_EMPRESAS.c_empresa
	    	FROM ORG04_PUESTOS, ORG03_EMPRESAS
     		{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    		{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
      	{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
        {%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 1=1 
      	{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa={#SOURCE:@oi_empresa} %} {% %} %}        
        {%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
        {%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
        {%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
	  		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     	 	{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
     		{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
     		oi_puesto ASC
    	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
				NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;c_puesto&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;9&quot; ID=&quot;x&quot; oi_banda_sal=&quot;&quot; oi_categoria=&quot;1&quot;&gt;&#13;&#10;  &lt;PUESTOS/&gt;&#13;&#10;    &#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('	
			  SELECT ORG04_PUESTOS.oi_puesto, ORG04_PUESTOS.c_puesto, 
			  ORG04_PUESTOS.d_puesto, ORG04_PUESTOS.oi_empresa, ORG03_EMPRESAS.c_empresa
 		  	FROM ORG04_PUESTOS, ORG03_EMPRESAS
     		{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    		{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
      	{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
        {%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 1=1 
      	{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa  ={#SOURCE:@oi_empresa} %} {% %} %}        
        {%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
        {%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
        {%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
	  		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     	 	{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
     		{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
     		oi_puesto ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_puesto" value="$r/@c_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto" type="Nomad.NSystem.Int"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
				NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ID OI_ESTRUCTURA=&quot;178&quot; /&gt;" name="GET_PUESTO">
			<qry:main doc="SOURCE">
				<qry:element name="PUESTO">
					<qry:insert-select name="QRY_PUESTO" doc-path="#SOURCE:ID"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PUESTO" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
				SELECT ORG04_POSICIONES.oi_puesto
				FROM ORG04_POSICIONES
				WHERE ORG04_POSICIONES.oi_unidad_org in 
						(SELECT ORG02_ESTRUCTURAS.oi_unidad_org
						FROM ORG02_ESTRUCTURAS WHERE ORG02_ESTRUCTURAS.oi_estructura = {%=#SOURCE:@OI_ESTRUCTURA%})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_puesto" value="$r/@oi_puesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DDOPOSICION"/>
		<doc:define name="EMPRESA"/>
		<doc:define name="DPTO">
			<DPTO oi_departamento="" oi_sector=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<doc:load-qry output-doc="PUESTO" qry="GET_PUESTO" input-doc-path="#SOURCE:"/>
			<doc:set-attribute from-attr-path="#PUESTO:@oi_puesto" to-attr-path="#FILTERDATA_ORGANIGRAMA:PUESTOS/PUESTO/@id"/>
			<doc:assign-value from-path="#FILTERDATA_ORGANIGRAMA:" to-doc="FILTERDATA"/>
			<doc:load-qry input-doc-path="#FILTERDATA:" qry="FILTER" output-doc="QRY"/>
			<doc:new-object class="NucleusRH.Base.Organizacion.Puestos.PUESTO" doc="DDO"/>
			<flow:open-form parent-doc-path="#QRY:" doc-path="#DDO:" iter-index="#QRY:ROW/@value" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="PUESTO">
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.filter.form" mode="FILTER" form-class="NucleusRH.Base.Organizacion.Puestos.filter.form" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.filter.autoform:FILTER">
			<flow:action name="open-flow-ADD">
				<doc:set-attribute from-attr-path="#SOURCE:@oi_empresa" to-attr-path="#NEWDDOROOT:oi_empresa/@value"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:set-attribute from-attr-path="#SOURCE:@oi_empresa" to-attr-path="#EMPRESA:@oi_empresa"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.form:SHOW" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.autoform:SHOW">
			<flow:action name="ADD">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Organizacion.Puestos.PUESTO"/>
				<doc:set-attribute from-attr-path="#SOURCE:oi_empresa/@value" to-attr-path="#NEWDDOROOT:oi_empresa/@value"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method this-doc="DDO" method="Borrar_Puesto"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.form:LIST" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:set-attribute from-attr-path="#SOURCE:oi_empresa/@value" to-attr-path="#NEWDDOROOT:oi_empresa/@value"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method this-doc="DDO" method="Borrar_Puesto"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.form:EDIT" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form" doc="SOURCE" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.autoform:EDIT">
			<flow:action name="SAVE">
				<flow:exec-method this-doc="SOURCE" method="Actualizar_Costo"/>
				<flow:comment>
					ESTE METODO ACTUALIZA LA UNIDAD_ORG CORRESPONDIENTE AL PUESTO EDITADO
				</flow:comment>
				<flow:exec-method this-doc="DDO" method="Editar_Puesto"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method this-doc="DDO" method="Borrar_Puesto"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.form:NEW" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form" doc="SOURCE" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.autoform:NEW">
			<flow:action name="save-DDO">
				<flow:exec-method this-doc="SOURCE" method="Actualizar_Costo"/>
				<flow:comment>
					ESTE METODO CREA LA UNIDAD_ORG CORRESPONDIENTE AL PUESTO CREADO
				</flow:comment>
				<flow:exec-method this-doc="SOURCE" method="Crear_Puesto"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform:SHOW" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform" mode="SHOW">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.form:EDIT" extends="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group name="POSICION">
		<flow:form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form:EDIT" extends="NucleusRH.Base.Organizacion.Puestos.POSICION.autoform:EDIT" doc-path="/POSICION[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" mode="EDIT">
			<flow:action name="delete-DDO">
				<flow:exec-method class="NucleusRH.Base.Organizacion.Puestos.POSICION" method="ValidarEliminarPosicion">
					<flow:param attr-path="#SOURCE:@id" name="oi_posicion" mode="in" type="Nomad.NSystem.String"/>
				</flow:exec-method>
				<doc:delete-object doc-path="#SOURCE:" class="NucleusRH.Base.Organizacion.Puestos.POSICION" doc="SOURCE"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:set-attribute to-attr-path="#EMPRESA:@oi_empresa" from-attr-path="#DDO:oi_empresa/@value"/>
				<flow:log text-path="#SOURCE:" text="DENIS"/>
				<doc:set-attribute from-attr-path="#SOURCE:oi_departamento/@value" to-attr-path="#DPTO:@oi_departamento"/>
				<doc:set-attribute from-attr-path="#SOURCE:oi_sector/@value" to-attr-path="#DPTO:@oi_sector"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form:LIST_EDIT" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" extends="NucleusRH.Base.Organizacion.Puestos.POSICION.autoform:LIST_EDIT" doc-path="/POSICION[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" mode="LIST_EDIT">
			<flow:action name="delete-DDO">
				<flow:exec-method class="NucleusRH.Base.Organizacion.Puestos.POSICION" method="ValidarEliminarPosicion">
					<flow:param attr-path="#FORM:ctrl[@id='LIST']/@xval" name="oi_posicion" mode="in" type="Nomad.NSystem.String"/>
				</flow:exec-method>
				<doc:delete-object doc-path="#PARENTSOURCE:POSICION[@id='{#FORM:ctrl[@id='LIST']/@xval}']" class="NucleusRH.Base.Organizacion.Puestos.POSICION"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Puestos.POSICION.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Puestos.POSICION.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" iter-index="#PARENTSOURCE:POSICION/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.POSICION.form" parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW"/>
