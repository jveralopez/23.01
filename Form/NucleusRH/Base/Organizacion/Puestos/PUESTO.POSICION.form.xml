	<form:Scripts>
		function set_convenio()
{   
 
	if(Ctrl('oi_departamento'))
	{
	 	if(Ctrl('main').GetMode() != "LIST" || Ctrl('main').GetMode() != "LIST_EDIT")
 		{
 			Ctrl('oi_departamento').SetWhere("ORG51_DEPARTAMENTOS.oi_empresa = '"+Ctrl('oi_empresa').GetXValue()+"'");
 			Ctrl('oi_departamento').SetXValue(Ctrl('oi_dpto').GetXValue());
 			if(Ctrl('oi_sec'))
 				Ctrl('oi_sector').SetXValue(Ctrl('oi_sec').GetXValue());	
 		} 
 		
 		if(Ctrl('main').GetMode() == "NEW")
 		{
 			Ctrl('oi_departamento').SetXValue('');
 			Ctrl('oi_sector').SetXValue('');	
 			                                  
 		}
 		
	}
	  
 	     
