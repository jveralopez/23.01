}              

function confirmGuardar()
{   
	if (Ctrl('main').GetMode()=="NEW")
	{                     
	var param="&lt;PARAM oi_empresa='"+Ctrl("oi_empresa").GetXValue()+"' oi_puesto='"+Ctrl("oi_puesto").GetXValue()+"' c_posicion='"+Ctrl("c_posicion").GetXValue()+"' /&gt;";
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
	var result = nSQL.GetOBJ(Ctrl("main").getResource("qry:POSICION_EXISTENTE"), param);   
		if (result.flag=="1")
			return confirm("Esta posici&#243;n ya esta creada. &#191;Esta seguro que desea modificar sus datos?");   
		else
			return true; 
	}   	
	return true;
}
	</form:Scripts>
	<form:Event action="set_convenio" name="onload" runat="client"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_empresa=&quot;9&quot; c_posicion=&quot;01&quot; oi_puesto=&quot;16&quot; /&gt;" name="qry:POSICION_EXISTENTE">
			<qry:main Doc="PARAM">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#PARAM:/PARAM" name="RS1"/>
					<qry:insert-select doc-path="." name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						ORG03_EMPRESAS.c_empresa,
						ORG04_PUESTOS.c_puesto,
						ORG04_POSICIONES.c_posicion 
					FROM 
						ORG03_EMPRESAS,
						ORG04_PUESTOS,
						ORG04_POSICIONES
					JOIN
						ORG03_EMPRESAS.oi_empresa INNER ORG04_PUESTOS.oi_empresa,
						ORG04_PUESTOS.oi_puesto INNER ORG04_POSICIONES.oi_puesto
					WHERE 
						ORG03_EMPRESAS.oi_empresa = {#PARAM:@oi_empresa}
					 	AND ORG04_PUESTOS.oi_puesto = {#PARAM:@oi_puesto}
						AND ORG04_POSICIONES.c_posicion = {#PARAM:@c_posicion}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
					<qry:attribute name="c_puesto" value="$r/@c_puesto"/>
					<qry:attribute name="c_posicion" value="$r/@c_posicion"/>
					<qry:attribute name="c_unidad_org" value="concat($r/@c_empresa,'-',$r/@c_puesto,'-',$r/@c_posicion)"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="RS2">
				<qry:xquery>
					for $r in sql('
					SELECT 
						ORG01_UNI_ORG.c_unidad_org
					FROM 
						ORG01_UNI_ORG
					WHERE 
						ORG01_UNI_ORG.c_unidad_org = {#PARAM:@c_unidad_org}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="aux1" value="$r/@c_unidad_org"/>
					<qry:if test="$r/@c_unidad_org!=''">
						<qry:then>
							<qry:attribute name="flag" value="'1'"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="flag" value="'0'"/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
