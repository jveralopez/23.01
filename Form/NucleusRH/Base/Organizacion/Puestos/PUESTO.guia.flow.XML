<flow:flow extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Puestos.PUESTO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.guia.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess oi_empresa=&quot;1&quot; ID=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG04_PUESTOS.oi_puesto as ID, ORG04_PUESTOS.c_puesto as CODE, 
					ORG04_PUESTOS.d_puesto as TEXT, ORG04_PUESTOS.l_convenio, 
					ORG04_PUESTOS.oi_categoria, ORG04_PUESTOS.oi_banda_sal
        	FROM ORG04_PUESTOS 
        	WHERE ORG04_PUESTOS.oi_puesto={#SOURCE:helper-mess/@ID}
       ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@l_convenio" name="l_convenio"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_categoria" name="oi_categoria"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_banda_sal" name="oi_banda_sal"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_empresa=&quot;1&quot; ID=&quot;1&quot; CODE=&quot;JVI&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG04_PUESTOS.oi_puesto as ID, ORG04_PUESTOS.c_puesto as CODE, 
					ORG04_PUESTOS.d_puesto as TEXT, ORG04_PUESTOS.l_convenio, 
					ORG04_PUESTOS.oi_categoria, ORG04_PUESTOS.oi_banda_sal
        	FROM ORG04_PUESTOS 
        	WHERE ORG04_PUESTOS.c_puesto={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}
        	AND ORG04_PUESTOS.oi_empresa = {#SOURCE:helper-mess/@oi_empresa} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@l_convenio" name="l_convenio"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_categoria" name="oi_categoria"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_banda_sal" name="oi_banda_sal"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_empresa=&quot;187&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('					
					SELECT ORG04_PUESTOS.oi_puesto as ID, ORG04_PUESTOS.c_puesto as CODE, 
					ORG04_PUESTOS.d_puesto as TEXT, ORG04_PUESTOS.l_convenio, 
					ORG04_PUESTOS.oi_categoria, ORG04_PUESTOS.oi_banda_sal
        	FROM ORG04_PUESTOS 
        	WHERE ORG04_PUESTOS.oi_empresa = {#SOURCE:helper-mess/@oi_empresa}
       ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_empresa" name="oi_empresa"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@l_convenio" name="l_convenio"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_categoria" name="oi_categoria"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_banda_sal" name="oi_banda_sal"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="Nomad.simple.guia.form:SHOW" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.guia.form:SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.PUESTO.guia.form"/>
</flow:flow>
