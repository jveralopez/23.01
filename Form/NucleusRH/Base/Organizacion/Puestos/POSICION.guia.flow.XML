<flow:flow extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Puestos.POSICION.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Puestos.POSICION"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess id=&quot;1&quot; oi_puesto_ult=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_POSICIONES.oi_posicion as ID, 
				ORG04_POSICIONES.c_posicion as CODE, ORG04_POSICIONES.d_posicion as TEXT,
				ORG04_POSICIONES.oi_puesto as PID 
        FROM ORG04_POSICIONES 
        WHERE ORG04_POSICIONES.oi_posicion={#SOURCE:helper-mess/@ID}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_puesto_ult=&quot;16&quot; CODE=&quot;01&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_puesto_ult" name="oi_puesto_ult"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG04_POSICIONES.oi_posicion as ID, 
				ORG04_POSICIONES.c_posicion as CODE, ORG04_POSICIONES.d_posicion as TEXT,
				ORG04_POSICIONES.oi_puesto as PID 
        FROM ORG04_POSICIONES 
        WHERE ORG04_POSICIONES.c_posicion={substring_before(#SOURCE:helper-mess/@CODE,\'-\')}				
        AND ORG04_POSICIONES.oi_puesto= {#SOURCE:helper-mess/@oi_puesto_ult} 
       ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_puesto_ult" name="oi_puesto_ult"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_puesto_ult=&quot;16&quot; CODE=&quot;01&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql(' 
 				SELECT ORG04_POSICIONES.oi_posicion as ID, 
				ORG04_POSICIONES.c_posicion as CODE, ORG04_POSICIONES.d_posicion as TEXT,
				ORG04_POSICIONES.oi_puesto as PID 
        FROM ORG04_POSICIONES 
        WHERE ORG04_POSICIONES.oi_puesto={#SOURCE:helper-mess/@oi_puesto_ult} 
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@oi_puesto_ult" name="oi_puesto_ult"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="Nomad.simple.guia.form:SHOW" name="NucleusRH.Base.Organizacion.Puestos.POSICION.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Puestos.POSICION.guia.form"/>
</flow:flow>
