<flow:flow extends="Nomad.combo.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Paises.PROVINCIA"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT ORG35_PROVINCIAS.oi_provincia, ORG35_PROVINCIAS.c_provincia, 
			ORG35_PROVINCIAS.d_provincia 
			FROM ORG35_PROVINCIAS 
			WHERE ORG35_PROVINCIAS.oi_pais = 1
			ORDER BY d_provincia ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_provincia" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_provincia" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_provincia" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_provincia" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
