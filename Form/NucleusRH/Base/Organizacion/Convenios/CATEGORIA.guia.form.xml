<form:Form extends="Nomad.parent.guia.form" doc="SOURCE" name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.guia" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label nowrap="1" style="S3 LCol_w" label="Seleccion de Categor&#237;as de Convenios" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:FKInput required="1" xsize="15" length="30" label="Convenios" nvalue="#SOURCE:@PARENTID" name="PARENTID">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|NEW|SHOW" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="server" action="RELOAD_QUERY" name="onReceiveData"/>
		</form:FKInput>
		<form:ListView nvalue="#SOURCE:@id" docname="RS" rows="-330" name="GRID" width="450px">
			<form:LVColumns>
				<form:LVColumn attrname="code1" width="20%" align="left" type="string" sorteable="1" name="COD" label="Codigo" descrip="Codigo"/>
				<form:LVColumn attrname="text1" width="65%" align="left" type="string" sorteable="1" name="DES" label="Descripcion" descrip="Descripcion"/>
				<form:LVColumn label="B&#225;sico Hora/Mes" descrip="Valor Hora / B&#225;sico Mes" additional="###,###,##0.00" type="number" width="15%" sorteable="1" name="n_valor_hora" attrname="n_valor_hora" align="right"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="NEW" visible="0"/>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
