<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucluesRH.Base.Organizacion.Clases_Organizativas.ESTRUC_PERS.flow">
	<flow:info label="flow para NucluesRH.Base.Organizacion.Clases_Organizativas.ESTRUC_PERS.flow"/>
	<flow:declare>
		<doc:define name="LEGAJOS">
			<FILTRO>
				<ROWS/>
			</FILTRO>
		</doc:define>
		<doc:define name="EMPRESA">
			<EMPRESA oi_empresa="" oi_estructura=""/>
		</doc:define>
		<doc:define name="ESTRUCTURA">
			<ESTRUCTURA id=""/>
		</doc:define>
		<doc:define name="RS">
			<ROW PARENTID="" CODE="" TEXT="">
				<ROWS/>
			</ROW>
		</doc:define>
		<doc:define name="PARAMIN"/>
		<qry:define declare="&lt;EMPRESA oi_empresa=&quot;9&quot; oi_estructura=&quot;110&quot; /&gt;" name="HELPPER">
			<qry:main doc="SOURCE">
				<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
				<qry:element name="rows">
					<qry:insert-select name="RS1" doc-path="#SOURCE:EMPRESA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.oi_personal_emp, PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom
				FROM PER02_PERSONAL_EMP, PER01_PERSONAL
				JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE PER02_PERSONAL_EMP.oi_empresa = {#SOURCE:@oi_empresa} 													
				AND PER02_PERSONAL_EMP.oi_personal_emp NOT IN 
				(SELECT ORG02_ESTRUC_PERS.oi_personal_emp FROM 
				ORG02_ESTRUC_PERS WHERE ORG02_ESTRUC_PERS.oi_estructura = {%=#SOURCE:@oi_estructura%})
				ORDER BY e_numero_legajo ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_personal_emp" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_personal_emp" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@e_numero_legajo" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_ape_y_nom" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
					SELECT NMD_SECURITY.policy 
					FROM NMD_SECURITY 
					WHERE NMD_SECURITY.class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\' 
					AND NMD_SECURITY.id={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELPUO">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute value="#SOURCE:ROW/@PARENTID" name="PARENTID"/>
					<qry:attribute value="#SOURCE:ROW/@CODE" name="CODE"/>
					<qry:attribute value="#SOURCE:ROW/@TEXT" name="TEXT"/>
					<qry:attribute value="#SOURCE:ROW/@FILTER" name="FILTER"/>
					<qry:attribute value="#SOURCE:ROW/@STAFF" name="STAFF"/>
					<qry:insert-select doc-path="." name="RS2"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path=".." name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('SELECT t.oi_tipo_uni_org as ID, t.c_tipo_uni_org as CODE, t.d_tipo_uni_org as TEXT, SEC.policy  FROM ORG01_TIPOS_UNI as t, NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Unidades_Organizativas.TIPO_UNI_ORG\') as SEC JOIN t.oi_tipo_uni_org LEFT OUTER SEC.id  WHERE t.oi_tipo_uni_org={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_unidad_org as ID, t.c_unidad_org as CODE, t.d_unidad_org as TEXT, t.oi_tipo_uni_org as PID FROM ORG01_UNI_ORG as t WHERE  t.oi_tipo_uni_org={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code1"/>
						<qry:attribute value="$r/@STAFF" name="staff"/>
						<qry:attribute value="$r/@TEXT" name="text1"/>
						<qry:attribute value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
						<qry:attribute value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRELOADUO">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:" name="HM"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS2"/>
					<qry:insert-select doc-path="." name="RS3"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path=".." name="RS1"/>
					</qry:element>
					<qry:attribute value="substring(#HM:@TEXT,1+string_length(./@TEXT))" name="FILTER"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS3">
				<qry:xquery>
					for $r in sql('SELECT t.oi_tipo_uni_org as ID, t.c_tipo_uni_org as CODE, t.d_tipo_uni_org as TEXT, SEC.policy  FROM ORG01_TIPOS_UNI as t, NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Unidades_Organizativas.TIPO_UNI_ORG\') as SEC JOIN t.oi_tipo_uni_org LEFT OUTER SEC.id  WHERE t.oi_tipo_uni_org={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('select t.oi_tipo_uni_org from ORG01_UNI_ORG as t where t.oi_unidad_org={#SOURCE:@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_tipo_uni_org" name="PARENTID"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_unidad_org as ID, t.c_unidad_org as CODE, t.d_unidad_org as TEXT, t.oi_tipo_uni_org as PID FROM ORG01_UNI_ORG as t WHERE  t.oi_tipo_uni_org={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code1"/>
						<qry:attribute value="$r/@TEXT" name="text1"/>
						<qry:attribute value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
						<qry:attribute value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELPORG">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_clase_org as ID, t.c_clase_org as CODE, t.d_clase_org as TEXT, SEC.policy  FROM ORG02_CLASES_ORG as t, NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG\') as SEC JOIN t.oi_clase_org LEFT OUTER SEC.id  ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;rows nmd-col=&quot;1&quot;&gt;&#13;&#10;  &lt;row check=&quot;1&quot; text=&quot;Sarmiento, Domingo Faustino&quot; code=&quot;1&quot; value=&quot;11423&quot; id=&quot;11423&quot; /&gt;&#13;&#10;  &lt;row check=&quot;1&quot; text=&quot;RIZZO, JUAN PABLO&quot; code=&quot;2&quot; value=&quot;232&quot; id=&quot;232&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;CRAPACHER, ATILIO PEDRO&quot; code=&quot;3&quot; value=&quot;233&quot; id=&quot;233&quot; /&gt;&#13;&#10;  &lt;row check=&quot;1&quot; text=&quot;BLAJOS, MARIO CONSTANTINO&quot; code=&quot;4&quot; value=&quot;234&quot; id=&quot;234&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;AVILA, JUSTO LORENZO&quot; code=&quot;5&quot; value=&quot;235&quot; id=&quot;235&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;ORTIZ, ANALIA CINTHIA&quot; code=&quot;6&quot; value=&quot;237&quot; id=&quot;237&quot; /&gt;&#13;&#10;  &lt;row check=&quot;1&quot; text=&quot;MAESTRO, LUIS RAUL&quot; code=&quot;7&quot; value=&quot;238&quot; id=&quot;238&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;CEREDA, CARLOS MARTIN&quot; code=&quot;8&quot; value=&quot;239&quot; id=&quot;239&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;LUCANGELI, JUAN IGNACIO&quot; code=&quot;9&quot; value=&quot;240&quot; id=&quot;240&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;MAKAUSKAS, CLAUDIA GABRIELA&quot; code=&quot;25&quot; value=&quot;11457&quot; id=&quot;11457&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;Gabrich, Ivan&quot; code=&quot;102&quot; value=&quot;11433&quot; id=&quot;11433&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;Olmos, Federico&quot; code=&quot;106&quot; value=&quot;11449&quot; id=&quot;11449&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;Ruiz, Miguel&quot; code=&quot;123&quot; value=&quot;11450&quot; id=&quot;11450&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;Alle