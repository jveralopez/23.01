; code=&quot;23147265&quot; value=&quot;11535&quot; id=&quot;11535&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;PALACIOS , FABIO&quot; code=&quot;23147266&quot; value=&quot;11538&quot; id=&quot;11538&quot; /&gt;&#13;&#10;  &lt;row check=&quot;0&quot; text=&quot;Canseco, Mariano Andres&quot; code=&quot;23147267&quot; value=&quot;11551&quot; id=&quot;11551&quot; /&gt;&#13;&#10;&lt;/rows&gt;&#13;&#10;" name="LEGAJOSADD">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:rows" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:row[@check='1']
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@id" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define class="NucleusRH.Base.Organizacion.Vistas.VISTA" name="DDO_VISTA"/>
		<qry:define name="FICTICIO">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1">
				<qry:xquery>
					for $r in SQL('
				select 
					U.oi_unidad_org
				from
					ORG01_UNI_ORG as U, ORG01_TIPOS_UNI as T
				join
					U.oi_tipo_uni_org INNER T.oi_tipo_uni_org
				where
					U.c_unidad_org=\'FIC\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="DELLEGAJO">
			<flow:exec-method class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG" method="QuitarLegajo">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
				<flow:param attr-path="#SOURCE:@VALUE" type="Nomad.NSystem.String" mode="in" name="personal_emp_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DELESTR">
			<flow:exec-method method="EliminarEstructura" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
				<flow:param attr-path="#SOURCE:@VALUE" type="Nomad.NSystem.String" mode="in" name="personal_emp_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="MOVEESTR">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.MOVER.guia.form" mode="SHOW_CLASS" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="SETRESP">
			<flow:exec-method method="SetResponsable" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
				<flow:param attr-path="#SOURCE:@VALUE" type="Nomad.NSystem.String" mode="in" name="personal_emp_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="UNSETRESP">
			<flow:exec-method method="UnSetResponsable" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
				<flow:param attr-path="#SOURCE:@VALUE" type="Nomad.NSystem.String" mode="in" name="personal_emp_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ADDLEGAJO">
			<doc:set-attribute to-attr-path="#LEGAJOS:@oi_estructura" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<flow:open-form doc-path="#LEGAJOS:" form-class="NucleusRH.Base.Organizacion.Clases_Organizativas.PERSONAL_EMP.guia.form" parent-doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="ADDHIJO">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:load-qry qry="PRELOADUO" output-doc="RS" input-doc-path="#SOURCE:"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.guia.autoform"/>
		</flow:action>
		<flow:action name="ADDHIJOFIC">
			<doc:load-qry output-doc="RS" qry="FICTICIO"/>
			<flow:exec-method method="AddHijo" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
				<flow:param attr-path="#RS:@oi_unidad_org" type="Nomad.NSystem.String" mode="in" name="unidad_org_id"/>
				<flow:param value="0" type="Nomad.NSystem.Boolean" mode="in" name="staff"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ADDORG">
			<doc:set-attribute to-attr-path="#ESTRUCTURA:@id" from-attr-path="#SOURCE:@OI_ESTRUCTURA"/>
			<doc:load-qry qry="HELPORG" output-doc="RS" input-doc-path="#SOURCE:"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.guia.autoform"/>
		</flow:action>
		<flow:action name="DELORG">
			<flow:exec-method method="DelOrganigrama" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_CLASE_ORG" type="Nomad.NSystem.String" mode="in" name="clase_org_id"/>
				<flow:param name="estr_padre_id" attr-path="#SOURCE:@OI_ESTR_PADRE" type="Nomad.NSystem.String" mode="in"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="SETSTAFF">
			<flow:exec-method method="SetStaff" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
