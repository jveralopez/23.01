			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DELSTAFF">
			<flow:exec-method method="DelStaff" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG">
				<flow:param attr-path="#SOURCE:@OI_ESTRUCTURA" type="Nomad.NSystem.String" mode="in" name="estructura_id"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DELVISTA">
			<doc:load-object doc="DDO_VISTA" id-path="#SOURCE:@VALUE" class="NucleusRH.Base.Organizacion.Vistas.VISTA"/>
			<doc:delete-object doc-path="#DDO_VISTA:"/>
			<doc:save-object class="NucleusRH.Base.Organizacion.Vistas.VISTA" doc="DDO_VISTA"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ADDVISTA">
