<form:Form default_mode="SHOW" xmlns:form="nomad_engine.form" name="NucleusRH.Base.Organizacion.Clases_Organizativas.TEST.guia" doc="SOURCE">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" label="Seleccion de Estructuras Organizativas" style="S3 LCol_w" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:FKInput name="PARENTID" nvalue="#SOURCE:@PARENTID" label="Estructuras Organizativas" length="30" xsize="15" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="EDIT|NEW|SHOW">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Combo name="oi_clase_org" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.combo.autoflow" required="1" nvalue="#SOURCE:@oi_clase_org" label="Clase Organizativa" action="COMBO" visible="SHOW"/>
		<form:FKInput name="#SOURCE:@oi_estructura" nvalue="#SOURCE:@PARENTID" label="Estructuras Organizativas" length="30" xsize="15" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X_CLASS" x2c="X2C_CLASS" help="HELP_CLASS" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
				<helper-mess oi_clase_org="{oi_clase_org.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="EDIT|NEW|SHOW">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
</form:Form>

