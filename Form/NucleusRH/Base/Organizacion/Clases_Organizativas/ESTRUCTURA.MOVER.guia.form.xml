	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_clase_org=&quot;42&quot; estructura=&quot;236&quot;/&gt;" name="qry:ESTRUCTURA">
			<qry:main doc="PARAM">
				<qry:append-doc name="INVAL" doc-path="#PARAM:/PARAM"/>
				<qry:element name="tree">
					<qry:element name="groups">
						<qry:insert-select name="qry_clase_organizativa" doc-path="#PARAM:/PARAM"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="qry_clase_organizativa" doc="PARAM">
				<qry:xquery>
					for $r in sql('
					SELECT ORG02_CLASES_ORG.oi_estructura_org, 
					ORG02_CLASES_ORG.d_clase_org 
					FROM ORG02_CLASES_ORG 
					WHERE ORG02_CLASES_ORG.oi_clase_org = {#PARAM:@oi_clase_org}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="group">
						<qry:attribute value="$r/@oi_estructura_org" name="id"/>
						<qry:attribute value="#PARAM:@oi_clase_org" name="pid"/>
						<qry:insert-select name="qry_padre" doc-path="."/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_padre" doc="PARAM">
				<qry:xquery>
					for $r in sql('
					SELECT ORG01_TIPOS_UNI.c_tipo_uni_org, 
					ORG01_UNI_ORG.c_unidad_org, 
					ORG01_UNI_ORG.d_unidad_org, 
					ORG02_ESTRUCTURAS.oi_unidad_org 
					FROM ORG02_ESTRUCTURAS, ORG01_UNI_ORG, ORG01_TIPOS_UNI 
					JOIN ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org, 
					ORG01_UNI_ORG.oi_tipo_uni_org INNER ORG01_TIPOS_UNI.oi_tipo_uni_org
					WHERE ORG02_ESTRUCTURAS.oi_estructura = {#PARAM:@id} 					
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="'('+$r/@c_tipo_uni_org+') '+$r/@c_unidad_org+' - '+$r/@d_unidad_org" name="name"/>
					<qry:attribute value="#PARAM:@id" name="id"/>
					<qry:attribute value="#PARAM:@pid" name="pid"/>
					<qry:attribute value="'1'" name="expanded"/>
					<qry:element name="groups">
						<qry:insert-select name="qry_unidad_organizativa" doc-path=".."/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_unidad_organizativa" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT ORG02_ESTRUCTURAS.oi_estructura, 
						ORG01_TIPOS_UNI.c_tipo_uni_org, 
						ORG01_UNI_ORG.c_unidad_org, 
						ORG01_UNI_ORG.d_unidad_org, 
						ORG02_ESTRUCTURAS.oi_unidad_org 
						FROM ORG02_ESTRUCTURAS, ORG01_UNI_ORG, ORG01_TIPOS_UNI 
						JOIN ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org,
						ORG01_UNI_ORG.oi_tipo_uni_org INNER ORG01_TIPOS_UNI.oi_tipo_uni_org
						WHERE ORG02_ESTRUCTURAS.oi_estr_padre = {#PARAM:@id} 						
						AND ORG02_ESTRUCTURAS.oi_estructura != {#INVAL:@estructura} 
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="group">
						<qry:attribute type="Nomad.NSystem.String" value="'('+$r/@c_tipo_uni_org+') '+$r/@c_unidad_org+' - '+$r/@d_unidad_org" name="name"/>
						<qry:attribute value="$r/@oi_estructura" name="id"/>
						<qry:attribute value="#PARAM:@pid" name="pid"/>
						<qry:attribute value="iif(#INVAL:@id=$r/@oi_estructura,'1','0')" name="showitem"/>
						<qry:attribute value="iif(#INVAL:@id=$r/@oi_estructura,'1','0')" name="bold"/>
						<qry:element name="groups">
							<qry:insert-select name="qry_unidad_organizativa" doc-path=".."/>
						</qry:element>
						<qry:insert-select name="expanded" doc-path="./groups/group[@showitem=1]"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="expanded" doc="PARAM">
				<qry:out>
					<qry:attribute value="1" name="showitem"/>
					<qry:attribute value="1" name="expanded"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
