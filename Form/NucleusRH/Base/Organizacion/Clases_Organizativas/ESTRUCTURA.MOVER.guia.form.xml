	<form:Resources>
		<form:Resource declare="&lt;PARAM id=&quot;539&quot; /&gt;" name="qry_estructura">
			<qry:main doc="PARAM">
				<qry:element name="tree">
					<qry:append-doc name="PARAMIN" doc-path="#PARAM:/PARAM"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:/PARAM"/>
					<qry:insert-select name="sql3" doc-path="#PARAM:/PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT ORG02_ESTRUCTURAS.oi_estructura, 
						ORG01_TIPOS_UNI.c_tipo_uni_org, 
						ORG01_UNI_ORG.c_unidad_org, 
						ORG01_UNI_ORG.d_unidad_org, 
						ORG02_ESTRUCTURAS.oi_unidad_org 
						FROM ORG02_ESTRUCTURAS, ORG01_UNI_ORG, ORG01_TIPOS_UNI 
						JOIN ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org,
						ORG01_UNI_ORG.oi_tipo_uni_org INNER ORG01_TIPOS_UNI.oi_tipo_uni_org
						WHERE ORG02_ESTRUCTURAS.oi_estr_padre = {#PARAM:@id} 					
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$PARAMIN/@oi_estructura!=$r/@oi_estructura">
						<qry:then>
							<qry:element name="group">
								<qry:attribute value="$r/@oi_estructura" name="id"/>
								<qry:if test="$r/@c_tipo_uni_org='FIC'">
									<qry:then>
										<qry:attribute value="'Ficticia'" name="label"/>
										<qry:attribute value="'REP-HIDDEN.ico'" name="imgClose"/>
										<qry:attribute value="'REP-HIDDEN.ico'" name="imgOpen"/>
									</qry:then>
									<qry:else>
										<qry:attribute value="'['+$r/@c_unidad_org+'] '+$r/@d_unidad_org" name="label"/>
										<qry:attribute value="'estructura.ico'" name="imgClose"/>
										<qry:attribute value="'estructura.ico'" name="imgOpen"/>
									</qry:else>
								</qry:if>
							</qry:element>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="sql3" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT 
							ORG02_ESTRUC_PERS.oi_estruc_pers,
							ORG02_ESTRUC_PERS.l_responsable,
							PER02_PERSONAL_EMP.e_numero_legajo,
							PER01_PERSONAL.d_ape_y_nom,
							ORG03_EMPRESAS.c_empresa
						FROM 
							ORG02_ESTRUC_PERS, PER02_PERSONAL_EMP, PER01_PERSONAL, ORG03_EMPRESAS  
						JOIN 
							ORG02_ESTRUC_PERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
							PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
							PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
						WHERE 
							ORG02_ESTRUC_PERS.oi_estructura = {#PARAM:@id} 					
						ORDER BY
							l_responsable DESC, d_ape_y_nom ASC
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="item">
						<qry:attribute value="$r/@oi_estruc_pers" name="id"/>
						<qry:attribute value="'['+$r/@c_empresa+'-'+$r/@e_numero_legajo+'] '+$r/@d_ape_y_nom" name="label"/>
						<qry:attribute value="iif ($r/@l_responsable=1,'user-si.ico','user.ico')" name="img"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Scripts>
		function LoadChilds(objTree, objGroup)
{
	nSQL = GetProxy().SQLService();
	         
	var id=objGroup.FullId.split("/"); id=id[id.length-1];
	if(id==".") id = "";
	
	var resultxt=nSQL.Get(Ctrl("main").getResource("qry_estructura"), "&lt;PARAM id=\""+id+"\" oi_estructura=\""+Ctrl("oi_estructura_orig").GetXValue()+"\"/&gt;");	
  objTree.SetXML(objGroup.FullId, resultxt);
}

function onLoad()
{ 
	nSQL = GetProxy().SQLService();
	
	var resultxt=nSQL.Get(Ctrl("main").getResource("qry_clases"), "&lt;PARAM oi_clase_org=\""+Ctrl("oi_clase_org").GetXValue()+"\" /&gt;");
	CLASS_TREE=clsClientTree("contESTR","oi_estructura_full","CLOCK.ico","folder-close.ico","folder.ico","item.ico",true,LoadChilds,null,onClick,1000);
	CLASS_TREE.SetXML(null, resultxt);
	
	CLASS_TREE.SetSelectedId(".");
	CLASS_TREE.ClickExpGroup(".");
}            

function ACCEPT()
{       
	var ids=Ctrl("oi_estructura_full").GetXValue().split("/");
	ids=ids[ids.length-1];             
	Ctrl("estructura_to_id").SetXValue(ids);
	return true;	
}
	</form:Scripts>
