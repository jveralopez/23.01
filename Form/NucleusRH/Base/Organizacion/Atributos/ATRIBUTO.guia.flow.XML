<flow:flow name="NucleusRH.Base.Organizacion.Atributos.ATRIBUTO.guia.flow" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form" extends="NucleusRH.Base.Organizacion.Atributos.ATRIBUTO.guia.autoflow">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Atributos.ATRIBUTO"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT ORG15_ATRIBUTOS.oi_atributo AS ID, ORG15_ATRIBUTOS.c_atributo AS CODE, 
			ORG15_ATRIBUTOS.d_atributo AS TEXT  
			FROM ORG15_ATRIBUTOS, ORG01_TUNI_ATRIB
			JOIN ORG15_ATRIBUTOS.oi_atributo INNER ORG01_TUNI_ATRIB.oi_atributo
			WHERE ORG01_TUNI_ATRIB.oi_tipo_uni_org = {#SOURCE:helper-mess/@oi_tipo_uni_org}
			AND ORG15_ATRIBUTOS.c_atributo={#SOURCE:helper-mess/@CODE}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="SUB_SEARCH" value="''" type="Nomad.NSystem.String"/>
					<qry:attribute name="PARENTID" value="''" type="Nomad.NSystem.String"/>
					<qry:attribute name="id" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="value" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="code" value="$r/@CODE" type="Nomad.NSystem.String"/>
					<qry:attribute name="text" value="$r/@TEXT" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG15_ATRIBUTOS.oi_atributo, ORG15_ATRIBUTOS.c_atributo, 
				ORG15_ATRIBUTOS.d_atributo 
				FROM ORG15_ATRIBUTOS, ORG01_TUNI_ATRIB
				WHERE ORG15_ATRIBUTOS.oi_atributo INNER ORG01_TUNI_ATRIB.oi_atributo
				ORG01_TUNI_ATRIB.oi_tipo_uni_org = {#SOURCE:helper-mess/@oi_tipo_uni_org}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@OI_ATRIBUTO" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@OI_ATRIBUTO" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@C_atributo" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@D_atributo" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
