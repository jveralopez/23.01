		<form:Blank name="bnk2"/>
		<form:Grid proto="&lt;LOCALIDAD/&gt;" width="480px" idvalue="#SOURCEGRILLA:@id" nvalue="#FILTERDATA:LOCALIDADES" name="grdLocalidad" doc="SOURCEGRILLA" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="">
