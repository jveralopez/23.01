				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#SOURCEGRILLA:@id" label="Localidad" name="oi_localidad" length="30" xsize="15" enabled="" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.PROVINCIA.Guia.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess oi_provincia="{oi_provincia.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Line name="line_2" width="100%"/>
		<form:Label label="Criterio de Ordenamiento" style="M1 LCol_g" align="center" visible="" name="lbl211"/>
		<form:Blank visible="" width="100%" name="bl5"/>
		<form:RowAligner columns="2" name="RAcamposOrden">
