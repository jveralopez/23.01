					<form:Helper name="NucleusRH.Base.Organizacion.Municipios.MUNICIPIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
