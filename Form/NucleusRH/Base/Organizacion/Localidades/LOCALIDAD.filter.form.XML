<form:Form extends="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.filter.autoform" default_mode="EDIT" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD" xmlns:form="nomad_engine.form">
	<form:Center>
