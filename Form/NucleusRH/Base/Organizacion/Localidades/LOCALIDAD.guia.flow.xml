<flow:flow default_action="HELP" extends="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.autoflow" name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Localidades.LOCALIDAD"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:log text-path="#RS:" text="kkrs"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot; /&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT ORG19_LOCALIDADES.oi_localidad as ID,
				ORG19_LOCALIDADES.c_localidad as CODE,
				ORG19_LOCALIDADES.d_localidad as TEXT,
				ORG19_LOCALIDADES.oi_provincia as PID 
				FROM ORG19_LOCALIDADES
				WHERE ORG19_LOCALIDADES.oi_localidad={#SOURCE:helper-mess/@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@PID" name="PID"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess PARENTID=&quot;3&quot; /&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('							
			SELECT ORG19_LOCALIDADES.oi_localidad as ID,
			ORG19_LOCALIDADES.c_postal as CODE,
			ORG19_LOCALIDADES.d_localidad as TEXT
			FROM ORG19_LOCALIDADES			
			WHERE ORG19_LOCALIDADES.oi_provincia={#SOURCE:@PARENTID}
		  ORDER BY TEXT ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
						<qry:insert-select doc-path="$r" name="SECURITY_LOCALIDAD"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_LOCALIDAD">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Localidades.LOCALIDAD\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.autoform:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.form:SHOW" form-class="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.guia.form"/>
</flow:flow>
