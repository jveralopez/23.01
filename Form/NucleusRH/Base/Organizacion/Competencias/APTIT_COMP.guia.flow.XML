<flow:flow extends="Nomad.parent.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Organizacion.Competencias.APTIT_COMP.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Organizacion.Competencias.APTIT_COMP"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define declare="&lt;helper-mess id=&quot;1&quot; /&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG21_APTIT_COMP.oi_aptit_comp AS ID, 
					ORG28_APTITUDES.c_aptitud AS CODE, 
					ORG28_APTITUDES.d_aptitud AS TEXT
					FROM ORG21_APTIT_COMP, ORG28_APTITUDES
					JOIN ORG28_APTITUDES.oi_aptitud INNER ORG21_APTIT_COMP.oi_aptitud
					WHERE ORG21_APTIT_COMP.oi_aptit_comp={#SOURCE:helper-mess/@id}					
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_competencia=&quot;3&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT ORG21_APTIT_COMP.oi_aptit_comp AS ID, 
					ORG28_APTITUDES.c_aptitud AS CODE, 
					ORG28_APTITUDES.d_aptitud AS TEXT
					FROM ORG21_APTIT_COMP, ORG28_APTITUDES
					JOIN ORG28_APTITUDES.oi_aptitud INNER ORG21_APTIT_COMP.oi_aptitud
					WHERE ORG21_APTIT_COMP.oi_competencia={#SOURCE:helper-mess/@oi_competencia}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
