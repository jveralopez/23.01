<form:Form xmlns:form="nomad_engine.form" name="ExportarOrg" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="Exportar Organigrama" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="cols1">
			<form:Column valign="middle" separation="5" name="col1" align="center">
				<form:Blank name="bc01"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.INFO_VIGENTES" visible="0" label="Organigrama" nvalue="#source:@oi_clase_org" name="oi_clase_org" xsize="40" mode="QRY" required="1"/>
				<form:FKInput label="Estructructura Inicial" descrip="Estructructura Inicial" nvalue="#source:@oi_estructura" required="1" enabled="" xsize="15" length="30" name="estructura">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:CheckBox nvalue="#source:@l_legajos" label="Legajos" name="l_legajos"/>
				<form:CheckBox label="Fecha ingreso" nvalue="#source:@l_ingreso" name="l_ingreso"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="95%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="OK" descrip="" visible="" enabled="" name="btnACCEPT" label="Aceptar" startvalidate="1">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button name="btnCANCEL" label="Volver" img="back" descrip="Volver" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
