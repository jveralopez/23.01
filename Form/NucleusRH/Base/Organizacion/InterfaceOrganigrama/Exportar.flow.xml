<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Organizacion.InterfaceOrganigrama.Exportar.flow" default_action="initializeOrg">
	<flow:declare>
		<doc:define name="BATCHDOC"/>
		<doc:define name="DATA">
			<DATA GROUP="ASSA"/>
		</doc:define>
		<doc:define name="FILTERDATA"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initializeOrg">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.InterfaceOrganigrama.ExportarOrg.form" doc-path="#DATA:" parent-doc-path="#DATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Organizacion.InterfaceOrganigrama.ExportarOrg.form:SHOW" form-class="NucleusRH.Base.Organizacion.InterfaceOrganigrama.ExportarOrg.form" doc="SOURCE" mode="SHOW">
		<flow:action name="BACK">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text-path="#SOURCE:" text="JP_SOURCE"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="NucleusRH.Base.Organizacion.InterfaceOrganigrama.ORGANIGRAMA" method="ExportOrg" out-attr-path="#BATCHDOC:@batch-id" priority="7">
				<flow:param attr-path="#SOURCE:@oi_estructura" name="oi_estructura" type="Nomad.NSystem.String" mode="in"/>
				<flow:param attr-path="#SOURCE:@l_legajos" type="Nomad.NSystem.Boolean" name="l_legajos" mode="in"/>
				<flow:param attr-path="#SOURCE:@l_ingreso" type="Nomad.NSystem.Boolean" name="l_ingreso" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Exportar Organigrama a Excel" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="NucleusRH.Base.Organizacion.InterfaceOrganigrama.download.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Organizacion.InterfaceOrganigrama" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Organizacion.InterfaceOrganigrama" doc="SOURCE"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.InterfaceOrganigrama.download.form:SHOW" form-class="NucleusRH.Base.Organizacion.InterfaceOrganigrama.download.form" mode="SHOW" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
</flow:flow>
