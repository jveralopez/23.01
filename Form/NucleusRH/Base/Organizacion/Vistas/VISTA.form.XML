<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Organizacion.Vistas.VISTA.form" extends="NucleusRH.Base.Organizacion.Vistas.VISTA.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" visible="NEW|EDIT" img="save" label="Guardar" name="SAVE" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Duplica el Registro Seleccionado." img="duplicate" label="Duplicar" name="DUPLICAR" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/DUPLICAR">
					<form:Event action="DUP" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="org" descrip="Ver detalle del Registro" name="DETAIL" visible="SHOW|LIST" label="Detalle">
					<form:Event action="DETAIL" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" visible="NEW|EDIT|DELETE" img="cancel" label="Cancelar" name="CANCEL" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Volver a la pantalla anterior." visible="SHOW|LIST" img="back" label="Volver" name="BACK" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Vistas/VISTA/form/ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
