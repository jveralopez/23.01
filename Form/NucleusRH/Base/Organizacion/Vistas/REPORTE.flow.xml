<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Organizacion.Vistas.REPORTE.flow" extends="NucleusRH.Base.Organizacion.Vistas.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Vistas"/>
	<flow:declare>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_clase_org=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATO oi_vista=""/>
		</doc:define>
		<qry:define declare="&#9;&lt;DATO oi_vista=&quot;1&quot;/&gt;" name="QRY_CLASE">
			<qry:main doc="SOURCE">
				<qry:insert-select name="sql1" doc-path="#SOURCE:DATO"/>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
						SELECT ORG42_VISTAS.oi_clase_org,
						ORG42_VISTAS.c_vista,
						ORG42_VISTAS.d_vista,
						ORG42_VISTAS.e_niveles,
						ORG42_VISTAS.oi_estructura
						FROM ORG42_VISTAS
						WHERE ORG42_VISTAS.oi_vista = {#SOURCE:@oi_vista}
					')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PARAMETERS">
						<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
						<qry:attribute name="oi_estructura_org" value="$r/@oi_estructura"/>
						<qry:attribute name="deep" value="$r/@e_niveles"/>
						<qry:attribute name="d_vista" value="'[' + $r/@c_vista + ' - ' + $r/@d_vista + ']'"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Vistas.REPORTE.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Organizacion.Vistas.REPORTE.filter.form:FILTER" form-class="NucleusRH.Base.Organizacion.Vistas.REPORTE.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<doc:load-qry input-doc-path="#FILTERDATA:" output-doc="PARAMETERS" qry="QRY_CLASE"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="REPORT" form-class="NucleusRH.Base.Organizacion.Vistas.REPORTE.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Organizacion.Vistas.REPORTE" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Organizacion.Vistas.REPORTE" doc="SOURCE"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.Vistas.REPORTE.form:REPORT" form-class="NucleusRH.Base.Organizacion.Vistas.REPORTE.form" doc="SOURCE" mode="REPORT">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
