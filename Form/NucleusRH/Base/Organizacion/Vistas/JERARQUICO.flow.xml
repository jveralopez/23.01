<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Organizacion.Vistas.JERARQUICO.flow" extends="NucleusRH.Base.Organizacion.Vistas.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Vistas"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_vista as oi_vista, 
				SEC.policy 
				FROM ORG42_VISTAS as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Vistas.VISTA\') as SEC,
				ORG02_CLASES_ORG
				JOIN t0.oi_vista LEFT OUTER SEC.id,
				t0.oi_clase_org INNER ORG02_CLASES_ORG.oi_clase_org
				WHERE ORG02_CLASES_ORG.l_automatica = \'1\' 
				ORDER BY oi_vista asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_vista"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_vista as oi_vista, 
				t0.c_vista as c_vista, 
				t0.d_vista as d_vista, 
				SEC.policy, 
				t0.c_vista as CODE, 
				t0.d_vista as TEXT, 
				t0.oi_clase_org as oi_clase_org 				
				FROM ORG42_VISTAS as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Vistas.VISTA\') as SEC,
				ORG02_CLASES_ORG
				JOIN t0.oi_vista LEFT OUTER SEC.id,
				t0.oi_clase_org INNER ORG02_CLASES_ORG.oi_clase_org
				WHERE ORG02_CLASES_ORG.l_automatica = \'1\' 
				ORDER BY oi_vista asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_vista"/>
						<qry:attribute name="c_vista" value="$r/@c_vista"/>
						<qry:attribute name="d_vista" value="$r/@d_vista"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&#9;&lt;DATO oi_vista=&quot;1&quot;/&gt;" name="QRY_CLASE">
			<qry:main doc="SOURCE">
				<qry:insert-select name="sql1" doc-path="#SOURCE:DATO"/>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
					SELECT ORG42_VISTAS.oi_clase_org,
					ORG42_VISTAS.c_vista,
					ORG42_VISTAS.d_vista,
					ORG42_VISTAS.e_niveles,
					ORG42_VISTAS.oi_estructura,
					ORG03_EMPRESAS.oi_empresa
					FROM ORG42_VISTAS, ORG02_CLASES_ORG, ORG02_ESTRUCTURAS, ORG03_EMPRESAS
					JOIN ORG42_VISTAS.oi_clase_org INNER ORG02_CLASES_ORG.oi_clase_org,
					ORG02_CLASES_ORG.oi_estructura_org INNER ORG02_ESTRUCTURAS.oi_estructura,
					ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG03_EMPRESAS.oi_unidad_org
					WHERE ORG42_VISTAS.oi_vista = {#SOURCE:@oi_vista}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PARAMETERS">
						<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
						<qry:attribute name="oi_estructura_org" value="$r/@oi_estructura"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
						<qry:attribute name="deep" value="$r/@e_niveles"/>
						<qry:attribute name="d_vista" value="'[' + $r/@c_vista + ' - ' + $r/@d_vista + ']'"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_clase_org=""/>
		</doc:define>
		<doc:define name="DATA">
			<DATO oi_vista=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE"/>
	<flow:form extends="NucleusRH.Base.Organizacion.Vistas.VISTA.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.filter.form:FILTER" form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.filter.autoform" mode="FILTER">
		<flow:action name="open-flow-SHOW">
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.noreg.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Vistas.VISTA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.noreg.form" mode="EDIT">
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Vistas.VISTA.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.form:SHOW" form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.form" mode="SHOW">
		<flow:action name="DETAIL">
			<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#DATA:@oi_vista"/>
			<doc:load-qry output-doc="PARAMETERS" input-doc-path="#DATA:" qry="QRY_CLASE"/>
			<flow:open-form parent-doc-path="#DDO:" form-class="NucleusRH.Base.Organizacion.Vistas.JERARQUICO.form" doc-path="#PARAMETERS:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Organizacion.Vistas.VISTA.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.form:LIST" form-class="NucleusRH.Base.Organizacion.Vistas.VISTA.form" mode="LIST">
		<flow:action name="DETAIL">
			<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#DATA:@oi_vista"/>
			<doc:load-qry output-doc="PARAMETERS" input-doc-path="#DATA:" qry="QRY_CLASE"/>
			<flow:open-form parent-doc-path="#DDO:" form-class="NucleusRH.Base.Organizacion.Vistas.JERARQUICO.form" doc-path="#PARAMETERS:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.Vistas.JERARQUICO.form:SHOW" form-class="NucleusRH.Base.Organizacion.Vistas.JERARQUICO.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form next-action="After-Change"/>
		</flow:action>
	</flow:form>
</flow:flow>
