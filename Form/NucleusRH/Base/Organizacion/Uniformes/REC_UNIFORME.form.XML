<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Recuento de Uniformes" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Recuento de Uniformes" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Recuento de Uniformes" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Recuento de Uniformes" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsREC_UNIFORME">
			<form:Column name="main_columnsREC_UNIFORMEcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW" mask="###.###.##0" xsize="12" label="Uniforme" nvalue="#source:@oi_uniforme" name="oi_uniforme"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW" mask="dd/mm/yyyy" label="Fecha" nvalue="#source:@f_recuento" name="f_recuento">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox required="1" enabled="NEW" mask="###.###.##0" xsize="12" label="Cantidad" nvalue="#source:@e_cantidad" name="e_cantidad"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ONLOAD" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1" visible="NEW">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Personal/LegajoEmpresa/CATEGORIA_PER/NEW" visible="EDIT|LIST_EDIT" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro" note="Agregar el Registro">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Personal/LegajoEmpresa/CATEGORIA_PER/DELETE" visible="EDIT|LIST_EDIT" mess="&#191;Est&#225; seguro que desae eliminar el registro?" name="DELETE" label="Eliminar" img="del" descrip="Eliminar el Registro" note="Eliminar el Registro">
					<form:Event runat="server" name="onclick" action="DELETE"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario" visible="NEW">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|DELETE|EDIT|LIST_EDIT" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|DELETE|EDIT|LIST_EDIT" name="PARENT" label="Ir al Raiz" img="back" descrip="Volver a la pantalla Raiz" note="Vuelve a la pantalla raiz del formulario" startvalidate="1">
					<form:Event action="PARENT" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ONLOAD()
{
	if (Ctrl('main').GetMode() == 'NEW')
		return;
	
	var ult = 0;
	if (Ctrl('LIST'))
	{
		if (Ctrl('LIST').GetXValue() == Ctrl('LIST').GetAttrValue(Ctrl('LIST').TotalRowsCount()-1, 'id'))
		{
			ult = 1;
		}
	}	
	else
	{
		if (Ctrl('iter-position').GetXValue() == Ctrl('iter-size').GetXValue())
		{
			ult = 1;
		}
	}
	
	CtrlEnabled('f_recuento', false);
	CtrlEnabled('e_cantidad', false);
	CtrlEnabled('DELETE', false);
	
	if (ult == 1)
	{
		CtrlEnabled('f_recuento', true);
		CtrlEnabled('e_cantidad', true);
		CtrlEnabled('DELETE', true);
	}
}
	</form:Scripts>
	<form:Event name="onload" action="ONLOAD" runat="client"/>
</form:Form>
