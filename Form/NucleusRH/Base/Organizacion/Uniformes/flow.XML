<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Organizacion.Uniformes.flow" extends="NucleusRH.Base.Organizacion.Uniformes.autoflow">
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="DDOREC"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.filter.autoform" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:group Name="UNIFORME">
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.filter.form:FILTER" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.filter.autoform" mode="FILTER">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form:SHOW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form:LIST" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form:EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form:NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME.form" mode="NEW">
			<flow:action name="save-DDO">
				<doc:new-object class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME" doc="DDOREC"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@e_recuento_stock" to-attr-path="#DDOREC:@e_cantidad"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@f_ult_rec_stock" to-attr-path="#DDOREC:@f_recuento"/>
				<doc:add-object parent-doc-path="#NEWDDOROOT:UNIF_REC" doc-path="#DDOREC:"/>
				<doc:save-object class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME" doc="NEWDDOROOT"/>
				<doc:load-object id-path="#NEWDDOROOT:@id" class="NucleusRH.Base.Organizacion.Uniformes.UNIFORME" doc="DDO"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group Name="REC_UNIFORME">
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.autoform:LIST_EDIT" doc-path="/REC_UNIFORME[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form:LIST_EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form" mode="LIST_EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:REC_UNIFORME/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST_EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method this-doc="DDO" method="EliminarRecuento"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.noreg.form:EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
				<flow:open-form iter-index="#PARENTSOURCE:REC_UNIFORME/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:REC_UNIFORME/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST_EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.autoform:EDIT" doc-path="/REC_UNIFORME[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form:EDIT" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method this-doc="DDO" method="EliminarRecuento"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form:NEW" form-class="NucleusRH.Base.Organizacion.Uniformes.REC_UNIFORME.form" mode="NEW">
			<flow:action name="ACCEPT">
				<flow:log text-path="#SOURCE:" text="emisource"/>
				<flow:exec-method method="Cambio_Recuento" this-doc="DDO">
					<flow:param name="recuento" mode="in" doc="SOURCE" type="Object" class="NucleusRH.Base.Personal.LegajoEmpresa.CATEG_PER"/>
				</flow:exec-method>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
