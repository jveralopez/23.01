<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Organizacion.AtributosAuxiliares.ATRIB_AUX.autoform" name="NucleusRH.Base.Organizacion.AtributosAuxiliares.ATRIB_AUX.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Help>
		<form:Help-title text="Atributos Auxiliares" name="TITLE"/>
		<form:Help-descr name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label=" " name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcolc_atrib_aux">
					<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_atrib_aux" name="c_atrib_aux">
						<form:Event name="onchange" action="ValidarCod" runat="client"/>
					</form:TextBox>
				</form:GColumn>
				<form:GColumn name="gcold_atrib_aux">
					<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_atrib_aux" name="d_atrib_aux"/>
				</form:GColumn>
				<form:GColumn name="gcolc_tipo">
					<form:ComboBox xsize="40" mode="OPT" required="1" enabled="NEW|EDIT" label="Tipo de Datos" nvalue="#source:@c_tipo" name="c_tipo">
						<options>
							<option text="Valor Alfanum&#233;rico" value="STR"/>
							<option text="N&#250;mero Entero" value="INT"/>
							<option text="N&#250;mero Decimal" value="DOU"/>
							<option text="Fecha" value="DAT"/>
							<option text="Valor L&#243;gico (Si / No)" value="BOO"/>
						</options>
					</form:ComboBox>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Scripts>
		var value;
function ValidarCod(obj){
	value = obj.GetXValue();
	
    var patt = new RegExp("^([a-z]|[A-Z])");
    if(!patt.test(value)){
    	alert("El c&#243;digo del atributo auxiliar debe comenzar con una letra min&#250;scula o may&#250;scula");
    	obj.SetXValue("");
    }
}
	</form:Scripts>
</form:Form>
