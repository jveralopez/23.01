<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Organizacion.Reportes.Orgramigrama.filter.form">
	<form:Title>
		<form:Label label="001 - Organigrama" visible="" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl2"/>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:ComboBox nvalue="#source:@org_padre" where1="ORG02_CLASES_ORG.c_estado = 'V'" xsize="60" queryname1="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.INFO" name="oi_clase_org" mode="QRY" required="1" label="Organigrama"/>
		<form:ComboBox prev="oi_clase_org" where1="ORG02_CLASES_ORG.c_estado != 'R'" queryname1="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.INFO_VERSION" xsize="60" nvalue="#source:@oi_clase_org" name="version" mode="QRY" required="1" label="Version"/>
		<form:ComboBox mode="OPT" required="1" name="modo" nvalue="#source:@modo" label="Modo de Visualizaci&#243;n">
			<options>
				<option text="Cl&#225;sico" value="C"/>
				<option text="&#193;rbol" value="A"/>
			</options>
			<form:Event runat="client" name="onchange" action="onChangeModo"/>
		</form:ComboBox>
		<form:CheckBox descrip="" note="" label="Mostrar Legajos" nvalue="#source:@chkMostrarLeg" name="chkMostrarLeg">
			<form:SButtons/>
		</form:CheckBox>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Acepta los datos ingresados y ejecuta el formulario" note="Ejecuta la busqueda" img="ok" label="Aceptar" name="btnAceptar" visible="" enabled="">
					<form:Event runat="client" name="onclick" action="onEjecutar"/>
				</form:Button>
				<form:Button descrip="Vuelve al menu principal sin ejecutar el formulario" note="Vuelve a la pantalla anterior" img="back" label="Volver" name="btnCAncelar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onChangeModo()
{                  
	switch(Ctrl("modo").GetXValue())
	{
		case "A":
			CtrlEnabled('chkMostrarLeg', true);
		break;
		
		case "C":		
			CtrlEnabled('chkMostrarLeg', false);
			Ctrl("chkMostrarLeg").SetXValue("1");		
		break;
		
		default:
			CtrlEnabled('chkMostrarLeg', false);			
		break;
	}
}


function onEjecutar()
{
	switch(Ctrl("modo").GetXValue())
	{
		case "A":
			Ctrl("main").DoEvent("TREE");
		break;
		
		case "C":
			Ctrl("main").DoEvent("CLASIC");
		break;
	}
}
	</form:Scripts>
	<form:Event runat="server" name="TREE" action="ACCEPT"/>
	<form:Event runat="server" name="CLASIC" action="CLASIC"/>
	<form:Event runat="client" name="onload" action="onChangeModo"/>
</form:Form>
