<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Organizacion.Organigrama" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Organigramas y Vistas (Imagen)" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank height="10px" name="blank1"/>
		<form:Combo flow="NucleusRH.Base.Organizacion.Reportes.OrganigramaImagen.TipoReporte.enum" action="COMBO" xsize="50" docname="STYLES" mode="DOC" nvalue="#source:@style" descrip="Estilo de Representaci&#243;n" label="Estilo" required="1" name="style"/>
		<form:FKInput label="Estructructura Inicial" descrip="Estructructura Inicial" nvalue="#source:@oi_estructura" required="1" enabled="" xsize="15" length="30" name="estructura">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:NumberBox required="1" xsize="3" length="3" precision="0" max="99" min="0" nvalue="#source:@uplevel" descrip="Niveles" label="Niveles Hacia Arriba" name="uplevels"/>
		<form:NumberBox required="1" xsize="3" length="3" precision="0" max="99" min="0" nvalue="#source:@level" descrip="Niveles" label="Niveles Hacia Abajo" name="levels"/>
		<form:Blank height="10px" name="blank2"/>
		<form:Line width="100%" name="line1"/>
		<form:Blank height="10px" name="blank3"/>
		<form:TextBox xsize="50" length="80" required="0" nvalue="#source:@title" descrip="Titulo del Reporte" label="Titulo" name="title"/>
		<form:TextBox xsize="50" ysize="5" length="2000" required="0" nvalue="#source:@legend" descrip="Leyenda del Reporte" label="Leyenda" name="legend"/>
		<form:Blank height="10px" name="blank8"/>
		<form:Line width="100%" name="line4"/>
		<form:Blank height="10px" name="blank9"/>
		<form:CheckBox nvalue="#source:@staff" descrip="Mostrar Staff" label="Mostrar Staff" name="staff">
			<form:Event name="OnClick" action="EnableButtons" runat="client"/>
		</form:CheckBox>
		<form:CheckBox nvalue="#source:@resp" descrip="Mostrar Responsable" label="Mostrar Responsable" name="resp">
			<form:Event name="OnClick" action="EnableButtons" runat="client"/>
		</form:CheckBox>
		<form:CheckBox nvalue="#source:@respimg" descrip="Mostrar Imagen del Responsable" label="Mostrar Imagen del Responsable" name="respimg"/>
		<form:CheckBox nvalue="#source:@leg" descrip="Mostrar Legajos" label="Mostrar Legajos" name="leg">
			<form:Event name="OnClick" action="EnableButtons" runat="client"/>
		</form:CheckBox>
		<form:CheckBox nvalue="#source:@legimg" descrip="Mostrar Imagen de los Legajos" label="Mostrar Imagen de los Legajos" name="legimg"/>
		<form:NumberBox nvalue="#source:@legcount" descrip="Limitar la Cantidad de Legajos" label="Limitar la Cantidad de Legajos" name="legcount" required="0" xsize="3" length="3" precision="0" max="99" min="0"/>
		<form:Blank height="10px" name="blank4"/>
		<form:Line width="100%" name="line2"/>
		<form:Blank height="10px" name="blank5"/>
		<form:CheckBox nvalue="#source:@extern" descrip="Mostrar Organigramas externos" label="Mostrar Organigramas Externos" name="extern"/>
		<form:CheckBox visible="0" nvalue="#source:@staff" descrip="Mostrar Nodos de Staff" label="Mostrar Nodos de Staff" name="staff"/>
		<form:CheckBox nvalue="#source:@hid-fic" name="hidfic" descrip="Ocular Nodos Ficticios Vacios" label="Ocultar Nodos Ficticios"/>
		<form:Blank height="10px" name="blank6"/>
		<form:Line width="100%" name="line3"/>
		<form:Blank height="10px" name="blank7"/>
		<form:NumberBox max="9999" nvalue="#source:@maxwidth" descrip="Limitar ancho de la Imagen" label="Limitar ancho de la Imagen" name="maxwidth" required="0" xsize="5" length="5" precision="0" min="0"/>
		<form:NumberBox nvalue="#source:@maxheight" descrip="Limitar altura de la Imagen" label="Limitar altura de la Imagen" name="maxheight" max="9999" required="0" xsize="5" length="5" precision="0" min="0"/>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function EnableButtons()
{  
	//Responsable
	if (Ctrl("resp").GetXValue()!="1")
	{
		Ctrl("respimg").SetXValue("0"); Ctrl("respimg").SetEnabled(false);
		Ctrl("leg"    ).SetXValue("0"); Ctrl("leg"    ).SetEnabled(false);
	} else
	{
		Ctrl("respimg").SetEnabled(true);
		Ctrl("leg"    ).SetEnabled(true);
	}

	//Legajos
	if (Ctrl("leg").GetXValue()!="1")
	{
		Ctrl("legimg"  ).SetXValue("0"); Ctrl("legimg"  ).SetEnabled(false);
		Ctrl("legcount").SetXValue("");  Ctrl("legcount").SetEnabled(false);
	} else
	{
		Ctrl("legimg"  ).SetEnabled(true);
		Ctrl("legcount").SetEnabled(true);
	}
}

function OnLoad()
{                       
	EnableButtons();
}
	</form:Scripts>
	<form:Event action="OnLoad" name="OnLoad" runat="client"/>
</form:Form>
