<form:Form xmlns:form="nomad_engine.form" name="DepartamentoSector filter" doc="source">
	<form:Title>
		<form:Label label="208 - Departamentos y sectores" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center height="100%" width="100%">
		<form:Columns name="cols">
			<form:Column name="col" separation="0" align="center" valign="top">
				<form:Blank visible="" width="100%" name="bl1"/>
				<form:Columns height="100%" width="100%" name="cols1">
					<form:Column name="col1" height="100%" width="100%" separation="2" align="right" valign="top">
