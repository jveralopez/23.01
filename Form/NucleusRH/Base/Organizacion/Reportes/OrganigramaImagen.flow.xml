<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.Image.batch.flow" default_action="initialize" name="NucleusRH.Base.Organizacion.Reportes.Organigrama">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Reportes.Organigrama"/>
	<flow:declare>
		<doc:define name="PARAMETERS">
			<DATA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#PARAMETERS:" mode="FILTER" form-class="NucleusRH.Base.Organizacion.Reportes.OrganigramaImagen.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Organizacion.Reportes.OrganigramaImagen.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Organizacion.Reportes.OrganigramaImagen.form" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportIMAGE" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param attr-path="#PARAMETERS:@style" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#PARAMETERS:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.Base.Image.batch.form" mode="SHOW" parent-doc-path="#SOURCE:" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Organizacion.Reportes.ORGANIGRAMA.Exportar" doc-path="#PARAMETERS:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Organizacion.Reportes.ORGANIGRAMA.Exportar" doc="PARAMETERS"/>
		</flow:action>
	</flow:form>
</flow:flow>
