<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" modo="HTML" oi_beneficio="" oi_tipo_benef=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" form-class="NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio.filter.form" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio.filter.form:EDIT" form-class="NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio.filter.form" doc="SOURCE">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Organizacion.BeneficiosPosicion.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="203 - Beneficios de las Posiciones" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
