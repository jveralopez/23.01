<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Organizacion.Reportes.PosicionesPorBeneficio.filter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="203 - Beneficios de las Posiciones" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="60%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Label name="lbl2" label="Criterios de B&#250;squeda" visible="" align="center" style="S3 LCol_g"/>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Columns name="columns1">
			<form:Column name="col1">
				<form:Combo nvalue="#FILTERDATA:@oi_tipo_benef" action="COMBO" flow="NucleusRH.Base.Organizacion.Tipos_de_Beneficios.TIPO_BENEF.Combo.autoflow" required="0" enabled="" descr="Tipo de Beneficio al cual pertenece el Beneficio." label="Tipo Beneficio" name="oi_tipo_benef"/>
				<form:FKInput nvalue="#FILTERDATA:@oi_beneficio" required="0" enabled="" xsize="15" length="30" label="Beneficio" name="oi_beneficio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Beneficios.BENEFICIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
