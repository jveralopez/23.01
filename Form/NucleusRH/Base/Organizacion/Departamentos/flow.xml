<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD.flow" extends="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Organizacion.Departamentos"/>
	<flow:declare>
		<doc:define name="SELECT">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="">
				<DEPARTAMENTOS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="FILTER">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form doc-path="#SELECT:" mode="FILTER" parent-doc-path="#SOURCE:" form-class="NucleusRH.Base.Organizacion.Departamentos.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Organizacion.Departamentos.filter.form" name="NucleusRH.Base.Organizacion.Departamentos.filter.form:FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#SOURCE:" text="facuSOURCE"/>
			<!--<flow:open-form iter-index="#SOURCE:DEPARTAMENTOS/DEPARTAMENTO/@id" form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_LIST.autoform" mode="LIST" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>-->
			<flow:open-form form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_LIST.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="LIST"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="SELECT" name="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_FIL.filter"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#SELECT:" name="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_FIL.filter"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_LIST.form:LIST" form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_LIST.form" mode="LIST" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SHOW">
			<flow:open-form mode="SHOW" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="ADD">
			<flow:open-form mode="NEW" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="EDIT">
			<flow:open-form mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="ADMIN">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO"/>
			<doc:load-object id-path="#SOURCE:@ID" doc="DDO" load-child="1" load-all="1" class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO"/>
			<flow:open-form mode="SHOW" parent-doc-path="#DDO:" doc-path="#DDO:" form-class="Nomad.Base.Security.form"/>
		</flow:action>
		<flow:action name="DELETE">
			<flow:call-action action="INT-DELETE"/>
		</flow:action>
		<flow:action name="INT-DELETE">
			<flow:exec-method class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO" method="Borrar_Departamento">
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.String" mode="in" name="ID"/>
			</flow:exec-method>
		</flow:action>
	</flow:form>
</flow:flow>
