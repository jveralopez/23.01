<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="NucleusRH.Base.Organizacion.Departamentos.filter.form" doc="source">
	<form:Center>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl1"/>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="columnas">
			<form:Column name="col1">
				<form:Combo nvalue="#source:@PARENT" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="FILTER" label="Empresa" name="oi_empresa"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Grid proto="&lt;DEPARTAMENTO /&gt;" name="grdDepartamentos" nvalue="#source:DEPARTAMENTOS" idvalue="#SOURCEGRILLA:@id" width="480px" note="" descrip="" rows="3" allowhelper="0" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Departamento" name="oi_departamento" nvalue="#SOURCEGRILLA:@id" required="0" enabled="" xsize="15" length="30">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO.EMPRESA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess oi_empresa="{oi_empresa.ReadXValue}" text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="bl4" width="100%" visible=""/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button label="Filtrar" startvalidate="1" name="FILTER" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/FILTER">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/FILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/FILTER"/>
					</form:Policies>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Organizacion/Departamentos/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
