<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Organizacion.Parametros.autoflow" name="NucleusRH.Base.Organizacion.Parametros">
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro as oi_parametro, 
				ORG26_PARAMETROS.c_modulo as c_modulo, ORG26_PARAMETROS.d_clase as d_clase, 
				ORG26_PARAMETROS.c_parametro as c_parametro, ORG26_PARAMETROS.d_parametro as d_parametro, 
				ORG26_PARAMETROS.d_tipo_parametro as d_tipo_parametro, ORG26_PARAMETROS.d_valor as d_valor 
				FROM ORG26_PARAMETROS 
 
				ORDER BY oi_parametro ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="value" value="$r/@oi_parametro" type="Nomad.NSystem.Int"/>
						<qry:attribute name="id" value="$r/@oi_parametro" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_modulo" value="$r/@c_modulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_clase" value="$r/@d_clase" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_parametro" value="$r/@c_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_parametro" value="$r/@d_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_tipo_parametro" value="$r/@d_tipo_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_valor" value="$r/@d_valor" type="Nomad.NSystem.String"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Parametros.PARAMETRO\'
				AND  NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="FIND:NucleusRH.Base.Organizacion.Parametros.PARAMETRO">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="RS1" doc-path="#SOURCE:VALUE"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[contains('|'+@c_modulo+'|'+@d_clase+'|'+@c_parametro+'|'+@d_parametro+'|'+@d_tipo_parametro+'|'+@d_valor+'|',#SOURCE:@FIND)]
				</qry:xquery>
				<qry:out>
					<qry:attribute name="findID" value="$r/@id" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST_ORG">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('				
				SELECT ORG26_PARAMETROS.oi_parametro as oi_parametro, 
				ORG26_PARAMETROS.c_modulo as c_modulo, ORG26_PARAMETROS.d_clase as d_clase, 
				ORG26_PARAMETROS.c_parametro as c_parametro, ORG26_PARAMETROS.d_parametro as d_parametro, 
				ORG26_PARAMETROS.d_tipo_parametro as d_tipo_parametro, ORG26_PARAMETROS.d_valor as d_valor 
				FROM ORG26_PARAMETROS 
 
				ORDER BY oi_parametro ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_parametro" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_modulo" value="$r/@c_modulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_clase" value="$r/@d_clase" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_parametro" value="$r/@c_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_parametro" value="$r/@d_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_tipo_parametro" value="$r/@d_tipo_parametro" type="Nomad.NSystem.String"/>
						<qry:attribute name="e_longitud" value="$r/@e_longitud" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_valor" value="$r/@d_valor" type="Nomad.NSystem.String"/>
						<qry:attribute name="l_bloqueado" value="$r/@l_bloqueado" type="Nomad.NSystem.Boolean"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Parametros.PARAMETRO\'
				AND  NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:group Name="PARAMETRO">
		<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.autoform:EDIT" mode="EDIT" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.autoform" name="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.noreg.form:EDIT" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="open-flow-SHOW">
				<doc:set-attribute from-value="ORG" to-attr-path="#DDO:@c_modulo"/>
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" mode="SHOW" doc-path="#DDO:" parent-doc-path="#QRY:" iter-index="#QRY:ROW/@id"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:set-attribute from-value="ORG" to-attr-path="#NEWDDOROOT:@c_modulo"/>
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" mode="NEW" doc-path="#NEWDDOROOT:"/>
			</flow:action>
			<flow:action name="goto-list">
				<doc:load-qry qry="LIST_ORG" output-doc="QRY_LIST" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="open-flow-LIST"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform:SHOW" mode="SHOW" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" name="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.form:SHOW" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="ADD">
				<doc:new-object class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO" doc="NEWDDOROOT"/>
				<doc:set-attribute from-value="ORG" to-attr-path="#NEWDDOROOT:@c_modulo"/>
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" mode="NEW" doc-path="#NEWDDOROOT:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform:LIST" mode="LIST" form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" name="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.form:LIST" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="ADD">
				<doc:new-object class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO" doc="NEWDDOROOT"/>
				<doc:set-attribute from-value="ORG" to-attr-path="#NEWDDOROOT:@c_modulo"/>
				<flow:open-form form-class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO.autoform" mode="NEW" doc-path="#NEWDDOROOT:"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:load-qry qry="LIST_ORG" output-doc="QRY_LIST" input-doc-path="#SOURCE:"/>
				<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
