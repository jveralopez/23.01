<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Migracion.Personal.CategoriasLegajos.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para NucleusRH.Base.Migracion.Organizacion.Convenios"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="SHOW" form-class="NucleusRH.Base.Migracion.Personal.CategoriasLegajos.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Migracion.Personal.CategoriasLegajos.form:SHOW" doc="PARAMETERS" form-class="NucleusRH.Base.Migracion.Personal.CategoriasLegajos.form" mode="SHOW">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Migracion.Personal.CategoriasLegajo.CATEGORIA_PER" method="ImportarCategoriasLegajos" out-attr-path="#BATCHDOC:@batch-id" priority="5"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
