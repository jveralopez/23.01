<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" doc="source" name="Autoevaluacion">
	<form:Title name="sgsf" width="90%">
		<form:Label label="Autoevaluaci&#243;n de Desempe&#241;o" name="lbl_titulo" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center name="sdvsdv" width="95%">
		<form:Blank name="1"/>
		<form:Blank name="3"/>
		<form:Columns height="50px" name="cols">
			<form:Column name="COL1" separation="2" align="center" valign="top">
				<form:ComboBox visible="0" label="Empleado" enabled="0" required="1" queryname1="NucleusRH.Base.Personal.Legajo.PERSONAL.INFO" name="oi_personal" nvalue="#PER:@oi_personal" xsize="50" mode="QRY"/>
				<form:Label style="M1 LCol_b" label="Eventos Evaluativos" name="eventoseva"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="4"/>
		<form:ListView width="50%" paging="1" rows="10" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn label="Evento Evaluativo" align="left" sorteable="1" type="string" attrname="d_evento" name="d_evento"/>
				<form:LVColumn type="string" name="c_estado" additional="&lt;OPTS&gt;&lt;OPT value=&quot;A&quot; text=&quot;Aplicado&quot; /&gt;&lt;OPT value=&quot;G&quot; text=&quot;Guardado&quot; /&gt;&lt;/OPTS&gt;" align="left" sorteable="1" label="Estado" attrname="c_estado"/>
			</form:LVColumns>
			<form:Event action="clickLista" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button img="SEARCH" descrip="Consultar Evaluaci&#243;n" name="SHOW" label="Consultar">
					<form:Event action="CONSULTAR" name="OnClick" runat="server"/>
				</form:Button>
				<form:Button label="Carga Autoevaluaci&#243;n" descrip="Cargar datos de la Autoevaluaci&#243;n" name="AUTO_SUP" img="edit">
					<form:Event action="EVALUADO" name="OnClick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function clickLista()
{
	if(Ctrl('LIST').GetSelectAttrValue('c_estado') == 'Cerrada')
	{
		CtrlEnabled('AUTO_SUP', false);
		CtrlEnabled('SHOW', true);
	}	
	else
	{
		CtrlEnabled('AUTO_SUP', true); 
		CtrlEnabled('SHOW', false);
	}
}    

function LoadForm()
{
	clickLista();
}
	</form:Scripts>
	<form:Event action="LoadForm" name="onload" runat="client"/>
</form:Form>
