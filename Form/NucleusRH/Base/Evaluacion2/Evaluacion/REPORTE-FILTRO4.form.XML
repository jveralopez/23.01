<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="FILTER2" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO3.form" extends="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.filter.form" doc="source">
	<form:Title>
		<form:Label label="005 - Resultados por Evaluaci&#243;n" visible="FILTER2" name="lbl_titulo" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gcustom" label="Criterios de selecci&#243;n de par&#225;metros para el Proceso" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="cols2" width="100%">
				<form:Column name="col2_1" valign="middle" separation="2" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Evaluacion2.Eventos.EVENTO.INFO" xsize="50" mode="QRY" required="1" nvalue="#source:@evento" descrip="Evento Evaluativo" label="Evento Evaluativo" name="EVENTO"/>
					<form:Combo label="Tipo de Salida" nvalue="#source:@tipo_salida" name="tipo_salida" required="1">
						<form:Opts name="opciones">
							<OPT value="std" code="estandar" name="estandar" text="Est&#225;ndar"/>
							<OPT name="detallada" code="detallada" value="det" text="Detallada"/>
						</form:Opts>
					</form:Combo>
				</form:Column>
			</form:Columns>
			<form:Columns name="cols1" visible="0" width="100%"/>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Evaluacion2/Evaluacion/REPORTE-FILTRO/form/empresa"/>
				</form:Column>
			</form:Columns>
			<form:Tab name="tab_filtro">
				<form:Panels>
					<form:Panel label="Evaluaci&#243;n" name="evaluacion" selected="1">
						<form:Columns name="cols_evaluacion" width="95%" height="130px">
							<form:Column name="col1_evaluacion" valign="top" align="left">
								<form:ComboBox xsize="50" mode="OPT" descrip="Estado" nvalue="#source:@estado" required="0" label="Estado" name="ESTADO">
									<options>
										<option text="Abierta" value="AB"/>
										<option text="Habilitada" value="HA"/>
										<option text="Evaluada" value="EV"/>
										<option text="Confirmada" value="CO"/>
										<option text="Aprobada" value="AP"/>
										<option text="Rechazada" value="RZ"/>
										<option text="Cerrada" value="CE"/>
									</options>
								</form:ComboBox>
							</form:Column>
						</form:Columns>
					</form:Panel>
				</form:Panels>
			</form:Tab>
		</form:VGroup>
	</form:Center>
	<form:Resources>
		<form:Resource name="qry_externo">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					EDD03_EVALUACION.oi_personal_emp
				FROM
					EDD03_EVALUACION
				WHERE 
					EDD03_EVALUACION.oi_evento = {#SOURCE:@EVENTO}
					{%?(#SOURCE:@ESTADO!='') {% and EDD03_EVALUACION.c_estado= {#SOURCE:@ESTADO} %} {% %} %}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
				<qry:params>
					##EVENTO,ESTADO##
				</qry:params>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
