<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="lista-evaluaciones" extends="NucleusRH.Base.Evaluacion2.Evaluacion.autoflow" name="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.flow">
	<flow:info label="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.flow"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<PERSONAS/>
				<EVENTOS/>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO gpers=&quot;&quot; empresa=&quot;1&quot; evento=&quot;1&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; legajo_desde=&quot;&quot; &#13;&#10;&#9;&#9;&#9;&#9;legajo_hasta=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; oi_centro_costo=&quot;&quot; &#13;&#10;&#9;&#9;&#9;&#9;oi_categoria=&quot;&quot; oi_ubicacion=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; &#13;&#10;&#9;&#9;&#9;&#9;oi_sindicato=&quot;&quot; supervisor=&quot;&quot; evaluador=&quot;&quot;&gt;&#13;&#10;&#9;&lt;PERSONAS&gt;&#13;&#10;    &lt;ROW VALUES=&quot;11566,11567,11568,11569,11570,11571,11573,11574,11575,11576,11578,11580,11581,11582,11583,11579,13885,13886,13887,13888,13889,13890,13891,13892,13895,13921,13922,13923,13924,13925,13926,13927,13928,13929,13930,13931,13932,13933,13935,11565&quot; /&gt;&#13;&#10;  &lt;/PERSONAS&gt;&#13;&#10;&lt;/FILTRO&gt;&#13;&#10;" name="REPORTE-NOMBRE">
			<qry:main doc="SOURCE">
				<REP>
					<qry:insert-select name="SQL" doc-path="#SOURCE:/FILTRO"/>
				</REP>
			</qry:main>
			<qry:select name="SQL" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
				SELECT
					T.d_reporte
				FROM
					EDD01_TIPOS_EVAL as T,
					EDD02_EVENTOS as E
				WHERE
					T.oi_tipo_eval=E.oi_tipo_eval and
					E.oi_evento={#SOURCE:@evento}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="nombre" value="substring_before(translate($r/@d_reporte,'.PLA_','.SHW_'),'.xml')"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="REPORTE-NOMBRE"/>
		<doc:define name="FILTERDATA1">
			<FILTRO>
				<PERSONAS/>
				<EVENTOS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.filter.form" mode="FILTER"/>
		</flow:action>
		<flow:action name="reporte">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form" mode="FILTER"/>
		</flow:action>
		<flow:action name="lista-evaluaciones">
			<flow:open-form form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form" mode="FILTER2" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="lista-eventos">
			<flow:open-form doc-path="#FILTERDATA1:" mode="FILTER2" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO2.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.filter.form:FILTER" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION.filter.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="NucleusRH.Base.Evaluacion2.Evaluacion.EVALUACION" method="ModMasivaEvaSup" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="FILTERDATA"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<!--flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/-->
		</flow:action>
	</flow:form>
	<flow:form mode="FILTER" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form:FILTER" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:load-qry output-doc="REPORTE-NOMBRE" input-doc-path="#FILTERDATA:" qry="REPORTE-NOMBRE"/>
			<flow:exec-method priority="6" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" method="ExecReportHTML">
				<flow:param attr-path="#REPORTE-NOMBRE:@nombre" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="002 - Consulta detallada de Evaluaciones" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.ASIGNACION" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<!--flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/-->
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="Nomad.base.batch.report.form:BATCH" form-class="Nomad.base.batch.report.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="show-report">
			<flow:close-form/>
			<flow:open-form form-class="nomad.Base.Report.GeneralReport.SHOW.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="nomad.Base.Report.GeneralReport.SHOW.form" name="nomad.Base.Report.GeneralReport.SHOW.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO.form:FILTER2" mode="FILTER2" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method priority="6" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" method="ExecReportHTML">
				<flow:param value="NucleusRH.Base.Evaluacion2.Evaluaciones.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="001 - Consulta de Evaluaciones" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.Evaluaciones" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.Evaluaciones" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<!--flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/-->
		</flow:action>
	</flow:form>
	<flow:form mode="FILTER2" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO2.form" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE-FILTRO2.form:FILTER2" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA1:" text="emig"/>
			<flow:exec-method priority="6" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" method="ExecReportHTML">
				<flow:param value="NucleusRH.Base.Evaluacion2.EvaluacionesPorLegajos.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA1:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-value="003 - Consulta de Evaluaciones por Legajos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.EvaPorLegajos" doc="FILTERDATA1"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluacion.EvaPorLegajos" doc-path="#FILTERDATA1:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="chuekflowsancor"/>
			<!--flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/-->
		</flow:action>
	</flow:form>
</flow:flow>
