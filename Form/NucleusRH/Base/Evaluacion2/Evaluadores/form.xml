<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Evaluacion2.Evaluadores.form">
	<form:Title name="secTitulo">
		<form:Label label="Asignaci&#243;n de Evaluadores" name="lblTitulo"/>
	</form:Title>
	<form:Center name="secCenter">
		<form:Columns name="cols1">
			<form:Column name="col1" separation="2" align="center" valign="top">
				<form:Blank name="bb1"/>
				<form:ComboBox enabled="0" nvalue="#source:@oi_empresa" name="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
				<form:ComboBox enabled="0" prev="oi_empresa" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="30" mode="QRY" required="1" label="Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
			</form:Column>
		</form:Columns>
		<form:Columns name="cols2">
			<form:Column name="col2" separation="2" align="center" valign="top">
				<form:Grid idvalue="#sourcegrilla:@id" nvalue="#source:ROWS" allowdel="1" width="700" allownew="1" rows="10" doc="sourcegrilla" proto="&lt;ROW/&gt;" name="grid1">
					<form:GColumns>
						<form:GColumn label="Evaluador">
							<form:ComboBox nvalue="#sourcegrilla:@oi_evaluador" label="Evaluador" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="30" mode="QRY" required="1" name="oi_evaluador"/>
						</form:GColumn>
						<form:GColumn label="Rol">
							<form:ComboBox nvalue="#sourcegrilla:@oi_rol" label="Rol" queryname1="NucleusRH.Base.Evaluacion2.Roles.ROL.INFO" xsize="30" mode="QRY" required="1" name="oi_rol"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom name="secBottom">
		<form:RowAligner name="rows1">
			<form:Row name="row1">
				<form:Button startvalidate="1" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="Est&#225; seguro que desea cancelar la edici&#243;n?" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
