<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Evaluacion2.Evaluadores.flow">
	<flow:info label="Asignaci&#243;n de evaluadores"/>
	<flow:declare>
		<qry:define name="qry_evaluadores">
			<qry:main doc="SOURCE">
				<DATA>
					<qry:attribute name="oi_empresa" value="$SOURCE/DATA/@oi_empresa"/>
					<qry:attribute name="oi_personal_emp" value="$SOURCE/DATA/@oi_personal_emp"/>
					<ROWS>
						<qry:insert-select name="qry1" doc-path="$SOURCE/DATA"/>
					</ROWS>
				</DATA>
			</qry:main>
			<qry:select name="qry1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
SELECT e.oi_evaluador360, e.oi_evaluador, e.oi_rol
FROM EDD06_EVALUADORES as e
WHERE e.oi_personal_emp = {$PARAM/@oi_personal_emp}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="id" value="$r/@oi_evaluador360"/>
						<qry:attribute name="oi_evaluador" value="$r/@oi_evaluador"/>
						<qry:attribute name="oi_rol" value="$r/@oi_rol"/>
					</ROW>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<DATA>
				<ROWS/>
			</DATA>
		</doc:define>
	</flow:declare>
	<flow:main doc="PARAMIN">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Evaluacion2.Evaluadores.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" form-class="NucleusRH.Base.Evaluacion2.Evaluadores.filter.form" name="NucleusRH.Base.Evaluacion2.Evaluadores.filter.form" doc="SOURCE">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Evaluacion2.Evaluadores.Asignacion" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Evaluacion2.Evaluadores.Asignacion"/>
		</flow:action>
		<flow:action name="FILTER">
			<flow:call-action action="Save-FILTER"/>
			<doc:load-qry output-doc="SOURCE" input-doc-path="#SOURCE:" qry="qry_evaluadores"/>
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Evaluacion2.Evaluadores.form" mode="EDIT"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form mode="EDIT" form-class="NucleusRH.Base.Evaluacion2.Evaluadores.form" name="NucleusRH.Base.Evaluacion2.Evaluadores.form" doc="SOURCE">
		<flow:action name="SAVE">
			<flow:exec-method class="NucleusRH.Base.Evaluacion2.Evaluadores.EVALUADOR360" method="Guardar">
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="datos"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
