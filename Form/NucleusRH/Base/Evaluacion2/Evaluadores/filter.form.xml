<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Evaluacion2.Evaluadores.filter.form">
	<form:Title name="secTitulo">
		<form:Label label="Asignaci&#243;n de evaluadores - Seleccionar Legajo" name="lblTitulo"/>
	</form:Title>
	<form:Center name="secCenter">
		<form:Columns name="cols1">
			<form:Column valign="top" name="col1" separation="2" align="center">
				<form:Blank name="bb1"/>
				<form:ComboBox nvalue="#source:@oi_empresa" name="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="30" mode="QRY" required="1" label="Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom name="secBottom">
		<form:RowAligner name="rows1">
			<form:Row name="row1">
				<form:Button startvalidate="1" img="filter" name="FILTER" descrip="Filtrar" label="Filtrar">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Salir" img="arrow_undo.gif" label="Salir" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
