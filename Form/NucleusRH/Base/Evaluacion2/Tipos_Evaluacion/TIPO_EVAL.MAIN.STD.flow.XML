<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion">
	<flow:info label="Flow para NucleusRH.Base.Evaluacion2.Tipos_Evaluacion"/>
	<flow:declare>
		<doc:define name="REPORTNAME"/>
		<qry:define name="REPORT" declare="&lt;object id=&quot;1&quot; /&gt;">
			<qry:main name="" doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
		select                
			TY.d_reporte as REPORT
		from        
			EDD01_TIPOS_EVAL as TY
		where
			 TY.oi_tipo_eval = {#SOURCE:@parent}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="REPORT" value="$r/@REPORT"/>
					<qry:attribute name="oi_tipo_eval" value="#SOURCE:@parent"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="PREVIEW">
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="REPORTNAME" qry="REPORT"/>
			<flow:open-form parent-doc-path="#REPORTNAME:" doc-path="#REPORTNAME:" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="SOURCE" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form:SHOW" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="on-open"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
