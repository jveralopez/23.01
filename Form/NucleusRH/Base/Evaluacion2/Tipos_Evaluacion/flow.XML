<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.autoflow" default_action="initialize" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion">
	<flow:info label="Flow para NucleusRH.Base.Evaluacion2.Tipos_Evaluacion"/>
	<flow:declare>
		<doc:define name="EMPTY-LIST">
			<RS/>
		</doc:define>
		<qry:define declare="&lt;DATA d_reporte=&quot;NucleusRH.Base.Evaluacion2.PLA_Evaluacion.rpt.xml&quot; /&gt;" name="COMBO_FORMATOS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select doc="SOURCE" name="SQL1">
				<qry:xquery>
					for $r in FILESTORE('HTML/{%=#SOURCE:@d_reporte %}')/html:html/html:xslt/xsl:template[@name='COMBO_TEMPLATES']/OPT
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="RS-FORMATOS"/>
		<doc:define name="REPORTNAME"/>
		<qry:define name="REPORT" declare="&lt;object id=&quot;1&quot; /&gt;">
			<qry:main name="" doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
				select                
					TY.d_reporte as REPORT
				from        
					EDD01_TIPOS_EVAL as TY
				where
					 TY.oi_tipo_eval = {#SOURCE:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="REPORT" value="$r/@REPORT"/>
					<qry:attribute name="oi_tipo_eval" value="#SOURCE:@id"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE"/>
	<flow:group Name="PLANTILLA">
		<flow:form extends="CLASSNOROOT:SHOW" doc-path="/PLANTILLA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform:SHOW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform" mode="SHOW">
			<flow:action name="CALL:OBJETIVO">
				<flow:open-form iter-index="#SOURCE:OBJETIVOS/OBJETIVO/@id" parent-doc-path="#SOURCE:OBJETIVOS" doc-path="#SOURCE:OBJETIVOS" mode="SHOW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.noreg.autoform"/>
			</flow:action>
			<flow:action name="CALL:FORMLIST">
