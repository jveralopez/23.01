			</flow:action>
			<flow:action name="on-show">
				<doc:load-qry qry="COMBO_FORMATOS" input-doc-path="#SOURCE:../.." output-doc="RS-FORMATOS"/>
				<flow:attach-doc doc-path="#RS-FORMATOS:" attach-id="RS-FORMATOS"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<doc:load-qry qry="COMBO_FORMATOS" input-doc-path="#SOURCE:../.." output-doc="RS-FORMATOS"/>
				<flow:attach-doc doc-path="#RS-FORMATOS:" attach-id="RS-FORMATOS"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSNOROOT:LIST" doc-path="/PLANTILLA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform:LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform" mode="LIST">
			<flow:action name="load-child-LIST">
				<doc:load-qry output-doc="QRY_LIST" input-doc-path="#PARENTSOURCE:" qry="LIST:NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA"/>
			</flow:action>
			<flow:action name="CALL:OBJETIVO">
				<flow:open-form iter-index="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS/OBJETIVO/@id" parent-doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" mode="SHOW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.noreg.autoform"/>
			</flow:action>
			<flow:action name="CALL:FORMLIST">
				<flow:open-form iter-index="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS/OBJETIVO/@id" parent-doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" mode="SHOW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.noreg.autoform"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSNOROOT:LIST_EDIT" doc-path="/PLANTILLA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform:LIST_EDIT" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform" mode="LIST_EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDO" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:PLANTILLA/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST_EDIT" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform"/>
			</flow:action>
			<flow:action name="load-child-LIST">
				<doc:load-qry output-doc="QRY_LIST" input-doc-path="#PARENTSOURCE:" qry="LIST:NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA"/>
			</flow:action>
			<flow:action name="CALL:OBJETIVO">
				<flow:open-form iter-index="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS/OBJETIVO/@id" parent-doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" mode="EDIT" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.noreg.autoform"/>
			</flow:action>
			<flow:action name="CALL:FORMLIST">
				<flow:open-form parent-doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" doc-path="#PARENTSOURCE:PLANTILLA[@id='{#FORM:ctrl[@id='LIST']/@xval}']/OBJETIVOS" mode="LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSNOROOT:EDIT" doc-path="/PLANTILLA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform:EDIT" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDO" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#SOURCE:" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA" doc="SOURCE"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform"/>
			</flow:action>
			<flow:action name="CALL:OBJETIVO">
				<flow:open-form iter-index="#SOURCE:OBJETIVOS/OBJETIVO/@id" parent-doc-path="#SOURCE:OBJETIVOS" doc-path="#SOURCE:OBJETIVOS" mode="EDIT" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO.noreg.autoform"/>
			</flow:action>
			<flow:action name="CALL:FORMLIST">
				<flow:open-form doc-path="#SOURCE:OBJETIVOS" parent-doc-path="#SOURCE:OBJETIVOS" mode="LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<doc:load-qry qry="COMBO_FORMATOS" input-doc-path="#SOURCE:../.." output-doc="RS-FORMATOS"/>
				<flow:attach-doc doc-path="#RS-FORMATOS:" attach-id="RS-FORMATOS"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:load-qry qry="COMBO_FORMATOS" input-doc-path="#SOURCE:../.." output-doc="RS-FORMATOS"/>
				<flow:attach-doc doc-path="#RS-FORMATOS:" attach-id="RS-FORMATOS"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.form:NEW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.PLANTILLA.autoform" mode="NEW">
			<flow:action name="on-show">
				<doc:load-qry input-doc-path="#PARENTSOURCE:.." qry="COMBO_FORMATOS" output-doc="RS-FORMATOS"/>
				<flow:attach-doc doc-path="#RS-FORMATOS:" attach-id="RS-FORMATOS"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form:LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form" mode="LIST">
		<flow:action name="load-child-LIST">
			<doc:load-qry output-doc="QRY_LIST" input-doc-path="#PARENTSOURCE:" qry="LIST:NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.OBJETIVO"/>
		</flow:action>
		<flow:action name="--------------------------------------------"/>
		<flow:action name="on-open"/>
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#EMPTY-LIST:" attach-id="RS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:exec-method this-doc="PARENTSOURCE" method="RefreshItems">
				<flow:param attr-path="#SOURCE:../@id" type="Nomad.NSystem.String" mode="in" name="plantilla"/>
			</flow:exec-method>
			<flow:close-form next-action="After-Back"/>
		</flow:action>
		<flow:action name="PARENT">
			<flow:exec-method this-doc="DDO" method="RefreshItems">
				<flow:param attr-path="#SOURCE:../@id" type="Nomad.NSystem.String" mode="in" name="plantilla"/>
			</flow:exec-method>
			<flow:close-form next-action="PARENT"/>
		</flow:action>
