	<flow:form parent-doc="SOURCE" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form" name="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form:SHOW" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="on-open"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.form:SHOW" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.autoform" mode="SHOW">
		<flow:action name="VISTA_PREVIA">
			<doc:load-qry input-doc-path="#DDO:" output-doc="REPORTNAME" qry="REPORT"/>
			<flow:log text-path="#REPORTNAME:" text="REPORTNAME"/>
			<flow:open-form parent-doc-path="#REPORTNAME:" doc-path="#REPORTNAME:" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.form:LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL.autoform" mode="LIST">
		<flow:action name="VISTA_PREVIA">
			<flow:call-action action="load-DDO"/>
			<doc:load-qry input-doc-path="#DDO:" output-doc="REPORTNAME" qry="REPORT"/>
			<flow:log text-path="#REPORTNAME:" text="REPORTNAME"/>
			<flow:open-form parent-doc-path="#REPORTNAME:" doc-path="#REPORTNAME:" form-class="NucleusRH.Base.Evaluacion2.Evaluacion.REPORTE.form" mode="SHOW"/>
		</flow:action>
	</flow:form>
</flow:flow>
