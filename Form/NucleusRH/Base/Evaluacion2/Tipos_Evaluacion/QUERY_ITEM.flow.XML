<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="LIST" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion">
	<flow:info label="Flow para NucleusRH.Base.Evaluacion2.Tipos_Evaluacion"/>
	<flow:declare>
		<doc:define name="LIST">
			<RS/>
		</doc:define>
		<doc:define name="ITEMS">
			<ITEMS/>
		</doc:define>
		<qry:define name="LOADITEMS">
			<qry:main doc="SOURCE">
				<ITEMS>
					<qry:insert-select name="ITEMS" doc-path="#SOURCE:."/>
				</ITEMS>
			</qry:main>
			<qry:select name="ITEMS" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT          
				edd01_objetivos.c_objetivo
			FROM
				edd01_objetivos   
			WHERE              
				edd01_objetivos.oi_plantilla={$PARAM/@PARENT}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ITEM>
						<qry:attribute name="c_objetivo" value="$r/@c_objetivo"/>
					</ITEM>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="LIST">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="LIST" form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.LISTA.form:LIST" mode="LIST">
		<flow:action name="on-open"/>
		<flow:action name="on-show">
			<doc:load-qry output-doc="ITEMS" input-doc-path="#SOURCE:" qry="LOADITEMS"/>
			<flow:exec-method out-doc="LIST" out-type="Nomad.NSystem.Proxy.NomadXML" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL" method="LoadItems">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.String" mode="in" name="plantilla"/>
			</flow:exec-method>
			<flow:attach-doc doc-path="#LIST:" attach-id="RS"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form next-action="After-Back"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exec-method method="RefreshItems" class="NucleusRH.Base.Evaluacion2.Tipos_Evaluacion.TIPO_EVAL">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.String" mode="in" name="plantilla"/>
				<flow:param doc="ITEMS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="Items"/>
			</flow:exec-method>
			<flow:close-form next-action="After-Back"/>
		</flow:action>
	</flow:form>
</flow:flow>
