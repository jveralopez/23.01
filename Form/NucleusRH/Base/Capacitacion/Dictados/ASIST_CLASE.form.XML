<form:Form extends="NucleusRH.Base.Capacitacion.Dictados.ASIST_CLASE.autoform" name="NucleusRH.Base.Capacitacion.Dictados.ASIST_CLASE.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:RowAligner visible="LIST" name="buttonlinks">
			<form:Row name="row_top">
				<form:Blank visible="LIST" name="blank_rowtop1"/>
				<form:TextBox visible="LIST" xsize="50" length="100" name="iter-search" label="Buscar" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
				<form:Blank name="ITERATOR_BLANK" width="100%"/>
				<form:Button label="Imprimir" visible="LIST" descrip="Imprimir la pantalla de lista" img="print" name="PRINT">
					<form:Event action="Imprimir" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
		<form:Grid idvalue="#source:@id" visible="0" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source"/>
		<form:Blank name="bl1"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn type="string" label="Inscripto" name="inscripto" attrname="inscripto" align="left" sorteable="1" width="50px"/>
			</form:LVColumns>
		</form:ListView>
		<form:Hidden nvalue="#DDO:@id" name="oi_dictado"/>
		form:Center width="95%"&gt;
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Capacitacion/Dictados/ASIST_CLASE/NEW" visible="0" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Capacitacion/Dictados/ASIST_CLASE/DELETE" visible="0" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|DELETE|EDIT|LIST" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Find()
{
	Ctrl("LIST").filter("",Ctrl("iter-search").GetCValue());
}
function Imprimir()
{       
	Ctrl("LIST").toPrinter();
}
function ToList()
{                
	if (parseInt(Ctrl("iter-size").GetXValue(),10)&lt;=50)
		Ctrl("LISTA").DoEvent("showList");
	else
		alert("Demasiados registros para ser mostrados en una lista.");
}
	</form:Scripts>
</form:Form>
