<form:Form xmlns:form="nomad_engine.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Dictados.CURSO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Crear Dictado" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_columnsDICTADO">
			<form:Column name="main_columnsDICTADOcolumn1">
				<form:Blank name="bln1"/>
				<form:FKInput visible="0" label="Curso" nvalue="#source:oi_curso/@value" required="1" enabled="NEW|EDIT" xsize="15" length="30" name="oi_curso">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Cursos.CURSO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox nvalue="#source:oi_curso/@value" enabled="NEW|EDIT" queryname1="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" xsize="40" mode="QRY" required="1" label="Curso" name="oi_curso"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Crear un dictado para el Curso seleccionado" startvalidate="1" visible="NEW" note="" img="ok" label="Aceptar" name="ACCEPT">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="NEW" note="Vuelve a la pantalla anterior del formulario" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
