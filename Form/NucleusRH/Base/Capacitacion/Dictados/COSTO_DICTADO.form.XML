<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Capacitacion.Dictados.COSTO_DICTADO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Dictados.COSTO_DICTADO">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCOSTO_DICTADO">
			<form:Column name="main_columnsCOSTO_DICTADOcolumn1">
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Cantidad Item" nvalue="#source:@n_cantidad" name="n_cantidad">
					<form:Event action="CalcularTotal" name="onchange" runat="client"/>
				</form:NumberBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Costo Unitario" nvalue="#source:@n_costo_uni" name="n_costo_uni">
					<form:Event name="onchange" runat="client" action="CalcularTotal"/>
				</form:NumberBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Costo Total" nvalue="#source:@n_costo_total" name="n_costo_total"/>
				<form:File enabled="NEW|EDIT" source="0" required="0" nvalue="#source:oi_doc_digital/@value" name="oi_doc_digital" label="Adjunto" class="NucleusRH.Base.Capacitacion.DocumentosDigitales.HEAD" X-POLICY="./FORM/NucleusRH/Base/Capacitacion/Dictados/COSTO_DICTADO/form/oi_doc_digital">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Capacitacion/Dictados/COSTO_DICTADO/form/oi_doc_digital/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Capacitacion/Dictados/COSTO_DICTADO/form/oi_doc_digital"/>
					</form:Policies>
				</form:File>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function CalcularTotal()
{
	if(Ctrl('n_cantidad').GetXValue() != '' &amp;&amp; Ctrl('n_costo_uni').GetXValue() != '')
	{		
		Ctrl('n_costo_total').SetCValue(Ctrl('n_cantidad').GetXValue() * Ctrl('n_costo_uni').GetXValue());
	}
}
	</form:Scripts>
</form:Form>
