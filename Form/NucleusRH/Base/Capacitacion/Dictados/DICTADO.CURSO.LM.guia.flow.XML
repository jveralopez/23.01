<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.LM.guia.flow">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.LM.guia.form" parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define declare="&lt;helper-mess oi_curso=&quot;81&quot;&gt;&#13;&#10;  &lt;rows nmd-col=&quot;1&quot;&gt;&#13;&#10;    &lt;!--row oi_dictado=&quot;897&quot; oi_personal_emp_SEARCH=&quot;&quot; /--&gt;&#13;&#10;    &#13;&#10;  &lt;/rows&gt;&#13;&#10;&lt;/helper-mess&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:helper-mess"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:helper-mess"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT CYD02_DICTADOS.oi_dictado,
				CYD02_DICTADOS.c_dictado,
				CYD02_DICTADOS.d_dictado
				FROM CYD02_DICTADOS				
				WHERE CYD02_DICTADOS.oi_curso = {#SOURCE:@oi_curso} 									
				{%? (string(#SOURCE:rows/row/@oi_dictado)!='') {%  AND CYD02_DICTADOS.oi_dictado in ({%=string(#FILTRO:helper-mess/rows/row/@oi_dictado) %}) %} {% AND 1=2 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_dictado" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_dictado" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_dictado" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_dictado" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="1" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY_SI"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_SI">
				<qry:xquery>
					for $r in sql('
					SELECT NMD_SECURITY.policy 
					FROM NMD_SECURITY 
					WHERE NMD_SECURITY.class=\'NucleusRH.Base.Capacitacion.Dictados.DICTADO\' 
					AND NMD_SECURITY.id={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
			 	SELECT CYD02_DICTADOS.oi_dictado,
				CYD02_DICTADOS.c_dictado,
				CYD02_DICTADOS.d_dictado
				FROM CYD02_DICTADOS				
				WHERE CYD02_DICTADOS.oi_curso = {#SOURCE:@oi_curso} 									
				{%? (string(#SOURCE:rows/row/@oi_dictado)!='') {%  AND CYD02_DICTADOS.oi_dictado not in ({%=string(#FILTRO:helper-mess/rows/row/@oi_dictado) %}) %} {% AND 1=1 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_dictado" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_dictado" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_dictado" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_dictado" name="text"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
						<qry:insert-select doc-path="." name="SECURITY_NO"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_NO">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Capacitacion.Dictados.DICTADO\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@id" name="oi_dictado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.LM.guia.form:SHOW" form-class="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.LM.guia.form" parent-doc="INVAL" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="OUT" input-doc-path="#SOURCE:" qry="PRUEBA"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
