<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="EditParameters">
	<flow:info label="EditParametersCap"/>
	<flow:declare>
		<doc:define name="DATA">
			<PARAMS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="DATA" class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO" method="ObtenerValores">
				<flow:param doc="DATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="PARAM"/>
			</flow:exec-method>
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Parametros.PARAMETRO.edit.form" doc-path="#DATA:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Parametros.PARAMETRO.edit.form" name="NucleusRH.Base.Capacitacion.Parametros.PARAMETRO.edit.form" mode="EDIT" doc="SOURCE">
		<flow:action name="SAVE">
			<flow:exec-method class="NucleusRH.Base.Organizacion.Parametros.PARAMETRO" method="GuardarValores">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="PARAM"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
