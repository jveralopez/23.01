<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION.guia.flow" extends="NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION.guia.autoflow">
	<flow:info label="Flow guia para NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION.guia.autoform"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT CYD12_EVALUACIONES.oi_evaluacion AS ID, 
				CYD12_EVALUACIONES.c_evaluacion AS CODE, 
				CYD12_EVALUACIONES.d_evaluacion AS TEXT 
				FROM CYD12_EVALUACIONES 
				WHERE CYD12_EVALUACIONES.c_evaluacion={substring_before(#INDOC:@CODE,\'-\')}
				AND CYD12_EVALUACIONES.c_tipo_eval = \'D\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT CYD12_EVALUACIONES.oi_evaluacion AS ID, 
				CYD12_EVALUACIONES.c_evaluacion AS CODE, 
				CYD12_EVALUACIONES.d_evaluacion AS TEXT 
				FROM CYD12_EVALUACIONES
				WHERE CYD12_EVALUACIONES.c_tipo_eval =\'D\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
