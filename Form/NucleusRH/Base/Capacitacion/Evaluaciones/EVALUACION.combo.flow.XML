<flow:flow name="NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION.combo.flow" extends="NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION.combo.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION"/>
	<flow:declare>
		<qry:define name="COMBO_ASIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_evaluacion as ID, 
				t.c_evaluacion as CODE, 
				t.d_evaluacion as TEXT, 
				SEC.policy  
				FROM CYD12_EVALUACIONES as t, NMD_SECURITY(class=\'NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION\') as SEC 
				JOIN t.oi_evaluacion LEFT OUTER SEC.id  
				WHERE t.c_tipo_eval = \'A\'
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@CODE+'-'+$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="COMBO_DICT">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_evaluacion as ID, 
				t.c_evaluacion as CODE, 
				t.d_evaluacion as TEXT, 
				SEC.policy  
				FROM CYD12_EVALUACIONES as t, NMD_SECURITY(class=\'NucleusRH.Base.Capacitacion.Evaluaciones.EVALUACION\') as SEC 
				JOIN t.oi_evaluacion LEFT OUTER SEC.id  
				WHERE t.c_tipo_eval = \'A\'
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@CODE+'-'+$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO_ASIST">
			<doc:load-qry qry="COMBO_ASIST" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="COMBO_DICT">
			<doc:load-qry qry="COMBO_DICT" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
</flow:flow>
