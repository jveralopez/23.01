<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.form" extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.autoform" default_mode="FILTER" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center>
