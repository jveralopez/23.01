				</form:FKInput>
				<form:Blank name="1231"/>
				<form:FKInput required="0" xsize="15" length="30" label="&#193;rea de Curso" nvalue="#source:@oi_area" name="oi_area">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Cursos.CURSO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime nvalue="#source:@f_desde_solicitud" name="f_desde_solicitud" label="Fecha Desde Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta_solicitud" name="f_hasta_solicitud" label="Fecha Hasta Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.c_estado.Combo.autoflow" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#USER:@user" name="user"/>
		<form:Hidden nvalue="#source:@f_hoy" name="f_hoy"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button startvalidate="1" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="getUser" name="onload" runat="client"/>
	<form:Event action="GET_USER" name="GET_USER" runat="server"/>
	<form:Scripts>
		function getUser()
{
	Ctrl('f_hoy').SetXValue(date2str(NowDate()));
	
	//if (Ctrl('main').GetMode()=="FILTER_ADMIN")
		//return;
	if (Ctrl('user').GetXValue()!="")
		return;
	var proxy = GetProxy();
	Ctrl('user').SetXValue(proxy.UserName());	
	Ctrl('main').DoEvent("GET_USER");
} 


function LoadPersonal(me)
{
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
	
	
		if (Ctrl('oi_personal').GetXValue() !="")
		{
			fecha = nSQL.GetOBJ(Ctrl("main").getResource("QRY_F_ANTIG"), "&lt;PARAM oi_personal=\""+Ctrl("oi_personal").GetXValue()+"\" /&gt;"); 		
			Ctrl("f_antiguedad_rec").SetXValue(fecha.f_computada);					
			return true;
		}
		else
		{
			Ctrl("f_antiguedad_rec").SetXValue("");					
		}
	
}
	</form:Scripts>
</form:Form>
