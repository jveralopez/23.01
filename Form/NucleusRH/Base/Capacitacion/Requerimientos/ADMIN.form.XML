<form:Form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Requerimientos.ADMIN" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsREQUERIMIENTO">
			<form:Column name="main_columnsREQUERIMIENTOcolumn1">
				<form:FKInput enabled="EDIT|NEW" required="1" xsize="15" length="30" label="Legajo Solicitante" nvalue="#source:oi_personal_emp/@value" name="oi_personal_emp">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Indicador de efectividad sugerido" nvalue="#source:@o_indicador" name="o_indicador"/>
				<form:DateTime enabled="EDIT|NEW" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" label="Fecha de Solicitud" nvalue="#source:@f_solicitud" name="f_solicitud"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				<form:DateTime visible="SHOW|EDIT" enabled="EDIT|NEW" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Dictado" nvalue="#source:@f_dictado" name="f_dictado">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox visible="SHOW|EDIT" enabled="EDIT|NEW" required="0" ysize="1" xsize="50" length="100" label="T&#237;tulo del Curso" nvalue="#source:@d_titulo" name="d_titulo"/>
				<form:TextBox visible="SHOW|EDIT" enabled="EDIT|NEW" required="0" ysize="4" xsize="50" length="1000" label="Motivo de Rechazo" nvalue="#source:@o_motivo_rechazo" name="o_motivo_rechazo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Organizacion.Cursos.CURSO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="&#193;rea de Curso" attrname="oi_curso" name="oi_curso"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Departamento/Sector" attrname="d_sector" name="d_sector"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Legajo Solicitante" attrname="oi_personal_emp" name="oi_personal_emp"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Estado" attrname="c_estado" name="c_estado"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Solicitud" attrname="f_solicitud" name="f_solicitud"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Urgencia del Requerimiento" attrname="c_urgencia" name="c_urgencia"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha tentativa de inicio" attrname="f_inicio" name="f_inicio"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="N&#250;mero de Participantes" attrname="e_cant_pers" name="e_cant_pers"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Dictado" attrname="f_dictado" name="f_dictado"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="T&#237;tulo del Curso" attrname="d_titulo" name="d_titulo"/>
			</form:LVColumns>
			<form:Event action="ONLOAD" name="onclick" runat="client"/>
		</form:ListView>
		<form:Hidden name="f_dictado" visible="LIST"/>
		<form:Hidden name="d_titulo" visible="LIST"/>
		<form:Hidden name="o_motivo_rechazo" visible="LIST"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Blank name="blank111"/>
				<form:Button mess="&#191;Est&#225; seguro que desea aprobar el Requerimiento?" descrip="Aprobar la solicitud de Capacitaci&#243;n" name="APROBAR" policy="NucleusRH/Base/Capacitacion/Requerimientos/EDIT" visible="SHOW|LIST" img="ok" label="Aprobar">
					<form:Event action="APROBAR" name="onclick" runat="extern">
						<form:helpper action="APROBAR" name="NucleusRH.Base.Capacitacion.Requerimientos.ADMIN.Motivo.flow" clientaction="setValues">
							<FILTRO f_dictado="" d_titulo="" o_motivo_rechazo=""/>
						</form:helpper>
					</form:Event>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea rechazar el Requerimiento?" descrip="Rechazar la solicitud de Capacitaci&#243;n" img="cancel" name="RECHAZAR" label="Rechazar" policy="NucleusRH/Base/Capacitacion/Requerimientos/EDIT" visible="SHOW|LIST">
					<form:Event name="onclick" action="RECHAZAR" runat="extern">
						<form:helpper action="RECHAZAR" name="NucleusRH.Base.Capacitacion.Requerimientos.ADMIN.Motivo.flow" clientaction="setValues">
							<FILTRO f_dictado="" d_titulo="" o_motivo_rechazo=""/>
						</form:helpper>
					</form:Event>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea cubrir el Requerimiento?" img="properties" descrip="Cubrir la solicitud de Capacitaci&#243;n" name="CUBRIR" label="Cubrir" policy="NucleusRH/Base/Capacitacion/Requerimientos/EDIT" visible="SHOW|LIST">
					<form:Event name="onclick" action="CUBRIR" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ONLOAD()
{
	var estado;
	// Busco el estado
	if (Ctrl('LIST'))
	{
		estado = Ctrl('LIST').GetSelectAttrValue('c_estado');
	}else
	{
		estado = Ctrl('c_estado').GetXValue();
	}
	
	if (estado == "S")
	{
		CtrlEnabled('APROBAR', true);
		CtrlEnabled('RECHAZAR', true);
	}else
	{
		CtrlEnabled('APROBAR', false);
		CtrlEnabled('RECHAZAR', false);
	}
	if (estado == "C")
	{
		CtrlEnabled('CUBRIR', false);
		if (Ctrl('main').GetMode() == 'EDIT')
			CtrlEnabled('REQS_DIC', false);
	}
	else
	{
		CtrlEnabled('CUBRIR', true);
	}
}

function setValues(obj, strResult)
{	
	var result = createDoc(strResult).documentElement;
	Ctrl('o_motivo_rechazo').SetXValue(result.getAttribute('o_motivo_rechazo'));
	Ctrl('f_dictado').SetXValue(result.getAttribute('f_dictado'));
	Ctrl('d_titulo').SetXValue(result.getAttribute('d_titulo'));
	
	if (result.getAttribute('action') == "A")
		Ctrl('main').DoEvent('APROBAR');
	else
		Ctrl('main').DoEvent('RECHAZAR');
	return true;
}
	</form:Scripts>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Event action="APROBAR" name="APROBAR" runat="server"/>
	<form:Event action="RECHAZAR" name="RECHAZAR" runat="server"/>
</form:Form>
