<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="NucleusRH.Base.Capacitacion.Requerimientos.autoflow" name="NucleusRH.Base.Capacitacion.Requerimientos">
	<flow:declare>
		<qry:define declare="&lt;DATOS user=&quot;pailan&quot; /&gt;" name="GET_USER">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:DATOS" name="PARAMIN"/>
				<qry:element name="DATOS">
					<qry:attribute value="#PARAMIN:@user" name="user"/>
					<qry:insert-select name="account-name"/>
				</qry:element>
			</qry:main>
			<qry:select name="account-name" doc="SOURCE">
				<qry:xquery>
					for $r in path('Nomad\\Base\\Login\\Cuentas')/CUENTA
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql2" doc="PARAM">
				<qry:xquery>
					for $r in file('Nomad\\Base\\Login\\Cuentas\\{%= #PARAM:@FILE %}')/CUENTA[@LOGIN=#PARAMIN:@user]/ENTIDAD
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql4" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql4" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.oi_personal_emp
				FROM PER01_PERSONAL, PER02_PERSONAL_EMP
				JOIN PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
				WHERE
				PER01_PERSONAL.oi_usuario_sistema = {#PARAM:@value}
				AND PER02_PERSONAL_EMP.oi_indic_activo = 1
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;11425&quot; oi_area=&quot;&quot; c_estado=&quot;&quot; f_solicitud_desde=&quot;&quot;/&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_requerimiento as oi_requerimiento, t0.f_solicitud
				FROM CYD15_REQS_CAP as t0
				WHERE 
				t0.oi_personal_emp = {#PARAM:@oi_personal_emp}
				{%?(#PARAM:@oi_area!='') {% AND t0.oi_curso = {#PARAM:@oi_area} %} {% %} %}
				{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
				{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
				{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_requerimiento"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST" declare="&lt;DATOS oi_personal_emp=&quot;11425&quot; oi_area=&quot;&quot; c_estado=&quot;&quot; f_solicitud_desde=&quot;&quot;/&gt;">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT t0.oi_requerimiento as oi_requerimiento, t0.d_sector as d_sector, t0.c_estado as c_estado, t0.f_solicitud as f_solicitud, t0.c_urgencia as c_urgencia, t0.f_inicio as f_inicio, t0.e_cant_pers as e_cant_pers, t0.f_dictado as f_dictado, t0.d_titulo as d_titulo, t0.d_sector as CODE, t0.o_descripcion as TEXT, t0.oi_curso as oi_curso, t0.oi_personal_emp as oi_personal_emp 
			FROM CYD15_REQS_CAP as t0
				WHERE 
				t0.oi_personal_emp = {#PARAM:@oi_personal_emp}
				{%?(#PARAM:@oi_area!='') {% AND t0.oi_curso = {#PARAM:@oi_area} %} {% %} %}
				{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
				{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
				{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_requerimiento"/>
						<qry:attribute name="d_sector" value="$r/@d_sector"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="f_solicitud" value="$r/@f_solicitud"/>
						<qry:attribute name="c_urgencia" value="$r/@c_urgencia"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="e_cant_pers" value="$r/@e_cant_pers"/>
						<qry:attribute name="f_dictado" value="$r/@f_dictado"/>
						<qry:attribute name="d_titulo" value="$r/@d_titulo"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_curso" value="$r/@oi_curso"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="USER">
			<DATOS user="" oi_personal_emp=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS oi_personal_emp="" c_estado="" oi_area="" f_desde_solicitud="" f_hasta_solicitud="" f_hoy="" user=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="REQUERIMIENTO">
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.form:FILTER" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.form" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
			<flow:action name="GET_USER">
				<doc:load-qry input-doc-path="#USER:" output-doc="USER" qry="GET_USER"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#SOURCE:@oi_personal_emp"/>
			</flow:action>
			<flow:action name="FILTER">
				<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.noreg.form:EDIT" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form:SHOW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form" mode="SHOW">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form:LIST" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form" mode="LIST">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form:EDIT" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form:NEW" form-class="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.form" mode="NEW"/>
	</flow:group>
</flow:flow>
