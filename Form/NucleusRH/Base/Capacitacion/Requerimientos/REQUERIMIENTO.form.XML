<form:Form extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO" xmlns:form="nomad_engine.form">
	<form:Right visible="0" width="90%"/>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsREQUERIMIENTO">
			<form:Column name="main_columnsREQUERIMIENTOcolumn1">
				<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="&#193;rea de Curso" nvalue="#source:oi_curso/@value" name="oi_curso">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Cursos.CURSO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput required="1" enabled="0" xsize="15" length="30" label="Legajo Solicitante" nvalue="#source:oi_personal_emp/@value" name="oi_personal_emp">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Indicador de efectividad sugerido" nvalue="#source:@o_indicador" name="o_indicador"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha de Solicitud" nvalue="#source:@f_solicitud" name="f_solicitud"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				<form:DateTime visible="SHOW" pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Dictado" nvalue="#source:@f_dictado" name="f_dictado">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox visible="SHOW" required="0" enabled="0" ysize="1" xsize="50" length="100" label="T&#237;tulo del Curso" nvalue="#source:@d_titulo" name="d_titulo"/>
				<form:TextBox visible="SHOW" required="0" enabled="0" ysize="4" xsize="50" length="1000" label="Motivo de Rechazo" nvalue="#source:@o_motivo_rechazo" name="o_motivo_rechazo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Organizacion.Cursos.CURSO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="&#193;rea de Curso" attrname="oi_curso" name="oi_curso"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Departamento/Sector" attrname="d_sector" name="d_sector"/>
				<form:LVColumn visible="0" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Legajo Solicitante" attrname="oi_personal_emp" name="oi_personal_emp"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Estado" attrname="c_estado" name="c_estado"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Solicitud" attrname="f_solicitud" name="f_solicitud"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Urgencia del Requerimiento" attrname="c_urgencia" name="c_urgencia"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha tentativa de inicio" attrname="f_inicio" name="f_inicio"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="N&#250;mero de Participantes" attrname="e_cant_pers" name="e_cant_pers"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Dictado" attrname="f_dictado" name="f_dictado"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="T&#237;tulo del Curso" attrname="d_titulo" name="d_titulo"/>
			</form:LVColumns>
			<form:Event action="ONLOAD" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Capacitacion/Requerimientos/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Capacitacion/Requerimientos/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|EDIT|DELETE" mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Capacitacion/Requerimientos/DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Capacitacion/Requerimientos/SECURITY" visible="0" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Scripts>
		function ONLOAD()
{
	var estado;
	
	// Busco el estado
	if (Ctrl('LIST'))
	{
		estado = Ctrl('LIST').GetSelectAttrValue('c_estado');
	}else
	{
		estado = Ctrl('c_estado').GetXValue();
	}
	
	// Deshabilito controles
	if (estado != 'S')
	{
		CtrlEnabled('EDIT', false);
		CtrlEnabled('DELETE', false);
	}else
	{
		CtrlEnabled('EDIT', true);
		CtrlEnabled('DELETE', true);
	}
}
	</form:Scripts>
</form:Form>
