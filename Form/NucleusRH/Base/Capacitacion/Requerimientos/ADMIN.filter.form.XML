							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime nvalue="#source:@f_desde_solicitud" name="f_desde_solicitud" label="Fecha Desde Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta_solicitud" name="f_hasta_solicitud" label="Fecha Hasta Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
