<form:Form name="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.form" extends="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.filter.autoform" default_mode="FILTER" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Center>
		<form:Blank name="bl40" width="100%" visible=""/>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Columns name="main_columnsCURSO">
			<form:Column name="main_columnsCURSOcolumn1">
				<form:FKInput nvalue="#source:@oi_personal_emp" label="Empresa - Legajo" required="0" xsize="15" length="30" name="oi_personal_emp">
