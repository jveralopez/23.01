							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.Requerimientos.REQUERIMIENTO.c_estado.Combo.autoflow" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
