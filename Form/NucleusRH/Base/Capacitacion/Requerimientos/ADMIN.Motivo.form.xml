<form:Form name="NucleusRH.Base.Capacitacion.Requerimientos.ADMIN.Motivo.form" doc="SOURCE" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label visible="APROBAR" label="Aprobaci&#243;n de Requerimiento de Capacitaci&#243;n" nowrap="1" style="S3 LCol_w" name="GEN"/>
				<form:Label visible="RECHAZAR" label="Rechazo de Requerimiento de Capacitaci&#243;n" nowrap="1" style="S3 LCol_w" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="blk1"/>
		<form:TextBox visible="APROBAR" required="0" ysize="1" xsize="50" length="100" label="T&#237;tulo del Curso" nvalue="#SOURCE:@d_titulo" name="d_titulo"/>
		<form:DateTime visible="APROBAR" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Dictado" nvalue="#SOURCE:@f_dictado" name="f_dictado">
			<form:SButtons>
				<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:TextBox visible="RECHAZAR" required="0" ysize="4" xsize="50" length="1000" label="Motivo de Rechazo" nvalue="#SOURCE:@o_motivo_rechazo" name="o_motivo_rechazo"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button startvalidate="1" note="Aceptar" descrip="Aceptar" img="OK" label="Aceptar" name="ACCEPT">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
