<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Capacitacion.Terceros.flow" extends="NucleusRH.Base.Capacitacion.Terceros.autoflow">
	<flow:declare>
		<doc:define name="PARAM">
			<VALUE/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute to-attr-path="#PARAM:@extern" from-value="0"/>
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.filter.autoform"/>
		</flow:action>
		<flow:action name="NEW">
			<doc:set-attribute to-attr-path="#PARAM:@extern" from-value="1"/>
			<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Capacitacion.Terceros.TERCERO"/>
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="TERCERO">
		<flow:form extends="NucleusRH.Base.Capacitacion.Terceros.TERCERO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Terceros.TERCERO.noreg.form:EDIT" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Terceros.TERCERO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form:SHOW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Terceros.TERCERO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form:LIST" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Capacitacion.Terceros.TERCERO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form:EDIT" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Capacitacion.Terceros.TERCERO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form:NEW" form-class="NucleusRH.Base.Capacitacion.Terceros.TERCERO.form" mode="NEW">
			<flow:action name="SAVE">
				<flow:call-action else="save-DDO-EXT" eq="0" if="#PARAM:@extern" action="save-DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
			<flow:action name="save-DDO-EXT">
				<doc:save-object class="NucleusRH.Base.Capacitacion.Terceros.TERCERO" doc="NEWDDOROOT"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@id" to-attr-path="#PARAM:@id"/>
				<flow:exit-flow return-path="#PARAM:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
