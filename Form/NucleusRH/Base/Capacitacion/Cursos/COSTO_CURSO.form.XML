<form:Form extends="NucleusRH.Base.Capacitacion.Cursos.COSTO_CURSO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Cursos.COSTO_CURSO" xmlns:form="nomad_engine.form">
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_item_costo">
					<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.ItemsCosto.ITEM_COSTO.Combo.autoflow" required="1" enabled="NEW|EDIT" label="Item Costo" nvalue="#source:oi_item_costo/@value" name="oi_item_costo"/>
				</form:GColumn>
				<form:GColumn name="gcoln_cantidad">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Cantidad" nvalue="#source:@n_cantidad" name="n_cantidad">
						<form:Event name="onchange" action="CalcularTotal" runat="client"/>
					</form:NumberBox>
				</form:GColumn>
				<form:GColumn name="gcoln_costo_uni">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Costo Unitario" nvalue="#source:@n_costo_uni" name="n_costo_uni">
						<form:Event name="onchange" action="CalcularTotal" runat="client"/>
					</form:NumberBox>
				</form:GColumn>
				<form:GColumn name="gcoln_costo_total">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Costo Total" nvalue="#source:@n_costo_total" name="n_costo_total"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Scripts>
		function CalcularTotal()
{
	var cantidad = Ctrl("MAIN_GRID").GetCellSelectedXValue("n_cantidad");
	var costo = Ctrl("MAIN_GRID").GetCellSelectedXValue("n_costo_uni");
	if (cantidad !='' &amp;&amp; costo !='')
	{
		Ctrl("MAIN_GRID").SetCellSelectedXValue("n_costo_total", number2str(cantidad * costo));
	}
}
	</form:Scripts>
</form:Form>
