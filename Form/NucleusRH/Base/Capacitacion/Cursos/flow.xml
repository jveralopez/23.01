		<doc:define name="FILTERDATA">
			<FILTRO oi_area="" oi_tipo_curso="" oi_categ_curso="" n_duracion_hs_desde="" n_duracion_hs_hasta="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="">
				<CURSOS/>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO oi_area=&quot;&quot; oi_tipo_curso=&quot;&quot; oi_categ_curso=&quot;&quot; n_duracion_hs_desde=&quot;&quot; n_duracion_hs_hasta=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN3=&quot;&quot;&gt;&#13;&#10;  &lt;CURSOS&gt;&#13;&#10;    &lt;CURSO id=&quot;81&quot; /&gt;&#13;&#10;  &lt;/CURSOS&gt;&#13;&#10;&lt;/FILTRO&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_curso as oi_curso,
				t0.c_curso as c_curso,
				t0.oi_area as oi_area,
				t0.oi_categ_curso as oi_tipo_curso,
				t0.oi_categ_curso as oi_categ_curso,
				t0.n_duracion_hs as n_duracion_hs				
				FROM CYD01_CURSOS as t0 
				WHERE 1=1
				{%? (#SOURCE:@oi_area!='')	{% AND t0.oi_area = {#SOURCE:@oi_area} %} {% %} %}
				{%? (#SOURCE:@oi_tipo_curso!='')	{% AND t0.oi_tipo_curso = {#SOURCE:@oi_tipo_curso} %} {% %} %}				    		
    		{%? (#SOURCE:@oi_categ_curso!='') {% AND t0.oi_categ_curso = {#SOURCE:@oi_categ_curso} %} {% %} %}
    		{%? (#SOURCE:@n_duracion_hs_desde!='')	{% AND t0.n_duracion_hs &gt;={#SOURCE:@n_duracion_hs_desde} %} {% %} %}
    		{%? (#SOURCE:@n_duracion_hs_hasta!='')	{% AND t0.n_duracion_hs &lt;={#SOURCE:@n_duracion_hs_hasta} %} {% %} %}
    	  {%? (string(#SOURCE:CURSOS/CURSO/@id)!='') {% AND t0.oi_curso in ({%=string(#SOURCE:CURSOS/CURSO/@id) %}) %} {%  %} %}
    	  ORDER BY 
     	  {%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     	  {%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
     		{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}     		
				oi_curso asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_curso"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO oi_area=&quot;78&quot; oi_tipo_curso=&quot;&quot; oi_categ_curso=&quot;&quot; n_duracion_hs_desde=&quot;&quot; n_duracion_hs_hasta=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN3=&quot;&quot;&gt;&#13;&#10;  &lt;CURSOS&gt;&#13;&#10; &#13;&#10;  &lt;/CURSOS&gt;&#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
