<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="IntegralCapacitacion" doc="source">
	<form:Title>
		<form:Label label="Listado integral de Capacitaci&#243;n" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1"/>
		<form:Columns name="colrep">
			<form:Column name="dict" separation="1" align="left" valign="top">
				<form:Rower separation="5" required="1" name="fdesdehasta" label="Fecha Inicio / fin">
					<form:DateTime required="1" name="f_desde" nvalue="#source:@f_desde" pattern="YYYYMMDD" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label name="lblfechas" label="..."/>
					<form:DateTime required="1" name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:ComboBox nvalue="#source:@oi_area" label="&#193;rea de Curso" queryname1="NucleusRH.Base.Organizacion.Cursos.CURSO.INFO" xsize="40" mode="QRY" required="0" name="oi_area"/>
				<form:FKInput enabled="" xsize="10" length="30" label="Curso" nvalue="#source:@oi_curso" name="oi_curso">
					<form:STexts>
						<form:SText xsize="40" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Cursos.CURSO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox name="oi_tipo_curso" nvalue="#source:@oi_tipo_curso" label="Tipo Curso" queryname1="NucleusRH.Base.Capacitacion.TiposCurso.TIPO_CURSO.INFO" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox queryname1="NucleusRH.Base.Capacitacion.CategoriasCurso.CATEG_CURSO.INFO" label="Categor&#237;a Curso" nvalue="#source:@oi_categ_curso" name="oi_categ_curso" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Competencias.COMPETENCIA.INFO" nvalue="#source:@oi_competencia" label="Competencias" name="oi_competencia" xsize="40" mode="QRY" required="0"/>
			</form:Column>
			<form:Column name="cur" separation="1" align="right" valign="top">
				<form:FKInput visible="0" nvalue="#source:@oi_dictado" label="Dictado" name="oi_dictado" required="0" enabled="" xsize="10" length="30">
					<form:STexts>
						<form:SText xsize="40" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox queryname2="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname1="NucleusRH.Base.Capacitacion.Dictados.DICTADO.INFO" xsize="40" mode="QRY" required="0" label="Dictado" nvalue="#source:@oi_dictado" name="oi_dictado"/>
				<form:ComboBox nvalue="#source:@c_estado" name="c_estado" xsize="40" mode="OPT" required="0" label="Estado">
					<options>
						<option text="Planificado" value="P"/>
						<option text="Finalizado" value="F"/>
						<option text="Cancelado" value="C"/>
					</options>
				</form:ComboBox>
				<form:ComboBox label="Proveedor" queryname1="NucleusRH.Base.Capacitacion.Proveedores.PROVEEDOR.INFO" nvalue="#source:@oi_proveedor" name="oi_proveedor" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox queryname1="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.INFO" nvalue="#source:@oi_docente" name="oi_docente" label="Docente" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox label="Lugar de Dictado" queryname1="NucleusRH.Base.Capacitacion.LugaresDictado.LUGAR_DICTADO.INFO" nvalue="#source:@oi_lugar_dictado" name="oi_lugar_dictado" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" label="Tipo de Asistencia" nvalue="#source:@c_tipo_asistencia" name="c_tipo_asistencia">
					<options>
						<option text="Concurrencia" value="C"/>
						<option text="A Distancia" value="D"/>
					</options>
				</form:ComboBox>
				<form:FKInput required="0" xsize="10" length="30" label="Solicitante" nvalue="#source:@oi_estructura" name="oi_estructura">
					<form:STexts>
						<form:SText xsize="40" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank width="100%" name="bl3"/>
		<form:Blank width="100%" name="bl4"/>
		<form:Columns width="50%" name="cHECKS">
			<form:Column separation="5" align="left" name="CCHHH">
				<form:Rower separation="20" width="100%" name="rower1">
					<form:Label label="Datos del Curso" style="M1 LCol_t" align="center" name="VCVC"/>
					<form:CheckBox label="Todos" name="all_per" nvalue="">
						<form:Event action="toggleAll" name="onclick" runat="client"/>
					</form:CheckBox>
				</form:Rower>
				<form:CheckBox nvalue="#source:@c_area_curso" label="&#193;rea de Curso" name="c_area_curso"/>
				<form:CheckBox nvalue="#source:@tipo_curso" name="tipo_curso" label="Tipo de Curso"/>
				<form:CheckBox label="Categor&#237;a de Curso" nvalue="#source:@cat_curso" name="cat_curso"/>
				<form:CheckBox label="Competencias" name="competencia" nvalue="#source:@competencia"/>
			</form:Column>
			<form:Column separation="5" align="right" name="SAAS">
				<form:Rower separation="20" width="100%" name="rower2">
					<form:Label label="Datos del Dictado" style="M1 LCol_t" nowrap="1" align="center" name="VCVCsa"/>
					<form:CheckBox label="Todos" name="all_leg" nvalue="">
						<form:Event action="toggleAll" name="onclick" runat="client"/>
					</form:CheckBox>
				</form:Rower>
				<form:CheckBox label="Fecha de Inicio" name="f_inicio" nvalue="#source:@f_inicio"/>
				<form:CheckBox label="Fecha de Fin" name="f_fin" nvalue="#source:@f_fin"/>
				<form:CheckBox nvalue="#source:@n_duracion_hs_dict" name="n_duracion_hs_dict" label="Duraci&#243;n(horas)"/>
				<form:CheckBox nvalue="#source:@proveedor_dict" name="proveedor_dict" label="Proveedor"/>
				<form:CheckBox label="Lugar de Dictado" nvalue="#source:@lugar_dictado" name="lugar_dictado"/>
				<form:CheckBox label="Tipo de Asistencia" nvalue="#source:@tipo_asistencia" name="tipo_asistencia"/>
				<form:CheckBox nvalue="#source:@inscripto" name="inscripto" label="Inscriptos"/>
				<form:CheckBox name="oi_clase_dictado" label="Clase del Dictado" nvalue="#source:@oi_clase_dictado"/>
				<form:CheckBox label="Costos" name="oi_costo_dictado" nvalue="#source:@oi_costo_dictado"/>
				<form:CheckBox nvalue="#source:@docente_dict" name="docente_dict" label="Docentes"/>
				<form:CheckBox label="Recursos" name="oi_recurso" nvalue="#source:@oi_recurso"/>
				<form:CheckBox label="Estado/Fecha Estado" nvalue="#source:@estadofecha" name="estadofecha"/>
				<form:CheckBox label="Cantidad de Asistentes" nvalue="#source:@cant_asis" name="cant_asis"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" enabled="" visible="" img="ok" name="btnEjecutar" label="Aceptar" note="Ejecuta" descrip="">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function toggleAll(me)
{
	var col = me.m_Parent.m_Parent;
	
	if (me.GetXValue()=="0")
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("0");
			} catch(err){}
		}
	}
	else
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("1");
			} catch(err){}
		}
	}
}
	</form:Scripts>
</form:Form>
