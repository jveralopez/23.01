<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para NucleusRH.Base.Personal.Reportes.AptitudesVsPuesto"/>
	<flow:declare>
		<doc:define class="NucleusRH.Base.Capacitacion.Dictados.DICTADO" name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY"/>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_dictado=""/>
		</doc:define>
		<doc:define name="PARAM">
			<DATOS oi_dictado="">
				<INSCRIPTOS/>
			</DATOS>
		</doc:define>
		<doc:define name="REPORT">
			<DATA empty-attr=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS f_fin=&quot;02/03/2007&quot; oi_dictado=&quot;1&quot; n_duracion_hs=&quot;10&quot; d_dictado=&quot;AFIANZAMIENTO PROFESIONAL&quot; f_hoy=&quot;viernes 13, julio, 2007&quot; f_inicio=&quot;26/02/2007&quot;&gt;&lt;INSCRIPTOS nmd-col=&quot;1&quot;&gt;&lt;INSCRIPTO d_ape_y_nom=&quot;Camarasa, Daniel&quot; asistencias=&quot;0&quot; c_dni=&quot;15001228&quot; l_aprobado=&quot;0&quot; clases=&quot;5&quot; chk_seleccion=&quot;1&quot; c_estado=&quot;INSC&quot; porcentaje_asist=&quot;0&quot; oi_personal_emp=&quot;224&quot; oi_inscripto=&quot;5&quot; f_estado=&quot;20070214&quot; /&gt;&lt;INSCRIPTO d_ape_y_nom=&quot;RIZZO, JUAN PABLO&quot; asistencias=&quot;0&quot; c_dni=&quot;30048248&quot; l_aprobado=&quot;0&quot; clases=&quot;5&quot; chk_seleccion=&quot;1&quot; c_estado=&quot;INSC&quot; porcentaje_asist=&quot;0&quot; oi_personal_emp=&quot;232&quot; oi_inscripto=&quot;4&quot; f_estado=&quot;20070214&quot; /&gt;&lt;INSCRIPTO d_ape_y_nom=&quot;CRAPACHER, ATILIO PEDRO&quot; asistencias=&quot;1&quot; c_dni=&quot;6059337&quot; l_aprobado=&quot;0&quot; clases=&quot;5&quot; chk_seleccion=&quot;1&quot; c_estado=&quot;INSC&quot; porcentaje_asist=&quot;20&quot; oi_personal_emp=&quot;233&quot; oi_inscripto=&quot;2&quot; f_estado=&quot;20070214&quot; /&gt;&lt;INSCRIPTO d_ape_y_nom=&quot;BLAJOS, MARIO CONSTANTINO&quot; asistencias=&quot;0&quot; c_dni=&quot;006061746&quot; l_aprobado=&quot;0&quot; clases=&quot;5&quot; chk_seleccion=&quot;1&quot; c_estado=&quot;INSC&quot; porcentaje_asist=&quot;0&quot; oi_personal_emp=&quot;234&quot; oi_inscripto=&quot;1&quot; f_estado=&quot;20070214&quot; /&gt;&lt;INSCRIPTO d_ape_y_nom=&quot;AVILA, JUSTO LORENZO&quot; asistencias=&quot;1&quot; c_dni=&quot;22222222&quot; l_aprobado=&quot;0&quot; clases=&quot;5&quot; chk_seleccion=&quot;1&quot; c_estado=&quot;INSC&quot; porcentaje_asist=&quot;20&quot; oi_personal_emp=&quot;235&quot; oi_inscripto=&quot;3&quot; f_estado=&quot;20070214&quot; /&gt;&lt;/INSCRIPTOS&gt;&lt;/DATOS&gt;" name="qry_filter">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="d_dictado" value="#SOURCE:DATOS/@d_dictado" type="Nomad.NSystem.String"/>
					<qry:attribute name="n_duracion_hs" value="#SOURCE:DATOS/@n_duracion_hs" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_inicio" value="#SOURCE:DATOS/@f_inicio" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_fin" value="#SOURCE:DATOS/@f_fin" type="Nomad.NSystem.String"/>
					<qry:attribute name="f_hoy" value="#SOURCE:DATOS/@f_hoy" type="Nomad.NSystem.String"/>
					<qry:element name="INSCRIPTOS">
						<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in #PARAM:INSCRIPTOS/INSCRIPTO[@chk_seleccion=1]
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.filter.form" mode="FILTER" doc-path="#PARAM:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.filter.form" mode="FILTER" doc="PARAMETERS">
		<flow:action name="ACCEPT">
			<doc:load-object id-path="#PARAM:@oi_dictado" class="NucleusRH.Base.Capacitacion.Dictados.DICTADO" doc="DDO"/>
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="PARAM" a-doc="DDO">
				<map docA="A" docB="B">
					<submap path-docB="#B:INSCRIPTOS" path-docA="#A:INSCRIPTOS">
						<map docA="A" docB="B">
							<link B="#B:@oi_inscripto" A="#A:@id"/>
							<link B="#B:@oi_personal_emp" A="#A:oi_personal_emp/@value"/>
							<link B="#B:@oi_tercero" A="#A:oi_tercero/@value"/>
							<link B="#B:@c_estado" A="#A:@c_estado"/>
							<link B="#B:@f_estado" A="#A:@f_estado"/>
							<link B="#B:@l_aprobado" A="#A:@l_aprobado"/>
							<link B="#B:@chk_seleccion" A="'1'"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<INSCRIPTO oi_personal_emp="" oi_inscripto="" c_estado="" f_estado="" l_aprobado="" chk_seleccion="1"/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:exec-method this-doc="DDO" class="NucleusRH.Base.Capacitacion.Dictados.DICTADO" method="Porcentaje_Asistencia">
				<flow:param name="xml_param" doc="PARAM" mode="inout" type="Nomad.NSystem.Object"/>
			</flow:exec-method>
			<flow:open-form parent-doc-path="#PARAM:INSCRIPTOS" doc-path="#PARAM:INSCRIPTOS" form-class="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.form" mode="SHOW"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.form" name="NucleusRH.Base.Capacitacion.Reportes.EmisionCertificados.form" mode="SHOW" doc="source">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="PARAM" input-doc-path="#PARAM:" qry="qry_filter"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportFO" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param value="NucleusRH.Base.Capacitacion.Certificados.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#PARAM:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.Reportes.Certificados.form" name="NucleusRH.Base.Capacitacion.Reportes.Reportes.Certificados.form" doc="source" mode="SHOW">
		<flow:action name="BACK">
			<flow:exit-flow return-path="#PARAM:"/>
		</flow:action>
	</flow:form>
</flow:flow>
