<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.PlanCapacitacion.filter.form" doc="source">
	<form:Center width="95%">
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bln1"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" label="Fecha Desde" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Fecha Desde" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Hasta" mask="dd/mm/yyyy" label="Fecha Hasta" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton descrip="Fecha Hasta" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bln2"/>
				<form:Grid name="grdCursos" proto="&lt;CURSO/&gt;" idvalue="#SOURCEGRILLA:@id" nvalue="#source:CURSOS" width="483px" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
					<form:Helper name="NucleusRH.Base.Capacitacion.Cursos.CURSO.LM.guia.flow" action="HELP">
						<helper-mess>
							{grdCurso.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput required="1" enabled="" xsize="15" length="30" label="Curso" nvalue="#SOURCEGRILLA:@id" name="oi_curso">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Capacitacion.Cursos.CURSO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Blank name="bln3"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button descrip="Ejecutar el reporte" label="Aceptar" name="btnFilter" img="ok">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Plan de Capacitaci&#243;n por Per&#237;odo" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Scripts>
		function set_f_hasta(me){
	var date = AddDays(me.TypedValue(), 30);  	
 	Ctrl('f_hasta').SetXValue(date2str(date)); 
}
	</form:Scripts>
</form:Form>
