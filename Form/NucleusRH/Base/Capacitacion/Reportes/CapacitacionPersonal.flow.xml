<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="ReportesCapacitacionPersonal">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<ROWS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal.filter.form">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Capacitacion.CapacitacionPersonal.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Capacitaciones Otorgadas al Personal" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
