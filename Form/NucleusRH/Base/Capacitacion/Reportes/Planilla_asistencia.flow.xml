<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_dictado="" f_desde="" f_hasta="" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia.filter.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.Planilla_asistencia" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Planilla de Asistencias" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param value="NucleusRH.Base.Capacitacion.Planilla_asistencia.rpt" name="pstrReportName" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Planilla para Control de Asistencia" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
