<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.PlanCapacitacion.filter.form" doc="source">
	<form:Center width="95%">
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bln1"/>
				<form:ComboBox nvalue="#source:@oi_periodo" xsize="60" queryname1="NucleusRH.Base.Capacitacion.Periodos.PERIODO.INFO" name="oi_periodo" mode="QRY" required="1" label="Per&#237;odo"/>
				<form:ComboBox nvalue="#source:@oi_clase_org" where1="ORG02_CLASES_ORG.c_estado = 'V'" xsize="60" queryname1="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.INFO" name="oi_clase_org" mode="QRY" required="1" label="Organigrama"/>
				<form:Blank name="bln2"/>
				<form:Grid idvalue="#SOURCEGRILLA:@id" nvalue="#source:ESTRUCTURAS" width="483px" doc="SOURCEGRILLA" proto="&lt;ESTRUCTURA oi_estructura=&quot;&quot;/&gt;" name="grdEstructuras" note="" descrip="" rows="3" allowhelper="0" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCEGRILLA:@oi_estructura" required="1" enabled="" xsize="15" length="30" label="Estructura Organizativa" name="oi_estructura">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" oi_clase_org="{oi_clase_org.ReadXValue}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Blank name="bln3"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button descrip="Ejecutar el reporte" label="Aceptar" name="btnFilter" img="ok">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Presupuesto Vs. Costos Reales por Per&#237;odo" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
</form:Form>
