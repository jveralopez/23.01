<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="DictadosPorPersonas" extends="Nomad.base.HTML_XLS.flow">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
		<flow:action name="dictadosPorClase">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonasPorClases.filter.form" doc-path="#FILTERDATA:" mode="Clase"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Capacitacion.DictadosPorPersonas.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Capacitaciones otorgadas al personal" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonasPorClases.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonasPorClases.filter.form:Clase" parent-doc="PARENTSOURCE" doc="SOURCE" mode="Clase">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonasPorClases" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonasPorClases" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Capacitacion.DictadosPorPersonasPorClases.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Capacitaciones otorgadas al personal" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
