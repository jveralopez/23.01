<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Capacitacion.Reportes.CapacitacionPersonal.filter.form">
	<form:Title>
		<form:Label label="Capacitaciones Otorgadas al Personal" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:DateTime label="Fecha Desde" pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Hasta" pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Hasta" mask="dd/mm/yyyy" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:CheckBox required="1" nvalue="#source:@l_contratistas" name="l_contratistas" label="Incluir Contratistas?"/>
				<form:ComboBox label="&#193;rea de Curso" queryname1="NucleusRH.Base.Organizacion.Cursos.CURSO.INFO" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_area" name="oi_area"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
