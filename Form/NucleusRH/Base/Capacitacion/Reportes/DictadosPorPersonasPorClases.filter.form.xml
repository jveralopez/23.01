<form:Form xmlns:form="nomad_engine.form" default_mode="filter" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPersonas.filter.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" doc="source">
	<form:Title>
		<form:Label label="Capacitaciones otorgadas al personal por Clases" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Rower label="Fecha desde/hasta" required="1" name="rwerfechas" separation="5">
						<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" nvalue="#source:@f_desde" name="f_desde">
							<form:SButtons>
								<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lbl_fecha_hasta" label="..."/>
						<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Hasta" mask="dd/mm/yyyy" nvalue="#source:@f_hasta" name="f_hasta">
							<form:SButtons>
								<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
					<form:ComboBox nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" label="Empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Accidentabilidad/Reportes/AccidentesLaborales/filter/form/empresa">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Accidentabilidad/Reportes/AccidentesLaborales/filter/form/empresa/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/Accidentabilidad/Reportes/AccidentesLaborales/filter/form/empresa"/>
						</form:Policies>
					</form:ComboBox>
					<form:ComboBox nvalue="#source:@oi_area" label="&#193;rea de Curso" queryname1="NucleusRH.Base.Organizacion.Cursos.CURSO.INFO" xsize="40" mode="QRY" required="0" name="oi_area"/>
					<form:CheckBox nvalue="#source:@l_asistencia" label="Mostrar s&#243;lo asistencias" name="l_asistencia"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%"/>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	if (arrFILTER.length==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}

	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
