<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="NucleusRH.Base.Capacitacion.DetalleInscriptos.filter.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Detalle de Inscriptos" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Label visible="" style="S3 LCol_g" align="center" label="Criterios de B&#250;squeda" name="lbl"/>
		<form:Columns width="90%" name="cols">
			<form:Column name="col1">
				<form:Blank name="bln1"/>
				<form:FKInput required="1" enabled="" xsize="15" length="30" label="Curso" nvalue="#FILTERDATA:@oi_curso" name="oi_curso">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Cursos.CURSO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="bl4" width="100%" visible=""/>
				<form:DateTime nvalue="#FILTERDATA:@f_desde" pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" label="Fecha Desde" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Fecha Desde" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#FILTERDATA:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Hasta" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton descrip="Fecha Hasta" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl5" width="100%" visible=""/>
				<form:Grid proto="&lt;DICTADO/&gt;" nvalue="#source:DICTADOS" idvalue="#SOURCEGRILLA:@id" width="483px" name="grdDictado" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
					<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.LM.guia.flow" action="HELP">
						<helper-mess oi_curso="{oi_curso.ReadXValue}">
							{grdDictado.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput label="Dictado" name="oi_dictado" required="0" enabled="" xsize="15" length="30" nvalue="#SOURCEGRILLA:@id">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.CURSO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess oi_curso="{oi_curso.ReadXValue}" text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button descrip="Ejecutar el reporte" label="Aceptar" name="btnFilter" img="ok">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
