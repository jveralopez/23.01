<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMS oi_dictado="" f_desde="" f_hasta="" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo.filter.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#SOURCE:" text="ppsource"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Capacitacion.DictadosPorPeriodo.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Detalle de Dictados" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
