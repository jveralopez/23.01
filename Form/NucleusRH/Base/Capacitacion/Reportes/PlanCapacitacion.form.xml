<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.PlanCapacitacion.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Plan de Capacitaci&#243;n" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="90%">
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bln1"/>
				<form:Blank name="bln3"/>
				<form:Rower width="40" label="Per&#237;odo Desde / Hasta" name="periododesdehasta" separation="4" required="1">
					<form:DateTime xsize="20" required="1" pattern="YYYYMM" mask="dd/mm/yyyy" nvalue="#source:@e_periodo_des" name="e_periodo_des">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label name="lblperiododesdehasta" label="..."/>
					<form:DateTime xsize="20" required="1" pattern="YYYYMM" mask="dd/mm/yyyy" nvalue="#source:@e_periodo_has" name="e_periodo_has">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:ComboBox visible="0" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Accidentabilidad/Reportes/AccidentesLaborales/filter/form/empresa"/>
				<form:Rower separation="0" label="Estructura Organizativa" name="rower_estr">
					<form:FKInput nvalue="#source:@oi_estructura" required="0" enabled="" xsize="15" length="30" name="estructura" label="Estructura Organizativa">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
					<form:Label name="subestr" label="Incluir subestructuras"/>
					<form:CheckBox name="l_recursivo" nvalue="#source:@l_recursivo" label="Incluir subestructuras"/>
				</form:Rower>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte" label="Aceptar" name="btnFilter" img="ok">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts/>
</form:Form>
