<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Capacitacion.Dictados.CLASE_DICTADO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Certificado Asistencia" nowrap="1" align="center" visible="SHOW" style="S3 LCol_w" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#source:../../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="bln1"/>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:FKInput label="Curso - Dictado" required="1" enabled="" xsize="15" length="30" nvalue="#PARAM:@oi_dictado" name="oi_dictado">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="bln2"/>
		<form:Grid rows="10" idvalue="#source:@oi_personal_emp" allowdel="0" allownew="0" paging="1" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn>
					<form:CheckBox nvalue="#source:@chk_seleccion" name="chk_seleccion"/>
				</form:GColumn>
				<form:GColumn>
					<form:Label dynamic="1" nvalue="#source:@inscripto" style="S2 LCol_g" label="Inscripto" name="descr"/>
				</form:GColumn>
				<form:GColumn>
					<form:Combo action="COMBO" flow="NucleusRH.Base.Capacitacion.Dictados.INSCRIPTO.c_estado.Combo.autoflow" required="1" enabled="NEW|EDIT" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				</form:GColumn>
				<form:GColumn>
					<form:DateTime enabled="0" nvalue="#source:@f_estado" name="f_estado" label="Fecha Estado" pattern="YYYYMMDD" required="1" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton descrip="Fecha Desde" img="Calendar" visible="" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn>
					<form:CheckBox enabled="0" label="Aprobado" nvalue="#source:@l_aprobado" name="l_aprobado"/>
				</form:GColumn>
				<form:GColumn>
					<form:NumberBox nvalue="#source:@porcentaje_asist" label="% Asistencia" name="porcentaje_asist" enabled="0" length="10"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operaci&#243;n" note="Acepta la operacion sobre el formulario">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
