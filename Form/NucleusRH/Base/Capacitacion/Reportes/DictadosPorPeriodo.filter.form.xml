<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Reportes.DictadosPorPeriodo" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Detalle de Dictados" name="GEN_SHOW" style="S3 LCol_w" align="center" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="cols">
			<form:Column valign="top" align="center" name="col1">
				<form:Blank name="bln1"/>
				<form:Blank name="bln2"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" label="Fecha Desde" nvalue="#source:@f_desde" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Fecha Desde" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="" descr="Fecha Hasta" mask="dd/mm/yyyy" label="Fecha Hasta" nvalue="#source:@f_hasta" name="f_hasta">
					<form:SButtons>
						<form:SButton descrip="Fecha Hasta" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:FKInput visible="0" nvalue="#source:@oi_dictado" label="Dictado" name="oi_dictado" required="0" enabled="" xsize="10" length="30">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox queryname2="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname1="NucleusRH.Base.Capacitacion.Dictados.DICTADO.INFO" xsize="40" mode="QRY" required="1" label="Curso - Dictado" nvalue="#source:@oi_dictado" name="oi_dictado"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte" label="Aceptar" name="btnFilter" img="ok">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
