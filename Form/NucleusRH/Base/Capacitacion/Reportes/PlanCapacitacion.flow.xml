<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion.flow">
	<flow:info label="Flow para NucleusRH.WillinerRH.Capacitacion.Reportes.PlanCapacitacion"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAM oi_empresa="" e_periodo_des="" e_periodo_has="" oi_estructura="" l_recursivo=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion.form:FILTER" form-class="NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion.form" mode="FILTER" doc="SOURCE">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Capacitacion.PlanCapacitacion.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Plan de Capacitaci&#243;n" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.PlanCapacitacion" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
</flow:flow>
