<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Capacitacion.Reportes.Integral" extends="Nomad.base.HTML_XLS.flow">
	<flow:info label="Flow para NucleusRH.Base.Capacitacion.Reportes.Integral"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMETERS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.Reportes.Integral.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.Reportes.Integral.filter.form" name="NucleusRH.Base.Capacitacion.Reportes.Integral.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="emifilter"/>
		</flow:action>
		<!--flow:action name="on-open">
		<flow:call-action action="Load-FILTER"/>
	</flow:action-->
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.Integral" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Capacitacion.Reportes.Integral" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Capacitacion.IntegralCapacitacion.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Listado integral de Capacitaci&#243;n" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
