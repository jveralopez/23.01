<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Reportes.RequerimientosCap.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" doc="source">
	<form:Title>
		<form:Label label="Requerimientos de Capacitaci&#243;n" name="lbl_titulo" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:ComboBox name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa"/>
					<form:DateTime required="0" nvalue="#source:@f_desde" pattern="YYYYMMDD" label="Fecha desde" name="f_desde">
						<form:SButtons>
							<form:SButton name="sbtncalendario" img="calendar">
								<form:Event action="SHOW_HELPER" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime required="0" nvalue="#source:@f_hasta" pattern="YYYYMMDD" label="Fecha hasta" name="f_hasta">
						<form:SButtons>
							<form:SButton name="sbtncalendario" img="calendar">
								<form:Event action="SHOW_HELPER" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:ComboBox name="area_curso" required="0" queryname1="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname2="NucleusRH.Base.Organizacion.Cursos.CURSO.INFO" nvalue="#source:@oi_curso" label="&#193;rea - Curso" xsize="40" mode="QRY"/>
					<form:Combo required="0" name="estado" nvalue="#source:@c_estado" label="Estado">
						<form:Opts>
							<OPT text="Solicitado" value="S"/>
							<OPT value="A" text="Aprobado"/>
							<OPT value="R" text="Rechazado"/>
							<OPT value="C" text="Cubierto"/>
						</form:Opts>
					</form:Combo>
					<form:Combo required="0" name="urgencia" label="Urgencia" nvalue="#source:@c_urgencia">
						<form:Opts>
							<OPT value="A" text="Alta"/>
							<OPT value="M" text="Media"/>
							<OPT value="B" text="Baja"/>
						</form:Opts>
					</form:Combo>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers" X-POLICY="./FORM/NucleusRH/SancorRH/Evaluacion2/Reportes/REPORTE-FILTRO-RESP-EVAL/form/vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%"/>
			<form:Policies>
				<form:Updateable X-POLICY="./FORM/NucleusRH/SancorRH/Evaluacion2/Evaluacion/ASIGNACION/filter/form/vgroupDatosPers/HAB"/>
				<form:Visible X-POLICY="./FORM/NucleusRH/SancorRH/Evaluacion2/Evaluacion/ASIGNACION/filter/form/vgroupDatosPers"/>
			</form:Policies>
			<form:Policies>
				<form:Updateable X-POLICY="./FORM/NucleusRH/SancorRH/Evaluacion2/Reportes/REPORTE-FILTRO-RESP-EVAL/form/vgroupDatosPers/HAB"/>
				<form:Visible X-POLICY="./FORM/NucleusRH/SancorRH/Evaluacion2/Reportes/REPORTE-FILTRO-RESP-EVAL/form/vgroupDatosPers"/>
			</form:Policies>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
		<!--form:HiddenArr help-stop="0" nvalue="#source:ROWS" proto="&lt;ROW id=&quot;&quot;/&gt;" name="legajos">
		<form:Attr name="id"/>
	</form:HiddenArr-->
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT">
					<form:Event action="Guardar" runat="client" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/ACCEPT"/>
					</form:Policies>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK">
					<form:Event action="BACK" runat="server" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/DetalleHorasConceptos/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
