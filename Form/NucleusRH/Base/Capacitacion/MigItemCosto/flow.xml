<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Capacitacion.MigItemCosto.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para NucleusRH.Base.Capacitacion.MigItemCosto"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Capacitacion.MigItemCosto.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Capacitacion.MigItemCosto.form" name="NucleusRH.Base.Capacitacion.MigItemCosto.form:SHOW" doc="PARAMETERS" mode="SHOW">
		<flow:action name="ACCEPT">
			<flow:exec-method method="ImportarItemsCostos" class="NucleusRH.Base.Capacitacion.MigItemCosto.ITEM_COSTO" out-attr-path="#BATCHDOC:@batch-id" priority="5"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
