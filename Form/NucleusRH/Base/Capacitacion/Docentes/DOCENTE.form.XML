<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.form" extends="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsDOCENTE">
			<form:Column name="main_columnsDOCENTEcolumn1">
				<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Persona" nvalue="#source:oi_personal/@value" name="oi_personal">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Capacitacion.Docentes.PERSONAL.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess d_ape_y_nom="{d_ape_y_nom.CValue}" c_nro_documento="{c_nro_documento.CValue}" oi_tipo_documento="{oi_tipo_documento.CValue}" text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="SetControls" name="onReceiveData" runat="client"/>
				</form:FKInput>
				<form:ComboBox visible="0" queryname1="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Tipo Documento" nvalue="#source:oi_tipo_documento/@value" name="oi_tipo_documento"/>
				<form:Combo enabled="NEW|EDIT" action="COMBO" flow="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.Combo.autoflow" required="1" label="Tipo Documento" nvalue="#source:oi_tipo_documento/@value" name="oi_tipo_documento" order-change="NEXT:oi_personal"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function SetControls()
{
	if(Ctrl('oi_personal').GetXValue() != '')		
	{
		CtrlEnabled('oi_tipo_documento', false);
		CtrlEnabled('c_nro_documento', false);
		CtrlEnabled('d_ape_y_nom', false);
	}
	else
	{
		CtrlEnabled('oi_tipo_documento', true);
		CtrlEnabled('c_nro_documento', true);
		CtrlEnabled('d_ape_y_nom', true);
	}
	
}
	</form:Scripts>
</form:Form>
