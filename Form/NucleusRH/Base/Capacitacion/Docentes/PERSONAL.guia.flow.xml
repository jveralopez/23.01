<flow:flow name="NucleusRH.Base.Capacitacion.Docente.PERSONAL.guia.flow" extends="NucleusRH.Base.Personal.Legajo.PERSONAL.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Personal.Legajo.PERSONAL.flow"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define declare="&lt;helper-mess id=&quot;&quot; d_ape_y_nom=&quot;KABABE, AGUSTIN&quot; c_nro_documento=&quot;30169169&quot; oi_tipo_documento=&quot;1&quot; &#13;&#10;text=&quot;KABABE, AGUSTIN&quot; code=&quot;DNI30169169&quot; /&gt;" name="HELP-START">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:/helper-mess[@id!='']" name="ROW"/>
				</qry:element>
			</qry:main>
			<qry:select name="ROW" doc="SOURCE">
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="#SOURCE:@id"/>
						<qry:attribute name="value" value="#SOURCE:@id"/>
						<qry:attribute name="code" value="#SOURCE:@code"/>
						<qry:attribute name="text" value="#SOURCE:@text"/>
						<qry:attribute value="#SOURCE:@text" name="d_ape_y_nom"/>
						<qry:attribute value="#SOURCE:@oi_tipo_documento" name="oi_tipo_documento"/>
						<qry:attribute value="#SOURCE:@c_nro_documento" name="c_nro_documento"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess id=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_personal as ID, 
				t.c_personal as CODE, 
				t.d_ape_y_nom as TEXT,
				t.oi_tipo_documento,
				t.c_nro_documento, 
				SEC.policy  
				FROM PER01_PERSONAL as t, NMD_SECURITY(class=\'NucleusRH.Base.Personal.Legajo.PERSONAL\') as SEC 
				JOIN t.oi_personal LEFT OUTER SEC.id  
				WHERE t.oi_personal={#SOURCE:helper-mess/@ID} 
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@TEXT" name="d_ape_y_nom"/>
					<qry:attribute value="$r/@oi_tipo_documento" name="oi_tipo_documento"/>
					<qry:attribute value="$r/@c_nro_documento" name="c_nro_documento"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess code=&quot;dni20653155&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_personal as ID, 
				t.c_personal as CODE, 
				t.d_ape_y_nom as TEXT, 
				t.oi_tipo_documento,
				t.c_nro_documento,
				SEC.policy  
				FROM PER01_PERSONAL as t, NMD_SECURITY(class=\'NucleusRH.Base.Personal.Legajo.PERSONAL\') as SEC 
				JOIN t.oi_personal LEFT OUTER SEC.id  
				WHERE t.c_personal={substring_before(#INDOC:@CODE,\'-\')}  
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
					<qry:attribute value="''" name="SUB_SEARCH"/>
					<qry:attribute value="''" name="PARENTID"/>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@TEXT" name="d_ape_y_nom"/>
					<qry:attribute value="$r/@oi_tipo_documento" name="oi_tipo_documento"/>
					<qry:attribute value="$r/@c_nro_documento" name="c_nro_documento"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_personal as ID, 
				t.c_personal as CODE, 
				t.d_ape_y_nom as TEXT, 
        t.oi_tipo_documento,
				t.c_nro_documento, 
				SEC.policy  
				FROM PER01_PERSONAL as t, NMD_SECURITY(class=\'NucleusRH.Base.Personal.Legajo.PERSONAL\') as SEC 
				JOIN t.oi_personal LEFT OUTER SEC.id  
				WHERE  ( CONTAIN(UCASE(t.c_personal),UCASE({#SOURCE:DATA/@FILTER})) 
				OR CONTAIN(UCASE(t.d_ape_y_nom),UCASE({#SOURCE:DATA/@FILTER})) ) 
				ORDER BY CODE asc
				')/ROWS/ROW[CONTAINS(UPPER_CASE(@TEXT),UPPER_CASE(#SOURCE:DATA/@FILTER)) or CONTAINS(UPPER_CASE(@CODE),UPPER_CASE(#SOURCE:DATA/@FILTER))]
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
						<qry:attribute value="$r/@TEXT" name="d_ape_y_nom"/>
						<qry:attribute value="$r/@oi_tipo_documento" name="oi_tipo_documento"/>
						<qry:attribute value="$r/@c_nro_documento" name="c_nro_documento"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
