<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Inscripcion.filter.form" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Inscripci&#243;n a Dictado" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:FKInput visible="0" label="Curso - Dictado" required="1" enabled="" xsize="15" length="30" nvalue="#source:@oi_dictado" name="oi_dictado">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:ComboBox queryname2="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname1="NucleusRH.Base.Capacitacion.Dictados.DICTADO.INFO" xsize="41" mode="QRY" required="1" label="Curso - Dictado" nvalue="#source:@oi_dictado" name="oi_dictado"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button label="Filtrar" descrip="Ejecuta el Filtro" startvalidate="1" visible="" name="btnAceptar" img="ok" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
