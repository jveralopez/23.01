<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Capacitacion.Inscripcion.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para NucleusRH.Base.Personal.AptitudesVsPuesto"/>
	<flow:declare>
		<doc:define name="DICTADO">
			<DICTADO oi_dictado=""/>
		</doc:define>
		<doc:define name="INSCRIPTOS"/>
		<doc:define name="LEGAJOS"/>
		<qry:define declare="&lt;DATOS oi_dictado=&quot;2&quot; gcustom=&quot;&quot; gpers=&quot;&quot; empresa=&quot;1&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;3&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; oi_centro_costo=&quot;&quot; oi_categoria=&quot;&quot; soloconvenio=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot;&gt;&#13;&#10;  &lt;ROWS&gt;&#13;&#10;    &lt;ROW id=&quot;9&quot; /&gt;&#13;&#10;  &lt;/ROWS&gt;&#13;&#10;&lt;/DATOS&gt;&#13;&#10;" name="QRY_DESCR">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS/ROWS" name="QRY_IDS"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_IDS" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:insert-select doc-path="$r" name="QRY_LEGAJOS"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_LEGAJOS" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom
				FROM PER02_PERSONAL_EMP, PER01_PERSONAL
				JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="legajo" value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DICTADO oi_dictado=&quot;6180&quot; /&gt;" name="QRY_INSCRIPTOS">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_dictado" value="#SOURCE:DICTADO/@oi_dictado"/>
					<qry:element name="ROWS">
						<qry:insert-select name="sql1" doc-path="#SOURCE:DICTADO"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
					SELECT 
						CYD02_INSCRIPTOS.oi_personal_emp
					FROM 
						CYD02_INSCRIPTOS, PER02_PERSONAL_EMP
					JOIN
						CYD02_INSCRIPTOS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp					
					WHERE 
						CYD02_INSCRIPTOS.oi_dictado = {#SOURCE:@oi_dictado}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#DICTADO:" form-class="NucleusRH.Base.Capacitacion.Inscripcion.filter.form" mode="FILTER"/>
		</flow:action>
		<flow:action name="INITLEGAJOS">
			<doc:load-qry output-doc="INSCRIPTOS" input-doc-path="#SOURCE:" qry="QRY_INSCRIPTOS"/>
			<flow:open-form doc-path="#INSCRIPTOS:" parent-doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Capacitacion.Inscripcion.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Capacitacion.Inscripcion.filter.form" form-class="NucleusRH.Base.Capacitacion.Inscripcion.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="INSCRIPTOS" input-doc-path="#SOURCE:" qry="QRY_INSCRIPTOS"/>
			<flow:open-form doc-path="#INSCRIPTOS:" parent-doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Capacitacion.Inscripcion.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form mode="SHOW" name="NucleusRH.Base.Capacitacion.Inscripcion.form" form-class="NucleusRH.Base.Capacitacion.Inscripcion.form" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SAVE">
			<flow:log text="ppsource" text-path="#SOURCE:"/>
			<doc:load-qry output-doc="LEGAJOS" input-doc-path="#SOURCE:" qry="QRY_DESCR"/>
			<flow:exec-method method="Inscripcion" out-attr-path="#BATCHDOC:@batch-id" priority="3" class="NucleusRH.Base.Capacitacion.Dictados.DICTADO">
				<flow:param doc="LEGAJOS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="legajos"/>
				<flow:param attr-path="#SOURCE:@oi_dictado" type="Nomad.NSystem.String" mode="in" name="oi_dictado"/>
				<flow:param value="0" type="Nomad.NSystem.Boolean" mode="in" name="tercero"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#SOURCE:ROWS" attach-id="ARRA"/>
		</flow:action>
	</flow:form>
</flow:flow>
