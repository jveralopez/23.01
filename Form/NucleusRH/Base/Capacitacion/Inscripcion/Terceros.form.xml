<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Inscripcion.Terceros.form" doc="source">
	<form:Title width="90%">
		<form:Label label="Inscripci&#243;n de Terceros a Dictado" nowrap="1" align="center" style="S3 LCol_w" name="lbl_tit"/>
	</form:Title>
	<form:Center>
		<form:Blank name="blank_iter01"/>
		<form:FKInput enabled="0" label="Curso - Dictado" required="1" xsize="15" length="30" nvalue="#source:@oi_dictado" name="oi_dictado">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="blank_iter011"/>
		<form:Grid width="400px" nvalue="#source:ROWS" idvalue="#DATAGRID:@id" proto="&lt;ROW/&gt;" doc="DATAGRID" allowdelall="1" allowdel="1" allownew="1" paging="1" rows="10" name="grdTerceros">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="colTercero">
					<form:ComboBox queryname1="NucleusRH.Base.Capacitacion.Terceros.TERCERO.INFO" xsize="50" mode="QRY" required="0" label="Tercero" nvalue="#DATAGRID:@id" name="oi_tercero"/>
				</form:GColumn>
			</form:GColumns>
			<form:SButtons>
				<form:SButton descrip="Agregar Nuevo Tercero" label="Nuevo" img="table_add" name="NEW">
					<form:Event action="NewTercero" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" img="cancel" label="Cancelar" name="CANCEL" X-POLICY="./FORM/NucleusRH/Base/Capacitacion/Terceros/TERCERO/autoform/CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function NewTercero()
{	
	openNewFlowWait('NucleusRH.Base.Capacitacion.Terceros.flow','NEW',"",new ObjectResult(), "L");			
}

function ObjectResult()
{
	this.processResult = function(strRET)
	{    
		var xmlRET = new NomadXML(strRET);
		if(xmlRET.GetAttr("id") != "")
		{			
			Ctrl('grdTerceros').AddNew();
			Ctrl('grdTerceros').GetCellSelectedControl("oi_tercero").SetXValue(xmlRET.GetAttr("id"));
		}		
	}
}
	</form:Scripts>
</form:Form>
