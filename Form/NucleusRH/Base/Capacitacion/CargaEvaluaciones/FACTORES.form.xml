<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.CargaEvaluaciones.FACTORES.form" doc="source">
	<form:Title>
		<form:Label align="center" nowrap="1" label="Carga Masiva de Resultados de Evaluaciones - Factores" name="lbl" style="S3 LCol_w" visible=""/>
		<form:Label align="center" dynamic="1" nvalue="#SOURCE:@inscripto" nowrap="1" style="S3 LCol_w" name="ti_01"/>
	</form:Title>
	<form:Center>
		<form:Blank name="blank00"/>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Grid nvalue="#SOURCE:FACTORES" idvalue="#source:@id" rows="12" name="MAIN_GRID" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" doc="source">
			<form:GColumns>
				<form:GColumn visible="0" name="id">
					<form:Label visible="0" name="id" dynamic="1" nvalue="#source:@id" style="S2 LCol_g" label="Id"/>
				</form:GColumn>
				<form:GColumn name="factor">
					<form:Label name="d_factor" dynamic="1" nvalue="#source:@d_factor" style="S2 LCol_g" label="Inscripto"/>
				</form:GColumn>
				<form:GColumn name="n_resultado" allow_order="0">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Resultado" nvalue="#source:@n_resultado" name="n_resultado"/>
				</form:GColumn>
				<form:GColumn name="oi_valor" allow_order="0">
					<form:ComboBox enabled="NEW|EDIT" label="Valor" queryname1="NucleusRH.Base.Capacitacion.Escalas.VALOR.INFO" nvalue="#source:oi_valor/@value" name="oi_valor" mode="QRY">
						<options/>
						<form:Event action="cambioValor" name="onchange" runat="client"/>
					</form:ComboBox>
				</form:GColumn>
				<form:GColumn name="o_fact_ev_as" allow_order="0">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="20" length="50" label="Observaciones" nvalue="#source:@o_fact_ev_as" name="o_fact_ev_as"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:HiddenArr name="arrFactores" nvalue="#SOURCE:FACTORES">
			<form:Attr name="id"/>
			<form:Attr name="oi_escala"/>
			<form:Attr name="oi_valor"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button img="back" label="Atras" name="btnCancelar" enabled="" visible="" descrip="Atras">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("MAIN_GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("MAIN_GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}             

var load = true;
function onload()
{
	for (i = 0; i&lt;Ctrl("MAIN_GRID").RowsCount(); i++)
	{
  		var oi_escala = Ctrl("arrFactores").GetRow(i).GetAttr("oi_escala");
		
	    var valor = Ctrl("MAIN_GRID").GetCellControl("oi_valor",i);
	    valor.SetWhere("OI_FIND = "+oi_escala);  
	    
	    var oi_valor = Ctrl("arrFactores").GetRow(i).GetAttr("oi_valor"); 
	    if(oi_valor != '')
	    	valor.SetXValue(oi_valor);
		
	}  
	load = false;
}             

function cambioValor()
{  
	if(!load)
	{   
		var oi_valor = Ctrl("MAIN_GRID").GetCellSelectedXValue("oi_valor");  
		var indice =  Ctrl("MAIN_GRID").SelectedRowIDX();
		Ctrl("arrFactores").GetRow(indice).SetAttr("oi_valor",oi_valor); 

	}
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
