<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.CargaEvaluaciones.filter.form" doc="source">
	<form:Title>
		<form:Label label="Carga Masiva de Resultados de Evaluaciones del Dictado" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1"/>
		<form:ComboBox where1="CYD02_DICTADOS.c_estado = 'P'" nvalue="#FILTERDATA:@oi_dictado" queryname2="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname1="NucleusRH.Base.Capacitacion.Dictados.DICTADO.INFO" xsize="41" mode="QRY" required="1" label="Curso - Dictado" name="oi_dictado">
			<form:Event action="onchange_EVAL" name="onchange" runat="client"/>
		</form:ComboBox>
		<form:Blank name="bl2"/>
		<form:Label label="Evaluaciones" name="lbl1" align="center" style="S3 LCol_b" visible=""/>
		<form:ListView rows="12" name="LIST" docname="RS">
			<form:LVColumns>
				<form:LVColumn label="Evaluacion" sorteable="1" additional="dd/mm/yyyy HH:MM" name="d_evaluacion" type="string" attrname="d_evaluacion"/>
				<form:LVColumn name="f_eval_as_dict" attrname="f_eval_as_dict" label="Fecha" additional="dd/mm/yyyy HH:MM" type="datetime"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button label="Ejecutar" descrip="Ejecuta el Filtro" startvalidate="1" visible="" name="btnAceptar" img="play" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ONLOAD()
{
	Ctrl("btnAceptar").SetEnabled(Ctrl("LIST").shownRegs.length==0?false:true);
}    

function onchange_EVAL() 
{	
	if(Ctrl("oi_dictado").GetCValue()!="") Ctrl("main").DoEvent("FILTRAR_EVAL");
}
	</form:Scripts>
	<form:Event action="ONLOAD" name="onpostbind" runat="client"/>
	<form:Event name="FILTRAR_EVAL" action="GET_EVAL" runat="server"/>
</form:Form>
