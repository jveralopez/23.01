<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Capacitacion.CargaEvaluaciones.INSCRIPTOS.form" doc="source">
	<form:Title>
		<form:Label label="Carga Masiva de Resultados de Evaluaciones" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="blank00"/>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Grid idvalue="#source:@id" nvalue="#INSCRIPTOS:" rows="12" name="MAIN_GRID" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" doc="source">
			<form:GColumns>
				<form:GColumn visible="0" name="id">
					<form:Label visible="0" name="id" dynamic="1" nvalue="#source:@id" style="S2 LCol_g" label="Id"/>
				</form:GColumn>
				<form:GColumn name="inscripto">
					<form:Label name="inscripto" dynamic="1" nvalue="#source:@inscripto" style="S2 LCol_g" label="Inscripto"/>
				</form:GColumn>
				<form:GColumn name="f_eval_asist" allow_order="0">
					<form:DateTime label="Fecha" pattern="YYYYMMDD" nvalue="#source:@f_eval_asist" name="f_eval_asist"/>
				</form:GColumn>
				<form:GColumn name="n_resultado" allow_order="0">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Resultado" nvalue="#source:@n_resultado" name="n_resultado"/>
				</form:GColumn>
				<form:GColumn name="oi_valor" allow_order="0">
					<form:ComboBox enabled="NEW|EDIT" label="Valor" queryname1="NucleusRH.Base.Capacitacion.Escalas.VALOR.INFO" nvalue="#source:oi_valor/@value" name="oi_valor" mode="QRY">
						<options/>
					</form:ComboBox>
				</form:GColumn>
				<form:GColumn name="o_eval_asist" allow_order="0">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="20" length="50" label="Observaciones" nvalue="#source:@o_eval_asist" name="o_eval_asist"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Hidden name="hayFactores" nvalue="#FACT:@hayFactores"/>
		<form:Hidden name="oi_inscripto" nvalue="#FILTERDATA:@oi_inscripto"/>
		<form:Hidden name="oi_evaluacion" nvalue="#FILTERDATA:@oi_evaluacion"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button descrip="Guardar los cambios" label="Guardar" startvalidate="1" visible="" name="btnGuardar" img="save" note="Ejecuta la busqueda">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" label="Volver" name="btnCancelar" enabled="" visible="" note="Agregar un nuevo registro" descrip="Cancelar la Operaci&#243;n">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button name="btnSiguiente" label="Siguiente" descrip="Ejecuta el Filtro" startvalidate="1" visible="" img="play" note="Ejecuta la busqueda">
					<form:Event action="siguiente" name="onclick" runat="client"/>
					<form:Event name="SIGUIENTE" action="SIGUIENTE" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("MAIN_GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("MAIN_GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}               

function onLoad()
{
	var factores = Ctrl("hayFactores").GetXValue();
 
	CtrlEnabled('btnSiguiente',factores == "1" ? true: false); 
	 
	 cargarWhere();
}                     

function siguiente()
{
 	var oi_inscripto = Ctrl("MAIN_GRID").SelectedRowID();
 	Ctrl('oi_inscripto').SetXValue(oi_inscripto);   
 	
 	Ctrl('btnSiguiente').DoEvent("SIGUIENTE");
 }                   
 
 
 
 
function cargarWhere()
{
     if(Ctrl("oi_evaluacion").GetXValue() != '')
	 {
	     var np, nSQL, i;
	
		 np = GetProxy();
		 nSQL = np.SQLService(); 	
		 var qry = Ctrl("main").getResource("qry_escala");
	 
		 var result = nSQL.GetXML(qry,"&lt;DATA oi_evaluacion='"+Ctrl("oi_evaluacion").GetXValue()+"' /&gt;");
		 
		 var TotalRows = Ctrl("MAIN_GRID").TotalRowsCount(); 
	    
    	 for (x = 0; x &lt; TotalRows ; x++) 
    	 { 
        	var oi_valor = Ctrl("MAIN_GRID").GetCellXValue("oi_valor", x);    
    	    
    	    rowCtrl = Ctrl("MAIN_GRID").GetCellControl("oi_valor",x);
    	    rowCtrl.SetWhere("OI_FIND = '"+result.GetAttr("oi_escala")+"'"); 
	 	 
	 	    if(oi_valor !='') 
	 	 	   rowCtrl.SetXValue(oi_valor);
		
         }
	 }
}               

 
	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
	<form:Resources>
		<form:Resource name="qry_escala" declare="&lt;DATA oi_evaluacion=&quot;1&quot;/&gt; ">
			<qry:main doc="SOURCE" name="">
				<qry:element name="ROW">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT
			CYD12_EVALUACIONES.oi_escala
			FROM 
			CYD12_EVALUACIONES
			WHERE
			CYD12_EVALUACIONES.oi_evaluacion = {#SOURCE:@oi_evaluacion}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_escala" value="$r/@oi_escala"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
