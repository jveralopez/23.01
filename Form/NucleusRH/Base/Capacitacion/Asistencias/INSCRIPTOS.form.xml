<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Asistencia.filter.form" doc="source">
	<form:Title>
		<form:Label label="Carga de Asistencias a Clases" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="blank00"/>
		<form:FKInput label="Curso - Dictado" enabled="0" name="oi_dictado" required="1" xsize="15" length="30" nvalue="#FILTERDATA:@oi_dictado">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:Event name="onReceiveData" action="GET_CLASES" runat="server"/>
		</form:FKInput>
		<form:Blank name="blank01"/>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Grid idvalue="#source:@oi_inscripto" nvalue="#INSCRIPTOS:" rows="12" name="MAIN_GRID" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" doc="source">
			<form:GColumns>
				<form:GColumn name="sel">
					<form:CheckBox name="selected" enabled="NEW|EDIT" nvalue="#source:@sel"/>
				</form:GColumn>
				<form:GColumn visible="0" name="col20" allow_order="0">
					<form:Label dynamic="1" nvalue="#source:@inscripto" style="S2 LCol_g" label="Inscripto" name="descr"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="blank02"/>
		<form:RowAligner name="links">
			<form:Row name="row_1">
				<form:Link label=" Todos" name="todos" img="check" descrip="Seleccionar todos" allowimg="1">
					<form:Event action="selAll" name="onclick" runat="client"/>
				</form:Link>
				<form:Link label=" Ninguno" img="uncheck" descrip="Deseleccionar todos" name="ninguno" allowimg="1">
					<form:Event action="selNone" name="onclick" runat="client"/>
				</form:Link>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button descrip="Guardar los cambios" label="Guardar" startvalidate="1" visible="" name="btnGuardar" img="save" note="Ejecuta la busqueda">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="cancel" label="Cancelar" mess="Est&#225; seguro que desea cancelar la operaci&#243;n?" name="btnCancelar" enabled="" visible="" note="Agregar un nuevo registro" descrip="Cancelar la Operaci&#243;n">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("MAIN_GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("MAIN_GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}

function selAll()
{	
	Ctrl("MAIN_GRID").FilterElements("","");
	
	for (i = 0; i&lt;Ctrl("MAIN_GRID").RowsCount(); i++)
	{
  	Ctrl("MAIN_GRID").SetCellXValue("selected",i,"1");
	}
}

function selNone()
{	
	Ctrl("MAIN_GRID").FilterElements("","");
	
	for (i = 0; i&lt;Ctrl("MAIN_GRID").RowsCount(); i++)
	{
  	Ctrl("MAIN_GRID").SetCellXValue("selected",i,"0");
	}
}
	</form:Scripts>
</form:Form>
