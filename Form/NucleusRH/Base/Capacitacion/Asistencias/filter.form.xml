<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Capacitacion.Asistencia.filter.form" doc="source">
	<form:Title>
		<form:Label label="Carga de Asistencias a Clases" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1"/>
		<form:FKInput visible="0" label="Curso - Dictado" name="oi_dictado" required="1" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_dictado">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Capacitacion.Dictados.DICTADO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event name="onReceiveData" action="GET_CLASES" runat="server"/>
		</form:FKInput>
		<form:ComboBox nvalue="#FILTERDATA:@oi_dictado" queryname2="NucleusRH.Base.Capacitacion.Cursos.CURSO.INFO" queryname1="NucleusRH.Base.Capacitacion.Dictados.DICTADO.INFO" xsize="41" mode="QRY" required="1" label="Curso - Dictado" name="oi_dictado">
			<form:Event action="onchange_CLASES" name="onchange" runat="client"/>
		</form:ComboBox>
		<form:Blank name="bl2"/>
		<form:Label name="lbl1" label="Clases" align="center" style="S3 LCol_b" visible=""/>
		<form:ListView rows="12" name="LIST" docname="RS">
			<form:LVColumns>
				<form:LVColumn sorteable="1" additional="dd/mm/yyyy HH:MM" label="Inicio" name="f_fecha_hora_ini" type="datetime" attrname="f_fecha_hora_ini"/>
				<form:LVColumn additional="dd/mm/yyyy HH:MM" label="Fin" name="f_fecha_hora_fin" type="datetime" attrname="f_fecha_hora_fin"/>
				<form:LVColumn sorteable="1" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Capacitacion.LugaresDictado.LUGAR_DICTADO.guia.autoflow&quot;/&gt;" label="Lugar" name="oi_lugar_dictado" type="fk" attrname="oi_lugar_dictado"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button label="Ejecutar" descrip="Ejecuta el Filtro" startvalidate="1" visible="" name="btnAceptar" img="play" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ONLOAD()
{
	Ctrl("btnAceptar").SetEnabled(Ctrl("LIST").shownRegs.length==0?false:true);
}    

function onchange_CLASES() 
{	
	if(Ctrl("oi_dictado").GetCValue()!="") Ctrl("main").DoEvent("FILTRAR_CLASES");
}
	</form:Scripts>
	<form:Event action="ONLOAD" name="onpostbind" runat="client"/>
	<form:Event name="FILTRAR_CLASES" action="GET_CLASES" runat="server"/>
</form:Form>
