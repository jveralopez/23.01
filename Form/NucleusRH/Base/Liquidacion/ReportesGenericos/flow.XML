<flow:flow xmlns:flow="nomad_engine.flow" extends="NucleusRH.Base.Liquidacion.ReportesGenericos.autoflow" name="NucleusRH.Base.Liquidacion.ReportesGenericos">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.ReportesGenericos"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.filter.autoform"/>
		</flow:action>
	</flow:main>
	<flow:group Name="REPORTE">
		<flow:form extends="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.form:EDIT" form-class="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.autoform" mode="EDIT">
			<flow:action name="SAVE">
				<flow:log text-path="#DDO:" text="g91"/>
				<flow:exec-method this-doc="DDO" class="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE" method="Guardar"/>
				<flow:call-action action="save-DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.form:NEW" form-class="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE.autoform" mode="NEW">
			<flow:action name="SAVE">
				<flow:exec-method this-doc="NEWDDOROOT" class="NucleusRH.Base.Liquidacion.ReportesGenericos.REPORTE" method="Guardar"/>
				<flow:call-action action="save-DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
