<flow:flow default_action="initialize" name="NucleusRH.Base.Liquidacion.Variables.BaseVariables.flow" description="Flow base para la carga de variables a las empresas y las personas." xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc">
	<flow:info label="Flow BASE para la carga de variables."/>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define declare="&lt;DATA oi=&quot;233&quot; /&gt;" name="GetVariables">
			<qry:main doc="PARAM">
				<qry:element name="FORM">
					<qry:element name="TITLE">
						<qry:attribute type="Nomad.NSystem.String" value="'titulo dinamico'" name="value"/>
					</qry:element>
					<qry:element name="ROWS">
						<qry:insert-select name="GRID" doc-path="#PARAM:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="GRID">
				<qry:xquery>
					for $r in sql('
				SELECT
					v.oi_variable as id,
					v.c_variable,
					v.d_variable,
					v.c_tipo_dato,
					ve.n_valor
				 
				FROM
					LIQ15_VAL_VARGF as ve,
					LIQ09_VARIABLES as v

				JOIN 
					v.oi_variable LEFT OUTER ve.oi_variable

				WHERE
					v.c_tipo_variable = \'4\'
					AND ve.oi_empresa = {#PARAM:@oi}


				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@id" name="id"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_variable" name="n"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_variable" name="d"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_tipo_dato" name="t"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@n_valor" name="v"/>
						<qry:attribute type="Nomad.NSystem.String" value="IIF($r/@n_valor = '', '0', '1')" name="x"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="NADA"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="RS" qry="GetVariables"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Variables.GrillaVariables.form" mode="EDIT" doc-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:group name="EditVariables">
		<flow:form name="NucleusRH.Base.Liquidacion.Variables.GrillaVariables.Base.form" form-class="NucleusRH.Base.Liquidacion.Variables.GrillaVariables.form" mode="EDIT" doc="SOURCE">
			<flow:action name="CANCEL">
				<flow:exit-flow return-path="#NADA:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
