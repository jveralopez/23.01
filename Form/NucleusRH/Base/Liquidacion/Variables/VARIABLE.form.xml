<form:Form xmlns:form="nomad_engine.form" default_mode="NEW" extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsVARIABLE">
			<form:Column name="main_columnsVARIABLEcolumn1">
				<form:ComboBox enabled="NEW|EDIT" xsize="40" mode="OPT" required="1" label="Tipo Variable" nvalue="#source:@c_tipo_variable" name="c_tipo_variable">
					<options>
						<option text="Novedad - Empleado" value="1"/>
						<option text="Novedad Retroactiva - Empleado" value="10"/>
						<option text="Novedad - Empresa" value="2"/>
						<option text="Fijo - Empleado" value="3"/>
						<option text="Fijo - Empresa" value="4"/>
						<option text="Acumulador - Empleado" value="5"/>
						<option text="Acumulador Periodo - Empleado" value="9"/>
						<option text="Sistema" value="6"/>
						<option text="Auxiliar" value="7"/>
						<option text="Calculada - Conceptos" value="8"/>
						<option text="Novedad - Cargo" value="11"/>
						<option text="Fijo - Cargo" value="12"/>
						<option text="Acumulador Periodo - Cargo" value="13"/>
					</options>
				</form:ComboBox>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_variable" name="c_variable">
					<form:Event action="cargar" name="onchange" runat="client"/>
					<form:Event action="ValidarFormato" name="onvalidate" runat="client"/>
				</form:TextBox>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_variable" name="d_variable"/>
				<form:CheckBox required="0" enabled="NEW|EDIT" label="Apertura" nvalue="#source:@l_apertura" name="l_apertura"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" nvalue="#source:@n_valor" name="n_valor"/>
				<form:CheckBox required="0" enabled="NEW|EDIT" label="Reservada" nvalue="#source:@l_reservada" name="l_reservada"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo Externo" nvalue="#source:@c_externo" name="c_externo"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_variable" name="o_variable"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		&#13;&#10;function cargar(){
	if (Ctrl('c_externo').GetCValue() =='')
	{
	  Ctrl('c_externo').SetCValue( Ctrl('c_variable').GetCValue());
	} 
}

function ValidarFormato(myThis)
{ 
	var codVar = myThis.GetXValue();
	
	var regexNumero = /^[0-9]+$/;
	if(regexNumero.test(codVar.toString().charAt(0)))
	{
		myThis.SetError('Formato de C&#243;digo de variable incorrecto: Los c&#243;digos no pueden comenzar con n&#250;mero.');
		return false;
	}
	
	var regexCodVar = /^[A-Za-z0-9_]+$/;
	if(!regexCodVar.test(codVar))
	{
		myThis.SetError('Formato de C&#243;digo de variable incorrecto: Solo se permite que tenga letras, n&#250;meros y guiones bajos.');
		return false;	
	}
	else
		return true;
}
	</form:Scripts>
</form:Form>
