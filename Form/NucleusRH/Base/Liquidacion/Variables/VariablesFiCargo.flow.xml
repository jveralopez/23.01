<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" description="Flow para la carga de variables FIJAS" name="NucleusRH.Base.Liquidacion.Variables.VariablesFiCargo.flow" extends="NucleusRH.Base.Liquidacion.Variables.BaseVariables.flow">
	<flow:info label="NucleusRH.Base.Liquidacion.Variables.VariablesFiCargo.flow"/>
	<flow:declare>
		<qry:define declare="&lt;DATA oi='1' oi_personal_emp=&quot;11445&quot; /&gt;" name="GetVariables">
			<qry:main doc="PARAM">
				<qry:element name="DATA">
					<qry:element name="TITLE">
						<qry:attribute type="Nomad.NSystem.String" value="#PARAM:DATA/@oi" name="oi"/>
						<qry:attribute type="Nomad.NSystem.String" value="#PARAM:DATA/@oi_personal_emp" name="oi_personal_emp"/>
						<qry:attribute type="Nomad.NSystem.String" value="'Cargo no encontrado'" name="value"/>
						<qry:insert-select name="TITLE" doc-path="#PARAM:DATA"/>
					</qry:element>
					<qry:element name="ROWS">
						<qry:insert-select name="GRID" doc-path="#PARAM:DATA"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="TITLE">
				<qry:xquery>
					for $r in sql('
				SELECT
					PER01_PERSONAL.d_ape_y_nom,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER02_CARGOS.oi_cargo 
				FROM
					PER01_PERSONAL,
					PER02_PERSONAL_EMP,
					PER02_CARGOS
				JOIN
					PER02_CARGOS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal  					
				WHERE 
					PER02_CARGOS.oi_cargo = {#PARAM:@oi} and
					PER02_CARGOS.oi_personal_emp = {#PARAM:@oi_personal_emp}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="'Carga de valores Personal [' + $r/@e_numero_legajo + ']' + $r/@d_ape_y_nom + ' - Cargo [' + $r/@oi_cargo + ']'" name="value"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="GRID">
				<qry:xquery>
					for $r in sql('
				SELECT
					v.oi_variable as id,
					v.c_variable,
					v.d_variable,
					v.c_tipo_dato,
					vp.n_valor
				 
				FROM
					LIQ07_VAREF_CARGO(LIQ07_VAREF_CARGO.oi_cargo = {%=#PARAM:@oi%} and LIQ07_VAREF_CARGO.oi_personal_emp = {%=#PARAM:@oi_personal_emp%}) as vp,
					LIQ09_VARIABLES as v

				JOIN 
					v.oi_variable LEFT OUTER vp.oi_variable

				WHERE
					v.c_tipo_variable = \'12\'
          and v.oi_variable in (select cv.oi_variable from LIQ14_CONC_VAR as cv, LIQ14_CONCEPTOS as c	JOIN 	cv.oi_concepto INNER c.oi_concepto where c.l_activo = 1)
        ORDER BY
         	c_variable ASC
                
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@id" name="id"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_variable" name="n"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_variable" name="d"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_tipo_dato" name="t"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@n_valor" name="v"/>
						<qry:attribute type="Nomad.NSystem.String" value="IIF($r/@n_valor = '', '0', '1')" name="x"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="RS" qry="GetVariables"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Variables.GrillaVariablesCargo.form" mode="EDIT" doc-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:group name="EditVariables">
		<flow:form name="NucleusRH.Base.Liquidacion.Variables.GrillaVariablesCargo.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Variables.GrillaVariablesCargo.form" extends="NucleusRH.Base.Liquidacion.Variables.GrillaVariables.Base.form" mode="EDIT" doc="SOURCE">
			<flow:action name="SAVE">
				<flow:exec-method method="CargarVarFijasCargo" class="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.PERSONAL_EMP">
					<flow:param doc="RS" type="Nomad.NSystem.Object" mode="in" name="pobjParametros"/>
				</flow:exec-method>
				<flow:call-action action="CANCEL"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
