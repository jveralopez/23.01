<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Variables.GrillaVariables.form" doc="SOURCE">
	<form:Scripts>
		function FilterGrid() {
	Ctrl("grdVariables").FilterElements("","");
	if (Ctrl("buscar").GetCValue() != "") Ctrl("grdVariables").FilterElements(Ctrl("buscar").GetCValue(),"");
}
	</form:Scripts>
	<form:Title width="100%">
		<form:Label width="90%" align="center" nowrap="1" nvalue="#SOURCE:TITLE/@value" dynamic="1" style="S3 LCol_w" name="lblTitulo1"/>
		<form:Label width="90%" align="center" nowrap="1" nvalue="#SOURCE:TITLE/@value2" dynamic="1" style="S3 LCol_w" name="lblTitulo2"/>
	</form:Title>
	<form:Center width="900px">
		<form:Blank name="blkBlank1"/>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blank_iter01"/>
		<form:Grid width="850px" idvalue="#ROW:@id" nvalue="#SOURCE:ROWS" paging="1" rows="10" doc="ROW" name="grdVariables" descrip="Grilla de carga para las variables" allowdelall="0" allowhelper="0" allowdel="0" allownew="0">
			<form:GColumns>
				<form:GColumn name="colLink">
					<form:Link allowimg="1" img="link2" label="" name="LINK"/>
				</form:GColumn>
				<form:GColumn name="colNombre" allow_order="0">
					<form:Label style="S2 LCol_g" width="80px" label="Nombre" nvalue="#ROW:@n" dynamic="1" name="lblGridNombre"/>
				</form:GColumn>
				<form:GColumn name="colDesc">
					<form:Label style="S2 LCol_g" width="350px" label="Descripci&#243;n" nvalue="#ROW:@d" dynamic="1" name="lblGridDesc"/>
				</form:GColumn>
				<form:GColumn name="colValor" allow_order="0">
					<form:NumberBox max="99999999" min="-99999999" precision="3" name="txtGridValor" required="0" descr="Titulo de la liquidacion" ysize="1" xsize="10" length="20" label="Valor" nvalue="#ROW:@v"/>
				</form:GColumn>
				<form:GColumn name="colCantidad" allow_order="0">
					<form:NumberBox label="Cantidad" precision="3" min="-99999999" max="99999999" name="txtGridCantidad" required="0" descr="Titulo de la liquidacion" ysize="1" xsize="10" length="20" nvalue="#ROW:@c"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="rowButtons">
			<form:Row name="row1">
				<form:Button name="SAVE" label="Guardar" img="save" descrip="Guardar los Cambios en la Base de Datos" startvalidate="0" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="SAVE"/>
				</form:Button>
				<form:Button img="cancel" label="Cancelar" name="CANCEL" descrip="" note="">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
