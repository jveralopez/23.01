<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Variables.CARGAPORVARIABLE" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Columns name="fgfg">
			<form:Column name="gggg">
				<form:Blank name="blank_iter01" visible=""/>
				<form:FKInput length="0" nvalue="#FILTERDATA:@oi_variable" label="Variable" name="fkVariable" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.EN.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="blank_iter01x" visible=""/>
				<form:FKInput nvalue="#FILTERDATA:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="blank_iter01xx" visible=""/>
				<form:Grid proto="&lt;PERSONA/&gt;" nvalue="#source:PERSONAS" idvalue="#SOURCEGRILLA:@id" doc="SOURCEGRILLA" width="660px" allownew="1" allowdelall="1" allowdel="1" allowhelper="0" rows="10" paging="1" name="grilla">
					<form:GColumns>
						<form:GColumn allow_order="0" name="grilla">
							<form:FKInput nvalue="#SOURCEGRILLA:@oi_personal_liq" label="N&#250;mero de legajo" name="oi_personal_liq" length="30" xsize="15" enabled="" required="1">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Legajo.LegajoLiq.guia.flow">
									<helper-mess liq="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton name="SEARCH" label="Search" img="SEARCH">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn name="valor">
							<form:TextBox nvalue="#SOURCEGRILLA:@n_valor" required="0" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" name="n_valor">
								<form:Event action="ValidadCampoValor" name="onchange" runat="client"/>
							</form:TextBox>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" note="Cancela la operacion sobre el formulario" descrip="Cancelar la operacion" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Carga de valores de novedades por variable" nowrap="1" align="center" style="S3 LCol_w" name="GEN_DEL"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Scripts>
		var value;
function ValidadCampoValor(obj){
	value = obj.GetXValue();
	if(value.indexOf(',') != -1){
		alert("Formato inv&#225;lido de n&#250;mero decimal:"+value+". Utilizar punto '.' en lugar coma ','");
		obj.SetXValue("");
	}
}
	</form:Scripts>
</form:Form>
