<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Liquidacion.Variables.CargaPorVariable.flow" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_variable="" oi_liquidacion="">
				<PERSONAS/>
			</DATOS>
		</doc:define>
		<doc:define name="TEMP">
			<DATOS oi_variable="" oi_liquidacion="">
				<PERSONAS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:assign-ref from-path="#FILTERDATA:" to-doc="TEMP"/>
			<flow:log text-path="#FILTERDATA:" text="chuekinitialize"/>
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Variables.CargaPorVariable.form" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Variables.CargaPorVariable.form" form-class="NucleusRH.Base.Liquidacion.Variables.CargaPorVariable.form" mode="EDIT" doc="SOURCE">
		<flow:action name="SAVE">
			<flow:log text-path="#SOURCEGRILLA:" text="SUPER1"/>
			<flow:log text-path="#SOURCE:" text="SUPER2"/>
			<doc:assign-mapping a-doc="FORM" b-doc="FILTERDATA" dir-apply="a-&gt;b">
				<map docA="A" docB="B">
					<submap path-docA="#A:ctrl[@id='grilla']/rows" path-docB="#B:PERSONAS">
						<map docA="A" docB="B">
							<link A="#A:columns/ctrl[@id='oi_personal_liq']/@xval" B="#B:@oi_personal_liq"/>
							<link A="#A:columns/ctrl[@id='n_valor']/@xval" B="#B:@n_valor"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<PER oi_personal_liq="" n_valor=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:log text-path="#FILTERDATA:" text="SUPER"/>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" method="NovPorVariables">
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Object" mode="in" name="xmlDoc"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="NOVEDAD" form-class="NucleusRH.Base.Liquidacion.Mensajes.form"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form doc="SOURCE" mode="NOVEDAD" form-class="NucleusRH.Base.Liquidacion.Mensajes.form" name="NucleusRH.Base.Liquidacion.Mensajes.form:NOVEDAD">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<doc:assign-ref from-path="#TEMP:" to-doc="FILTERDATA"/>
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
