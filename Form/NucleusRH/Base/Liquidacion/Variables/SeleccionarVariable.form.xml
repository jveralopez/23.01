<form:Form doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.SeleccionarVariable.form" xmlns:form="nomad_engine.form">
	<form:Scripts/>
	<form:Title>
		<form:RowAligner name="rowTitle">
			<form:Row name="rowt1">
				<form:Label align="center" nowrap="1" nvalue="#SOURCE:TITLE/@value" dynamic="1" style="S3 LCol_w" name="lblTitulo1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="blank01"/>
		<form:FKInput nvalue="#SOURCE:CENTER/@oi_variable" label="Seleccione una variable" name="fkVariable" required="1">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.EN.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|SHOW_FILTRO" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="rowButtons">
			<form:Row name="row1">
				<form:Button label="Cargar personas" name="LIST" img="list" descrip="Cargar los valores de las variables" startvalidate="1" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="LIST"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="" note="">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
