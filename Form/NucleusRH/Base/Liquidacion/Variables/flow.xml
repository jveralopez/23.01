<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Liquidacion.Variables.autoflow" name="NucleusRH.Base.Liquidacion.Variables">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Variables"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS c_tipo_variable="" ORDEN1="" ATRIB_ORDEN1=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS c_tipo_variable=&quot;2&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;d_variable&quot; variable=&quot;&quot;/&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT t0.oi_variable, t0.c_variable, t0.d_variable
			FROM LIQ09_VARIABLES AS t0
			WHERE t0.c_tipo_variable = {#PARAM:@c_tipo_variable}
			{%? (#PARAM:@variable!='')	
			{% 
			AND (CONTAIN(t0.d_variable, {#PARAM:@variable}) OR
			CONTAIN(t0.c_variable, {#PARAM:@variable}) )
			%}
			{% %} 
			%}
			ORDER BY
			{%? (#PARAM:@ATRIB_ORDEN1!='')	{% {%=#PARAM:@ATRIB_ORDEN1%} {%? (#PARAM:@ORDEN1!='') {% {%=#PARAM:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
			oi_variable ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_variable"/>
						<qry:attribute name="value" value="$r/@oi_variable"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS c_tipo_variable=&quot;2&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; variable=&quot;emi&quot;/&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT t0.oi_variable as oi_variable, 
			t0.c_variable as c_variable, 
			t0.d_variable as d_variable, 
			t0.c_tipo_dato as c_tipo_dato, 
			t0.c_variable as CODE, 
			t0.d_variable as TEXT, 
			t0.c_tipo_variable as c_tipo_variable,
			t0.c_externo
			FROM LIQ09_VARIABLES AS t0
			WHERE t0.c_tipo_variable = {#PARAM:@c_tipo_variable}
			{%? (#PARAM:@variable!='')	
			{% 
			AND (CONTAIN(t0.d_variable, {#PARAM:@variable}) OR
			CONTAIN(t0.c_variable, {#PARAM:@variable}) )
			%}
			{% %} 
			%}
			ORDER BY
			{%? (#PARAM:@ATRIB_ORDEN1!='')	{% {%=#PARAM:@ATRIB_ORDEN1%} {%? (#PARAM:@ORDEN1!='') {% {%=#PARAM:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
			oi_variable ASC
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_variable"/>
						<qry:attribute name="c_variable" value="$r/@c_variable"/>
						<qry:attribute name="d_variable" value="$r/@d_variable"/>
						<qry:attribute name="c_tipo_dato" value="$r/@c_tipo_dato"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="c_tipo_variable" value="$r/@c_tipo_variable"/>
						<qry:attribute name="c_externo" value="$r/@c_externo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Variables.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="VARIABLE">
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Variables.filter.form" mode="FILTER">
			<flow:action name="on-show"/>
			<flow:action name="FILTER">
				<doc:load-qry input-doc-path="#SOURCE:" qry="FILTER" output-doc="QRY"/>
				<doc:new-object class="NucleusRH.Base.Liquidacion.Variables.VARIABLE" doc="DDO"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:open-form form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.noreg.autoform" parent-doc-path="#QRY:" doc-path="#DDO:" iter-index="#QRY:ROW/@value" mode="EDIT"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form:NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form" mode="NEW"/>
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.noreg.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform" mode="SHOW">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form:LIST" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform" mode="LIST">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.autoform" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Variables.VARIABLE.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
