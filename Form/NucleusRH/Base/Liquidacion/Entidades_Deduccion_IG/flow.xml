			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.form" mode="EDIT"/>
