	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_entidad_ig as oi_entidad_ig FROM LIQ05_ENTIDADES_IG as t0 ORDER BY oi_entidad_ig asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_entidad_ig"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_entidad_ig as oi_entidad_ig, t0.c_entidad_ig as c_entidad_ig, t0.d_entidad_ig as d_entidad_ig, t0.d_direccion as d_direccion, t0.c_nro_cuit as c_nro_cuit, t0.c_entidad_ig as CODE, t0.d_entidad_ig as TEXT FROM LIQ05_ENTIDADES_IG as t0 ORDER BY oi_entidad_ig asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_entidad_ig"/>
						<qry:attribute name="c_entidad_ig" value="$r/@c_entidad_ig"/>
						<qry:attribute name="d_entidad_ig" value="$r/@d_entidad_ig"/>
						<qry:attribute name="d_direccion" value="$r/@d_direccion"/>
						<qry:attribute name="c_nro_cuit" value="$r/@c_nro_cuit"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.filter.autoform"/>
