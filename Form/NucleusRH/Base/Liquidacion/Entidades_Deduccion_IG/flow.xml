			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.autoform:LIST" form-class="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.form" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Entidades_Deduccion_IG.ENTIDAD_IG.form:LIST" mode="LIST">
			<flow:action name="open-flow-EDIT">
