<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia" doc="SOURCE">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" label="Seleccion de Sindicatos" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Grid name="GRID" nvalue="#SOURCE:" idvalue="#SOURCE:@id" doc="SOURCE" rows="8" paging="1" allownew="0" allowdel="0">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:CheckBox name="seleccionados" nvalue="#SOURCE:@check" label="" enabled="" required="0"/>
				</form:GColumn>
				<form:GColumn name="col2" allow_order="1">
					<form:TextBox name="c_liquidacion" nvalue="#SOURCE:@code" label="C&#243;digo del Sindicato" length="30" xsize="15" ysize="1" enabled="NEW|EDIT" required="0"/>
				</form:GColumn>
				<form:GColumn name="col3" allow_order="1">
					<form:TextBox name="d_titulo" nvalue="#SOURCE:@text" label="Nombre del Sindicato" length="100" xsize="40" ysize="1" descr="Titulo de la liquidacion" enabled="NEW|EDIT" required="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>

