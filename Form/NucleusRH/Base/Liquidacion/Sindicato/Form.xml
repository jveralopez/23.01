<form:Form name="sindicatofoerm" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label name="lblTitulo" label="Listado de aportes a los Sindicatos" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:RowAligner name="RAFiltros" columns="1">
			<form:Row name="Rcampo1">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
			</form:Row>
			<form:Row name="Rcampo1_">
				<form:DateTime pattern="YYYYMM" required="1" enabled="" descr="Periodo" mask="mm/yyyy" label="Periodo" nvalue="#source:@F_DESDE" name="f_desde">
					<form:SButtons>
						<form:SButton descrip="Periodo" img="Calendar" visible="" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="bblank1" width="100%" visible=""/>
		<form:Grid name="grdDatosLiq" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Liquidacion.Sindicato.Sindicatos.LM.guia.flow" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdDatosLiq.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput required="0" enabled="NEW" xsize="15" length="30" label="Sindicatos" nvalue="#source:oi_sindicato/@value" name="oi_sindicato">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="5">
			<form:Row name="filaBotones">
				<form:Button enabled="" visible="" name="btnImprimir" label="Imprimir" img="print" note="" descrip="Imprime la lista de personas por Sindicato">
					<form:Event action="PRINT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl7_1" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnVistaPrelim" label="Vista preliminar" img="play" note="" descrip="Muestra la vista preliminar de la lista de personas por Sindicato">
					<form:Event action="VP" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl7" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="vuelve al menu principal">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
