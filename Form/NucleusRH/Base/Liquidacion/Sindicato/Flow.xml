<flow:flow xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Liquidacion.Conceptos">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Conceptos"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="DDONuevo"/>
		<doc:define name="QRY"/>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					c.OI_CONCEPTO
				FROM
					LIQ14_CONCEPTOS as c
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_CONCEPTO" name="value"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_CONCEPTO" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:comment>
		Esto es lo que pasa cuando arranca el Flow
	</flow:comment>
	<flow:comment>
		Que se habra el formulario en un determinado modo, con un determinado documento, y se especifica qu#orlulario abrir
	</flow:comment>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Sindicato.Form"/>
		</flow:action>
	</flow:main>
	<flow:comment>
		Declaro los formularios con sus respectivos modos
	</flow:comment>
	<flow:comment>
		Se declaran las acciones, ya sean de link o los botones
	</flow:comment>
	<flow:comment>
		El siguiente c#o sirve si tengo un bot#GREGAR
	</flow:comment>
	<flow:form doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Sindicato.Form" mode="NEW">
		<flow:action name="ADD">
			<flow:close-form/>
			<doc:new-object doc="DDO" class="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO"/>
			<flow:open-form doc-path="#DDO:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Concepto.Concepto.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
