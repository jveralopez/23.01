<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" name="cerrar" doc="SOURCE">
	<form:Title>
		<form:Label name="lblTitulo" label="Liquidaciones de Haberes - Cerrar" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:FKInput nvalue="#FILTER_DATA_CERRAR:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" required="1" enabled="" xsize="15" length="30" name="oi_liquidacion" visible="EDIT">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_INICIALIZADA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" visible="NEW|EDIT" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Combo nvalue="#SOURCE:oi_empresa/@value" visible="SHOW" enabled="0" required="0" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" label="Empresa" name="empresa"/>
		<form:FKInput visible="SHOW" name="oi_liquidacion" nvalue="#SOURCE:@id" enabled="0" label="Liquidaci&#243;n" required="0" xsize="15" length="30">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION-EMPRESA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
		</form:FKInput>
		<form:Blank name="b1" height="20px"/>
		<form:VGroup label="Comprobar Cambios" name="V1">
			<form:CheckBox nvalue="#CIERRE:@l_compConcChange" name="l_compConcChange" label="Conceptos/Variables/Codificadoras"/>
			<form:CheckBox nvalue="#CIERRE:@l_compEmpChange" name="l_compEmpChange" label="Empresa/Liquidacion"/>
			<form:CheckBox nvalue="#CIERRE:@l_compPerChange" name="l_compPerChange" label="Personas/Legajos"/>
		</form:VGroup>
		<form:Blank name="b3" height="20px"/>
		<form:VGroup name="V2" label="Acciones">
			<form:CheckBox nvalue="#CIERRE:@l_delPerNoLiq" name="l_delPerNoLiq" label="Eliminar Legajos sin Recibo"/>
			<form:CheckBox nvalue="#CIERRE:@l_CerrarLiquidacion" name="l_CerrarLiquidacion" label="Cerrar Liquidacion">
				<form:Event name="OnClick" action="RefreshButtons" runat="client"/>
			</form:CheckBox>
			<form:CheckBox nvalue="#CIERRE:@l_ActAcumuladores" name="l_ActAcumuladores" label="Actualizar Acumuladores"/>
		</form:VGroup>
		<form:Hidden nvalue="#DDO:oi_tipo_liq/@value" name="oi_tipo_liq"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button mess="&#191;Est&#225; seguro que desea Cerrar la Liquidaci&#243;n?" startvalidate="1" enabled="" visible="" name="btnEjecutar" label="Ejecutar" img="ok" note="" descrip="">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="Volver">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function RefreshButtons()
{
	CtrlEnabled("l_ActAcumuladores",Ctrl("l_CerrarLiquidacion").GetXValue()=="1"?true:false);

	if(Ctrl("oi_tipo_liq").GetXValue() == "7" &amp;&amp; CtrlExists("l_ActAcumuladores"))	
	{
		CtrlEnabled("l_ActAcumuladores",false);
		
		//Ctrl("l_ActAcumuladores").SetXValue("0");
		
	} 
}
	</form:Scripts>
	<form:Event action="RefreshButtons" name="OnLoad" runat="client"/>
</form:Form>
