<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Liquidacion.Legajo.filter.form" doc="source" name="NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.BUSCAR.form" default_mode="SHOW">
	<form:Help/>
	<form:Title>
		<form:Label label="Administrar Liquidaciones - Procesar" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left">
					<form:ComboBox nvalue="#source:@oi_empresa" enabled="0" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" name="empresa"/>
					<form:ComboBox nvalue="#source:@oi_liquidacion" enabled="0" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1" label="Liquidaci&#243;n" name="liquidacion"/>
					<form:SButton name="img_ojo" img="eye.gif"/>
				</form:Column>
			</form:Columns>
			<form:Hidden name="cb_confidenciales" nvalue="#source:@cb_confidenciales"/>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button visible="0" label="Filtrar" img="ok" name="btnFILTER" descrip="Consultar los Legajos seleccionados" note="Consultar los Legajos seleccionados"/>
				<form:Button visible="0" img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial"/>
				<form:Button label="Ejecutar" img="ok" name="ACCEPT">
					<form:Event action="Ejecutar" name="onclick" runat="client"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="CANCEL">
					<form:Event name="onclick" action="BACK" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{  	
 	FillArray(100);
Ctrl("main").DoEvent("ACCEPT");
}

function Ejecutar()
{
if (arrFILTER.length==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}

Guardar();
}

function ONLOAD_custom()
{
Ctrl("where").SetXValue("LEG.oi_personal_emp in (SELECT LIQ25_PERSONAL_LIQ.oi_personal_emp FROM LIQ25_PERSONAL_LIQ WHERE LIQ25_PERSONAL_LIQ.oi_liquidacion = "+Ctrl("liquidacion").GetXValue()+")");     

if(!Ctrl('img_ojo').GetEnabled())
{
	//cargar solo los legajos que son no confidenciales
	Ctrl('cb_confidenciales').SetXValue('NC');
}   
else
{
	Ctrl('cb_confidenciales').SetXValue('T');
}
}
	</form:Scripts>
	<form:Resources/>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
</form:Form>
