<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.parent.guia.flow" name="NucleusRH.Base.Liquidacion.Liquidacion.EJECUCION.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.EJECUCION"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.EJECUCION.guia.autoform"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT 
				count(LIQ25_PERSONAL_LIQ.oi_personal_liq)  as cant
			FROM
				LIQ25_PERSONAL_LIQ				
	    WHERE
	      LIQ25_PERSONAL_LIQ.oi_liquidacion={#SOURCE:helper-mess/@ID} 
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="#SOURCE:helper-mess/@ID" name="id"/>
					<qry:attribute value="#SOURCE:helper-mess/@ID" name="value"/>
					<qry:attribute value="$r/@cant" name="code"/>
					<qry:attribute value="$r/@cant" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
