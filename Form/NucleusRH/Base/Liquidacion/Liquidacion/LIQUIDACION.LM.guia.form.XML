<form:Form extends="Nomad.simple.guia.form" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" label="Seleccion de Liquidaciones" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Grid allowdel="0" allownew="0" paging="1" rows="8" doc="SOURCE" idvalue="#SOURCE:@id" nvalue="#SOURCE:" name="GRID">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:CheckBox required="0" enabled="" label="" nvalue="#SOURCE:@check" name="seleccionados"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col2">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="15" length="30" label="C&#243;digode Liquidaci&#243;n" nvalue="#SOURCE:@code" name="c_liquidacion"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col3">
					<form:TextBox required="0" enabled="NEW|EDIT" descr="Titulo de la liquidacion" ysize="1" xsize="40" length="100" label="T&#237;tulo de la Liquidaci&#243;n" nvalue="#SOURCE:@text" name="d_titulo"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col4">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="15" length="30" label="C&#243;digode Empresa" nvalue="#SOURCE:@codEmpresa" name="c_empresa"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col5">
					<form:TextBox required="0" enabled="NEW|EDIT" descr="Titulo de la liquidacion" ysize="1" xsize="40" length="100" label="Descripci&#237;n de la Empresa" nvalue="#SOURCE:@dscEmpresa" name="d_empresa"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button note="Aceptar" descrip="Aceptar" img="OK" label="Aceptar" name="ACCEPT">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
