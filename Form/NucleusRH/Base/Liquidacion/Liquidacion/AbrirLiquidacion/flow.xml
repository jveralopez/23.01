<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.Liquidacion.flow">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Liquidacion"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_liquidacion="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="BATCHDOC">
			<VALUE batch-id=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.AbrirLiquidacion.filtro.form" mode="SHOW" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:group name="Ejecutar">
		<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.AbrirLiquidacion.filtro.form" name="NucleusRH.Base.Liquidacion.Liquidacion.AbrirLiquidacion.filtro.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
			<flow:action name="ACCEPT">
				<flow:log text="KKSOURCE" text-path="#SOURCE:"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO" method="RemoteReopenLiq" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="7">
					<flow:param type="Nomad.NSystem.String" name="oi_liquidacion" mode="in" attr-path="#SOURCE:@oi_liquidacion"/>
					<flow:param type="Nomad.NSystem.Proxy.NomadXML" name="oi_per_emp_list" mode="in" doc-path="#SOURCE:"/>
				</flow:exec-method>
				<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
			<flow:action name="BACK">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form next-action="BACK"/>
		</flow:action>
	</flow:form>
</flow:flow>
