<form:Form xmlns:form="nomad_engine.form" name="Migracion de grupos de variables" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title>
		<form:Label label="Migracion de grupos de variables" name="lblTitulo" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bk1"/>
		<form:Columns name="cols">
			<form:Column name="Column10" width="60%">
				<form:File filename="GruposVariables.dat" descrip="Selecciona el archivo a subir" name="file" label="Archivo" note="" required="1" class="INTERFACES" source="1">
					<form:SButtons>
						<form:SButton descrip="Selecciona el archivo a subir" enabled="" visible="" name="sbHelper" label="Buscar archivo" img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button mess="&#191;Est&#225; seguro que desea Migrar los grupos de variables?" startvalidate="1" enabled="" visible="" name="btnEjecutar" label="Ejecutar" img="ok" note="" descrip="">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="Cancelar">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
