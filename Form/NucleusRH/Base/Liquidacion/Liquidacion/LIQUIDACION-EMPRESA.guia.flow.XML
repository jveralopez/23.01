<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION-EMPRESA.guia" extends="Nomad.simple.guia.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Bancos.BANCO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION-EMPRESA.guia.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
SELECT 
	t.oi_liquidacion as ID, 
	t.c_liquidacion as CODE, 
	t.d_titulo as TEXT, 
	t.oi_empresa as PID 
FROM 
	LIQ19_LIQUIDACION as t 
WHERE 
	t.oi_liquidacion={#SOURCE:helper-mess/@ID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@INTERFACE" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
SELECT 
	t.oi_liquidacion as ID, 
	t.c_liquidacion as CODE, 
	t.d_titulo as TEXT, 
	t.oi_empresa as PID 
FROM 
	LIQ19_LIQUIDACION as t 
WHERE 
	t.c_liquidacion={substring_before(#INDOC:@CODE,\'-\')} and 
	t.oi_empresa={#INDOC:@OI_EMPRESA} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
					<qry:attribute value="''" name="SUB_SEARCH"/>
					<qry:attribute value="''" name="PARENTID"/>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@INTERFACE" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
SELECT 
t.oi_liquidacion as ID, 
t.c_liquidacion as CODE, 
t.d_titulo as TEXT, 
t.oi_empresa as PID,
SEC.policy 
FROM 
LIQ19_LIQUIDACION as t,
NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\') as SEC 					 
JOIN
t.oi_liquidacion LEFT OUTER SEC.id
WHERE 
t.oi_empresa={#INDOC:@OI_EMPRESA} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
						<qry:attribute value="$r/@INTERFACE" name="interface"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION-EMPRESA.guia.form" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION-EMPRESA.guia.form:SHOW" extends="nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW"/>
</flow:flow>
