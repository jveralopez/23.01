<flow:flow default_action="SHOW" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq"/>
	<flow:main doc="SOURCE">
		<flow:action name="C2X">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="C2X"/>
			<flow:log text-path="#RS:" text="javierC2X"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form doc-path="#RS:" parent-doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq.guia.form"/>
		</flow:action>
		<flow:action name="X2C">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="X2C"/>
			<flow:log text-path="#RS:" text="javierX2C"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.Int" value="#SOURCE:helper-mess/@liq" name="liq"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
			SELECT
        per02.OI_PERSONAL_EMP as ID,
        per02.E_NUMERO_LEGAJO as CODE,
        per01.D_APE_Y_NOM as TEXT
      FROM
        PER02_PERSONAL_EMP as per02,
        PER01_PERSONAL as per01,
        liq07_personal as liq07
			WHERE
				liq07.oi_personal_emp = per02.oi_personal_emp
			AND				
				per02.OI_PERSONAL = per01.OI_PERSONAL 
			AND
				per02.OI_PERSONAL_EMP={#SOURCE:helper-mess/@ID}
     ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess CODE=&quot;1&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@liq" name="liq"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in SQL('
			SELECT
				per02.OI_PERSONAL_EMP as IDD,
				per02.E_NUMERO_LEGAJO,
				per01.D_APE_Y_NOM
			FROM
        PER02_PERSONAL_EMP as per02,
        PER01_PERSONAL as per01,
        liq07_personal as liq07
			WHERE
				liq07.oi_personal_emp = per02.oi_personal_emp
			AND 
				per02.OI_PERSONAL = per01.OI_PERSONAL
      AND
      	per02.E_NUMERO_LEGAJO={#SOURCE:helper-mess/@code}  
     ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot;/&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
		SELECT
			per02.OI_PERSONAL_EMP as IDD,
			per02.E_NUMERO_LEGAJO,
			per01.D_APE_Y_NOM 
    FROM
    	PER02_PERSONAL_EMP as per02,
    	PER01_PERSONAL as per01,
    	liq07_personal as liq07
		WHERE
			liq07.oi_personal_emp = per02.oi_personal_emp
		AND 
    	per02.OI_PERSONAL = per01.OI_PERSONAL
  ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@liq" name="liq"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq.guia.form">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:exit-flow return-path="#RS:ROW[@id={#FORM:ctrl[@id='GRID']/@selectedRow}]"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
