<form:Form xmlns:form="nomad_engine.form" name="MigracionValoresDeVariables" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title>
		<form:Label label="Migracion de Valores de Variables" name="lblTitulo" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bk1"/>
		<form:Columns name="cols">
			<form:Column name="Column10" width="60%">
				<form:ComboBox required="1" label="Empresa" name="oi_empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" mode="QRY">
					<options/>
				</form:ComboBox>
				<form:DateTime name="e_periodo_desde" nvalue="#source:@e_periodo_desde" label="Per&#237;odo Desde" pattern="YYYYMM" required="1" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="e_periodo_hasta" nvalue="#source:@e_periodo_hasta" label="Per&#237;odo Hasta" pattern="YYYYMM" required="1" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox mode="QRY" required="0" prev="oi_empresa" label="Liquidacion" name="oi_liquidacion" nvalue="#source:@oi_liquidacion" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO">
					<options/>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="0" enabled="" visible="" name="btnEjecutar" label="Ejecutar" img="ok" note="" descrip="">
					<form:Event action="Aceptar" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="Cancelar">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Aceptar()
{
	var f_desde =Ctrl('e_periodo_desde').GetXValue();
	var f_hasta = Ctrl('e_periodo_hasta').GetXValue();
	
	if(f_desde &gt; f_hasta)                                      
	{
		alert('el periodo desde debe ser menor al periodo hasta');
		return false;
	}          
	
	Ctrl('btnEjecutar').DoEvent("ACCEPT");
}
	</form:Scripts>
</form:Form>
