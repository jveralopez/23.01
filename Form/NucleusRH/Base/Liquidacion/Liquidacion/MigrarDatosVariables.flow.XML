<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.MigrarDatosVariables.flow">
	<flow:info label="NucleusRH.Base.Liquidacion.MigrarDatosVariables.flow"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Liquidacion.Liquidacion.MigrarDatosVariables.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="BATCHDOC">
			<VALUE batch-id=""/>
		</doc:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.MigrarDatosVariables.form" name="NucleusRH.Base.Liquidacion.Liquidacion.MigrarDatosVariables.form:SHOW" parent-doc="PARENT" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:exec-method method="MigrarDatosVariables" class="NucleusRH.Base.Liquidacion.Grupos.GRUPO" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9">
				<flow:param attr-path="#SOURCE:@oi_liquidacion" type="Nomad.NSystem.String" mode="in" name="oi_liquidacion"/>
				<flow:param attr-path="#SOURCE:@e_periodo_desde" type="Nomad.NSystem.Int" mode="in" name="e_periodo_desde"/>
				<flow:param attr-path="#SOURCE:@e_periodo_hasta" type="Nomad.NSystem.Int" name="e_periodo_hasta" mode="in"/>
			</flow:exec-method>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
