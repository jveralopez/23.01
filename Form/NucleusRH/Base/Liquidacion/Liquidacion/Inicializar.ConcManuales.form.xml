<form:Form name="concmanuales" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:Label name="lblTitulo" label="Liquidaciones de Haberes - Inicializar - Conceptos Variables" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl004d" width="100%" visible=""/>
		<form:RowAligner name="RADD" columns="1">
			<form:Row name="Rdliq">
				<form:TextBox name="txtLiq" nvalue="#source:@direcion" label="Liquidacion" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="0" visible="" required="0"/>
			</form:Row>
			<form:Row name="RdLegajo">
				<form:TextBox name="txtPer" nvalue="#source:@direcion" label="Personal" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="0" visible="" required="0"/>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="bldd" width="100%" visible=""/>
		<form:RowAligner name="RAbuscar" columns="3">
			<form:Row name="Rbuscar">
				<form:Blank name="bl04" width="100%" visible=""/>
				<form:Button visible="EDIT|NEW|SHOW" note="" descrip="" img="search" label="Buscar" name="buscar">
					<form:Event action="BUSCAR_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:TextBox name="txtBuscar" nvalue="#source:@direcion" label="" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW|SHOW" visible="" required="0"/>
			</form:Row>
		</form:RowAligner>
		<form:Grid name="grdDatos" note="" descrip="" rows="5" allownew="1" allowdel="1">
			<form:SButtons>
				<form:SButton enabled="" visible="" name="sbuscar" img="search" note="" descrip="Abre un formulario para selleccionar una determinada cantidad"/>
				<form:SButton enabled="" visible="" name="sbuVaciar" img="eliminate" note="" descrip="Elimina todos los registro"/>
			</form:SButtons>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:CheckBox name="chkActivo" nvalue="#persona/@activo" label="" note="" descrip=""/>
				</form:GColumn>
				<form:GColumn allow_order="1">
					<form:FKInput required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Concepto" nvalue="#source:oi_concepto/@value" name="oi_concepto">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn allow_order="1">
					<form:TextBox name="txtUnidad" nvalue="#source:@direcion" label="Unidad" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="0" visible="" required="0"/>
				</form:GColumn>
				<form:GColumn allow_order="1">
					<form:TextBox name="txtCantidad" nvalue="#source:@direcion" label="Cantidad" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW|SHOW" visible="" required="0"/>
				</form:GColumn>
				<form:GColumn allow_order="1">
					<form:TextBox name="txtValor" nvalue="#source:@direcion" label="Valor" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW|SHOW" visible="" required="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="1">
			<form:Row name="filaBotones">
				<form:Button visible="EDIT|NEW|SHOW" note="" descrip="" img="back" label="Volver" name="Volver">
					<form:Event action="VOLVER_CLICK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
