<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.Inicializar.LegajoLiq"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="DebugManual" doc="DATA"/>
			<flow:open-form parent-doc-path="#DATA:" doc-path="#DATA:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.Debug.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="DATA">
			<DATA/>
		</doc:define>
		<doc:define name="BATCHDOC">
			<VALUE batch-id=""/>
		</doc:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Liquidacion.Liquidacion.Debug.form:SHOW" parent-doc="PARENT" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.Debug.form">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:save-user-data name="DebugManual" doc-path="#SOURCE:"/>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO" method="RemoteDebug" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" name="oi_per_emp_list" mode="in" doc-path="#SOURCE:"/>
			</flow:exec-method>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
