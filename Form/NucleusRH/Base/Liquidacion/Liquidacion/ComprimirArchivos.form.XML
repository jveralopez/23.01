<form:Form xmlns:form="nomad_engine.form" name="Comprimir Archivos" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title>
		<form:Label label="Comprimir / Extraer Archivos de detalles de recibo" name="lblTitulo" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank width="20px" name="f1"/>
		<form:Columns name="COLS">
			<form:Column name="Col1" separation="2" align="center" valign="top">
				<form:DateTime name="e_periodo" nvalue="#source:@e_periodo" label="Per&#237;odo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button img="newlist" label="Descomprimir" name="btnDescomprimir" startvalidate="0" enabled="" visible="" note="" descrip="">
					<form:Event action="DESC" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="lock" label="Comprimir" name="btnComprimir" startvalidate="0" enabled="" visible="" note="" descrip="">
					<form:Event action="COMP" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="Cancelar">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
