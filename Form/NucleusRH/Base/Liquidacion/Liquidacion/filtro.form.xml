<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="filtro" doc="source">
	<form:Title>
		<form:Label style="S3 LCol_w" visible="" label="Liquidaciones de Haberes" name="lblTitulo"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl3"/>
		<form:Columns name="cols001">
			<form:Column name="col001" separation="2" align="center" valign="top">
				<form:Grid proto="&lt;EMPRESA/&gt;" label="Empresas" idvalue="#SOURCE:@id" nvalue="#source:EMPRESAS" width="400px" doc="SOURCE" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdDatosEmp">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:ComboBox name="oi_empresa" nvalue="#SOURCE:@id" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa">
								<form:Event action="CHANGE" name="onchange" runat="client"/>
							</form:ComboBox>
						</form:GColumn>
					</form:GColumns>
					<form:Event action="ELIMINAR" name="onrowadded" runat="client"/>
					<form:Event action="ELIMINAR" name="onrowdeleted" runat="client"/>
				</form:Grid>
				<form:Blank width="20px" name="ppblank"/>
				<form:ComboBox nvalue="#FILTERDATA:@c_estado" xsize="40" mode="OPT" required="0" label="Estado" name="c_estado">
					<options>
						<option text="Abierta" value="A"/>
						<option text="Inicializada" value="I"/>
						<option text="Cerrada" value="C"/>
					</options>
				</form:ComboBox>
				<form:ComboBox label="Tipo de Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ.INFO" xsize="40" mode="QRY" required="0" nvalue="#FILTERDATA:@oi_tipo_liq" name="oi_tipo_liq"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl33"/>
		<form:RowAligner name="RAFiltros1">
			<form:Row name="Rcampo2">
				<form:Grid idvalue="#SOURCE:@id" nvalue="#source:LIQUIDACIONES" proto="&lt;LIQUIDACION/&gt;" width="300px" doc="SOURCE" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdDatosLiq">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:ComboBox queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" name="oi_liquidacion" nvalue="#SOURCE:@id" xsize="40" mode="QRY" required="0" label="Liquidaci&#243;n"/>
						</form:GColumn>
					</form:GColumns>
					<form:Event action="AGREGAR_LIQ" name="onrowadded" runat="client"/>
				</form:Grid>
				<form:Blank width="20px" name="ppblank"/>
				<form:Grid idvalue="#SOURCE:@id" doc="SOURCE" nvalue="#source:PERIODOS" proto="&lt;PERIODO/&gt;" width="200px" paging="1" allowdelall="1" allowhelper="0" allowdel="1" allownew="1" rows="3" descrip="" note="" name="grdDatosPeriodo">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:DateTime nvalue="#SOURCE:@id" name="periodo" label="Per&#237;odo" mask="dd/mm/yyyy" required="0" pattern="YYYYMM">
								<form:SButtons>
									<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:DateTime>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Hidden nvalue="#source:@id_emp" name="id_emp"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="botones">
			<form:Row name="filaBotones">
				<form:Button startvalidate="1" descrip="Filtrar" note="" img="ok" label="Filtrar" name="btnEjecutar" visible="" enabled="">
					<form:Event action="FILTER" name="onclick" runat="client"/>
					<form:Event runat="server" name="FILTER" action="FILTER"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl7"/>
				<form:Button descrip="Agrega un nuevo registro" note="" img="new" label="Agregar" name="btnAgregar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button descrip="vuelve al menu principal" note="" img="back" label="Volver" name="btnVolver" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FILTER()
{
if(Ctrl('grdDatosEmp').RowsCount() == 0)
{
alert('Debe seleccionar al menos una empresa');
}   
else
{
for(i = 0; i&lt;Ctrl('grdDatosEmp').RowsCount();i++)
{
	 if(Ctrl('grdDatosEmp').GetCellXValue('oi_empresa',i)=='')
	 {
	 	alert('Debe seleccionar al menos una empresa y no debe haber filas vacias');
	 	return false;
	 } 
}   

for(i = 0; i&lt;Ctrl('grdDatosLiq').RowsCount();i++)
{
	 if(Ctrl('grdDatosLiq').GetCellXValue('oi_liquidacion',i)=='')
	 {
	 	alert('No debe haber filas vacias de liquidacion');
	 	return false;
	 } 
}   

Ctrl('btnEjecutar').DoEvent('FILTER');
}
}            

function CHANGE()
{               
var valor = '';   
if(Ctrl('grdDatosEmp').RowsCount() != 0)
{         
	for(i=0;i&lt;Ctrl('grdDatosEmp').RowsCount();i++)
	{
	  	if(Ctrl('grdDatosEmp').GetCellXValue('oi_empresa',i)!='')
	  	{                    
	  	    var oi = Ctrl('grdDatosEmp').GetCellXValue('oi_empresa',i);
	  		valor += oi+','; 
	  	}
	}  
	 
	if(valor!='')
	{
	    var v = valor.substring(0, valor.length - 1)
		Ctrl('id_emp').SetXValue(v); 
	} 
 
                       
} 
}       

function AGREGAR_LIQ()
{             
	CHANGE();      
	if(Ctrl('id_emp').GetXValue()!= '')
	{
	    for(i=0;i&lt;Ctrl('grdDatosLiq').RowsCount();i++)
		{  
			var control = Ctrl('grdDatosLiq').GetCellControl("oi_liquidacion",i);
  			control.SetWhere("LIQ19_LIQUIDACION.oi_empresa in ("+Ctrl('id_emp').GetXValue()+")");    
		}
	}
	else
	{
		 Ctrl('grdDatosLiq').DelAllRows();
	}
	  
}               

function ELIMINAR()
{         
	Ctrl('id_emp').SetXValue('');
	Ctrl('grdDatosLiq').DelAllRows();
}        

function LOAD()
{
	CHANGE();
}
	</form:Scripts>
	<form:Event action="LOAD" name="onload" runat="client"/>
</form:Form>
