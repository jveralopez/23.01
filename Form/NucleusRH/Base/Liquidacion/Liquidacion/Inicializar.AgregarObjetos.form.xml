	<form:form xmlns:form="nomad_engine.form">

		<form:title>
			<form:label name="lblTitulo" label="Liquidaciones de Haberes - Inicializar - Agregar Objetos" visible="" style="M1 LCol_w"/>
		</form:title>

		<form:center >
			<form:Blank name="bl004d" width="100%" visible=""/>
			<form:RowAligner name="RAbuscar" columns="3">
		    <form:row name="Rbuscar">
		    	<form:Blank name="bl04" width="100%" visible=""/>
					<form:button visible="EDIT|NEW|SHOW" note="" descrip="" 
							img="search" label="Buscar" name="buscar">
							<form:event action="Cargar_Click" name="onclick" runat="server"/>  
					</form:button>			    	
					<form:TextBox name="txtBuscar" nvalue="#source:@direcion" 
					    label="" length="15" xsize="15" ysize="1" 
					    pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" 
					    enabled="EDIT|NEW|SHOW" visible="" required="0" >
					</form:TextBox>
				</form:row>
			</form:RowAligner>

			
			<form:Grid name="grdDatos"  
		    note="" descrip="" rows="5" allownew="1" allowdel="1">
		    <form:GColumns>
  				<form:GColumn allow_order="0">
						<form:CheckBox name="chkActivo" nvalue="#persona/@activo" 
						    label="" note="" descrip="">
						</form:CheckBox> 			    				
					</form:GColumn>
  				<form:GColumn allow_order="0">
						<form:TextBox name="txtLegajo" nvalue="#source:@direcion" 
						    label="Numero de Legajo" length="15" xsize="15" ysize="1" 
						    pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" 
						    enabled="EDIT|NEW|SHOW" visible="" required="0">
						</form:TextBox>
  				</form:GColumn>
  				<form:GColumn allow_order="0">
						<form:TextBox name="txtApe" nvalue="#source:@direcion" 
						    label="Apellido y Nombre" length="100" xsize="30" ysize="1" 
						    pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" 
						    enabled="EDIT|NEW|SHOW" visible="" required="0">
						</form:TextBox>
  				</form:GColumn>
  			</form:GColumns>
			</form:Grid>
		</form:center>

		<form:bottom>
			<form:RowAligner name="botones" columns="1">
			    <form:row name="filaBotones">
						<form:button visible="EDIT|NEW|SHOW" note="" descrip="" 
								img="back" label="Volver" name="Volver">
								<form:event action="VOLVER_CLICK" name="onclick" runat="server"/>
						</form:button>																														
			    </form:row>
			</form:RowAligner>
		</form:bottom>
	</form:form>	

