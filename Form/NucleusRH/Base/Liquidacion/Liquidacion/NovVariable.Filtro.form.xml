<form:Form name="novvarfiltro" xmlns:form="nomad_engine.form" doc="source">
	<form:Scripts>
		function validarEmpresa()
				{ 
					if (g_CTRLs[&apos;oi_empresa&apos;].GetCValue() == &quot;&quot;)
						{
							g_CTRLs[&apos;oi_liquidacion&apos;].SetEnabled(false);
							g_CTRLs[&apos;oi_liquidacion&apos;].SetCValue(&quot;&quot;);							
						} else
							{	
								g_CTRLs[&apos;oi_liquidacion&apos;].SetCValue(&quot;&quot;);
								g_CTRLs[&apos;oi_liquidacion&apos;].SetEnabled(true);
								
							}
				}
		
	
	</form:Scripts>
	<form:Title>
		<form:Label name="lblTitulo" label="Variables de Novedad de Personas de una Liquidacion" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:comment>
			<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="0" enabled="" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa">
				<form:Event action="validarEmpresa" name="onchange" runat="client"/>
			</form:Combo>
		</form:comment>
		<form:FKInput required="1" enabled="" xsize="15" length="30" label="Liquidaci&#243;n" nvalue="#source:@id" name="oi_liquidacion">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" visible="NEW|EDIT" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button enabled="" visible="" startvalidate="1" name="btnEjecutar" label="Ejecutar" img="ok" note="" descrip="">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl0" width="50%" visible=""/>
				<form:Button visible="" note="" descrip="" img="back" label="Volver" name="Volver">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>

