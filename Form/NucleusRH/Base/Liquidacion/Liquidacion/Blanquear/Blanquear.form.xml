	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:FKInput nvalue="#SOURCE:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" required="1" enabled="" xsize="15" length="30" name="oi_liquidacion" visible="EDIT">
			<form:STexts>
				<form:SText xsize="50"/>
