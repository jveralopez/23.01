<flow:flow name="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.flow" default_action="initialize" extends="Nomad.Base.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Liquidacion"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data doc="SOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.flow"/>
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.Blanquear.form" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="BLANQUEAR">
		<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.Blanquear.form" name="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.Blanquear.form:EDIT" doc="SOURCE" mode="EDIT">
			<flow:action name="ACCEPT">
				<flow:log text-path="#FORM:ctrl[@id='oi_liquidacion']/@xval" text="log_blanq3"/>
				<flow:log text-path="#SOURCE:" text="funente"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" out-attr-path="#SOURCE:@batch-id" priority="7" method="BlanquearTodo">
					<flow:param attr-path="#SOURCE:@oi_liquidacion" type="Nomad.NSystem.String" mode="in" name="poi_empresa"/>
				</flow:exec-method>
				<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
				<flow:save-user-data name="NucleusRH.Base.Liquidacion.Liquidacion.Blanquear.flow" doc-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="BACK">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
