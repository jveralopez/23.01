<form:Form doc="SOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" label="Seleccion de Personal Para una Liquidacion" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:FKInput required="0" enabled="0" xsize="15" length="30" label="Liquidaci&#243;n" nvalue="#SOURCE:@ID" name="PARENTID">
					<form:STexts>
						<form:SText xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:Blank name="blnk1"/>
			</form:Column>
		</form:Columns>
		<form:RowAligner name="ra1">
			<form:Row name="row1">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Row>
		</form:RowAligner>
		<form:Grid allowdel="0" allownew="0" paging="1" rows="8" doc="SOURCE" idvalue="#SOURCE:@id" nvalue="#SOURCE:ROWS" name="GRID">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:CheckBox required="0" enabled="" label="" nvalue="#SOURCE:@check" name="seleccionados"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col2">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="15" length="30" label="Numero de Legajo" nvalue="#SOURCE:@code" name="e_numero_legajo"/>
				</form:GColumn>
				<form:GColumn allow_order="1" name="col3">
					<form:TextBox required="0" enabled="NEW|EDIT" descr="Titulo de la liquidacion" ysize="1" xsize="40" length="100" label="Apellido y Nombre" nvalue="#SOURCE:@text" name="d_ape_y_nom"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}
	</form:Scripts>
</form:Form>
