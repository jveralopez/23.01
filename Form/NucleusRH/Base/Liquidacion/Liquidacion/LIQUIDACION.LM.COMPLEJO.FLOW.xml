<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Liquidacion" default_action="HELP">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Multiple"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<flow:comment>
				<flow:log text="SOURCELOG" text-path="#SOURCE:"/>
			</flow:comment>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="PRELOAD"/>
			<flow:comment>
				<flow:log text="rslog" text-path="#RS:"/>
			</flow:comment>
			<flow:open-form form-class="NucleusRH.Base.LISTA_MULTIPLE_CODIGO_COMPLEJO.FORM" parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="ACEPTAR_QRY">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
					<qry:element name="rows">
						<qry:insert-select name="QRY"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="QRY" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE/HIJOS/HIJO[@check = 1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute name="oi_liquidacion" value="$r/@ID" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_padre" value="#SOURCE:DATOS/@oi_padre" type="Nomad.NSystem.Int"/>
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
					<qry:element name="PADRES">
						<qry:insert-select name="QRY_PADRE"/>
					</qry:element>
					<qry:element name="FILTRO2">
						<qry:element name="ROWS">
							<qry:insert-select name="QRY_PADRES_ELEGIDA"/>
						</qry:element>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PADRE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE
				</qry:xquery>
				<qry:out>
					<qry:element name="PADRE">
						<qry:attribute name="oi_padre" value="$r/@oi_padre" type="Nomad.NSystem.Int"/>
						<qry:element name="HIJOS">
							<qry:insert-select doc-path="..[@oi_padre != #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_SI"/>
							<qry:insert-select doc-path="..[@oi_padre != #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_NO"/>
							<qry:insert-select doc-path="..[@oi_padre = #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_SI_ELEGIDA"/>
							<qry:insert-select doc-path="..[@oi_padre = #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_NO_ELEGIDA"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_PADRES_ELEGIDA">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #FILTRO:DATOS/@oi_padre]
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="QRY_HIJO_SI_FILTRO"/>
					<qry:insert-select doc-path="$r" name="QRY_HIJO_NO_FILTRO"/>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 1]
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 0]
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI_ELEGIDA" doc="SOURCE">
				<qry:xquery>
					for $r in 
              {%? (string(#FILTRO:DATOS/FILTRO2/ROWS/ROW/@ID)!='') 
              {% #FILTRO:DATOS/FILTRO2/ROWS/ROW[@check = 1] %}
              {% #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 1] %} %}
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO_ELEGIDA" doc="SOURCE">
				<qry:xquery>
					for $r in 
              {%? (string(#FILTRO:DATOS/FILTRO2/ROWS/ROW/@ID)!='') 
              {% #FILTRO:DATOS/FILTRO2/ROWS/ROW[@check = 0] %}
              {% #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 0] %} %}
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI_FILTRO" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 1]
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO_FILTRO" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 0]
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRELOAD">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_padre" value="'0'" type="Nomad.NSystem.Int"/>
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
					<qry:element name="PADRES">
						<qry:insert-select name="QRY_PADRES"/>
					</qry:element>
					<qry:element name="FILTRO2">
						<qry:element name="ROWS"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PADRES">
				<qry:xquery>
					for $r in SQL('
			SELECT
				org03.oi_empresa as oi_padre
			FROM
				org03_empresas as org03
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PADRE">
						<qry:attribute name="oi_padre" value="$r/@oi_padre" type="Nomad.NSystem.Int"/>
						<qry:element name="HIJOS">
							<qry:insert-select doc-path=".." name="QRY_HIJO_SI"/>
							<qry:insert-select doc-path=".." name="QRY_HIJO_NO"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT
				liq19.oi_liquidacion as ID,
				liq19.c_liquidacion as CODE,
				liq19.d_titulo as TEXT,
				SEC.policy 
			FROM
				liq19_liquidacion as liq19,   
  				NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\') as SEC  
			JOIN
				liq19.oi_liquidacion LEFT OUTER SEC.id   				
			WHERE
				liq19.OI_EMPRESA = {%= #SOURCE:@oi_padre%}  
				and liq19.oi_tipo_liq != 7
			{%? (string(#FILTRO:helper-mess/rows/row/@oi_liquidacion)!='') 
				{% AND liq19.oi_liquidacion in ({%=string(#FILTRO:helper-mess/rows/row/@oi_liquidacion) %}) %} 
				{% and 1 = 2 %}
			%}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT
				liq19.oi_liquidacion as ID,
				liq19.c_liquidacion as CODE,
				liq19.d_titulo as TEXT,
				SEC.policy
			FROM
				liq19_liquidacion as liq19,   
  				NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\') as SEC 
			JOIN
				liq19.oi_liquidacion LEFT OUTER SEC.id  				
			WHERE 
				liq19.OI_EMPRESA = {%= #SOURCE:@oi_padre%} 
				and liq19.oi_tipo_liq !=7
			{%? (string(#FILTRO:helper-mess/rows/row/@oi_liquidacion)!='') 
				{% AND liq19.oi_liquidacion not in 
					({%=string(#FILTRO:helper-mess/rows/row/@oi_liquidacion) %})
			 	%}
				{% AND 1 = 1 %}
			%}
 	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PARA_CARGAR"/>
		<qry:define name="HELP_PREV">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_padre" value="#SOURCE:DATOS/@oi_padre" type="Nomad.NSystem.Int"/>
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:"/>
					<qry:element name="PADRES">
						<qry:insert-select name="QRY_PADRES"/>
					</qry:element>
					<qry:element name="FILTRO2">
						<qry:element name="ROWS"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PADRES">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE
				</qry:xquery>
				<qry:out>
					<qry:element name="PADRE">
						<qry:attribute name="oi_padre" value="$r/@oi_padre" type="Nomad.NSystem.Int"/>
						<qry:element name="HIJOS">
							<qry:insert-select doc-path="..[@oi_padre != #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_SI"/>
							<qry:insert-select doc-path="..[@oi_padre != #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_NO"/>
							<qry:insert-select doc-path="..[@oi_padre = #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_SI_ELEGIDA"/>
							<qry:insert-select doc-path="..[@oi_padre = #FILTRO:DATOS/@oi_padre]" name="QRY_HIJO_NO_ELEGIDA"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 1]
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO" doc="SOURCE">
				<qry:xquery>
					for $r in #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 0]
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_SI_ELEGIDA" doc="SOURCE">
				<qry:xquery>
					for $r in 
              {%? (string(#FILTRO:DATOS/FILTRO2/ROWS/ROW/@ID)!='') 
              {% #FILTRO:DATOS/FILTRO2/ROWS/ROW[@check = 1] %}
              {% #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 1] %} %}
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_HIJO_NO_ELEGIDA" doc="SOURCE">
				<qry:xquery>
					for $r in 
              {%? (string(#FILTRO:DATOS/FILTRO2/ROWS/ROW/@ID)!='') 
              {% #FILTRO:DATOS/FILTRO2/ROWS/ROW[@check = 0] %}
              {% #FILTRO:DATOS/PADRES/PADRE[@oi_padre = #SOURCE:@oi_padre]/HIJOS/HIJO[@check = 0] %} %}
				</qry:xquery>
				<qry:out>
					<qry:element name="HIJO">
						<qry:attribute name="ID" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="CODE" value="$r/@CODE" type="Nomad.NSystem.Int"/>
						<qry:attribute name="TEXT" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.LISTA_MULTIPLE_CODIGO_COMPLEJO.FORM:SHOW" form-class="NucleusRH.Base.LISTA_MULTIPLE_CODIGO_COMPLEJO.FORM" parent-doc="INVAL" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="RELOAD_QUERY">
			<doc:load-qry output-doc="RS" input-doc-path="#RS:" qry="HELP_PREV"/>
			<doc:assign-mapping a-doc="FORM" b-doc="RS" dir-apply="a-&gt;b">
				<map docA="A" docB="B">
					<link A="#A:ctrl[@id='oi_padre']/@xval" B="#B:@oi_padre"/>
				</map>
			</doc:assign-mapping>
			<flow:comment>
				<flow:log text="rs111lodsasdadsag" text-path="#RS:"/>
			</flow:comment>
			<doc:load-qry qry="HELP" input-doc-path="#RS:" output-doc="RS"/>
			<flow:comment>
				<flow:log text="rs111log" text-path="#RS:"/>
			</flow:comment>
			<doc:assign-mapping a-doc="FORM" b-doc="RS" dir-apply="b-&gt;a">
				<map docA="A" docB="B">
					<link A="#A:ctrl[@id='oi_padre']/@xval" B="#B:@oi_padre"/>
				</map>
			</doc:assign-mapping>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:load-qry qry="HELP" input-doc-path="#RS:" output-doc="RS"/>
			<flow:comment/>
			<flow:log text="RSLOGLOG" text-path="#RS:"/>
			<doc:load-qry qry="ACEPTAR_QRY" input-doc-path="#RS:" output-doc="PARA_CARGAR"/>
			<flow:comment/>
			<flow:log text="parabajar" text-path="#PARA_CARGAR:"/>
			<flow:exit-flow return-path="#PARA_CARGAR:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
