<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.Liquidacion.DepurarEstado.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.DepurarEstado"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="DepurarEstado" doc="DATA"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.DepurarEstado.form" parent-doc-path="#DATA:" doc-path="#DATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="DATA">
			<DATA/>
		</doc:define>
		<doc:define name="BATCHDOC">
			<VALUE batch-id=""/>
		</doc:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.DepurarEstado.form" name="NucleusRH.Base.Liquidacion.Liquidacion.DepurarEstado.form:SHOW" parent-doc="PARENT" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:save-user-data name="DepurarEstado" doc-path="#SOURCE:"/>
			<flow:exec-method method="DepurarEstado" class="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9">
				<flow:param attr-path="#SOURCE:@oi_liquidacion" type="Nomad.NSystem.String" name="oi_liquidacion" mode="in"/>
			</flow:exec-method>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
