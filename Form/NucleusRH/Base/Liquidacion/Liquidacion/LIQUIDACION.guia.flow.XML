<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.autoflow" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION"/>
	<flow:main doc="SOURCE">
		<flow:action name="C2X">
			<flow:log text-path="#SOURCE:" text="logsource"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="C2X"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="HELP">
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<doc:load-qry qry="PRELOAD" output-doc="RS" input-doc-path="#SOURCE:"/>
			<flow:call-action action="OPEN-GUIA"/>
		</flow:action>
		<flow:action name="X2C">
			<flow:log text-path="#SOURCE:" text="logx2cchueca"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="X2C"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess text=&quot;&quot; id=&quot;69&quot; code=&quot;000129-082008&quot; /&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
		SELECT
			liq19.oi_liquidacion as ID,
			liq19.c_liquidacion as CODE,
			liq19.d_titulo as TEXT,
			liq19.oi_empresa as PID
		FROM
			LIQ19_LIQUIDACION as liq19
		WHERE
			liq19.oi_liquidacion={#SOURCE:helper-mess/@ID}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@PID" name="PID"/>
					<qry:insert-select doc-path="." name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in SQL('
		SELECT
			org03.oi_empresa as ID,
			org03.c_empresa as CODE,
			org03.d_empresa as TEXT
		FROM
			ORG03_EMPRESAS as org03
		WHERE
			org03.oi_empresa={#SOURCE:@PID}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE+'-'+#SOURCE:@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT+'-'+#SOURCE:@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess text=&quot;&quot; id=&quot;&quot; code=&quot;000129-A&quot; /&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
		SELECT
			org03.oi_empresa as ID,
			org03.c_empresa as CODE,
			org03.d_empresa as TEXT
		FROM
			ORG03_EMPRESAS as org03
		WHERE
			org03.c_empresa={substring_before(#INDOC:@CODE,\'-\')}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="substring_after(#INDOC:@CODE,'-')" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@ID" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:insert-select doc-path="$r" name="SECURITY_EMPRESA"/>
					<qry:insert-select doc-path="." name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_EMPRESA">
				<qry:xquery>
					for $r in SQL('
		select
			n.policy
		from
			NMD_SECURITY as n
		where
			n.class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\'
		and
			n.id={#PARAM:@id}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in SQL('
		SELECT
			liq19.oi_liquidacion as ID,
			liq19.c_liquidacion as CODE,
			liq19.d_titulo as TEXT
		FROM
			LIQ19_LIQUIDACION as liq19
		WHERE
			liq19.c_liquidacion={substring_before(#SOURCE:@SUB_SEARCH,\'-\')}
		AND
			liq19.oi_empresa={#SOURCE:@PARENTID}     
		and liq19.oi_tipo_liq != 7
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="SUB_SEARCH"/>
					<qry:attribute type="Nomad.NSystem.String" value="''" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					<qry:insert-select doc-path="$r" name="SECURITY_LIQUIDACION"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY_LIQUIDACION">
				<qry:xquery>
					for $r in SQL('
		select
			n.policy
		from
			NMD_SECURITY as n
		where
			n.class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\'
		and
			n.id={#PARAM:@id}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROW PARENTID=&quot;2&quot; id=&quot;&quot;&gt;&lt;ROWS /&gt;&lt;/ROW&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.Int" value="#SOURCE:ROW/@PARENTID" name="PARENTID"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:ROW/@CODE" name="CODE"/>
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:ROW/@TEXT" name="TEXT"/>
					<qry:insert-select doc-path="." name="RS2"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path=".." name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in SQL('
SELECT
	org03.oi_empresa as ID,
	org03.c_empresa as CODE,
	org03.d_empresa as TEXT
FROM
	ORG03_EMPRESAS as org03
WHERE
	org03.oi_empresa={#SOURCE:@PARENTID}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
SELECT 
	LIQ19_LIQUIDACION.oi_liquidacion, 
	LIQ19_LIQUIDACION.c_liquidacion, 
	LIQ19_LIQUIDACION.d_titulo,
	SEC.policy
FROM 
	LIQ19_LIQUIDACION,
	NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\') as SEC
JOIN
	LIQ19_LIQUIDACION.oi_liquidacion LEFT OUTER SEC.id
WHERE 
	LIQ19_LIQUIDACION.oi_empresa = {#SOURCE:@parentid}	
	and LIQ19_LIQUIDACION.oi_tipo_liq != 7		
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_liquidacion" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_liquidacion" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code1" value="$r/@c_liquidacion" type="Nomad.NSystem.String"/>
						<qry:attribute name="text1" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="#SOURCE:@CODE+'-'+$r/@c_liquidacion" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="#SOURCE:@TEXT+'-'+$r/@d_titulo" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess text=&quot;&quot; id=&quot;&quot; code=&quot;&quot; /&gt;" name="PRELOAD">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="HM"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS2"/>
					<qry:insert-select doc-path="." name="RS3"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path=".." name="RS1"/>
					</qry:element>
					<qry:attribute value="substring(#HM:@TEXT,1+string_length(./@TEXT))" name="FILTER"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS3">
				<qry:xquery>
					for $r in sql('SELECT t.oi_empresa as ID, t.c_empresa as CODE, t.d_empresa as TEXT, SEC.policy  FROM ORG03_EMPRESAS as t, NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC JOIN t.oi_empresa LEFT OUTER SEC.id  WHERE t.oi_empresa={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('select t.oi_empresa from LIQ19_LIQUIDACION as t where t.oi_liquidacion={#SOURCE:@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_empresa" name="PARENTID"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_liquidacion as ID, t.c_liquidacion as CODE, t.d_titulo as TEXT, t.oi_empresa as PID, SEC.policy  FROM LIQ19_LIQUIDACION as t, NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION\') as SEC JOIN t.oi_liquidacion LEFT OUTER SEC.id  WHERE  t.oi_empresa={#SOURCE:@PARENTID} and t.oi_tipo_liq != 7 ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code1"/>
						<qry:attribute value="$r/@TEXT" name="text1"/>
						<qry:attribute value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
						<qry:attribute value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.autoform:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.form"/>
</flow:flow>
