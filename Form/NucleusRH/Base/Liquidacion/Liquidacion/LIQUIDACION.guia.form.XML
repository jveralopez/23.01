<form:Form extends="Nomad.parent.guia.form" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" label="Selecci&#243;n de Liquidaciones" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo name="oi_empresa" nvalue="#SOURCE:@PARENTID" label="Empresa" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO">
					<form:Event name="onchange" action="RELOAD_QUERY" runat="server"/>
				</form:Combo>
			</form:Column>
		</form:Columns>
		<form:FKInput visible="NUNCA" required="1" name="PARENTID" nvalue="#SOURCE:@parentid" label="Parent Label" length="30" xsize="10" descr="Seleccion del padre generico" requiered="1">
			<form:STexts>
				<form:SText name="txt1" xsize="40"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="unknown">
				<helper-mess code="{PARENTID.CVal}" id="{PARENTID.XVal}" text="{PARENTID.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event name="onReceiveData" action="RELOAD_QUERY" runat="server"/>
		</form:FKInput>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button note="Aceptar" descrip="Aceptar" img="OK" label="Aceptar" name="ACCEPT">
					<form:Event action="ACCEPT" name="onclick" runat="client"/>
				</form:Button>
				<form:Button note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Agregar/Modificar/Eliminar elementos" label="Agregar" note="Editar" img="NEW" name="NEW">
					<form:Event action="EDIT" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
