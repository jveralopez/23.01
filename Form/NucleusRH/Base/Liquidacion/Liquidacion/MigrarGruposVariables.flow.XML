<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.MigrarGruposVariables.flow">
	<flow:info label="NucleusRH.Base.Liquidacion.MigrarGruposVariables.flow"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Liquidacion.Liquidacion.MigrarGruposVariables.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="BATCHDOC">
			<VALUE batch-id=""/>
		</doc:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Liquidacion.MigrarGruposVariables.form" name="NucleusRH.Base.Liquidacion.Liquidacion.MigrarGruposVariables.form:SHOW" parent-doc="PARENT" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:exec-method method="MigrarGruposVariables" class="NucleusRH.Base.Liquidacion.Grupos.GRUPO" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9"/>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
