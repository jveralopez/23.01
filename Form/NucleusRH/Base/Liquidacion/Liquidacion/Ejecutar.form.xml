<form:Form xmlns:form="nomad_engine.form" name="formnombre" doc="source">
	<form:Scripts>
		function validarEmpresa()
				{ 
					if (g_CTRLs['oi_empresa'].GetCValue() == "")
						{	
							g_CTRLs['oi_liquidacion'].SetEnabled(false);
							g_CTRLs['grdDatosPer'].SetEnabled(false);
							g_CTRLs['oi_liquidacion'].SetCValue("");							
							g_CTRLs['grdDatosPer'].DelAllRows();	
						} else
							{	
								g_CTRLs['oi_liquidacion'].SetCValue("");
								g_CTRLs['grdDatosPer'].DelAllRows();								
								g_CTRLs['oi_liquidacion'].SetEnabled(true);
								g_CTRLs['grdDatosPer'].SetEnabled(true);
								
							}
				}
				function validarLiquidacion()
				{ 
					if (g_CTRLs['oi_liquidacion'].GetCValue() == "")
						{
							g_CTRLs['grdDatosPer'].DelAllRows();
							g_CTRLs['grdDatosPer'].SetEnabled(false);
						} else
							{	
								g_CTRLs['grdDatosPer'].DelAllRows();								
								g_CTRLs['grdDatosPer'].SetEnabled(true);
								
							}
				}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label style="S3 LCol_w" visible="" label="Ejecutar Liquidacion" name="lblTitulo"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:FKInput label="Empresa - Liquidacion" name="oi_liquidacion" nvalue="#source:@id" length="30" xsize="15" visible="EDIT" enabled="NEW|EDIT" required="1">
			<form:Event runat="client" name="onchange" action="validarLiquidacion"/>
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_INICIALIZADA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" visible="NEW|EDIT" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Hidden visible="SHOW" nvalue="#source:@id" name="oi_liquidacion"/>
		<form:CheckBox nvalue="#source:@todos" name="todos" label="Todos" enabled="" required="0"/>
		<form:CheckBox name="excluirLegajos" nvalue="#source:@IncluirLegajos" label="Excluir" enabled="" required="0"/>
		<form:Blank visible="" width="100%" name="bla4"/>
		<form:Grid rows="10" doc="SOURCE" paging="1" allowdel="1" allownew="0" allowdelall="1" allowhelper="1" descrip="" note="" name="grdDatosPer">
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.Ejecutar.Legajo.LM.flow" action="HELP">
				<helper-mess liq="{oi_liquidacion.XValue}">
					{grdDatosPer.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn name="col1">
					<form:Link name="LINK" allowimg="1" img="link2" label=""/>
				</form:GColumn>
				<form:GColumn name="col2" allow_order="0">
					<form:FKInput name="oi_personal_emp" label="Legajo" length="30" xsize="15" enabled="0" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.Ejecutar.Legajo.LM.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess liq="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila6">
				<form:Button startvalidate="1" mess="Esta seguro que desea Ejecutar la Liquidacion?" descrip="" note="" img="ok" label="Ejecutar" name="btnEjecutar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button startvalidate="1" name="VISTAPREVIA" label="Vista Previa" img="search" descrip="" note="" visible="">
					<form:Event runat="server" name="onclick" action="VISTAPREVIA"/>
				</form:Button>
				<form:Button name="Volver" label="Volver" img="back" descrip="" note="" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
