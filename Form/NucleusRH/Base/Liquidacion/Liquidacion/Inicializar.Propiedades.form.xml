<form:Form name="prp" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:Label name="lblTitulo" label="Liquidaciones de Haberes - Inicializar - Propiedades" visible="" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner name="buttonlinks" columns="1">
			<form:Row name="row_top">
				<form:Button note="Ir al primer Registro" descrip="Primer Registro" label="|&lt;" name="ITERATOR_FIRST">
					<form:Event action="ITERATOR_FIRST_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Ir al Registro Anterior" descrip="Anterior Registro" label="&lt;&lt;" name="ITERATOR_PREV">
					<form:Event action="ITERATOR_PREV_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Ir al Registro Proximo" descrip="Proximo Registro" label="&gt;&gt;" name="ITERATOR_NEXT">
					<form:Event action="ITERATOR_NEXT_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button note="Ir al Ultimo Registro" descrip="Ultimo Registro" label="&gt;|" name="ITERATOR_LAST">
					<form:Event action="ITERATOR_LAST_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank width="100%" name="ITERATOR_BLANK"/>
			</form:Row>
		</form:RowAligner>
		<form:Columns name="columnas">
			<form:Column name="col1">
				<form:RowAligner name="datos" columns="1">
					<form:Row name="d1">
						<form:TextBox name="txtLegajo" nvalue="#source:@direcion" label="Numero de Legajo" length="15" xsize="15" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW" visible="" required="0"/>
					</form:Row>
					<form:Row name="d2">
						<form:Blank name="bl4d" width="100%" visible=""/>
					</form:Row>
					<form:Row name="d3">
						<form:TextBox name="txtPeriodo" nvalue="#source:@direcion" label="Apellido y Nombre" length="100" xsize="30" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW" visible="" required="0"/>
					</form:Row>
					<form:Row name="d4">
						<form:Blank name="bl544" width="100%" visible=""/>
					</form:Row>
					<form:Row name="d5">
						<form:TextBox name="txtRecibo" nvalue="#source:@direcion" label="Recibo" length="100" xsize="30" ysize="1" pattern="regularexp" mask="[A-Z][a-z]" note="" descrip="" enabled="EDIT|NEW" visible="" required="0">
							<form:SButtons>
								<form:SButton enabled="" visible="" name="sbuVaciar" img="ok" note="" descrip=""/>
							</form:SButtons>
						</form:TextBox>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="1">
			<form:Row name="filaBotones">
				<form:Button visible="EDIT|NEW|SHOW" note="" descrip="" img="back" label="Volver" name="Volver">
					<form:Event action="VOLVER_CLICK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>

