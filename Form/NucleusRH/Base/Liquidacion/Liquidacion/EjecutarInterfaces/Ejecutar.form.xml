<form:Form name="formnombre" doc="source" xmlns:form="nomad_engine.form">
	<form:Scripts>
		function validarEmpresa()
				{ 
					if (g_CTRLs['oi_empresa'].GetCValue() == "")
						{	
							g_CTRLs['oi_liquidacion'].SetEnabled(false);
							g_CTRLs['grdDatosPer'].SetEnabled(false);
							g_CTRLs['oi_liquidacion'].SetCValue("");							
							g_CTRLs['grdDatosPer'].DelAllRows();	
						} else
							{	
								g_CTRLs['oi_liquidacion'].SetCValue("");
								g_CTRLs['grdDatosPer'].DelAllRows();								
								g_CTRLs['oi_liquidacion'].SetEnabled(true);
								g_CTRLs['grdDatosPer'].SetEnabled(true);
								
							}
				}
				function validarLiquidacion()
				{ 
					if (g_CTRLs['oi_liquidacion'].GetCValue() == "")
						{
							g_CTRLs['grdDatosPer'].DelAllRows();
							g_CTRLs['grdDatosPer'].SetEnabled(false);
						} else
							{	
								g_CTRLs['grdDatosPer'].DelAllRows();								
								g_CTRLs['grdDatosPer'].SetEnabled(true);
								
							}
				}
	</form:Scripts>
	<form:Title>
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" style="S3 LCol_w" visible="" label="Ejecutar Conceptos Interfaces" name="lblTitulo"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Hidden visible="SHOW" nvalue="#source:@id" name="oi_liquidacion"/>
		<form:Grid proto="&lt;CONCEPTO/&gt;" idvalue="#SOURCEGRILLA:@id" nvalue="#DOC_EJECUTAR:CONCEPTOS" name="grdConcepto" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Conceptos.LM.guia.flow" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdConcepto.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput required="0" enabled="" xsize="10" length="30" label="Concepto" nvalue="#SOURCEGRILLA:@id" name="oi_concepto">
						<form:STexts>
							<form:SText xsize="40" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.CONCEPTO.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila6">
				<form:Button startvalidate="1" mess="Esta seguro que desea Ejecutar la Liquidacion?" descrip="" note="" img="ok" label="Ejecutar" name="btnEjecutar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="Volver" label="Volver" img="back" descrip="" note="" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
