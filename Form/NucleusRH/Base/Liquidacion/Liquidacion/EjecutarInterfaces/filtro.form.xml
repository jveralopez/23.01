<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="filtro" doc="source">
	<form:Title>
		<form:Label style="S3 LCol_w" visible="" label="Liquidaciones de Haberes" name="lblTitulo"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl3"/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl22"/>
		<form:RowAligner columns="1" name="RAFiltros">
			<form:Row name="Rcampo1">
				<form:Combo nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa" label="Empresa" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
			</form:Row>
			<form:Row name="Rcampo2">
				<form:Combo enabled="0" flow="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.c_estado.Combo.autoflow" nvalue="#FILTERDATA:@c_estado" action="COMBO" descrip="estado de la liquidacion" note="estado de la liquidacion" label="Estado" required="0" name="c_estado"/>
			</form:Row>
			<form:Row name="Rcampo3">
				<form:Combo flow="NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ.combo.autoflow" name="oi_tipo_liq" nvalue="#FILTERDATA:@oi_tipo_liq" descrip="Tipo de Liquidacion" label="Tipo de Liquidacion" enabled="" required="0" action="COMBO"/>
			</form:Row>
		</form:RowAligner>
		<form:Blank visible="" width="100%" name="bl32"/>
		<form:RowAligner name="RAFiltros1">
			<form:Row name="Rcampo2">
				<form:Grid idvalue="#SOURCE:@id" nvalue="#source:LIQUIDACIONES" proto="&lt;LIQUIDACION/&gt;" width="485px" doc="SOURCE" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="3" descrip="" note="" name="grdDatosLiq">
					<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_CERRADA.LM.COMPLEJO.FLOW" action="HELP">
						<helper-mess>
							{grdDatosLiq.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCE:@id" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="0">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_CERRADA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton name="SEARCH" label="Search" img="SEARCH">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Grid doc="SOURCE" idvalue="#SOURCE:@id" nvalue="#source:PERIODOS" proto="&lt;PERIODO/&gt;" width="200px" paging="1" allowdelall="1" allowhelper="0" allowdel="1" allownew="1" rows="3" descrip="" note="" name="grdDatosPeriodo">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:DateTime nvalue="#SOURCE:@id" name="periodo" label="Per&#237;odo" mask="dd/mm/yyyy" required="0" pattern="YYYYMM">
								<form:SButtons>
									<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:DateTime>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blank11"/>
		<form:Line width="100%" name="line_1"/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de Ordenaci&#243;n" name="lbl201"/>
		<form:RowAligner columns="2" name="RAcamposOrden">
			<form:Row name="RC1O">
				<form:Combo nvalue="#FILTERDATA:@ATRIB_ORDEN1" action="COMBO" flow="NucleusRH.Base.Liquidacion.Liquidacion.atribFiltro.enum" note="" label="" name="cboCampo1"/>
				<form:Combo nvalue="#FILTERDATA:@ORDEN1" action="COMBO" flow="NucleusRH.Base.Orden.enum" note="AscendenteDecendente" label="" name="cboOrdenCampo1"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="botones">
			<form:Row name="filaBotones">
				<form:Button descrip="Ejecutar la consulta" note="" img="play" label="Ejecutar" name="btnEjecutar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Blank visible="0" enabled="0" width="50%" name="bl7"/>
				<form:Button visible="0" enabled="0" descrip="Agrega un nuevo registro" note="" img="new" label="Agregar" name="btnAgregar">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button descrip="vuelve al menu principal" note="" img="back" label="Volver" name="btnVolver" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{
   Ctrl('c_estado').SetCValue("C");
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
