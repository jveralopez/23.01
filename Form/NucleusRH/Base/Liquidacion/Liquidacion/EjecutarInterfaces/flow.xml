<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="NucleusRH.Base.Liquidacion.Liquidacion.autoflow" name="NucleusRH.Base.Liquidacion.Liquidacion.flow">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Liquidacion"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_empresa="" c_estado="" oi_tipo_liq="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="" ATRIB_ORDEN4="" ORDEN4="">
				<LIQUIDACIONES/>
				<PERIODOS/>
			</FILTRO>
		</doc:define>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('select 
					t19.OI_LIQUIDACION, 
					t19.c_liquidacion, 
					t19.d_titulo,
					org03.c_empresa,
					t19.e_periodo 
					
					from 
					LIQ19_LIQUIDACION as t19, 
					ORG03_EMPRESAS as org03
					JOIN
					t19.OI_EMPRESA INNER org03.OI_EMPRESA 					
	        where 1=1 
	        {%? (#SOURCE:@oi_empresa!='')	{% and t19.oi_empresa= {%=#SOURCE:@oi_empresa %} %} {% %} %}
	        {%? (#SOURCE:@c_estado!='')	{% and t19.c_estado= {#SOURCE:@c_estado} %} {% %} %}
	        {%? (#SOURCE:@oi_tipo_liq!='')	{% and t19.oi_tipo_liq= {#SOURCE:@oi_tipo_liq} %} {% %} %}
	        {%? (string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id)!='') {% AND t19.oi_liquidacion in ({%=string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id) %}) %} {%  %} %}
	        {%? (string(#SOURCE:PERIODOS/PERIODO/@id)!='') {% AND t19.e_periodo in ({%=string(#SOURCE:PERIODOS/PERIODO/@id) %}) %} {%  %} %}
	        order by 
        	{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}        	
        	oi_liquidacion	ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_LIQUIDACION" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_LIQUIDACION" name="id"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_liquidacion" name="c_liquidacion"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_titulo" name="d_titulo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO oi_empresa=&quot;164&quot;&gt;&#13;&#10;&lt;LIQUIDACIONES/&gt;&#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT 
				t19.oi_liquidacion as oi_liquidacion, 
				t19.c_liquidacion as c_liquidacion, 
				t19.d_titulo as d_titulo, 
				t19.f_liquidacion as f_liquidacion, 
				t19.f_cierre as f_cierre,
				t19.e_quincena as e_quincena,
				t19.c_clase as c_clase,				
				t19.e_periodo as e_periodo, 
				t19.f_pago as f_pago,				
				t19.l_ajuste as l_ajuste, 
				t19.c_estado as c_estado, 
				t19.l_simulacion as l_simulacion, 
				t19.oi_empresa as oi_empresa, 
				t19.oi_forma_pago as oi_forma_pago, 
				t19.oi_tipo_liq as oi_tipo_liq 
			FROM
				LIQ19_LIQUIDACION as t19, 
				ORG03_EMPRESAS as org03
	    WHERE
	      t19.OI_EMPRESA = org03.OI_EMPRESA 
	      {%? 
	      	(#SOURCE:@oi_empresa!='')	
	       	{% and t19.oi_empresa= {%=#SOURCE:@oi_empresa %}%} 
	      	{% %} 
	      %}
	      {%? 
	        (#SOURCE:@c_estado!='')	
	        {% and t19.c_estado= {#SOURCE:@c_estado} %} 
	        {% %} 
	      %}
	      {%?
	      	(#SOURCE:@oi_tipo_liq!='')
	      	{% and t19.oi_tipo_liq= {#SOURCE:@oi_tipo_liq} %}
	      	{% %}
	      %}
	      {%? 
	        (string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id)!='') 
	        {% AND t19.oi_liquidacion in ({%=string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id) %}) %} 
	        {%  %} 
	      %}
	      {%? 
	        (string(#SOURCE:PERIODOS/PERIODO/@id)!='') 
	        {% AND t19.e_periodo in ({%=string(#SOURCE:PERIODOS/PERIODO/@id) %}) %} 
	        {%  %} 
	      %}           
	    ORDER BY
        {%? 
        	(#SOURCE:@ATRIB_ORDEN1!='') 
        	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%=#SOURCE:@ORDEN1 %}, %} 
        	{% %} 
        %} 
        oi_liquidacion	ASC
     ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_liquidacion" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_titulo" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_liquidacion" value="$r/@f_liquidacion" type="Nomad.NSystem.DateTime"/>
						<qry:attribute name="f_cierre" value="$r/@f_cierre" type="Nomad.NSystem.DateTime"/>
						<qry:attribute name="e_quincena" value="$r/@e_quincena" type="Nomad.NSystem.Int"/>
						<qry:attribute name="e_periodo" value="$r/@e_periodo" type="Nomad.NSystem.Int"/>
						<qry:attribute name="f_pago" value="$r/@f_pago" type="Nomad.NSystem.DateTime"/>
						<qry:attribute name="c_estado" value="$r/@c_estado" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_clase" value="$r/@c_clase" type="Nomad.NSystem.String"/>
						<qry:attribute name="l_simulacion" value="$r/@l_simulacion" type="Nomad.NSystem.Int"/>
						<qry:attribute name="l_ajuste" value="$r/@l_ajuste" type="Nomad.NSystem.Int"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
						<qry:attribute name="oi_tipo_liq" value="$r/@oi_tipo_liq"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO oi_liquidacion=&quot;83&quot; todo=&quot;1&quot; excluir=&quot;0&quot;&gt;&#13;&#10;&#9;&lt;PERSONAS&gt;&#13;&#10;&#9;&#9;&lt;PERSONA id=&quot;24&quot; /&gt;&#13;&#10;&#9;&lt;/PERSONAS&gt;&#13;&#10;&lt;/FILTRO&gt;" name="QRY_EJECUTAR">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
		SELECT
    	liq25.OI_PERSONAL_emp,
    	per02.e_numero_legajo,
    	liq19.c_liquidacion,
    	org03.c_empresa 
    FROM
    	LIQ25_PERSONAL_LIQ as liq25,
    	per02_personal_emp as per02,
    	liq19_liquidacion as liq19,
    	org03_empresas as org03
    WHERE
      org03.OI_EMPRESA = liq19.OI_EMPRESA
    AND
      liq25.OI_LIQUIDACION = liq19.OI_LIQUIDACION
    AND
    	liq25.OI_PERSONAL_EMP = per02.OI_PERSONAL_EMP
    AND
			liq25.OI_LIQUIDACION = {#SOURCE:@oi_liquidacion}
		AND
      {%? (#SOURCE:@todo=1) 
      	{% 1=1 %}
        {%  
        	{%? (string(#SOURCE:PERSONAS/PERSONA/@id)!='')
        		{% liq25.oi_personal_emp 
        		{%? (#SOURCE:@excluir=1)
        			{% not %}
        			{%  %}
        		%} 
        		in ({%=string(#SOURCE:PERSONAS/PERSONA/@id) %})
        		%}
        	{% 1=2 %}
        	%}
        %}
      %} 
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_emp" name="oi_personal_emp"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@E_NUMERO_LEGAJO" name="e_numero_legajo"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@C_LIQUIDACION" name="c_liquidacion"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@C_EMPRESA" name="c_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DOC_EJECUTAR">
			<FILTRO oi_liquidacion="" todo="" excluir="">
				<CONCEPTOS/>
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="DOC_OUT_EJECUTAR"/>
		<qry:define declare="&lt;FILTRO oi_liquidacion=&quot;71&quot; todo=&quot;1&quot; excluir=&quot;&quot; todos=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&#9;&lt;CONCEPTOS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;CONCEPTO id=&quot;50&quot; /&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;CONCEPTO id=&quot;4999000&quot; /&gt;&#13;&#10;&#9;&#9;&#9;&#9;&#9;&#9;&lt;CONCEPTO id=&quot;5600000&quot; /&gt;&#13;&#10;&#9;&#9;&#9;&lt;/CONCEPTOS&gt;&#13;&#10;&#9;&#9;&#9;&lt;PERSONAS /&gt;&#13;&#10;&lt;/FILTRO&gt;" name="obtenerDatos">
			<qry:main doc="SOURCE">
				<qry:element name="FILTRO">
					<qry:attribute value="#SOURCE:FILTRO/@oi_liquidacion" name="oi_liquidacion"/>
					<qry:attribute value="#SOURCE:FILTRO/@todo" name="todo"/>
					<qry:insert-select name="obtenerLiquidacionDDO" doc-path="#SOURCE:FILTRO"/>
					<qry:append-doc name="DOCUM" doc-path="."/>
					<qry:element name="CONCEPTOS">
						<qry:insert-select name="obtenerConceptos" doc-path="#SOURCE:FILTRO"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="obtenerLiquidacionDDO">
				<qry:xquery>
					for $r in SQL('
SELECT 
	l.oi_liquidacion_ddo, 
	x.oi_cab_conc_ddo
FROM 
	LIQ19_EJECUCIONES AS l, 
	LIQ99_LIQUIDACION AS x
JOIN
	l.oi_liquidacion_ddo INNER x.oi_liquidacion_ddo
WHERE
	x.c_estado=\'F\'
	AND
	l.oi_liquidacion = {#SOURCE:@oi_liquidacion}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_liquidacion_ddo" name="oi_liquidacion_ddo"/>
					<qry:attribute value="$r/@oi_cab_conc_ddo" name="oi_cab_conc_ddo"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="obtenerConceptos">
				<qry:xquery>
					for $r in #SOURCE:CONCEPTOS/CONCEPTO
				</qry:xquery>
				<qry:out>
					<qry:element name="CONCEPTO">
						<qry:attribute value="$r/@id" name="id"/>
						<qry:insert-select name="obtenerCadaConceptos" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="obtenerCadaConceptos">
				<qry:xquery>
					for $r in SQL('
SELECT 
	s.oi_concepto_ddo   
FROM 
	LIQ96_CONCEPTOS AS s, 
	LIQ14_CONCEPTOS AS d
JOIN
	s.c_concepto INNER d.c_concepto
WHERE
	s.oi_cab_conc_ddo = {#DOCUM:@oi_cab_conc_ddo}
	and
	d.oi_concepto = {#SOURCE:@id}	
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_concepto_ddo" name="oi_concepto_ddo"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.filter.autoform:FILTER" form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.filtro.form" name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.filtro.form:EDIT" mode="FILTER" doc="SOURCE">
		<flow:action name="FILTER">
			<flow:log text-path="#FILTERDATA:" text="logppfilter"/>
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="open-flow-SHOW"/>
		</flow:action>
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.noreg.autoform" iter-index="#QRY:ROW/@value" doc-path="#DDO:" parent-doc-path="#QRY:" mode="SHOW"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.noreg.autoform" iter-index="#QRY:ROW/@value" doc-path="#DDO:" parent-doc-path="#QRY:" mode="SHOW"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Liquidacion.Liquidacion.EJECUTARINTERFACES"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Liquidacion.Liquidacion.EJECUTARINTERFACES"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.noreg.autoform:EDIT" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.noreg.form:SHOW" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.noreg.autoform" mode="SHOW">
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form" doc-path="#DDO:" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" mode="SHOW"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form" doc-path="#DDO:" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" mode="LIST"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.autoform:SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form" name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form:SHOW" doc="SOURCE" mode="SHOW" parent-doc="PARENTSOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Ejecutar.form" parent-doc-path="#DDO:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.autoform:LIST" form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form" name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Liquidacion.form:LIST" doc="SOURCE" mode="LIST" parent-doc="PARENTSOURCE"/>
	<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Ejecutar.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Liquidacion.EjecutarInterfaces.Ejecutar.form" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#DOC_EJECUTAR:@oi_liquidacion"/>
			<doc:set-attribute from-value="1" to-attr-path="#DOC_EJECUTAR:@todo"/>
			<doc:load-qry output-doc="DOC_EJECUTAR" input-doc-path="#DOC_EJECUTAR:" qry="obtenerDatos"/>
			<flow:log text-path="#DOC_EJECUTAR:" text="pppppp"/>
			<flow:log text-path="#PARENTSOURCE:" text="pppppp1"/>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO" method="EjecucionCerradas">
				<flow:param doc="DOC_EJECUTAR" mode="in" type="Nomad.NSystem.Proxy.NomadXML" name="xmlParam"/>
			</flow:exec-method>
			<doc:load-qry output-doc="DOC_OUT_EJECUTAR" qry="QRY_EJECUTAR" input-doc-path="#DOC_EJECUTAR:"/>
			<flow:exec-method method="RemoteStartReLiq" class="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9">
				<flow:param name="oi_liquidacion" mode="in" attr-path="#DDO:@id" type="String"/>
				<flow:param name="oi_per_emp_list" mode="in" doc-path="#DOC_OUT_EJECUTAR:"/>
			</flow:exec-method>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
