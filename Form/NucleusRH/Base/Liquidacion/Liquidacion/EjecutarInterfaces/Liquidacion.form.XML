			<form:Link enabled="0" label="Editar Datos de Novedad" policy="NucleusRH/Base/Liquidacion/Liquidacion/VAL_VARGN/EDIT" name="VAL_VARGN_EDIT" allowimg="1" descrip="Valores de datos de Novedad para la Liquidaci&#243;n">
				<form:Event action="CALL_VAL_VARGN" runat="client" name="onclick"/>
			</form:Link>
			<form:Link visible="SHOW" label="Administrar Legajos" name="PERSONAS" allowimg="1" descrip="Legajos inicializados en la liquidaci&#243;n">
				<form:Event action="CALL_PERSONAS" runat="client" name="onclick"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="100%">
		<form:Columns visible="0" name="main_columnsLIQUIDACION">
			<form:Column name="main_columnsLIQUIDACIONcolumn1"/>
