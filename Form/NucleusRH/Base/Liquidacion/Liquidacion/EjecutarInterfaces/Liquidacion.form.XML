<form:Form mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.autoform" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.form" xmlns:form="nomad_engine.form" doc="source" default_mode="NEW">
	<form:Scripts>
		&#13;&#10;&#13;&#10;function set_oi() {
	if (Ctrl('LIST'))
		Ctrl('oi').SetXValue(Ctrl('LIST').GetXValue());
	else
		Ctrl('oi').SetXValue(Ctrl('oi_ddo').GetXValue());	
}
                       
function CALL_PERSONAS() {
	set_oi();
	openNewFlowWait("NucleusRH.Base.Liquidacion.Personal_Liquidacion.flow","initialize_liq","&lt;DATA oi=\"" + Ctrl('oi').GetXValue() + "\" /&gt;",new ObjtectResult(),"L");
}

function refresh() {
	Ctrl('main').DoEvent('REFRESH');
}

function ObjtectResult()
{        
	this.processResult= function(xmlin)
											{    
											}
}
	</form:Scripts>
	<form:Right>
		<form:VGroup visible="0" name="vgChildsLIQUIDACION" width="95%" collapse="1" label="Dependencias">
			<form:Link visible="0" name="novporEmpresa" label="Novedades por Empresa" allowimg="1">
				<form:Event runat="server" name="onclick" action="CALL:NOV_EMPRESAS"/>
			</form:Link>
			<form:Link visible="0" name="novPorVariable" label="Novedades por Legajo" allowimg="1">
				<form:Event runat="server" name="onclick" action="CALL:NOV_VARIABLE"/>
			</form:Link>
			<form:Link visible="0" name="errores" label="Errores" allowimg="1">
				<form:Event runat="server" name="onclick" action="CALL:ERRORES"/>
			</form:Link>
			<form:Link visible="0" name="perIni" label="Personas Inicializadas" allowimg="1">
				<form:Event runat="server" name="onclick" action="CALL:PerIni"/>
			</form:Link>
		</form:VGroup>
		<form:VGroup width="100%" name="vgChildsLIQUIDACION1" label="Dependencias" collapse="1">
			<form:Link visible="SHOW|EDIT|LIST" allowimg="1" policy="NucleusRH/Base/Liquidacion/Liquidacion/VAL_VARGN/READ" descrip="Valores de los variables de Generales Novedad" label="Datos de Novedad" name="VAL_VARGN">
				<form:Event policy="NucleusRH/Base/Liquidacion/Liquidacion/VAL_VARGN/EDIT" action="CALL:VAL_VARGN" name="onclick" runat="server"/>
			</form:Link>
			<form:Link label="Ejecuciones de la Liquidaci&#243;n" visible="SHOW|LIST|EDIT" allowimg="1" policy="NucleusRH/Base/Liquidacion/Liquidacion/EJECUCION/READ" descrip="Guarda todas las Ejecuciones de la Liquidacion" name="EJECUCIONES">
				<form:Event policy="NucleusRH/Base/Liquidacion/Liquidacion/EJECUCION/EDIT" action="CALL:EJECUCION" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
		<form:Blank name="blank1"/>
