					<form:CheckBox required="0" enabled="NEW|EDIT" label="Retroactivos" nvalue="#source:@l_retroactivo" name="l_retroactivo">
						<form:Event runat="client" name="onchange" action="cambiarRetro"/>
					</form:CheckBox>
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Per&#237;odo Retroactivo" nvalue="#source:@e_periodo_ret" name="e_periodo_ret">
						<form:Event runat="client" name="onvalidate" action="retroValidar"/>
					</form:NumberBox>
					<form:CheckBox visible="0" required="0" enabled="NEW|EDIT" descr="Indica si la liquidacion va a ser utilizada para simulacion." label="Se Utiliza para Simulacion?" nvalue="#source:@l_simulacion" name="l_simulacion"/>
					<form:CheckBox required="0" enabled="NEW|EDIT" label="Generar informaci&#243;n adicional" nvalue="#source:@l_debug" name="l_debug"/>
				</form:Panel>
				<form:Panel selected="1" label="Datos Adicionales" name="Liq">
					<form:Combo visible="" enabled="NEW|EDIT" action="COMBO" flow="NucleusRH.Base.Personal.Formas_Pago.FORMA_PAGO.Combo.autoflow" required="0" label="Forma de Pago" nvalue="#source:oi_forma_pago/@value" name="oi_forma_pago"/>
					<form:Combo label="Banco de Ultimo Dep&#243;sito RNPS" action="COMBO" flow="NucleusRH.Base.Liquidacion.Bancos.BANCO.Combo.autoflow" required="0" enabled="NEW|EDIT" nvalue="#source:oi_banco/@value" name="oi_banco"/>
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="Mes de Ultimo Dep&#243;sito RNPS" nvalue="#source:@c_mes_deposito" name="c_mes_deposito"/>
