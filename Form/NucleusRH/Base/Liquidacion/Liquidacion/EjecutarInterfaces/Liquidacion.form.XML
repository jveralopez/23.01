					<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ.Combo.autoflow" required="1" enabled="NEW|EDIT" label="Tipo Liquidaci&#243;n" nvalue="#source:oi_tipo_liq/@value" name="oi_tipo_liq"/>
					<form:CheckBox enabled="NEW|EDIT" required="1" label="Liquidacion de Ajuste?" nvalue="#source:@l_ajuste" name="l_ajuste"/>
					<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
					<form:Combo name="c_clase" nvalue="#source:@c_clase" label="Clase Liquidacion" enabled="NEW|EDIT" required="1" flow="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.c_clase.Combo.autoflow" action="COMBO">
						<form:Event runat="client" name="onchange" action="cambiarClase"/>
					</form:Combo>
					<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.e_quincena.Combo.autoflow" required="0" enabled="NEW|EDIT" descr="Quincena" label="Quincena" nvalue="#source:@e_quincena" name="e_quincena">
						<form:Event runat="client" name="onvalidate" action="quincenaValidar"/>
					</form:Combo>
					<form:NumberBox enabled="NEW0|EDIT0" label="Per&#237;odo (AAAAMM)" required="1" mask="###.###.##0" xsize="12" nvalue="#source:@e_periodo" name="e_periodo"/>
					<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Pago de la Liquidaci&#243;n" nvalue="#source:@f_pago" name="f_pago">
