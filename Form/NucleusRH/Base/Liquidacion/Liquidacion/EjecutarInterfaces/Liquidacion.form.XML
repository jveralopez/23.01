						<form:SButtons>
							<form:SButton visible="EDIT|NEW" name="Calendar" label="Calendar" img="Calendar">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Valor para el pase Contable" nvalue="#source:@f_valor" name="f_valor">
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Cierre" nvalue="#source:@f_cierre" name="f_cierre"/>
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_liquidacion" name="o_liquidacion"/>
