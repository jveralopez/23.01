			<qry:main doc="SOURCE">
				<qry:element name="FLAG">
					<qry:append-doc name="FILTRO" doc-path="#SOURCE:FILTRO"/>
					<qry:append-doc name="PUNTO" doc-path="."/>
					<qry:attribute value="'0'" name="flag"/>
					<qry:attribute value="iif(#SOURCE:FILTRO/@chkOcultarLeyenda!='',#SOURCE:FILTRO/@chkOcultarLeyenda,0)" name="chkOcultarLeyenda"/>
					<qry:attribute value="iif(#SOURCE:FILTRO/@chkInvertir!='',#SOURCE:FILTRO/@chkInvertir,0)" name="chkInvertir"/>
					<qry:insert-select name="QRY_EMPRESA" doc-path="#SOURCE:FILTRO"/>
					<qry:element name="ROWS">
						<qry:attribute name="flag" value="0"/>
						<qry:attribute name="hts:delete" value="1"/>
						<qry:insert-select doc-path="#SOURCE:FILTRO/PERSONAS/ROW" name="QRY_RECIBOS"/>
					</qry:element>
