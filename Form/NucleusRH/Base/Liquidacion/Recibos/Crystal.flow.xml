			<qry:select name="QRY_EMPRESA" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					LIQ19_LIQUIDACION.oi_empresa,
					ORG03_EMPRESAS.c_empresa
				FROM
					LIQ19_LIQUIDACION, ORG03_EMPRESAS
				JOIN
					LIQ19_LIQUIDACION.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE
					LIQ19_LIQUIDACION.oi_liquidacion = {#SOURCE:@oi_liquidacion}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
					<qry:attribute value="$r/@c_empresa" name="c_empresa"/>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_RECIBOS" doc="SOURCE">
				<qry:xquery>
					for $r in sql('			
				SELECT
					{%? (#FILTRO:@orden1!=''){% {%=#FILTRO:@orden1 %} as orden1,%}{% %} %}
					{%? (#FILTRO:@orden2!=''){% {%=#FILTRO:@orden2 %} as orden2,%}{% %} %}
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per, 
					LIQ99_RECIBOS.e_numero_legajo,
					LIQ99_RECIBOS.e_numero_legajo AS LEG
				FROM
					ORG03_EMPRESAS,
					LIQ19_LIQUIDACION,
					LIQ99_LIQUIDACION,
					LIQ99_RECIBOS, 
					LIQ20_TOT_LIQ_PER,
					LIQ25_PERSONAL_LIQ,
					PER02_PERSONAL_EMP,
					LIQ97_PERSONAL_EMP,
					ORG03_UBICACIONES(ORG03_UBICACIONES.oi_empresa = {%=$PUNTO/@oi_empresa%})
				JOIN	
					ORG03_EMPRESAS.oi_empresa INNER LIQ19_LIQUIDACION.oi_empresa,
					ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
					LIQ19_LIQUIDACION.c_liquidacion INNER LIQ99_LIQUIDACION.c_liquidacion,
					ORG03_EMPRESAS.c_empresa INNER LIQ99_LIQUIDACION.c_empresa,
					LIQ99_LIQUIDACION.oi_liquidacion_ddo INNER LIQ99_RECIBOS.oi_liquidacion_ddo,
					LIQ99_RECIBOS.e_numero_legajo INNER PER02_PERSONAL_EMP.e_numero_legajo,
					LIQ99_RECIBOS.oi_tot_liq_per INNER LIQ20_TOT_LIQ_PER.oi_tot_liq_per,
					LIQ19_LIQUIDACION.oi_liquidacion INNER LIQ25_PERSONAL_LIQ.oi_liquidacion,
					PER02_PERSONAL_EMP.oi_personal_emp INNER LIQ25_PERSONAL_LIQ.oi_personal_emp,
					LIQ20_TOT_LIQ_PER.oi_per_emp_ddo INNER LIQ97_PERSONAL_EMP.oi_per_emp_ddo,
					LIQ97_PERSONAL_EMP.c_ubicacion LEFT OUTER ORG03_UBICACIONES.c_ubicacion
				WHERE 	
					LIQ99_LIQUIDACION.c_estado = \'F\'
					AND LIQ19_LIQUIDACION.oi_liquidacion = {#FILTRO:@oi_liquidacion}
					{%? (string(#SOURCE:@VALUES)!='') {% AND LIQ25_PERSONAL_LIQ.oi_personal_emp in ({%=string(#SOURCE:@VALUES) %}) %} {%  %} %}
				ORDER BY
					{%? (#FILTRO:@orden1!='') {% orden1 ASC, %} {% %} %}
					{%? (#FILTRO:@orden2!='') {% orden2 ASC, %} {% %} %}
					LEG ASC 
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="RECIBO">
						<qry:attribute value="$r/@oi_tot_liq_per" name="oi_tot_liq_per"/>
						<qry:attribute value="iif($FILTRO/@orden1!='' AND $FILTRO/@orden1!='0', NMD_FILLRIGHT($r/@orden1, ' ', 50, 'L'), '')" name="order"/>
						<qry:attribute value="@order + iif($FILTRO/@orden2!='' AND $FILTRO/@orden2!='0', NMD_FILLRIGHT($r/@orden2, ' ', 50, 'L'), '')" name="order"/>
						<qry:attribute value="@order + NMD_FILLLEFT($r/@e_numero_legajo, '0', 10, 'R')" name="order"/>
						<qry:attribute value="$r/@e_numero_legajo" name="e_numero_legajo"/>
					</qry:element>
					<qry:attribute value="'1'" name="flag"/>
				</qry:out>
			</qry:select>
			<!--qry:select name="QRY_FLAG" doc="SOURCE">
		<qry:xquery>
			for $r in #SOURCE:RECIBOS/RECIBO
		</qry:xquery>
		<qry:out>
			<qry:attribute value="'1'" name="flag"/>
		</qry:out>
	</qry:select-->
			<qry:select name="QRY_ORDER" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:RECIBO ORDERBY $r/@order ASC
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERLIQ">
			<FILTRO excluir="" oi_liquidacion="">
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
		<doc:define name="PARAMLIQS"/>
		<qry:define declare="&lt;FILTRO oi_empresa=&quot;164&quot; legajo=&quot;15139&quot; excluir=&quot;&quot; oi_liquidacion=&quot;&quot; gcustom=&quot;&quot; periodo_desde=&quot;201201&quot; periodo_hasta=&quot;201601&quot; liqID=&quot;5482&quot; oi_personal_emp=&quot;1&quot;&gt;&#13;&#10;&#9;&lt;LIQUIDACIONES&gt;&lt;ROW VALUES=&quot;5482&quot; /&gt;&lt;/LIQUIDACIONES&gt;&#13;&#10;&lt;/FILTRO&gt;" name="QRY_PARAM_LIQ">
			<qry:main doc="SOURCE">
				<qry:element name="FLAG">
					<qry:attribute value="1" name="flag"/>
					<qry:attribute value="0" name="chkOcultarLeyenda"/>
					<qry:attribute value="0" name="chkInvertir"/>
					<qry:attribute name="oi_empresa" value="#SOURCE:FILTRO/@oi_empresa"/>
					<qry:element name="RECIBOS">
						<qry:element name="RECIBO">
							<qry:attribute name="oi_tot_liq_per" value="#SOURCE:FILTRO/LIQUIDACIONES/ROW/@VALUES"/>
							<qry:attribute name="e_numero_legajo" value="#SOURCE:FILTRO/@legajo"/>
						</qry:element>
					</qry:element>
				</qry:element>
			</qry:main>
		</qry:define>
		<qry:define name="QRY_LEGAJO">
			<qry:main doc="SOURCE">
				<qry:element name="PER">
					<qry:attribute name="flag" value="'0'"/>
					<qry:insert-select name="sql1" doc-path="."/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in SQL(' 
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER01_PERSONAL.oi_personal,
					PER01_PERSONAL.d_ape_y_nom,
					PER01_PERSONAL.oi_foto, 
					ORG03_EMPRESAS.oi_empresa,
					ORG03_EMPRESAS.d_empresa
					
				FROM
					PER02_PERSONAL_EMP, 
					PER01_PERSONAL,
					ORG03_EMPRESAS
				JOIN
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
					PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE 
					PER01_PERSONAL.oi_usuario_sistema = {#PROXY:@etty}
					AND PER02_PERSONAL_EMP.oi_indic_activo=1   
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
					<qry:attribute name="legajo" value="$r/@e_numero_legajo"/>
					<qry:attribute name="nombre" value="$r/@d_ape_y_nom"/>
					<qry:attribute name="empresa" value="$r/@d_empresa"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="image" value="$r/@oi_foto"/>
					<qry:attribute name="flag" value="'1'"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="LEGAJO"/>
		<doc:define name="RECIBOS"/>
		<qry:define declare="&lt;FILTRO excluir=&quot;&quot; oi_liquidacion=&quot;&quot; oi_personal_emp=&quot;11545&quot; periodo_liq=&quot;&quot; l_intervalo=&quot;&quot; periodo_desde=&quot;012008&quot; periodo_hasta=&quot;&quot; oi_empresa=&quot;&quot;&gt;&lt;LIQUIDACIONES /&gt;&lt;/FILTRO&gt;&#13;&#10;&#13;&#10;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:append-doc name="PARAMIN" doc-path="#SOURCE:."/>
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					LIQ20_TOT_LIQ_PER.oi_tot_liq_per, LIQ97_PERSONAL_EMP.e_numero_legajo, 
					LIQ97_PERSONAL_EMP.d_ape_y_nom, LIQ19_EJECUCIONES.oi_ejecucion,
					LIQ99_LIQUIDACION.c_liquidacion, LIQ99_LIQUIDACION.d_titulo,
					LIQ20_TOT_LIQ_PER.f_cierre,LIQ20_TOT_LIQ_PER.n_totpag, LIQ99_LIQUIDACION.f_liquidacion,
					PER02_PERSONAL_EMP.oi_personal_emp,LIQ25_PERSONAL_LIQ.oi_personal_liq,
					LIQ99_LIQUIDACION.e_periodo, LIQ99_LIQUIDACION.f_pago, ORG03_EMPRESAS.oi_empresa,
					ORG03_EMPRESAS.c_empresa, ORG03_EMPRESAS.d_empresa,LIQ19_EJECUCIONES.oi_liquidacion 
				FROM
					LIQ25_PERSONAL_LIQ, LIQ19_EJECUCIONES, LIQ99_LIQUIDACION,
					LIQ99_RECIBOS, LIQ20_TOT_LIQ_PER, ORG03_EMPRESAS, 
					LIQ97_PERSONAL_EMP, PER02_PERSONAL_EMP, LIQ19_LIQUIDACION
				WHERE
					LIQ19_LIQUIDACION.oi_liquidacion = LIQ19_EJECUCIONES.oi_liquidacion AND
					LIQ25_PERSONAL_LIQ.oi_liquidacion = LIQ19_EJECUCIONES.oi_liquidacion AND
					LIQ19_EJECUCIONES.oi_liquidacion_ddo = LIQ99_LIQUIDACION.oi_liquidacion_ddo AND
					LIQ99_LIQUIDACION.oi_liquidacion_ddo = LIQ99_RECIBOS.oi_liquidacion_ddo AND
					LIQ99_RECIBOS.oi_tot_liq_per = LIQ20_TOT_LIQ_PER.oi_tot_liq_per AND
					LIQ20_TOT_LIQ_PER.oi_per_emp_ddo = LIQ97_PERSONAL_EMP.oi_per_emp_ddo AND
					LIQ97_PERSONAL_EMP.e_numero_legajo = PER02_PERSONAL_EMP.e_numero_legajo AND
					LIQ25_PERSONAL_LIQ.oi_personal_emp = PER02_PERSONAL_EMP.oi_personal_emp AND
					LIQ97_PERSONAL_EMP.c_empresa = ORG03_EMPRESAS.c_empresa AND
					LIQ99_LIQUIDACION.c_estado = \'F\' AND  
					ISNOTNULL(LIQ20_TOT_LIQ_PER.f_cierre) AND  
					LIQ19_LIQUIDACION.oi_tipo_liq != 6 AND
					PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}               
					
					{%? (string(#SOURCE:@periodo_liq)!='') {%  AND LIQ99_LIQUIDACION.e_periodo = {%=$SOURCE/@periodo_liq%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_desde)!='') {%  AND LIQ99_LIQUIDACION.e_periodo &gt;= {%=$SOURCE/@periodo_desde%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_hasta)!='') {%  AND LIQ99_LIQUIDACION.e_periodo &lt;= {%=$SOURCE/@periodo_hasta%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_desde)!='' and string(#SOURCE:@periodo_hasta)!='')  {%  
								AND LIQ99_LIQUIDACION.e_periodo &lt;= {%=$SOURCE/@periodo_hasta%} 
								AND LIQ99_LIQUIDACION.e_periodo &lt;= {%=$SOURCE/@periodo_hasta%}  
					%} {% %} %}
					
				ORDER BY 
					f_liquidacion DESC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_tot_liq_per"/>
						<qry:attribute name="oi_tot_liq_per" value="$r/@oi_tot_liq_per"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
