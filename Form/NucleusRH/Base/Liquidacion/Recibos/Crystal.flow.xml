					{%? (string(#SOURCE:@periodo_liq)!='') {%  AND LIQ99_LIQUIDACION.e_periodo = {%=$SOURCE/@periodo_liq%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_desde)!='') {%  AND LIQ99_LIQUIDACION.e_periodo &gt;= {%=$SOURCE/@periodo_desde%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_hasta)!='') {%  AND LIQ99_LIQUIDACION.e_periodo &lt;= {%=$SOURCE/@periodo_hasta%}  %} {% %} %}
					
					{%? (string(#SOURCE:@periodo_desde)!='' and string(#SOURCE:@periodo_hasta)!='')  {%  
