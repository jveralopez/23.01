<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="ReciboSueldoCargos" extends="Nomad.Base.flow">
	<flow:info label="ReciboSueldoCargos"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO excluir="" oi_liquidacion="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="PARAMETERS"/>
		<doc:define name="source"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Recibos.ReciboCargos.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Recibos.ReciboCargos.filter.form" name="NucleusRH.Base.Liquidacion.Recibos.ReciboCargos.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="ppfilterdata" text-path="#FILTERDATA:"/>
			<flow:call-action action="REPORT"/>
		</flow:action>
		<flow:action name="REPORT">
			<flow:exec-method method="ExecReportFO" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5">
				<flow:param value="NucleusRH.Base.Liquidacion.ReciboCargos.ReciboCargos.rpt" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" name="report-param" mode="in"/>
			</flow:exec-method>
			<flow:open-form mode="BATCH" form-class="Nomad.base.batch.report.form" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="NODATA">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Recibos.NODATA.form" mode="SHOW" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Liquidacion.Recibos_sueldo"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Liquidacion.Recibos_sueldo"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		f
	</flow:form>
	<flow:form mode="SHOW" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Recibos.NODATA.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Recibos.NODATA.form">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
