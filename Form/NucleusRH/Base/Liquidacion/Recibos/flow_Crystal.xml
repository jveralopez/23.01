<flow:flow extends="Nomad.Base.flow" name="Nomad.Base.Liquidacion.Recibos" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="DOC_RECIBO"/>
		<doc:define name="VERREC">
			<DATO ids=""/>
		</doc:define>
		<flow:comment>
			Para Eliminar el Recibo
		</flow:comment>
		<doc:define name="FILTER_DATA"/>
		<doc:define name="DOC_OUT"/>
		<doc:define name="RECIBO"/>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN4="" ATRIB_ORDEN4="" ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_empresa="">
				<LIQUIDACIONES/>
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="FiltroReporteRecibo">
			<DATOS>
				<PERSONAS/>
			</DATOS>
		</doc:define>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE">
				<qry:insert-select name="qryDatos" doc-path="#SOURCE:FILTRO"/>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in table('
        select LIQ20_TOT_LIQ_PER.oi_tot_liq_per RECI 
        , PER01_PERSONAL.D_APE_Y_NOM APEYNOM
        from LIQ20_TOT_LIQ_PER
        , LIQ19_LIQUIDACION
        , LIQ25_PERSONAL_LIQ
        , PER01_PERSONAL
        , PER02_PERSONAL_EMP
        , LIQ07_PERSONAL
        , ORG03_EMPRESAS
        , LIQ15_EMPRESAS
        where 1=1                                
        AND LIQ25_PERSONAL_LIQ.OI_LIQUIDACION =  LIQ19_LIQUIDACION.OI_LIQUIDACION
        AND LIQ25_PERSONAL_LIQ.OI_PERSONAL_EMP = LIQ07_PERSONAL.OI_PERSONAL_EMP
        AND LIQ07_PERSONAL.OI_PERSONAL_EMP = PER02_PERSONAL_EMP.OI_PERSONAL_EMP
        AND PER02_PERSONAL_EMP.OI_PERSONAL = PER01_PERSONAL.OI_PERSONAL
        AND LIQ19_LIQUIDACION.OI_EMPRESA = LIQ15_EMPRESAS.OI_EMPRESA
        AND LIQ15_EMPRESAS.OI_EMPRESA = ORG03_EMPRESAS.OI_EMPRESA
        AND LIQ20_TOT_LIQ_PER.OI_TOT_LIQ_PER = LIQ25_PERSONAL_LIQ.OI_TOT_LIQ_PERS
        {%? (#SOURCE:@oi_empresa!='')	{% and LIQ19_LIQUIDACION.oi_empresa= {%=#SOURCE:@oi_empresa %} %} {% %} %}
        {%? (string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id)!='') 
        		{% AND LIQ25_PERSONAL_LIQ.oi_liquidacion in 
        			({%=string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id) %}) 
        		%} 
        		{%  %} 
        %}
        {%? (string(#SOURCE:PERSONAS/PERSONA/@id)!='') 
        		{% AND LIQ25_PERSONAL_LIQ.oi_PERSONAL_EMP in 
        			({%=string(#SOURCE:PERSONAS/PERSONA/@id) %}) 
        		%} 
        		{%  %} 
        %}  
        order by 
        	{%? (#SOURCE:@ATRIB_ORDEN1!='') {% {%=#SOURCE:@ATRIB_ORDEN1%} {%=#SOURCE:@ORDEN1 %}, %} {% %} %} 
        	{%? (#SOURCE:@ATRIB_ORDEN2!='') {% {%=#SOURCE:@ATRIB_ORDEN2%} {%=#SOURCE:@ORDEN2 %}, %} {% %} %}
        	{%? (#SOURCE:@ATRIB_ORDEN3!='') {% {%=#SOURCE:@ATRIB_ORDEN3%} {%=#SOURCE:@ORDEN3 %}, %} {% %} %} 
        	{%? (#SOURCE:@ATRIB_ORDEN4!='') {% {%=#SOURCE:@ATRIB_ORDEN4%} {%=#SOURCE:@ORDEN4 %}, %} {% %} %}       
        	OI_TOT_LIQ_PER
        ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="value" value="$r/@RECI" type="Nomad.NSystem.Int"/>
						<qry:attribute name="oi_tot_liq_per" value="$r/@RECI" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@APEYNOM" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="Param" name="qryDatos" xmlns:qry="nomad.xquery">
				<qry:xquery>
					&#9;&#9;for $r in table('		SELECT \' \' blanco  ,\'pdf\'   FormatRPT
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="FILTRO">
						<qry:attribute value="$r/@blanco" type="Nomad.NSystem.String" name="file-name"/>
						<qry:attribute name="batch-id" value="$r/@blanco" type="Nomad.NSystem.String"/>
						<qry:attribute value="$r/@FormatRPT" name="FormatRPT"/>
						<qry:element name="ROWS">
							<qry:insert-select doc-path="#Param:" name="RS1"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<flow:comment>
			Para Eliminar el Recibo
		</flow:comment>
		<qry:define name="FILTER_ATRIB">
			<qry:main doc="SOURCE">
				<qry:element name="FILTRO">
					<qry:attribute name="oi_empresa" value="''" type="Nomad.NSystem.String"/>
					<qry:attribute name="oi_liquidacion" value="''" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:main>
		</qry:define>
		<qry:define name="QRY_RECIBO">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="report" value="" type="Nomad.NSystem.String"/>
					<qry:insert-select doc-path="#SOURCE:DATO" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in table('
				select liq25_personal_liq.oi_tot_liq_pers reci
				from liq25_personal_liq
				where liq25_personal_liq.oi_personal_liq = {#SOURCE:@ids}
         ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_tot_liq_per" value="$r/@reci" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="QRY_RECIBO_ABM">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="report" value="" type="Nomad.NSystem.String"/>
					<qry:attribute name="oi_tot_liq_per" value="#SOURCE:ic/@value" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:main>
		</qry:define>
		<qry:define name="PARAMETROS">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_empresa" value="0" type="Nomad.NSystem.String"/>
					<qry:attribute name="oi_tot_liq_per" value="" type="Nomad.NSystem.String"/>
					<qry:attribute name="report" value="" type="Nomad.NSystem.String"/>
				</qry:element>
			</qry:main>
		</qry:define>
		<qry:define name="QRY_EJECUTAR">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in table('
        select 
        oi_tot_liq_pers 
        from LIQ25_PERSONAL_LIQ
        where LIQ25_PERSONAL_LIQ.OI_LIQUIDACION = {#SOURCE:@oi_liquidacion}  AND
        and  oi_tot_liq_pers is not null
        {%? (#SOURCE:@todos=1) 
        	{% 1=1 %}
        	{%  
        			 {%? (string(#SOURCE:PERSONAS/PERSONA/@id)!='') {% oi_personal_emp 
        			 {%? (#SOURCE:@excluir=1) {% not %} {%  %} %} 
        			 in ({%=string(#SOURCE:PERSONAS/PERSONA/@id) %}) %} {% 1=2 %} %} %} %} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_tot_liq_pers" value="$r/@oi_tot_liq_pers" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO FormatRPT=&quot;pdf&quot; batch-id=&quot;00007640-00006258-20070322-121800-00000000&quot; file-name=&quot; &quot;&gt;&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW d_ape_y_nom=&quot;Camarasa, Daniel&quot; oi_tot_liq_per=&quot;5&quot; value=&quot;5&quot; /&gt;&lt;ROW d_ape_y_nom=&quot;RIZZO, JUAN PABLO&quot; oi_tot_liq_per=&quot;6&quot; value=&quot;6&quot; /&gt;&lt;ROW d_ape_y_nom=&quot;AVILA, JUSTO LORENZO&quot; oi_tot_liq_per=&quot;7&quot; value=&quot;7&quot; /&gt;&lt;ROW d_ape_y_nom=&quot;CEREDA, CARLOS MARTIN&quot; oi_tot_liq_per=&quot;8&quot; value=&quot;8&quot; /&gt;&lt;/ROWS&gt;&lt;/FILTRO&gt;&#13;&#10;" name="QRY_HTML">
			<qry:main doc="PARAM">
				<qry:append-doc doc-path="#PARAM:/FILTRO" name="FILTRO"/>
				<qry:element name="datos">
					<qry:insert-select doc-path="#FILTRO:/ROWS" name="qry_cabecera"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_cabecera">
				<qry:xquery>
					for $r in table('
				SELECT  liq25_personal_liq.oi_tot_liq_pers oi_tot_liq_per, d_empresa, ORG03_EMPRESAS.d_domicilio domin, ORG03_EMPRESAS.c_cuit c_cuit,
				e_numero_legajo, d_ape_y_nom, f_pago, D_CATEGORIA, e_periodo,
				f_deposito, c_mes_deposito, d_banco, 
				ORG08_CS_COSTO.c_centro_costo cCentroCosto, 
				ORG08_CS_COSTO.d_centro_costo dCentroCosto,
				c_liquidacion, d_titulo, f_ingreso, f_egreso, f_antiguedad_rec, per01_personal.c_nro_cuil nro_cuil
				
				FROM liq19_liquidacion, liq25_personal_liq, liq07_personal, 
				per01_personal, per02_personal_emp, liq22_bancos, org03_empresas,
				org18_categorias, ORG08_CS_COSTO 
				WHERE 
				
				liq19_liquidacion.oi_liquidacion = liq25_personal_liq.oi_liquidacion
				and PER02_PERSONAL_EMP.oi_ctro_costo_ult = ORG08_CS_COSTO.oi_centro_costo
				and per01_personal.oi_personal = per02_personal_emp.oi_personal 
				and per02_personal_emp.oi_personal_emp = liq07_personal.oi_personal_emp
				and liq25_personal_liq.oi_personal_emp = liq07_personal.oi_personal_emp
				and org18_categorias.oi_categoria =* per02_personal_emp.oi_categoria_ult
				and liq19_liquidacion.oi_banco *= liq22_bancos.oi_banco
				and liq19_liquidacion.oi_empresa = org03_empresas.oi_empresa
				{%? (#FILTRO:@oi_tot_liq_per!='') {% AND liq25_personal_liq.oi_tot_liq_pers = {%=#FILTRO:@oi_tot_liq_per %} %} {% AND 1=1%} %}
																
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="cabecera">
						<qry:attribute name="d_empresa" value="$r/@d_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_domicilio" value="$r/@domin" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_cuit" value="$r/@c_cuit" type="Nomad.NSystem.String"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_pago" value="format_date($r/@f_pago,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="D_CATEGORIA" value="$r/@D_CATEGORIA" type="Nomad.NSystem.String"/>
						<qry:attribute name="e_periodo" value="substring($r/@e_periodo,4,2) + '/' + substring($r/@e_periodo,0,4)" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_deposito" value="format_date($r/@f_deposito,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_mes_deposito" value="$r/@c_mes_deposito" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_banco" value="$r/@d_banco" type="Nomad.NSystem.String"/>
						<qry:attribute name="CentroCosto" value="$r/@cCentroCosto" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_titulo" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_egreso" value="format_date($r/@f_egreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_antiguedad_rec" value="format_date($r/@f_antiguedad_rec,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="nro_cuil" value="substring($r/@nro_cuil,0,2) + '-'+ substring($r/@nro_cuil,2,string_length($r/@nro_cuil) - 3 )+ '-'+ substring($r/@nro_cuil,string_length($r/@nro_cuil) - 1 ,1)" type="Nomad.NSystem.String"/>
						<qry:element name="detalles">
							<qry:attribute value="$r/@d_empresa" name="aa"/>
							<qry:insert-select doc-path="$r" name="qry_detalle"/>
							<qry:element name="PieDetalle">
								<qry:attribute value="$r/@d_empresa" name="ab"/>
								<qry:insert-select doc-path="$r" name="qry_Remuneraciones"/>
							</qry:element>
							<qry:element name="Pie">
								<qry:attribute value="$r/@d_empresa" name="ac"/>
								<qry:insert-select doc-path="$r" name="qry_pie"/>
							</qry:element>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_detalle">
				<qry:xquery>
					for $r in table('
SELECT c_concepto, d_concepto, 
valorRemun = sum(
case liq14_conceptos.oi_tipo_concepto
WHEN 1 THEN liq20_conc_liq_per.n_valor
WHEN 9 THEN liq20_conc_liq_per.n_valor
WHEN 2 THEN liq20_conc_liq_per.n_valor
WHEN 5 THEN liq20_conc_liq_per.n_valor	
ELSE null
END)
,valorDeduc = sum(
case liq14_conceptos.oi_tipo_concepto
WHEN 3 THEN liq20_conc_liq_per.n_valor
WHEN 7 THEN liq20_conc_liq_per.n_valor
ELSE null
END)

,cantidad = sum(
case liq14_conceptos.ca_fig_recibo
WHEN \'S\' THEN liq20_conc_liq_per.n_cantidad 
ELSE null
END)
				FROM liq20_tot_liq_per  , liq20_conc_liq_per , liq14_conceptos 
				WHERE 
				liq20_tot_liq_per.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}
				and liq20_tot_liq_per.oi_tot_liq_per = liq20_conc_liq_per.oi_tot_liq_per
				and liq14_conceptos.oi_concepto = liq20_conc_liq_per.oi_concepto
				and liq14_conceptos.oi_tipo_concepto in (9,5,3,7,2,1)
				and liq14_conceptos.ca_fig_recibo in (\'S\', \'I\')
				
				group by c_concepto, d_concepto, e_secuencia
				order by e_secuencia, c_concepto
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="Datosdetalle">
						<qry:attribute name="c_concepto" value="$r/@c_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_concepto" value="$r/@d_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="cantidad" value="$r/@cantidad" type="Nomad.NSystem.String"/>
						<qry:attribute name="remun" value="$r/@valorRemun" type="Nomad.NSystem.String"/>
						<qry:attribute name="deduc" value="abs($r/@valorDeduc)" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_Remuneraciones">
				<qry:xquery>
					for $r in table('
				SELECT  remuneraciones = 
				convert(decimal (9,2), sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 1 THEN liq20_conc_liq_per.n_valor
					 WHEN 9 THEN liq20_conc_liq_per.n_valor
				         WHEN 2 THEN liq20_conc_liq_per.n_valor
					 WHEN 5 THEN liq20_conc_liq_per.n_valor
				         ELSE 0
				      END) )
				,  deducciones = 
				convert(decimal (9,2),sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 3 THEN liq20_conc_liq_per.n_valor
				         WHEN 7 THEN liq20_conc_liq_per.n_valor
				      END) )
				, Resultado = 
				convert(decimal (9,2),sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 1 THEN liq20_conc_liq_per.n_valor
					 WHEN 9 THEN liq20_conc_liq_per.n_valor
				         WHEN 2 THEN liq20_conc_liq_per.n_valor
					 WHEN 5 THEN liq20_conc_liq_per.n_valor
				         WHEN 3 THEN liq20_conc_liq_per.n_valor
				         WHEN 7 THEN liq20_conc_liq_per.n_valor
				         ELSE 0
				      END) )
				
				FROM liq20_conc_liq_per , liq14_conceptos 
				WHERE 
				liq20_conc_liq_per.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}
				and liq14_conceptos.oi_concepto = liq20_conc_liq_per.oi_concepto
				and (liq14_conceptos.oi_tipo_concepto in (9,5,3,7,2,1))
				and (liq14_conceptos.ca_fig_recibo in (\'S\',\'I\'))
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="DatosPiedetalle">
						<qry:attribute name="remuneraciones" value="$r/@remuneraciones" type="Nomad.NSystem.String"/>
						<qry:attribute name="deduccciones" value="abs($r/@deducciones)" type="Nomad.NSystem.String"/>
						<qry:attribute name="Resultado" value="$r/@Resultado" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_pie">
				<qry:xquery>
					for $r in table('
				select 
				c_cta_bancaria, d_banco
				from liq25_personal_liq, 
				(select oi_sucursal, d_banco 
				from liq22_bancos, liq22_bancos_sucur
				where liq22_bancos.oi_banco = liq22_bancos_sucur.oi_banco)
				as bancoPer right join liq07_personal on
				bancoper.oi_sucursal = liq07_personal.oi_sucursal
				where 
				liq25_personal_liq.oi_personal_emp = liq07_personal.oi_personal_emp
				and liq25_personal_liq.oi_tot_liq_pers = {#PARAM:@oi_tot_liq_per}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_cta_bancaria" value="$r/@c_cta_bancaria" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_banco" value="$r/@d_banco" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PARAMETROS_CR" declare="&lt;flow-empty-doc oi_liquidacion=&quot;1&quot; valor=&quot;1&quot; /&gt;">
			<qry:main doc="SOURCE">
				<qry:insert-select doc-path="#SOURCE:/." name="qryDatos"/>
			</qry:main>
			<qry:select doc="Param" name="qryDatos" xmlns:qry="nomad.xquery">
				<qry:xquery>
					&#9;&#9;for $r in table('		SELECT \' \' blanco
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="FILTRO">
						<qry:attribute value="$r/@blanco" type="Nomad.NSystem.String" name="file-name"/>
						<qry:attribute name="batch-id" value="$r/@blanco" type="Nomad.NSystem.String"/>
						<qry:attribute name="FormatRPT" value="#Param:@FormatRPT"/>
						<qry:element name="DATOS">
							<qry:attribute value="#Param:@oi_tot_liq_per" type="Nomad.NSystem.String" name="oi_tot_liq_per"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO FormatRPT=&quot;pdf&quot; batch-id=&quot; &quot; file-name=&quot; &quot;&gt;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&lt;ROW d_ape_y_nom=&quot;RIZZO, JUAN PABLO&quot; oi_tot_liq_per=&quot;5&quot; value=&quot;5&quot; /&gt;&#13;&#10;&lt;ROW d_ape_y_nom=&quot;RIZZO, JUAN PABLO&quot; oi_tot_liq_per=&quot;8&quot; value=&quot;8&quot; /&gt;&#13;&#10;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;&lt;/FILTRO&gt;" name="QUERY_CRYSTAL">
			<qry:main doc="PARAM">
				<qry:append-doc doc-path="#PARAM:/FILTRO" name="FILTRO"/>
				<qry:element name="datos">
					<qry:insert-select doc-path="#FILTRO:/ROWS" name="qry_cabecera"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_cabecera">
				<qry:xquery>
					for $r in table('
				SELECT  liq25_personal_liq.oi_tot_liq_pers oi_tot_liq_per, d_empresa, ORG03_EMPRESAS.d_domicilio domin, ORG03_EMPRESAS.c_cuit c_cuit,
				e_numero_legajo, d_ape_y_nom, f_pago, D_CATEGORIA, e_periodo,
				f_deposito, c_mes_deposito, d_banco, 
				ORG08_CS_COSTO.c_centro_costo cCentroCosto, 
				ORG08_CS_COSTO.d_centro_costo dCentroCosto,
				c_liquidacion, d_titulo, f_ingreso, f_egreso, f_antiguedad_rec, per01_personal.c_nro_cuil nro_cuil
				
				FROM liq19_liquidacion, liq25_personal_liq, liq07_personal, 
				per01_personal, per02_personal_emp, liq22_bancos, org03_empresas,
				org18_categorias, ORG08_CS_COSTO 
				WHERE 
				
				liq19_liquidacion.oi_liquidacion = liq25_personal_liq.oi_liquidacion
				and PER02_PERSONAL_EMP.oi_ctro_costo_ult = ORG08_CS_COSTO.oi_centro_costo
				and per01_personal.oi_personal = per02_personal_emp.oi_personal 
				and per02_personal_emp.oi_personal_emp = liq07_personal.oi_personal_emp
				and liq25_personal_liq.oi_personal_emp = liq07_personal.oi_personal_emp
				and org18_categorias.oi_categoria =* per02_personal_emp.oi_categoria_ult
				and liq19_liquidacion.oi_banco *= liq22_bancos.oi_banco
				and liq19_liquidacion.oi_empresa = org03_empresas.oi_empresa
	{%?(string(#PARAM:/ROW/@oi_tot_liq_per)!='') 
		{% AND liq25_personal_liq.oi_tot_liq_pers in ({%=string(#PARAM:/ROW/@oi_tot_liq_per)%}) %} 
		{% AND 1=1%} 
	%}			
	
																
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="cabecera">
						<qry:attribute name="d_empresa" value="$r/@d_empresa" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_domicilio" value="$r/@domin" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_cuit" value="$r/@c_cuit" type="Nomad.NSystem.String"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_pago" value="format_date($r/@f_pago,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="D_CATEGORIA" value="$r/@D_CATEGORIA" type="Nomad.NSystem.String"/>
						<qry:attribute name="e_periodo" value="substring($r/@e_periodo,4,2) + '/' + substring($r/@e_periodo,0,4)" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_deposito" value="format_date($r/@f_deposito,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_mes_deposito" value="$r/@c_mes_deposito" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_banco" value="$r/@d_banco" type="Nomad.NSystem.String"/>
						<qry:attribute name="CentroCosto" value="$r/@cCentroCosto" type="Nomad.NSystem.String"/>
						<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_titulo" value="$r/@d_titulo" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_ingreso" value="format_date($r/@f_ingreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_egreso" value="format_date($r/@f_egreso,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="f_antiguedad_rec" value="format_date($r/@f_antiguedad_rec,'dd/mm/yyyy')" type="Nomad.NSystem.String"/>
						<qry:attribute name="nro_cuil" value="substring($r/@nro_cuil,0,2) + '-'+ substring($r/@nro_cuil,2,string_length($r/@nro_cuil) - 3 )+ '-'+ substring($r/@nro_cuil,string_length($r/@nro_cuil) - 1 ,1)" type="Nomad.NSystem.String"/>
						<qry:element name="detalles">
							<qry:attribute value="$r/@d_empresa" name="aa"/>
							<qry:insert-select doc-path="$r" name="qry_detalle"/>
							<qry:element name="PieDetalle">
								<qry:attribute value="$r/@d_empresa" name="ab"/>
								<qry:insert-select doc-path="$r" name="qry_Remuneraciones"/>
							</qry:element>
							<qry:element name="Pie">
								<qry:attribute value="$r/@d_empresa" name="ac"/>
								<qry:insert-select doc-path="$r" name="qry_pie"/>
							</qry:element>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_detalle">
				<qry:xquery>
					for $r in table('
SELECT c_concepto, d_concepto, 
valorRemun = sum(
case liq14_conceptos.oi_tipo_concepto
WHEN 1 THEN liq20_conc_liq_per.n_valor
WHEN 9 THEN liq20_conc_liq_per.n_valor
WHEN 2 THEN liq20_conc_liq_per.n_valor
WHEN 5 THEN liq20_conc_liq_per.n_valor	
ELSE 0 
END)
,valorDeduc = sum(
case liq14_conceptos.oi_tipo_concepto
WHEN 3 THEN liq20_conc_liq_per.n_valor
WHEN 7 THEN liq20_conc_liq_per.n_valor
ELSE 0 
END)

,cantidad = sum(
case liq14_conceptos.ca_fig_recibo
WHEN \'S\' THEN liq20_conc_liq_per.n_cantidad 
ELSE 0
END)
				FROM liq20_tot_liq_per  , liq20_conc_liq_per , liq14_conceptos 
				WHERE 
				liq20_tot_liq_per.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}
				and liq20_tot_liq_per.oi_tot_liq_per = liq20_conc_liq_per.oi_tot_liq_per
				and liq14_conceptos.oi_concepto = liq20_conc_liq_per.oi_concepto
				and liq14_conceptos.oi_tipo_concepto in (9,5,3,7,2,1)
				and liq14_conceptos.ca_fig_recibo in (\'S\', \'I\')
				
				group by c_concepto, d_concepto, e_secuencia
				order by e_secuencia, c_concepto
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="Datosdetalle">
						<qry:attribute name="c_concepto" value="$r/@c_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="d_concepto" value="$r/@d_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute value="abs($r/@cantidad)" type="Nomad.NSystem.Decimal" name="cantidad"/>
						<qry:attribute value="abs($r/@valorRemun)" type="Nomad.NSystem.Decimal" name="remun"/>
						<qry:attribute name="deduc" value="abs($r/@valorDeduc)"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_Remuneraciones">
				<qry:xquery>
					for $r in table('
				SELECT  remuneraciones = 
				convert(decimal (9,2), sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 1 THEN liq20_conc_liq_per.n_valor
					 WHEN 9 THEN liq20_conc_liq_per.n_valor
				         WHEN 2 THEN liq20_conc_liq_per.n_valor
					 WHEN 5 THEN liq20_conc_liq_per.n_valor
				         ELSE 0
				      END) )
				,  deducciones = 
				convert(decimal (9,2),sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 3 THEN liq20_conc_liq_per.n_valor
				         WHEN 7 THEN liq20_conc_liq_per.n_valor
				      END) )
				, Resultado = 
				convert(decimal (9,2),sum(CASE liq14_conceptos.oi_tipo_concepto
				         WHEN 1 THEN liq20_conc_liq_per.n_valor
					 WHEN 9 THEN liq20_conc_liq_per.n_valor
				         WHEN 2 THEN liq20_conc_liq_per.n_valor
					 WHEN 5 THEN liq20_conc_liq_per.n_valor
				         WHEN 3 THEN liq20_conc_liq_per.n_valor
				         WHEN 7 THEN liq20_conc_liq_per.n_valor
				         ELSE 0
				      END) )
				
				FROM liq20_conc_liq_per , liq14_conceptos 
				WHERE 
				liq20_conc_liq_per.oi_tot_liq_per = {#PARAM:@oi_tot_liq_per}
				and liq14_conceptos.oi_concepto = liq20_conc_liq_per.oi_concepto
				and (liq14_conceptos.oi_tipo_concepto in (9,5,3,7,2,1))
				and (liq14_conceptos.ca_fig_recibo in (\'S\',\'I\'))
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="DatosPiedetalle">
						<qry:attribute value="abs($r/@remuneraciones)" name="remuneraciones" type="Nomad.NSystem.String"/>
						<qry:attribute name="deduccciones" value="abs($r/@deducciones)"/>
						<qry:attribute value="abs($r/@Resultado)" name="Resultado"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_pie">
				<qry:xquery>
					for $r in table('
				select 
				 c_cta_bancaria  				,d_banco ,   				   oi_tot_liq_pers
				from liq25_personal_liq, 
				(select oi_sucursal, d_banco 
				from liq22_bancos, liq22_bancos_sucur
				where liq22_bancos.oi_banco = liq22_bancos_sucur.oi_banco)
				as bancoPer right join liq07_personal on
				bancoper.oi_sucursal = liq07_personal.oi_sucursal
				where 
				liq25_personal_liq.oi_personal_emp = liq07_personal.oi_personal_emp
				and oi_tot_liq_pers = {#PARAM:@oi_tot_liq_per}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@c_cta_bancaria " name="c_cta_bancaria" type="Nomad.NSystem.String"/>
					<qry:attribute value="$r/@d_banco " name="d_banco" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
