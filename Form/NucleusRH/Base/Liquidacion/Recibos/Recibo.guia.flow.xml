<flow:flow extends="Nomad.parent.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Recibos.Recibo.Guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Recibos.Recibo.Guia"/>
	<flow:main doc="SOURCE">
		<flow:action name="C2X">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="C2X"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.form"/>
		</flow:action>
		<flow:action name="X2C">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="X2C"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('select OI_TOT_LIQ_PERS,E_NUMERO_LEGAJO, D_APE_Y_NOM 
        from PER02_PERSONAL_EMP, PER01_PERSONAL, liq25_personal_liq, LIQ07_PERSONAL 
        where PER02_PERSONAL_EMP.OI_PERSONAL=PER01_PERSONAL.OI_PERSONAL 
        AND liq07_personal.oi_personal_emp = per02_personal_emp.oi_personal_emp
        AND PER02_PERSONAL_EMP.oi_personal_emp = liq25_personal_liq.oi_personal_emp 
        OI_TOT_LIQ_PERS={#SOURCE:helper-mess/@CODE}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="value"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="code"/>
					<flow:comment>
						qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/
					</flow:comment>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('select OI_TOT_LIQ_PERS, E_NUMERO_LEGAJO, D_APE_Y_NOM 
        from PER02_PERSONAL_EMP, PER01_PERSONAL, liq25_personal_liq, LIQ07_PERSONAL
        where PER02_PERSONAL_EMP.oi_personal_emp = liq25_personal_liq.oi_personal_emp 
        AND liq07_personal.oi_personal_emp = per02_personal_emp.oi_personal_emp
        AND PER02_PERSONAL_EMP.OI_PERSONAL=PER01_PERSONAL.OI_PERSONAL')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="value"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="code"/>
						<flow:comment>
							qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/
						</flow:comment>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('select OI_TOT_LIQ_PERS,E_NUMERO_LEGAJO, D_APE_Y_NOM 
        from PER02_PERSONAL_EMP, PER01_PERSONAL, liq25_personal_liq, LIQ07_PERSONAL 
        where PER02_PERSONAL_EMP.OI_PERSONAL=PER01_PERSONAL.OI_PERSONAL 
        AND liq07_personal.oi_personal_emp = per02_personal_emp.oi_personal_emp
        and PER02_PERSONAL_EMP.oi_personal_emp = liq25_personal_liq.oi_personal_emp 
 				{%? (#SOURCE:helper-mess/@id!='')	{% and OI_TOT_LIQ_PERS= {%=#SOURCE:helper-mess/@id %} %} {% and 1=2 %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="value"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_TOT_LIQ_PERS" name="code"/>
					<flow:comment>
						qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/
					</flow:comment>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.form">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<flow:exit-flow return-path="#RS:ROW[@id={#FORM:ctrl[@id='GRID']/@selectedRow}]"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
