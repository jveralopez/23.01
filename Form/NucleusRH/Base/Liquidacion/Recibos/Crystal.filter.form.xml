<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Liquidacion.Legajo.Legajo.buscar2.form" doc="source" name="ReciboSueldo">
	<form:Title>
		<form:Label style="S3 LCol_w" label="203 - Recibo de Sueldo" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/vgroupDatosCustom">
			<form:Columns width="100%" name="colsc">
				<form:Column width="1%" name="colc1" separation="2" align="left" valign="top">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/empresa"/>
					<form:ComboBox where1="LIQ19_LIQUIDACION.oi_tipo_liq != 7" nvalue="#source:@oi_liquidacion" prev="empresa" name="liquidacion" label="Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1">
						<form:Event name="onchange" action="clearFILTER" runat="client"/>
					</form:ComboBox>
					<form:CheckBox nvalue="#FILTERDATA:@chkOcultarLeyenda" label="Ocultar Leyenda" name="chkOcultarLeyenda"/>
					<form:CheckBox nvalue="#FILTERDATA:@chkInvertir" label="Invertir recibos Empleador/Empleado" name="chkInvertir"/>
					<form:Rower label="Ordenar por" name="rwerOrden" separation="6">
						<form:Combo nvalue="#source:@orden1" name="orden1" flow="NucleusRH.Base.Liquidacion.Recibos.Crystal.atribOrden.form" action="COMBO" required="0" label="Orden" X-POLICY="./FORM/NucleusRH/Base/Personal/Reportes/LegajosPorEmpresa/filter/form/orden">
							<form:Event name="onchange" action="val_orden" runat="client"/>
						</form:Combo>
						<form:Label style="S2 LCol_g" label="y luego por" name="lbl_orden"/>
						<form:Combo flow="NucleusRH.Base.Liquidacion.Recibos.Crystal.atribOrden.form" action="COMBO1" nvalue="#source:@orden2" name="orden2" required="0" X-POLICY="./FORM/NucleusRH/Base/Personal/Reportes/LegajosPorEmpresa/filter/form/orden"/>
					</form:Rower>
				</form:Column>
				<form:Column name="c2" width="100%" separation="2" align="center" valign="top"/>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left">
					<form:ComboBox visible="0" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@empresa" name="empresa" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/empresa">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/empresa/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Recibos/Crystal/filter/form/empresa"/>
						</form:Policies>
					</form:ComboBox>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button label="Aceptar" img="ok" name="btnFILTER" descrip="Ejecuta el reporte" note="Consultar los Legajos seleccionados">
					<form:Event action="Filtrar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SendToServer()
{       
	GetProxy().StoreService().SetUserStore("LIQ_IDsLegajos", array2stringcustom(arrB, "ROWS", "ROW"));
	return true;
}

function Filtrar()
{   
	if (arrFILTER.length==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}
 	               
	FillArray(100);
	
	Ctrl("main").DoEvent("FILTER");
}

function enable_custom_buttons()
{
	if (Ctrl("list2"))
		CtrlEnabled("btnFILTER", Ctrl("list2").TotalRowsCount()?true:false);
}

function ONLOAD_custom()
{
 val_orden();
}
function val_orden() 
{
if (Ctrl('orden1').GetXValue() == "ORG03_UBICACIONES.c_ubicacion" || Ctrl('orden1').GetXValue() == "ORG03_UBICACIONES.d_ubicacion")
 {
 	CtrlEnabled('orden2',true);
 }
else
 {
  CtrlEnabled('orden2',false);
  Ctrl("orden2").SetXValue("");
 } 
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
	<!--form:Event action="ONLOAD_custom" name="onload" runat="client"/-->
	<form:Resources>
		<form:Resource name="qry_autowhere">
			<qry:where>
				$$LEG.oi_personal_emp in (SELECT LIQ25_PERSONAL_LIQ.oi_personal_emp FROM LIQ25_PERSONAL_LIQ WHERE LIQ25_PERSONAL_LIQ.oi_liquidacion={%=SOURCE.liquidacion %} )$$
			</qry:where>
			<qry:params>
				##liquidacion##
			</qry:params>
		</form:Resource>
	</form:Resources>
</form:Form>
