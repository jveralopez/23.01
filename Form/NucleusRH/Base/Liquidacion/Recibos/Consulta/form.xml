				<qry:element name="RESULT">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					LIQ25_PERSONAL_LIQ.oi_personal_emp
				FROM 
					LIQ25_PERSONAL_LIQ
				WHERE 
					LIQ25_PERSONAL_LIQ.oi_personal_emp = {#SOURCE:@oi_personal_emp} 
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<LEGAJO>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:insert-select name="SECURITY" doc-path="."/>
					</LEGAJO>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\' 
				AND NMD_SECURITY.id={#PARAM:@oi_personal_emp}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
