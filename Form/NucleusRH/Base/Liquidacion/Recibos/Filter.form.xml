<form:Form name="dfd" doc="source" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:Label style="S3 LCol_w" align="center" visible="" label="Recibos" name="lblTitulo"/>
	</form:Title>
	<form:Center width="70%">
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl2"/>
		<form:Columns name="dsds">
			<form:Column name="sdds">
				<form:FKInput nvalue="#FILTERDATA:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="45"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" visible="NEW|EDIT" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="blank45"/>
				<form:RowAligner columns="2" name="RAFiltros2">
					<form:Row name="Rcampo2">
						<form:NumberBox xsize="30" width="30" label="Legajo desde" nvalue="#FILTERDATA:@LegajoDesde" name="LegajoDesde" descrip="Legajo desde"/>
						<form:NumberBox xsize="30" width="30" label="Legajo hasta" nvalue="#FILTERDATA:@LegajoHasta" name="LegajoHasta" descrip="Legajo hasta"/>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
		<form:Line width="100%" name="line_1"/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de Ordenaci&#243;n" name="lbl21"/>
		<form:RowAligner columns="2" name="RAcamposOrden">
			<form:Row name="RC1O">
				<form:COMBO nvalue="#source:@ATRIB_ORDEN1" action="COMBO" flow="NucleusRH.Base.Liquidacion.Recibos.atribFiltro.enum" note="" label="" name="cboCampo1"/>
				<form:COMBO nvalue="#source:@ORDEN1" action="COMBO" flow="NucleusRH.Base.Orden.enum" note="AscendenteDecendente" label="" name="cboOrdenCampo1"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="botones">
			<form:Row name="filaBotones">
				<form:Button startvalidate="1" descrip="Ejecutar la consulta" note="" img="play" label="Filtrar" name="btnEjecutar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="EJECUTAR_CLICK"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl7"/>
				<form:Button descrip="Agrega un nuevo registro" note="" img="new" label="Agregar" name="btnAgregar" visible="0" enabled="">
					<form:Event runat="server" name="onclick" action="AGREGAR_CLICK"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
