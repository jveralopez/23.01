<form:Form xmlns:form="nomad_engine.form" name="recibos" extends="nomad.Base.interface.form" doc="source">
	<form:Scripts>
		function validarLoad()
{    
	if (Ctrl('oi_liquidacion').GetXValue() == "") 
	{
		g_CTRLs['oi_tot_liq_per'].SetEnabled(false);
		g_CTRLs['oi_tot_liq_per'].SetCValue("");							
	}
}
				
function validarEmpresa()
{ 
	if (g_CTRLs['oi_empresa'].GetCValue() == "")
		{	
			g_CTRLs['oi_liquidacion'].SetEnabled(false);
			g_CTRLs['oi_tot_liq_per'].SetEnabled(false);
			g_CTRLs['oi_liquidacion'].SetCValue("");							
			g_CTRLs['oi_tot_liq_per'].SetCValue("");							
		} else
			{	
				g_CTRLs['oi_liquidacion'].SetCValue("");
				g_CTRLs['oi_tot_liq_per'].SetCValue("");							
				g_CTRLs['oi_liquidacion'].SetEnabled(true);
				
			}
}         

function validarLiquidacion()
{ 
	if (g_CTRLs['oi_liquidacion'].GetCValue() == "")
		{
			g_CTRLs['oi_tot_liq_per'].SetCValue("");		
			g_CTRLs['oi_tot_liq_per'].SetEnabled(false);
	
		} else
			{	
	
				g_CTRLs['oi_tot_liq_per'].SetCValue("");							
				g_CTRLs['oi_tot_liq_per'].SetEnabled(true);
				
			}
}
	</form:Scripts>
	<form:Title>
		<form:Label visible="EDIT" label="Recibo" style="S3 LCol_w" align="center" name="lbl"/>
		<form:Label visible="COMPLETO" label="Detalle de Conceptos Liquidados" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:FKInput nvalue="#VERREC:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.SISIM.Guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" visible="NEW|EDIT|COMPLETO" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank visible="" width="100%" name="bla4"/>
		<form:FKInput label="N&#250;mero de legajo" name="oi_personal_liq" nvalue="#source:@oi_personal_liq" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Reporte.LegajoLiq.guia.flow">
				<helper-mess liq="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" visible="NEW|EDIT|COMPLETO" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="" note="" img="ok" label="Filtrar" name="btnAccept" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnCancel" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
