<form:Form default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Liquidacion.GeneracionNum.GENERACION" xmlns:form="nomad_engine.form">
	<form:Help>
		<form:Help-title text="Generaciones de Numeros de Recibos" name="TITLE"/>
		<form:Help-descr text="Almacena las generaciones de numeros de recibos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Generaciones de Numeros de Recibos" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner visible="SHOW|LIST" name="buttonlinks">
			<form:Row name="row_top">
				<form:Columns width="100%" name="columns1">
					<form:Column name="col1">
						<form:RowAligner width="100%" name="rowsiter" align="left">
							<form:Row name="rowiter">
								<form:TextBox visible="SHOW" xsize="50" length="100" name="iter_search" label="Buscar" ysize="1" descr="Busca.">
									<form:Event runat="client" name="onpressenter" action="Find"/>
									<form:SButtons>
										<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
											<form:Event runat="client" name="onclick" action="Find"/>
										</form:SButton>
									</form:SButtons>
								</form:TextBox>
							</form:Row>
						</form:RowAligner>
					</form:Column>
				</form:Columns>
			</form:Row>
		</form:RowAligner>
		<form:ListView visible="" paging="1" rows="5" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="dd/mm/yyyy HH:MM" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Generacion" attrname="f_generacion" name="f_generacion"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Empresa" attrname="c_empresa" name="c_empresa"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Liquidacion" attrname="c_liquidacion" name="c_liquidacion"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Numero Desde" attrname="c_num_desde" name="c_num_desde"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Numero Hasta" attrname="c_num_hasta" name="c_num_hasta"/>
				<form:LVColumn additional="###,###,##0" align="right" sorteable="1" width="10px" type="number" label="Act" attrname="Actualizado" name="Actualizado"/>
			</form:LVColumns>
		</form:ListView>
		<form:Line width="100%" name="linea"/>
		<form:Columns name="main_columnsGENERACION">
			<form:Column name="main_columnsGENERACIONcolumn1">
				<form:FKInput nvalue="#FILTERDATA:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="1">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
						<form:SText xsize="10" name="txt2"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.GeneracionNum.LIQUIDACION.Guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}" text10="{this.Text.2}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="1" enabled="SHOW" ysize="1" xsize="30" length="30" label="Numero Desde" nvalue="#FILTERDATA:@d_valor" name="c_num_desde"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" mess="Esta Seguro que desea generar los numeros de recibos para la liquidacion ingresada?" descrip="Ejecutar la Generacion de Numeros de Recibos" name="Ejecutar" visible="SHOW" img="ok" label="Ejecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button name="BACK" img="back" visible="SHOW" descrip="Volver al Menu" label="Volver">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
