<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Parametros.PARAMETRO.edit" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Par&#225;metros" name="GEN_EDIT"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center height="100%" width="95%">
		<form:Blank name="bb1"/>
		<form:Columns name="cols01">
			<form:Column width="50%" name="col01" separation="2" align="center" valign="top">
				<form:TextBox length="100" xsize="50" nvalue="#source:PARAM[@c_parametro='PathForm649']/@d_valor" label="Ruta para almacenar Formularios 649" name="PathForm649"/>
				<form:TextBox length="100" xsize="50" nvalue="#source:PARAM[@c_parametro='PathForm572']/@d_valor" label="Ruta para almacenar Formularios 572" name="PathForm572"/>
				<form:TextBox length="100" xsize="50" nvalue="#source:PARAM[@c_parametro='PathConceptos']/@d_valor" label="Conceptos para base de c&#225;lculo de embargos" name="PathConceptos"/>
				<form:NumberBox precision="0" xsize="12" label="Cantidad de decimales a usar en la liquidaci&#243;n" nvalue="#source:PARAM[@c_parametro='cant_dec_liq']/@d_valor" name="cant_dec_liq"/>
				<form:CheckBox nvalue="#source:PARAM[@c_parametro='AdmNumRec']/@d_valor" label="Administrar N&#250;meros de Recibos" name="AdmNumRec"/>
				<form:NumberBox precision="0" xsize="12" nvalue="#source:PARAM[@c_parametro='ProxNumDesde']/@d_valor" label="Pr&#243;ximo numero de recibo de sueldo" name="ProxNumDesde"/>
				<form:CheckBox nvalue="#source:PARAM[@c_parametro='noValidarCerradas']/@d_valor" label="Omitir validaci&#243;n de liquidaciones cerradas" name="noValidarCerradas"/>
				<form:CheckBox nvalue="#source:PARAM[@c_parametro='PlantillaLibroLey']/@d_valor" label="Utilizar plantilla para Libro de Sueldos" name="PlantillaLibroLey"/>
				<form:CheckBox nvalue="#source:PARAM[@c_parametro='DomicilioLibroLey']/@d_valor" label="Mostrar domicilios en Libro de Sueldos" name="DomicilioLibroLey"/>
				<form:CheckBox nvalue="#source:PARAM[@c_parametro='FamiliaresLibroLey']/@d_valor" label="Mostrar familiares en Libro de Sueldos" name="FamiliaresLibroLey"/>
				<form:CheckBox label="Reporte 215-Liquidaci&#243;n IG para NDOC" name="Reportef1357" nvalue="#source:PARAM[@c_parametro='Reportef1357']/@d_valor" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Parametros/PARAMETRO/edit/form/Reportef1357">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Parametros/PARAMETRO/edit/form/Reportef1357/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Parametros/PARAMETRO/edit/form/Reportef1357"/>
					</form:Policies>
				</form:CheckBox>
				<form:CheckBox label="Mostrar Remuneraci&#243;n B&#225;sica en Libro de Sueldos" name="RemuneracionLibroLey" nvalue="#source:PARAM[@c_parametro='RemuneracionLibroLey']/@d_valor"/>
				<form:CheckBox label="Mostrar Total de Anticipos en Resumen del Libro de Sueldos" name="DetalleAnticipo" nvalue="#source:PARAM[@c_parametro='DetalleAnticipo']/@d_valor"/>
				<form:Rower name="rr1" label="Flow para abrir desde el legajo">
					<form:TextBox length="100" xsize="50" nvalue="#source:PARAM[@c_parametro='flowPivot']/@d_valor" name="flowPivot"/>
					<form:Label label=" (no modificar)" style="S2 LCol_t" dynamic="0" name="ll1"/>
				</form:Rower>
				<form:Rower label="Flow para abrir los recibos desde el legajo" name="rr2">
					<form:TextBox length="100" xsize="50" nvalue="#source:PARAM[@c_parametro='flowRecibos']/@d_valor" name="flowRecibos"/>
					<form:Label label=" (no modificar)" style="S2 LCol_t" dynamic="0" name="ll1"/>
				</form:Rower>
			</form:Column>
			<form:Column width="50%" name="col02" separation="2" align="center" valign="top">
				<form:TextBox label="Int. F.1357 C&#243;digo de impuesto" xsize="10" name="F1357CodImpuesto" nvalue="#source:PARAM[@c_parametro='F1357CodImpuesto']/@d_valor" length="5"/>
				<form:TextBox label="Int. F.1357 C&#243;digo de concepto" nvalue="#source:PARAM[@c_parametro='F1357CodConcepto']/@d_valor" name="F1357CodConcepto" length="3" xsize="10"/>
				<form:TextBox label="Int. F.1357 N&#250;mero de formulario" xsize="10" name="F1357NroForm" nvalue="#source:PARAM[@c_parametro='F1357NroForm']/@d_valor" length="4"/>
				<form:TextBox label="Int. F.1357 Versi&#243;n del sistema" nvalue="#source:PARAM[@c_parametro='F1357VerSistema']/@d_valor" name="F1357VerSistema" length="5" xsize="10"/>
				<form:NumberBox label="Int. F.1357 Legajos con ingresos iguales o superiores a" width="15" max="0" min="0" name="F1357IngresosMaximos" nvalue="#source:PARAM[@c_parametro='F1357IngresosMaximos']/@d_valor"/>
				<form:NumberBox label="Int. F.1359 Legajos con ingresos iguales o superiores a" width="15" max="0" min="0" name="F1359IngresosMaximos" nvalue="#source:PARAM[@c_parametro='F1359IngresosMaximos']/@d_valor"/>
				<form:TextBox label="Int. F2122 Versi&#243;n del sistema" nvalue="#source:PARAM[@c_parametro='F2122VerSistema']/@d_valor" name="F2122VerSistema" length="5" xsize="10"/>
				<form:NumberBox label="Int. F2122 Legajos con ingresos iguales o superiores a" width="15" max="0" min="0" name="F2122IngresosMaximos" nvalue="#source:PARAM[@c_parametro='F2122IngresosMaximos']/@d_valor"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Organizacion/Parametros/EDIT" descrip="Guardar los cambios" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" label="Cancelar" name="CANCEL" policy="NucleusRH/Base/Organizacion/Parametros/NEW" descrip="Cancelar la edici&#243;n">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
