		function CALL_VAL_VAREF()
{
set_oi();
Ctrl('main').DoEvent('CALL:VAL_VAREF');
}


function CALL_VAL_VAREA()
{
set_oi();
Ctrl('main').DoEvent('CALL:VAL_VAREA');
}

function CALL_VAL_VARPA()
{
set_oi();
Ctrl('main').DoEvent('CALL:VAL_VARPA');
}


function set_oi()
{
if (Ctrl('LIST'))
Ctrl('oi').SetXValue(Ctrl('LIST').GetXValue());
else
Ctrl('oi').SetXValue(Ctrl('oi_ddo').GetXValue());
}

function refresh()
{
Ctrl('main').DoEvent('REFRESH');
}

function validate(me)
{
if (me.GetXValue() == "")
{
me.SetError("No tiene categoria cargada. Debe ir al legajo de la persona y cargarla.");
return false;
}else
{ 
return true;
}
} 

//Navegabilidad a Legajo Empresa   
function verLegajo()
{                                   
if(Ctrl("main").GetMode()=="LIST")     
getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+Ctrl("LIST").GetSelectAttrValue("id").toString()+"\" /&gt;", false);    
else
getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+Ctrl("oi_personal_emp").GetXValue()+"\" /&gt;", false); 	
}
     
//Navegabilidad a Empresa   
function verEmpresa()
{         
if(Ctrl("main").GetMode()=="LIST")       
{
var np = new NomadProxy("",ut);
var nSQL =  np.SQLService();
var empresa= nSQL.GetOBJ(Ctrl("main").getResource("QRY_EMPRESA"),"&lt;PARAM oi_personal_emp=\""+Ctrl("LIST").GetSelectAttrValue("id").toString()+"\" /&gt;");
getFormInMain("NucleusRH.Base.Organizacion.Empresas.NAV.flow", "filter",  "&lt;EMPRESA VALUE=\""+empresa.oi_empresa.toString()+"\" /&gt;", false);
}	
else
getFormInMain("NucleusRH.Base.Organizacion.Empresas.NAV.flow", "filter",  "&lt;EMPRESA VALUE=\""+Ctrl("oi_empresa").GetXValue()+"\" /&gt;", false);
}                       

//Navegabilidad a Administrar Liquidaciones
function verAdministrarLiquidaciones()
{   
getFormInMain("NucleusRH.Base.Liquidacion.Liquidacion.flow", "initialize",  "", false);
}           


function onload()
{      
	if(Ctrl('img_ojo') != undefined)
	{
	    if(Ctrl('main').GetMode() == "SHOW" || Ctrl('main').GetMode() == "EDIT")
		{
		    if(!Ctrl('img_ojo').GetEnabled() &amp;&amp; Ctrl('l_confidencial').GetXValue() == "1")
			{           
			
				CtrlEnabled('DISTRIB_COS',false); 
				CtrlEnabled('VAL_VAREF',false); 
				CtrlEnabled('VAL_VAREA',false); 
				CtrlEnabled('PARAM_PER',false);   
				CtrlEnabled('VAL_VARPA',false);
				CtrlEnabled('OTROS_EMP',false); 
				CtrlEnabled('CARGOS',false); 
				     
				CtrlEnabled('VAL_VAREF_EDIT',false); 
				CtrlEnabled('VAL_VAREA_EDIT',false); 
				CtrlEnabled('VAL_VARPA_EDIT',false);  
				
				Ctrl('n_ult_remun').SetCValue(" ");
				Ctrl('f_desde_remun').SetXValue(" "); 
				Ctrl('oi_categoria_ult').SetCValue(" "); 
				
				}                               
				else
				 {
				CtrlEnabled('DISTRIB_COS',true); 
				CtrlEnabled('VAL_VAREF',true); 
				CtrlEnabled('VAL_VAREA',true); 
				CtrlEnabled('PARAM_PER',true);   
				CtrlEnabled('VAL_VARPA',true);
				CtrlEnabled('OTROS_EMP',true); 
				CtrlEnabled('CARGOS',true); 
				     
				CtrlEnabled('VAL_VAREF_EDIT',true); 
				CtrlEnabled('VAL_VAREA_EDIT',true); 
				CtrlEnabled('VAL_VARPA_EDIT',true); 
			 }
		}  
	}      
	 

}
	</form:Scripts>
	<form:Resources>
		<form:Resource name="QRY_EMPRESA" declare="&lt;PARAM oi_personal_emp=&quot;1&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_empresa
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp} 
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="onload" name="onload" runat="client"/>
