<flow:flow xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Legajo.LegajoLiq.guia">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Legajo.LegajoLiq.LM.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
					pe.OI_PERSONAL_EMP,
					pe.E_NUMERO_LEGAJO,
					p.D_APE_Y_NOM,
					e.c_empresa,
					e.d_empresa
				FROM
					PER02_PERSONAL_EMP as pe,
					org03_empresas as e,
					PER01_PERSONAL as p
				WHERE
					pe.oi_empresa = e.oi_empresa 
					and pe.OI_PERSONAL = p.OI_PERSONAL 
					AND {%? (string(#SOURCE:helper-mess/rows/row/@oi_personal_emp)!='') {%  pe.OI_PERSONAL_EMP in ({%=string(#SOURCE:helper-mess/rows/row/@oi_PERSONAL_EMP) %}) %} {% 1 = 2 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_empresa" name="codEmpresa"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_empresa" name="dscEmpresa"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="1" name="check"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
				SELECT
					pe.OI_PERSONAL_EMP,
					pe.E_NUMERO_LEGAJO,
					p.D_APE_Y_NOM,
					e.c_empresa,
					e.d_empresa
				FROM
					PER02_PERSONAL_EMP as pe,
					org03_empresas as e,
					PER01_PERSONAL as p
				WHERE
					pe.oi_empresa = e.oi_empresa 
					and pe.OI_PERSONAL = p.OI_PERSONAL 
					AND  {%? (string(#SOURCE:helper-mess/rows/row/@OI_PERSONAL_EMP)!='') {%  pe.OI_PERSONAL_EMP not in ({%=string(#SOURCE:helper-mess/rows/row/@OI_PERSONAL_EMP) %}) %} {% 1 = 1 %} %}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@OI_PERSONAL_EMP" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_empresa" name="codEmpresa"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_empresa" name="dscEmpresa"/>
						<qry:attribute type="Nomad.NSystem.Boolean" value="0" name="check"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@id" name="oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Legajo.LegajoLiq.LM.guia.form">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="OUT" input-doc-path="#SOURCE:" qry="PRUEBA"/>
			<!--flow:log text="nachonachonachonacho" text-path="#OUT:"/-->
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<!-- flow:exit-flow/ -->
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
