<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Legajo.Legajo.CARGA_MASIVA" doc="source">
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="SAVE" img="save" descrip="Guardar un Registro" label="Guardar">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|LIST|DELETE|EDIT|LIST_EDIT" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="0">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Center width="95%">
		<form:Columns name="main_columnsCM">
			<form:Column visible="SHOW|EDIT|NEW" name="main_columnsCMcolumn1">
				<form:Blank name="BLANK12"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipo_Anticipo.TIPO_ANTICIPO.Combo.autoflow" required="0" enabled="NEW|EDIT" label="Tipo de anticipo" nvalue="#source:@oi_tipo_anticipo" name="oi_tipo_anticipo"/>
				<form:DateTime name="f_solicitud" nvalue="#source:@f_solicitud" label="Fecha de Solicitud" pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="validateFecha" name="onvalidate" runat="client"/>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Anticipo" nvalue="#source:@f_anticipo" name="f_anticipo">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox name="n_importe" nvalue="#source:@n_importe" label="Importe" precision="3" xsize="15" mask="###.###.##0.00" descr="Importe pendiente de descontar." required="1"/>
				<form:NumberBox required="1" enabled="0" descr="Cantidad de cuotas que se va a descontar el anticipo" mask="###.###.##0" xsize="12" max="100" min="1" label="Cantidad de Cuotas" nvalue="#source:@e_cant_cuotas" name="e_cant_cuotas"/>
				<form:DateTime pattern="YYYYMM" required="1" mask="dd/mm/yyyy" label="Per&#237;odo a Comenzar Descuento" nvalue="#source:@e_periodo" name="e_periodo">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo action="COMBO" nvalue="#source:@e_quincena" name="e_quincena" label="Quincena a comenzar descuento" flow="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.ANTICIPO.e_quincena.Combo.autoflow"/>
				<form:CheckBox name="l_liquida" nvalue="#source:@l_liquida" label="Se liquida autom&#225;ticamente?" required="1"/>
				<form:CheckBox label="Solo los marcados con dato fijo (fp_cargaanticipo)" nvalue="#source:@fp_cargaanticipos" name="fp_cargaanticipos">
					<form:Event action="OnChange" name="onchange" runat="client"/>
				</form:CheckBox>
				<form:Combo nvalue="#source:@EMPRESA" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:Blank name="BLANK11"/>
				<form:Grid proto="&lt;LEGAJO/&gt;" nvalue="#source:LEGAJOS" idvalue="#SOURCEGRILLA:@id" width="485px" name="grdPersonal" note="" descrip="" rows="6" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.LM.guia.flow" action="HELP">
						<helper-mess oi_empresa="{oi_empresa.ReadXValue}">
							{grdPersonal.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput label="Legajo" required="0" enabled="" xsize="15" length="30" nvalue="#SOURCEGRILLA:@id" name="oi_personal_emp">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.EMPRESA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess oi_empresa="{oi_empresa.ReadXValue}" text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Hidden nvalue="#source:@c_estado" name="c_estado"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function onLoad()
{       
	var hoy =date2str(NowDate());
	Ctrl('f_solicitud').SetXValue(hoy);
	Ctrl('f_anticipo').SetXValue(hoy);
	Ctrl('l_liquida').SetCValue("1");     
	Ctrl('e_cant_cuotas').SetCValue("1");
	Ctrl('c_estado').SetCValue("O");
}                      

function OnChange()
{
  if (Ctrl('fp_cargaanticipos').GetCValue() == "1")
	{
		CtrlEnabled('grdPersonal',false);
	}else 
	{
		CtrlEnabled('grdPersonal',true);
	} 
}        

function validateFecha()
{ 
var bandera = 0;
if (Ctrl('f_solicitud').GetXValue() &gt; Ctrl('f_anticipo').GetXValue())
	bandera = 1;
if (bandera == 1)
{	
	Ctrl('f_solicitud').SetError("La Fecha de Solicitud no puede ser mayor a la Fecha de Anticipo");
	return false;
}
	else return true;	
}
	</form:Scripts>
	<form:Right visible="0">
		<form:VGroup label="Dependencias" collapse="1" width="90%" name="vgChildsANTICIPO">
			<form:Link enabled="EDIT|NEW|SHOW|LIST" allowimg="1" policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/DESC_ANTICIPO/READ" visible="EDIT|SHOW|LIST|LIST_EDIT|DELETE" descrip="Registro del detalle o plan de pago del anticipo que es otorgado a una persona." label="Descuentos de Anticipos" name="DESC_ANTI">
				<form:Event policy="NucleusRH/Base/Liquidacion/Legajo_Liquidacion/DESC_ANTICIPO/EDIT" action="CALL:DESC_ANTICIPO" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Event action="onLoad" name="onload" runat="client"/>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Carga Masiva de Anticipos" nowrap="1" align="center" style="S3 LCol_w" name="GEN_EDIT"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
</form:Form>
