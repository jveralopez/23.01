<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.OTROS_EMP.autoform" name="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.OTROS_EMP.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Scripts>
		function cambioPeriodo()
{
	 
	for(i = 0; i &lt; Ctrl('MAIN_GRID').RowsCount();i++)
	{   
		var periodo = Ctrl('MAIN_GRID').GetCellXValue('e_periodo',i);
		if(periodo.length != 4 || isNaN(parseInt(periodo,10)) || parseInt(periodo,10) &lt; 0)  
		{
		    alert('El periodo Debe ser un a&#241;o');   
		    Ctrl('MAIN_GRID').SetCellXValue('e_periodo',i,'');
	 		return false;
	 	} 
	}   
}
	</form:Scripts>
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label=" " name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcolc_cuit">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="CUIT" nvalue="#source:@c_cuit" name="c_cuit"/>
				</form:GColumn>
				<form:GColumn name="gcold_denominacion">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Denominaci&#243;n" nvalue="#source:@d_denominacion" name="d_denominacion"/>
				</form:GColumn>
				<form:GColumn name="gcole_periodo">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Per&#237;odo" nvalue="#source:@e_periodo" name="e_periodo">
						<form:Event action="cambioPeriodo" name="onChange" runat="client"/>
					</form:NumberBox>
				</form:GColumn>
				<form:GColumn name="gcoll_agente">
					<form:CheckBox label="Es Agente Retenci&#243;n" required="0" enabled="NEW|EDIT" nvalue="#source:@l_agente" name="l_agente"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
</form:Form>
