<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="intentrada" doc="source">
	<form:Title>
		<form:Label label="Interface de Salida para Sindicatos" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Combo flow="NucleusRH.Base.Liquidacion.Interface.EMPRESA_DDO.combo.flow" action="COMBO" required="1" nvalue="#source:@c_empresa" name="empresa" label="Empresa"/>
		<form:FKInput nvalue="#source:@oi_sindicato" label="Sindicato" name="oi_sindicato" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess interface="{interface.XValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event action="cambiocombo" runat="client" name="onchange"/>
		</form:FKInput>
		<form:Hidden name="interface" nvalue="#source:@interface"/>
		<form:ComboBox enabled="0" required="1" nvalue="#source:@inteface2" name="interface2" prev="interface" label="Interface" mode="QRY" queryname1="NucleusRH.Base.Personal.Sindicatos.SINDICATO.INTERFACES"/>
		<form:DateTime nvalue="#source:@p_periodo" name="p_periodo" label="Periodo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ClearSucursal()
{                     
	Ctrl("oi_sucursal").SetCValue("");
	Ctrl("oi_sucursal_interface").SetCValue("");
}

function ClearLiquidacion()
{                                              
	Ctrl("grdDatosLiq").DelAllRows();
}

function EJECUTAR_CLICK()
{                                    
	if (Ctrl("interface").GetXValue()=="") { alert("El Sindicato no tiene ninguna interface asociada."); return false; }
	
	if (!Ctrl("main").Validate()) return false;
	 
	Ctrl('interface').SetXValue(Ctrl('interface2').GetXValue()); 
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}                      

function cambiocombo()
{
	if(Ctrl('interface2').GetXValue()=='')
	{   
	  inter = Ctrl('interface').GetXValue();
	  if(inter != '')
	  {
	     inter = inter.split(',')[0];     
	     Ctrl("interface2").SetXValue(inter);
	  }
	}
	    
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
	<form:Event action="cambiocombo" name="onload" runat="client"/>
</form:Form>
