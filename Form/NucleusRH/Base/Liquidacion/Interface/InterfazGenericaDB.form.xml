<form:Form xmlns:form="nomad_engine.form" default_mode="LOAD_AL" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" name="Interfaz de Entrada desde la Base de Datos" doc="source">
	<form:Title>
		<form:Label name="lbl_titulo" label="Importar de Variables desde la Base de Datos" style="S3 LCol_w" align="center" visible=""/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsemps">
				<form:Column separation="2" align="center" name="col1" valign="top">
					<form:ComboBox nvalue="#source:@oi_empresa" visible="LOAD_FL|LOAD_AL|LOAD_APL|LOAD_NL|LOAD_NLR" enabled="0" xsize="40" mode="QRY" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" required="1" label="Empresa" name="empresa">
						<options/>
					</form:ComboBox>
					<form:ComboBox nvalue="#source:@oi_liquidacion" visible="LOAD_NL|LOAD_NLR" enabled="0" where1="isNull(LIQ19_LIQUIDACION.f_cierre)" xsize="40" mode="QRY" prev="empresa" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" label="Liquidaci&#243;n" name="Liquidacion" required="0">
						<options/>
					</form:ComboBox>
				</form:Column>
				<form:Column separation="10" width="40px" name="colsep" align="center" valign="top"/>
				<form:Column separation="2" align="center" name="col2" valign="top">
					<form:ComboBox label="Variable Fija" xsize="30" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" visible="LOAD_FL" where1="LIQ09_VARIABLES.c_tipo_variable='3'" mode="QRY" required="1" nvalue="#source:@VAR" name="VAR">
						<options/>
					</form:ComboBox>
					<form:ComboBox label="Acumulador" xsize="30" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" visible="LOAD_AL" where1="LIQ09_VARIABLES.c_tipo_variable='5'" mode="QRY" required="1" nvalue="#source:@VAR" name="VAR">
						<options/>
					</form:ComboBox>
					<form:ComboBox label="Acumulador" visible="LOAD_APL" xsize="30" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" where1="LIQ09_VARIABLES.c_tipo_variable='9'" mode="QRY" required="1" nvalue="#source:@VAR" name="VAR">
						<options/>
					</form:ComboBox>
					<form:ComboBox label="Novedad" xsize="30" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" visible="LOAD_NL" where1="LIQ09_VARIABLES.c_tipo_variable='1'" mode="QRY" required="1" nvalue="#source:@VAR" name="VAR">
						<options/>
					</form:ComboBox>
					<form:ComboBox visible="LOAD_NLR" where1="LIQ09_VARIABLES.c_tipo_variable='10'" label="Novedad Retroactiva" xsize="30" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" mode="QRY" required="1" nvalue="#source:@VAR" name="VAR">
						<options/>
					</form:ComboBox>
					<form:ComboBox xsize="20" mode="OPT" required="1" nvalue="#source:@MOD" label="Modo" name="MOD">
						<options>
							<option text="Valor Fijo" value="FI"/>
							<option text="Cargar desde la DB" value="DB"/>
						</options>
					</form:ComboBox>
					<form:NumberBox length="10" required="1" precision="2" nvalue="#source:@VAL" descrip="Valor" label="Valor" name="VAL"/>
					<form:Rower label="Periodos" visible="LOAD_APL" separation="5" name="PERIODOS" required="1">
						<form:DateTime nvalue="#source:@PER_DES" name="PER_DES" pattern="YYYYMM" required="1"/>
						<form:DateTime nvalue="#source:@PER_HAS" name="PER_HAS" pattern="YYYYMM" required="1"/>
					</form:Rower>
					<form:DateTime label="Periodo" visible="LOAD_NLR" nvalue="#source:@PER" name="PER" pattern="YYYYMM" required="1"/>
				</form:Column>
				<form:Column width="60%" name="col3" separation="2" align="center" valign="top"/>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Interface/InterfazGenericaDB/form/vgroupDatosPers">
			<form:Policies>
				<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Interface/InterfazGenericaDB/form/vgroupDatosPers/HAB"/>
				<form:Visible X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Interface/InterfazGenericaDB/form/vgroupDatosPers"/>
			</form:Policies>
			<form:Columns visible="0" name="colsemps" width="100%"/>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="95%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button name="btnLOAD" img="table_go" descrip="Carga las Variables Limpiando previamente la Lista." label="Cargar" visible="" enabled="" startvalidate="1">
					<form:Event action="LOAD" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnBack" visible="" enabled="">
					<form:Event action="BACK" name="OnClick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function LOAD()
{
	FillArray(100);
	Ctrl("main").DoEvent("LOAD");
}
	</form:Scripts>
	<form:Event action="LOAD" name="LOAD" runat="server"/>
</form:Form>
