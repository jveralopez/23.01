<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.flow" name="Nomad.Base.Liquidacion.Liquidacion">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Liquidacion">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="PAGE">
			<PAGE oi_empresa="" oi_liquidacion="" num="0"/>
		</doc:define>
		<doc:define name="BLANK">
			<PAGE oi_empresa="" oi_liquidacion="" num="0"/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<PAGE>
				<PERSONAS/>
			</PAGE>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenerica.form" doc-path="#PAGE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenerica.form" name="NucleusRH.Base.Liquidacion.Interface.InterfazGenerica.form:EDIT" mode="SHOW" doc="SOURCE">
		<flow:action name="EXECUTE">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="Execute" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="7"/>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Refresh">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="ToPage">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-attr-path="#FORM:ctrl[@id='topage']/@xval" to-attr-path="#BLANK:@num"/>
			<doc:assign-value to-doc="PAGE" from-path="#BLANK:"/>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Clean">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="Clean">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Reset">
			<doc:assign-value to-doc="PAGE" from-path="#BLANK:"/>
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="LOAD_FE">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param name="Consulta" value="LOAD_FE" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="LOAD_NE">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param value="LOAD_NE" type="Nomad.NSystem.String" mode="in" name="Consulta"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="LOAD_FL">
			<doc:set-attribute to-attr-path="#FILTERDATA:@VAR" from-value=""/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_empresa" from-attr-path="#PAGE:@oi_empresa"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_liquidacion" from-attr-path="#PAGE:@oi_liquidacion"/>
			<flow:open-form mode="LOAD_FL" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form"/>
		</flow:action>
		<flow:action name="LOAD_AL">
			<doc:set-attribute to-attr-path="#FILTERDATA:@VAR" from-value=""/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_empresa" from-attr-path="#PAGE:@oi_empresa"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_liquidacion" from-attr-path="#PAGE:@oi_liquidacion"/>
			<flow:open-form mode="LOAD_AL" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form"/>
		</flow:action>
		<flow:action name="LOAD_APL">
			<doc:set-attribute to-attr-path="#FILTERDATA:@VAR" from-value=""/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_empresa" from-attr-path="#PAGE:@oi_empresa"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_liquidacion" from-attr-path="#PAGE:@oi_liquidacion"/>
			<flow:open-form mode="LOAD_APL" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form"/>
		</flow:action>
		<flow:action name="LOAD_NL">
			<doc:set-attribute to-attr-path="#FILTERDATA:@VAR" from-value=""/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_empresa" from-attr-path="#PAGE:@oi_empresa"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_liquidacion" from-attr-path="#PAGE:@oi_liquidacion"/>
			<flow:open-form mode="LOAD_NL" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form"/>
		</flow:action>
		<flow:action name="LOAD_NLR">
			<doc:set-attribute to-attr-path="#FILTERDATA:@VAR" from-value=""/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_empresa" from-attr-path="#PAGE:@oi_empresa"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@oi_liquidacion" from-attr-path="#PAGE:@oi_liquidacion"/>
			<flow:open-form mode="LOAD_NLR" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form"/>
		</flow:action>
		<flow:action name="IMPORT_FILE">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaFILE.form" mode="SHOW" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form:LOAD_FL" mode="LOAD_FL" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param name="Consulta" value="LOAD_FL" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form:LOAD_AL" mode="LOAD_AL" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param name="Consulta" value="LOAD_AL" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form:LOAD_APL" mode="LOAD_APL" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param value="LOAD_APL" name="Consulta" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form:LOAD_NL" mode="LOAD_NL" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param value="LOAD_NL" name="Consulta" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form:LOAD_NLR" mode="LOAD_NLR" form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaDB.form" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="CargarVariables">
				<flow:param value="LOAD_NLR" name="Consulta" type="Nomad.NSystem.String" mode="in"/>
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaFILE.form" name="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaFILE.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="LOAD">
			<flow:exec-method out-attr-path="#BATCHDOC:@batch-id" priority="7" class="NucleusRH.Base.Liquidacion.InterfaceVariablesGenerica.ENTRADA" method="ImportarArchivo">
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlPage"/>
			</flow:exec-method>
			<flow:close-form/>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form next-action="Reset"/>
		</flow:action>
	</flow:form>
</flow:flow>
