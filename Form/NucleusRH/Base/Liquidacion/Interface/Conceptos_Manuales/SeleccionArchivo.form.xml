<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interface.Conceptos_Manuales.SeleccionArchivo.form" default_mode="EDIT">
	<form:Scripts/>
	<form:Title>
		<form:Label label="Interfaz de Conceptos Manuales" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center>
		<form:Columns name="ColsCenter">
			<form:Column name="col01">
				<form:Blank name="blank02"/>
				<form:FKInput name="oi_liquidacion" nvalue="#DATOSLIQ:@oi_liquidacion" label="Liquidaci&#243;n" length="30" xsize="15" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_INICIALIZADA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
						<helper-mess code="{oi_liquidacion.CVal}" id="{oi_liquidacion.XVal}" text="{oi_liquidacion.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="blank03"/>
				<form:File nvalue="#DATOSLIQ:@file_name" class="INTERFACES" filename="IntItemsGan.dat" required="1" source="1" name="filArchivo" label="Archivo de interface">
					<form:SButtons>
						<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Blank name="blank031"/>
				<form:Container name="contTexto" rheight="400px" rwidth="700px" label="Aclaraciones" borderwidth="1">
					<form:RowAligner name="dddd">
						<form:Row name="a1">
							<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a2">
							<form:Blank name="blank031"/>
							<form:Label label="Legajo;CodigoConcepto;Valor;Cantidad;CodigoCentrodeCosto" name="formato1"/>
						</form:Row>
						<form:Row name="a3">
							<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a4">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- El legajo debe estar inicializado en la liquidaci&#243;n seleccionada"/>
						</form:Row>
						<form:Row name="a5">
							<form:Blank name="blank031"/>
							<form:Label name="validacion2" label="- El C. de Costo debe ser el asociado al legajo o pertenecer a la Distribuci&#243;n de C. de Costos"/>
						</form:Row>
						<form:Row name="importe1">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="- El Valor y la Cantidad deben:"/>
						</form:Row>
						<form:Row name="importe2">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* Ser num&#233;rico (entero o decimal)"/>
						</form:Row>
						<form:Row name="importe5">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion32" label="* No debe contener letras o palabras ya que pueden agregarse valores indeseados"/>
						</form:Row>
						<form:Row name="importe3">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* El separador decimal debe ser punto"/>
						</form:Row>
						<form:Row name="importe4">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* Sin separador de miles"/>
						</form:Row>
						<form:Row name="a7">
							<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="1;91000019;80;10.80;104401"/>
						</form:Row>
						<form:Row name="a9">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="7;93954995;81;11;"/>
						</form:Row>
						<form:Row name="a11">
							<form:Blank name="blank038"/>
							<form:Label name="ejemplo3" label="8;93955000;82;12;"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
