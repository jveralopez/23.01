<flow:flow extends="Nomad.combo.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interfase_Contable.DET_INT_CONT.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Interfase_Contable.DET_INT_CONT"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in FILEIO('INTERFACE-DEF\\legales.def.xml')/INTERFACE-TYPE/INTERFACE
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@code" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@code" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@code" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@code+'-'+$r/@desc" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
