<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Nomad.Base.Liquidacion.Interface.Sicore.flow" default_action="initialize" extends="Nomad.Base.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Liquidacion">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA interface="SICORE.SICORE.GENERICO">
				<LIQS/>
			</DATA>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Sicore-Interface" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.Sicore.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.Sicore.form" name="NucleusRH.Base.Liquidacion.Interface.Sicore.form:EDIT" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:save-user-data name="Sicore-Interface" doc-path="#FILTERDATA:"/>
			<flow:exec-method method="InterfaceSalida" class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="9">
				<flow:param value="SICORE" mode="in" name="interfaceTIPO" type="Nomad.NSystem.String"/>
				<flow:param value="SICORE" mode="in" type="Nomad.NSystem.String" name="interdaceID"/>
				<flow:param doc-path="#FILTERDATA:" type="Nomad.NSystem.Object" mode="in" name="parametros"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.Base.Batch.Download.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
