<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interface.Sicore.form" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="Interfaz con Aplicativo SI.CO.RE" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:ComboBox nvalue="#source:@oi_empresa" label="Empresa" name="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1">
			<form:Event action="change_parent" name="onchange" runat="client"/>
		</form:ComboBox>
		<form:DateTime nvalue="#source:@e_periodo" name="e_periodo" label="Per&#237;odo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="client" name="onchange" action="change_parent"/>
		</form:DateTime>
		<form:Blank visible="" width="100%" name="bl5"/>
		<form:Grid width="450px" nvalue="#source:LIQS" proto="&lt;LIQ/&gt;" idvalue="#ROW:@id" doc="ROW" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="5" descrip="" note="" name="grdDatosLiq">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:ComboBox queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO_IG_EMP_PER" xsize="60" prev="parent" mode="QRY" required="1" nvalue="#ROW:@id" label="Liquidaci&#243;n" name="oi_liquidacion"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Hidden nvalue="#source:@parent" name="parent"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="1">
					<form:Event action="EJECUTAR_CLICK" runat="server" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function change_parent()
{
	Ctrl('parent').SetXValue(Ctrl('oi_empresa').GetXValue() + '_' + Ctrl('e_periodo').GetXValue());
	Ctrl('grdDatosLiq').DelAllRows();
}
	</form:Scripts>
</form:Form>
