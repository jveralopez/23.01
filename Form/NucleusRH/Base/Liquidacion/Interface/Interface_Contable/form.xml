<form:Form xmlns:form="nomad_engine.form" doc="SOURCE" name="Interface Contable" extends="nomad.Base.interface.form">
	<form:Title>
		<form:Label name="lbl" style="S3 LCol_w" label="Ejecutar Interface Contable"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#SOURCE:@oi_empresa" name="oi_empresa"/>
		<form:Blank name="b1" width="100%" visible=""/>
		<form:DateTime pattern="YYYYMM" required="1" enabled="" nvalue="#SOURCE:@e_periodo" mask="mm/yyyy" label="Periodo" name="e_periodo">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="bl31" width="100%" visible=""/>
		<form:FKInput name="oi_interface_contable" nvalue="#SOURCE:@oi_interface_contable" label="Interface Contable" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Interfase_Contable.INT_CONT.guia.autoflow">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" visible="NEW|EDIT" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
</form:Form>
