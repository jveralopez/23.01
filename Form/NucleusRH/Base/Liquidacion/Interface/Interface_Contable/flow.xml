<flow:flow extends="Nomad.Base.interface.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="Nomad.Base.Liquidacion.interface.Interface_contable">
	<flow:info label="Flow para Nomad.Base.Liquidacion.interface.Interface_contable">
		Flow para Nomad.Base.Liquidacion.interface.Interface_contable
	</flow:info>
	<flow:declare>
		<doc:define name="RESULTADO">
			<DATOS Periodo="" oi_empresa="" oi_interface_contable=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Interface.Interface_Contable.form"/>
		</flow:action>
	</flow:main>
	<flow:form extends="Nomad.Base.Interface.form:EDIT" name="NucleusRH.Base.Liquidacion.Interface.Interface_Contable.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Interface.Interface_Contable.form" doc="SOURCE" mode="EDIT">
		<flow:action name="ACCEPT">
			<doc:assign-mapping a-doc="FORM" b-doc="RESULTADO" dir-apply="a-&gt;b">
				<map docA="A" docB="B">
					<link A="#A:ctrl[@id='oi_empresa']/@xval" B="#B:@oi_empresa"/>
					<link A="#A:ctrl[@id='e_periodo']/@xval" B="#B:@Periodo"/>
					<link A="#A:ctrl[@id='oi_interface_contable']/@xval" B="#B:@oi_interface_contable"/>
				</map>
			</doc:assign-mapping>
			<flow:comment>
				<flow:log text="Esteban" text-path="#RESULTADO:"/>
			</flow:comment>
			<flow:exec-method priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id" method="EjecutarICBach" class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA">
				<flow:param name="param" mode="in" doc="RESULTADO"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
