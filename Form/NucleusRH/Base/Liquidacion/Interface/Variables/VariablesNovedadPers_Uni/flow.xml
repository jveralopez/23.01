<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.flow" extends="Nomad.Base.flow" description="Flow para la carga de interfaces de variables de novedad para las personas." default_action="initialize">
	<flow:info label="Flow para la carga de interfaces de variables de novedad para las personas."/>
	<flow:declare>
		<doc:define name="DATOSLIQ">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Int_VariablesNovedadPers_Uni" doc="DATOSLIQ"/>
			<doc:set-attribute to-attr-path="#DATOSLIQ:@file_name" from-value=""/>
			<flow:open-form doc-path="#DATOSLIQ:" form-class="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.SeleccionArchivo.form" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="SeleccionArchivo">
		<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.SeleccionArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.SeleccionArchivo.form" doc="SOURCE" mode="EDIT">
			<flow:action name="VOLVER">
				<flow:exit-flow return-path="#DATOSLIQ:"/>
			</flow:action>
			<flow:action name="EJECUTAR">
				<flow:save-user-data name="Int_VariablesNovedadPers_Uni" doc-path="#DATOSLIQ:"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceEntradaNov.ENTRADA" out-attr-path="#DATOSLIQ:@batch-id" priority="5" method="ImportarVariables">
					<flow:param attr-path="#DATOSLIQ:@oi_liquidacion" name="poi_liquidacion" type="Nomad.NSystem.String" mode="in"/>
					<flow:param attr-path="#DATOSLIQ:@Codigo_oculto" type="Nomad.NSystem.String" name="pC_Variable" mode="in"/>
				</flow:exec-method>
				<flow:open-form doc-path="#DATOSLIQ:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group name="VisualizacionArchivo">
		<flow:form doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.VisualizarArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesNovedadPers_Uni.VisualizarArchivo.form">
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="PROCESAR">
				<flow:log text-path="#DATOSLIQ:" text="LogVariab"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
