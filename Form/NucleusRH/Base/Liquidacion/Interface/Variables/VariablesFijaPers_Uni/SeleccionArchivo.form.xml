<form:Form xmlns:form="nomad_engine.form" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Interface.Variables.VariablesFijaPers_Uni.SeleccionArchivo.form" default_mode="EDIT">
	<form:Scripts>
		function fncCodigo()

{
Ctrl("Codigo_oculto").SetCValue(Ctrl("fkVariable").GetCValue()); 

}
	</form:Scripts>
	<form:Title>
		<form:Label label="Interface de Datos Fijos por Variable" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="60%">
		<form:Columns width="100%" name="fgfg">
			<form:Column width="60%" name="gggg">
				<form:Blank name="blank02"/>
				<form:Combo nvalue="#DATOSLIQ:@oi_empresa" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:Blank name="blank03"/>
				<form:FKInput nvalue="#DATOSLIQ:CENTER/@oi_variable" label="Seleccione una variable" name="fkVariable" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.EF.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|SHOW_FILTRO" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event name="onprocessResult" action="fncCodigo" runat="client"/>
				</form:FKInput>
				<form:Blank name="blan4"/>
				<form:File nvalue="#DATOSLIQ:@file_name" filename="IntVarLiqFijUnica.dat" class="INTERFACES" required="1" source="1" name="filArchivo" label="Archivo de interface">
					<form:SButtons>
						<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Hidden nvalue="#DATOSLIQ:@Codigo_oculto" name="Codigo_oculto" descrip="Codigo_oculto"/>
				<form:Blank name="blank031"/>
				<form:Container rheight="370px" rwidth="700px" label="Aclaraciones" name="aa" borderwidth="1">
					<form:RowAligner name="dddd">
						<form:Row name="a1">
							<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a2">
							<form:Blank name="blank031"/>
							<form:Label name="formato1" label="NumeroLegajo;Valor"/>
						</form:Row>
						<form:Row name="a3">
							<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a4">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- La persona debe trabajar en la empresa"/>
						</form:Row>
						<form:Row name="a5">
							<form:Blank name="blank031"/>
							<form:Label name="validacion2" label="- El valor a ingresar debe tener el formato de la variable"/>
						</form:Row>
						<form:Row name="a6">
							<form:Blank name="blank034"/>
							<form:Label name="validacion3" label="- Si la persona esta dos o mas veces en el archivo se toma el ultimo valor"/>
						</form:Row>
						<form:Row name="a7">
							<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="1;1"/>
						</form:Row>
						<form:Row name="a9">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="2;4.2"/>
						</form:Row>
						<form:Row name="a11">
							<form:Blank name="blank038"/>
							<form:Label name="ejemplo3" label="161;8.0"/>
						</form:Row>
						<form:Row name="a12">
							<form:Blank name="blank039"/>
							<form:Label name="ejemplo4" label="3;3.0"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
