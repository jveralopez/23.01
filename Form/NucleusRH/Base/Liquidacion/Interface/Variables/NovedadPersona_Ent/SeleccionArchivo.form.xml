<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Liquidacion.Interface.Variables.NovedadPersona_Ent.SeleccionArchivo.form" default_mode="EDIT">
	<form:Scripts/>
	<form:Title>
		<form:Label style="S3 LCol_w" nowrap="1" name="lblTitulo" label="Interface de Novedades"/>
	</form:Title>
	<form:Center>
		<form:Columns name="fgfg">
			<form:Column name="fgfgsaas">
				<form:Blank name="blank02"/>
				<form:FKInput nvalue="#DATOSLIQ:@oi_liquidacion" label="Empresa - Liquidacion" required="1" name="fkLiquidacion">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION_INICIALIZADA.Guia.flow" c2x="C2X" x2c="X2C" help="HELP">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton startvalidate="0" name="SEARCH" visible="NEW|EDIT" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Blank name="blank03"/>
				<form:File nvalue="#DATOSLIQ:@file_name" class="INTERFACES" filename="IntVarLiq.dat" required="1" source="1" name="filArchivo" label="Archivo de interface">
					<form:SButtons>
						<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Blank name="blank031"/>
				<form:Container rheight="400px" rwidth="700px" label="Aclaraciones" name="aa" borderwidth="1">
					<form:RowAligner name="dddd">
						<form:Row name="a1">
							<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a2">
							<form:Blank name="blank031"/>
							<form:Label name="formato1" label="NumeroLegajo;CodigoExternoVariable;Valor"/>
						</form:Row>
						<form:Row name="a3">
							<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a4">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- La persona debe estar inicializada en la liquidacion"/>
						</form:Row>
						<form:Row name="a5">
							<form:Blank name="blank031"/>
							<form:Label name="validacion2" label="- El valor a ingresar debe tener el formato de la variable correspondiente"/>
						</form:Row>
						<form:Row name="a6">
							<form:Blank name="blank034"/>
							<form:Label name="validacion3" label="- La variable debe ser del tipo Novedad del Empleado"/>
						</form:Row>
						<form:Row name="a61">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="- Si hay dos registros para una persona con la misma variable, toma el ultimo valor"/>
						</form:Row>
						<form:Row name="a7">
							<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="1;np_sacmes1;66.6"/>
						</form:Row>
						<form:Row name="a9">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="2;np_montoig;200.3"/>
						</form:Row>
						<form:Row name="a11">
							<form:Blank name="blank038"/>
							<form:Label name="ejemplo3" label="161;np_sacmes12;56.6"/>
						</form:Row>
						<form:Row name="a12">
							<form:Blank name="blank039"/>
							<form:Label name="ejemplo4" label="3;np_diassac;155.5"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
