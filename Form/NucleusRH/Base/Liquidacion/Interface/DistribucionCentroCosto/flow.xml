<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" description="Flow para la carga de interfaces Distribucion de Centro de Costo" name="NucleusRH.Base.Liquidacion.Interface.DistribucionCentroCosto.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="Flow para la carga de interfaces de Distribucion de Centro de Costo"/>
	<flow:declare>
		<doc:define name="DATOSLIQ">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Int_DistCC" doc="DATOSLIQ"/>
			<doc:set-attribute to-attr-path="#DATOSLIQ:@file_name" from-value=""/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.DistribucionCentroCosto.SeleccionArchivo.form" doc-path="#DATOSLIQ:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="SeleccionArchivo">
		<flow:form name="NucleusRH.Base.Liquidacion.Interface.DistribucionCentroCosto.SeleccionArchivo.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Interface.DistribucionCentroCosto.SeleccionArchivo.form" doc="SOURCE" mode="EDIT">
			<flow:action name="VOLVER">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="EJECUTAR">
				<flow:save-user-data doc-path="#SOURCE:" name="Int_DistCC"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceDistribucionCentroCosto.ENTRADA" out-attr-path="#SOURCE:@batch-id" priority="5" method="Importar">
					<flow:param attr-path="#SOURCE:@oi_empresa" type="Nomad.NSystem.String" mode="in" name="poi_empresa"/>
				</flow:exec-method>
				<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
