<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interface.DistribucionCentroCosto.SeleccionArchivo.form" default_mode="EDIT">
	<form:Scripts/>
	<form:Title>
		<form:Label label="Interfaz de Distribucion de Centro de Costo" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center>
		<form:Columns name="ColsCenter">
			<form:Column name="col01">
				<form:Blank name="blank02"/>
				<form:Combo nvalue="#DATOSLIQ:@oi_empresa" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:Blank name="blank03"/>
				<form:File nvalue="#DATOSLIQ:@file_name" class="INTERFACES" filename="IntDistCC.dat" required="1" source="1" name="filArchivo" label="Archivo de interface">
					<form:SButtons>
						<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Blank name="blank031"/>
				<form:Container name="contTexto" rheight="400px" rwidth="700px" label="Aclaraciones" borderwidth="1">
					<form:RowAligner name="dddd">
						<form:Row name="a1">
							<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a2">
							<form:Blank name="blank031"/>
							<form:Label label="Legajo;CodigoCentroDeCosto;Porcentaje;Observacion" name="formato1"/>
						</form:Row>
						<form:Row name="a3">
							<form:Label label="Validaciones 1:" style="M1 LCol_t" name="validacion"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a4">
							<form:Blank name="blank031"/>
							<form:Label name="validacion1" label="- La persona debe trabajar en la empresa"/>
						</form:Row>
						<form:Row name="a5">
							<form:Blank name="blank031"/>
							<form:Label label="- El centro de costo debe estar dado de alta en el sistema" name="validacion2"/>
						</form:Row>
						<form:Row name="a6">
							<form:Blank name="blank034"/>
							<form:Label label="- Los valores: 'Legajo' y 'CodigoCentroDeCosto' son obligatorios" name="validacion3"/>
						</form:Row>
						<form:Row name="importe1">
							<form:Blank name="blank0341"/>
							<form:Label label="- El 'Porcentaje' debe:" name="validacion31"/>
						</form:Row>
						<form:Row name="importe2">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* Ser num&#233;rico (entero o decimal)"/>
						</form:Row>
						<form:Row name="importe5">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion32" label="* No debe contener letras o palabras ni caracteres especiales"/>
						</form:Row>
						<form:Row name="importe3">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* El separador decimal debe ser punto"/>
						</form:Row>
						<form:Row name="importe4">
							<form:Blank name="blank0341"/>
							<form:Label name="validacion31" label="* Sin separador de miles"/>
						</form:Row>
						<form:Row name="importe6">
							<form:Blank name="blank0341"/>
							<form:Label label="* No debe ser un valor nulo/vacio" name="validacion31"/>
						</form:Row>
						<form:Row name="importe7">
							<form:Blank name="blank0341"/>
							<form:Label label="* No debe ser un igual a cero" name="validacion31"/>
						</form:Row>
						<form:Row name="a12">
							<form:Label label="Validaciones 2:" style="M1 LCol_t" name="validacion"/>
							<form:Blank name="blank031"/>
						</form:Row>
						<form:Row name="a10">
							<form:Blank name="blank037"/>
							<form:Label label="- Para borrar todos los datos de la dist. de CC de un legajo:" name="ejemplo2"/>
						</form:Row>
						<form:Row name="a11">
							<form:Blank name="blank037"/>
							<form:Label label="* En el archivo indicar &#250;nicamente valor en el campo 'Legajo'" name="ejemplo2"/>
						</form:Row>
						<form:Row name="a7">
							<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="3;99-340;1;Prueba Inicial"/>
						</form:Row>
						<form:Row name="a9">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="1"/>
						</form:Row>
						<form:Row name="a13">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="1;99-340;1;Prueba Inicial"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
