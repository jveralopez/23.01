<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.Seleccio" default_mode="EDIT">
	<form:Scripts>
		function LoadForm()
{
	var p = GetProxy().UserToken();
	
	var file = Ctrl("filArchivo").SetFileName(p);
	
	Ctrl('filename').SetXValue(file);
}
	</form:Scripts>
	<form:Title>
		<form:Label label="Interface SIRADIG" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center>
		<form:Columns name="fgfg">
			<form:Column name="fgfgsaas">
				<form:Blank name="blank02"/>
				<form:Combo nvalue="#DATOSLIQ:@oi_empresa" action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:Blank name="blank03"/>
				<form:File nvalue="#DATOSLIQ:@file_name" class="TEMP" filename="intSiradig.dat" required="1" source="1" name="filArchivo" label="Archivo de interface">
					<form:SButtons>
						<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:Hidden nvalue="#DATOSLIQ:@filename" name="filename"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="LoadForm" name="onload" runat="client"/>
</form:Form>
