<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.flow" extends="Nomad.Base.flow" description="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias" default_action="initialize">
	<flow:info label="Flow NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias"/>
	<flow:declare>
		<doc:define name="DATOSLIQ">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Int_deduccion" doc="DATOSLIQ"/>
			<doc:set-attribute to-attr-path="#DATOSLIQ:@file_name" from-value=""/>
			<flow:open-form doc-path="#DATOSLIQ:" form-class="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.SeleccionArchivo.form" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="SeleccionArchivo">
		<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.SeleccionArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.SeleccionArchivo.form" doc="SOURCE" mode="EDIT">
			<flow:action name="VOLVER">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="EJECUTAR">
				<flow:save-user-data doc-path="#SOURCE:" name="Int_deduccion"/>
				<flow:log text-path="#DATOSLIQ:" text="emiDATOSLIQ"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.PERSONAL_EMP" out-attr-path="#SOURCE:@batch-id" priority="5" method="InterfazSidarig">
					<flow:param attr-path="#SOURCE:@oi_empresa" type="Nomad.NSystem.String" mode="in" name="poi_empresa"/>
					<flow:param attr-path="#SOURCE:@file_name" type="Nomad.NSystem.String" mode="in" name="pfile_name"/>
				</flow:exec-method>
				<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group name="VisualizacionArchivo">
		<flow:form doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.VisualizarArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.DeduccionGanancias.VisualizarArchivo.form">
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="PROCESAR">
				<flow:log text="Log_oi_empresa" text-path="#SOURCE:@oi_empresa"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
