<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="intentrada" doc="source">
	<form:Title>
		<form:Label label="Interface de Salida para Afjp" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Combo flow="NucleusRH.Base.Liquidacion.Interface.EMPRESA_DDO.combo.flow" action="COMBO" required="1" nvalue="#source:@c_empresa" name="empresa" label="Empresa"/>
		<form:FKInput nvalue="#source:@oi_afjp" label="Afjp" name="oi_afjp" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Personal.AFJP.AFJP.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess interface="{interface.XValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Hidden nvalue="#source:@interface" name="interface"/>
		<form:DateTime nvalue="#source:@p_periodo" name="p_periodo" label="Periodo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:Grid width="500" proto="&lt;LIQ/&gt;" idvalue="#ROW:@id" nvalue="#source:LIQS" name="grdDatosLiq" note="" descrip="" rows="6" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="ROW">
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.LM.COMPLEJO.FLOW" action="HELP">
				<helper-mess>
					{grdDatosLiq.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#ROW:@id" label="Empresa - Liquidaci&#243;n" required="0" enabled="" xsize="15" length="30" name="oi_liquidacion">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function EJECUTAR_CLICK()
{
	if (Ctrl("interface").GetXValue()=="") { alert("La Afjp no tiene ninguna interfaz asociada."); return false; }
	
	if (!Ctrl("main").Validate()) return false;
	
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
</form:Form>
