<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Liquidacion.Interface.BatchCSV.download.form">
	<form:Title>
		<form:Label label="Seguimiento del proceso" name="title" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="90%">
		<form:Blank name="blank"/>
		<form:BatchComm visible="BATCH" resultaction="download" resultflow="Nomad.base.flow" tobatchlist="1" name="batch" label="Proceso Batch" nvalue="#source:@batch-id" width="800" showbar="1" showlog="1" allowstop="EDIT" allowrefresh="1"/>
		<form:BatchComm visible="DOWNLOAD|DOWNLOAD_RTF" tobatchlist="0" name="batch" label="Proceso Batch" nvalue="#source:@batch-id" width="800" showbar="1" showlog="1" allowstop="EDIT" allowrefresh="0"/>
		<form:RowAligner visible="0" name="RA1">
			<form:Row name="R1">
				<form:File visible="DOWNLOAD" filename="{xvalue}.txt" source="1" descrip="Descarga Interface" class="INTERFACES" nvalue="#source:@batch-id" name="download" label="Descargar Interface"/>
				<form:File visible="DOWNLOAD_RTF" filename="{xvalue}.rtf" source="1" descrip="Descarga Interface" class="INTERFACES" nvalue="#source:@batch-id" name="download" label="Descargar Interface"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="ra1">
			<form:Row name="r1">
				<form:Button name="DOWNLOADXLS" img="xls" descrip="Descarga el reporte generado a un archivo CSV" label="Descargar">
					<form:Event action="DownloadXLS" runat="client" name="onclick"/>
				</form:Button>
				<form:Button name="DOWNLOADTXT" img="page.gif" descrip="Descarga el reporte generado a un archivo TXT" label="Descargar">
					<form:Event action="DownloadTXT" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK">
					<form:Event name="onclick" action="EXIT" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function DownloadTXT()
{
	DownloadFile("INTERFACES\\" + Ctrl("batch").GetXValue() + ".txt", Ctrl("batch").GetXValue() + ".txt");
}                   

function DownloadXLS()
{
	DownloadFile("INTERFACES\\" + Ctrl("batch").GetXValue() + ".txt", Ctrl("batch").GetXValue() + ".csv");
}
	</form:Scripts>
</form:Form>
