<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.Liquidacion.Interface.BatchCSV.flow">
	<flow:info label="flow batch csv"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA>
				<LIQS/>
			</DATA>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Batch-Interface" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.Sindicatos.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.Sindicatos.form" name="NucleusRH.Base.Liquidacion.Interface.Sindicatos.form:EDIT" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:save-user-data name="Batch-Interface" doc-path="#FILTERDATA:"/>
			<flow:exec-method method="InterfaceSalida" class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="5">
				<flow:param attr-path="#SOURCE:@tipo_interface" mode="in" name="interfaceTIPO" type="Nomad.NSystem.String"/>
				<flow:param attr-path="#SOURCE:@interface" mode="in" type="Nomad.NSystem.String" name="interdaceID"/>
				<flow:param doc-path="#FILTERDATA:" type="Nomad.NSystem.Object" mode="in" name="parametros"/>
			</flow:exec-method>
			<flow:open-form mode="DOWNLOAD" form-class="NucleusRH.Base.Liquidacion.Interface.BatchCSV.download.form" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Interface.BatchCSV.download.form:DOWNLOAD" mode="DOWNLOAD" form-class="NucleusRH.Base.Liquidacion.Interface.BatchCSV.download.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="download">
			<flow:close-form/>
			<flow:open-form form-class="Nomad.Base.Batch.Download.form" mode="DOWNLOAD" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
