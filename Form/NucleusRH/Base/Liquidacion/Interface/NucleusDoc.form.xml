<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Liquidacion.Interface.NucleusDoc.Form">
	<form:Title>
		<form:Label label="Interface Nucleus Doc" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank name="b0001"/>
		<form:Columns height="100%" width="100%" name="cols1">
			<form:Column width="100%" name="Coltipo" separation="2" align="right" valign="top">
				<form:ComboBox nvalue="#FILTERDATA:@oi_empresa" name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
				<form:ComboBox where1="LIQ19_LIQUIDACION.c_estado='C'" nvalue="#FILTERDATA:@oi_liquidacion" prev="empresa" name="oi_liquidacion" label="Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1"/>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#FILTERDATA:@interface" name="interface"/>
		<form:Hidden nvalue="#FILTERDATA:@tipo_interface" name="tipo_interface"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button img="play" label="Ejecutar" descrip="" note="" startvalidate="1" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
					<form:Event action="VOLVER_CLICK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onLoad()
{
                               
}                   

function EJECUTAR_CLICK()
{     
    Ctrl("interface").SetXValue("NUCLEUSDOC");
	Ctrl("tipo_interface").SetXValue("LIQUIDACIONES");	
	
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
</form:Form>
