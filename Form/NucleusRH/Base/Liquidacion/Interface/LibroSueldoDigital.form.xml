<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="intentrada" doc="source">
	<form:Title>
		<form:Label label="Interface de Salida Libro de Sueldos Digital" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:ComboBox required="1" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa" name="oi_empresa" nvalue="#source:@oi_empresa" mode="QRY">
			<options/>
		</form:ComboBox>
		<form:DateTime nvalue="#source:@e_periodo" name="e_periodo" label="Periodo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Hidden name="interface" nvalue="#source:@interface"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		&#32;&#13;&#10;function EJECUTAR_CLICK()
{                                    
	if (Ctrl("interface").GetXValue()=="") 
	{ 
		Ctrl("interface").SetXValue("LSDIG");  
	}
	
	if (!Ctrl("main").Validate()) return false;
	
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
</form:Form>
