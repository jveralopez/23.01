<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Interface.Items_Ganancia.SeleccionArchivo.form" default_mode="EDIT">
	<form:Title>
		<form:Label label="Interfaz de Rangos de IG" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="80%">
		<form:Columns name="ColsCenter">
			<form:Column name="col01">
				<form:Columns name="cc1">
