							<form:Blank name="blank035"/>
						</form:Row>
						<form:Row name="a8">
							<form:Blank name="blank036"/>
							<form:Label name="ejemplo1" label="1;0;833.33;0;9"/>
						</form:Row>
						<form:Row name="a9">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="1;833.33;1666.67;75;14"/>
						</form:Row>
						<form:Row name="a10">
							<form:Blank name="blank037"/>
							<form:Label name="ejemplo2" label="1;1666.67;2500;191.67;19"/>
						</form:Row>
					</form:RowAligner>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="EJECUTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
