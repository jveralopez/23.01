<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" description="Flow para la carga de interfaces rangos de ganancias." name="NucleusRH.Base.Liquidacion.Interface.RangosIG.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="Flow para la carga de interfaces de Items de Ganancia."/>
	<flow:declare>
		<doc:define name="DATOSLIQ">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Int_RangosIG" doc="DATOSLIQ"/>
			<doc:set-attribute to-attr-path="#DATOSLIQ:@file_name" from-value=""/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.RangosIG.SeleccionArchivo.form" doc-path="#DATOSLIQ:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="SeleccionArchivo">
		<flow:form form-class="NucleusRH.Base.Liquidacion.Interface.RangosIG.SeleccionArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.RangosIG.SeleccionArchivo.form" doc="SOURCE" mode="EDIT">
			<flow:action name="VOLVER">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="EJECUTAR">
				<flow:save-user-data name="Int_RangosIG" doc-path="#SOURCE:"/>
				<flow:exec-method class="NucleusRH.Base.Liquidacion.InterfaceRangosIG.ENTRADA" out-attr-path="#SOURCE:@batch-id" priority="5" method="Importar">
					<flow:param attr-path="#DATOSLIQ:@e_anio" type="Nomad.NSystem.Int" mode="in" name="e_anio"/>
				</flow:exec-method>
				<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
