<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA">
	<form:Right>
		<form:VGroup label="Dependencias" collapse="1" width="90%" name="vgChildsEMPRESA">
			<form:Link allowimg="1" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/EMPRESA_BANCO/READ" descrip="Se asocian todos los bancos con los que trabaja una empresa." label="Bancos" name="EMPRESA_BCOS">
				<form:Event policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/EMPRESA_BANCO/EDIT" action="CALL:EMPRESA_BANCO" name="onclick" runat="server"/>
			</form:Link>
			<form:Link allowimg="1" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/VAL_VARGF/READ" descrip="Valores de los variables de Generales Fijas" label="Datos Fijos" name="VAL_VARGF">
				<form:Event policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/VAL_VARGF/EDIT" action="CALL:VAL_VARGF" name="onclick" runat="server"/>
			</form:Link>
			<form:Link allowimg="1" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/PARAM_EMPRE/READ" descrip="Registra los parametros de la Liquidacion para la Empresa." label="Par&#225;metros por Empresa" name="PARAM_EMP">
				<form:Event policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/PARAM_EMPRE/EDIT" action="CALL:PARAM_EMPRE" name="onclick" runat="server"/>
			</form:Link>
			<form:Link allowimg="1" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/UBICACION/READ" descrip="Registra los datos de las ubicaciones para una Empresa para la Liquidacion." label="Ubicaciones" name="UBICACIONES">
				<form:Event policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/UBICACION/EDIT" action="CALL:UBICACION" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
		<form:Blank name="blank1"/>
		<form:VGroup visible="SHOW|LIST" name="vgActionsEMPRESA" label="Acciones" collapse="1" width="90%">
			<form:Link name="VAL_VARGF_EDIT" allowimg="1" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/VAL_VARGF/READ" descrip="Valores de los variables de Generales Fijas" label="Editar Datos Fijos">
				<form:Event action="set_oi" runat="client" name="onclick"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOWNO" name="main_columnsEMPRESA">
			<form:Column name="main_columnsEMPRESAcolumn1"/>
		</form:Columns>
		<form:Columns name="main_columnsEMPRESA_H" visible="SHOW|EDIT|DELETE|NEW">
			<form:Column name="main_columnsEMPRESAcolumn1">
				<form:TextBox required="1" enabled="NEWNo" descr="C&#243;digo de Empresa. Puede ser un alfanum&#233;rico de hasta 30 caracteres." ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_empresa" name="c_empresa"/>
				<form:TextBox required="1" enabled="NEWNo" descr="Descripci&#243;n de Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_empresa" name="d_empresa"/>
				<form:TextBox required="0" enabled="NEWNo" descr="Descripci&#243;n Corta de Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="15" length="15" label="Descripci&#243;n Corta" nvalue="#source:@dc_empresa" name="dc_empresa"/>
				<form:TextBox required="0" enabled="NEWNo" descr="Ubicaci&#243;n del Logo de la Empresa. Puede ser un alfanum&#233;rico de hasta 200 caracteres." ysize="1" xsize="50" length="200" label="Path Logo" nvalue="#source:@p_logo" name="p_logo"/>
				<form:TextBox required="0" enabled="NEWNo" descr="CUIT de la Empresa." ysize="1" xsize="15" length="15" label="CUIT" nvalue="#source:@c_cuit" name="c_cuit"/>
			</form:Column>
		</form:Columns>
		<form:Columns name="main_columnsEMPRESA2" visible="SHOW|EDIT|DELETE|NEW">
			<form:Column name="main_columnsEMPRESAcolumn1">
				<form:Line width="50%" name="lin_ext_NucleusRH.Base.Organizacion.Empresas.EMPRESA"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" required="0" enabled="NEW|EDIT" label="Organigrama para Liquidar" nvalue="#source:oi_clase_org/@value" name="oi_clase_org"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Codigo de Actividad de la Empresa que corresponde informar para el SIJP" ysize="1" xsize="30" length="30" label="C&#243;digo de Actividad (AFIP)" nvalue="#source:@c_actividad" name="c_actividad"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" descr="Corresponde Decreto 96/99 (SIJP)" label="Corresponde Decreto 96/99 (AFIP)" nvalue="#source:@l_decreto96_99" name="l_decreto96_99"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" descr="Servicios Evantuales (SIJP)" label="Servicios Eventuales (AFIP)" nvalue="#source:@l_eventuales" name="l_eventuales"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" descr="Corresponde reducciones(SIJP)" label="Corresponde Reduccion (AFIP)" nvalue="#source:@l_reduccion" name="l_reduccion"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Codigo del Tipo de empresa para el SIJP." ysize="1" xsize="30" length="30" label="Tipo de Empresa (AFIP)" nvalue="#source:@c_tipo_empresa" name="c_tipo_empresa"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Dependencia DGI en la que se halla inscripto" nvalue="#source:@d_dependencia_emp" name="d_dependencia_emp"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Responsable 649" nvalue="#source:@d_encargado_F649" name="d_encargado_F649"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Puesto del Responsable 649" nvalue="#source:@d_puesto_enc_F649" name="d_puesto_enc_F649"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Lugar de emision del 649" nvalue="#source:@d_lugar_F649" name="d_lugar_F649"/>
				<form:Image width="96" height="96" required="0" nvalue="#source:oi_firma_f649/@value" name="oi_firma_f649" label="Firma Responsable del 649" enabled="NEW|EDIT" class="NucleusRH.Base.Personal.Imagenes.HEAD">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:Image>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_empresa" name="o_empresa"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:Hidden name="oi"/>
		<form:Hidden nvalue="#DDO:@id" name="oi_ddo"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/NEW" visible="NEWNo" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/DELETE" visible="NEWNo" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event name="CALL:VAL_VARGF" policy="NucleusRH/Base/Liquidacion/Empresa_Liquidacion/VAL_VARGF/EDIT" action="CALL:VAL_VARGF" runat="extern">
		<form:helpper action="initialize" name="NucleusRH.Base.Liquidacion.Variables.VariablesFiEmpresa.flow">
			<DATA oi="{oi.XValue}"/>
		</form:helpper>
	</form:Event>
	<form:Scripts>
		function set_oi()
{
	if (Ctrl('LIST'))
		Ctrl('oi').SetXValue(Ctrl('LIST').GetXValue());
	else
		Ctrl('oi').SetXValue(Ctrl('oi_ddo').GetXValue());
	
	Ctrl('main').DoEvent('CALL:VAL_VARGF');
}
	</form:Scripts>
</form:Form>
