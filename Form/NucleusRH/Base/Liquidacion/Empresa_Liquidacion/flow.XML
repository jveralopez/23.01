<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.autoflow" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.flow">
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT 
			t0.oi_empresa as oi_empresa 
			
			FROM ORG03_EMPRESAS as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC 				
				JOIN
				t0.oi_empresa LEFT OUTER SEC.id 
			
			 ORDER BY oi_empresa asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT 
				t0.oi_empresa as oi_empresa, 
				t0.c_empresa as c_empresa, 
				t0.d_empresa as d_empresa, 
				t0.c_empresa as CODE, 
				t0.d_empresa as TEXT 
				
				FROM ORG03_EMPRESAS as t0 ,
				NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC 				
				JOIN
				t0.oi_empresa LEFT OUTER SEC.id 
				ORDER BY 
				
				oi_empresa asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_empresa"/>
						<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
						<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.filter.autoform" extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.noreg.autoform" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.noreg.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.noreg.autoform" mode="SHOW">
		<flow:action name="open-flow-SHOW">
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form" mode="SHOW">
		<flow:action name="open-flow-EDIT">
			<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form:LIST" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form" mode="LIST">
		<flow:action name="open-flow-EDIT">
			<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.form" mode="EDIT">
		<flow:action name="CALL:VAL_VARGF">
			<flow:open-form iter-index="#SOURCE:VAL_VARGF/VAL_VARGF/@id" parent-doc-path="#SOURCE:VAL_VARGF" doc-path="#SOURCE:VAL_VARGF" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.VAL_VARGF.noreg.autoform"/>
		</flow:action>
	</flow:form>
</flow:flow>
