<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initializeListadoObraSocial" extends="Nomad.Base.report.flow" name="Nomad.Base.Liquidacion.Recibos">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" e_periodo="" c_empresa="">
				<OSS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initializeListadoObraSocial">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.Report.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.Report.form:EDIT" extends="Nomad.Base.Report.filtro.form" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.Report.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<link B="#B:@c_empresa" A="#A:ctrl[@id='c_empresa']/@xval"/>
					<link B="#B:@e_periodo" A="#A:ctrl[@id='e_periodo']/@xval"/>
					<submap path-docB="#B:OSS" path-docA="#A:ctrl[@id='grddatosObrSoc']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_obra_social']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<OS id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ListadoObraSocial.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ListadoObraSocial.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.form"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoObraSocial" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoObraSocial" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form extends="Nomad.report.form:REPORT" name="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.form:REPORT" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoObraSocial.form" doc="SOURCE"/>
</flow:flow>
