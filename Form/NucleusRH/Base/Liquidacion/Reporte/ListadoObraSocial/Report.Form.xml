<form:Form xmlns:form="nomad_engine.form" doc="source" extends="nomad.Base.report.filtro.form" name="listadoobrasocial">
	<form:Title>
		<form:Label name="lbl" label="Listado de Obras Sociales" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Interface.EMPRESA_DDO.combo.flow" required="1" enabled="" label="Empresa" nvalue="#source:@c_empresa" name="c_empresa"/>
		<form:Blank name="b3la4" width="100%" visible=""/>
		<form:DateTime pattern="YYYYMM" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Per&#237;odo" nvalue="#source:@e_periodo" name="e_periodo">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="EDIT|NEW">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="b3la5" width="100%" visible=""/>
		<form:Grid idvalue="#SOURCE:@id" doc="SOURCE" width="480px" proto="&lt;OS/&gt;" nvalue="#source:OSS" name="grddatosObrSoc" note="" descrip="" rows="3" allowhelper="0" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#SOURCE:@id" required="0" enabled="NEW|EDIT|REINGRESAR" xsize="15" length="30" label="Obra Social" name="oi_obra_social">
						<form:STexts>
							<form:SText xsize="50" name="txt1"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Personal.Obras_Sociales.OBRA_SOCIAL.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" visible="NEW|EDIT|REINGRESAR" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="b33l37" width="100%" visible=""/>
		<form:Combo required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
