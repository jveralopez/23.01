<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.CertificadoEmpleo.filter.form" doc="source">
	<form:Title>
		<form:Label label="Certificado de Empleo" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1"/>
		<form:Blank name="bl2"/>
		<form:ComboBox required="1" order-change="PREV:oi_personal_emp" label="Listar Legajos" name="cb_confidenciales" nvalue="#source:@cb_confidenciales" mode="OPT">
			<options>
				<option text="Todos" value="T"/>
				<option text="Confidenciales" value="C"/>
				<option text="No Confidenciales" value="NC"/>
			</options>
			<form:Event action="onchange" name="onchange" runat="client"/>
		</form:ComboBox>
		<form:ComboBox queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_CONF" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="35" mode="QRY" required="1" label="Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
		<form:Blank name="bl3"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button label="Ejecutar" descrip="Ejecuta el Filtro" startvalidate="1" visible="" name="btnAceptar" img="play" note="Ejecuta la busqueda">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button img="back" enabled="" visible="" name="btnVolver" label="Volver" note="Agregar un nuevo registro" descrip="Volver a la pantalla anterior">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{
	if(Ctrl('cb_confidenciales')!=undefined)
	{
		 if(!Ctrl('cb_confidenciales').GetEnabled())
		 {
		 	Ctrl('cb_confidenciales').SetXValue('NC');
		 }                                          
		 else
		 {         
		 	if(Ctrl('cb_confidenciales').GetXValue()=='')
		 		Ctrl('cb_confidenciales').SetXValue('T');
		 }  
		 
		 Ctrl('oi_personal_emp').SetWhere(Ctrl('cb_confidenciales').GetXValue());
	}    
}         

function onchange()
{      
	if(Ctrl('cb_confidenciales')!=undefined)
	{
 	   Ctrl('oi_personal_emp').SetWhere(Ctrl('cb_confidenciales').GetXValue());
 	}
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
