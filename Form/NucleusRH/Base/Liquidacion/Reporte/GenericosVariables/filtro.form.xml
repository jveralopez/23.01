<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" doc="source" extends="nomad.Base.report.filtro.form" name="listadoobrasocial">
	<form:Title>
		<form:Label label="111 - Genericos de Variables" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:FKInput nvalue="#FILTERDATA:@oi_empresa" required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Empresa" name="oi_empresa">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="b3la4" width="100%" visible=""/>
		<form:DateTime nvalue="#FILTERDATA:@e_periodo" pattern="YYYYMM" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Per&#237;odo" name="e_periodo">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="EDIT|NEW">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="b3l11a4" width="100%"/>
		<form:FKInput nvalue="#FILTERDATA:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" required="0" enabled="" xsize="15" length="30" name="oi_liquidacion">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="b3la5" width="100%" visible=""/>
		<form:Combo flow="NucleusRH.Base.Liquidacion.ReportesGenericosVariables.REPORTE.Combo.autoflow" name="oi_reporte" nvalue="#source:@oi_reporte" label="Reporte" enabled="" required="1" action="COMBO"/>
		<form:Blank name="b33l37" width="100%" visible=""/>
		<form:Combo visible="0" required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
