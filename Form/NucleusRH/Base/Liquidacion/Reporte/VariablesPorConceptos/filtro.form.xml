<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.VariablesporConceptos" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="nomad.filter.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="003 - Conceptos por Variables" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="60%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Label visible="0" name="lbl22" label="Criterios de B&#250;squeda" align="center" style="M1 LCol_g"/>
		<form:Blank visible="0" name="bl4" width="100%"/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:ComboBox xsize="40" mode="OPT" required="0" label="Tipo Variable" nvalue="#source:@c_tipo_variable" name="c_tipo_variable">
					<options>
						<option text="Novedad - Empleado" value="1"/>
						<option text="Novedad - Empresa" value="2"/>
						<option text="Fijo - Empleado" value="3"/>
						<option text="Fijo - Empresa" value="4"/>
						<option text="Acumulador - Empleado" value="5"/>
						<option text="Sistema" value="6"/>
						<option text="Auxiliar" value="7"/>
						<option text="Calculada - Conceptos" value="8"/>
					</options>
				</form:ComboBox>
				<form:Blank name="bl4p" width="100%" visible=""/>
				<form:ComboBox xsize="40" mode="OPT" required="0" nvalue="#FILTERDATA:@concepto" label="Con conceptos" name="conconceptos">
					<options>
						<option name="si" text="Si" code="si" value="si"/>
						<option name="no" text="No" code="no" value="no"/>
					</options>
				</form:ComboBox>
				<form:Blank name="bl4psss" width="100%" visible=""/>
				<form:ComboBox required="0" mode="OPT" xsize="40" name="activos" label="Conceptos Activos" nvalue="#FILTERDATA:@activo">
					<options>
						<option name="si" text="Si" code="1" value="1"/>
						<option name="no" text="No" code="0" value="0"/>
					</options>
				</form:ComboBox>
				<form:Blank name="bl4pasas" width="100%" visible=""/>
				<form:TextBox label="Variable (descripci&#243;n de la variable)" nvalue="#FILTERDATA:@variable" length="20" xsize="28" name="variable"/>
				<form:Blank name="bla4pasas" width="100%" visible=""/>
				<form:FKInput required="0" enabled="" xsize="15" length="30" label="Variable" nvalue="#FILTERDATA:@oi_variable" name="oi_variable">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank name="b33l37" width="100%" visible=""/>
		<form:Combo required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
		<form:Blank name="bl11" width="100%" visible=""/>
		<form:Line name="line_1" width="100%"/>
		<form:Label visible="0" name="lbl201" label="Criterio de Ordenaci&#243;n" align="center" style="M1 LCol_g"/>
		<form:RowAligner visible="0" name="RAcamposOrden" columns="2">
			<form:Row name="RC1O">
				<form:Combo nvalue="#FILTERDATA:@ATRIB_ORDEN1" name="cboCampo1" label="" note="" action="COMBO">
					<form:Opts>
						<OPT text="C&#243;digo" code="c_variable" value="c_variable"/>
						<OPT text="Descripci&#243;n" code="d_variable" value="d_variable"/>
					</form:Opts>
				</form:Combo>
				<form:Combo name="cboOrdenCampo1" label="" note="AscendenteDecendente" flow="NucleusRH.Base.Orden.enum" action="COMBO" nvalue="#FILTERDATA:@ORDEN1"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
