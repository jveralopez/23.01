<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="Nomad.Base.Liquidacion.InterfazContable">
	<flow:info label="Flow para Nomad.Base.Liquidacion.InterfazContable">
		Flow para Nomad.Base.Liquidacion.InterfazContable
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" salida="HTML" oi_liquidacion="" oi_variable="" report="" gpers="1"/>
		</doc:define>
		<doc:define name="QRY">
			<ROWS/>
		</doc:define>
		<doc:define name="RAIZBACKUP">
			<DATOS/>
		</doc:define>
		<doc:define name="RAIZ">
			<DATOS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.InterfazContable.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.InterfazContable.filtro.form" name="NucleusRH.Base.Liquidacion.Reporte.InterfazContable.filtro.form:EDIT" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:load-user-data doc="QRY" name="Lista_IDS_IC"/>
			<doc:assign-value from-path="#RAIZBACKUP:" to-doc="RAIZ"/>
			<doc:add-object parent-doc-path="#RAIZ:" doc-path="#QRY:"/>
			<doc:add-object doc-path="#FILTERDATA:" parent-doc-path="#RAIZ:"/>
			<flow:log text-path="#FILTERDATA:" text="log1316"/>
			<flow:log text-path="#RAIZ:" text="log13162"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="RepInterfazContable" class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="RAIZ" mode="in" name="param"/>
				<flow:param attr-path="#FILTERDATA:@agrupar" type="Nomad.NSystem.String" mode="in" name="agrupar"/>
			</flow:exec-method>
			<doc:set-attribute from-value="114 - Listado de Interfaz Contable" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.InterfazContable_FILTER" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.InterfazContable_FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<!--flow:load-user-data doc="QRY" name="Lista_IDS_IC"/-->
			<flow:log text="log13163" text-path="#QRY:"/>
			<flow:attach-doc doc-path="#QRY:" attach-id="ARRB"/>
		</flow:action>
	</flow:form>
</flow:flow>
