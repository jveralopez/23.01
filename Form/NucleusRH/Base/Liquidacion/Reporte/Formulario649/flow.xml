<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Nomad.Base.Liquidacion.Reporte.Formulario649" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Formulario649">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" modo="HTML" oi_liquidacion_ddo="" oi_per_emp_ddo=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649.filtro.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="initialize_recibo">
			<flow:log text-path="#SOURCE:" text="emifilter"/>
			<flow:html-gen ext="html" template-file="NucleusRH.Base.Liquidacion.Formulario649.rpt" input-doc-path="#SOURCE:" out-file-path="#SOURCE:@report"/>
			<flow:open-form doc-path="#SOURCE:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.Formulario649.filtro.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Liquidacion.Formulario649.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="204 - Asistente Formulario de IG 1357 (ex 649)" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Formulario649" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Formulario649" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.Formulario649.form:REPORT" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649.form" mode="REPORT">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
