<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Nomad.Base.Liquidacion.TotalesPorLegajos" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Liquidacion.TotalesPorLegajos">
		Flow para Nomad.Base.Liquidacion.TotalesPorLegajos
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<PERSONAS/>
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.TotalesPorLegajos.filtro2.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.TotalesPorLegajos.filtro2.form" name="NucleusRH.Base.Liquidacion.Reporte.TotalesPorLegajos.filtro2.form:EDIT" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Liquidacion.TotalesLegajos.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="107 - Totales por Legajos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.TotalesPorLegajos_FILTER2" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.TotalesPorLegajos_FILTER2" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
</flow:flow>
