<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="SueldosPorCargo" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="SueldosPorCargo"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO salida="HTML"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosPorCargo.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosPorCargo.filter.form" name="NucleusRH.Base.Liquidacion.Reporte.SueldosPorCargo.filter.form:FILTER" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.SueldosPorCargo" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.SueldosPorCargo" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Sueldos a Pagar Por Cargo" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="pstrReportName" value="NucleusRH.Base.Liquidacion.SueldosPorCargo.rpt" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="122 - Listado Sueldos por Cargo" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
			<flow:log text-path="#FILTERDATA:" text="emifilter"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
