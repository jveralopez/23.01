<form:Form xmlns:form="nomad_engine.form" name="filtro.sueldoporcargo" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Title>
		<form:Label label="122 - Listado de Sueldos Por Cargo" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
		<form:ComboBox required="1" label="Listar Legajos" name="cb_confidenciales" nvalue="#source:@cb_confidenciales" mode="OPT">
			<options>
				<option text="Todos" value="T"/>
				<option text="Confidenciales" value="C"/>
				<option text="No Confidenciales" value="NC"/>
			</options>
		</form:ComboBox>
		<form:DateTime nvalue="#FILTERDATA:@e_periodo" pattern="YYYYMM" required="1" mask="dd/mm/yyyy" label="Per&#237;odo" name="e_periodo">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" xsize="30" mode="QRY" required="0" label="Ubicaci&#243;n" nvalue="#FILTERDATA:@oi_ubicacion" name="oi_ubicacion"/>
		<form:CheckBox label="Listar Detalle" name="l_detallada" nvalue="#source:@l_detallada"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Aceptar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{
	if(Ctrl('cb_confidenciales')!=undefined)
	{
		 if(!Ctrl('cb_confidenciales').GetEnabled())
		 {
		 	Ctrl('cb_confidenciales').SetXValue('NC');
		 }                                          
		 else
		 {         
		 	if(Ctrl('cb_confidenciales').GetXValue()=='')
		 		Ctrl('cb_confidenciales').SetXValue('T');
		 }   
	}    
}  
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
