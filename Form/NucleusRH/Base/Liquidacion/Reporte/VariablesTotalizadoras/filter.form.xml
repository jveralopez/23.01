<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="TotalesConceptosfilter" doc="source">
	<form:Title>
		<form:Label label="011 - Variables Totalizadoras" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center height="100%" width="100%">
		<form:Columns height="50%" width="40%" name="cols">
			<form:Column height="100%" width="100%" name="col" separation="2" align="center" valign="top">
				<form:Blank visible="" width="100%" name="bl1"/>
				<form:Label label="Criterios de B&#250;squeda" style="M1 LCol_g" align="center" visible="" name="lbl2"/>
				<form:Blank visible="" width="100%" name="bl2"/>
				<form:Blank visible="" width="100%" name="bl1510"/>
				<form:Columns height="100%" width="100%" name="cols1">
					<form:Column name="col1" height="100%" width="100%" separation="2" align="right" valign="top">
						<form:ListView docname="TOT" arr-control="TOT" nvalue="#source:@selected" rows="8" width="450px" label="Totales" name="Totales">
							<form:LVColumns>
								<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Total" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
									<form:Event action="FullTOT" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
									<form:Event action="ClearTOT" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr nvalue="#source:TOT" proto="&lt;C /&gt;" name="TOT">
							<form:Attr name="id"/>
						</form:HiddenArr>
					</form:Column>
				</form:Columns>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Totales seleccionados">
					<form:Event action="Validar" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu principal" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<qry:main doc="SOURCE">
			<qry:element name="DATO">
				<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
			</qry:element>
		</qry:main>
	</form:Resources>
	<form:Scripts>
		function Find()
{
	Ctrl("Totales").filter("",Ctrl("iter_search").GetCValue());
}

function ClearTOT()
{
	Ctrl("TOT").DelAllRow();
	Ctrl("Totales").Refresh();
}

function FullTOT()
{
	Ctrl("TOT").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Totales").TotalRowsCount(); t++)
		Ctrl("TOT").AddRow().SetAttr("id", Ctrl("Totales").GetAttrValue(t, "id"));
	
	Ctrl("Totales").Refresh();
} 

function Validar()
{
   if (Ctrl("TOT").CountRow()==0)
   		alert("Debe seleccionar al menos un Total");
   else  
   		return true;    
}
	</form:Scripts>
</form:Form>
