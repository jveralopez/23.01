<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="Nomad.Base.Liquidacion.NovedadesLiquidacion" extends="Nomad.Base.report.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.NovedadesLiquidacion">
		Flow para Nomad.Base.Liquidacion.NovedadesLiquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" salida="HTML" oi_liquidacion="" oi_variable="" report="">
				<ROWS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.sim.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.sim.filtro.form" name="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.sim.filtro.form:EDIT" mode="FILTER" extends="Nomad.Base.Report.filtro.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:log text="ppopo" text-path="#FILTERDATA:"/>
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.NovedadesLiquidacion.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.NovedadesLiquidacion.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion1" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion1" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="Nomad.report.form:REPORT" name="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.form:REPORT" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacion.form" mode="REPORT">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
