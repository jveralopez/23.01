<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Liquidacion.Reportes.AcreditacionHaberes" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Liquidacion.AHs">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" c_empresa="" oi_banco="" f_acreditacion="" c_liquidacion="" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes.Report.form"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" mode="FILTER" name="NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes.Report.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes.Report.form" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Acreditacion de Haberes" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param value="NucleusRH.Base.Liquidacion.AcreditacionHaberesMOTOR-C.rpt" name="pstrReportName" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="105 - Listado de Acreditaci&#243;n de Haberes" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
