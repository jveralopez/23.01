<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.AcreditacionHaberes.Report.Form" extends="Nomad.Base.report.filtro.form" doc="source">
	<form:Title>
		<form:Label label="105 - Listado de Acreditaci&#243;n de Haberes" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank name="b0001"/>
		<form:Columns height="100%" width="100%" name="cols1">
			<form:Column width="100%" name="Coltipo" separation="2" align="right" valign="top">
				<form:ComboBox nvalue="#source:@oi_empresa" name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
				<form:ComboBox where1="LIQ19_LIQUIDACION.oi_tipo_liq != 7" nvalue="#source:@oi_liquidacion" prev="empresa" name="oi_liquidacion" label="Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1"/>
				<form:ComboBox nvalue="#source:@oi_banco" name="oi_banco" label="Banco" queryname1="NucleusRH.Base.Liquidacion.Bancos.BANCO.INFO" xsize="40" mode="QRY" required="0"/>
				<form:DateTime nvalue="#source:@f_acreditacion" name="f_acreditacion" label="Fecha Acreditaci&#243;n" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
