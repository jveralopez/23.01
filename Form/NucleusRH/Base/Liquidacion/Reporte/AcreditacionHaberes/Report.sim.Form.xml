<form:Form xmlns:form="nomad_engine.form" name="ahnbsf" extends="Nomad.Base.report.filtro.form" doc="source">
	<form:Title>
		<form:Label style="S3 LCol_w" align="center" visible="" label="Acreditaci&#243;n de Haberes" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4bis"/>
		<form:FKInput name="oi_liquidacion" nvalue="#source:@oi_liquidacion" label="Empresa - Liquidaci&#243;n" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO.guia.SISIM.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank visible="" width="100%" name="bla54"/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Bancos.BANCO.Combo.autoflow" required="1" label="Banco" nvalue="#source:@oi_banco" name="oi_banco"/>
		<form:Blank visible="" width="100%" name="bla4"/>
		<form:DateTime nvalue="#source:@f_acreditacion" name="f_acreditacion" label="Fecha Acreditaci&#243;n" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" img="Calendar">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank visible="" width="100%" name="bla54assa"/>
		<form:Combo required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function clearLiq()
{
	Ctrl('oi_liquidacion').SetCValue('');
}
	</form:Scripts>
</form:Form>
