<form:Form name="filtro.sueldoapagar" extends="nomad.Base.report.filtro.form" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Sueldos a Pagar - Todos" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:DateTime nvalue="#FILTERDATA:@e_periodo" pattern="YYYYMM" required="0" mask="dd/mm/yyyy" label="Per&#237;odo" name="e_periodo">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:Combo nvalue="#FILTERDATA:@FormatRPT" action="COMBO" required="1" flow="Nomad.Base.report.cboFormatRpt.enum" name="Formato" label="Formato del Reporte"/>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:Grid idvalue="#SOURCE:@id" width="480px" proto="&lt;LIQUIDACION/&gt;" nvalue="#source:LIQUIDACIONES" name="grdDatosLiq" note="" descrip="" rows="6" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCE">
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.LM.COMPLEJO.FLOW" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdDatosLiq.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#SOURCE:@id" label="Empresa - Liquidaci&#243;n" required="0" enabled="" xsize="15" length="30" name="oi_liquidacion">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event action="VALIDATE" runat="client" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
	<form:Scripts>
		function VALIDATE() {
	if (Ctrl("e_periodo").GetXValue() == "" &amp;&amp; Ctrl("grdDatosLiq").TotalRowsCount() == 0)
		alert("Debe elegir un per&#237;odo o una liquidaci&#243;n");
	else 
		Ctrl('main').DoEvent("ACCEPT");
	
}
	</form:Scripts>
</form:Form>
