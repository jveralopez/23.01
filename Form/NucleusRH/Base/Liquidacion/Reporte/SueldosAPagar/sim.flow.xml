<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.report.flow" name="SueldosAPagar">
	<flow:info label="ReporteFichadasIncorporadas"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO salida="HTML">
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.filter.sim.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form extends="Nomad.Base.Report.filtro.form" name="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.filter.sim.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.filter.sim.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.SueldoAPAGAR" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.SueldoAPAGAR" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.SueldosAPagar.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.form" doc-path="#FILTERDATA:" mode="REPORT"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.SueldosAPagar.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.form" doc-path="#FILTERDATA:" mode="REPORT"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
