<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="filtro.sueldoapagar" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Title>
		<form:Label label="106 - Listado Sueldos a Pagar" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:ComboBox label="Listar Liquidaciones" required="1" name="cb_confidenciales" nvalue="#source:@cb_confidenciales" mode="OPT">
			<options>
				<option text="Todas" value="T"/>
				<option text="Confidenciales" value="C"/>
				<option text="No Confidenciales" value="NC"/>
			</options>
		</form:ComboBox>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:DateTime nvalue="#FILTERDATA:@e_periodo" pattern="YYYYMM" required="1" mask="dd/mm/yyyy" label="Per&#237;odo" name="e_periodo">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="bl7" width="100%" visible=""/>
		<form:Combo nvalue="#FILTERDATA:@oi_forma_pago" required="0" action="COMBO" flow="NucleusRH.Base.Personal.Formas_Pago.FORMA_PAGO.combo.autoflow" enabled="" label="Forma de Pago" name="forma_pago"/>
		<form:Blank name="bl2" width="100%" visible=""/>
		<form:Rower label="Ordenar por" name="rwerOrden" separation="6">
			<form:Combo nvalue="#source:@orden1" name="orden1" flow="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.SueldosAPagar.atribOrden.form" action="COMBO" required="0" label="Orden" X-POLICY="./FORM/NucleusRH/Base/Personal/Reportes/LegajosPorEmpresa/filter/form/orden">
				<form:Event name="onchange" action="val_orden" runat="client"/>
			</form:Combo>
			<form:Label style="S2 LCol_g" label="y luego por" name="lbl_orden"/>
			<form:Combo flow="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.SueldosAPagar.atribOrden.form" action="COMBO1" nvalue="#source:@orden2" name="orden2" required="0" X-POLICY="./FORM/NucleusRH/Base/Personal/Reportes/LegajosPorEmpresa/filter/form/orden"/>
		</form:Rower>
		<form:Combo visible="0" required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Grid idvalue="#SOURCE:@id" width="480px" proto="&lt;LIQUIDACION/&gt;" nvalue="#source:LIQUIDACIONES" name="grdDatosLiq" note="" descrip="" rows="6" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCE">
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.LM.COMPLEJO.FLOW" action="HELP">
				<helper-mess>
					{grdDatosLiq.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#SOURCE:@id" label="Empresa - Liquidaci&#243;n" required="0" enabled="" xsize="15" length="30" name="oi_liquidacion">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.NOSIM.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Hidden name="oi_user" nvalue="#source:@oi_user"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="LoadForm" name="onload" runat="client"/>
	<form:Scripts>
		function LoadForm()
{
 val_orden();                
 var np = GetProxy();
 Ctrl('oi_user').SetXValue(np.Etty()); 
 
 if(Ctrl('cb_confidenciales')!=undefined)
 {
 	 if(!Ctrl('cb_confidenciales').GetEnabled())
 	 {
 	 	Ctrl('cb_confidenciales').SetXValue('NC');
 	 }                                          
 	 else
 	 {         
 	 	if(Ctrl('cb_confidenciales').GetXValue()=='')
 	 		Ctrl('cb_confidenciales').SetXValue('T');
 	 }   
 } 
}  

function val_orden() 
{
if (Ctrl('orden1').GetXValue() == "ORG03_UBICACIONES.c_ubicacion" || Ctrl('orden1').GetXValue() == "ORG03_UBICACIONES.d_ubicacion")
 {
 	CtrlEnabled('orden2',true);
 }
else
 {
  CtrlEnabled('orden2',false);
  Ctrl("orden2").SetXValue("");
 } 
}
	</form:Scripts>
</form:Form>
