<flow:flow extends="Nomad.Base.report.Crystal.flow" name="SueldosAPagar" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="ReporteFichadasIncorporadas"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.Crystal.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.Crystal.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar.Crystal.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text="ppfilterdata" text-path="#FILTERDATA:"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTpdf" eq="PDF"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTxls" eq="XLS"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTrtf" eq="RTF"/>
		</flow:action>
		<flow:action name="ACCEPTpdf">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.SueldosAPagar\SueldosAPagarPDF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
			<flow:call-action action="save-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPTxls">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.SueldosAPagar\SueldosAPagarXLS.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
			<flow:call-action action="save-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPTrtf">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.SueldosAPagar\SueldosAPagarRTF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
			<flow:call-action action="save-FILTER"/>
		</flow:action>
		<flow:action name="save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="load-FILTER"/>
		</flow:action>
		<flow:action name="load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.Liquidacion.Reporte.SueldosAPagar" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
</flow:flow>
