<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.ListadoSaldosAnticiposPersonal.filter.form" doc="source" default_mode="FILTER">
	<form:Title>
		<form:Label label="015 - Listado saldo de anticipos" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank width="100%" name="bl1"/>
		<form:Columns name="cols1">
			<form:Column name="col1" separation="2" align="center" valign="top">
				<form:ComboBox xsize="40" required="1" label="Empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" name="oi_empresa" mode="QRY"/>
				<form:Combo nvalue="#source:@oi_tipo_anticipo" action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipo_Anticipo.TIPO_ANTICIPO.Combo.autoflow" required="0" label="Tipo de anticipo" name="oi_tipo_anticipo"/>
				<form:DateTime label="Fecha desde" pattern="YYYYMMDD" nvalue="#source:@f_desde_anticipo" name="f_desde_anticipo" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
