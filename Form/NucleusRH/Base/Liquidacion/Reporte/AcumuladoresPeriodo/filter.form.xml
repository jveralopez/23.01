<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.AcumuladoresPeriodo" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="010 - Datos Acumulados por Per&#237;odo" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:ComboBox xsize="40" required="1" label="Empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" name="oi_empresa" mode="QRY"/>
				<form:ComboBox required="1" label="Listar Legajos" name="cb_confidenciales" nvalue="#source:@cb_confidenciales" mode="OPT">
					<options>
						<option text="Todos" value="T"/>
						<option text="Confidenciales" value="C"/>
						<option text="No Confidenciales" value="NC"/>
					</options>
					<form:Event action="onchange" name="onchange" runat="client"/>
				</form:ComboBox>
				<form:DateTime nvalue="#source:@per_desde" label="Per&#237;odo Desde" name="per_desde" pattern="YYYYMM" required="1" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@per_hasta" label="Per&#237;odo Hasta" name="per_hasta" pattern="YYYYMM" required="1" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox nvalue="#source:@c_variable" length="30" xsize="30" required="0" label="Variable contiene:" name="c_variable"/>
				<form:ComboBox where1="LIQ09_VARIABLES.c_tipo_variable = '9'" xsize="40" required="0" label="Variable" nvalue="#source:@oi_variable" queryname1="NucleusRH.Base.Liquidacion.Variables.VARIABLE.INFO" name="oi_variable" mode="QRY"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_CONF" prev="oi_empresa" xsize="40" required="0" label="Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp" mode="QRY"/>
				<form:CheckBox label="Incluir Inactivos?" nvalue="#source:@l_incluir" name="l_incluir"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{
	if(Ctrl('cb_confidenciales')!=undefined)
	{
		 if(!Ctrl('cb_confidenciales').GetEnabled())
		 {
		 	Ctrl('cb_confidenciales').SetXValue('NC');
		 }                                          
		 else
		 {         
		 	if(Ctrl('cb_confidenciales').GetXValue()=='')
		 		Ctrl('cb_confidenciales').SetXValue('T');
		 }  
		 
		 Ctrl('oi_personal_emp').SetWhere(Ctrl('cb_confidenciales').GetXValue());
	}    
}         

function onchange()
{      
	if(Ctrl('cb_confidenciales')!=undefined)
	{
 	   Ctrl('oi_personal_emp').SetWhere(Ctrl('cb_confidenciales').GetXValue());
 	}
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
