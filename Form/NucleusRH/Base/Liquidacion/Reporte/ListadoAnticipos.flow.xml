<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="Nomad.Base.Liquidacion.Recibos" extends="Nomad.Base.report.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" f_desde_anticipo="" f_hasta_anticipo="" c_estado="" report="">
				<PERSONAS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoAnticipos.Filter.form" mode="EDIT"/>
		</flow:action>
		<flow:action name="REPORTE">
			<flow:log text="logAnticipos" text-path="#SOURCE:"/>
			<flow:html-gen out-file-path="#SOURCE:@report" input-doc-path="#SOURCE:" template-file="NucleusRH.Base.Liquidacion.ListadoAnticipos.rpt"/>
			<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Liquidacion.Reporte.listadoAnticipos.form" mode="REPORT"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoAnticipos.Filter.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoAnticipos.Filter.form" mode="EDIT" doc="SOURCE" extends="Nomad.Base.Report.filtro.form">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<link B="#B:@oi_empresa" A="#A:ctrl[@id='oi_empresa']/@xval"/>
					<submap path-docB="#B:PERSONAS" path-docA="#A:ctrl[@id='grdDatosPersona']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_personal_emp']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<PERSONA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:log text="logAnticipos" text-path="#FILTERDATA:"/>
			<flow:html-gen out-file-path="#FILTERDATA:@report" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ListadoAnticipos.rpt"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.listadoAnticipos.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoAnticipos"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoAnticipos"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.listadoAnticipos.form:REPORT" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.listadoAnticipos.form" doc="SOURCE" extends="Nomad.report.form:REPORT"/>
</flow:flow>
