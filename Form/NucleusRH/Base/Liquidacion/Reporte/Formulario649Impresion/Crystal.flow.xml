<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="Nomad.Base.flow" name="Formulario649Impresion">
	<flow:info label="ReporteFichadasIncorporadas"/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649Impresion.Crystal.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" salida="HTML" oi_liquidacion="" oi_variable="" report="" gpers="1"/>
		</doc:define>
		<doc:define name="QRY">
			<ROWS/>
		</doc:define>
		<doc:define name="RAIZBACKUP">
			<DATOS/>
		</doc:define>
		<doc:define name="RAIZ">
			<DATOS/>
		</doc:define>
		<qry:define declare="&lt;DATOS&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW id=&quot;11565&quot; /&gt;&lt;ROW id=&quot;11566&quot; /&gt;&lt;ROW id=&quot;11567&quot; /&gt;&lt;ROW id=&quot;11568&quot; /&gt;&lt;ROW id=&quot;11569&quot; /&gt;&lt;ROW id=&quot;11570&quot; /&gt;&lt;ROW id=&quot;11571&quot; /&gt;&lt;ROW id=&quot;11573&quot; /&gt;&lt;ROW id=&quot;11574&quot; /&gt;&lt;ROW id=&quot;11575&quot; /&gt;&lt;ROW id=&quot;11576&quot; /&gt;&lt;ROW id=&quot;11578&quot; /&gt;&lt;ROW id=&quot;11580&quot; /&gt;&lt;ROW id=&quot;11581&quot; /&gt;&lt;ROW id=&quot;11582&quot; /&gt;&lt;ROW id=&quot;11583&quot; /&gt;&lt;ROW id=&quot;11579&quot; /&gt;&lt;ROW id=&quot;13885&quot; /&gt;&lt;ROW id=&quot;13886&quot; /&gt;&lt;ROW id=&quot;13887&quot; /&gt;&lt;ROW id=&quot;13888&quot; /&gt;&lt;ROW id=&quot;13889&quot; /&gt;&lt;ROW id=&quot;13890&quot; /&gt;&lt;ROW id=&quot;13891&quot; /&gt;&lt;ROW id=&quot;13892&quot; /&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&#9;&lt;DATOS oi_empresa=&quot;&quot; salida=&quot;HTML&quot; oi_liquidacion=&quot;&quot; oi_variable=&quot;&quot; report=&quot;&quot; gpers=&quot;&quot; gcustom=&quot;&quot; oi_empresaFIL=&quot;196&quot; oi_liquidacionFIL=&quot;122&quot; l_anioAnterior=&quot;&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; legajo_desde=&quot;&quot; legajo_hasta=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; oi_centro_costo=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; /&gt;&#13;&#10;&lt;/DATOS&gt;" name="QRY_RECIBOS_LIQ">
			<qry:main doc="SOURCE">
				<qry:element name="FLAG">
					<qry:attribute value="'0'" name="flag"/>
					<qry:insert-select name="QRY_RECIBOS" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_RECIBOS" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
	COUNT(P.oi_per_emp_ddo) as cant
FROM 
	LIQ19_EJECUCIONES AS E
	, LIQ99_LIQUIDACION AS L
	, LIQ99_RECIBOS AS R
	, LIQ20_TOT_LIQ_PER AS T
	, LIQ97_PERSONAL_EMP AS P
	, LIQ25_PERSONAL_LIQ AS PL
	, PER02_PERSONAL_EMP AS PE
	, LIQ07_PERSONAL AS PS
JOIN
	E.oi_liquidacion_ddo INNER L.oi_liquidacion_ddo
	, L.oi_liquidacion_ddo INNER R.oi_liquidacion_ddo
	, R.oi_tot_liq_per INNER T.oi_tot_liq_per
	, T.oi_per_emp_ddo INNER P.oi_per_emp_ddo
	, E.oi_liquidacion INNER PL.oi_liquidacion
	, PL.oi_personal_emp INNER PE.oi_personal_emp
	, PL.oi_personal_emp INNER PS.oi_personal_emp
	, PE.e_numero_legajo INNER P.e_numero_legajo

WHERE	
	E.oi_liquidacion = {#SOURCE:DATOS/@oi_liquidacionFIL}
	{%? (string(#SOURCE:ROWS/ROW/@id)!='') {% AND PE.oi_personal_emp in ({%=string(#SOURCE:ROWS/ROW/@id) %}) %} {% %} %}
	AND L.c_estado = \'F\'
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="flag" value="iif($r/@cant&gt;0,1,0)"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FLAG"/>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.Formulario649Impresion.Crystal.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario649Impresion.Crystal.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:load-user-data doc="QRY" name="Lista_IDS_IC"/>
			<doc:assign-value from-path="#RAIZBACKUP:" to-doc="RAIZ"/>
			<doc:add-object parent-doc-path="#RAIZ:" doc-path="#QRY:"/>
			<doc:add-object doc-path="#FILTERDATA:" parent-doc-path="#RAIZ:"/>
			<flow:log text-path="#FILTERDATA:" text="log1316"/>
			<flow:log text-path="#RAIZ:" text="log13162"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="ppfilterdata" text-path="#FILTERDATA:"/>
			<doc:load-qry output-doc="FLAG" input-doc-path="#RAIZ:" qry="QRY_RECIBOS_LIQ"/>
			<flow:log text="ppparam" text-path="#FILTERDATA:"/>
			<flow:call-action else="NODATA" eq="1" if="#FLAG:@flag" action="REPORT"/>
		</flow:action>
		<flow:action name="REPORT">
			<flow:exec-method out-attr-path="#RAIZ:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.Formulario649\Formulario649.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param doc="RAIZ" name="report-param" mode="in" type="Nomad.NSystem.Object"/>
				<flow:param attr-path="#RAIZ:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form mode="BATCH" form-class="Nomad.base.batch.report.form" doc-path="#RAIZ:"/>
		</flow:action>
		<flow:action name="NODATA">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Recibos.NODATA.form" mode="SHOW" doc-path="#RAIZ:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.Formulario649Impresion" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.Formulario649Impresion" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:log text="log13163" text-path="#QRY:"/>
			<flow:attach-doc doc-path="#QRY:" attach-id="ARRB"/>
		</flow:action>
	</flow:form>
	<flow:form mode="SHOW" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Recibos.NODATA.form:SHOW" form-class="NucleusRH.Base.Liquidacion.Recibos.NODATA.form">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
