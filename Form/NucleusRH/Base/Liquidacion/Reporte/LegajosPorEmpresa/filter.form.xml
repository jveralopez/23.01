<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.Reportes.LegajosPorEmpresa.filter.form" doc="source" default_mode="FILTER" name="LegajoPorEmpresa">
	<form:Title>
		<form:Label label="001 - Listado de Legajos" style="S3 LCol_w" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4"/>
		<form:Columns name="cHECKS">
			<form:Column name="sasa" separation="2" align="center" valign="top">
				<form:Rower separation="20" width="100%" name="rower1">
					<form:Label name="aaVCVCsa" label="Datos de Liquidaci&#243;n" style="M1 LCol_t" nowrap="1" align="center"/>
					<form:CheckBox label="Todos" name="all_liq" nvalue="" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Reporte/LegajosPorEmpresa/filter/form/all_per">
						<form:Event action="toggleAll" name="onclick" runat="client"/>
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Reporte/LegajosPorEmpresa/filter/form/all_per/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Reporte/LegajosPorEmpresa/filter/form/all_per"/>
						</form:Policies>
					</form:CheckBox>
				</form:Rower>
				<form:CheckBox label="Cuenta Bancaria" name="c_cta_bancaria" nvalue="#PARAMETERS:@c_cta_bancaria"/>
				<form:CheckBox label="Banco - Sucursal" name="banco" nvalue="#PARAMETERS:@banco"/>
				<form:CheckBox label="CBU" name="c_cbu" nvalue="#PARAMETERS:@c_cbu"/>
				<form:CheckBox nvalue="#PARAMETERS:@oi_distrib_cos" label="Distribuci&#243;n de Costos" name="oi_distrib_cos"/>
				<form:CheckBox label="Observaci&#243;n Leg.Liquidaci&#243;n" name="o_liq_per" nvalue="#PARAMETERS:@o_liq_per"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function toggleAll(me)
{
	var col = me.m_Parent.m_Parent;
	
	if (me.GetXValue()=="0")
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("0");
			} catch(err){}
		}
	}
	else
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{
				col.GetChild(i).SetXValue("1");
			} catch(err){}
		}
	}
}
	</form:Scripts>
</form:Form>
