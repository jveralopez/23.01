<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.report.flow" name="Nomad.Base.Liquidacion.Recibos">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" e_periodo="200802" oi_empresa="164" modo="HTML" oi_liquidacion="40" OI_REPORTE="2" l_sueldo="1" l_sujeto="1" l_nosujeto="1" l_cuil="1" l_legajo="1" l_nombre="1" l_desc="1" l_cont="1" l_totpag="1"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.sim.filtro.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.sim.filtro.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.sim.filtro.form" extends="Nomad.Base.Report.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="ppp9"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ReportesPorConceptos.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ReportesPorConceptos.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.form"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.ReportesGenericos" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.ReportesGenericos" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ReportesGenericos.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
