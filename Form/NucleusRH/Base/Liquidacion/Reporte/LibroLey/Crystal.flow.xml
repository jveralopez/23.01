<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.report.Crystal.flow" name="LibroLEy">
	<flow:info label="ReporteFichadasIncorporadas"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO FormatRPT="PDF">
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
		<doc:define name="SUELDOS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Liquidacion.Reporte.LibroLey.Crystal.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.LibroLey.Crystal.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.LibroLey.Crystal.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<!--flow:log text="ppfilterdata" text-path="#FILTERDATA:"/-->
			<flow:call-action action="ACCEPTpdf"/>
		</flow:action>
		<flow:action name="ACCEPTpdf">
			<!--flow:exec-method priority="5" out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="SUELDOS" class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" method="LibroSueldos" out-attr-path="">
		<flow:param type="Nomad.NSystem.Proxy.NomadXML" name="report-param" mode="in" doc="FILTERDATA"/>
	</flow:exec-method-->
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="9" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.LibroLey\LibroLeyPDF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param doc="FILTERDATA" name="report-param" mode="in" type="Nomad.NSystem.Object"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTxls">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="9" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.LibroLey\LibroLeyXLS.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTrtf">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="9" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.LibroLey\LibroLeyRTF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.LibroLey" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.LibroLey" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
</flow:flow>
