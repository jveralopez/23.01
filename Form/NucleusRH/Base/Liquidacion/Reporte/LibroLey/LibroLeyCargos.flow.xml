<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="LibroLeyCargos">
	<flow:info label="LibroLeyCargos"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO FormatRPT="PDF">
				<LIQUIDACIONES/>
			</FILTRO>
		</doc:define>
		<doc:define name="SUELDOS"/>
	</flow:declare>
	<flow:main doc="PARAMIN">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LibroLey.LibroLeyCargos.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.LibroLey.LibroLeyCargos.filter.form" name="NucleusRH.Base.Liquidacion.Reporte.LibroLey.LibroLeyCargos.filter.form:FILTER" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="REPORT"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.LibroLey" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reportes.LibroLey" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="REPORT">
			<flow:exec-method method="ExecReportFO" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5">
				<flow:param value="NucleusRH.Base.Liquidacion.LibroLeyCargos.LibroLeyCargos.rpt" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" name="report-param" mode="in"/>
			</flow:exec-method>
			<flow:open-form mode="BATCH" form-class="Nomad.base.batch.report.form" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
