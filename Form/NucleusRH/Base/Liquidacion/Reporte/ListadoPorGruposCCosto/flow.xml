<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS report="" oi_liquidacion="" salida="HTML"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param type="Nomad.NSystem.String" mode="in" name="ReportName" value="NucleusRH.Base.Liquidacion.ListadoPorConceptos-GCCosto.rpt"/>
				<flow:param name="xmlParam" type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="110 - Totales por Grupo de Centros de Costo" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
