<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto" extends="Nomad.Base.report.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS report="" oi_liquidacion="" salida="HTML"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.sim.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.sim.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.filter.sim.form" mode="FILTER" extends="Nomad.Base.Report.filtro.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen template-file="NucleusRH.Base.Liquidacion.ListadoPorConceptos-GCCosto.rpt" ext="html" input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen template-file="NucleusRH.Base.Liquidacion.ListadoPorConceptos-GCCosto.rpt" ext="xls" input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorGruposCCosto.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
