<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Liquidacion.Reporte.DeduccionesPorPersona">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Reporte.DeduccionesPorPersona"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.DeduccionesPorPersona.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Liquidacion.Reporte.DeduccionesPorPersona.filter.form:FILTER" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.DeduccionesPorPersona.filter.form" mode="FILTER">
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Personal.Reporte.DeduccionesPorPersona"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Personal.Reporte.DeduccionesPorPersona"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="logDianeSource" text-path="#SOURCE:"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Liquidacion.FamiliaresDeduccionesIG.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="207 - Deducciones Por Persona" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
