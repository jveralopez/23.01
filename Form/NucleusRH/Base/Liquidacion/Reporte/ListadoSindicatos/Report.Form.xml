<form:Form xmlns:form="nomad_engine.form" doc="source" name="listadosindicatos" extends="nomad.Base.report.filtro.form">
	<form:Title>
		<form:Label label="103 - Listado de Sindicatos" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:Combo name="oi_empresa" nvalue="#source:@c_empresa" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Liquidacion.Interface.EMPRESA_DDO.combo.flow" action="COMBO"/>
		<form:Blank visible="" width="100%" name="b3la4"/>
		<form:DateTime name="e_periodo" nvalue="#source:@e_periodo" label="Per&#237;odo" mask="dd/mm/yyyy" enabled="NEW|EDIT" required="1" pattern="YYYYMM">
			<form:SButtons>
				<form:SButton visible="EDIT|NEW" name="Calendar" label="Calendar" img="Calendar">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Grid idvalue="#SOURCE:@oi_sindicato" width="480px" nvalue="#source:SINDICATOS" doc="SOURCE" proto="&lt;SINDICATO/&gt;" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdSindicatos">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput name="oi_sindicato" nvalue="#SOURCE:@oi_sindicato" label="Sindicato" length="30" xsize="15" enabled="NEW|EDIT|REINGRESAR" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.Guia.autoflow">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton name="SEARCH" label="Search" visible="NEW|EDIT|REINGRESAR" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="b33l37" width="100%" visible=""/>
		<form:Combo required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
