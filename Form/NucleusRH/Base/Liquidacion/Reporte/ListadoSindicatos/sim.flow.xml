<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initializeListadoSindicatos" name="Nomad.Base.Liquidacion.Recibos" extends="Nomad.Base.report.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTER_DATA"/>
		<doc:define name="DOC_OUT"/>
		<doc:define name="RECIBO"/>
		<doc:define name="FILTERDATA">
			<DATOS c_empresa="" e_periodo="" report="" salida="HTML">
				<SINDICATOS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initializeListadoSindicatos">
			<flow:open-form mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.Report.form" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.Report.form" doc="SOURCE" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.Report.form" extends="Nomad.Base.Report.filtro.form">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<!--flow:log text-path="#SOURCE:" text="logpp"/-->
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ListadoSindicatos.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.ListadoSindicatos.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.form"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoSindicatos" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoSindicatos" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.form" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoSindicatos.form" mode="REPORT" extends="Nomad.report.form:REPORT"/>
</flow:flow>
