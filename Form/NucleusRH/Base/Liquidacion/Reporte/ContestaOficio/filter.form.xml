	<form:Scripts>
		function valEmbargo(me)
{
	if (Ctrl('LIST').RowsCount() == 0)
	{
		me.SetError('No hay ning&#250;n embargo seleccionado');
		return false;
	}
	return true;
}

function RELOAD()
{	
	var MyRows;
	var PARAM = "&lt;DATOS oi_personal_emp=\""+Ctrl('oi_personal_emp').GetXValue()+"\" /&gt;";		
	MyRows=GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_EMBARGOS"), PARAM)
		
	Ctrl("LIST").processResult(MyRows.ToString());	
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;DATOS oi_personal_emp=&quot;2063&quot;/&gt;" name="QRY_EMBARGOS">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="qry1" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				SELECT 
					EMB.oi_embargo,
					EMB.e_nro_oficio,
					EMB.f_recepcion,
					EMB.o_caratula,
					EMB.c_nro_expediente,
					EMB.c_estado
				FROM 
					LIQ07_EMBARGOS AS EMB
				WHERE 				
					EMB.oi_personal_emp = {#PARAM:@oi_personal_emp}	AND
					EMB.c_tipo_embargo = \'OC\' AND
			 		EMB.c_estado = \'I\' 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_embargo"/>
						<qry:attribute name="f_recepcion" value="$r/@f_recepcion"/>
						<qry:attribute name="e_nro_oficio" value="$r/@e_nro_oficio"/>
						<qry:attribute name="c_nro_expediente" value="$r/@c_nro_expediente"/>
						<qry:attribute name="o_caratula" value="$r/@o_caratula"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
