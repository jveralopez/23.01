<form:Form xmlns:form="nomad_engine.form" name="filtro.reporte.novedadesliquidacion" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Scripts>
		function clearLiq()
{
	Ctrl('oi_liquidacion').SetCValue('');
}
	</form:Scripts>
	<form:Title>
		<form:Label label="115 - Diferencias de Ejecuciones" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:FKInput label="Empresa - Liquidaci&#243;n" required="1" enabled="" xsize="15" length="30" nvalue="#source:@oi_liquidacion" name="oi_liquidacion">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.NOSIM.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="blk12"/>
		<form:NumberBox label="Secuencia desde" nvalue="#source:@sec1" name="desde"/>
		<form:NumberBox nvalue="#source:@sec2" label="Secuencia Hasta" name="hasta"/>
		<form:Blank name="zzzz"/>
		<form:Combo visible="0" required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
