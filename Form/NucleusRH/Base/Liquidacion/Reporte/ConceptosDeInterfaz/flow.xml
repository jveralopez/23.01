<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="Nomad.Base.Liquidacion.ConceptosDeInterfaz">
	<flow:info label="Flow para Nomad.Base.Liquidacion.ConceptosDeInterfaz">
		Flow para Nomad.Base.Liquidacion.ConceptosDeInterfaz
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" salida="HTML" oi_liquidacion="" oi_variable="" report="">
				<ROWS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ConceptosDeInterfaz.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.ConceptosDeInterfaz.filtro.form" name="NucleusRH.Base.Liquidacion.Reporte.ConceptosDeInterfaz.filtro.form:EDIT" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Conceptos de Interfaz" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="pstrReportName" value="NucleusRH.Base.Liquidacion.ConceptosDeInterfaz.rpt" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="116 - Conceptos de Interfaz" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ConceptosDeInterfaz1" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ConceptosDeInterfaz1" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
