<form:Form xmlns:form="nomad_engine.form" name="Filtro del Listado de variable por grupo" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="125 - Variables Por Grupo" help-stop="1" name="lbl_titulo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:ComboBox required="1" label="Empresa" name="oi_empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" mode="QRY">
			<options/>
		</form:ComboBox>
		<form:Blank name="blk12"/>
		<form:ComboBox required="1" prev="oi_empresa" label="Liquidacion" name="oi_liquidacion" nvalue="#source:@oi_liquidacion" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" mode="QRY">
			<options/>
		</form:ComboBox>
		<form:Blank name="xxxx"/>
		<form:ComboBox queryname1="NucleusRH.Base.Liquidacion.Grupos.GRUPO.INFO" mode="QRY" required="1" label="Grupo" nvalue="#source:@oi_grupo" name="oi_grupo"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
