<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.Liquidacion.Reporte.Formulario572">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Reporte.Formulario572"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS/>
		</doc:define>
		<doc:define name="QRY">
			<ROWS/>
		</doc:define>
		<doc:define name="RAIZBACKUP">
			<DATOS/>
		</doc:define>
		<doc:define name="RAIZ">
			<DATOS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario572.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.Formulario572.filter.form:FILTER" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.Formulario572.filter.form" mode="FILTER">
		<flow:action name="on-open">
			<!--flow:call-action action="Load-FILTER"/-->
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:load-user-data name="Lista_IDS_f572" doc="QRY"/>
			<doc:assign-value from-path="#RAIZBACKUP:" to-doc="RAIZ"/>
			<doc:add-object parent-doc-path="#RAIZ:" doc-path="#QRY:"/>
			<doc:add-object doc-path="#FILTERDATA:" parent-doc-path="#RAIZ:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="REPORT"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.Formulario572" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.Formulario572" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="REPORT">
			<flow:call-action else="REPORT_SCREEN" eq="1" if="#SOURCE:@l_archivo" action="REPORT_FILE"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#QRY:" attach-id="ARRB"/>
		</flow:action>
		<flow:action name="NODATA"/>
		<flow:action name="REPORT_FILE">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" priority="5" out-attr-path="#BATCHDOC:@batch-id" method="Form572">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc-path="#RAIZ:" mode="in" name="report-param"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batch.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="REPORT_SCREEN">
			<flow:exec-method class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" priority="5" out-attr-path="#BATCHDOC:@batch-id" method="Form572">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc-path="#RAIZ:" mode="in" name="report-param"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
