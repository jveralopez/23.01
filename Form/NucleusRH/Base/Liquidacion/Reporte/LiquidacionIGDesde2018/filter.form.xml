<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="Filtro del reporte de la impresion LiquidacionIGDesde2018" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR.form" doc="source">
	<form:Title>
		<form:Label label="215 - Liquidaci&#243;n IG - 4ta cat. Rel. de Dependencia" name="lbl_titulo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event action="Filtrar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SendToServer()
{       
	GetProxy().StoreService().SetUserStore("Lista_IDS_IC", array2stringcustom(arrB, "ROWS", "ROW"));
	return true;
}

function Filtrar()
{
	SendToServer();
	Ctrl("main").DoEvent("ACCEPT");
}

function enable_custom_buttons()
{
	CtrlEnabled("btnAccept", Ctrl("list2").TotalRowsCount()?true:false);
}         

function val_orden() 
{
if (Ctrl('orden1').GetXValue() == "P.c_ubicacion" || Ctrl('orden1').GetXValue() == "U.d_ubicacion")
 {
 	CtrlEnabled('orden2',true);
 }
else
 {
  CtrlEnabled('orden2',false);
  Ctrl("orden2").SetXValue("");
 } 
}              
function cargarPagina()
{
	Ctrl("vgroupDatosPers").SetXValue('0');	
	var reporte = Ctrl("reporte");          
  	MyCUR = reporte.m_opts.LastChild();
 	reporte.SetXValue(MyCUR.GetAttr("value"));			 
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
	<form:Center width="100%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:VGroup visible="" nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:ComboBox nvalue="#source:@oi_empresaFIL" name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
			<form:ComboBox where1="LIQ19_LIQUIDACION.oi_tipo_liq != 7" nvalue="#source:@oi_liquidacionFIL" prev="empresa" name="oi_liquidacionFil" label="Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1"/>
			<form:ComboBox label="Version del Reporte" nvalue="#source:@reporte" docname="REPORTES" xsize="40" mode="DOC" required="0" name="reporte">
				<options/>
			</form:ComboBox>
			<form:DateTime pattern="YYYYMMDD" nvalue="#source:@f_fecha" name="f_fecha" label="Fecha emisi&#243;n">
				<form:SButtons>
					<form:SButton img="Calendar" label="Calendar" name="Calendar">
						<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
					</form:SButton>
				</form:SButtons>
			</form:DateTime>
			<form:CheckBox nvalue="#source:@l_anioAnterior" label="Obtener Formulario 649 del a&#241;o anterior incluyendo el ajuste" name="l_anioAnterior"/>
			<form:CheckBox nvalue="#source:@l_archivo" label="Guardar formularios en archivos separados" name="l_archivo"/>
			<form:CheckBox nvalue="#source:@l_retencion" label="Solo legajos con retenci&#243;n" name="l_retencion"/>
			<form:Rower separation="6" label="Ordenar por" name="rwerOrden">
				<form:Combo nvalue="#source:@orden1" label="Orden" name="orden1">
					<form:Opts>
						<OPT code="P.c_ubicacion" value="P.c_ubicacion" text="Cod de Ubicaci&#243;n"/>
						<OPT code="U.d_ubicacion" value="U.d_ubicacion" text="Desc de Ubicaci&#243;n"/>
						<OPT code="0" value="0" text="Legajo"/>
						<OPT code="P.d_ape_y_nom" value="P.d_ape_y_nom" text="Apellido y Nombre"/>
					</form:Opts>
					<form:Event name="onchange" action="val_orden" runat="client"/>
				</form:Combo>
				<form:Label style="S2 LCol_g" label="y luego por" name="lbl_orden"/>
				<form:Combo nvalue="#source:@orden2" name="orden2">
					<form:Opts>
						<OPT code="0" value="0" text="Legajo"/>
						<OPT code="P.d_ape_y_nom" value="P.d_ape_y_nom" text="Apellido y Nombre"/>
					</form:Opts>
				</form:Combo>
			</form:Rower>
		</form:VGroup>
		<form:VGroup name="vgroupDatosPers" nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas">
			<form:Columns visible="0" name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@empresa" name="empresa"/>
				</form:Column>
			</form:Columns>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Event action="cargarPagina" name="onload" runat="client"/>
</form:Form>
