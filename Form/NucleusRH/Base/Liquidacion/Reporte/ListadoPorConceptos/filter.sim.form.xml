<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.filter" doc="source" extends="nomad.Base.report.filtro.form">
	<form:Title>
		<form:Label label="Totales por Concepto" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:FKInput label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" nvalue="#source:@oi_liquidacion" length="30" xsize="15" enabled="" required="1">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.LiquidacionDDO.LIQUIDACION_DDO.guia.SISIM.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="b3la5" width="100%" visible=""/>
		<form:Combo label="Tipo de Concepto" action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.Combo.autoflow" required="0" nvalue="#source:@oi_tipo_concepto" name="oi_tipo_concepto"/>
		<form:Blank name="b3lacd5" width="100%" visible=""/>
		<form:RowAligner name="fggfgf">
			<form:Row name="fgfgggfgggg">
				<form:CheckBox descrip="Indica si el reporte sale por centro de costo" label="Por centro de costo?" nvalue="#FILTERDATA:@ccosto" name="centro"/>
				<form:FKInput label="Centro Costo" required="0" xsize="15" length="30" nvalue="#FILTERDATA:@oi_centro_costo" name="oi_centro_costo">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_centro_costo.Text.1}" id="{oi_centro_costo.XVal}" code="{oi_centro_costo.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" visible="" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blanco01" width="100%" visible=""/>
		<form:Combo required="1" nvalue="#FILTERDATA:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
			<form:Opts name="aaa">
				<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
				<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function clearLiq()
{
	Ctrl('oi_liquidacion').SetCValue('');
}
	</form:Scripts>
</form:Form>
