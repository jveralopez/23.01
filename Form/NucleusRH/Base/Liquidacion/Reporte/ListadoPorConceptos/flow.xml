<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize_detalle" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" oi_liquidacion="" c_empresa="" oi_tipo_concepto="" c_concepto=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.filter.form" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="initialize_detalle">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.Detalle.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" mode="FILTER" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.filter.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.filter.form" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Listado por Concepto" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="pstrReportName" value="NucleusRH.Base.Liquidacion.ListadoPorConceptos.rpt" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.Detalle.filter.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.Detalle.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.Detalle" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoPorConceptos.Detalle" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Listado por Concepto (Detalle)" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="pstrReportName" value="NucleusRH.Base.Liquidacion.DetalleConceptos.rpt" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
