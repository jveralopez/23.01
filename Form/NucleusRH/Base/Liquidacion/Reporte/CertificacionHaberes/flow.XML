<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.report.flow" name="Nomad.Base.Liquidacion.Recibos">
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" e_periodo="" c_empresa="">
				<OSS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.CertificacionHaberes.Report.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.CertificacionHaberes.Report.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.CertificacionHaberes.Report.form" extends="Nomad.Base.Report.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method out-type="String" out-attr-path="#SOURCE:@batch-id" priority="5" method="execute" class="Nomad.NSystem.Interface.NmdInterfaceBatch">
				<flow:param value="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.ReporteCertificacionHaberes" name="interface_name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param doc="SOURCE" name="interface_param" mode="in" type="Nomad.NSystem.Object" class="Nomad.NSystem.Document.NmdXmlDocument"/>
				<flow:param value="{BATCHID}.rtf" name="interface_file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.Base.Batch.Download.form" mode="BATCH" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoObraSocial" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.ListadoObraSocial" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="Nomad.Base.Batch.Download.form" name="Nomad.Base.Batch.Download.form:BATCH" mode="BATCH" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="download">
			<flow:close-form/>
			<flow:open-form mode="DOWNLOAD_RTF" form-class="Nomad.Base.Batch.Download.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="DOWNLOAD_RTF" name="Nomad.Base.Batch.Download.form:DOWNLOAD" form-class="Nomad.Base.Batch.Download.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="download"/>
	</flow:form>
</flow:flow>
