<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize2" extends="Nomad.base.HTML_XLS.flow" name="Nomad.Base.Liquidacion.ListadoConceptosPorPersonas">
	<flow:info label="Flow para Nomad.Base.Liquidacion.ListadoConceptosPorPersonas">
		Flow para Nomad.Base.Liquidacion.ListadoConceptosPorPersonas
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_empresa="" salida="HTML" oi_liquidacion="" oi_variable="" report="" gconceptos="1">
				<ROWS/>
				<PERSONAS/>
				<LIQUIDACIONES/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="initialize2">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro2.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro.form" name="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro.form:EDIT" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="log_filterdata"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Reportes de Conceptos por Persona" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param value="NucleusRH.Base.Liquidacion.ListadoConceptosPorPersonas.rpt" name="pstrReportName" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="113 - Listado Conceptos Por Personas" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro2.form" name="NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas.filtro2.form:EDIT" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Liquidacion.ListadoConceptosPorPersonas2.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="113 - Listado de Conceptos por Personas" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas2" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.ListadoConceptosPorPersonas2" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
