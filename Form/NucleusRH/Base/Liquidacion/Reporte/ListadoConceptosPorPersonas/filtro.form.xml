<form:Form xmlns:form="nomad_engine.form" name="113-filtro.reporte.ListadoConceptosPorPersonas" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Scripts>
		function clearLiq()
{
	Ctrl('oi_liquidacion').SetCValue('');
}
	</form:Scripts>
	<form:Title>
		<form:Label label="113 - Listado de Conceptos por Personas" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:VGroup visible="" nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="empresa"/>
			<form:DateTime pattern="YYYYMM" required="1" enabled="" nvalue="#source:@e_periodo" mask="mm/yyyy" label="Periodo" name="e_periodo" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Reporte/InterfazContable/filtro/form/e_periodo">
				<form:SButtons>
					<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
						<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
					</form:SButton>
				</form:SButtons>
			</form:DateTime>
			<form:ComboBox label="Liquidaci&#243;n" name="oi_liquidacion" prev="empresa" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_liquidacion"/>
			<!--form:ComboBox label="Centro de Costo" queryname1="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.INFO" nvalue="#source:@oi_centro_costo" name="oi_centro_costo" xsize="40" mode="QRY" required="0"/>
	
	<form:ComboBox label="Cuenta" name="c_cuenta" prev="oi_int_cont" queryname1="NucleusRH.Base.Liquidacion.Interfase_Contable.DET_INT_CONT.INFO1" xsize="40" mode="QRY" required="0" nvalue="#source:@c_cuenta"/>
	
	<form:ComboBox xsize="60" mode="OPT" required="1" nvalue="#FILTERDATA:@agrupar" label="Agrupar por" name="agrupar">
		<options>
			<option value="Centro" text="Centro de Costo"/>
			<option value="Cuenta" text="Cuenta"/>
			<option value="GCentro" text="Grupo de Centros de Costo"/>
			<option value="CtaGCentro" text="Cuenta X Grupo CCosto"/>
		</options>
		<form:Opts/>
	</form:ComboBox-->
			<form:ComboBox where1="LIQ12_TIPOS_CONC.l_nolistado = 0" queryname1="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.INFO" xsize="40" mode="QRY" required="0" label="Tipo Concepto" nvalue="#source:@oi_tipo_concepto" name="oi_tipo_concepto"/>
			<form:ComboBox required="0" prev="empresa" name="oi_ubicaciondesde" nvalue="#source:@oi_ubicaciondesde" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" label="Ubicaci&#243;n Desde" xsize="40" mode="QRY"/>
			<form:ComboBox required="0" prev="empresa" name="oi_ubicacionhasta" nvalue="#source:@oi_ubicacionhasta" help-stop="0" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" label="Ubicaci&#243;n Hasta" xsize="40" mode="QRY"/>
			<form:CheckBox label="Mostrar todos los conceptos activos" nvalue="#source:@l_mostrarTodos" name="l_mostrarTodos"/>
			<form:ComboBox visible="0" descrip="Indica el formato de salida del Reporte" label="Formato de Salida" mode="OPT" required="1" nvalue="#FILTERDATA:@salida" name="salida">
				<options>
					<option value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
					<option value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
				</options>
				<form:Opts/>
			</form:ComboBox>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gconceptos" visible="" border="1" width="90%" label="Criterios de selecci&#243;n de Conceptos" name="gconceptos" collapse="1">
			<form:Grid width="480px" nvalue="#source:ROWS" proto="&lt;ROW/&gt;" name="grdConcepto" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" doc="SOURCE">
				<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.Conceptos.LM.guia.flow" action="HELP">
					<helper-mess>
						{grdConcepto.Nodes}
					</helper-mess>
				</form:Helper>
				<form:GColumns>
					<form:GColumn allow_order="0">
						<form:FKInput nvalue="#SOURCE:@id" required="0" enabled="" xsize="10" length="30" label="Concepto" name="oi_concepto">
							<form:STexts>
								<form:SText xsize="50" name="txt1"/>
							</form:STexts>
							<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
								<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
							</form:Helper>
							<form:SButtons>
								<form:SButton img="SEARCH" label="Search" name="SEARCH">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:FKInput>
					</form:GColumn>
				</form:GColumns>
			</form:Grid>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
