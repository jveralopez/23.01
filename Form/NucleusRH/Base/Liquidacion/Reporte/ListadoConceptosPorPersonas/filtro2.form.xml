<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Liquidacion.Reporte.Liquidacion.filter.form" name="120-filtro.reporte.ListadoConceptosPorPersonas" doc="source">
	<form:Title>
		<form:Label name="lbl_titulo" label="113 - Listado de Conceptos por Personas" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup visible="" nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" height="100%" name="cols1">
				<form:Column width="50%" name="Coltipo" separation="2" align="right" valign="top">
					<form:ComboBox nvalue="#SOURCE:@oi_empresa" name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
					<form:ComboBox label="Mostrar" name="mostrar" nvalue="#SOURCE:@mostrar" xsize="40" mode="OPT" required="1">
						<options>
							<option text="Valor" value="v"/>
							<option text="Cantidad" value="c"/>
							<option value="Todos" text="Todos"/>
						</options>
					</form:ComboBox>
					<form:ComboBox queryname1="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.INFO" label="Tipo de conceptos" name="oi_tipo_concepto" nvalue="#SOURCE:@oi_tipo_concepto" xsize="40" mode="QRY" required="0"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Scripts>
		function change_val ()
{
	Ctrl("n_valor").SetXValue("1");
	Ctrl("n_cantidad").SetXValue("0");
}
function change_can ()
{
	Ctrl("n_valor").SetXValue("0");
	Ctrl("n_cantidad").SetXValue("1");
}
	</form:Scripts>
</form:Form>
