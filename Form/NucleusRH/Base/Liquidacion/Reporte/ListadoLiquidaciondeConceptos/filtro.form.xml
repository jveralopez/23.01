<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Reporte.ListadoLiquidaciondeConceptos" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="nomad.filter.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Conceptos" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Label name="lbl2" label="Criterios de B&#250;squeda" visible="" align="center" style="S3 LCol_g"/>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Columns name="columns1">
			<form:Column name="col1">
				<form:Rower name="rwerconcepto" separation="5" label="Conceptos">
					<form:NumberBox precision="0" length="10" help-stop="1" xsize="6" nvalue="#source:@cod_desde" name="cod_desde"/>
					<form:Label label="..." name="lbl_hasta"/>
					<form:NumberBox precision="0" length="10" xsize="6" nvalue="#source:@cod_hasta" name="cod_hasta"/>
				</form:Rower>
				<form:Blank name="blnk001"/>
				<form:Combo name="cboActivo" label="Est&#225; Activo" nvalue="#source:@l_activo" note="" flow="NucleusRH.Base.Liquidacion.SiNo.enum" action="COMBO"/>
				<form:Blank name="blnk002"/>
				<form:Grid idvalue="#SOURCE:@id" nvalue="#source:CONCEPTOS" width="480px" proto="&lt;CONCEPTO/&gt;" name="grdConcepto" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCE">
					<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.Conceptos.LM.guia.flow" action="HELP">
						<helper-mess>
							{grdConcepto.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput required="0" enabled="" xsize="10" length="30" label="Concepto" nvalue="#SOURCE:@id" name="oi_concepto">
								<form:STexts>
									<form:SText xsize="40" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Combo flow="NucleusRH.Base.Liquidacion.SiNo.enum" nvalue="#source:@ca_fig_recibo" name="cboFigRecibo" label="Figura en Recibo" note="" descrip="" action="COMBO"/>
				<form:CheckBox label="Incluir formula?" nvalue="#source:@l_incluir" name="l_incluir"/>
				<form:CheckBox nvalue="#source:@l_incluir1" name="l_incluir1" label="Incluir Observaci&#243;n"/>
				<form:Rower name="rwerObservacion" separation="5" label="Contiene Descripci&#243;n">
					<form:TextBox nvalue="#source:@contiene_observacion" length="10" precision="0" xsize="40" name="contiene_observacion"/>
				</form:Rower>
				<form:ComboBox nvalue="#source:@oi_tipo_liq" name="oi_tipo_liq" queryname1="NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ.INFO" xsize="40" mode="QRY" required="0" label="Tipo Liquidaci&#243;n"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
			</form:Column>
		</form:Columns>
		<form:Line name="line_1" width="60%"/>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:Label name="lbl201" label="Criterios de Ordenaci&#243;n" align="center" style="S3 LCol_g"/>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:RowAligner name="RAcamposOrden" columns="2">
			<form:Row name="RC1O">
				<form:Combo flow="NucleusRH.Base.Liquidacion.Conceptos.atribFiltro.enum" name="cboCampo1" note="" action="COMBO" nvalue="#source:@ATRIB_ORDEN1"/>
				<form:Combo name="cboOrdenCampo1" label="" note="AscendenteDecendente" flow="NucleusRH.Base.Orden.enum" action="COMBO" nvalue="#source:@ORDEN1" style="S3 LCol_g"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button visible="FILTER0" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
				<form:Blank name="blank_buttons"/>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
