	function Find()
{
	Ctrl("TiposLiq").filter("",Ctrl("iter_search").GetCValue());
}
function ClearTIPOS()
{
	Ctrl("TIPOS").DelAllRow();
	Ctrl("TiposLiq").Refresh();
}
function FullTIPOS()
{
	Ctrl("TIPOS").DelAllRow();     
	for (var t=0; t&lt;Ctrl("TiposLiq").TotalRowsCount(); t++)
		Ctrl("TIPOS").AddRow().SetAttr("id", Ctrl("TiposLiq").GetAttrValue(t, "id"));
		Ctrl("TiposLiq").Refresh();
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
</form:Form>
