<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Liquidacion.Legajo.filter2.form" name="Filtro del Listado de Totales por Conceptos" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="118 - Totales por Conceptos" help-stop="1" name="lbl_titulo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
