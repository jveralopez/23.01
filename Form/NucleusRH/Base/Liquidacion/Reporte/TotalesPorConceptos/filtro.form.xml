						</form:SButtons>
					</form:DateTime>
					<form:DateTime label="Periodo Hasta" pattern="YYYYMM" required="1" enabled="" mask="dd/mm/yyyy hh:mm:ss" nvalue="#FILTERDATA:@f_has" name="f_has">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Rower name="rwerconcepto" separation="5" label="Conceptos">
						<form:NumberBox precision="0" length="10" help-stop="1" xsize="6" nvalue="#source:@cod_desde" name="cod_desde"/>
