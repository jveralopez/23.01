					</form:Rower>
					<form:ComboBox nvalue="#SOURCE:@oi_liquidacionFIL" prev="empresa" name="oi_liquidacionFil" label="Liquidaci&#243;n" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="0"/>
					<form:ComboBox xsize="40" mode="OPT" required="0" label="Agrupar por" nvalue="#source:@c_agrupacion" name="c_agrupacion">
						<options>
							<option text="Ubicaci&#243;n" value="ubicacion"/>
							<option text="Obra Social" value="obra"/>
							<option text="Sindicato" value="sindicato"/>
							<option text="Convenio" value="convenio"/>
							<option text="Categor&#237;a" value="categ"/>
						</options>
					</form:ComboBox>
					<form:CheckBox label="Listar Detalle" nvalue="#source:@l_incluir" name="l_incluir"/>
					<form:ComboBox prev="empresa" name="oi_ubicaciondesde" nvalue="#SOURCE:@oi_ubicaciondesde" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" label="Ubicaci&#243;n Desde" xsize="40" mode="QRY"/>
					<form:ComboBox prev="empresa" name="oi_ubicacionhasta" nvalue="#SOURCE:@oi_ubicacionhasta" help-stop="0" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" label="Ubicaci&#243;n Hasta" xsize="40" mode="QRY"/>
				</form:Column>
				<form:Column height="100%" name="col1" width="100%" separation="2" align="right" valign="top">
					<form:ListView docname="TIPOS" arr-control="TIPOS" nvalue="#source:@selected" rows="4" width="350px" label="tiposLiq" name="TiposLiq">
						<form:LVColumns>
							<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Tipo Liquidaci&#243;n" name="des"/>
						</form:LVColumns>
						<form:SButtons>
							<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
								<form:Event action="FullTIPOS" name="OnClick" runat="client"/>
							</form:SButton>
							<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
								<form:Event action="ClearTIPOS" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:ListView>
					<form:HiddenArr nvalue="#source:TIPOS" proto="&lt;C /&gt;" name="TIPOS">
						<form:Attr name="id"/>
					</form:HiddenArr>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%">
				<form:Column valign="middle" name="colemp" align="left">
					<form:ComboBox enabled="0" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="empresa"/>
				</form:Column>
			</form:Columns>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="60%"/>
	<form:Scripts>
		function enable_buttons()
{                                                                 
	if (Ctrl("list1"))
	{
		CtrlEnabled("DEL"    , Ctrl("list1").TotalRowsCount()?true:false);
		CtrlEnabled("DEL_ALL", Ctrl("list1").TotalRowsCount()?true:false);

		CtrlEnabled("list1_Clear" , Ctrl("list1").TotalRowsCount()?true:false);
		CtrlEnabled("list1_Delete", Ctrl("list1").TotalRowsCount()?true:false);
		CtrlEnabled("list1_UnMark", Ctrl("list1").TotalRowsCount()?true:false);
	}
	if (Ctrl("list2"))
	{
		CtrlEnabled("ADD"    , Ctrl("list2").TotalRowsCount()?true:false);
		CtrlEnabled("ADD_ALL", Ctrl("list2").TotalRowsCount()?true:false);
		
		CtrlEnabled("list2_Clear" , Ctrl("list2").TotalRowsCount()?true:false);
		CtrlEnabled("list2_Delete", Ctrl("list2").TotalRowsCount()?true:false);
		CtrlEnabled("list2_UnMark", Ctrl("list2").TotalRowsCount()?true:false);
	}
	
}


