<form:Form xmlns:form="nomad_engine.form" name="Listado de Anticipos" doc="source" extends="nomad.Base.report.filtro.form">
	<form:Title>
		<form:Label label="002 - Listado de Anticipos" name="lblTitulo" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="70%">
		<form:Columns name="sd">
			<form:Column name="dasf">
				<form:Blank name="k"/>
				<form:Combo name="oi_empresa" nvalue="#source:@oi_empresa" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
				<form:Combo nvalue="#source:@oi_tipo_anticipo" action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipo_Anticipo.TIPO_ANTICIPO.Combo.autoflow" required="0" label="Tipo de anticipo" name="oi_tipo_anticipo"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.ANTICIPO.c_estado.Combo.autoflow" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				<form:DateTime nvalue="#source:@f_desde_anticipo" name="f_desde_anticipo" label="Fecha Desde Anticipo" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_hasta_anticipo" label="Fecha Hasta Anticipo" nvalue="#source:@f_hasta_anticipo" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="kk"/>
				<form:RowAligner name="RAFiltros2" columns="2">
					<form:Row name="Rcampo2">
						<form:Grid idvalue="#SOURCE:@id" width="480px" proto="&lt;PERSONA/&gt;" nvalue="#source:PERSONAS" name="grdDatosPersona" note="" descrip="" rows="5" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCE">
							<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.GUIA_COMPLEJO.FLOW" action="HELP">
								<helper-mess>
									{grdDatosPersona.Nodes}
								</helper-mess>
							</form:Helper>
							<form:GColumns>
								<form:GColumn allow_order="0">
									<form:FKInput nvalue="#SOURCE:@id" required="0" enabled="" xsize="15" length="30" label="Personal" name="oi_personal_emp">
										<form:STexts>
											<form:SText name="txt1" xsize="45"/>
										</form:STexts>
										<form:Helper name="NucleusRH.Base.Liquidacion.Legajo_Liquidacion.PERSONAL_EMP.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
											<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
										</form:Helper>
										<form:SButtons>
											<form:SButton img="SEARCH" label="Search" visible="NEW|EDIT" name="SEARCH">
												<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
											</form:SButton>
										</form:SButtons>
									</form:FKInput>
								</form:GColumn>
							</form:GColumns>
						</form:Grid>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
