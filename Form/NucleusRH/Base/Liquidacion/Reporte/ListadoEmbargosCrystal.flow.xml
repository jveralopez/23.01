<flow:flow extends="Nomad.Base.flow" default_action="initialize" name="Nomad.Base.Liquidacion.Recibos" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="EDIT" doc-path="#SOURCE:" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoEmbargosCrystal.Filter.form"/>
		</flow:action>
	</flow:main>
	<flow:info label="Flow para Nomad.Base.Liquidacion.Recibos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	
	
	
	
	
	
	
	
	</flow:info>
	<flow:declare>
		<doc:define name="FiltroReporte">
			<FILTRO oi_empresa="" file-name="" batch-id="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ListadoEmbargosCrystal.Filter.form:EDIT" mode="EDIT" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.ListadoEmbargosCrystal.Filter.form">
		<flow:action name="ACCEPT">
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FiltroReporte" a-doc="FORM">
				<map docB="B" docA="A">
					<link B="#B:@oi_empresa" A="#A:ctrl[@id='oi_empresa']/@xval"/>
					<submap path-docB="#B:PERSONAS" path-docA="#A:ctrl[@id='grdDatosPersona']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_personal_emp']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<PERSONA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:exec-method out-attr-path="#FiltroReporte:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="TestCrystal\Informe.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FiltroReporte"/>
				<flow:param attr-path="#FiltroReporte:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FiltroReporte:"/>
		</flow:action>
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
