<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Personal.Reportes.Legajo.flow" name="NucleusRH.Base.Liquidacion.Conceptos.listado" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Conceptos"/>
	<flow:declare>
		<doc:define name="QRY"/>
		<doc:define name="FILTERDATA">
			<FILTRO oi_liquidacion="">
				<CONCEPTOS/>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO ATRIB_ORDEN1=&quot;c_concepto&quot; ORDEN1=&quot;&quot; L_ACTIVO=&quot;&quot; oi_clase_concepto=&quot;&quot; oi_tipo_concepto=&quot;&quot;/&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					c.oi_concepto,
					c.c_concepto,
					c.d_concepto,
					c.oi_grupo_tliq,
					c.oi_tipo_concepto,
					c.oi_clase_concepto,
					c.ca_fig_recibo,
					c.l_activo,
					c.e_secuencia
				FROM 
					LIQ14_CONCEPTOS as c
				WHERE 
					1=1 
	        		{%? (string(#SOURCE:CONCEPTOS/CONCEPTO/@id)!='') {% AND c.OI_CONCEPTO in ({%=string(#SOURCE:CONCEPTOS/CONCEPTO/@id) %}) %} {%  %} %}
	        		{%? (#SOURCE:@oi_tipo_concepto!='') {% AND c.oi_tipo_concepto = {#SOURCE:@oi_tipo_concepto} %} {%  %} %}
	        		{%? (#SOURCE:@oi_clase_concepto!='') {% AND c.oi_clase_concepto = {#SOURCE:@oi_clase_concepto} %} {%  %} %}
	        		{%? (#SOURCE:@ca_fig_recibo!='') {% AND c.ca_fig_recibo={#SOURCE:@ca_fig_recibo} %} {% %} %}
	        		{%? (#SOURCE:@l_activo!='')	{% AND c.l_activo= {%=#SOURCE:@l_activo %} %} {% %} %}
	        		
	        	ORDER BY        			
        			{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
        			{%? (#SOURCE:@ATRIB_ORDEN2!='')	{% {%=#SOURCE:@ATRIB_ORDEN2%} {%? (#SOURCE:@ORDEN2!='') {% {%=#SOURCE:@ORDEN2%}, %} {% ASC, %}	%} %} {% %} %}
        			{%? (#SOURCE:@ATRIB_ORDEN3!='')	{% {%=#SOURCE:@ATRIB_ORDEN3%} {%? (#SOURCE:@ORDEN3!='') {% {%=#SOURCE:@ORDEN3%}, %} {% ASC, %}	%} %} {% %} %}
        			OI_CONCEPTO ASC	

        			        	
        	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_CONCEPTO" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_CONCEPTO" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="obtenerIDs" declare="&lt;FILTRO ATRIB_ORDEN1=&quot;c_concepto&quot; ORDEN1=&quot;&quot; L_ACTIVO=&quot;&quot; oi_clase_concepto=&quot;&quot; oi_tipo_concepto=&quot;&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="FILTRO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:datos"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					c.oi_liquidacion, 
					c.oi_personal_emp, 
					d.e_numero_legajo
				FROM 
					LIQ25_personal_liq as c, per02_personal_emp as d
				JOIN
				  c.oi_personal_emp INNER d.oi_personal_emp
				WHERE 
					1=1 
        		{%? (#SOURCE:@oi_personal_liq!='') 
        			{% AND c.oi_personal_liq = {#SOURCE:@oi_personal_liq} %} 
        			{% AND 1 = 2 %} 
        		%}                   			        	
        	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_liquidacion" name="oi_liquidacion"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@oi_personal_emp" name="oi_personal_emp"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@e_numero_legajo" name="legajo"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.filter.form" doc-path="#PARAMETERS:" mode="FILTER"/>
		</flow:action>
		<flow:action name="initializeDesde25">
			<doc:load-qry output-doc="FILTERDATA" input-doc-path="#SOURCE:" qry="obtenerIDs"/>
			<doc:set-attribute from-attr-path="#FILTERDATA:@oi_personal_emp" to-attr-path="#PARAMETERS:@oi_personal_emp"/>
			<doc:set-attribute from-attr-path="#FILTERDATA:@oi_liquidacion" to-attr-path="#PARAMETERS:@oi_liquidacion"/>
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacionCerrada" doc-path="#PARAMETERS:"/>
			<flow:log text-path="#PARAMETERS:" text="PPOOP"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.filter.form" doc-path="#PARAMETERS:" mode="FILTER1"/>
		</flow:action>
	</flow:main>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.filter.form" doc="FILTERDATA" name="NucleusRH.Base.Liquidacion.LegajoLiquidacion.Cerradas.form:FILTER" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="P1A1RAMETROS" text-path="#PARAMETERS:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Liquidacion.LegajoLiquidacionCerradas.rpt" input-doc-path="#PARAMETERS:" out-file-path="#PARAMETERS:@report"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.form" doc-path="#PARAMETERS:" mode="REPORT"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<!--flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacionCerrada" doc="PARAMETERS"/-->
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacionCerrada" doc-path="#PARAMETERS:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Liquidacion.LegajoLiquidacion.Cerradas.form:FILTER" name="NucleusRH.Base.Liquidacion.LegajoLiquidacion.Cerradas.form:FILTER1" mode="FILTER1" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.filter.form" doc="FILTERDATA"/>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.form" name="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.Cerradas.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
