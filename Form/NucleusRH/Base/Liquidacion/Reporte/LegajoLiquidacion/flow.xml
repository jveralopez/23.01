<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Personal.Reportes.Legajo.flow" name="NucleusRH.Base.Liquidacion.Conceptos.listado" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Conceptos"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.filter.form" doc-path="#PARAMETERS:" mode="FILTER"/>
		</flow:action>
		<flow:action name="initializeDesde25">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#PARAMETERS:@oi_personal_emp"/>
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacion" doc-path="#PARAMETERS:"/>
			<flow:log text-path="#PARAMETERS:" text="PPOOP"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.filter.form" doc-path="#PARAMETERS:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.filter.form" doc="PARAMETERS" name="NucleusRH.Base.Liquidacion.LegajoLiquidacion.form:FILTER" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="chuek_liq" text-path="#PARAMETERS:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Liquidacion.Legajo.rpt" input-doc-path="#PARAMETERS:" out-file-path="#PARAMETERS:@report"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.form"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacion" doc="PARAMETERS"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.LegajoLiquidacion" doc-path="#PARAMETERS:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.form" name="NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
