<flow:flow default_action="initialize" extends="Nomad.Base.report.flow" name="Nomad.Base.Liquidacion.Recibos" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow para Nomad.Base.Liquidacion.ResumenIG">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO e_anio=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.filtro.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.filtro.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.filtro.form" extends="Nomad.Base.Report.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="ESTABAN444" text-path="#FILTERDATA:"/>
			<flow:html-gen template-file="NucleusRH.Base.Liquidacion.ResumenIG.rpt" out-file-path="#FILTERDATA:@report" input-doc-path="#FILTERDATA:"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.ResumenIG" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.ResumenIG" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.form:REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.ResumenIG.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
