<form:Form xmlns:form="nomad_engine.form" name="127 - Totales por Conceptos y Periodos" extends="NucleusRH.Base.Liquidacion.Reporte.Liquidacion.filter.form" doc="source">
	<form:Title>
		<form:Label label="127 - Totales por Conceptos y Periodos" name="lbl_titulo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup visible="" nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns height="100%" width="100%" name="cols1">
				<form:Column width="50%" name="Coltipo" separation="2" align="left" valign="top">
					<form:ComboBox nvalue="#SOURCE:@oi_empresa" name="empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
					<form:ComboBox xsize="40" queryname1="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.INFO" mode="QRY" nvalue="#source:@oi_tipo_concepto" label="Tipo de Concepto" name="oi_tipo_concepto"/>
					<form:Blank name="bl1"/>
					<form:Grid width="480px" nvalue="#source:ROWS" proto="&lt;ROW/&gt;" name="grdConcepto" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" doc="SOURCE">
						<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.Conceptos.LM.guia.flow" action="HELP">
							<helper-mess>
								{grdConcepto.Nodes}
							</helper-mess>
						</form:Helper>
						<form:GColumns>
							<form:GColumn allow_order="0">
								<form:FKInput nvalue="#SOURCE:@id" required="0" enabled="" xsize="10" length="30" label="Concepto" name="oi_concepto">
									<form:STexts>
										<form:SText xsize="50" name="txt1"/>
									</form:STexts>
									<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
										<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
									</form:Helper>
									<form:SButtons>
										<form:SButton img="SEARCH" label="Search" name="SEARCH">
											<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
										</form:SButton>
									</form:SButtons>
								</form:FKInput>
							</form:GColumn>
						</form:GColumns>
					</form:Grid>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
</form:Form>
