<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Liquidacion.Parametros.PARAMETRO.edit" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Configuraci&#243;n Avanzada" nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center height="100%" width="95%">
		<form:Blank name="bb1"/>
		<form:Columns name="cols01">
			<form:Column name="col01" separation="2" align="center" valign="top">
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConFecEgreso']/@d_valor" name="ConFecEgreso" label="Concepto Fecha de Egreso"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConAntiguedad']/@d_valor" name="ConAntiguedad" label="Concepto Antiguedad"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConMejorRemun']/@d_valor" name="ConMejorRemun" label="Concepto Mejor Remuneraci&#243;n"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConRecupInver']/@d_valor" name="ConRecupInver" label="Concepto Recupero de Inversi&#243;n"/>
				<form:Line name="line1"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConPreaviso']/@d_valor" name="ConPreaviso" label="Conceptos Preaviso"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConSacProp']/@d_valor" name="ConSacProp" label="Conceptos Sac Proporcional"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConVacNoGoz']/@d_valor" name="ConVacNoGoz" label="Conceptos Vacaciones no Gozadas"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConIndAntig']/@d_valor" name="ConIndAntig" label="Conceptos Ind. Antiguedad"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConIndClien']/@d_valor" name="ConIndClien" label="Conceptos Ind. por Clientela"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConIndVencC']/@d_valor" name="ConIndVencC" label="Conceptos Ind. Venc. Contrato"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConIndInval']/@d_valor" name="ConIndInval" label="Conceptos Ind. por Invalidez"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConIndFalle']/@d_valor" name="ConIndFalle" label="Conceptos Ind. por Fallecimiento"/>
				<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConOtrasInd']/@d_valor" name="ConOtrasInd" label="Conceptos otras Ind. / Gratif."/>
				<form:Rower label="Auxiliar 1 (Descripci&#243;n - Conceptos)" name="rr1">
					<form:TextBox length="100" xsize="30" nvalue="#source:PARAM[@c_parametro='DescAux1']/@d_valor" name="DescAux1" label="Descripci&#243;n Auxiliar 1"/>
					<form:Label style="S2 LCol_g" name="ll1" label=" - "/>
					<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConAux1']/@d_valor" name="ConAux1" label="Conceptos Auxiliar 1"/>
				</form:Rower>
				<form:Rower label="Auxiliar 2 (Descripci&#243;n - Conceptos)" name="rr2">
					<form:TextBox length="100" xsize="30" nvalue="#source:PARAM[@c_parametro='DescAux2']/@d_valor" name="DescAux2" label="Descripci&#243;n Auxiliar 2"/>
					<form:Label style="S2 LCol_g" name="ll1" label=" - "/>
					<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConAux2']/@d_valor" name="ConAux2" label="Conceptos Auxiliar 2"/>
				</form:Rower>
				<form:Rower label="Auxiliar 3 (Descripci&#243;n - Conceptos)" name="rr3">
					<form:TextBox length="100" xsize="30" nvalue="#source:PARAM[@c_parametro='DescAux3']/@d_valor" name="DescAux3" label="Descripci&#243;n Auxiliar 3"/>
					<form:Label style="S2 LCol_g" name="ll1" label=" - "/>
					<form:TextBox length="100" xsize="20" nvalue="#source:PARAM[@c_parametro='ConAux3']/@d_valor" name="ConAux3" label="Conceptos Auxiliar 3"/>
				</form:Rower>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Organizacion/Parametros/EDIT" descrip="Guardar los cambios" img="save" label="Guardar" name="SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" label="Cancelar" name="CANCEL" policy="NucleusRH/Base/Organizacion/Parametros/NEW" descrip="Cancelar la edici&#243;n">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
