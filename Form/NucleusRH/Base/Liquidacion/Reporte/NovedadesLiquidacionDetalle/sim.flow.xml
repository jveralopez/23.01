<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" name="Nomad.Base.Liquidacion.NovedadesLiquidacionDetalle" extends="Nomad.Base.report.flow">
	<flow:info label="Flow para Nomad.Base.Liquidacion.NovedadesLiquidacionDetalle">
		Flow para Nomad.Base.Liquidacion.NovedadesLiquidacionDetalle
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" oi_empresa="" oi_liquidacion="" oi_variable="" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.filtro.sim.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.filtro.sim.form" name="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.filtro.sim.form:EDIT" mode="FILTER" extends="Nomad.Base.Report.filtro.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@l_simulacion"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.NovedadesLiquidacionDetalle.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.form"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusRH.Base.Liquidacion.NovedadesLiquidacionDetalle.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="REPORT" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.form"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="Nomad.report.form:REPORT" name="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.form:REPORT" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Reporte.NovedadesLiquidacionDetalle.form" mode="REPORT">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
