<form:Form extends="Nomad.parent.guia.form" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL.guia" xmlns:form="nomad_engine.form">
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo nvalue="#SOURCE:@PARENTID" name="oi_banco" label="Banco">
					<form:Event action="RELOAD_QUERY" name="onChange" runat="server"/>
				</form:Combo>
			</form:Column>
		</form:Columns>
		<form:FKInput visible="0" required="1" xsize="15" length="30" label="Bancos" nvalue="#SOURCE:@PARENTID" name="PARENTID">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Bancos.BANCO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|NEW|SHOW" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="server" action="RELOAD_QUERY" name="onReceiveData"/>
		</form:FKInput>
	</form:Center>
	<form:Scripts>
		function onLoad()
{
	var OPTS = Ctrl('main').GetLastDoc('OPTS');
	
	if (OPTS != null)
		Ctrl('oi_banco').setOptions(OPTS);
	
	Ctrl('oi_banco').SyncHTML();
}
	</form:Scripts>
	<form:Event action="onLoad" name="onload" runat="client"/>
</form:Form>
