<flow:flow name="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL-BANCO.guia" extends="Nomad.simple.guia.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Bancos.BANCO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL-BANCO.guia.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.d_interfaz as INTERFACE, t.oi_sucursal as ID, t.c_sucursal as CODE, t.d_sucursal as TEXT, t.oi_banco as PID FROM LIQ22_BANCOS_SUCUR as t WHERE t.oi_sucursal={#SOURCE:helper-mess/@ID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@INTERFACE" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.d_interfaz as INTERFACE, t.oi_sucursal as ID, t.c_sucursal as CODE, t.d_sucursal as TEXT, t.oi_banco as PID FROM LIQ22_BANCOS_SUCUR as t WHERE t.c_sucursal={substring_before(#INDOC:@CODE,\'-\')} and t.oi_banco={#INDOC:@OI_BANCO} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
					<qry:attribute value="''" name="SUB_SEARCH"/>
					<qry:attribute value="''" name="PARENTID"/>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@INTERFACE" name="interface"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.d_interfaz as INTERFACE, t.oi_sucursal as ID, t.c_sucursal as CODE, t.d_sucursal as TEXT, t.oi_banco as PID FROM LIQ22_BANCOS_SUCUR as t WHERE t.oi_banco={#INDOC:@OI_BANCO} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
						<qry:attribute value="$r/@INTERFACE" name="interface"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL-BANCO.guia.form" name="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL-BANCO.guia.form:SHOW" extends="nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW"/>
</flow:flow>
