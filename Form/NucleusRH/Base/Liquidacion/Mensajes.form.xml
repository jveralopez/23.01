<form:Form default_mode="INICIALIZAR" name="MENSAJES" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label visible="INICIALIZAR" label="Inicializaci&#243;n de Liquidaciones" name="lblTitulo" style="S3 LCol_w"/>
		<form:Label visible="NOVEDAD" label="Carga de Novedades" name="lblTitulo" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Blank name="bl14" width="100%" visible=""/>
		<form:Blank name="bl43" width="100%" visible=""/>
		<form:Label name="lblTituloBlanq" label="Se Han Eliminado Correctamente las Personas de la Liquidacion" visible="BLANQUEAR"/>
		<form:Label style="M3 LCol_t" name="lblTituloNov" label="Se Han Guardado Correctamente las novedades para las personas ingresadas" visible="NOVEDAD"/>
		<form:Columns visible="INICIALIZAR" name="gg">
			<form:Column name="g1">
				<form:Label label="Personas inicializadas correctamente:" style="M3 LCol_t" name="lblTituloIni" visible="INICIALIZAR"/>
				<form:TextBox visible="" xsize="50" length="100" name="iter_search" label="Buscar" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="FindOK"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event action="FindOK" runat="client" name="onclick"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
				<form:ListView name="LISTOK" docname="RSSOK" visible="INICIALIZAR" paging="1" rows="-250">
					<form:LVColumns>
						<form:LVColumn align="left" sorteable="1" descr="Descripcion de la liquidacion" width="400px" type="string" label="Personas sin errores" attrname="desc" name="desc"/>
					</form:LVColumns>
				</form:ListView>
			</form:Column>
			<form:Column name="g2">
				<form:Label label="Personas con error:" name="lblTituloIniOK" style="M3 LCol_t" visible="INICIALIZAR"/>
				<form:TextBox name="iter_search1" xsize="50" length="100" label="Buscar" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
				<form:ListView docname="RSS" name="LIST" visible="INICIALIZAR" paging="1" rows="-250">
					<form:LVColumns>
						<form:LVColumn align="left" sorteable="1" descr="Descripcion de la liquidacion" width="400px" type="string" label="Descripcion del Error" attrname="desc" name="desc"/>
					</form:LVColumns>
				</form:ListView>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button visible="!NOVEDAD" note="" descrip="" img="back" label="Salir" name="Salir">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="NOVEDAD" note="" descrip="" img="back" label="Volver" name="Salir">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Find()
{
	Ctrl("LIST").filter("",Ctrl("iter_search1").GetCValue());
}
                 	function FindOK()
{
	Ctrl("LISTOK").filter("",Ctrl("iter_search").GetCValue());
}
	</form:Scripts>
</form:Form>
