	<flow:declare>
		<doc:define name="RS"/>
		<qry:define declare="    &#13;&#10;&lt;helper-mess liq=&quot;1&quot; code=&quot;&quot; id=&quot;239&quot; text=&quot;&quot;&gt;&lt;rows&gt;&lt;row oi_personal_emp=&quot;&quot; /&gt;&lt;/rows&gt;&lt;/helper-mess&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute value="#SOURCE:helper-mess/@liq" type="Nomad.NSystem.Int" name="liq"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				{%? 
					(#SOURCE:helper-mess/@liq!='')	
					{% 
					SELECT
        				pe.OI_PERSONAL_EMP as ID,
        				pe.E_NUMERO_LEGAJO as CODE,
        				pp.D_APE_Y_NOM as TEXT
        			FROM
        				PER02_PERSONAL_EMP as pe,
        				org03_empresas as e,
        				PER01_PERSONAL as pp,
        				liq19_liquidacion as l, 
        				liq07_personal as pl
					WHERE
						pl.oi_personal_emp = pe.oi_personal_emp 
						AND pe.OI_PERSONAL = pp.OI_PERSONAL 
						and l.oi_empresa = e.oi_empresa 
						AND l.OI_LIQUIDACION = {#SOURCE:helper-mess/@liq}
						AND pe.oi_empresa = e.oi_empresa 
						and pe.OI_PERSONAL_EMP={#SOURCE:helper-mess/@ID}
        
			
				    %}
				    {% select 1 where 1 = 2 %} %}		
        ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess liq=&quot;1&quot; code=&quot;8&quot; /&gt;&#13;&#10;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@liq" name="liq"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
				{%? 
					(#SOURCE:helper-mess/@liq!='')	
					{% 
						SELECT
	        				pe.OI_PERSONAL_EMP as IDD,
	        				pe.E_NUMERO_LEGAJO,
	        				pp.D_APE_Y_NOM
						FROM
							PER02_PERSONAL_EMP as pe,
							PER01_PERSONAL as pp,
							liq19_liquidacion as l,
							org03_empresas as e,
							liq07_personal as pl
						WHERE 
							pl.oi_personal_emp = pe.oi_personal_emp
				 			AND pe.OI_PERSONAL = pp.OI_PERSONAL 
							AND pe.oi_empresa = e.oi_empresa 							
							AND l.oi_empresa = e.oi_empresa 
        					AND l.OI_LIQUIDACION = {#SOURCE:helper-mess/@liq} 
        					AND pe.E_NUMERO_LEGAJO = {%= #SOURCE:helper-mess/@code %}

    				 %}
    				{% select 1 where 1 = 2 %} %}
    				
	        ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess liq=&quot;1&quot;&gt;&#13;&#10;&lt;rows&gt;&#13;&#10;&lt;row oi_personal_emp = &quot;12&quot; /&gt;&#13;&#10;&lt;/rows&gt;      &#13;&#10;&lt;/helper-mess&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT
    				pe.OI_PERSONAL_EMP as IDD,
    				pe.E_NUMERO_LEGAJO,
    				pp.D_APE_Y_NOM
				FROM
					PER02_PERSONAL_EMP as pe,
					org03_empresas as e,
					PER01_PERSONAL as pp,
					liq19_liquidacion as l,
					liq07_personal as pl
				WHERE
					pl.oi_personal_emp = pe.oi_personal_emp 
					AND pe.OI_PERSONAL = pp.OI_PERSONAL 
			        AND l.oi_empresa = e.oi_empresa 
			        AND l.OI_LIQUIDACION = {#SOURCE:helper-mess/@liq} 
			        AND pe.oi_empresa = e.oi_empresa
			  ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="#SOURCE:helper-mess/@liq" name="liq"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@IDD" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@E_NUMERO_LEGAJO" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_APE_Y_NOM" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
