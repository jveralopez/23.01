<flow:flow name="NucleusRH.Base.Liquidacion.Concepto.ClasesConceptos.guia" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry qry="HELP" input-doc-path="#SOURCE:" output-doc="RS"/>
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Conceptos.ClasesConceptos.LM.guia.form" mode="SHOW" doc-path="#RS:" parent-doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<doc:define name="OUT"/>
		<qry:define declare="&lt;helper-mess&gt;&#13;&#10;&#9;&lt;rows&gt;&#13;&#10;&#9;&#9;&lt;row oi_clase_concepto = &quot;1&quot;/&gt;&#13;&#10;&#9;&lt;/rows&gt;&#13;&#10;&lt;/helper-mess&gt;&#13;&#10;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
					<qry:insert-select doc-path="#SOURCE:" name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					cc.oi_clase_concepto, 
					cc.c_clase_concepto, 
					cc.d_clase_concepto
				FROM 
					liq13_clases_conc as cc
				WHERE 
					{%? (string(#SOURCE:helper-mess/rows/row/@oi_clase_concepto)!='') {%  cc.oi_clase_concepto in ({%=string(#SOURCE:helper-mess/rows/row/@oi_clase_concepto) %}) %} {% 1 = 2 %} %}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_clase_concepto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_clase_concepto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@c_clase_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@d_clase_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="1" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					cc.oi_clase_concepto, 
					cc.c_clase_concepto, 
					cc.d_clase_concepto 
				FROM
					liq13_clases_conc as cc
				WHERE  
					{%? (string(#SOURCE:helper-mess/rows/row/@oi_clase_concepto)!='') {%  cc.oi_clase_concepto not in ({%=string(#SOURCE:helper-mess/rows/row/@oi_clase_concepto) %}) %} {% 1 = 1 %} %} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_clase_concepto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_clase_concepto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@c_clase_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@d_clase_concepto" type="Nomad.NSystem.String"/>
						<qry:attribute name="check" value="0" type="Nomad.NSystem.Boolean"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRUEBA">
			<qry:main doc="SOURCE">
				<qry:element name="helper-mess">
					<qry:element name="rows">
						<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW[@check=1]
				</qry:xquery>
				<qry:out>
					<qry:element name="row">
						<qry:attribute name="oi_clase_concepto" value="$r/@id" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form name="NucleusRH.Base.Liquidacion.Conceptos.ClasesConceptos.LM.guia.form" form-class="NucleusRH.Base.Liquidacion.Conceptos.ClasesConceptos.LM.guia.form" mode="SHOW" doc="SOURCE" parent-doc="INVAL">
		<flow:action name="on-show"/>
		<flow:action name="ACCEPT">
			<doc:load-qry qry="PRUEBA" input-doc-path="#SOURCE:" output-doc="OUT"/>
			<flow:exit-flow return-path="#OUT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
