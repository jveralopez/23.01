<form:Form xmlns:form="nomad_engine.form" name="AsociarVariablesAConceptosFiltro" default_mode="FILTER" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Filtro de Asociar Conceptos a Variables" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="70%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:FKInput required="1" enabled="" xsize="15" length="30" label="Variable" nvalue="#FILTERDATA:@oi_variable" name="oi_variable">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Blank name="b1l3" width="100%" visible=""/>
		<form:Combo required="1" nvalue="#FILTERDATA:@tipo" label="Tipo de Parametro" name="acumula">
			<form:Opts name="Acum">
				<OPT descrip="Acumula Cantidad" name="ACC" text="Acumula Cantidad" code="ACC" value="ACC"/>
				<OPT name="ACV" descrip="Acumula Valor" text="Acumula Valor" code="ACV" value="ACV"/>
			</form:Opts>
		</form:Combo>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Conceptos/CONCEPTO/filter/autoform/FILTER">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Liquidacion/Conceptos/CONCEPTO/filter/autoform/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
