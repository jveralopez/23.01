<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" extends="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.filter.autoform" name="CONCEPTO.FILTRO" doc="source">
	<form:Center width="70%">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Label name="lbl2" label="Criterios de B&#250;squeda" visible="" align="center" style="S3 LCol_g"/>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Columns name="columns1">
			<form:Column name="col1">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.Combo.autoflow" required="0" label="Tipo Concepto" nvalue="#source:@oi_tipo_concepto" name="oi_tipo_concepto"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Liquidacion.Clases_Conceptos.CLASE_CONCEPTO.Combo.autoflow" required="0" label="Clase Concepto" nvalue="#source:@oi_clase_concepto" name="oi_clase_concepto"/>
				<form:Blank name="blnk001"/>
				<form:Combo flow="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.ca_fig_recibo.Combo.autoflow" nvalue="#source:@ca_fig_recibo" name="cboFigRecibo" label="Figura en Recibo" note="" descrip="" action="COMBO"/>
				<form:Combo name="cboActivo" label="Est&#225; Activo" nvalue="#source:@l_activo" note="" flow="NucleusRH.Base.Liquidacion.SiNo.enum" action="COMBO"/>
				<form:Blank name="blnk002"/>
				<form:Grid width="480px" nvalue="#source:ROWS" proto="&lt;ROW/&gt;" name="grdConcepto" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" doc="SOURCE">
					<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.Conceptos.LM.guia.flow" action="HELP">
						<helper-mess>
							{grdConcepto.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCE:@id" required="0" enabled="" xsize="10" length="30" label="Concepto" name="oi_concepto">
								<form:STexts>
									<form:SText xsize="50" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.CONCEPTO.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl15" width="100%" visible=""/>
		<form:Blank name="bl35" width="100%" visible=""/>
		<form:Line name="line_1" width="60%"/>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:Label label="Criterio de Ordenamiento" name="lbl201" align="center" style="S3 LCol_g"/>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:RowAligner name="RAcamposOrden" columns="2">
			<form:Row name="RC1O">
				<form:Combo flow="NucleusRH.Base.Liquidacion.Conceptos.atribFiltro.enum" name="cboCampo1" note="" action="COMBO" nvalue="#source:@ATRIB_ORDEN1"/>
				<form:Combo name="cboOrdenCampo1" label="" note="AscendenteDecendente" flow="NucleusRH.Base.Orden.enum" action="COMBO" nvalue="#source:@ORDEN1"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Blank name="blank_buttons"/>
				<form:Button img="execute" label="Importar" name="IMPORT" descrip="Importar Conceptos Seleccionados" note="Vuelve a la pantalla anterior del formulario" visible="FILTER">
					<form:Event action="IMPORT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea exportar los conceptos filtrados?" label="Exportar" name="EXPORT" descrip="Exportar Conceptos Seleccionados" img="save" note="Vuelve a la pantalla anterior del formulario" visible="FILTER">
					<form:Event action="EXPORT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button descrip="Exportar Conceptos Seleccionados Verson 2.0" label="Exportar 2.0" name="EXPORT2" mess="&#191;Est&#225; seguro que desea exportar los conceptos filtrados?" img="save" note="Vuelve a la pantalla anterior del formulario" visible="FILTER">
					<form:Event action="EXPORT2" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
