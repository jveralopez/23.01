<form:Form name="test" xmlns:form="nomad_engine.form" doc="SOURCE">
	<form:Event action="validar" name="onload" runat="client"/>
	<form:Scripts>
		function validar()
				{ 
					g_CTRLs['oi_personal_emp'].SetEnabled(false);
				}

				function validarLiquidacion()
				{ 
					if (g_CTRLs['oi_liquidacion'].GetCValue() == "")
						{	
							g_CTRLs['oi_personal_emp'].SetEnabled(false);
							g_CTRLs['oi_personal_emp'].SetCValue("");							
						} else
							{	
								g_CTRLs['oi_personal_emp'].SetCValue("");
								g_CTRLs['oi_personal_emp'].SetEnabled(true);
								
							}
				}
	</form:Scripts>
	<form:Title>
		<form:Label name="lblTitulo" label="Concepto - Formula del Concepto" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:FKInput required="0" enabled="" xsize="15" length="30" label="Liquidaci&#243;n" nvalue="" name="oi_liquidacion">
			<form:Event action="validarLiquidacion" name="onReceiveData" runat="client"/>
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" visible="" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:FKInput required="0" enabled="" xsize="15" length="30" label="Personal" nvalue="" name="oi_personal_emp">
			<form:STexts>
				<form:SText xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Conceptos.Testing.Personal.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" liq="{oi_liquidacion.XVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" visible="" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:Hidden name="t_formula" nvalue="#SOURCE:@t_formula"/>
		<form:Label name="lblV" label="Valorizacion de Variables" visible="" style="S3" align="center"/>
		<form:Grid name="grdValoress" idvalue="#SOURCE:@name" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#SOURCE:vars" doc="SOURCE">
			<form:GColumns>
				<form:GColumn allow_order="1">
					<form:TextBox required="0" enabled="" ysize="1" xsize="40" length="30" label="Codigo de la Variable" nvalue="#SOURCE:@name" name="name"/>
				</form:GColumn>
				<form:GColumn allow_order="1">
					<form:TextBox required="0" enabled="" ysize="1" xsize="40" length="30" label="Descripcion de la Variable" nvalue="#SOURCE:@descrip" name="desc"/>
				</form:GColumn>
				<form:GColumn>
					<form:TextBox required="0" enabled="" ysize="1" xsize="40" length="30" label="Valor Para Testing" nvalue="#SOURCE:@value" name="value"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="blB" width="100%" visible=""/>
		<form:TextBox required="0" ysize="4" xsize="80" length="4000" label="Errores" nvalue="" name="error"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="1">
			<form:Row name="filaBotones">
				<form:Button visible="" note="" descrip="" img="formula" label="Ver Formula" name="VerFormula">
					<form:Event action="VerFormula" name="onclick" runat="extern">
						<DATOS name="NucleusRH.Base.Liquidacion.Conceptos.flow" action="VerFormula">
							<DATO formula="{t_formula.XValue}"/>
						</DATOS>
					</form:Event>
				</form:Button>
				<form:Button visible="SHOW" note="Calcula la formula con los valores de Testing" descrip="Calcula la Formula con los Valores de Testing" img="result" label="Resultado" name="Resultado">
					<form:Event action="RES_CLICK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="" note="Vuelve a la pantalla anterior del formulario" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
