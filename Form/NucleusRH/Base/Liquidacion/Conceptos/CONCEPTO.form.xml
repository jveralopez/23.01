function ValidarFormula(myThis){
	
	var formula = myThis.GetXValue();
	
	if (formula.length&gt;4000)
	{
			//alert("El Concepto tiene una Formula mas larga de 4000... (Largo: "+formula.length+") ");
						
			//ENTER DOS-&gt;UNIX
			if (formula.indexOf("\r\n")&gt;=0)
			{
				//alert("Largo: "+formula.length+" - Replazo 'ENTER DOS' por 'ENTER UNIX'...");
				formula=formula.replace("\r\n","\n");
				//alert("Largo: "+formula.length);
			}
			
			//ESPACIOS AL FINAL DE LA LINEA
			if (formula.indexOf(" \n")&gt;=0 || formula.indexOf("\t\n")&gt;=0)
			{
				//alert("Largo: "+formula.length+" - Elimino los Espacios al Final de las LINEAS...");
				do {
					org=formula;
					formula=formula.replace(" \n" ,"\n");
					formula=formula.replace("\t\n","\n");
				} while(org!=formula);
				//alert("Largo: "+formula.length);
			}
			
			//REEMPLAZO ESPACIOS DOBLES POR TAB
			if (formula.length&gt;0)
				if (formula.indexOf("  ")&gt;=0 || formula.indexOf(" \t")&gt;=0 || formula.indexOf("\t ")&gt;=0)
				{
					//alert("Largo: "+formula.length+" - Reemplazo los 'Espacios Dobles' por 'Tabs'...");
					do {
						org=formula;
						formula=formula.replace("  " ,"\t");
						formula=formula.replace(" \t","\t");
						formula=formula.replace("\t ","\t");
					} while(org!=formula);
					//alert("Largo: "+formula.length);
				}
			
			//REEMPLAZO ENTER DOBLES
			if (formula.length&gt;4000)
				if (formula.indexOf("\n\n")&gt;=0)
				{
					//alert("Largo: "+formula.length+" - Reemplazo los 'Espacios Dobles' por 'Tabs'...");
					do {
						org=formula;
						formula=formula.replace("\n\n","\n");
					} while(org!=formula);
					//alert("Largo: "+formula.length);
				}

			if (formula.length&gt;400)
			{
				myThis.SetError("Se modific&#243; la Formula pero sigue siendo larga (longitud mayor a 4000 caracteres). Largo actual: "+formula.length+") ");
				return false;
			}
	} 
	
	return true;
}
