<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" doc="source" extends="NucleusRH.Base.Liquidacion.Personal_Liquidacion.VAREN_CARGO.STD_FIL.autoform" name="NucleusRH.Base.Liquidacion.Personal_Liquidacion.VAREN_CARGO.VARE">
	<form:Help/>
	<form:Scripts>
		function setPER_EMP()
{
	//Seteo el legajo a traves del oi_personal_liq
	var nSQL = GetProxy().SQLService(); 
	var xml = nSQL.GetOBJ(Ctrl("main").getResource("qry_perEmp"), "&lt;PARAM oi_personal_liq=\""+Ctrl("oi_personal_liq").GetXValue()+"\" /&gt;");
	Ctrl("oi_personal_emp").SetXValue(xml.per_emp); 
}
	</form:Scripts>
	<form:Title width="90%">
		<form:Label name="lbl_titulo" visible="0"/>
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" name="GEN_NEW" label="Carga Manual de Novedades por Cargo"/>
				<form:Label nowrap="1" align="center" style="S3 LCol_w" dynamic="1" name="OBJ"/>
				<form:Label nowrap="1" align="center" style="S2 LCol_w" dynamic="1" name="PAR"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_cols">
			<form:Column name="main_col">
				<form:Blank name="main_BB" height="15px"/>
				<form:ComboBox xsize="40" mode="QRY" name="oi_empresa" prev="" nvalue="#source:@oi_empresa" required="1" label="Empresa" descrip="Empresa" visible="" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" where1=""/>
				<form:ComboBox xsize="40" mode="QRY" name="oi_liquidacion" prev="oi_empresa" nvalue="#source:@oi_liquidacion" required="1" label="Liquidaci&#243;n" descrip="Liquidaci&#243;n" enabled="" visible="" queryname1="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.INFO" where1="LIQ19_LIQUIDACION.c_estado != 'C'"/>
				<form:ComboBox queryname1="NucleusRH.Base.Liquidacion.Personal_Liquidacion.PERSONAL_LIQ.INFO_CUS" xsize="40" mode="QRY" name="oi_personal_liq" prev="oi_liquidacion" nvalue="#source:@oi_personal_liq" required="1" label="Legajo" descrip="Legajo" enabled="" visible="" where1="">
					<form:Event action="setPER_EMP" name="onChange" runat="client"/>
				</form:ComboBox>
				<form:Hidden name="oi_personal_emp" nvalue="#source:@oi_personal_emp" order-change="PREV:oi_cargo"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.LegajoEmpresa.CARGO.INFO_CUS" xsize="40" mode="QRY" name="oi_cargo" prev="oi_personal_emp" nvalue="#source:@oi_cargo" required="1" label="Cargo" descrip="Cargo" enabled="" visible="" where1=""/>
			</form:Column>
		</form:Columns>
		<form:Hidden name="PARENT" nvalue="#source:@PARENT"/>
		<form:Hidden name="ID" nvalue="#source:@ID"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="0" name="ACCEPT" descrip="Aceptar" img="OK" label="Aceptar" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" name="BACK" descrip="Volver" img="BACK" label="Volver">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Siguiente" img="next" descrip="" visible="" enabled="" name="btnExecute" startvalidate="1">
					<form:Event action="EXECUTE" name="OnClick" runat="server"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Salir" name="btnBack" visible="" enabled="">
					<form:Event action="BACK" name="OnClick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_personal_liq=&quot;5320&quot;/&gt;" name="qry_perEmp">
			<qry:main name="" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_LEG" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_LEG" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT
				PER02_CARGOS.oi_personal_emp
			FROM	
				PER02_CARGOS,
				LIQ25_PERSONAL_LIQ
			JOIN
				PER02_CARGOS.oi_personal_emp INNER LIQ25_PERSONAL_LIQ.oi_personal_emp
			WHERE
				LIQ25_PERSONAL_LIQ.oi_personal_liq = {#PARAM:@oi_personal_liq}
			GROUP BY
				PER02_CARGOS.oi_personal_emp
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="per_emp" value="$r/@oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
