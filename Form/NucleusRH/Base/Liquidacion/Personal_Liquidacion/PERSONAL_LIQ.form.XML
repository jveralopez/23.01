{
	set_oi();
	openNewFlowWait("NucleusRH.Base.Liquidacion.Recibos.flow","initializeReciboDesde25","&lt;datos oi_personal_liq=\""+Ctrl('oi').GetXValue()+"\" /&gt;",new ObjtectResult(),"L");
}
function VER_LEGAJO()
{
	set_oi();
	openNewFlowWait("NucleusRH.Base.Liquidacion.Reporte.LegajoLiquidacion.flow","initializeDesde25","&lt;PARAMETERS oi_personal_emp=\""+Ctrl('oi_emp').GetXValue()+"\" /&gt;",new ObjtectResult(),"L");
}     
