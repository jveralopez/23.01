function VER_RECIBO()
{  
	set_oi();
	openNewFlowWait("NucleusRH.Base.Liquidacion.Recibos.flow","initializeReciboLiquidacion","&lt;DATOS oi_personal_liq=\""+Ctrl('oi').GetXValue()+"\" /&gt;",new ObjtectResult(),"L");
}
