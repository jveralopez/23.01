function EDIT()
{
	set_oi();
	Ctrl('main').DoEvent('EDIT');
}

function set_oi()
{
 	GetProxy().StoreService().SetSessionStore("LIQ25_ADMIN_LEGS", array2stringcustom(arrB, "ROWS", "ROW"));

	if (Ctrl('list2'))
	{
		Ctrl('oi').SetXValue(Ctrl('list2').GetSelectAttrValue("oi_personal_liq"));
		Ctrl('oi_emp').SetXValue(Ctrl('list2').GetSelectAttrValue("id"));
	}
	else
	{
		Ctrl('oi').SetXValue(Ctrl('oi_ddo').GetXValue());
		Ctrl('oi_emp').SetXValue(Ctrl('oi_personal_emp').GetXValue());
	}
}

function refresh()
{
	Ctrl('main').DoEvent('REFRESH');
}


function ObjtectResult()
{
	this.processResult= function(xmlin){}
}

function CALL_VAL_VAREF()
{
	set_oi();
	Ctrl('main').DoEvent('CALL:VAL_VAREF');
}


