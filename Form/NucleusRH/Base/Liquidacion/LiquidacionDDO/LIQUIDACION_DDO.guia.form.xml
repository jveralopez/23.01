<form:Form extends="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia.autoform" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.guia" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label nowrap="1" style="S3 LCol_w" label="Selecci&#243;n de Liquidaciones" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo visible="0" name="oi_empresa" nvalue="#SOURCE:@PARENTID" label="Empresa" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO">
					<form:Event name="onchange" action="RELOAD_QUERY" runat="server"/>
				</form:Combo>
				<form:Combo name="PARENTID" nvalue="#SOURCE:@PARENTID" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Liquidacion.Interface.EMPRESA_DDO.combo.flow" action="COMBO">
					<form:Event runat="server" action="RELOAD_QUERY" name="onchange"/>
				</form:Combo>
			</form:Column>
		</form:Columns>
		<form:FKInput visible="0" required="1" xsize="15" length="30" label="Datos de Liquidaci&#243;n por Empresa" nvalue="#SOURCE:@PARENTID" name="PARENTID">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|NEW|SHOW" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="server" action="RELOAD_QUERY" name="onReceiveData"/>
		</form:FKInput>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button note="Aceptar" descrip="Aceptar" img="OK" label="Aceptar" name="ACCEPT">
					<form:Event action="ACCEPT" name="onclick" runat="client"/>
				</form:Button>
				<form:Button note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Agregar/Modificar/Eliminar elementos" label="Agregar" note="Editar" img="NEW" name="NEW">
					<form:Event action="EDIT" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
