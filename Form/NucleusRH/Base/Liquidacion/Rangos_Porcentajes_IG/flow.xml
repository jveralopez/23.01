<flow:flow extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.autoflow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG"/>
	<flow:declare>
		<qry:define declare="&lt;DATOS e_anio_d=&quot;2007&quot; e_anio_h=&quot;2009&quot; e_mes_d=&quot;1&quot; e_mes_h=&quot;2&quot;/&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT 
			t0.oi_ig as oi_ig 
			FROM LIQ06_IG as t0 
			WHERE
			1 = 1 
			{%? (#PARAM:@e_anio_d!='')	{% AND t0.e_anio &gt;= {%=#PARAM:@e_anio_d %} %} {% %} %}
			{%? (#PARAM:@e_anio_h!='')	{% AND t0.e_anio &lt;= {%=#PARAM:@e_anio_h %} %} {% %} %}
			{%? (#PARAM:@e_mes_d!='')	{% AND t0.e_mes &gt;= {%=#PARAM:@e_mes_d %} %} {% %} %}
			{%? (#PARAM:@e_mes_h!='')	{% AND t0.e_mes &lt;= {%=#PARAM:@e_mes_h %} %} {% %} %}
			ORDER BY oi_ig asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_ig"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS e_anio_d=&quot;2007&quot; e_anio_h=&quot;2007&quot; e_mes_h=&quot;5&quot; e_mes_d=&quot;1&quot;/&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT 
			t0.oi_ig as oi_ig, 
			t0.e_anio as e_anio, 
			t0.e_mes as e_mes, 
			t0.n_tot_imp_d as n_tot_imp_d, 
			t0.n_tot_imp_h as n_tot_imp_h, 
			t0.n_cuota as n_cuota, 
			t0.n_p_rango as n_p_rango, 
			t0.oi_ig as CODE, 
			t0.oi_ig as TEXT 
			FROM LIQ06_IG as t0 
			WHERE
			1 = 1 
			{%? (#PARAM:@e_anio_d!='')	{% AND t0.e_anio &gt;= {%=#PARAM:@e_anio_d %} %} {% %} %}
			{%? (#PARAM:@e_anio_h!='')	{% AND t0.e_anio &lt;= {%=#PARAM:@e_anio_h %} %} {% %} %}
			{%? (#PARAM:@e_mes_d!='')	{% AND t0.e_mes &gt;= {%=#PARAM:@e_mes_d %} %} {% %} %}
			{%? (#PARAM:@e_mes_h!='')	{% AND t0.e_mes &lt;= {%=#PARAM:@e_mes_h %} %} {% %} %}
			ORDER BY oi_ig asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_ig"/>
						<qry:attribute name="e_anio" value="$r/@e_anio"/>
						<qry:attribute name="e_mes" value="$r/@e_mes"/>
						<qry:attribute name="n_tot_imp_d" value="$r/@n_tot_imp_d"/>
						<qry:attribute name="n_tot_imp_h" value="$r/@n_tot_imp_h"/>
						<qry:attribute name="n_cuota" value="$r/@n_cuota"/>
						<qry:attribute name="n_p_rango" value="$r/@n_p_rango"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<DATOS e_anio_d="" e_anio_h="" e_mes_d="" e_mes_h=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="IG">
		<flow:form extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.filter.form:FILTER" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.filter.form" mode="FILTER">
			<flow:action name="on-show"/>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.noreg.form:EDIT" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form:SHOW" extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form:LIST" extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form:EDIT" extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form" mode="EDIT"/>
		<flow:form name="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form:NEW" extends="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG.form" mode="NEW"/>
	</flow:group>
</flow:flow>
