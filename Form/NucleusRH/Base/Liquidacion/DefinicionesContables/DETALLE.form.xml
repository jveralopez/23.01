	<form:Scripts>
		function Validate()
{
	var flag = true;
	for (i=0;i&lt;Ctrl('MAIN_GRIDTC').TotalRowsCount();i++)	
	{		
		var ctrl = Ctrl('MAIN_GRIDTC').GetCellControl("oi_tipo_concepto", i)		
		if (ctrl.GetXValue() == "")
		{
			flag = false;
			alert("El valor de Tipo de Concepto es obligatorio");			
			return false;
		}		
	}
	
	for (i=0;i&lt;Ctrl('MAIN_GRIDCPT').TotalRowsCount();i++)	
	{		
		var ctrl = Ctrl('MAIN_GRIDCPT').GetCellControl("oi_concepto", i)		
		if (ctrl.GetXValue() == "")
		{
			flag = false;
			alert("El valor de Concepto es obligatorio");			
			return false;
		}		
	}
	
	for (i=0;i&lt;Ctrl('MAIN_GRIDGCC').TotalRowsCount();i++)	
	{		
		var ctrl = Ctrl('MAIN_GRIDGCC').GetCellControl("oi_grupo_ccosto", i)		
		if (ctrl.GetXValue() == "")
		{
			flag = false;
			alert("El valor de Grupo de Centro de Costo es obligatorio");			
			return false;
		}		
	}
	
	for (i=0;i&lt;Ctrl('MAIN_GRIDCC').TotalRowsCount();i++)	
	{		
		var ctrl = Ctrl('MAIN_GRIDCC').GetCellControl("oi_centro_costo", i)		
		if (ctrl.GetXValue() == "")
		{
			flag = false;
			alert("El valor de Centro de Costo es obligatorio");			
			return false;
		}		
	}
	
	for (i=0;i&lt;Ctrl('MAIN_GRIDCONV').TotalRowsCount();i++)	
	{		
		var ctrl = Ctrl('MAIN_GRIDCONV').GetCellControl("oi_convenio", i)		
		if (ctrl.GetXValue() == "")
		{
			flag = false;
			alert("El valor de Convenio es obligatorio");			
			return false;
		}		
	}
	
	return true;	
}
	</form:Scripts>
