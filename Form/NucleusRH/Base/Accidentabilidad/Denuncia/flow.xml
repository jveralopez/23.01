<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Accidentabilidad.Denuncia.flow">
	<flow:info label="Denuncia Accdidente"/>
	<flow:declare>
		<doc:define name="PARAMS">
			<DATOS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Accidentabilidad.Denuncia.DENUNCIA.form" mode="NEW" doc-path="#PARAMS:"/>
		</flow:action>
	</flow:main>
	<flow:form doc="SOURCE" parent-doc="PARENTSOURCE" name="NucleusRH.Base.Accidentabilidad.Denuncia.DENUNCIA.form:NEW" form-class="NucleusRH.Base.Accidentabilidad.Denuncia.DENUNCIA.form" mode="NEW">
		<flow:action name="SAVE">
			<flow:exec-method class="NucleusRH.Base.Accidentabilidad.LegajoAccidentes.PERSONAL_EMP" priority="1" out-attr-path="#BATCHDOC:@batch-id" method="RegistrarDenuncia">
				<flow:param doc="PARAMS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
				<flow:param attr-path="#FORM:ctrl[@id='licvalue']/@xval" type="Nomad.NSystem.Boolean" mode="in" name="genlic"/>
				<flow:param attr-path="#FORM:ctrl[@id='licvalueART']/@xval" name="genlicART" type="Nomad.NSystem.Boolean" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form extends="Nomad.base.HTML_XLS.form:SHOW" form-class="Nomad.base.HTML_XLS.form" name="Nomad.base.HTML_XLS:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="BACK">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
