	<form:Scripts>
		function ValData()
{
	Ctrl('licvalue').SetXValue("0"); 
	Ctrl('licvalueART').SetXValue("0");

	ValTest(); 
	
	if(Ctrl('licencia') &amp;&amp; Ctrl('licenciaART'))
	{  
		if(Ctrl('licencia').GetXValue() != "1" &amp;&amp; Ctrl('licenciaART').GetXValue() != "1") 
		{
			if (confirm("La licencia correspondiente al accidente no ser&#225; generada. &#191;Desea continuar de todas maneras?")) 
			{
				Ctrl('licvalue').SetXValue("0");
				Ctrl('licvalueART').SetXValue("0");
			}
			else
				return false;
		} 
		else
		{	
			if(Ctrl('licencia').GetXValue() == "1" &amp;&amp; Ctrl('licenciaART').GetXValue() == "1")
			{
				alert("Solo puede seleccionar un solo check a la vez");
				return false;
			}
			else
			{	
			
				if(Ctrl('licencia').GetXValue() == "1") 
				{					
					Ctrl('licvalue').SetXValue("1");
				}

				if(Ctrl('licenciaART').GetXValue() == "1") 
				{					
					Ctrl('licvalueART').SetXValue("1");
				}							
				
				if(Ctrl("f_fechahora_baja").GetXValue() == "")
				{
					alert("No se ha ingresado la fecha de baja");
					return false;
				}
				if (Ctrl("f_fechahora_alta").GetXValue() == "")
				{
					alert("No se ha ingresado la fecha de alta");
				 	return false;
				}
			}
		}
	}
	 
	//Si se oculta por seguridad el nuevo check - Realizara las validaciones anteriores 
	if((Ctrl('licenciaART') == undefined) &amp;&amp; Ctrl('licencia'))	
	{
		if(Ctrl('licencia').GetXValue() != "1")
		{
			if (confirm("La licencia correspondiente al accidente no ser&#225; generada. &#191;Desea continuar de todas maneras?"))
				Ctrl('licvalue').SetXValue("0");
			else
				return false;
		}
		else
		{			
			Ctrl('licvalue').SetXValue("1");
			if(Ctrl("f_fechahora_baja").GetXValue() == "")
			{
				alert("No se ha ingresado la fecha de baja");
				return false;
			}
			if (Ctrl("f_fechahora_alta").GetXValue() == "")
			{
				alert("No se ha ingresado la fecha de alta");
			 	return false;
			}
		}
	}	
		
	Ctrl('main').DoEvent("guardar");
}

function ValTest()
{
	if (Ctrl("e_testigo_1").GetXValue() != "" || Ctrl("d_apellido_1").GetXValue() != "" || Ctrl("d_nombres_1").GetXValue() != "")
	{
		if (Ctrl("e_testigo_1").GetXValue() == "" || Ctrl("d_apellido_1").GetXValue() == "" || Ctrl("d_nombres_1").GetXValue() == "")
		{
			alert("Para cada testigo es obligatorio indicar n&#250;mero, apellido y nombre");
		 	return false;
		}
	}
	
	if (Ctrl("e_testigo_2").GetXValue() != "" || Ctrl("d_apellido_2").GetXValue() != "" || Ctrl("d_nombres_2").GetXValue() != "")
	{
		if (Ctrl("e_testigo_2").GetXValue() == "" || Ctrl("d_apellido_2").GetXValue() == "" || Ctrl("d_nombres_2").GetXValue() == "")
		{
			alert("Para cada testigo es obligatorio indicar n&#250;mero, apellido y nombre");
		 	return false;
		}
	}
	
	if (Ctrl("e_testigo_3").GetXValue() != "" || Ctrl("d_apellido_3").GetXValue() != "" || Ctrl("d_nombres_3").GetXValue() != "")
	{
		if (Ctrl("e_testigo_3").GetXValue() == "" || Ctrl("d_apellido_3").GetXValue() == "" || Ctrl("d_nombres_3").GetXValue() == "")
		{
			alert("Para cada testigo es obligatorio indicar n&#250;mero, apellido y nombre");
		 	return false;
		}
	}
	
	if (Ctrl("e_testigo_4").GetXValue() != "" || Ctrl("d_apellido_4").GetXValue() != "" || Ctrl("d_nombres_4").GetXValue() != "")
	{
		if (Ctrl("e_testigo_4").GetXValue() == "" || Ctrl("d_apellido_4").GetXValue() == "" || Ctrl("d_nombres_4").GetXValue() == "")
		{
			alert("Para cada testigo es obligatorio indicar n&#250;mero, apellido y nombre");
		 	return false;
		}
	}
  return true;
}   

function CalcularDias()
{
 	if (Ctrl('f_fechahora_alta').GetXValue() != "" &amp;&amp; Ctrl('f_fechahora_baja').GetXValue() != "")
 	{ 		
 		if (Ctrl('f_fechahora_alta').GetXValue() &gt;= Ctrl('f_fechahora_baja').GetXValue())
 		{
 			Ctrl('e_dias_perdidos').SetTypedValue(DiffDays(Ctrl('f_fechahora_alta').TypedValue(), Ctrl('f_fechahora_baja').TypedValue()));
 		} 
 		else
 			alert("La fecha de alta del empleado debe ser mayor a la fecha de baja");
 			return false; 
  }
}
