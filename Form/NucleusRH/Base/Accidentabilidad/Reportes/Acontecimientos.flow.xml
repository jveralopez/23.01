<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.base.HTML_XLS.flow" name="ReporteConceptosLegajos">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA f_desde="20050302" f_hasta="20160317" c_group="causa" l_acciones="1"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Accidentabilidad.Reportes.Acontecimientos.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Accidentabilidad.Reportes.Acontecimientos.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Accidentabilidad.Reportes.Acontecimientos.filter.form">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.Acontecimiento" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.Acontecimiento" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text-path="#FILTERDATA:" text="logAngel"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Accidentabilidad.Acontecimientos.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="004 - Acontecimientos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
