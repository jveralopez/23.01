<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente">
	<flow:info label="Flow para NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY"/>
		<doc:define name="FILTERDATA">
			<DATOS oi_personal_emp="" oi_accidente=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;243&quot; /&gt;" name="qry_accidentes">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="qry1" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
			SELECT ACC01_ACCIDENTES.oi_accidente, ACC01_ACCIDENTES.f_fechahora_acc, ACC01_ACCIDENTES.oi_tipo_acc
			FROM ACC01_ACCIDENTES
			WHERE ACC01_ACCIDENTES.oi_personal_emp = {#PARAM:@oi_personal_emp}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_accidente" type="Nomad.NSystem.DateTime"/>
						<qry:attribute name="f_fecha_acc" value="$r/@f_fechahora_acc" type="Nomad.NSystem.DateTime"/>
						<qry:attribute name="f_hora_acc" value="$r/@f_fechahora_acc" type="Nomad.NSystem.DateTime"/>
						<qry:insert-select name="sql2" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in sql('
				SELECT ACC10_TIPOS_ACC.oi_tipo_acc, 
				ACC10_TIPOS_ACC.c_tipo_acc, 
				ACC10_TIPOS_ACC.d_tipo_acc
				FROM ACC10_TIPOS_ACC 
				WHERE ACC10_TIPOS_ACC.oi_tipo_acc={#PARAM:@oi_tipo_acc}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_tipo_acc" value="$r/@c_tipo_acc" type="Nomad.NSystem.String"/>
					<qry:attribute name="d_tipo_acc" value="$r/@d_tipo_acc" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="RS">
			<ROWS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente.filter.form:FILTER" form-class="NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente.filter.form" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#FILTERDATA:@oi_accidente"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Denuncia de Accidente" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param value="NucleusRH.Base.Accidentabilidad.DenunciaAccidente.rpt" name="pstrReportName" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="002 - Denuncia de Accidente" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.DenunciaAccidente" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<doc:load-qry output-doc="RS" input-doc-path="#FILTERDATA:" qry="qry_accidentes"/>
			<flow:attach-doc attach-id="RS" doc-path="#RS:"/>
		</flow:action>
	</flow:form>
</flow:flow>
