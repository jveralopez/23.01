<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="ReportesAccidentesLaborales">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Accidentabilidad.Reportes.AccidentesLaborales.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Accidentabilidad.Reportes.AccidentesLaborales.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Accidentabilidad.Reportes.AccidentesLaborales.filter.form">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.AccidentesLaborales" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Accidentabilidad.Reportes.AccidentesLaborales" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportBatch" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="Accidentes Laborales" name="pstrMessage" type="Nomad.NSystem.String" mode="in"/>
				<flow:param value="NucleusRH.Base.Accidentabilidad.AccidentesLaborales.rpt" name="pstrReportName" type="Nomad.NSystem.String" mode="in"/>
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="001 - Accidentes Laborales" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
