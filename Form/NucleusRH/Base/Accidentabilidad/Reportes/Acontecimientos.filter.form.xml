<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Accidentabilidad.Reportes.Acontecimientos.filter.form">
	<form:Title>
		<form:Label label="004 - Acontecimientos" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="columns">
			<form:Column name="col1" separation="2" align="center" valign="top">
				<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo label="Agrupado por" required="1" name="c_group" nvalue="#source:@c_group">
					<form:Opts name="opciones">
						<OPT code="sinagrup" value="sinagrup" name="sinagrup" text="Sin Agrupar"/>
						<OPT text="Agrupado por Causa" name="causa" code="causa" value="causa"/>
					</form:Opts>
				</form:Combo>
				<form:CheckBox required="1" label="Incluye acciones correctivas" name="l_acciones" nvalue="#source:@l_acciones"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila1">
				<form:Button startvalidate="1" enabled="" visible="" img="ok" name="btnEjecutar" label="Aceptar" note="Ejecuta" descrip="">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
