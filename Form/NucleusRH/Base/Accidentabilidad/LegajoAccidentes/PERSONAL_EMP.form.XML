					</form:Policies>
				</form:ComboBox>
				<form:TextBox required="0" enabled="0" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_personal_emp" name="o_personal_emp"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Accidentabilidad/LegajoAccidentes/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Accidentabilidad/LegajoAccidentes/NEW" visible="0" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Accidentabilidad/LegajoAccidentes/DELETE" mess="&#191;Est&#225; seguro que desa eliminar el registro?" visible="0" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Accidentabilidad/LegajoAccidentes/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function VerLegajo()
{                                   
	if(Ctrl("main").GetMode()=="LIST")     
		getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+Ctrl("LIST").GetSelectAttrValue("id").toString()+"\" /&gt;", false);    
	else
		{
		var np = new NomadProxy("", ut);
		var nSQL = np.SQLService();       
		var legajo= nSQL.GetOBJ(Ctrl("main").getResource("QRY_LEGAJO"),"&lt;PARAM oi_personal=\""+Ctrl("oi_personal").GetXValue().toString()+"\" oi_empresa=\""+Ctrl("oi_empresa").GetXValue().toString()+"\" /&gt;");
		getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+legajo.oi_personal_emp.toString()+"\" /&gt;", false); 
		}
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_personal=&quot;11472&quot; oi_empresa=&quot;10&quot;/&gt;" name="QRY_LEGAJO">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_personal = {#SOURCE:@oi_personal} AND
					PER02_PERSONAL_EMP.oi_empresa  = {#SOURCE:@oi_empresa} 				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
