				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" descr="Fecha de Ingreso del empleado a la Empresa." mask="dd/mm/yyyy" label="Fecha Ingreso" nvalue="#source:@f_ingreso" name="f_ingreso"/>
