						<form:Image nvalue="#PER:@oi_foto" height="100" width="100" enabled="0" class="NucleusRH.Base.Personal.Imagenes.Head" extensions="jpg|bmp|gif|jpeg|JPG|BMP|GIF|JPEG" heith="96" required="0" visible="" descrip="Foto de la persona" note="" name="oi_foto"/>
					</form:Column>
