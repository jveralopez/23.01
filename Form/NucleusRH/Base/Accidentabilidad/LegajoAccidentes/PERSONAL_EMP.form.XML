						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.ART.ART.INFO" xsize="40" mode="QRY" required="0" enabled="0" label="ART" nvalue="#source:oi_art/@value" name="oi_art" X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_art">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_art/HAB"/>
