				<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO" queryname1="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO" xsize="30" mode="QRY" required="0" enabled="0" label="Convenio - Categoria (Ultimo)" nvalue="#source:oi_categoria_ult/@value" name="oi_categoria_ult" X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_categoria_ult">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_categoria_ult/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_categoria_ult"/>
