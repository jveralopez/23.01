							<form:Policies>
								<form:Updateable X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_personal/HAB"/>
								<form:Visible X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_personal"/>
							</form:Policies>
						</form:ComboBox>
						<form:NumberBox required="0" enabled="0" descr="N&#250;mero de Legajo." mask="###.###.##0" xsize="12" label="Numero Legajo" nvalue="#source:@e_numero_legajo" name="e_numero_legajo"/>
						<form:ComboBox queryname1="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.INFO" xsize="40" mode="QRY" required="0" enabled="0" label="Tipo Personal" nvalue="#source:oi_tipo_personal/@value" name="oi_tipo_personal" X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_tipo_personal">
							<form:Policies>
								<form:Updateable X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_tipo_personal/HAB"/>
								<form:Visible X-POLICY="./FORM/NucleusRH/Base/MedicinaLaboral/LegajoMedicina/PERSONAL_EMP/form/oi_tipo_personal"/>
							</form:Policies>
