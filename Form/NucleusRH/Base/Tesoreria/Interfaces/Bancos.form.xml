<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tesoreria.Interfaces.Bancos.form" default_mode="SHOW" doc="source">
	<form:Title>
		<form:Label label="Interface de Salida para Bancos" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4"/>
		<form:ComboBox name="oi_empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa"/>
		<form:FKInput name="oi_banco" label="Banco" length="30" xsize="15" enabled="" required="1" nvalue="#source:@oi_banco">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Bancos.BANCO.guia.flow">
				<helper-mess interface="{oi_banco_interface.XValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event action="ClearSucursal" name="onchange" runat="client"/>
			<form:Event action="loadCombo" name="onprocessresult" runat="client"/>
		</form:FKInput>
		<form:Hidden name="oi_banco_interface"/>
		<form:FKInput name="oi_sucursal" label="Sucursal" length="30" xsize="15" required="0" nvalue="#source:@oi_sucursal">
			<form:STexts>
				<form:SText name="txt1" xsize="50"/>
			</form:STexts>
			<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Liquidacion.Bancos.SUCURSAL-BANCO.guia.flow">
				<helper-mess interface="{oi_sucursal_interface.XValue}" oi_banco="{oi_banco.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
			<form:Event action="loadCombo" runat="client" name="onprocessresult"/>
		</form:FKInput>
		<form:Combo name="interface" nvalue="#source:@interface" required="1" label="Interfaz"/>
		<form:Hidden name="oi_sucursal_interface"/>
		<form:DateTime nvalue="#source:@f_acreditacion" name="f_acreditacion" label="Fecha Acreditacion" mask="dd/mm/yyyy" required="1" pattern="YYYYMMDD">
			<form:SButtons>
				<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank visible="" width="100%" name="bl3"/>
		<form:Grid nvalue="#source:ODS" proto="&lt;OD/&gt;" idvalue="#ROW:@oi_orden_pago" doc="ROW" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="5" descrip="" note="" name="grdDatosOD">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.INFO_CUS" label="Orden de Pago" name="oi_orden_pago" nvalue="#ROW:@oi_orden_pago" xsize="40" mode="QRY" required="1"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="4" name="botonera">
			<form:Row name="fila6">
				<form:Button img="play" descrip="" visible="" enabled="" name="btnEjecutar" label="Ejecutar" startvalidate="0">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="" note="" img="back" label="Volver" name="btnVolver" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="VOLVER_CLICK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ClearSucursal()
{                     
	Ctrl("oi_sucursal").SetCValue("");
	Ctrl("oi_sucursal_interface").SetCValue("");
}

function loadCombo()
{
	
	var ints = Ctrl("oi_banco_interface").GetXValue().split(";");
	if (Ctrl("oi_sucursal").GetXValue() != "")
		ints = Ctrl("oi_sucursal_interface").GetXValue().split(";");

	var xml_source = "&lt;ROWS&gt;";
	for (i = 0; i &lt; ints.length; i++)	
	{
		xml_source += "&lt;OPT value=\"" + ints[i] + "\" text=\"" + ints[i] + "\" code=\"" + ints[i] + "\"/&gt;";
	}
	xml_source += "&lt;/ROWS&gt;";
	Ctrl("interface").setOptions(String2DOM(xml_source).documentElement);
	Ctrl("interface").SyncHTML();
	if (ints.length &gt; 0)
		Ctrl("interface").SetXValue(ints[0]);
}

function ClearLiquidacion()
{                                              
	Ctrl("grdDatosOD").DelAllRows();
}

function EJECUTAR_CLICK()
{                                    
	if (Ctrl("grdDatosOD").TotalRowsCount()==0) { alert("Debe cargar al menos una Orden de Pago."); return false; }
	
	if (Ctrl("oi_sucursal").GetXValue()!="")
	{
		Ctrl("interface").SetXValue(Ctrl("oi_sucursal_interface").GetXValue());
		if (Ctrl("interface").GetXValue()=="") { alert("La Sucursal no tiene ninguna interface asociada."); return false; }
	}
	else
	if (Ctrl("oi_banco").GetXValue()!="")
	{
		Ctrl("interface").SetXValue(Ctrl("oi_banco_interface").GetXValue());
		if (Ctrl("interface").GetXValue()=="") { alert("El Banco no tiene ninguna interface asociada."); return false; }
	}
	
	if (!Ctrl("main").Validate()) return false;
	
	Ctrl("main").DoEvent("EJECUTAR_CLICK");
	return true;
}
	</form:Scripts>
	<form:Event action="EJECUTAR_CLICK" name="EJECUTAR_CLICK" runat="server"/>
	<form:Event action="loadCombo" name="onload" runat="client"/>
</form:Form>
