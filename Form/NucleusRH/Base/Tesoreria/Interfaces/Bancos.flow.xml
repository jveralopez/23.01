<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tesoreria.Interfaces.Bancos.flow" default_action="initialize" extends="Nomad.Base.flow">
	<flow:info label="NucleusRH.Base.Tesoreria.Interfaces.Bancos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA>
				<ODS/>
			</DATA>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="NucleusRH.Base.Tesoreria.Interfaces.bancos.flow" doc="FILTERDATA"/>
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tesoreria.Interfaces.Bancos.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form extends="Nomad.Base.Batch.Download.form:DOWNLOAD" name="NucleusRH.Base.Tesoreria.Interfaces.Bancos.form:EDIT" form-class="NucleusRH.Base.Tesoreria.Interfaces.Bancos.form" mode="SHOW" doc="SOURCE">
		<flow:action name="EJECUTAR_CLICK">
			<flow:save-user-data name="NucleusRH.Base.Tesoreria.Interfaces.bancos.flow" doc-path="#FILTERDATA:"/>
			<flow:exec-method method="InterfaceSalida" class="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="5">
				<flow:param value="BANCOS" mode="in" name="interfaceTIPO" type="Nomad.NSystem.String"/>
				<flow:param attr-path="#SOURCE:@interface" mode="in" type="Nomad.NSystem.String" name="interdaceID"/>
				<flow:param doc-path="#FILTERDATA:" type="Nomad.NSystem.Object" mode="in" name="parametros"/>
			</flow:exec-method>
			<flow:open-form mode="DOWNLOAD" form-class="Nomad.Base.Batch.Download.form" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="VOLVER_CLICK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
