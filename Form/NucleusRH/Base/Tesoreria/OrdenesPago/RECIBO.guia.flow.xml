<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" default_action="HELP" name="NucleusRH.Base.Liquidacion.Recibos.RECIBO.guia.flow" extends="Nomad.simple.guia.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Recibos.RECIBO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form form-class="NucleusRH.Base.Liquidacion.Recibos.RECIBOS.guia.form" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess ID=&quot;2&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				LIQ20_TOT_LIQ_PER.oi_tot_liq_per as ID,
				LIQ99_LIQUIDACION.c_liquidacion as CODE,
				LIQ99_LIQUIDACION.d_titulo as TEXT
			FROM 
				LIQ20_TOT_LIQ_PER, LIQ99_LIQUIDACION
			JOIN
				LIQ20_TOT_LIQ_PER.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo
			WHERE 
				LIQ20_TOT_LIQ_PER.oi_tot_liq_per={#INDOC:@ID}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form form-class="NucleusRH.Base.Liquidacion.Recibos.RECIBOS.guia.form" name="NucleusRH.Base.Liquidacion.Recibos.RECIBOS.guia.form:SHOW" extends="nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW"/>
</flow:flow>
