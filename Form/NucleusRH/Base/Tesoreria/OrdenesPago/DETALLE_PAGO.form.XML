<form:Form xmlns:form="nomad_engine.form" extends="nomad.childIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Tesoreria.OrdenesPago.DETALLE_PAGO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Detalle" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Detalle" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Detalle" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Detalle" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsDETALLE_PAGO">
			<form:Column name="main_columnsDETALLE_PAGOcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Orden de Pago" nvalue="#source:@oi_orden_pago" name="oi_orden_pago"/>
				<form:FKInput label="Liquidaci&#243;n" required="1" enabled="NEW|EDIT" xsize="15" length="30" nvalue="#source:oi_tot_liq_per/@value" name="oi_tot_liq_per">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tesoreria.OrdenesPago.RECIBO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Ingresa el Nro de Cuenta bancaria de la surcursal" ysize="1" xsize="30" length="30" label="Nro de Cuenta Bancaria" nvalue="#source:@c_cta_bancaria" name="c_cta_bancaria"/>
				<form:NumberBox required="1" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Monto" nvalue="#source:@n_monto" name="n_monto"/>
				<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Legajo" nvalue="#source:oi_per_emp_ddo/@value" name="oi_per_emp_ddo">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tesoreria.OrdenesPago.PER_EMP_DDO.Guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Anulado" nvalue="#source:@l_anulado" name="l_anulado"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Anulaci&#243;n" nvalue="#source:@f_anulacion" name="f_anulacion">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Motivo de Anulaci&#243;n" nvalue="#source:@d_motivo_anulacion" name="d_motivo_anulacion"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="N&#250;mero de Modificaci&#243;n" nvalue="#source:@e_nro_modif" name="e_nro_modif"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn label="Liquidaci&#243;n" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Tesoreria.OrdenesPago.RECIBO.guia.flow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" attrname="oi_tot_liq_per" name="oi_tot_liq_per"/>
				<form:LVColumn visible="0" align="left" sorteable="1" descr="Ingresa el Nro de Cuenta bancaria de la surcursal" width="100px" type="string" label="Nro de Cuenta Bancaria" attrname="c_cta_bancaria" name="c_cta_bancaria"/>
				<form:LVColumn visible="0" additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Monto" attrname="n_monto" name="n_monto"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Tesoreria.OrdenesPago.PER_EMP_DDO.guia.flow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Legajo" attrname="oi_per_emp_ddo" name="oi_per_emp_ddo"/>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Anulado" attrname="l_anulado" name="l_anulado"/>
				<form:LVColumn name="n_monto1" additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Monto" attrname="n_monto"/>
				<form:LVColumn name="l_anulado1" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Anulado" attrname="l_anulado"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Anulaci&#243;n" attrname="f_anulacion" name="f_anulacion"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Motivo de Anulaci&#243;n" attrname="d_motivo_anulacion" name="d_motivo_anulacion"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="N&#250;mero de Modificaci&#243;n" attrname="e_nro_modif" name="e_nro_modif"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="EDIT|LIST_EDIT" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" visible="EDIT|LIST_EDIT" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
