<form:Form xmlns:form="nomad_engine.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Tesoreria.OrdenesPago.DETALLE_PAGO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Detalle" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Anular Legajos" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Detalle" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Detalle" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="blank_rowList"/>
		<form:ListView paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn align="right" type="number" name="e_numero_legajo" attrname="e_numero_legajo" additional="########" sorteable="1" width="15px" label="Legajo"/>
				<form:LVColumn label="Apellido y Nombre" type="string" name="d_ape_y_nom" attrname="d_ape_y_nom" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Tesoreria.OrdenesPago.PER_EMP_DDO.guia.flow&quot; /&gt;" align="left" sorteable="1" width="50px"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" width="10px" type="bool" sorteable="1" name="l_anulado" label="Anulado" attrname="l_anulado" align="center"/>
				<form:LVColumn align="right" additional="##,###,##0.00" width="50px" type="number" sorteable="1" name="n_monto" label="Monto" attrname="n_monto"/>
			</form:LVColumns>
			<form:Event action="list_click" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button mess="&#191;Est&#225; seguro que desa anular el registro?" descrip="Anula el Legajo seleccionado de la Orden de Pago" img="cancel" name="ANULAR" label="Anular">
					<form:Event action="ANULAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function list_click()
{
	if (Ctrl('LIST').GetSelectAttrValue("l_anulado") == "1")
		CtrlEnabled('ANULAR', false);
	else
		CtrlEnabled('ANULAR', true);
}

function ONLOAD ()
{
	if (Ctrl('LIST').TotalRowsCount ==0)
		CtrlEnabled('ANULAR', false);
	else
		CtrlEnabled('ANULAR', true);
	
	list_click();
}
	</form:Scripts>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
</form:Form>
