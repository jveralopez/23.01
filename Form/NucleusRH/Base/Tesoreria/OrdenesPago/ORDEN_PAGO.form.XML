			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right>
		<form:VGroup label="Dependencias" collapse="1" width="90%" name="vgChildsORDEN_PAGO">
			<form:Link allowimg="1" label="Detalle" name="DET_PAGO">
				<form:Event action="CALL:DETALLE_PAGO" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsORDEN_PAGO">
			<form:Column name="main_columnsORDEN_PAGOcolumn1">
				<form:TextBox required="1" enabled="0" ysize="1" xsize="30" length="30" label="N&#250;mero de Orden" nvalue="#source:@c_orden_pago" name="c_orden_pago"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_orden_pago" name="d_orden_pago"/>
				<form:FKInput required="1" enabled="NEW|EDIT" xsize="15" length="30" label="Forma Pago" nvalue="#source:oi_forma_pago/@value" name="oi_forma_pago">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.Formas_Pago.FORMA_PAGO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Alta" nvalue="#source:@f_alta" name="f_alta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Pago" nvalue="#source:@f_pago" name="f_pago">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox required="1" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Total Original" nvalue="#source:@n_total_original" name="n_total_original"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Total Modificado" nvalue="#source:@n_total_modificado" name="n_total_modificado"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Anulada" nvalue="#source:@l_anulada" name="l_anulada"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Anulaci&#243;n" nvalue="#source:@f_anulacion" name="f_anulacion">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox visible="0" required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Motivo de Anulaci&#243;n" nvalue="#source:@d_motivo_anulacion" name="d_motivo_anulacion"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Archivo Generado" nvalue="#source:@l_generado" name="l_generado"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Generaci&#243;n" nvalue="#source:@f_generacion" name="f_generacion">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Cantidad de Modificaciones" nvalue="#source:@e_cant_modif" name="e_cant_modif"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_orden_pago" name="o_orden_pago"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn type="string" width="100px" sorteable="0" attrname="empresa" align="left" label="Empresa" name="empresa"/>
				<form:LVColumn name="c_orden_pago" align="left" sorteable="1" width="70px" type="string" label="C&#243;digo" attrname="c_orden_pago"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_orden_pago" name="d_orden_pago"/>
				<form:LVColumn label="Liquidaci&#243;n" attrname="liquidacion" name="liquidacion" type="string" width="100px" sorteable="0" align="left"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.Formas_Pago.FORMA_PAGO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Forma Pago" attrname="oi_forma_pago" name="oi_forma_pago"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Alta" attrname="f_alta" name="f_alta"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Pago" attrname="f_pago" name="f_pago"/>
				<form:LVColumn additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Total Original" attrname="n_total_original" name="n_total_original"/>
				<form:LVColumn additional="###,###,##0.00" align="right" sorteable="1" width="50px" type="number" label="Total Modificado" attrname="n_total_modificado" name="n_total_modificado"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Anulada" attrname="l_anulada" name="l_anulada"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Anulaci&#243;n" attrname="f_anulacion" name="f_anulacion"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Motivo de Anulaci&#243;n" attrname="d_motivo_anulacion" name="d_motivo_anulacion"/>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Archivo Generado" attrname="l_generado" name="l_generado"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Generaci&#243;n" attrname="f_generacion" name="f_generacion"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Cantidad de Modificaciones" attrname="e_cant_modif" name="e_cant_modif"/>
			</form:LVColumns>
			<form:Event action="list_click" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea Anular la Orden de Pago?" descrip="Anular la Orden de Pago" img="del" name="ANULAR" visible="SHOW|LIST" label="Anular">
					<form:Event name="onclick" action="ANULAR" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" visible="0" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="onload" name="onload" runat="client"/>
	<form:Scripts>
		function list_click()
{
	if (Ctrl("LIST").GetSelectAttrValue("l_anulada") == "1")
	{
		CtrlEnabled("ANULAR", false);
		CtrlEnabled("EDIT", false);
	}
	else
	{
		CtrlEnabled("ANULAR", true);
		CtrlEnabled("EDIT", true);
	}
}

function onload()
{
	if (Ctrl("LIST"))
	{
		list_click();
	}
	else
	{
		if (Ctrl("l_anulada").GetXValue()=="1")
		{
			CtrlEnabled("ANULAR", false);
			CtrlEnabled("EDIT", false);
		}
		else
		{
			CtrlEnabled("ANULAR", true);
			CtrlEnabled("EDIT", true);
		}
	}
}

function ToList()
{                
	if (parseInt(Ctrl("iter_size").GetXValue(),10)&lt;=3000)
		Ctrl("LISTA").DoEvent("showList");
	else
		showMess("Modo Lista", "Demasiados registros para ser mostrados en una lista.");
}
	</form:Scripts>
</form:Form>
