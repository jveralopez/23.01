<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="consulta" extends="NucleusRH.Base.Tesoreria.OrdenesPago.autoflow" name="NucleusRH.Base.Tesoreria.OrdenesPago">
	<flow:info label="Flow para NucleusRH.Base.Tesoreria.OrdenesPago"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_orden_pago as oi_orden_pago, t0.c_orden_pago as c_orden_pago FROM TES01_ORD_PAGO as t0 ORDER BY c_orden_pago desc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_orden_pago"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t0.oi_orden_pago as oi_orden_pago, 
				t0.c_orden_pago as c_orden_pago, 
				t0.d_orden_pago as d_orden_pago, 
				t0.f_alta as f_alta, 
				t0.f_pago as f_pago, 
				t0.n_total_original as n_total_original, 
				t0.n_total_modificado as n_total_modificado, 
				t0.l_anulada as l_anulada, 
				t0.f_anulacion as f_anulacion, 
				t0.d_motivo_anulacion as d_motivo_anulacion, 
				t0.l_generado as l_generado, 
				t0.f_generacion as f_generacion, 
				t0.e_cant_modif as e_cant_modif, 
				t0.c_orden_pago as CODE, 
				t0.d_orden_pago as TEXT, 
				t0.oi_liquidacion_ddo as oi_liquidacion_ddo, 
				t0.oi_forma_pago as oi_forma_pago,
				t1.c_liquidacion, t1.d_titulo,
				t2.c_empresa, t2.d_empresa
			FROM 
				TES01_ORD_PAGO as t0, LIQ99_LIQUIDACION as t1, ORG03_EMPRESAS as t2
			JOIN
				t0.oi_liquidacion_ddo LEFT OUTER t1.oi_liquidacion_ddo,
				t1.c_empresa LEFT OUTER t2.c_empresa
			ORDER BY c_orden_pago desc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_orden_pago"/>
						<qry:attribute name="c_orden_pago" value="$r/@c_orden_pago"/>
						<qry:attribute name="d_orden_pago" value="$r/@d_orden_pago"/>
						<qry:attribute name="f_alta" value="$r/@f_alta"/>
						<qry:attribute name="f_pago" value="$r/@f_pago"/>
						<qry:attribute name="n_total_original" value="$r/@n_total_original"/>
						<qry:attribute name="n_total_modificado" value="$r/@n_total_modificado"/>
						<qry:attribute name="l_anulada" value="$r/@l_anulada"/>
						<qry:attribute name="f_anulacion" value="$r/@f_anulacion"/>
						<qry:attribute name="d_motivo_anulacion" value="$r/@d_motivo_anulacion"/>
						<qry:attribute name="l_generado" value="$r/@l_generado"/>
						<qry:attribute name="f_generacion" value="$r/@f_generacion"/>
						<qry:attribute name="e_cant_modif" value="$r/@e_cant_modif"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_liquidacion_ddo" value="$r/@oi_liquidacion_ddo"/>
						<qry:attribute name="oi_forma_pago" value="$r/@oi_forma_pago"/>
						<qry:attribute name="empresa" value="'[' + $r/@c_empresa + '] ' + $r/@d_empresa"/>
						<qry:attribute name="liquidacion" value="'[' + $r/@c_liquidacion + '] ' + $r/@d_titulo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;data&gt;&#13;&#10;&lt;DETALLE_PAGO&gt;&#13;&#10;&lt;oi_tot_liq_per value=&quot;1&quot; /&gt;&#13;&#10;&lt;oi_per_emp_ddo value=&quot;1&quot; /&gt;&#13;&#10;&lt;/DETALLE_PAGO&gt;&#13;&#10;&lt;/data&gt;" name="LIST:NucleusRH.Base.Tesoreria.OrdenesPago.DETALLE_PAGO">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:./DETALLE_PAGO[substring_before(@nmd-status,',')!='~d' and substring_before(@nmd-status,',')!='~x']" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in #PARAM:
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:attribute name="c_cta_bancaria" value="$r/@c_cta_bancaria"/>
						<qry:attribute name="n_monto" value="$r/@n_monto"/>
						<qry:attribute name="oi_per_emp_ddo" value="$r/oi_per_emp_ddo/@value"/>
						<qry:attribute name="l_anulado" value="$r/@l_anulado"/>
						<qry:attribute name="f_anulacion" value="$r/@f_anulacion"/>
						<qry:attribute name="d_motivo_anulacion" value="$r/@d_motivo_anulacion"/>
						<qry:attribute name="e_nro_modif" value="$r/@e_nro_modif"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_tot_liq_per" value="$r/oi_tot_liq_per/@value"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA oi_liquidacion_ddo=&quot;2120&quot; oi_forma_pago=&quot;5&quot; l_negativos=&quot;&quot; l_excluir=&quot;&quot; monto_total=&quot;0&quot; monto_pagar=&quot;0&quot; monto_pen=&quot;0&quot;&gt;&#13;&#10;&#9;&lt;ROWS/&gt;&#13;&#10;&lt;/DATA&gt;" name="qry_recibos">
			<qry:main doc="SOURCE">
				<qry:element name="orden">
					<qry:attribute name="oi_liquidacion_ddo" value="#source:data/@oi_liquidacion_ddo"/>
					<qry:attribute name="oi_forma_pago" value="#source:data/@oi_forma_pago"/>
					<qry:attribute name="d_orden_pago" value="#source:data/@d_orden_pago"/>
					<qry:attribute name="f_pago" value="#source:data/@f_pago"/>
					<qry:attribute name="o_orden_pago" value="#source:data/@o_orden_pago"/>
					<qry:insert-select doc-path="#source:data" name="liquidacion"/>
					<qry:insert-select doc-path="#source:data" name="forma_pago"/>
					<qry:element name="legajos">
						<qry:insert-select doc-path="#source:data" name="orden"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="liquidacion" doc="source">
				<qry:xquery>
					for $r in SQL('
				SELECT LIQ99_LIQUIDACION.c_empresa, LIQ99_LIQUIDACION.c_liquidacion, LIQ99_LIQUIDACION.d_titulo
				FROM LIQ99_LIQUIDACION
				WHERE LIQ99_LIQUIDACION.oi_liquidacion_ddo = {#source:@oi_liquidacion_ddo}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@c_empresa + '-' + $r/@c_liquidacion" name="liquidacion"/>
					<qry:attribute value="$r/@c_liquidacion" name="c_liquidacion"/>
					<qry:attribute value="$r/@d_titulo" name="d_titulo"/>
				</qry:out>
			</qry:select>
			<qry:select name="forma_pago" doc="source">
				<qry:xquery>
					for $r in SQL('
				SELECT PER31_FORMAS_PAGO.c_forma_pago, PER31_FORMAS_PAGO.d_forma_pago
				FROM PER31_FORMAS_PAGO
				WHERE PER31_FORMAS_PAGO.oi_forma_pago = {#source:@oi_forma_pago}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@c_forma_pago + ' - ' + $r/@d_forma_pago" name="d_forma_pago"/>
				</qry:out>
			</qry:select>
			<qry:select name="orden" doc="source">
				<qry:xquery>
					for $r in SQL('SELECT
	L97.oi_per_emp_ddo,
	L97.e_numero_legajo,
	L97.d_ape_y_nom,
	REC.oi_tot_liq_per,
	REC.n_totpag,
	REC.n_montopagado,
	PER.oi_forma_pago_alt
FROM                           
	LIQ99_RECIBOS as RECLIC,
	LIQ20_TOT_LIQ_PER as REC,
	LIQ97_PERSONAL_EMP as L97,
	PER02_PERSONAL_EMP as LEG,
	LIQ07_PERSONAL as PER,
	ORG03_EMPRESAS as EMP,
	PER31_FORMAS_PAGO as FP
JOIN                      
	REC.oi_per_emp_ddo inner L97.oi_per_emp_ddo, 
	REC.oi_tot_liq_per inner RECLIC.oi_tot_liq_per,
	EMP.oi_empresa inner LEG.oi_empresa,
	LEG.oi_personal_emp inner PER.oi_personal_emp,
	L97.e_numero_legajo inner LEG.e_numero_legajo,
	L97.c_empresa inner EMP.c_empresa
WHERE
	RECLIC.oi_liquidacion_ddo={#source:@oi_liquidacion_ddo} and
	(REC.n_totpag != REC.n_montopagado or isnull(REC.n_montopagado)) and
	REC.n_totpag &gt; 0	and
	FP.oi_forma_pago = {#source:@oi_forma_pago} and
	(PER.oi_forma_pago_alt = {#source:@oi_forma_pago} OR
	(isNull(PER.oi_forma_pago_alt) and
	REC.c_forma_pago = FP.c_forma_pago))
		
	{%? (string(#source:/ROWS/ROW/@e_numero_legajo)!='')
		{% AND L97.e_numero_legajo {%=IIF(#source:@l_excluir,'not in','in') %} ({%=string(#source:/ROWS/ROW/@e_numero_legajo) %}) %}
		{% %}
	%}
ORDER BY e_numero_legajo ASC
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="legajo">
						<qry:attribute value="$r/@oi_per_emp_ddo" name="oi_per_emp_ddo"/>
						<qry:attribute value="$r/@e_numero_legajo" name="legajo"/>
						<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
						<qry:attribute value="$r/@n_totpag" name="totpag"/>
						<qry:attribute value="Number($r/@n_totpag)-Number($r/@n_montopagado)" name="totpen"/>
						<qry:attribute value="Number($r/@n_totpag)-Number($r/@n_montopagado)" name="totpen_org"/>
						<qry:element name="recibos">
							<qry:element name="recibo">
								<qry:attribute value="$r/@oi_tot_liq_per" name="oi_tot_liq_per"/>
								<qry:attribute value="$r/@n_totpag" name="totpag"/>
								<qry:attribute value="Number($r/@n_totpag)-Number($r/@n_montopagado)" name="totpen_org"/>
								<qry:attribute value="'?'" name="totpen"/>
							</qry:element>
						</qry:element>
						<qry:insert-select doc-path=".[#source:@l_negativos=1]" name="recibos_negativos"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="recibos_negativos" doc="source">
				<qry:xquery>
					for $r in SQL('SELECT
				REC.oi_tot_liq_per,
				REC.n_totpag,
				REC.n_montopagado
			
			FROM                           
				LIQ99_LIQUIDACION as LIQ,
				LIQ99_RECIBOS as RECLIC,
				LIQ20_TOT_LIQ_PER as REC,
				LIQ97_PERSONAL_EMP as PER
				
			JOIN                     
				LIQ.oi_liquidacion_ddo inner RECLIC.oi_liquidacion_ddo,
				REC.oi_tot_liq_per inner RECLIC.oi_tot_liq_per,
				REC.oi_per_emp_ddo inner PER.oi_per_emp_ddo
				
			WHERE
				REC.n_totpag &lt; 0 and PER.e_numero_legajo = {#source:@legajo} and
				LIQ.c_estado=\'F\' and isNotNull(LIQ.f_cierre)

')/ROWS/ROW[Number(#source:@totpen) &gt; 0]
				</qry:xquery>
				<qry:out>
					<qry:attribute value="Number(./@totpen)+(Number($r/@n_totpag)-Number($r/@n_montopagado))" name="totpen"/>
					<qry:element name="recibos" edit="yes">
						<qry:element name="recibo">
							<qry:attribute value="$r/@oi_tot_liq_per" name="oi_tot_liq_per"/>
							<qry:attribute value="$r/@n_totpag" name="totpag"/>
							<qry:attribute name="totpen_org" value="Number($r/@n_totpag)-Number($r/@n_montopagado)"/>
							<qry:attribute value="iif(number(../../@totpen)&lt;0, Number(../../@totpen) ,0)" name="totpen"/>
						</qry:element>
					</qry:element>
					<qry:attribute value="iif(number(@totpen)&lt;0, 0, @totpen)" name="totpen"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA d_orden_pago=&quot;MMMMMMMM&quot; oi_liquidacion_ddo=&quot;191&quot; oi_forma_pago=&quot;5&quot; f_pago=&quot;20080821&quot; l_negativos=&quot;1&quot; o_orden_pago=&quot;&quot; l_excluir=&quot;&quot; monto_total=&quot;4425.889999999999&quot; monto_pagar=&quot;4425.889999999999&quot; monto_pen=&quot;0&quot;&gt;&lt;ROWS /&gt;&lt;/DATA&gt;" name="qry_val_cerrada">
			<qry:main doc="SOURCE">
				<qry:element nAme="DATA">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
		SELECT LIQ19_LIQUIDACION.f_cierre
		FROM LIQ99_LIQUIDACION, LIQ19_EJECUCIONES, LIQ19_LIQUIDACION
		JOIN  LIQ19_LIQUIDACION.oi_liquidacion INNER LIQ19_EJECUCIONES.oi_liquidacion,
		LIQ19_EJECUCIONES.oi_liquidacion_ddo INNER LIQ99_LIQUIDACION.oi_liquidacion_ddo
		WHERE	LIQ99_LIQUIDACION.c_estado = \'F\' AND
		LIQ99_LIQUIDACION.oi_liquidacion_ddo = {#SOURCE:@oi_liquidacion_ddo}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="f_cierre" value="$r/@f_cierre"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ORDEN_PAGO id=&quot;1&quot; /&gt;" name="qry_legajos">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:ORDEN_PAGO" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					LIQ97_PERSONAL_EMP.d_ape_y_nom, LIQ97_PERSONAL_EMP.e_numero_legajo,
					TES01_DET_PAGO.l_anulado, SUM(TES01_DET_PAGO.n_monto) AS n_monto
				FROM TES01_DET_PAGO, LIQ97_PERSONAL_EMP
				JOIN TES01_DET_PAGO.oi_per_emp_ddo INNER LIQ97_PERSONAL_EMP.oi_per_emp_ddo
				WHERE TES01_DET_PAGO.oi_orden_pago = {#SOURCE:@id}
				GROUP BY
					LIQ97_PERSONAL_EMP.e_numero_legajo,
					LIQ97_PERSONAL_EMP.d_ape_y_nom,
					TES01_DET_PAGO.l_anulado
				ORDER BY
					e_numero_legajo ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@e_numero_legajo"/>
						<qry:attribute name="l_anulado" value="$r/@l_anulado"/>
						<qry:attribute name="n_monto" value="$r/@n_monto"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="AUXDOC">
			<DATA>
				<ROWS/>
			</DATA>
		</doc:define>
		<doc:define name="RECIBOS"/>
		<doc:define name="CRITERIOS">
			<DATA>
				<porcentajes/>
				<montos/>
			</DATA>
		</doc:define>
		<doc:define name="AUX"/>
		<doc:define name="LEGAJOS"/>
		<qry:define name="qry_blank_aux">
			<qry:main doc="SOURCE">
				<DATA>
					<ROWS/>
				</DATA>
			</qry:main>
		</qry:define>
		<qry:define name="qry_blank_criterios">
			<qry:main doc="SOURCE">
				<DATA>
					<porcentajes/>
					<montos/>
				</DATA>
			</qry:main>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.filter.autoform"/>
		</flow:action>
		<flow:action name="vista_previa">
			<flow:log text-path="#SOURCE:" text="kkee"/>
			<flow:html-gen ext="html" out-file-path="#SOURCE:@report" input-doc-path="#SOURCE:" template-file="NucleusRH.Base.Tesoreria.VistaPrevia.rpt"/>
			<flow:open-form doc-path="#SOURCE:" mode="REPORT" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.VistaPrevia.form"/>
		</flow:action>
		<flow:action name="consulta">
			<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			<flow:open-form mode="NEW1" doc-path="#NEWDDOROOT:" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO_NEW.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="ORDEN_PAGO">
		<flow:form extends="FILTER:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.filter.autoform:FILTER" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.filter.autoform" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
				<flow:close-form/>
				<flow:call-action action="FILTER"/>
			</flow:action>
			<flow:action name="inits-DDO">
				<doc:new-object doc="DDO" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form next-action="goto-list" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.noreg.autoform"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.autoform"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.noreg.autoform"/>
				<!--flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.autoform"/-->
			</flow:action>
			<flow:action name="Load-FILTER">
				<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			</flow:action>
			<flow:action name="Save-FILTER">
				<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSROOT:NOREG:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.noreg.autoform:EDIT" form-class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO.noreg.autoform" mode="EDIT">
			<flow:action name="on-move-iterator"/>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#QRY:ROW[1]/@id" class="NucleusRH.Base.Tesoreria.OrdenesPago.ORDEN_PAGO" doc="DDO"/>
