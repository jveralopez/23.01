<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.simple.guia.flow" name="NucleusRH.Base.Liquidacion.LegajoEmpresaDDO.PER_EMP_DDO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.LegajoEmpresaDDO.PER_EMP_DDO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA"/>
	</flow:main>
	<flow:declare>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot;/&gt;&#13;&#10;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
			SELECT
				LIQ97_PERSONAL_EMP.d_ape_y_nom as TEXT, 
				LIQ97_PERSONAL_EMP.e_numero_legajo as CODE,				
				LIQ97_PERSONAL_EMP.oi_per_emp_ddo as ID
			FROM
				LIQ97_PERSONAL_EMP
			WHERE
				LIQ97_PERSONAL_EMP.oi_per_emp_ddo = {#SOURCE:helper-mess/@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
