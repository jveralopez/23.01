<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Tesoreria.Reportes.PagosAcumulados">
		Flow para Nomad.Base.Tesoreria.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS>
				<ORDENES/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados.Report.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados.Report.form:EDIT" form-class="NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados.Report.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Tesoreria.PagosAcumulados.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="003 - Listado de Pagos Acumulados" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Tesoreria.Reportes.PagosAcumulados"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
