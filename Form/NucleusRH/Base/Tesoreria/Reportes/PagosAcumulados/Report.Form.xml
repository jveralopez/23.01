<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.MuniVCRH.Liquidacion.Reporte.PagosAcumulados" doc="source">
	<form:Title>
		<form:Label label="003 - Listado de Pagos Acumulados" style="S3 LCol_w" align="center" visible="" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl4bis"/>
		<form:Columns name="cols1">
			<form:Column name="col1" separation="2" align="center" valign="top">
				<form:Rower required="1" separation="5" label="Per&#237;odo Desde / Hasta" name="periodo">
					<form:DateTime nvalue="#FILTERDATA:@e_periodo_des" name="e_periodo_des" pattern="YYYYMM" required="1" mask="dd/mm/yyyy" label="Per&#237;odo">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label label="..." name="lbl_hasta"/>
					<form:DateTime nvalue="#FILTERDATA:@e_periodo_has" label="Per&#237;odo " name="e_periodo_has" pattern="YYYYMM" required="1" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:ComboBox name="oi_empresa" nvalue="#source:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
