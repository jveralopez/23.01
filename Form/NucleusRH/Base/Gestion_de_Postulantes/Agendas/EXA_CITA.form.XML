<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Gestion_de_Postulantes.Agendas.EXA_CITA.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Agendas.EXA_CITA">
	<form:Title width="90%"/>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsEXA_CITA">
			<form:Column name="main_columnsEXA_CITAcolumn11">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Cita" nvalue="#source:@oi_cita" name="oi_cita"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Empresa" nvalue="#source:oi_empresa/@value" name="oi_empresa"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Requerimiento" nvalue="#source:oi_req/@value" name="oi_req"/>
				<form:ComboBox prev="oi_req" nvalue="#source:oi_referencia/@value" name="oi_referencia" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Referencia"/>
				<form:ComboBox prev="oi_referencia" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Reclutado" nvalue="#source:oi_rec/@value" name="oi_rec"/>
				<form:ComboBox prev="oi_rec" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.EXA_REC.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Examen" nvalue="#source:oi_exa_rec/@value" name="oi_exa_rec" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec"/>
					</form:Policies>
				</form:ComboBox>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_cita_exa" name="o_cita_exa"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="14" xsize="50" length="4000" label="Texto" nvalue="#source:@t_nota_exa" name="t_nota_exa"/>
			</form:Column>
			<form:Column visible="0" name="main_columnsEXA_CITAcolumn1"/>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Examen por Reclutado" attrname="oi_exa_rec" name="oi_exa_rec" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Agendas/EXA_CITA/form/oi_exa_rec"/>
					</form:Policies>
				</form:LVColumn>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom/>
	<form:Event action="LoadForm" name="onload" runat="client"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_exa_rec=&quot;1&quot; /&gt;" name="QRY_DATOS">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT 
				SEL13_RECLUTADOS.oi_reclutado, 
				SEL02_REFERENCIAS.oi_referencia, 
				SEL02_REQ.oi_req, 
				ORG03_EMPRESAS.oi_empresa 
			FROM 
				SEL13_RECLUTADOS, 
				SEL02_REFERENCIAS, 
				SEL02_REQ, 
				ORG03_EMPRESAS,
				SEL13_EXA_REC
			JOIN          
				SEL13_EXA_REC.oi_reclutado INNER SEL13_RECLUTADOS.oi_reclutado,
				SEL13_RECLUTADOS.oi_referencia INNER SEL02_REFERENCIAS.oi_referencia, 
				SEL02_REFERENCIAS.oi_req INNER SEL02_REQ.oi_req,
				SEL02_REQ.oi_empresa INNER ORG03_EMPRESAS.oi_empresa 
			WHERE 
				SEL13_EXA_REC.oi_exa_rec={#SOURCE:@oi_exa_rec}
			
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_reclutado" value="$r/@oi_reclutado"/>
					<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
					<qry:attribute name="oi_req" value="$r/@oi_req"/>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="oi_exa_rec" value="#SOURCE:@oi_exa_rec"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Scripts>
		function LoadForm()
{    
  if (Ctrl('main').GetMode()=="SHOW" || Ctrl('main').GetMode()=="EDIT")
  {
	  if (Ctrl('oi_exa_rec').GetXValue()!='')
		{	
			var datos;  
	  	var nSQL = GetProxy().SQLService();
	  	datos = nSQL.GetOBJ(Ctrl("main").getResource("QRY_DATOS"), "&lt;PARAM oi_exa_rec=\""+Ctrl('oi_exa_rec').GetXValue()+"\" /&gt;");
	  
	  	Ctrl("oi_empresa").SetXValue(datos.oi_empresa);
	  	Ctrl("oi_req").SetXValue(datos.oi_req);
	  	Ctrl("oi_referencia").SetXValue(datos.oi_referencia);
	  	Ctrl("oi_rec").SetXValue(datos.oi_reclutado);
	  	Ctrl("oi_exa_rec").SetXValue(datos.oi_exa_rec);
		}
	}
} 



	</form:Scripts>
</form:Form>
