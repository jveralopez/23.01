<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.filter.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR.form" doc="source">
	<form:Title>
		<form:Label label="Selecci&#243;n de Postulantes" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup visible="0" nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1"/>
		<form:VGroup name="vgroupDatosPers" nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas">
			<form:Columns name="colsemps" width="100%" visible="0"/>
			<form:Columns visible="0" name="colsact" width="100%"/>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
				<form:Column valign="top" align="center" name="col2">
					<form:ListView arr-control="list2arr" width="480px" rows="6" name="list2">
						<form:LVColumns>
							<form:LVColumn name="e_numero_legajo1" label="Documento" additional="########" attrname="documento" width="80px" sorteable="1" type="string"/>
							<form:LVColumn width="300px" type="string" sorteable="1" attrname="d_ape_y_nom" label="Apellido y Nombre" name="d_ape_y_nom1"/>
							<form:LVColumn name="d_empresa1" visible="0"/>
						</form:LVColumns>
					</form:ListView>
				</form:Column>
			</form:Columns>
			<form:Tab name="tab_filtro">
				<form:Panels>
					<form:Panel visible="0" label="Legajo" name="legajo"/>
					<form:Panel visible="0" label="Laboral" name="relacionlab"/>
					<form:Panel visible="0" name="afiliacion" label="Afiliaci&#243;n"/>
					<form:Panel name="postulante" label="Postulante">
						<form:Columns name="cols_postulante" width="95%" height="130px">
							<form:Column name="col1_postulante" valign="top" align="left">
								<form:ComboBox xsize="40" mode="OPT" required="0" label="Estado" nvalue="#source:@estado" name="estado">
									<options>
										<option text="Disponible" value="D"/>
										<option text="Contratado" value="C"/>
									</options>
								</form:ComboBox>
								<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Idiomas.IDIOMA.Combo.autoflow" required="0" label="Idioma" nvalue="#source:@idioma" name="idioma"/>
								<form:Combo action="COMBO" flow="NucleusRH.Base.Personal.Titulos.TITULO.Combo.autoflow" required="0" label="Titulo" nvalue="#source:@titulo" name="titulo"/>
								<form:FKInput label="Localidad de Residencia" required="0" xsize="15" length="30" nvalue="#source:@localidad" name="localidad">
									<form:STexts>
										<form:SText xsize="50" name="txt1"/>
									</form:STexts>
									<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
										<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
									</form:Helper>
									<form:SButtons>
										<form:SButton img="SEARCH" label="Search" name="SEARCH">
											<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
										</form:SButton>
									</form:SButtons>
								</form:FKInput>
								<form:Rower label="Fecha de Nacimiento" separation="5" name="rwernacim">
									<form:DateTime nvalue="#source:@nacim_desde" name="nacim_desde" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
										<form:SButtons>
											<form:SButton img="Calendar" label="Calendar" name="Calendar">
												<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
											</form:SButton>
										</form:SButtons>
									</form:DateTime>
									<form:Label label="..." name="lbl_hasta"/>
									<form:DateTime nvalue="#source:@nacim_hasta" name="nacim_hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Nacimiento">
										<form:SButtons>
											<form:SButton img="Calendar" label="Calendar" name="Calendar">
												<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
											</form:SButton>
										</form:SButtons>
									</form:DateTime>
								</form:Rower>
							</form:Column>
						</form:Columns>
					</form:Panel>
				</form:Panels>
			</form:Tab>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button label="Filtrar" img="ok" name="btnFILTER" descrip="Consultar los Legajos seleccionados" note="Consultar los Legajos seleccionados">
					<form:Event action="Filtrar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button name="AGREGAR" descrip="Agregar una persona" label="Agregar" img="add" note="Volver al Menu princial">
					<form:Event action="ADD" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<form:Resource declare="&lt;ROWS&gt;&lt;ROW id=&quot;12072&quot;/&gt;&lt;/ROWS&gt;" name="qry">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:/ROWS/ROW"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT SEL.oi_postulante,
			SEL.c_dni, 
			SEL.d_postulante, 
			SEC.policy
			FROM 
			SEL01_POSTULANTE as SEL,
			NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE\') AS SEC			
			JOIN SEL.oi_postulante LEFT OUTER SEC.id
			WHERE SEL.oi_postulante={#SOURCE:@id}
			ORDER BY d_postulante ASC
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_postulante"/>
						<qry:attribute name="documento" value="'DNI ' + $r/@c_dni"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_postulante"/>
						<qry:attribute name="policy" value="$r/@policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource name="qry_persona">
			<qry:main name="qry">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT SEL.oi_postulante,
			SEL.c_dni, 
			SEL.d_postulante, 
			SEC.policy
			FROM 
			SEL01_POSTULANTE as SEL,
			NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE\') AS SEC			
			JOIN SEL.oi_postulante LEFT OUTER SEC.id
			WHERE 1=1
			{%?('##nombre##'!='') {% and contain(SEL.d_postulante, \'##nombre##\') %} {% %} %}
			{%?('##documento##'!='') {% and contain(SEL.c_dni, \'##documento##\') %} {% %} %}			
			{%?('##sexo##'!='') {% and SEL.c_sexo =\'##sexo##\' %} {% %} %}
			{%?('##grupo_sanguineo##'!='') {% and SEL.oi_grupo_sanguineo = ##grupo_sanguineo## %} {% %} %}			
			ORDER BY d_postulante ASC
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_postulante"/>
						<qry:attribute name="documento" value="'DNI ' + $r/@c_dni"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_postulante"/>
						<qry:attribute name="policy" value="$r/@policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource name="qry_postulante">
			<qry:main name="qry">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT SEL.oi_postulante,
			SEL.c_dni, 
			SEL.d_postulante, 
			SEC.policy
			FROM 
			SEL01_POSTULANTE as SEL,
			NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE\') AS SEC			
			JOIN SEL.oi_postulante LEFT OUTER SEC.id
			WHERE 1=1			
			{%?('##estado##'!='') {% and SEL.c_estado = \'##estado##\' %} {% %} %}
			{%?('##idioma##'!='') {% and SEL.oi_idioma = ##idioma## %} {% %} %}
			{%?('##titulo##'!='') {% and SEL.oi_titulo = ##titulo## %} {% %} %}
			{%?('##localidad##'!='') {% and SEL.oi_localidad = ##localidad## %} {% %} %}			
			{%?('##nacim_desde##'!='') {% and SEL.f_nacim &gt;= {Datetime(\'##nacim_desde##\')} %} {% %} %}
			{%?('##nacim_hasta##'!='') {% and SEL.f_nacim &lt; {Datetime(Number(Datetime(\'##nacim_hasta##\'))+1)} %} {% %} %}
			ORDER BY d_postulante ASC
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_postulante"/>
						<qry:attribute name="documento" value="'DNI ' + $r/@c_dni"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_postulante"/>
						<qry:attribute name="policy" value="$r/@policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Scripts>
		function SendToServer()
{       
	GetProxy().StoreService().SetUserStore("PER_IDsPersonas", array2stringcustom(arrB, "ROWS", "ROW"));
	return true;
}

function Filtrar()
{               
 	if (Ctrl("list2").TotalRowsCount()==0)
 	{             
 		alert("No hay personas filtradas.");
 		return false;
 	}
 	
 	if (Ctrl("list2").TotalRowsCount()&gt;100)
 	{             
 		alert("Hay demasiados registros seleccionados, afine la b&#250;squeda.");
 		return false;
 	}
	SendToServer();
	Ctrl("main").DoEvent("FILTER");
}

function enable_custom_buttons()
{
	if (Ctrl("list2"))
		CtrlEnabled("btnFILTER", Ctrl("list2").TotalRowsCount()?true:false);
}
	</form:Scripts>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
</form:Form>
