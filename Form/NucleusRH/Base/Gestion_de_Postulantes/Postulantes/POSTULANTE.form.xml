	<form:Scripts>
		function LoadForm()
{
	if (Ctrl('main').GetMode()=="NEW")
	{
		Ctrl('c_estado').SetXValue('D');
	}
}

function nombreyapellido ()
	{
		Ctrl('d_postulante').SetCValue(Ctrl('d_apellido').GetCValue()+', '+Ctrl('d_nombre').GetCValue());		
	}

	function valida (myThis)
	{

		if (Ctrl('f_nacim').GetXValue() != "")
		{
			if (Ctrl('f_nacim').TypedValue() &gt;= NowDate())
			{
			  myThis.SetError('La fecha de Nacimiento debe ser anterior a Hoy');
				return false;
			}			
		} 			

		if (Ctrl('f_casamiento').GetXValue() != "")
		{
			if (Ctrl('f_casamiento').GetXValue() &lt;= Ctrl('f_nacim').GetXValue() || Ctrl('f_casamiento').TypedValue() &gt;= NowDate())
			{
				myThis.SetError('La fecha de Casamiento debe ser posterior a la fecha de Nacimiento y anterior a hoy');
				return false;
			}			
		}		
				
		if (Ctrl('f_ingreso_pais').GetXValue() != "")
		{
			if (Ctrl('f_ingreso_pais').GetXValue() &lt;= Ctrl('f_nacim').GetXValue() || Ctrl('f_ingreso_pais').TypedValue() &gt;= NowDate())
			{
				myThis.SetError('La fecha de Ingreso al pais debe ser posterior a la fecha de Nacimiento y anterior a Hoy');
				return false;
			}			
		}     	           		
				
		 return true;
	}  
	
function ObjectResult()
{
	this.processResult = function()
	{
		Ctrl('main').DoEvent("CHANGE");		
	}
}
             
function ObjtectResult()
{
	this.processResult= function(xmlin){}
}

function Trayectoria() 
{    
	openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Trayectoria_Postulante.flow","initialize",'&lt;DATA oi_postulante="'+Ctrl('oi_postulante').GetXValue()+'"/&gt;' , new ObjtectResult(),"M");
}
