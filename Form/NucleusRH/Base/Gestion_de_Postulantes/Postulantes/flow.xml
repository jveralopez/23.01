				<flow:log text="logNEWDDOROOT" text-path="#NEWDDOROOT:"/>
				<doc:save-object class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE" doc="NEWDDOROOT"/>
