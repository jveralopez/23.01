				<doc:new-object class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE" doc="NEWDDOROOT"/>
				<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form" mode="NEW" doc-path="#NEWDDOROOT:"/>
			</flow:action>
			<flow:action name="EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
			<flow:action name="CALL:PROCESOS">
				<flow:log text-path="#SOURCE:" text="emisource"/>
				<!--flow:open-form mode="LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.PROCESOS_POS.form" doc-path="#SOURCE:" parent-doc-path="#SOURCE:" iter-index="#SOURCE:@id"/-->
			</flow:action>
		</flow:form>
		<flow:form mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form" name="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form:NEW" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.autoform:NEW">
