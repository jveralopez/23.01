<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.autoflow" default_action="initialize" name="Postulantes">
	<flow:info label="flow para POSTULANTE"/>
	<flow:declare>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_empresa=&quot;&quot; F_DESDE=&quot;&quot; F_HASTA=&quot;&quot; SEXO=&quot;&quot;&gt;&#13;&#10;  &lt;PERSONAS nmd-col=&quot;1&quot;/&gt;&#13;&#10;&#13;&#10;  &lt;/FILTRO&gt;&#13;&#10;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
						SEL01_POSTULANTE.oi_postulante, 
						SEL01_POSTULANTE.c_postulante, 
						SEL01_POSTULANTE.d_postulante, 
						SEL01_POSTULANTE.c_sexo,
					 	SEL01_POSTULANTE.d_apellido,   
					 	SEL01_POSTULANTE.f_nacim
				FROM
					SEL01_POSTULANTE				
				WHERE 
					SEL01_POSTULANTE.oi_postulante in ({%=string(#SOURCE:ROWS/ROW/@id) %})				
				ORDER BY 
					d_postulante ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_postulante" value="$r/@c_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_postulante" value="$r/@d_postulante" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW id=&quot;12&quot; /&gt;&lt;ROW id=&quot;6&quot; /&gt;&lt;ROW id=&quot;17&quot; /&gt;&lt;ROW id=&quot;14&quot; /&gt;&lt;ROW id=&quot;2&quot; /&gt;&lt;ROW id=&quot;9&quot; /&gt;&lt;ROW id=&quot;3&quot; /&gt;&lt;ROW id=&quot;1&quot; /&gt;&lt;ROW id=&quot;28&quot; /&gt;&lt;ROW id=&quot;10&quot; /&gt;&lt;/ROWS&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_postulante as oi_postulante, 
					t0.c_postulante as c_postulante, 
					t0.d_postulante as d_postulante,
					t0.d_apellido,   
					t0.f_nacim,
					t0.c_estado as c_estado, 
					t0.c_dni as c_dni, 
					t0.c_sexo as c_sexo, 
					t0.d_email as d_email
				FROM 
					SEL01_POSTULANTE as t0              
				WHERE
					t0.oi_postulante in ({%=string(#SOURCE:ROWS/ROW/@id) %})				
				ORDER BY					
					d_postulante asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_postulante"/>
						<qry:attribute name="c_postulante" value="$r/@c_postulante"/>
						<qry:attribute name="d_postulante" value="$r/@d_postulante"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="c_dni" value="$r/@c_dni"/>
						<qry:attribute name="c_sexo" value="$r/@c_sexo"/>
						<qry:attribute name="d_email" value="$r/@d_email"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_empresa="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<qry:define name="QRY_POSTULANTE">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				
				SELECT 
					max(SEL01_POSTULANTE.oi_postulante) as oi_postulante
				FROM 
					SEL01_POSTULANTE
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_postulante" value="$r/@oi_postulante + 1"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="POSTULANTE"/>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&lt;ROW id=&quot;12&quot; /&gt;&#13;&#10;&#9;&#13;&#10;&lt;/ROWS&gt;" name="LIST:NucleusRH.Base.Gestion_de_Postulantes.Postulantes.PROCESOS_POS">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					SEL01_POSTULANTE.oi_postulante,
					SEL13_RECLUTADOS.c_estado,
					SEL13_RECLUTADOS.f_reclutamiento,
					SEL13_RECLUTADOS.f_seleccion,
					SEL13_RECLUTADOS.f_contratacion,
					SEL13_RECLUTADOS.f_rankeo,
					SEL13_RECLUTADOS.F_descartado,
					SEL13_RECLUTADOS.oi_referencia
				FROM 
					SEL01_POSTULANTE,
					SEL13_RECLUTADOS
				JOIN
					SEL01_POSTULANTE.oi_postulante INNER SEL13_RECLUTADOS.oi_postulante
				WHERE
					SEL01_POSTULANTE.oi_postulante in ({%=string(#SOURCE:ROWS/ROW/@id) %})				
				ORDER BY					
					oi_referencia ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_referencia"/>
						<qry:switch test="$r/@c_estado">
							<qry:case value="R">
								<qry:attribute name="estado" value="'Reclutado'"/>
								<qry:attribute name="f_estado" value="format_date($r/@f_reclutamiento,'dd/mm/yyyy')"/>
							</qry:case>
							<qry:case value="N">
								<qry:attribute name="estado" value="'Rankeado'"/>
								<qry:attribute name="f_estado" value="format_date($r/@f_rankeo,'dd/mm/yyyy')"/>
							</qry:case>
							<qry:case value="S">
								<qry:attribute name="estado" value="'Seleccionado'"/>
								<qry:attribute name="f_estado" value="format_date($r/@f_seleccion,'dd/mm/yyyy')"/>
							</qry:case>
							<qry:case value="C">
								<qry:attribute name="estado" value="'Contratado'"/>
								<qry:attribute name="f_estado" value="format_date($r/@f_contratacion,'dd/mm/yyyy')"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="estado" value="'Descartado'"/>
								<qry:attribute name="f_estado" value="format_date($r/@f_descartado,'dd/mm/yyyy')"/>
							</qry:default>
						</qry:switch>
						<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA oi_postulante=&quot;202&quot; ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_empresa=&quot;&quot; F_DESDE=&quot;&quot; F_HASTA=&quot;&quot; SEXO=&quot;&quot;/&gt;&#13;&#10;&#13;&#10;" name="FILTER_EXT">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:." name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
						SEL01_POSTULANTE.oi_postulante, 
						SEL01_POSTULANTE.c_postulante, 
						SEL01_POSTULANTE.d_postulante, 
						SEL01_POSTULANTE.c_sexo,
					 	SEL01_POSTULANTE.d_apellido,   
					 	SEL01_POSTULANTE.f_nacim
				FROM
					SEL01_POSTULANTE				
				WHERE 
					SEL01_POSTULANTE.oi_postulante = {#SOURCE:@oi_postulante}				
				ORDER BY 
					d_postulante ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_postulante" value="$r/@c_postulante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_postulante" value="$r/@d_postulante" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.filter.form" mode="FILTER"/>
		</flow:action>
