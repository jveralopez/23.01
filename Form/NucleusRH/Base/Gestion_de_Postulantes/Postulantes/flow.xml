				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.noreg.autoform" mode="EDIT" extends="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.noreg.autoform:EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.noreg.autoform">
			<flow:action name="ADD">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form"/>
			</flow:action>
			<flow:action name="goto-list">
				<flow:log text-path="#QRY:" text="ppqry"/>
