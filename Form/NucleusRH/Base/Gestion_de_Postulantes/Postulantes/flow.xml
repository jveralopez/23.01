		</flow:form>
		<flow:form mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form" name="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.form:SHOW" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Gestion_de_Postulantes.Postulantes.POSTULANTE.autoform:SHOW">
			<flow:action name="After-Change">
				<doc:iter-refresh/>
				<doc:iter-move value-path="#DDO:@id"/>
			</flow:action>
			<flow:action name="on-show"/>
