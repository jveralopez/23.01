<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.autoform" default_mode="FILTER" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center>
		<form:Blank name="bl40" width="100%" visible=""/>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Columns name="main_columnsCURSO">
			<form:Column name="main_columnsCURSOcolumn1">
				<form:FKInput visible="FILTER" enabled="0" label="Empresa - Legajo" required="1" xsize="15" length="30" nvalue="#USER:@oi_personal_emp" name="oi_personal_emp">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
				</form:FKInput>
				<form:Blank name="1231"/>
				<form:Combo flow="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.c_estado.Combo.autoflow" action="COMBO" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				<form:DateTime name="f_solicitud_desde" nvalue="#source:@f_desde_solicitud" label="Fecha Desde Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_solicitud_hasta" nvalue="#source:@f_hasta_solicitud" label="Fecha Hasta Solicitud" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#USER:@user" name="user"/>
		<form:Hidden nvalue="#source:@f_hoy" name="f_hoy"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button startvalidate="1" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="getUser" name="onload" runat="client"/>
	<form:Event action="GET_USER" name="GET_USER" runat="server"/>
	<form:Scripts>
		function getUser()
{
	Ctrl('f_hoy').SetXValue(date2str(NowDate()));
	
	//if (Ctrl('main').GetMode()=="FILTER_ADMIN")
		//return;
	if (Ctrl('user').GetXValue()!="")
		return;
	var proxy = GetProxy();
	Ctrl('user').SetXValue(proxy.UserName());
	Ctrl('main').DoEvent('GET_USER');
}
	</form:Scripts>
</form:Form>
