<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD">
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsSOLICITUD">
			<form:Column name="main_columnsSOLICITUDcolumn1">
				<form:FKInput required="1" enabled="0" xsize="15" length="30" label="Empresa - Legajo Solicitante" nvalue="#source:oi_personal_emp/@value" name="oi_personal_emp">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha de Solicitud" nvalue="#source:@f_solicitud" name="f_solicitud">
					<form:SButtons>
						<form:SButton visible="0" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Nombre de Puesto" nvalue="#source:@d_puesto" name="d_puesto"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="&#193;rea" nvalue="#source:@d_area" name="d_area"/>
				<form:Combo action="COMBO" flow="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado de Solicitud" nvalue="#source:@c_estado" name="c_estado"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Empresa - Legajo Solicitante" attrname="oi_personal_emp" name="oi_personal_emp"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Solicitud" attrname="f_solicitud" name="f_solicitud"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Nombre de Puesto" attrname="d_puesto" name="d_puesto"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="&#193;rea" attrname="d_area" name="d_area"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Estado de Solicitud" attrname="c_estado" name="c_estado"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha tentativa de Incorporaci&#243;n" attrname="f_incorporacion" name="f_incorporacion"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Edad Desde" attrname="e_edad_desde" name="e_edad_desde"/>
				<form:LVColumn visible="0" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Edad Hasta" attrname="e_edad_hasta" name="e_edad_hasta"/>
				<form:LVColumn visible="0" additional="&lt;combo action=&quot;COMBO&quot; flow=&quot;NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL.Combo.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="combo" label="Estado Civil" attrname="oi_estado_civil" name="oi_estado_civil"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Procedencia" attrname="d_procedencia" name="d_procedencia"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Radicaci&#243;n" attrname="d_radicacion" name="d_radicacion"/>
				<form:LVColumn visible="0" additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Disponibilidad para viajar" attrname="l_disp_viajar" name="l_disp_viajar"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Dedicaci&#243;n" attrname="c_dedicacion" name="c_dedicacion"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Formaci&#243;n acad&#233;mica requerida" attrname="d_formacion_req" name="d_formacion_req"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Experiencia Requerida" attrname="d_experiencia_req" name="d_experiencia_req"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Motivo que origina la solicitud" attrname="c_motivo" name="c_motivo"/>
				<form:LVColumn visible="0" align="left" sorteable="1" width="100px" type="string" label="Modalidad de Contrataci&#243;n" attrname="c_mod_contrato" name="c_mod_contrato"/>
			</form:LVColumns>
			<form:Event action="ONLOAD" name="onclick" runat="client"/>
		</form:ListView>
	</form:Center>
	<form:Right visible="SHOW|EDIT|LIST"/>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Gestion_de_Postulantes/Solicitudes/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Gestion_de_Postulantes/Solicitudes/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Gestion_de_Postulantes/Solicitudes/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Gestion_de_Postulantes/Solicitudes/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Scripts>
		function ONLOAD()
{
	var estado;
	
	// Busco el estado
	if (Ctrl('LIST'))
	{
		estado = Ctrl('LIST').GetSelectAttrValue('c_estado');
	}else
	{
		estado = Ctrl('c_estado').GetXValue();
	}
	
	// Deshabilito controles
	if (estado != 'SOL')
	{
		CtrlEnabled('EDIT', false);
		CtrlEnabled('DELETE', false);
	}else
	{
		CtrlEnabled('EDIT', true);
		CtrlEnabled('DELETE', true);
	}   
	if ((Ctrl('main').GetMode() == 'NEW') || (Ctrl('main').GetMode() == 'EDIT'))
	{
	  if ((Ctrl('c_estado').GetXValue()=='ARH') || (Ctrl('c_estado').GetXValue()=='AGG'))
	  {
	  	CtrlEnabled('REF_SOL',true);
	  	CtrlEnabled('SEG_SOLIC',true);
	  }else
	  {
	  	CtrlEnabled('REF_SOL',false); 
	  	CtrlEnabled('SEG_SOLIC',false);
	  }
	 }else
	 	{                            
	 		CtrlEnabled('REF_SOL',true);   
	 		CtrlEnabled('SEG_SOLIC',true);
	 	}
  
}
	</form:Scripts>
</form:Form>
