<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.autoflow" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes">
	<flow:info label="Flow para NucleusRH.Base.Gestion_de_Postulantes.Solicitudes"/>
	<flow:declare>
		<doc:define name="USER">
			<DATOS user="" oi_personal_emp=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS oi_personal_emp="" c_estado="" oi_area="" f_desde_solicitud="" f_hasta_solicitud="" f_hoy="" user=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;68&quot; oi_area=&quot;2&quot; c_estado=&quot;&quot; f_desde_solicitud=&quot;&quot;/&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_solicitud as oi_solicitud, 
					t0.f_solicitud
				FROM 
					SEL18_SOLICITUDES as t0
				WHERE 
					t0.oi_personal_emp = {#PARAM:@oi_personal_emp}
					{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
					{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
					{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY 
					f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_solicitud"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;68&quot; oi_area=&quot;2&quot; c_estado=&quot;&quot; f_desde_solicitud=&quot;&quot;/&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_solicitud as oi_solicitud, 
					t0.f_solicitud as f_solicitud, 
					t0.d_puesto as d_puesto, 
					t0.d_area as d_area, 
					t0.c_estado as c_estado, 
					t0.f_incorporacion as f_incorporacion, 
					t0.e_edad_desde as e_edad_desde, 
					t0.e_edad_hasta as e_edad_hasta, 
					t0.d_procedencia as d_procedencia, 
					t0.d_radicacion as d_radicacion, 
					t0.l_disp_viajar as l_disp_viajar, 
					t0.c_dedicacion as c_dedicacion, 
					t0.d_formacion_req as d_formacion_req, 
					t0.d_experiencia_req as d_experiencia_req, 
					t0.c_motivo as c_motivo, 
					t0.c_mod_contrato as c_mod_contrato, 
					t0.c_solicitud as CODE, t0.d_puesto as TEXT, 
					t0.oi_personal_emp as oi_personal_emp, 
					t0.oi_estado_civil as oi_estado_civil 
				FROM 
					SEL18_SOLICITUDES as t0
				WHERE 
					t0.oi_personal_emp = {#PARAM:@oi_personal_emp}
					{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
					{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
					{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY 
					f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_solicitud"/>
						<qry:attribute name="c_solicitud" value="$r/@CODE"/>
						<qry:attribute name="f_solicitud" value="$r/@f_solicitud"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto"/>
						<qry:attribute name="d_area" value="$r/@d_area"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'SOL', 'SYB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'EVA', 'SYB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'ARH', 'SGB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'AGG', 'SGB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'RRH', 'SRB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'RGG', 'SRB.gif',./@img)"/>
						<qry:attribute name="f_incorporacion" value="$r/@f_incorporacion"/>
						<qry:attribute name="e_edad_desde" value="$r/@e_edad_desde"/>
						<qry:attribute name="e_edad_hasta" value="$r/@e_edad_hasta"/>
						<qry:attribute name="d_procedencia" value="$r/@d_procedencia"/>
						<qry:attribute name="d_radicacion" value="$r/@d_radicacion"/>
						<qry:attribute name="l_disp_viajar" value="$r/@l_disp_viajar"/>
						<qry:attribute name="c_dedicacion" value="$r/@c_dedicacion"/>
						<qry:attribute name="d_formacion_req" value="$r/@d_formacion_req"/>
						<qry:attribute name="d_experiencia_req" value="$r/@d_experiencia_req"/>
						<qry:attribute name="c_motivo" value="$r/@c_motivo"/>
						<qry:attribute name="c_mod_contrato" value="$r/@c_mod_contrato"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="oi_estado_civil" value="$r/@oi_estado_civil"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS user=&quot;jprizzo&quot; oi_personal_emp=&quot;&quot; /&gt;" name="GET_USER">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:DATOS" name="PARAMIN"/>
				<qry:element name="DATOS">
					<qry:attribute value="#PARAMIN:@user" name="user"/>
					<qry:insert-select name="account-name"/>
				</qry:element>
			</qry:main>
			<qry:select name="account-name" doc="SOURCE">
				<qry:xquery>
					for $r in path('Nomad\\Base\\Login\\Cuentas')/CUENTA
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql2" doc="PARAM">
				<qry:xquery>
					for $r in file('Nomad\\Base\\Login\\Cuentas\\{%= #PARAM:@FILE %}')/CUENTA[@LOGIN=#PARAMIN:@user]/ENTIDAD
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql4" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql4" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					PER01_PERSONAL, PER02_PERSONAL_EMP
				JOIN 
					PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
				WHERE
					PER01_PERSONAL.oi_usuario_sistema = {#PARAM:@value}
					AND PER02_PERSONAL_EMP.oi_indic_activo = 1
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="SOLICITUD">
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.form:FILTER" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.filter.form" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
			<flow:action name="GET_USER">
				<flow:log text="jprUSER" text-path="#USER:"/>
				<doc:load-qry input-doc-path="#USER:" output-doc="USER" qry="GET_USER"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#SOURCE:@oi_personal_emp"/>
			</flow:action>
			<flow:action name="FILTER">
				<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.noreg.form:EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form:SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form" mode="SHOW">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form:LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form" mode="LIST">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD"/>
				<doc:set-attribute from-attr-path="#USER:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@f_hoy" to-attr-path="#NEWDDOROOT:@f_solicitud"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form:EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form:NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD.form" mode="NEW">
			<flow:action name="save-DDO">
				<doc:new-object class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SEG_SOLIC" doc="NEWDDO"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@f_solicitud" to-attr-path="#NEWDDO:@f_modificacion"/>
				<doc:set-attribute from-value="Creaci&#243;n de la Solicitud" to-attr-path="#NEWDDO:@d_seg_solic"/>
				<doc:set-attribute from-attr-path="#USER:@user" to-attr-path="#NEWDDO:@d_usuario"/>
				<doc:set-attribute from-value="SOL" to-attr-path="#NEWDDO:@c_estado"/>
				<doc:add-object parent-doc-path="#NEWDDOROOT:SEG_SOLIC" doc-path="#NEWDDO:"/>
				<doc:save-object class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD" doc="NEWDDOROOT"/>
				<doc:load-object id-path="#NEWDDOROOT:@id" class="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.SOLICITUD" doc="DDO"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
