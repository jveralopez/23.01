<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes.autoflow" name="NucleusRH.Base.Gestion_de_Postulantes.Solicitudes">
	<flow:declare>
		<doc:define name="USER">
			<DATOS user="" oi_personal_emp=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS oi_personal_emp="" c_estado="" f_desde_solicitud="" f_hasta_solicitud="" f_hoy="" user="" function=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;&quot; oi_area=&quot;2&quot; c_estado=&quot;&quot; f_desde_solicitud=&quot;&quot;/&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_solicitud as oi_solicitud, t0.f_solicitud
				FROM SEL18_SOLICITUDES as t0
				WHERE 1=1
				{%?(#PARAM:@oi_personal_emp!='') {% AND t0.oi_personal_emp = {#PARAM:@oi_personal_emp} %} {% %} %}
				{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
				{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
				{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_solicitud"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;68&quot; oi_area=&quot;2&quot; c_estado=&quot;&quot; f_desde_solicitud=&quot;&quot;/&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_solicitud as oi_solicitud, t0.f_solicitud as f_solicitud, t0.d_puesto as d_puesto, t0.d_area as d_area, t0.c_estado as c_estado, t0.f_incorporacion as f_incorporacion, t0.e_edad_desde as e_edad_desde, t0.e_edad_hasta as e_edad_hasta, t0.d_procedencia as d_procedencia, t0.d_radicacion as d_radicacion, t0.l_disp_viajar as l_disp_viajar, t0.c_dedicacion as c_dedicacion, t0.d_formacion_req as d_formacion_req, t0.d_experiencia_req as d_experiencia_req, t0.c_motivo as c_motivo, t0.c_mod_contrato as c_mod_contrato, t0.c_solicitud as CODE, t0.d_puesto as TEXT, t0.oi_personal_emp as oi_personal_emp, t0.oi_estado_civil as oi_estado_civil 
				FROM SEL18_SOLICITUDES as t0
				WHERE 1=1
				{%?(#PARAM:@oi_personal_emp!='') {% AND t0.oi_personal_emp = {#PARAM:@oi_personal_emp} %} {% %} %}
				{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}
				{%?(#PARAM:@f_desde_solicitud!='') {% AND t0.f_solicitud &gt;= {DateTime(#PARAM:@f_desde_solicitud)} %} {% %} %}
				{%?(#PARAM:@f_hasta_solicitud!='') {% AND t0.f_solicitud &lt;= {DateTime(#PARAM:@f_hasta_solicitud)} %} {% %} %}
				ORDER BY f_solicitud desc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_solicitud"/>
						<qry:attribute name="c_solicitud" value="$r/@CODE"/>
						<qry:attribute name="f_solicitud" value="$r/@f_solicitud"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto"/>
						<qry:attribute name="d_area" value="$r/@d_area"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'SOL', 'SYB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'EVA', 'SYB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'ARH', 'SGB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'AGG', 'SGB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'RRH', 'SRB.gif',./@img)"/>
						<qry:attribute name="img" value="iif($r/@c_estado = 'RGG', 'SRB.gif',./@img)"/>
						<qry:attribute name="f_incorporacion" value="$r/@f_incorporacion"/>
						<qry:attribute name="e_edad_desde" value="$r/@e_edad_desde"/>
						<qry:attribute name="e_edad_hasta" value="$r/@e_edad_hasta"/>
						<qry:attribute name="d_procedencia" value="$r/@d_procedencia"/>
						<qry:attribute name="d_radicacion" value="$r/@d_radicacion"/>
						<qry:attribute name="l_disp_viajar" value="$r/@l_disp_viajar"/>
						<qry:attribute name="c_dedicacion" value="$r/@c_dedicacion"/>
						<qry:attribute name="d_formacion_req" value="$r/@d_formacion_req"/>
						<qry:attribute name="d_experiencia_req" value="$r/@d_experiencia_req"/>
						<qry:attribute name="c_motivo" value="$r/@c_motivo"/>
						<qry:attribute name="c_mod_contrato" value="$r/@c_mod_contrato"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="oi_estado_civil" value="$r/@oi_estado_civil"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="MAIL"/>
		<qry:define declare="&#13;&#10;&#9;&lt;SOLICITUD id=&quot;1&quot; &#13;&#10;&#9;&#9;c_solicitud=&quot;1&quot; &#13;&#10;&#9;&#9;f_solicitud=&quot;20080714&quot; &#13;&#10;&#9;&#9;d_puesto=&quot;01&quot; &#13;&#10;&#9;&#9;d_area=&quot;01&quot; c_estado=&quot;ARH&quot; l_disp_viajar=&quot;0&quot; descr=&quot;[1] 01&quot;&gt;&#13;&#10;&#9;&#9;&lt;oi_personal_emp value=&quot;68&quot;/&gt;&#13;&#10;&#9;&#9;&lt;oi_estado_civil/&gt;&#13;&#10;&#9;&#9;&lt;SEG_SOLIC&gt;&#13;&#10;&#9;&#9;&#9;&lt;SEG_SOLIC id=&quot;2&quot; oi_solicitud=&quot;1&quot; f_modificacion=&quot;20080714&quot; d_seg_solic=&quot;Aprobada por Gerencia de RRHH&quot; d_usuario=&quot;demo&quot; c_estado=&quot;ARH&quot; descr=&quot;[1] 01 - [2] Aprobada por Gerencia de RRHH&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&lt;SEG_SOLIC id=&quot;1&quot; oi_solicitud=&quot;1&quot; f_modificacion=&quot;20080714&quot; d_seg_solic=&quot;Creaci&amp;#243;n de la Solicitud&quot; d_usuario=&quot;demo&quot; c_estado=&quot;SOL&quot; descr=&quot;[1] 01 - [1] Creaci&amp;#243;n de la Solicitud&quot;/&gt;&#13;&#10;&#9;&#9;&lt;/SEG_SOLIC&gt;&#13;&#10;&#9;&#9;&lt;REF_SOL&gt;&#13;&#10;&#9;&#9;&#9;&lt;REF_SOL id=&quot;1&quot; oi_solicitud=&quot;1&quot; descr=&quot;[1] 01 - [1] 1&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;oi_referencia value=&quot;14&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&lt;/REF_SOL&gt;&#13;&#10;&#9;&#9;&#9;&lt;REF_SOL id=&quot;2&quot; oi_solicitud=&quot;1&quot; descr=&quot;[1] 01 - [2] 2&quot;&gt;&#13;&#10;&#9;&#9;&#9;&#9;&lt;oi_referencia value=&quot;15&quot;/&gt;&#13;&#10;&#9;&#9;&#9;&lt;/REF_SOL&gt;&#13;&#10;&#9;&#9;&lt;/REF_SOL&gt;&#13;&#10;&#9;&lt;/SOLICITUD&gt;&#13;&#10;" name="SENDMAIL">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:SOLICITUD" name="DDO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="DDO" name="DDO">
				<qry:xquery>
					for $r in #DDO:
				</qry:xquery>
				<qry:out>
					<qry:attribute value="'La Referencia:[' + $r/@c_solicitud + '] ' + $r/@d_puesto + ' fue aprobada por RRHH y esta pendiente de aprobacion'" name="MSG"/>
					<qry:insert-select name="PARAM"/>
				</qry:out>
			</qry:select>
			<qry:select doc="DDO" name="PARAM">
				<qry:xquery>
					for $r in sql('
			SELECT            
				c.d_valor
			FROM
				ORG26_PARAMETROS as c     
			WHERE
				c.c_parametro = \'mailGerencia\' 
				and
				c.c_modulo = \'SEL\'			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@d_valor" name="MAILS"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
