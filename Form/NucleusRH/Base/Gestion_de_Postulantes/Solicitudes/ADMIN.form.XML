	<form:Event action="ONLOAD" name="onload" runat="client"/>
	<form:Scripts>
		function ONLOAD()
{
	
	if ((Ctrl('c_estado').GetXValue() == 'ARH') || (Ctrl('c_estado').GetXValue() == 'AGG'))
	{   
		CtrlEnabled('CUBRIR',true);	
	}else                        	
		{                           
			CtrlEnabled('CUBRIR',false);	
		
		}
	    
	Ctrl('f_hoy').SetXValue(date2str(NowDate()));
	
	var estado;
	// Busco el estado
	if (Ctrl('LIST'))
	{
		estado = Ctrl('LIST').GetSelectAttrValue('c_estado');
	}else
	{
		estado = Ctrl('c_estado').GetXValue();
	}
	
	CtrlEnabled('NEW_REQ', false);
	CtrlEnabled('EVALUAR', false);
	
	var funcion = Ctrl('function').GetXValue();
	// Deshabilito controles
	if (funcion == 'RH')
	{
		if (estado == 'SOL')
		{
			CtrlEnabled('EVALUAR', true);
			CtrlEnabled('APROBAR', true);
			CtrlEnabled('RECHAZAR', true);
		}else if (estado == 'EVA')
		{
			CtrlEnabled('APROBAR', true);
			CtrlEnabled('RECHAZAR', true);
		}else
		{
			CtrlEnabled('APROBAR', false);
			CtrlEnabled('RECHAZAR', false);
		}
		if (estado == 'AGG')
			CtrlEnabled('NEW_REQ', true);
			
	}else if (funcion == 'GG')
	{
		if (estado == 'ARH')
		{
			CtrlEnabled('APROBAR', true);
			CtrlEnabled('RECHAZAR', true);
		}else
		{
			CtrlEnabled('APROBAR', false);
			CtrlEnabled('RECHAZAR', false);
		}
	}   
	
	if ((Ctrl('main').GetMode() == 'NEW') || (Ctrl('main').GetMode() == 'EDIT'))
	{
	  if ((Ctrl('c_estado').GetXValue()=='ARH') || (Ctrl('c_estado').GetXValue()=='AGG'))
	  {
	  	CtrlEnabled('REF_SOL',true);
	  	CtrlEnabled('SEG_SOLIC',false);
	  }else
	  {
	  	CtrlEnabled('REF_SOL',false); 
	  	CtrlEnabled('SEG_SOLIC',false);
	  }
	 }else
	 	{                            
	 		CtrlEnabled('REF_SOL',true);   
	 		CtrlEnabled('SEG_SOLIC',true);
	 	}
}
 
function NEW_REQ()
{
	var a = "&lt;DATOS oi_personal_emp=\"" + Ctrl('oi_personal_emp').GetXValue() +
	"\" f_solicitud=\"" + Ctrl('f_solicitud').GetXValue() +	
	"\" d_area=\"" + Ctrl('d_area').GetXValue() + " - " + Ctrl('d_puesto').GetXValue() +
	"\" c_estado=\"" + Ctrl('c_estado').GetXValue()+
	"\" f_hoy=\"" + Ctrl('f_hoy').GetXValue()+
	"\" f_incorporacion=\"" + Ctrl('f_incorporacion').GetXValue()+
	"\" e_edad_desde=\"" + Ctrl('e_edad_desde').GetXValue()+
	"\" e_edad_hasta=\"" + Ctrl('e_edad_hasta').GetXValue()+
	"\" oi_estado_civil=\"" + Ctrl('oi_estado_civil').GetXValue() +
	"\" c_motivo=\"" + Ctrl('c_motivo').GetXValue()+
	"\" c_mod_contrato=\""  + Ctrl('c_mod_contrato').GetXValue()+
	"\" c_solicitud=\"SOL_"  + Ctrl('c_solicitud').GetXValue()+
	"\" o_solicitud=\"" + Ctrl('o_solicitud').GetXValue()+"\" /&gt;" ;

	openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.flow","new_req", a, new ObjtectResult(),"L");
}

function ObjtectResult()
{        
	this.processResult = function(xmlin)
											{
											}
}
	</form:Scripts>
</form:Form>
