<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="INTERNO" name="filtro" doc="source">
	<form:Title>
		<form:Label visible="INTERNO" style="S3 LCol_w" label="Reclutamiento Interno" name="lblTitulo"/>
		<form:Label name="lblTitulo1" visible="EXTERNO" style="S3 LCol_w" label="Reclutamiento Externo"/>
	</form:Title>
	<form:Center height="70%" width="100%">
		<form:Blank name="blanco2"/>
		<form:Columns height="50px" width="50%" name="cols11">
			<form:Column height="100%" width="100%" name="col" separation="2" align="center" valign="top">
				<form:ComboBox enabled="INTERNO|EXTERNO" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox where1="SEL02_REQ.ca_estado != 'C'" nvalue="#source:@oi_req" name="oi_req" enabled="INTERNO|EXTERNO" prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="1">
					<form:Event action="setReferencia" runat="client" name="onChange"/>
				</form:ComboBox>
				<form:Hidden nvalue="#source:@oi_referencia" name="oi_referencia"/>
			</form:Column>
		</form:Columns>
		<form:Columns height="200px" width="85%" name="FiltrosPondes">
			<form:Column height="100%" width="50%" valign="top" align="left" separation="2" name="Filtros">
				<form:Container border="1" height="100%" width="100%" rheight="40" label="Filtros" name="Filtros" borderwidth="2" rwidth="40">
					<form:Blank name="blanco1"/>
					<form:CheckBox label="Ignorar Filtros por &#193;rea de Conocimiento?" required="0" nvalue="#source:@ignorarAreas" name="ignorarAreas"/>
					<form:CheckBox required="0" nvalue="#source:@ignorarCursos" name="ignorarCursos" label="Ignorar Filtros por Curso?"/>
					<form:CheckBox required="0" nvalue="#source:@ignorarEstudios" name="ignorarEstudios" label="Ignorar Filtros por Estudios?"/>
					<form:CheckBox required="0" nvalue="#source:@ignorarExperiencia" name="ignorarExperiencia" label="Ignorar Filtros por Experiencia?"/>
					<form:CheckBox required="0" nvalue="#source:@ignorarIdiomas" name="ignorarIdiomas" label="Ignorar Filtros por Idioma?"/>
					<form:CheckBox required="0" nvalue="#source:@ignorarReferencia" name="ignorarReferencia" label="Ignorar Filtros de la Referencia?"/>
					<form:CheckBox nvalue="#source:@postulados" label="Solo postulados a la referencia" name="postulados" required="0"/>
				</form:Container>
			</form:Column>
			<form:Column separation="2" width="50%" height="100%" valign="top" align="right" name="Ponderacio">
				<form:Container border="1" height="100%" width="100%" rheight="40" rwidth="40" borderwidth="2" label="Ponderaciones" name="Ponderacion">
					<form:Blank name="blanco3"/>
					<form:Blank name="blanco4"/>
					<form:NumberBox min="0" precision="3" nvalue="#SOURCE:@pondPostulacion" name="pondPostulacion" label="Por Postulacion"/>
					<form:NumberBox precision="3" label="Por Inscripci&#243;n a la Referencia" nvalue="#source:@pondInscripcion" name="pondInscripcion" min="0"/>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="botones">
			<form:Row name="filaBotones">
				<form:Button name="btnEjecutar1" startvalidate="1" visible="INTERNO" descrip="Ejecutar la consulta" note="" img="play" enabled="" label="Ejecutar">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button name="btnEjecutar2" startvalidate="1" visible="EXTERNO" descrip="Ejecutar la consulta" img="play" enabled="" label="Ejecutar">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button descrip="vuelve al menu principal" note="" img="back" label="Volver" name="btnVolver" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function CONSTRUCCION()
{
	alert("En Construccion")
}     

function setReferencia()
{
	//Seteo la referencia a traves del oi_req
	var nSQL = GetProxy().SQLService();   
	var xml = nSQL.GetOBJ(Ctrl("main").getResource("qry_referencia"), "&lt;PARAM oi_req=\""+Ctrl("oi_req").GetXValue()+"\" /&gt;");	
	Ctrl("oi_referencia").SetXValue(xml.oi_referencia); 
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_req=&quot;447&quot; /&gt;" name="qry_referencia">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_ref" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_ref" doc="PARAM">
				<qry:xquery>
					for $r in SQL('  
			SELECT
				SEL02_REFERENCIAS.oi_referencia
			FROM
				SEL02_REFERENCIAS
			WHERE
				SEL02_REFERENCIAS.oi_req = {#PARAM:@oi_req}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
