<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="X2C" name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.CantidadContratados.guia.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.CantidadContratados.flow"/>
	<flow:main doc="SOURCE">
		<flow:action name="X2C">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="X2C"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS">
			<ROW PARENTID="" CODE="" TEXT="">
				<ROWS/>
			</ROW>
		</doc:define>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute name="id" value="#SOURCE:helper-mess/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="value" value="#SOURCE:helper-mess/@ID" type="Nomad.NSystem.Int"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in table('select count (oi_reclutado) cant
			from sel13_reclutados
			where c_estado = \'C\'
			and oi_referencia = {%= #SOURCE:helper-mess/@ID %} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="code" value="$r/@cant" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
