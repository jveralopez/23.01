<form:Form xmlns:form="nomad_engine.form" extends="nomad.childGrid.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN">
	<form:Help>
		<form:Help-title text="Examenes a Realizar por Referencia" name="TITLE"/>
		<form:Help-descr text="Seran los examenes que se le realizaran a cada Reclutado para una referencia dada." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Examenes a Realizar por Referencia" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Examenes a Realizar por Referencia" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Examenes a Realizar por Referencia" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Examenes a Realizar por Referencia" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsREF_EXAMEN">
			<form:Link allowimg="1" policy="NucleusRH/Base/Gestion_de_Postulantes/Requerimientos/REF_RES_EXA/READ" visible="EDIT|SHOW|DELETE" descrip="Sirve para Cargar los resultados posibles  de los examenes definidos por referencia." label="Resultados de Examenes por Referencia" name="REF_RES_EXA">
				<form:Event policy="NucleusRH/Base/Gestion_de_Postulantes/Requerimientos/REF_RES_EXA/EDIT" action="CALL:REF_RES_EXA" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label=" " name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_examen">
					<form:ComboBox queryname1="NucleusRH.Base.Gestion_de_Postulantes.Examenes.EXAMEN.INFO" xsize="30" mode="QRY" required="1" enabled="NEW|EDIT" label="Tipo Examen - Examen" nvalue="#source:oi_examen/@value" name="oi_examen"/>
				</form:GColumn>
				<form:GColumn name="gcole_orden">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Orden" nvalue="#source:@e_orden" name="e_orden"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Gestion_de_Postulantes/Requerimientos/REF_EXAMEN/NEW" visible="EDIT|LIST_EDIT" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Gestion_de_Postulantes/Requerimientos/REF_EXAMEN/DELETE" visible="EDIT|LIST_EDIT" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
