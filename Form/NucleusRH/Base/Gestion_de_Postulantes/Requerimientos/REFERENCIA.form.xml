function LoadRef()
{
	if (Ctrl('main').GetMode() == "EDIT")
	{           
		CtrlEnabled('DELETE', false);
		if (Ctrl('ca_estado').GetXValue() == "A" )
		{
			CtrlEnabled('DELETE',true);
		}
		
		if (Ctrl('ca_estado').GetXValue() == "F" || Ctrl('ca_estado').GetXValue() == "N")
		{
		  DeshabilitarCenter();
		  DeshabilitarRigth();
		} 
		else
		{
			HabilitarCenter();		
			HabilitarRight();
		}                            
	}
		
	if (Ctrl('main').GetMode() == "NEW")
	{           
		SetPuesto();
	}            
	
	if (Ctrl('main').GetMode() == "SHOW")
	{
		CtrlEnabled("INICIAR", false);
		CtrlEnabled("ABORTAR", false);
		if(Ctrl("ca_estado").GetXValue() == "A")
		{
			CtrlEnabled("INICIAR", true);
			CtrlEnabled("ABORTAR", true);
		}
		
		if(Ctrl("ca_estado").GetXValue() == "I")
		{
			CtrlEnabled("INICIAR", false);
			CtrlEnabled("ABORTAR", true);
		}	
		
		if(Ctrl("ca_estado").GetXValue() == "N")
		{
			CtrlEnabled("INICIAR", true);
			CtrlEnabled("ABORTAR", false);
		}	  		
	}
	
	if (Ctrl('main').GetMode() == "LIST")
	{
		CtrlEnabled("INICIAR", false);
		CtrlEnabled("ABORTAR", false);
		ChangeSelect();
		
	}	
}

function ChangeSelect()
{		
	if(Ctrl("LIST").GetSelectAttrValue("ca_estado")=="A")		
	{
		CtrlEnabled("INICIAR", true);
		CtrlEnabled("ABORTAR", true);
	}	
	
	if(Ctrl("LIST").GetSelectAttrValue("ca_estado")=="I")
	{
		CtrlEnabled("INICIAR", false);
		CtrlEnabled("ABORTAR", true);
	}	
	
	if(Ctrl("LIST").GetSelectAttrValue("ca_estado")=="N")		
	{
		CtrlEnabled("INICIAR", true);
		CtrlEnabled("ABORTAR", false);
	}	  		
}
	
function SetPuesto()
{
	Ctrl('oi_puesto').SetWhere("SEL10_PUESTOS.oi_puesto IN (SELECT ORG04_PUESTOS.oi_puesto FROM ORG04_PUESTOS WHERE ORG04_PUESTOS.oi_empresa = " +  Ctrl('oi_empresa').GetCValue() + ")");		
}


