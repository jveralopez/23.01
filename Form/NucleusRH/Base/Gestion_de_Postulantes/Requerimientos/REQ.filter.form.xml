<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ">
	<form:Center>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl1"/>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="columnas">
			<form:Column name="col1">
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox nvalue="#FILTERDATA:@oi_req" prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Requerimiento" xsize="40" mode="QRY" required="0" name="oi_req"/>
				<form:ComboBox nvalue="#FILTERDATA:@ca_estado" xsize="40" mode="OPT" required="0" label="Estado" name="ca_estado">
					<options>
						<option text="Abierto" value="A"/>
						<option text="Inicializado" value="I"/>
						<option text="Cerrado" value="C"/>
						<option text="Anulada" value="N"/>
					</options>
				</form:ComboBox>
				<form:FKInput label="Unidad Organizativa Solicitante" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura" length="30" xsize="15" required="0" cache="no">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:ComboBox label="Empresa - Legajo Solicitante" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="40" mode="QRY" required="0" nvalue="#FILTERDATA:@oi_personal_emp" name="oi_personal_emp"/>
			</form:Column>
		</form:Columns>
	</form:Center>
</form:Form>
