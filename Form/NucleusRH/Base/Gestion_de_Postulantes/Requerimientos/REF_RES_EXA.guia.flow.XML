<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.simple.guia.flow" name="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:log text-path="#helper-mess:" text="pphelper"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.guia.autoform"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_ref_res_exa ID, SEL08_RESULTADOS.c_resultado CODE, SEL08_RESULTADOS.d_resultado TEXT, oi_ref_examen PID FROM SEL02_REF_RES_EXA, SEL08_RESULTADOS WHERE oi_ref_res_exa={#SOURCE:helper-mess/@ID} AND SEL02_REF_RES_EXA.oi_resultado=SEL08_RESULTADOS.oi_resultado')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@PID" name="PID"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_ref_res_exa ID, SEL08_RESULTADOS.c_resultado CODE, SEL08_RESULTADOS.d_resultado TEXT
				FROM SEL02_REF_RES_EXA, SEL08_RESULTADOS		
				WHERE SEL02_REF_RES_EXA.oi_ref_examen = {#INDOC:@oi_ref_examen} 		  
				AND SEL08_RESULTADOS.c_resultado={#SOURCE:@code} 		
				AND SEL02_REF_RES_EXA.oi_resultado=SEL08_RESULTADOS.oi_resultado')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_ref_res_exa ID, SEL08_RESULTADOS.c_resultado CODE, SEL08_RESULTADOS.d_resultado TEXT
			FROM SEL02_REF_RES_EXA, SEL08_RESULTADOS 
			WHERE SEL02_REF_RES_EXA.oi_ref_examen = {#INDOC:@oi_ref_examen} 
			AND SEL02_REF_RES_EXA.oi_resultado=SEL08_RESULTADOS.oi_resultado')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="Nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.guia.autoform"/>
</flow:flow>
