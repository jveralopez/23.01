<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="EDIT" doc="source" name="Seleccion">
	<form:Title>
		<form:RowAligner name="oooooojjjjj">
			<form:Row name="ooo">
				<form:Label label="Personas posibles para Selecci&#243;n" nowrap="1" visible="POSIBLES" name="lblTitulo" style="S3 LCol_w"/>
				<form:Label nowrap="1" label="Personas Seleccionadas" style="S3 LCol_w" name="lblTitulo1" visible="SELECCION"/>
				<form:Label nowrap="1" label="Filtro de Selecci&#243;n de Personal" style="S3 LCol_w" name="lblTitulo2" visible="FILTRO"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="F"/>
		<form:Columns name="cols">
			<form:Column name="col1" separation="2" align="center" valign="top">
				<form:ComboBox nvalue="#FILTERDATA:@oi_empresa" enabled="FILTRO" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" name="oi_empresa"/>
				<form:ComboBox nvalue="#FILTERDATA:@oi_req" enabled="FILTRO" prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="1" name="oi_req">
					<form:Event action="setReferencia" runat="client" name="onChange"/>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
		<form:Columns height="70%" width="100%" name="columns2">
			<form:Column width="100%" name="col1">
				<form:ListView arr-control="listarr" label="Personas" visible="POSIBLES|SELECCION" width="70%" rows="15" docname="RS" name="list1">
					<form:LVColumns>
						<form:LVColumn label="C&#243;digo" attrname="c_reclutado" name="c_reclutado" sorteable="1" width="5%" type="string" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutamiento/ADMINISTRAR/form/n_merito"/>
						<form:LVColumn label="Reclutado" attrname="d_reclutado" name="d_reclutado" sorteable="1" width="5%" type="string" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutamiento/ADMINISTRAR/form/n_merito"/>
						<form:LVColumn attrname="cumpleEntrev" name="cumpleEntrev" label="Complet&#243; Entrevistas" align="center" additional="Listas/tick.gif|Listas/cross.gif" sorteable="1" width="40px" type="bool"/>
						<form:LVColumn attrname="cumpleExa" name="cumpleExa" label="Complet&#243; Ex&#225;menes" align="center" additional="Listas/tick.gif|Listas/cross.gif" sorteable="1" width="40px" type="bool"/>
					</form:LVColumns>
					<form:SButtons>
						<form:SButton label="Desmarcar los Elementos" img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
							<form:Event action="unmark_list" name="OnClick" runat="client"/>
						</form:SButton>
						<form:SButton label="Marcar los Elementos" img="table_check" descrip="Marcar los Elementos" name="Mark">
							<form:Event action="mark_list" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:ListView>
				<form:HiddenArr nvalue="#ELEGIDOS:RECLUTADOS" proto="&lt;ROW/&gt;" name="listarr">
					<form:Attr name="id"/>
				</form:HiddenArr>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#source:@oi_referencia" name="oi_referencia"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="BOTO">
			<form:Row name="R">
				<form:Button img="ok" visible="FILTRO" label="Filtrar" note="" descrip="Ejecutar la consulta" startvalidate="1" name="btnEjecutar">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="play" label="Seleccionar" visible="POSIBLES" name="FILTRAR" descrip="Selecciona a las Personas" startvalidate="1" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE"/>
					</form:Policies>
					<form:Event action="Seleccionar" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="POSIBLES|SELECCION" img="SEARCH" label="Ver Reclutado" name="btnreclutado">
					<form:Event action="VerReclutado" name="onclick" runat="client"/>
				</form:Button>
				<form:Button label="Ex&#225;menes y Entrevistas" visible="POSIBLES|SELECCION" img="SEARCH" name="btnestado">
					<form:Event action="VerEstado" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="" name="btnVolver" label="Volver" img="back" note="" descrip="vuelve al menu principal">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ObjtectResult()
{
	this.processResult= function(xmlin){}
}    

function VerReclutado()
{   
	openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Reclutados.flow","ver_reclutado","&lt;FILTRO id=\""+Ctrl('list1').GetSelectAttrValue('id')+"\" /&gt;",new ObjtectResult(),"L");
}  

function VerEstado()
{   
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
 
 	open("../../../ReportViewer.aspx?ut="+GetProxy().UserToken()+String.fromCharCode(38)+"file=NucleusRH.Base.Gestion_de_Postulantes.EstExaEntrev.rpt"+String.fromCharCode(38)+"id="+Ctrl('list1').GetSelectAttrValue('id'), '', 'channelmode=no,directories=no,fullscreen=no,location=center,menubar=no,resizable=yes,scrollbars=yes,status=no,titlebar=no,toolbar=no,left=0,top=0,width='+(screen.width-400)+',height='+(screen.height-300)); 
}  

function unmark_list()
{
	Ctrl("listarr").DelAllRow();
	Ctrl("list1").Refresh();
}

function mark_list()
{
	Ctrl("listarr").DelAllRow();     
	for (var t=0; t&lt;Ctrl("list1").RowsCount(); t++)
		Ctrl("listarr").AddRow().SetAttr("id", Ctrl("list1").shownRegs[t].attributes.getNamedItem("id").value);
	
	Ctrl("list1").Refresh();
}

function onLoad()
{   
	if(Ctrl('main').GetMode()=='POSIBLES')
	{
		Ctrl("listarr").DelAllRow();
		Ctrl("list1").Refresh();
	}	
}

function Seleccionar() 
{    
	if(Ctrl("listarr").CountRow() == 0) 
	{
		alert("Debe seleccionar al menos un Reclutado");
		return false;
	}             
	else
	{
		//SendToServer();
		Ctrl("main").DoEvent("FILTER");
	}	
}      

function setReferencia()
{
	//Seteo la referencia a traves del oi_req
	var nSQL = GetProxy().SQLService();   
	var xml = nSQL.GetOBJ(Ctrl("main").getResource("qry_referencia"), "&lt;PARAM oi_req=\""+Ctrl("oi_req").GetXValue()+"\" /&gt;");	
	Ctrl("oi_referencia").SetXValue(xml.oi_referencia); 
}
	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_req=&quot;447&quot; /&gt;" name="qry_referencia">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_ref" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_ref" doc="PARAM">
				<qry:xquery>
					for $r in SQL('  
			SELECT
				SEL02_REFERENCIAS.oi_referencia
			FROM
				SEL02_REFERENCIAS
			WHERE
				SEL02_REFERENCIAS.oi_req = {#PARAM:@oi_req}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
