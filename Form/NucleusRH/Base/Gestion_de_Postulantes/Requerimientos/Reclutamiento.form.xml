<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="Reclutamiento" doc="source" default_mode="EDIT">
	<form:Scripts>
		function ObjtectResult()
{        
	this.processResult = function(xmlin){};
}

function CALL_LEGAJO()
{
	np = new NomadProxy("", ut);
	nSQL = np.SQLService();
	PARAM = "&lt;DATOS oi_req=\""+Ctrl('grilla').SelectedRowID()+"\" /&gt;";		
	XMLSearch = nSQL.Get(Ctrl("main").getResource("QRY_REC"), PARAM); 
	pp = new nomadDOM(XMLSearch);
	/*alert("PARAM" + PARAM);       
	alert("XMLSEARCH" + XMLSearch);       
	alert("REC"+ Ctrl('grilla').SelectedRowID());
	alert("PER"+ pp.per);
	alert("POS"+ pp.pos);*/
	 
	if (pp.per==pp.undefined) 
	{
		openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.flow","proceso","&lt;DATOS oi_postulante=\"" + pp.pos + "\" /&gt;",new ObjtectResult(),"L");  
		//alert("postulante");
	}
	else
	{                    
		openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPersonal.flow","proceso","&lt;DATOS oi_personal_emp=\"" + pp.per + "\" /&gt;",new ObjtectResult(),"L");     
		//alert("personal");
	}
}


	</form:Scripts>
	<form:Title>
		<form:RowAligner name="oooooojjjjj">
			<form:Row name="ooo">
				<form:Label visible="EDIT|FILTRO" label="Personas Rankeadas" style="S3 LCol_w" name="lblTitulo"/>
				<form:Label visible="RECLUTADOS" label="Personas Reclutadas" name="lblTitulo1" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Bottom>
		<form:RowAligner name="BOTO">
			<form:Row name="R">
				<form:Button visible="EDIT|FILTRO" name="btnEjecutar" startvalidate="1" descrip="Ejecutar la consulta" note="" img="play" label="Reclutar">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button descrip="vuelve al menu principal" note="" img="back" label="Volver" name="btnVolver" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Center>
		<form:Blank name="F"/>
		<form:Columns name="cols">
			<form:Column name="col">
				<form:ComboBox visible="EDIT" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.EMP_REQ_INFO" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa - Referencia" xsize="40" mode="QRY" required="1" enabled="0" nvalue="#source:@oi_referencia" name="oi_referencia"/>
				<form:ComboBox visible="FILTRO" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.EMP_REQ_INFO" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa - Referencia" xsize="40" mode="QRY" required="1" nvalue="#source:@oi_referencia" name="oi_referencia"/>
				<form:ComboBox visible="RECLUTADOS" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.EMP_REQ_INFO" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" label="Empresa - Referencia" xsize="40" mode="QRY" required="1" enabled="0" nvalue="#source:@oi_referencia" name="oi_referencia"/>
				<form:Grid name="grilla" allownew="0" allowdel="0" allowhelper="0" allowdelall="0" paging="1" idvalue="#source:@oi_reclutado" doc="source" rows="12" nvalue="#source:ROWS">
					<form:GColumns>
						<form:GColumn visible="EDIT|FILTRO" allow_order="0" name="check">
							<form:CheckBox name="elegir" nvalue="#source:@elegir" required="0">
								<form:SButtons>
									<form:SButton img="receipt" descrip="Mostrar Legajo" name="Legajo">
										<form:Event action="CALL_LEGAJO" runat="client" name="onclick"/>
									</form:SButton>
								</form:SButtons>
							</form:CheckBox>
						</form:GColumn>
						<form:GColumn name="d" allow_order="1">
							<form:FKInput enabled="0" label="Personas" length="0" name="oi_reclutado" nvalue="#source:@oi_reclutado" required="0">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO.Show.guia.flow">
									<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="0">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn visible="EDIT|FILTRO" name="o" allow_order="1">
							<form:NumberBox name="n_ranking" nvalue="#source:@n_ranking" label="Ranking" precision="3" enabled="0"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Resources>
		<form:Resource declare="&lt;DATOS oi_req=&quot;152&quot;/&gt;" name="QRY_REC">
			<qry:main doc="SOURCE" name="">
				<qry:element name="DATOS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="qry_reclutado"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="qry_reclutado">
				<qry:xquery>
					for $r in sql('
	select 
		S.oi_personal_emp,
		S.oi_postulante		

	from 
		sel13_reclutados AS S
	where 
		S.oi_reclutado=  {#SOURCE:@oi_req}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_personal_emp" name="per"/>
					<qry:attribute value="$r/@oi_postulante" name="pos"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
