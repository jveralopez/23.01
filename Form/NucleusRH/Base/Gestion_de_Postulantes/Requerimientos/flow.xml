<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.flow" extends="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.autoflow">
	<flow:info label="NucleusRh.Base.Gestion_de_Postulantes.Requerimientos.flow"/>
	<flow:declare>
		<qry:define declare="&lt;DATOS oi_req=&quot;551&quot; oi_referencia=&quot;413&quot;&gt;&#13;&#10;&#9;&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&#9;&lt;ROW n_ranking=&quot;0&quot; elegir=&quot;1&quot; oi_reclutado=&quot;3464&quot; /&gt;&#13;&#10;&#9;&#9;&lt;ROW n_ranking=&quot;0&quot; elegir=&quot;0&quot; oi_reclutado=&quot;3465&quot; /&gt;&#13;&#10;&#9;&lt;/ROWS&gt;&#13;&#10;&lt;/DATOS&gt;" name="RECLUTADOS">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_referencia" value="#SOURCE:DATOS/@oi_referencia" type="Nomad.NSystem.Int"/>
					<qry:insert-select doc-path="#SOURCE:DATOS/ROWS" name="RS0"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:DATOS" name="RS1"/>
					</qry:element>
					<qry:insert-select doc-path="#SOURCE:DATOS" name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS0" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cant" value="iif($r/@elegir='1',number(@cant)+1,@cant)"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
					SEL13_RECLUTADOS.oi_reclutado,
					SEL13_RECLUTADOS.n_ranking
				FROM
					SEL13_RECLUTADOS
				WHERE
					SEL13_RECLUTADOS.oi_referencia=  {#SOURCE:@oi_referencia} 
					AND SEL13_RECLUTADOS.c_estado = \'R\' 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_reclutado" value="$r/@oi_reclutado"/>
						<qry:attribute name="elegir" value="'0'"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT COUNT(SEL13_RECLUTADOS.oi_reclutado) as cant					
				FROM
					SEL13_RECLUTADOS
				WHERE
					SEL13_RECLUTADOS.oi_referencia=  {#SOURCE:@oi_referencia} 
					AND SEL13_RECLUTADOS.c_estado = \'R\' 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cant" value="' ' + $r/@cant"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_personal_emp=&quot;&quot; /&gt;" name="QRY_EMPRESA">
			<qry:main doc="SOURCE">
				<qry:element name="EMP">
					<qry:insert-select name="qry_empresa" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_empresa" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_empresa 
				FROM 
					PER02_PERSONAL_EMP
				WHERE 
					PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@oi_empresa"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;datos &#13;&#10;&#9;oi_empresa=&quot;1&quot; &#13;&#10;&#9;ca_estado=&quot;&quot; &#13;&#10;&#9;oi_estructura=&quot;&quot; &#13;&#10;&#9;oi_personal_emp=&quot;&quot; &#13;&#10;&#9;oi_req=&quot;&quot;&#13;&#10;&#9;c_orden=&quot;&quot; &#13;&#10;&#9;c_tipo_orden=&quot;&quot; &#13;&#10;/&gt;" name="FILTER">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT
					t0.oi_req,
					t0.oi_empresa,
					t0.ca_estado,
					t0.oi_personal_emp,
					t0.oi_estructura,
					t0.f_req,
					t0.c_req,
					t0.d_req,
					o03.c_empresa
				FROM
					SEL02_REQ as t0, 
					ORG03_EMPRESAS as o03
				JOIN 
					t0.oi_empresa INNER o03.oi_empresa
				WHERE
					{%? (#PARAM:datos/@oi_empresa!='') {% t0.oi_empresa = {#PARAM:datos/@oi_empresa} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@ca_estado!='') {% t0.ca_estado = {#PARAM:datos/@ca_estado} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_personal_emp!='') {%t0.oi_personal_emp = {%=#PARAM:datos/@oi_personal_emp%} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_estructura!='') {% t0.oi_estructura = {#PARAM:datos/@oi_estructura} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_req!='') {% t0.oi_req = {#PARAM:datos/@oi_req} %} {% 1 = 1 %} %}
			    
				ORDER BY 
					{%? (#PARAM:datos/@c_orden!='') {% {%=#PARAM:datos/@c_orden%} {%? (#PARAM:datos/@c_tipo_orden!='') {% {%=#PARAM:datos/@c_tipo_orden%}, %} {% ASC, %}  %}	%} {% %} %}
					oi_req	ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_req"/>
						<qry:attribute value="$r/@oi_empresa" name="oi_empresa"/>
						<qry:attribute value="$r/@ca_estado" name="ca_estado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;datos &#13;&#10;&#9;oi_empresa=&quot;1&quot; &#13;&#10;&#9;ca_estado=&quot;&quot; &#13;&#10;&#9;oi_estructura=&quot;&quot; &#13;&#10;&#9;oi_personal_emp=&quot;&quot; &#13;&#10;&#9;oi_req=&quot;&quot;&#13;&#10;&#9;c_orden=&quot;&quot; &#13;&#10;&#9;c_tipo_orden=&quot;&quot; &#13;&#10;/&gt;" name="LIST">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
					SELECT
						t0.oi_req as oi_req,
						t0.c_req as c_req,
						t0.d_req as d_req,
						t0.ca_estado as ca_estado,
						t0.f_req as f_req,
						t0.f_alta as f_alta,
						t0.f_anulacion as f_anulacion,
						t0.c_req as CODE,
						t0.d_req as TEXT,
						t0.oi_empresa as oi_empresa
					FROM
						SEL02_REQ as t0, 
						ORG03_EMPRESAS as o03
					JOIN 
						t0.oi_empresa INNER o03.oi_empresa 
					WHERE
						{%? (#PARAM:datos/@oi_empresa!='') {% t0.oi_empresa = {#PARAM:datos/@oi_empresa} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@ca_estado!='') {% t0.ca_estado = {#PARAM:datos/@ca_estado} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_personal_emp!='') {%t0.oi_personal_emp = {%=#PARAM:datos/@oi_personal_emp%} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_estructura!='') {% t0.oi_estructura = {#PARAM:datos/@oi_estructura} %} {% 1 = 1 %} %}
					AND {%? (#PARAM:datos/@oi_req!='') {% t0.oi_req = {#PARAM:datos/@oi_req} %} {% 1 = 1 %} %}
					ORDER BY 
						{%? (#PARAM:datos/@c_orden!='') {% {%=#PARAM:datos/@c_orden%} {%? (#PARAM:datos/@c_tipo_orden!='') {% {%=#PARAM:datos/@c_tipo_orden%}, %} {% ASC, %}  %}	%} {% %} %}
						oi_req	ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_req"/>
						<qry:attribute name="c_req" value="$r/@c_req"/>
						<qry:attribute name="d_req" value="$r/@d_req"/>
						<qry:attribute name="ca_estado" value="$r/@ca_estado"/>
						<qry:attribute name="f_req" value="$r/@f_req"/>
						<qry:attribute name="f_alta" value="$r/@f_alta"/>
						<qry:attribute name="f_anulacion" value="$r/@f_anulacion"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="RECLUTAMIENTO">
			<DATOS oi_referencia="" pondPostulacion="0" pondInscripcion="0" ignorarCursos="0" ignorarEstudios="0" ignorarIdiomas="0" ignorarExperiencia="0" ignorarReferencia="0">
				<ROWS/>
			</DATOS>
		</doc:define>
		<doc:define name="RECSOURCE"/>
		<doc:define name="SELECCION">
			<DATOS oi_referencia="" mensaje="">
				<RECLUTADOS/>
			</DATOS>
		</doc:define>
		<doc:define name="ELEGIDOS">
			<DATOS oi_referencia="" mensaje="">
				<RECLUTADOS/>
			</DATOS>
		</doc:define>
		<doc:define name="EMP"/>
		<doc:define name="FILTERDATA">
			<datos/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_referencia=&quot;1&quot; oi_req=&quot;50&quot; oi_empresa=&quot;1&quot; Mensaje=&quot;&quot;&gt;&#13;&#10; &#13;&#10;&lt;/DATOS&gt;&#13;&#10;" name="POSIBLES">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="RS1"/>
				</qry:element>
				<qry:insert-select doc-path="#SOURCE:DATOS" name="RS2"/>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
					SEL13_RECLUTADOS.oi_reclutado,
					SEL13_RECLUTADOS.c_reclutado,
					SEL13_RECLUTADOS.d_reclutado,
					SEL13_RECLUTADOS.f_reclutamiento
				FROM
					SEL13_RECLUTADOS
				WHERE
					SEL13_RECLUTADOS.oi_referencia=  {#SOURCE:@oi_referencia} 
					AND SEL13_RECLUTADOS.c_estado = \'R\' 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_reclutado"/>
						<qry:attribute name="oi_reclutado" value="$r/@oi_reclutado"/>
						<qry:attribute name="c_reclutado" value="$r/@c_reclutado"/>
						<qry:attribute name="d_reclutado" value="$r/@d_reclutado"/>
						<qry:attribute name="f_reclutamiento" value="format_date($r/@f_reclutamiento, 'dd/mm/yyyy')"/>
						<qry:attribute name="elegir" value="'0'"/>
						<qry:insert-select name="qry_count_exa" doc-path="$r"/>
						<qry:insert-select name="qry_count_entrev" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT COUNT(SEL13_RECLUTADOS.oi_reclutado) as cant					
				FROM
					SEL13_RECLUTADOS
				WHERE
					SEL13_RECLUTADOS.oi_referencia=  {#SOURCE:@oi_referencia} 
					AND SEL13_RECLUTADOS.c_estado = \'R\' 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cant" value="$r/@cant"/>
					<qry:insert-select name="qry_cargado_0" doc-path="$r/.[@cantExa=0]"/>
					<qry:insert-select name="qry_cargado_1" doc-path="$r/.[@cantExa!=0]"/>
					<qry:insert-select name="qry_cargado_2" doc-path="$r/.[@cantEntrev=0]"/>
					<qry:insert-select name="qry_cargado_3" doc-path="$r/.[@cantEntrev!=0]"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_count_exa" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT 
				COUNT(SEL13_EXA_REC.oi_reclutado) as cantExa					
			FROM          
				SEL13_EXA_REC,
				SEL13_RECLUTADOS
			JOIN
				SEL13_RECLUTADOS.oi_reclutado LEFT OUTER SEL13_EXA_REC.oi_reclutado
			WHERE
				SEL13_RECLUTADOS.oi_reclutado = {#SOURCE:@oi_reclutado} 
				AND SEL13_EXA_REC.c_estado = \'RE\'
				AND SEL13_EXA_REC.oi_reclutado NOT IN
					(SELECT SEL13_EXA_REC.oi_reclutado
					FROM SEL13_EXA_REC
					WHERE SEL13_EXA_REC.c_estado != \'RE\') 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cumpleExa" value="iif($r/@cantExa=0,'0','1')"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_count_entrev" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT 
				COUNT(SEL13_ENTREV_REC.oi_reclutado) as cantEntrev					
			FROM          
				SEL13_ENTREV_REC,
				SEL13_RECLUTADOS
			JOIN
				SEL13_RECLUTADOS.oi_reclutado LEFT OUTER SEL13_ENTREV_REC.oi_reclutado
			WHERE
				SEL13_RECLUTADOS.oi_reclutado = {#SOURCE:@oi_reclutado} 
				AND SEL13_ENTREV_REC.c_estado = \'RE\'  
				AND SEL13_ENTREV_REC.oi_reclutado NOT IN
					(SELECT SEL13_ENTREV_REC.oi_reclutado
					FROM SEL13_ENTREV_REC
					WHERE SEL13_ENTREV_REC.c_estado != \'RE\')
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cumpleEntrev" value="iif($r/@cantEntrev=0,'0','1')"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_cargado_0">
				<qry:out>
					<qry:attribute name="title" value="'No Completo Examenes'"/>
					<qry:attribute name="img" value="'Listas/WF.gif'"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_cargado_1">
				<qry:out>
					<qry:attribute name="title" value="'Completo Examenes'"/>
					<qry:attribute name="img" value="'Listas/WF_END.gif'"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_cargado_2">
				<qry:out>
					<qry:attribute name="title" value="'Completo Entrevistas'"/>
					<qry:attribute name="img" value="'Listas/WF_END.gif'"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_cargado_3">
				<qry:out>
					<qry:attribute name="title" value="'Completo Entrevistas'"/>
					<qry:attribute name="img" value="'Listas/WF_END.gif'"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_referencia=&quot;412&quot; pondPostulacion=&quot;0&quot; pondInscripcion=&quot;0&quot; ignorarCursos=&quot;1&quot; ignorarEstudios=&quot;1&quot; ignorarIdiomas=&quot;1&quot; ignorarExperiencia=&quot;1&quot; ignorarReferencia=&quot;1&quot; oi_empresa=&quot;10&quot; ignorarAreas=&quot;1&quot; postulados=&quot;&quot; oi_req=&quot;550&quot;&gt;&lt;ROWS /&gt;&lt;/DATOS&gt;" name="RANKEADOS">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute name="oi_referencia" value="#SOURCE:DATOS/@oi_referencia"/>
					<qry:attribute name="oi_req" value="#SOURCE:DATOS/@oi_req"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:DATOS" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
					S.oi_reclutado, 
					S.n_ranking 
				FROM
					SEL13_RECLUTADOS AS S
				WHERE
					S.c_estado = \'N\' 
					{%? (#SOURCE:@oi_referencia!='')	{% AND S.oi_referencia = {#SOURCE:@oi_referencia} %} {% %} %}
					
				ORDER BY
					n_ranking desc 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_reclutado" value="$r/@oi_reclutado" type="Nomad.NSystem.Int"/>
						<qry:attribute name="elegir" value="'0'" type="Nomad.NSystem.Int"/>
						<qry:attribute name="n_ranking" value="$r/@n_ranking" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="SOLIC">
			<SOLIC id="1"/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.filter.form"/>
		</flow:action>
		<flow:action name="initializeReclutamientoInterno">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.Reclutamiento.Filtro.form" mode="INTERNO" doc-path="#RECLUTAMIENTO:"/>
		</flow:action>
		<flow:action name="reclutamiento"/>
		<flow:action name="reclutamientoIni">
			<flow:open-form mode="FILTRO" doc-path="#RECLUTAMIENTO:" form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.Reclutamiento.form"/>
		</flow:action>
		<flow:action name="show-report">
			<flow:open-form doc-path="#RECLUTAMIENTO:" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.Reclutamiento.form"/>
		</flow:action>
		<flow:action name="seleccion">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTRO" form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.Seleccion.form"/>
		</flow:action>
		<flow:action name="initializeReclutamientoExterno">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.Reclutamiento.Filtro.form" mode="EXTERNO" doc-path="#RECLUTAMIENTO:"/>
		</flow:action>
		<flow:action name="new_req">
			<doc:new-object class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ" doc="NEWDDOROOT"/>
			<doc:load-qry output-doc="EMP" input-doc-path="#SOURCE:" qry="QRY_EMPRESA"/>
			<doc:set-attribute from-attr-path="#EMP:@id" to-attr-path="#NEWDDOROOT:oi_empresa/@value"/>
			<doc:set-attribute from-attr-path="#SOURCE:@c_solicitud" to-attr-path="#NEWDDOROOT:@c_req"/>
			<doc:set-attribute from-attr-path="#SOURCE:@d_area" to-attr-path="#NEWDDOROOT:@d_req"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#NEWDDOROOT:oi_personal_emp/@value"/>
			<doc:set-attribute from-attr-path="#SOURCE:@f_hoy" to-attr-path="#NEWDDOROOT:@f_req"/>
			<doc:set-attribute from-value="A" to-attr-path="#NEWDDOROOT:@ca_estado"/>
			<doc:new-object class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA" doc="NEWDDO"/>
			<doc:set-attribute from-attr-path="#SOURCE:@c_solicitud" to-attr-path="#NEWDDO:@c_referencia"/>
			<doc:set-attribute from-attr-path="#SOURCE:@d_area" to-attr-path="#NEWDDO:@d_referencia"/>
			<doc:set-attribute from-value="E" to-attr-path="#NEWDDO:@ca_estado"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#NEWDDO:oi_personal_emp/@value"/>
			<doc:set-attribute from-attr-path="#SOURCE:@f_incorporacion" to-attr-path="#NEWDDO:@f_incorp_aprox"/>
			<doc:set-attribute from-attr-path="#SOURCE:@e_edad_desde" to-attr-path="#NEWDDO:@e_edad_minima_req"/>
			<doc:set-attribute from-attr-path="#SOURCE:@e_edad_hasta" to-attr-path="#NEWDDO:@e_edad_maxima_req"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_estado_civil" to-attr-path="#NEWDDO:oi_estado_civil/@value"/>
			<doc:set-attribute from-attr-path="#SOURCE:@o_solicitud" to-attr-path="#NEWDDO:@o_referencia"/>
			<doc:add-object doc-path="#NEWDDO:" parent-doc-path="#NEWDDOROOT:REFERENCIAS"/>
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.form"/>
			<flow:log text-path="#SOURCE:" text="kkeuey"/>
