<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN.guia.autoflow" name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="PRELOAD"/>
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN.guia.autoform" parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_ref_examen ID, SEL07_EXAMENES.c_examen CODE, SEL07_EXAMENES.d_examen TEXT, oi_referencia PID FROM SEL02_REF_EXAMEN, SEL07_EXAMENES WHERE oi_ref_examen={#SOURCE:helper-mess/@ID} AND SEL02_REF_EXAMEN.oi_examen=SEL07_EXAMENES.oi_examen')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
