<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.filter.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.filter.autoform" doc="source">
	<form:Center>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl1"/>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="columnas">
			<form:Column name="col1">
				<form:ComboBox enabled="FILTER" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Grid proto="&lt;PUESTO /&gt;" nvalue="#source:PUESTOS" idvalue="#SOURCEGRILLA:@id" width="480px" name="grdPuestos" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.LM.guia.flow" action="HELP">
				<helper-mess oi_empresa="{oi_empresa.ReadXValue}">
					{grdPuestos.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput nvalue="#SOURCEGRILLA:@id" required="0" enabled="" xsize="15" length="30" label="Puesto" name="oi_puesto">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Organizacion.Puestos.PUESTO.EMPRESA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess oi_empresa="{oi_empresa.ReadXValue}" text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="bl4" width="100%" visible=""/>
		<form:Columns name="columnas2">
			<form:Column name="col2">
				<form:FKInput nvalue="#source:@oi_banda_sal" required="0" enabled="" xsize="15" length="30" label="Banda Salarial" name="oi_banda_sal">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Bandas_Salariales.BANDA_SAL.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_banda_sal.Text.1}" id="{oi_banda_sal.XVal}" code="{oi_banda_sal.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput label="Convenio - Categoria" required="0" enabled="" xsize="15" length="30" nvalue="#source:@oi_categoria" name="oi_categoria">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{oi_categoria.Text.1}" id="{oi_categoria.XVal}" code="{oi_categoria.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl5" width="100%" visible=""/>
		<form:Line name="line_1" width="60%"/>
		<form:Label label="Criterio de Ordenamiento" name="lbl2" align="center" style="M1 LCol_g" visible=""/>
		<form:Blank name="bl6" width="100%" visible=""/>
		<form:RowAligner name="RAcamposOrden" columns="2">
			<form:Row name="RC1O">
				<form:Combo name="ATRIB_ORDEN1" label="" note="" flow="NucleusRH.Base.Organizacion.Puestos.atribFiltro.enum" action="COMBO" nvalue="#source:@ATRIB_ORDEN1"/>
				<form:Combo name="ORDEN1" label="" note="AscendenteDecendente" flow="NucleusRH.Base.Orden.enum" action="COMBO" nvalue="#source:@ORDEN1"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" visible="0">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
