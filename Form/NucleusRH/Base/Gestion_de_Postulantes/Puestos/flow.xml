<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" name="PUESTOS" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Gestion_de_Postulantes.Puestos"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS/>
			</FILTRO>
		</doc:define>
		<doc:define name="QRY"/>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;&quot; ID=&quot;x&quot;&gt;&lt;PUESTOS&gt;&lt;PUESTO id=&quot;696&quot; /&gt;&lt;/PUESTOS&gt;&lt;/FILTRO&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG04_PUESTOS.oi_puesto, 
					ORG04_PUESTOS.c_puesto, 
					ORG04_PUESTOS.d_puesto,	
					ORG03_EMPRESAS.c_empresa
	    	FROM 
	    		ORG04_PUESTOS, 
	    		ORG03_EMPRESAS
     			{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    			{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN 
      		ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
      		{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
        	{%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 1=1 
	      	{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa={#SOURCE:@oi_empresa} %} {% %} %}        
	        {%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
	        {%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
	        {%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
		  		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
	     		oi_puesto ASC
    	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND 
					NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;c_puesto&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;9&quot; ID=&quot;x&quot; oi_banda_sal=&quot;&quot; oi_categoria=&quot;1&quot;&gt;&#13;&#10;  &lt;PUESTOS/&gt;&#13;&#10;    &#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('	
			  SELECT 
			  	ORG04_PUESTOS.oi_puesto, 
			  	ORG04_PUESTOS.c_puesto, 
			  	ORG04_PUESTOS.d_puesto, 
			  	ORG04_PUESTOS.oi_empresa, 
			  	ORG03_EMPRESAS.c_empresa
 		  	FROM 
 		  		ORG04_PUESTOS, 
 		  		ORG03_EMPRESAS
     			{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    			{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN 
      		ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
	      	{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
	        {%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 1=1 
	      	{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa  ={#SOURCE:@oi_empresa} %} {% %} %}        
	        {%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
	        {%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
	        {%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
		  		{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
	     		oi_puesto ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_puesto" value="$r/@c_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa" type="Nomad.NSystem.Int"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND 
					NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ID OI_ESTRUCTURA=&quot;178&quot; /&gt;" name="GET_PUESTO">
			<qry:main doc="SOURCE">
				<qry:element name="PUESTO">
					<qry:insert-select name="QRY_PUESTO" doc-path="#SOURCE:ID"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PUESTO" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
				SELECT ORG04_POSICIONES.oi_puesto
				FROM ORG04_POSICIONES
				WHERE ORG04_POSICIONES.oi_unidad_org in 
						(SELECT ORG02_ESTRUCTURAS.oi_unidad_org
						FROM ORG02_ESTRUCTURAS WHERE ORG02_ESTRUCTURAS.oi_estructura = {%=#SOURCE:@OI_ESTRUCTURA%})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_puesto" value="$r/@oi_puesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PUESTO">
			<PUESTO oi_puesto=""/>
		</doc:define>
		<doc:define name="FILTERDATA_ORGANIGRAMA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS>
					<PUESTO id=""/>
				</PUESTOS>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<doc:load-qry output-doc="PUESTO" qry="GET_PUESTO" input-doc-path="#SOURCE:"/>
			<doc:set-attribute from-attr-path="#PUESTO:@oi_puesto" to-attr-path="#FILTERDATA_ORGANIGRAMA:PUESTOS/PUESTO/@id"/>
			<doc:assign-value from-path="#FILTERDATA_ORGANIGRAMA:" to-doc="FILTERDATA"/>
			<doc:load-qry input-doc-path="#FILTERDATA:" qry="FILTER" output-doc="QRY"/>
			<doc:new-object class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO" doc="DDO"/>
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.noreg.autoform" parent-doc-path="#QRY:" doc-path="#DDO:" iter-index="#QRY:ROW/@value" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.filter.form:FILTER" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.filter.autoform:FILTER" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE"/>
	<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.noreg.autoform:EDIT" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.noreg.autoform" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.noreg.form:EDIT" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="open-flow-SHOW">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form"/>
		</flow:action>
	</flow:form>
	<flow:form mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form:SHOW" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.autoform:SHOW">
		<flow:action name="on-move-iterator">
			<doc:load-object doc="DDO" class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO" id-path="#iter-cursor:@value"/>
		</flow:action>
		<flow:action name="EDIT">
			<flow:log text-path="#DDO:" text="ppddo"/>
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" mode="EDIT" doc-path="#DDO:"/>
		</flow:action>
		<flow:action name="CALL:POSICION">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform" mode="SHOW" doc-path="#SOURCE:POSICIONES" parent-doc-path="#SOURCE:POSICIONES" iter-index="#SOURCE:POSICIONES/POSICION/@id"/>
		</flow:action>
	</flow:form>
	<flow:form mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form:EDIT" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.autoform:EDIT">
		<flow:action name="SAVE">
			<doc:save-object doc="DDO" class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO"/>
			<flow:close-form next-action="After-Change"/>
		</flow:action>
		<flow:action name="DELETE">
			<doc:delete-object doc="DDO" class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO" doc-path="#DDO:"/>
			<doc:save-object doc="DDO" class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO"/>
			<flow:close-form next-action="After-Change"/>
		</flow:action>
		<flow:action name="CALL:POSICION">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform" mode="EDIT" doc-path="#SOURCE:POSICIONES" parent-doc-path="#SOURCE:POSICIONES" iter-index="#SOURCE:POSICIONES/POSICION/@id"/>
		</flow:action>
		<flow:action name="CALL:PUES_EXA">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUES_EXA.noreg.autoform" mode="EDIT" doc-path="#SOURCE:PUES_EXA" parent-doc-path="#SOURCE:PUES_EXA" iter-index="#SOURCE:PUES_EXA/PUES_EXA/@id"/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.form:SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform" mode="SHOW" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform:SHOW">
		<flow:action name="on-move-iterator">
			<flow:open-form iter-index="#PARENTSOURCE:POSICION/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form"/>
		</flow:action>
	</flow:form>
	<flow:form mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form:SHOW" doc="SOURCE" parent-doc="PARENTSOURCE" doc-path="/POSICION[@id='{#iter-cursor:@value}']" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.autoform:SHOW"/>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.form:EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform" mode="EDIT" extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.noreg.autoform:EDIT">
		<flow:action name="on-move-iterator">
			<flow:open-form iter-index="#PARENTSOURCE:POSICION/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.autoform:EDIT" doc-path="/POSICION[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form:EDIT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.POSICION.form" mode="EDIT"/>
	<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.autoform:LIST" name="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form:LIST" form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="LIST">
		<flow:action name="load-DDO">
			<doc:load-object class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO" id-path="#FORM:ctrl[@id='LIST']/@xval" doc="DDO"/>
		</flow:action>
		<flow:action name="open-flow-EDIT">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Puestos.PUESTO.form" doc-path="#DDO:" mode="EDIT"/>
		</flow:action>
		<flow:action name="EDIT">
			<flow:call-action action="load-DDO"/>
			<flow:call-action action="open-flow-EDIT"/>
		</flow:action>
	</flow:form>
</flow:flow>
