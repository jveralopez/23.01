<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Trayectoria_Personal" doc="SOURCE">
	<form:Title width="100%">
		<form:Label nvalue="#TIT:@value" width="90%" align="center" nowrap="1" dynamic="1" style="S3 LCol_w" name="lblTitulo"/>
	</form:Title>
	<form:Center width="80%">
		<form:Blank name="blkBlank1"/>
		<form:Blank name="blank_iter01"/>
		<form:ListView docname="RS" paging="1" rows="10" name="LIST">
			<form:LVColumns>
				<form:LVColumn attrname="d_referencia" label="Referencia" name="d_referencia" align="left" sorteable="1" width="100px" type="string"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Estado" attrname="estado" name="estado"/>
				<form:LVColumn additional="dd/mm/yyyy" attrname="f_estado" name="f_estado" type="datetime" align="left" sorteable="1" width="100px" label="Fecha"/>
				<form:LVColumn attrname="d_mot_autoex" name="d_mot_autoex" align="left" sorteable="1" width="100px" type="string" label="Motivo de Rechazo"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="rowButtons">
			<form:Row name="row1">
				<form:Button visible="0" name="SAVE" label="Guardar" img="save" descrip="Guardar los Cambios en la Base de Datos" startvalidate="0" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="SAVE"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="CANCEL" descrip="" note="">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
