<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.simple.guia.flow" name="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.ESCALA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.ESCALA"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<flow:log text="ppsource" text-path="#SOURCE:"/>
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.ESCALA.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_escala ID, c_escala CODE, d_escala TEXT, oi_tipo_escala PID FROM SEL06_ESCALAS WHERE oi_escala={#SOURCE:helper-mess/@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@PID" name="PID"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_ref_fact=&quot;9&quot; text=&quot;&quot; id=&quot;&quot; code=&quot;E1&quot; /&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('select oi_tipo_escala from sel02_ref_fact 
											where oi_ref_fact={#INDOC:@oi_ref_fact}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in table('SELECT DISTINCT SEL06_ESCALAS.oi_escala ID, c_escala CODE, d_escala TEXT 
								FROM SEL06_ESCALAS, SEL06_TIPOS_ESCALA, SEL17_FACTORES 
								WHERE c_escala={#INDOC:@code}
								AND SEL17_FACTORES.oi_tipo_escala={#SOURCE:@oi_tipo_escala}
								AND SEL06_ESCALAS.oi_tipo_escala = SEL06_TIPOS_ESCALA.oi_tipo_escala
								AND SEL06_TIPOS_ESCALA.oi_tipo_escala = SEL17_FACTORES.oi_tipo_escala')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_ref_fact=&quot;9&quot; text=&quot;Escala 1&quot; id=&quot;1&quot; code=&quot;E1&quot; /&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('select oi_tipo_escala from sel02_ref_fact 
											where oi_ref_fact={#INDOC:@oi_ref_fact}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in table('SELECT DISTINCT SEL06_ESCALAS.oi_escala ID, c_escala CODE, d_escala TEXT 
								FROM SEL06_ESCALAS, SEL06_TIPOS_ESCALA, SEL17_FACTORES 
								WHERE SEL17_FACTORES.oi_tipo_escala={#SOURCE:@oi_tipo_escala}
								AND SEL06_ESCALAS.oi_tipo_escala = SEL06_TIPOS_ESCALA.oi_tipo_escala
								AND SEL06_TIPOS_ESCALA.oi_tipo_escala = SEL17_FACTORES.oi_tipo_escala')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="Nomad.simple.guia.form:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.ESCALA.guia.form"/>
</flow:flow>
