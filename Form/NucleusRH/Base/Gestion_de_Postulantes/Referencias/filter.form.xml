<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Referencias.filter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/FILTER">
					<form:Event runat="server" name="onclick" action="FILTER"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/FILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/FILTER"/>
					</form:Policies>
				</form:Button>
				<form:Button name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ADD">
					<form:Event runat="server" name="onclick" action="ADD"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ADD/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ADD"/>
					</form:Policies>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Help>
		<form:Help-title text="Requerimientos de Personal" name="TITLE"/>
		<form:Help-descr text="Registra los Requerimientos del Personal." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Referencias de Personal" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl1"/>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="columnas">
			<form:Column name="col1">
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_empresa">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_empresa/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_empresa"/>
					</form:Policies>
				</form:ComboBox>
				<form:ComboBox nvalue="#FILTERDATA:@oi_req" prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="0" name="oi_req" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_req">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_req/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_req"/>
					</form:Policies>
				</form:ComboBox>
				<form:ComboBox nvalue="#FILTERDATA:@ca_estado" xsize="40" mode="OPT" required="0" label="Estado" name="ca_estado" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ca_estado">
					<options>
						<option text="Abierta" value="A"/>
						<option text="Inicializada" value="I"/>
						<option text="Cerrada" value="C"/>
						<option text="Anulada" value="N"/>
					</options>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ca_estado/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/ca_estado"/>
					</form:Policies>
				</form:ComboBox>
				<form:FKInput label="Unidad Organizativa Solicitante" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura" length="30" xsize="15" required="0" cache="no" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_estructura">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_estructura/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_estructura"/>
					</form:Policies>
				</form:FKInput>
				<form:ComboBox label="Empresa - Legajo Solicitante" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="40" mode="QRY" required="0" nvalue="#FILTERDATA:@oi_personal_emp" name="oi_personal_emp" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_personal_emp">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_personal_emp/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Referencias/filter/form/oi_personal_emp"/>
					</form:Policies>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
	</form:Center>
</form:Form>
