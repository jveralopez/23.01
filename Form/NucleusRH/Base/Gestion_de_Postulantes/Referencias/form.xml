function ListClick()
{ 
	var img;
	
	if (Ctrl('main').GetMode() == "LIST")
	{
		
		img=Ctrl("LIST").GetSelectAttrValue("img").toUpperCase().split("/");
		img=img[img.length-1].split(".")[0];
		
		switch(img)
		{
			case "LOCK":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKDEL":
				CtrlEnabled("EDIT"  ,true );
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKEDIT":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",true );
			break;
			default:
				CtrlEnabled("EDIT"  ,true);
				CtrlEnabled("DELETE",true);
			break;
		}
	}
	
	if ((Ctrl("LockREG")) &amp;&amp; (Ctrl("HiLockREG"))) 
	{                  
		
		Ctrl("LockREG").SetXValue(Ctrl("HiLockREG").GetXValue());
		CtrlEnabled("EDIT"  ,Ctrl("LockREG").GetXValue()!="1");
		CtrlEnabled("DELETE",Ctrl("LockREG").GetXValue()!="1");
	}
}

function ACEPTAR_NEW_EDIT(meThis)
 {
	if (CtrlExists('f_min_inc') &amp;&amp; CtrlExists('f_max_inc'))  
 	{          
		if (Ctrl('f_min_inc').GetXValue() != "" &amp;&amp; Ctrl('f_max_inc').GetXValue() != "")
  		{
			if (Ctrl('f_min_inc').GetXValue() &gt; Ctrl('f_max_inc').GetXValue())
			{
				meThis.SetError("La fecha m&#225;xima de inscripci&#243;n debe ser posterior a la fecha m&#237;nima de inscripci&#243;n");
				return false;						
			}
  		}
  	}
      

 	if (CtrlExists('f_req')) {

 		if (CtrlExists('f_min_inc'))
		{  
			if (Ctrl('f_min_inc').GetXValue() != "" &amp;&amp; Ctrl('f_req').GetXValue() != "")
	  		{ 	
	 			if (Ctrl('f_min_inc').GetXValue() &lt; Ctrl('f_req').GetXValue())  
				{	
					meThis.SetError("La fecha m&#237;nima de inscripci&#243;n debe ser posterior a la fecha del Requerimiento");
					return false;						
				}
	  		}
	 	}
	  
	  	if (CtrlExists('f_max_inc')) 
	 	{          		
			if (Ctrl('f_max_inc').GetXValue() != "" &amp;&amp; Ctrl('f_req').GetXValue() != "")
	  		{
				if (Ctrl('f_max_inc').GetXValue() &lt; Ctrl('f_req').GetXValue())		
				{
					meThis.SetError("La fecha m&#225;xima de inscripci&#243;n debe ser posterior a la fecha del Requerimiento");
					return false;						
				}
			}
	  	}
	  
	  	if (CtrlExists('f_inicio'))
	 	{          
			if (Ctrl('f_inicio').GetXValue() != "" &amp;&amp; Ctrl('f_req').GetXValue() != "")
	  		{
	    		if (Ctrl('f_inicio').GetXValue() &lt; Ctrl('f_req').GetXValue())	
				{
					meThis.SetError("La fecha de inicio debe ser posterior a la fecha del Requerimiento");
					return false;						
				}				
			} 
		}
	}


  	if (CtrlExists('f_inicio')) {

	  	if (CtrlExists('f_min_inc'))
	 	{ 
			if (Ctrl('f_min_inc').GetXValue() != "" &amp;&amp; Ctrl('f_inicio').GetXValue() != "")
	  		{
				if (Ctrl('f_min_inc').GetXValue() &lt; Ctrl('f_inicio').GetXValue())	
				{
					meThis.SetError("La fecha m&#237;nima de inscripci&#243;n debe ser posterior a la fecha de inicio del Requerimiento");
					return false;						
				}
			}
	  	}
	  
		if (CtrlExists('f_max_inc'))
	 	{          	
			if (Ctrl('f_max_inc').GetXValue() != "" &amp;&amp; Ctrl('f_inicio').GetXValue() != "")
	  		{
				if (Ctrl('f_max_inc').GetXValue() &lt; Ctrl('f_inicio').GetXValue())	
				{
					meThis.SetError("La fecha m&#225;xima de inscripci&#243;n debe ser posterior a la fecha de inicio del Requerimiento");
					return false;						
				}
	 		}  
		}
	}
				
	return true;
					
 }  
   
function LoadForm()
{
	//alert(Ctrl('main').GetMode());
	if (Ctrl('ca_estado').GetXValue() == "I")
	{	
		CtrlEnabled('DELETE',false);
		if (Ctrl('main').GetMode() == "SHOW" )
		{
			CtrlEnabled('cerrar', true);	
			CtrlEnabled('anular', false);	 	 
			CtrlEnabled('iniciar', false);
		}
	}
	   
	if (Ctrl('ca_estado').GetXValue() == "A" )
	{
		if (Ctrl('main').GetMode() != "NEW")
		{
			CtrlEnabled('DELETE', true);  
		}
		if (Ctrl('main').GetMode() == "SHOW" )
		{	
			CtrlEnabled('cerrar', false);
			CtrlEnabled('iniciar', true);
			CtrlEnabled('anular', true);			 	
		}
	}
	if (Ctrl('ca_estado').GetXValue() == "C")
	{
		if (Ctrl('main').GetMode() == "LIST")
		{
		CtrlEnabled('EDIT', false);
		CtrlEnabled('DELETE', false);	
		}
	}
		
	if (Ctrl('ca_estado').GetXValue() == "C")
	{
		if (Ctrl('main').GetMode() == "SHOW")
		{
			CtrlEnabled('iniciar', false);
			CtrlEnabled('cerrar', false);
			CtrlEnabled('anular', false);
		}
		
		CtrlEnabled('EDIT', false);
		CtrlEnabled('DELETE', false);	
		
	}	
	
	if (Ctrl('ca_estado').GetXValue() == "N")
	{
	if (Ctrl('main').GetMode() == "SHOW")
	{
		CtrlEnabled('iniciar', true);
		CtrlEnabled('cerrar', false);
		CtrlEnabled('anular', true);
	}
	CtrlEnabled('EDIT', false);
	CtrlEnabled('DELETE', true);			 
	}
	
	CtrlEnabled('f_req', false);
	if (Ctrl('main').GetMode() == "NEW")
	{
		CtrlEnabled('f_req', true);
	}  
	if(Ctrl('main').GetMode() == "LIST")
		Ctrl('oi_ref_hid').SetCValue(Ctrl('LIST').GetSelectAttrValue('oi_referencia'));
		
}

function SetConsultora()
{
  if(Ctrl("c_tipo_req").GetXValue()!="1")
	{
		if (Ctrl('main').GetMode() == "EDIT" || Ctrl('main').GetMode() == "NEW")
		{
		CtrlEnabled('d_consultora', true);	                                      
		} 
	} 
	else
	{
		CtrlEnabled('d_consultora', false);
		Ctrl("d_consultora").SetXValue("");
	}
}

