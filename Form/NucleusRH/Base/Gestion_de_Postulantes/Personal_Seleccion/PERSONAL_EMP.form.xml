<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Personal_Seleccion.PERSONAL_EMP.autoform" name="PERSONAL_EMP" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?">
	<form:Right>
		<form:VGroup visible="0" name="vgChildsPERSONAL_EMP" width="90%" collapse="1" label="Dependencias" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Personal_Seleccion/PERSONAL_EMP/form/vgChildsPERSONAL_EMP"/>
		<form:VGroup name="vgChildsPERSONAL_EMP_Seleccion" width="90%" collapse="1" label="Dependencias" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Personal_Seleccion/PERSONAL_EMP/form/vgChildsPERSONAL_EMP">
			<form:Link name="PERS_PUESTO" label="Puestos a Postularse" descrip="Registra los Puestos a los que se postularia el Personal de la Empresa" allowimg="1" X-POLICY="./FORM/NucleusRH/Base/Gestion_de_Postulantes/Personal_Seleccion/PERSONAL_EMP/form/PERS_PUESTO">
				<form:Event runat="server" name="onclick" action="CALL:PERS_PUESTO"/>
			</form:Link>
		</form:VGroup>
		<form:VGroup visible="LIST|SHOW" label="Acciones" collapse="1" width="95%" name="TrayecPERSONAL">
			<form:Link label="Trayectoria" name="TRAYEC_PER" descrip="Muestra los distintos procesos por los que pas&#243; el Legajo." allowimg="1" policy="NucleusRH/Base/Gestion_de_Postulantes/Postulantes/DOCUMENTO_POS/READ">
				<form:Event policy="NucleusRH/Base/Gestion_de_Postulantes/Postulantes/DOCUMENTO_POS/EDIT" action="Trayectoria" name="onclick" runat="client"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns name="main_columnsPERSONAL_EMP">
			<form:Column visible="0" name="main_columnsPERSONAL_EMPcolumn1"/>
			<form:Column visible="EDIT|SHOW" name="main_columnsPERSONAL_EMP_Seleccion">
				<form:Blank name="bl1" width="50" visible="SHOW|EDIT|NEW"/>
				<form:Combo name="oi_empresa" nvalue="#source:oi_empresa/@value" label="Empresa" enabled="NEW" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
				<form:FKInput name="oi_personal" nvalue="#source:oi_personal/@value" label="Personal" length="30" xsize="15" enabled="NEW" required="1">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Personal.Legajo.PERSONAL.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="0">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:DateTime name="f_ingreso" nvalue="#source:@f_ingreso" label="Fecha Ingreso" mask="dd/mm/yyyy" descr="Fecha de Ingreso del empleado a la Empresa." enabled="NEW" required="0" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Ingreso del empleado a la Empresa." visible="0">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox name="e_numero_legajo" nvalue="#source:@e_numero_legajo" label="N&#250;mero Legajo" xsize="12" mask="###.###.##0" descr="N&#250;mero de Legajo." enabled="NEW" required="0"/>
				<form:FKInput name="oi_puesto_ult" nvalue="#source:oi_puesto_ult/@value" label="Puesto (&#218;ltimo)" length="30" xsize="15" enabled="NEW" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Puestos.PUESTO.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="0">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput name="oi_posicion_ult" nvalue="#source:oi_posicion_ult/@value" label="Puesto - Posici&#243;n (&#218;ltimo)" length="30" xsize="15" enabled="NEW" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Puestos.POSICION.Guia.autoflow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton name="SEARCH" label="Search" img="SEARCH" visible="0">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:Image nvalue="#FOTOUT:@oi_foto" class="NucleusRH.Base.Personal.Imagenes.HEAD" enabled="NEW" label="Foto" name="oi_foto" required="0" height="96" width="96">
					<form:SButtons>
						<form:SButton name="sbHelper" label="sbHelper" img="search" visible="NEW">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
						<form:SButton name="sbClean" label="sbClean" img="eliminate" visible="NEW">
							<form:Event runat="client" name="onclick" action="CLEAR_VALUES"/>
						</form:SButton>
					</form:SButtons>
				</form:Image>
				<form:TextBox length="1000" required="0" enabled="NEW|EDIT" ysize="4" xsize="50" label="Observaciones" nvalue="#source:@o_personal_sel" name="o_personal_sel"/>
			</form:Column>
		</form:Columns>
		<form:Hidden name="oi_personal_emp" nvalue="#DDO:@id"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="SAVE" label="Guardar" img="save" descrip="Guardar los Cambios en la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="NEW|EDIT" startvalidate="1">
					<form:Event runat="server" name="onclick" action="SAVE"/>
				</form:Button>
				<form:Button name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" visible="0">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button visible="SHOW|LIST" name="EDIT" label="Modificar" img="edit" descrip="Modificar el Registro de la Base de Datos" note="Modificar el Registro de la Base de Datos">
					<form:Event runat="server" name="onclick" action="EDIT"/>
				</form:Button>
				<form:Button name="DELETE" label="Eliminar" img="del" descrip="Eliminar el Registro de la Base de Datos" note="Eliminar el Registro de la Base de Datos" visible="DELETE" mess="&#191;Est&#225; seguro que desea eliminar el registro?">
					<form:Event runat="server" name="onclick" action="DELETE"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario" visible="NEW|EDIT|DELETE" mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="SHOW|LIST" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ObjtectResult()
{
	this.processResult= function(xmlin){}
}

function Trayectoria() 
{    
	openNewFlowWait("NucleusRH.Base.Gestion_de_Postulantes.Trayectoria_Personal.flow","initialize",'&lt;DATA oi_personal_emp="'+Ctrl('oi_personal_emp').GetXValue()+'"/&gt;' , new ObjtectResult(),"M");
}
	</form:Scripts>
</form:Form>
