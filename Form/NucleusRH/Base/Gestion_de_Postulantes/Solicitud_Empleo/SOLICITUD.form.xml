		function saveForm()
{
	
		Ctrl('c_estado').SetXValue('D'); 
		Ctrl('oi_tipo_familiar').SetXValue('5');
		Ctrl('DDOMADREoi_tipo_familiar').SetXValue('4');
		Ctrl('CONYUGEoi_tipo_familiar').SetXValue('1');
		if ((Ctrl('d_apellidoPadre').GetXValue()!='') &amp;&amp; (Ctrl('d_nombresPadre').GetXValue()!=''))
		{
			Ctrl('l_cargarpadre').SetXValue('1'); 
			Ctrl('d_familiar_pos').SetXValue(Ctrl('d_apellidoPadre').GetXValue() + ', ' + Ctrl('d_nombresPadre').GetXValue()); 
		}else
			{
				Ctrl('l_cargarpadre').SetXValue('0');
			}
		if ((Ctrl('DDOMADREd_apellido').GetXValue()!='') &amp;&amp; (Ctrl('DDOMADREd_nombres').GetXValue()!=''))
		{
			Ctrl('l_cargarmadre').SetXValue('1');
			Ctrl('DDOMADREd_familiar_pos').SetXValue(Ctrl('DDOMADREd_apellido').GetXValue() + ', ' + Ctrl('DDOMADREd_nombres').GetXValue()); 
		}else
			{
				Ctrl('l_cargarmadre').SetXValue('0');
			}
		if ((Ctrl('CONYUGEd_apellido').GetXValue()!='') &amp;&amp; (Ctrl('CONYUGEd_nombres').GetXValue()!=''))
		{
			Ctrl('l_cargarconyuge').SetXValue('1');
			Ctrl('CONYUGEd_familiar_pos').SetXValue(Ctrl('CONYUGEd_apellido').GetXValue() + ', ' + Ctrl('CONYUGEd_nombres').GetXValue()); 
		}else
			{
				Ctrl('l_cargarconyuge').SetXValue('0');
			}
		if ((Ctrl('oi_tipo_domicilio').GetXValue()!='') &amp;&amp; (Ctrl('d_calle').GetXValue()!=''))
		{
			Ctrl('l_domicilio').SetXValue('1');
		}else
			{
				Ctrl('l_domicilio').SetXValue('0');
			}		
		if ((Ctrl('d_empresa').GetXValue()!=''))
		{
			Ctrl('l_experiencia1').SetXValue('1');
		}else
			{
				Ctrl('l_experiencia1').SetXValue('0');
			}			
		if ((Ctrl('d_puesto').GetXValue()!=''))
		{
			Ctrl('l_experiencia1Puesto').SetXValue('1');
		}else
			{
				Ctrl('l_experiencia1Puesto').SetXValue('0');
			}			    
		if ((Ctrl('d_empresa2').GetXValue()!=''))
		{
			Ctrl('l_experiencia2').SetXValue('1');
		}else
			{
				Ctrl('l_experiencia2').SetXValue('0');
			}			
		if ((Ctrl('d_puesto1').GetXValue()!=''))
		{
			Ctrl('l_experiencia2Puesto').SetXValue('1');
		}else
			{
				Ctrl('l_experiencia2Puesto').SetXValue('0');
			}						
		return true;	                 
}

