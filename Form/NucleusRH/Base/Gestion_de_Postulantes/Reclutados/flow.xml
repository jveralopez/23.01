<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="Reclutados.flow" extends="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Gestion_de_Postulantes.Reclutados"/>
	<flow:declare>
		<qry:define declare="&lt;FILTRO oi_reclutado=&quot;508&quot; oi_empresa=&quot;196&quot; /&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT    
				t0.oi_reclutado as oi_reclutado 
			FROM 
				SEL13_RECLUTADOS as t0,
				SEL02_REQ as t1,
				SEL02_REFERENCIAS as t2
			JOIN
				t0.oi_referencia INNER t2.oi_referencia,
				t2.oi_req INNER t1.oi_req
			WHERE
				t1.oi_empresa = {#SOURCE:@oi_empresa}
				{%? (#SOURCE:@oi_req!='')	{% AND t1.oi_req = {#SOURCE:@oi_req} %} {% %} %}
				{%? (#SOURCE:@oi_referencia!='')	{% AND t2.oi_referencia = {#SOURCE:@oi_referencia} %} {% %} %}
				{%? (#SOURCE:@oi_reclutado!='')	{% AND t0.oi_reclutado = {#SOURCE:@oi_reclutado} %} {% %} %}
				{%? (#SOURCE:@c_estado!='')	{% AND t0.c_estado = {#SOURCE:@c_estado} %} {% %} %}
			ORDER BY oi_reclutado asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclutado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO oi_referencia=&quot;3&quot; oi_empresa=&quot;9&quot; oi_reclutado=&quot;117&quot; c_estado=&quot;&quot; /&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t0.oi_reclutado as oi_reclutado, 
				t0.c_reclutado as c_reclutado,
				t0.d_reclutado as d_reclutado, 
				t0.c_estado as c_estado, 
				t0.f_reclutamiento as f_reclutamiento, 
				t0.f_seleccion as f_seleccion, 
				t0.f_contratacion as f_contratacion,
			  t0.f_rankeo as f_rankeo,
			  t0.f_descartado as f_descartado,
				t0.n_ranking as n_ranking, 
				t0.oi_reclutado as CODE, 
				t0.oi_reclutado as TEXT, 
				t0.oi_referencia as oi_referencia, 
				t0.oi_personal_emp as oi_personal_emp, 
				t0.oi_postulante as oi_postulante, 
				t0.oi_mot_autoex as oi_mot_autoex 
			FROM 
				SEL13_RECLUTADOS as t0,
				SEL02_REQ as t1,
				SEL02_REFERENCIAS as t2
			JOIN
				t0.oi_referencia INNER t2.oi_referencia,
				t2.oi_req INNER t1.oi_req
			WHERE
				t1.oi_empresa = {#SOURCE:@oi_empresa}
				{%? (#SOURCE:@oi_req!='')	{% AND t1.oi_req = {#SOURCE:@oi_req} %} {% %} %}
				{%? (#SOURCE:@oi_referencia!='')	{% AND t2.oi_referencia = {#SOURCE:@oi_referencia} %} {% %} %}
				{%? (#SOURCE:@oi_reclutado!='')	{% AND t0.oi_reclutado = {#SOURCE:@oi_reclutado} %} {% %} %}
				{%? (#SOURCE:@c_estado!='')	{% AND t0.c_estado = {#SOURCE:@c_estado} %} {% %} %}
			ORDER BY oi_reclutado asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclutado"/>
						<qry:attribute name="c_reclutado" value="$r/@c_reclutado"/>
						<qry:attribute name="d_reclutado" value="$r/@d_reclutado"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="f_reclutamiento" value="$r/@f_reclutamiento"/>
						<qry:attribute name="f_seleccion" value="$r/@f_seleccion"/>
						<qry:attribute name="f_contratacion" value="$r/@f_contratacion"/>
						<qry:attribute name="f_rankeo" value="$r/@f_rankeo"/>
						<qry:attribute name="f_descartado" value="$r/@f_descartado"/>
						<qry:attribute name="n_ranking" value="$r/@n_ranking"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="oi_postulante" value="$r/@oi_postulante"/>
						<qry:attribute name="oi_mot_autoex" value="$r/@oi_mot_autoex"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
