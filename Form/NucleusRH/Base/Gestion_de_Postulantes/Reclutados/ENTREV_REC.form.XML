<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.ENTREV_REC.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.ENTREV_REC">
	<form:Title width="90%"/>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsENTREV_REC">
			<form:Column name="main_columnsENTREV_RECcolumn1">
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Entrevista" nvalue="#source:@f_fecha_hora_ent" name="f_fecha_hora_ent">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:File source="0" required="0" nvalue="#source:oi_doc_digital/@value" name="oi_doc_digital" label="Adjuntar Informe" enabled="NEW|EDIT" class="NucleusRH.Base.Gestion_de_Postulantes.DocumentosDigitales.HEAD">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="search" label="Buscar" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton label="Eliminar" visible="EDIT|NEW" img="eliminate" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Entrevista" attrname="f_fecha_hora_ent" name="f_fecha_hora_ent"/>
				<form:LVColumn additional="&lt;OPTS&gt;&lt;OPT value=&quot;PL&quot; text=&quot;Planificada&quot; /&gt;&lt;OPT value=&quot;RE&quot; text=&quot;Realizada&quot; /&gt;&lt;OPT value=&quot;PO&quot; text=&quot;Postergada&quot; /&gt;&lt;OPT value=&quot;NR&quot; text=&quot;No Realizada&quot; /&gt;&lt;/OPTS&gt;" align="left" sorteable="1" width="50px" type="enum" label="Estado" attrname="c_estado" name="c_estado"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Empresa - Legajo" attrname="oi_personal_emp" name="oi_personal_emp"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Ideal Para" attrname="d_ideal_para" name="d_ideal_para"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom/>
</form:Form>
