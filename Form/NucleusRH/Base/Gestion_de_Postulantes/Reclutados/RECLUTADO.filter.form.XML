<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Reclutados" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bl40" width="100%" visible=""/>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Blank name="bl411" width="100%" visible=""/>
		<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
		<form:Hidden name="oi_referencia" order-change="PREV:oi_reclutado"/>
		<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_req" name="oi_req">
			<form:Event action="setReferencia" runat="client" name="onChange"/>
		</form:ComboBox>
		<form:ComboBox prev="oi_referencia" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO.INFO" nvalue="#source:@oi_reclutado" label="Reclutado" name="oi_reclutado" xsize="40" mode="QRY" required="0"/>
		<form:ComboBox xsize="40" mode="OPT" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado">
			<options>
				<option text="Reclutado" value="R"/>
				<option text="Rankeado" value="N"/>
				<option text="Seleccionado" value="S"/>
				<option text="Contratado" value="C"/>
				<option text="Descartado" value="D"/>
				<option text="Pre Ingreso" value="P"/>
			</options>
		</form:ComboBox>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button visible="FILTER0" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_req=&quot;447&quot; /&gt;" name="qry_referencia">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_ref" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_ref" doc="PARAM">
				<qry:xquery>
					for $r in SQL('  
			SELECT
				SEL02_REFERENCIAS.oi_referencia
			FROM
				SEL02_REFERENCIAS
			WHERE
				SEL02_REFERENCIAS.oi_req = {#PARAM:@oi_req}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_referencia" value="$r/@oi_referencia"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Scripts>
		function setReferencia()
{
	//Seteo la referencia a traves del oi_req
	var nSQL = GetProxy().SQLService();   
	var xml = nSQL.GetOBJ(Ctrl("main").getResource("qry_referencia"), "&lt;PARAM oi_req=\""+Ctrl("oi_req").GetXValue()+"\" /&gt;");
	Ctrl("oi_referencia").SetXValue(xml.oi_referencia); 
}   

function onLoadCus()
{
	if(Ctrl("oi_req").GetXValue() != "")
	{
		setReferencia();
	}
}
	</form:Scripts>
	<form:Event action="onLoadCus" name="onLoad" runat="client"/>
</form:Form>
