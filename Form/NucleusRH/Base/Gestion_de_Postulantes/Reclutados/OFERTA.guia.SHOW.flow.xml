<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.parent.guia.flow" name="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.OFERTA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Gestion_de_Postulantes.Reclutados.OFERTA"/>
	<flow:main doc="SOURCE"/>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in table('SELECT oi_oferta ID, c_oferta CODE, f_oferta TEXT, oi_reclutado PID FROM SEL13_OFERTAS WHERE oi_oferta={#SOURCE:helper-mess/@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="id"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@ID" name="value"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@CODE" name="code"/>
					<qry:attribute type="Nomad.NSystem.String" value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
