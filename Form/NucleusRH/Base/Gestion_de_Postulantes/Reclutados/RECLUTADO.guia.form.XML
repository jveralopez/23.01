<form:Form xmlns:form="nomad_engine.form" extends="Nomad.parent.guia.form" doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Reclutados.RECLUTADO.guia">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label nowrap="1" style="S3 LCol_w" label="Seleccion de Reclutados" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:FKInput required="1" xsize="15" length="30" label="Referencias" nvalue="#SOURCE:@PARENTID" name="PARENTID">
			<form:STexts>
				<form:SText xsize="50" name="txt1"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT|NEW|SHOW" img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="server" action="RELOAD_QUERY" name="onReceiveData"/>
		</form:FKInput>
	</form:Center>
	<form:Scripts>
		function GetFlowAction() { return "NucleusRH.Base.Gestion_de_Postulantes.Reclutados.autoflow:initialize"; }
	</form:Scripts>
</form:Form>
