<form:Form name="EXA_REC.resultado.form" mess="&#191;Est&#225; seguro que desa cancelar?" doc="source" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:Label label="Carga de Resultados de Examen" style="S3 LCol_w" name="Label 1" align="center"/>
	</form:Title>
	<form:Center>
		<form:Blank name="blank 1"/>
		<form:FKInput nvalue="#source:oi_ref_examen/@value" name="oi_ref_examen" enabled="0" label="Examen" length="30" xsize="15" visible="" required="1">
			<form:STexts>
				<form:SText name="txt12" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_EXAMEN.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="FILTER" name="SEARCH" label="Search" img="SEARCH" enabled="FILTER">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
		<form:FKInput nvalue="#source:oi_ref_res_exa/@value" name="oi_ref_res_exa" enabled="EDIT" label="Resultado" length="30" xsize="15" visible="" required="0">
			<form:STexts>
				<form:SText name="txt12" xsize="50"/>
			</form:STexts>
			<form:Helper name="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REF_RES_EXA.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
				<helper-mess oi_ref_examen="{oi_ref_examen.XValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton visible="EDIT" enabled="EDIT" name="SEARCH" label="Search" img="SEARCH">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:FKInput>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Vuelve a la pantalla anterior" img="back" name="btnVolver" visible="EDIT" label="Volver" note="Acepta la operacion sobre el formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts/>
</form:Form>
