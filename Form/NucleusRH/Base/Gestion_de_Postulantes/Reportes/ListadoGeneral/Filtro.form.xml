<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoGeneral.Filtro.form" doc="source">
	<form:Title>
		<form:Label label="Listado de Referencias" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bl40" width="100%" visible=""/>
				<form:Label name="lblreq" label="Criterios de B&#250;squeda seg&#250;n Requerimientos" align="center" style="S3 LCol_g" visible=""/>
				<form:Blank name="bl411" width="100%" visible=""/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Requerimiento" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_req" name="oi_req"/>
				<form:ComboBox name="ca_estado_req" nvalue="#source:@ca_estado_req" xsize="40" mode="OPT" required="0" label="Estado del Requerimiento">
					<options>
						<option text="Abierto" value="A"/>
						<option text="Inicializado" value="I"/>
						<option text="Cerrado" value="C"/>
						<option text="Anulada" value="N"/>
					</options>
				</form:ComboBox>
				<form:DateTime name="f_desde_req" nvalue="#source:@f_desde_req" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_hasta_req" nvalue="#source:@f_hasta_req" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl50" width="100%" visible=""/>
				<form:Label name="lblref" label="Criterios de B&#250;squeda seg&#250;n Referencias" align="center" style="S3 LCol_g" visible=""/>
				<form:Blank name="bl511" width="100%" visible=""/>
				<form:ComboBox prev="oi_req" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REFERENCIA.INFO" nvalue="#source:@oi_referencia" label="Referencia" name="oi_referencia" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox name="ca_estado_ref" nvalue="#source:@ca_estado_ref" label="Estado de la Referencia" xsize="40" mode="OPT" required="0">
					<options>
						<option text="Abierta" value="A"/>
						<option text="Inicializada" value="I"/>
						<option text="Finalizada" value="F"/>
						<option text="Abortada" value="N"/>
						<option text="Nueva" value="E"/>
						<option text="Parcialmente Finalizada" value="P"/>
					</options>
				</form:ComboBox>
				<form:Blank name="b60" width="100%" visible=""/>
				<form:Label name="lblper" label="Criterios de B&#250;squeda seg&#250;n Personas" align="center" style="S3 LCol_g" visible=""/>
				<form:Blank name="bl611" width="100%" visible=""/>
				<form:ComboBox name="ca_estado_per" nvalue="#source:@ca_estado_per" label="Estado de la Persona" xsize="40" mode="OPT" required="0">
					<options>
						<option text="Reclutado" value="R"/>
						<option text="Rankeado" value="N"/>
						<option text="Seleccionado" value="S"/>
						<option text="Contratado" value="C"/>
					</options>
				</form:ComboBox>
				<form:DateTime label="Fecha Desde Estado" name="f_desde_per" nvalue="#source:@f_desde_per" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Hasta Estado" name="f_hasta_per" nvalue="#source:@f_hasta_per" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
