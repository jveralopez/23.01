<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="Base.Gestion_De_Postulantes.Resportes.ListadoContratados">
	<flow:info label="Flow para Nomad.Base.Gestion_De_Postulantes.Resportes.ListadoContratados">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO f_desde="" f_hasta="" oi_empresa="" ATRIB_ORDEN1="" ORDEN1="">
				<REQS/>
				<REFERENCIAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoContratados.Filtro.Form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" doc="FILTERDATA" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoContratados.Filtro.Form" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoContratados.Filtro.Form">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Gestion_de_Postulantes.ListadoContratados.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="101 - Listado de Contratados" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoContratados" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoContratados" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
