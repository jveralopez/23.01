<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoReferencias.Filtro.form" doc="source">
	<form:Title>
		<form:Label label="101 - Listado de Contratados" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bl40" width="100%" visible=""/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:DateTime label="Fecha Contrataci&#243;n Desde" name="f_desde" nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Contrataci&#243;n Hasta" name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_req" name="oi_req"/>
				<form:Line width="100%" name="line_1"/>
				<form:Label label="Criterio de Ordenamiento" style="M1 LCol_g" align="center" visible="" name="lbl201"/>
				<form:RowAligner columns="2" name="RAcamposOrden">
					<form:Row name="RC1O">
						<form:ComboBox xsize="40" mode="OPT" nvalue="#source:@ATRIB_ORDEN1" name="cboCampo1">
							<options>
								<option text="C&#243;digo Reclutado" value="c_reclutado"/>
								<option text="Fecha Contrataci&#243;n" value="f_contratacion"/>
								<option text="C&#243;digo Empresa" value="c_empresa"/>
								<option text="Descripci&#243;n Empresa" value="d_empresa"/>
							</options>
							<form:Opts/>
						</form:ComboBox>
						<form:ComboBox xsize="40" mode="OPT" nvalue="#source:@ORDEN1" name="cboOrdenCampo1">
							<options>
								<option text="Ascendente" value="Asc"/>
								<option text="Descendente" value="Desc"/>
							</options>
						</form:ComboBox>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
