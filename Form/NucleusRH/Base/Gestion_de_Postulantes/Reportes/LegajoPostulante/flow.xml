<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY"/>
		<doc:define name="PARAMETERS">
			<PARAMETERS oi_postulante="" chkDatosPersonales="1" chkDatosPrincipales="1" report=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#PARAMETERS:" mode="FILTER" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form"/>
		</flow:action>
		<flow:action name="proceso">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_postulante" to-attr-path="#PARAMETERS:@oi_postulante"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="PRO" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="PARAMETROS" text-path="#PARAMETERS:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Gestion_de_Postulantes.LegajoPostulante.rpt" input-doc-path="#PARAMETERS:" out-file-path="#PARAMETERS:@report"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="REPORT" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action eq="" if="#PARAMETERS:@oi_postulante" action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante" doc-path="#PARAMETERS:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante" doc="PARAMETERS"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.form:REPORT" doc="SOURCE" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.form" mode="REPORT">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form:FILTER" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form:PRO" doc="PARAMETERS" form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.LegajoPostulante.filter.form" mode="PRO"/>
</flow:flow>
