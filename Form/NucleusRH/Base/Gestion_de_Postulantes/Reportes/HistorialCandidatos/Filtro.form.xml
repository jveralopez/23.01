<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.HistorialCandidatos.Filtro.form" doc="source">
	<form:Title>
		<form:Label label="103 - Historial de Candidatos" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bl411" width="100%" visible=""/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Puestos.PUESTO.INFO" prev="oi_empresa" nvalue="#source:@oi_puesto" label="Puesto" name="oi_puesto" xsize="40" mode="QRY" required="0"/>
				<form:DateTime label="Fecha Desde" name="f_desde" nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Hasta" name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
