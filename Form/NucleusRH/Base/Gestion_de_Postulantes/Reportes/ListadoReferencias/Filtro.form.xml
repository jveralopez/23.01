<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoReferencia" doc="source">
	<form:Title>
		<form:Label label="100 - Listado de Referencias" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:Blank name="bl40" width="100%" visible=""/>
				<form:Label name="lblreq" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
				<form:Blank name="bl411" width="100%" visible=""/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox prev="oi_empresa" queryname1="NucleusRH.Base.Gestion_de_Postulantes.Requerimientos.REQ.INFO" label="Referencia" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_req" name="oi_req"/>
				<form:ComboBox name="ca_estado_req" nvalue="#source:@ca_estado_req" xsize="40" mode="OPT" required="0" label="Estado Referencia">
					<options>
						<option text="Abierta" value="A"/>
						<option text="Inicializada" value="I"/>
						<option text="Cerrada" value="C"/>
						<option text="Anulada" value="N"/>
					</options>
				</form:ComboBox>
				<form:DateTime name="f_desde_req" nvalue="#source:@f_desde_req" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_hasta_req" nvalue="#source:@f_hasta_req" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl50" width="100%" visible=""/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
