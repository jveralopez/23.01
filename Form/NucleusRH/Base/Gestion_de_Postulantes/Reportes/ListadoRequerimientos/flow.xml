<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Base.Gestion_De_Postulantes.Resportes.ListadoRequerimientos" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoRequerimientos">
		Flow para Nomad.Base.Liquidacion.Liquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoRequerimientos.Filtro.form" doc-path="#FILTERDATA:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoRequerimientos.Filtro.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoRequerimientos.Filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Gestion_de_Postulantes.ListadoRequerimientos.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="105 - Listado de Requerimientos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-Base.Gestion_De_Postulantes.Resportes.ListadoRequerimientos" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-Base.Gestion_De_Postulantes.Resportes.ListadoRequerimientos" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
