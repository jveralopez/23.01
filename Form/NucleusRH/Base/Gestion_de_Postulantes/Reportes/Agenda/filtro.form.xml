<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Gestion_de_Postulantes.Reportes.ListadoReferencias.Filtro.form" doc="source">
	<form:Title>
		<form:Label label="200 - Agenda del Evaluador" name="lbl" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b20" width="100%" visible=""/>
		<form:Columns name="cols">
			<form:Column name="col1">
				<form:ComboBox queryname1="NucleusRH.Base.Gestion_de_Postulantes.Evaluadores.EVALUADOR.INFO" xsize="40" mode="QRY" nvalue="#source:@oi_evaluador" required="0" label="Evaluador" name="oi_evaluador">
					<options/>
				</form:ComboBox>
				<form:ComboBox xsize="40" mode="OPT" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado">
					<options>
						<option text="Planificada" value="PL"/>
						<option text="Realizada" value="RE"/>
						<option text="Postergada" value="PO"/>
						<option text="No Realizada" value="NR"/>
					</options>
				</form:ComboBox>
				<form:ComboBox queryname1="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Examenes.TIPO_EXAMEN.INFO" nvalue="#source:@oi_tipo_examen" name="oi_tipo_examen" label="Tipo de Evaluaci&#243;n" xsize="40" mode="QRY" required="0"/>
				<form:DateTime name="f_desde" nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" descr="Es la fecha de Creacion del Requerimiento" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
