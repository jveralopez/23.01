		///////////////////////////////////////////////////////////////////////////////          
//EVENTOS
function OnLoad()
{                                                                                                             
	Ctrl("txt_ini_day"  ).SetXValue(Ctrl("fec_ini").GetXValue()==""?"*":Ctrl("fec_ini").GetXValue().substr(2,2));
	Ctrl("txt_ini_month").SetXValue(Ctrl("fec_ini").GetXValue()==""?"*":Ctrl("fec_ini").GetXValue().substr(0,2));

	Ctrl("txt_fin_day"  ).SetXValue(Ctrl("fec_fin").GetXValue()==""?"*":Ctrl("fec_fin").GetXValue().substr(2,2));
	Ctrl("txt_fin_month").SetXValue(Ctrl("fec_fin").GetXValue()==""?"*":Ctrl("fec_fin").GetXValue().substr(0,2));
}

function ACCEPT()
{       
	if (Ctrl("txt_ini_day").GetXValue()=="*" || (Ctrl("txt_ini_month").GetXValue()=="*"))          
	{
		Ctrl("fec_ini").SetXValue("");
		Ctrl("txt_ini").SetXValue("*");
	} else
	{
		Ctrl("fec_ini").SetXValue(Ctrl("txt_ini_month").GetXValue()+Ctrl("txt_ini_day").GetXValue());
		Ctrl("txt_ini").SetXValue(Ctrl("txt_ini_day").GetCValue()+"-"+Ctrl("txt_ini_month").GetCValue());
	}
	
	if (Ctrl("txt_fin_day").GetXValue()=="*" || (Ctrl("txt_fin_month").GetXValue()=="*"))          
	{
		Ctrl("fec_fin").SetXValue("");
		Ctrl("txt_fin").SetXValue("*");
	} else
	{
		Ctrl("fec_fin").SetXValue(Ctrl("txt_fin_month").GetXValue()+Ctrl("txt_fin_day").GetXValue());
		Ctrl("txt_fin").SetXValue(Ctrl("txt_fin_day").GetCValue()+"-"+Ctrl("txt_fin_month").GetCValue());
	}
	
	Ctrl("txt_page").SetXValue(Ctrl("id_page").GetCValue());

	return true;
}
	</form:Scripts>
