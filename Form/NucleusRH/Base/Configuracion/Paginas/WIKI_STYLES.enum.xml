<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Configuracion.Paginas.WIKI_STYLES.enum" default_action="COMBO">
	<flow:info label="Flow guia para NucleusRH.Base.Liquidacion.Liquidacion.atribFiltro.enum"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry output-doc="RS" qry="COMBO"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="COMBO">
			<qry:main>
				<ROWS>
					<qry:insert-select name="SQL1"/>
				</ROWS>
			</qry:main>
			<qry:select doc="SOURCE" name="SQL1">
				<qry:xquery>
					for $r in FS('./APP/{%=#PROXY:@PATH%}/HTML')/LIST/FILE[contains(upper_case(@name),'.STYLE_WIKI.')]
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="SQL2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="SQL2">
				<qry:xquery>
					for $r in FILESTORE('HTML/{%=#SOURCE:@name %}')/html:html
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute name="code" value="substring(#SOURCE:@name,0,string-length(#SOURCE:@name)-4)"/>
						<qry:attribute name="value" value="substring(#SOURCE:@name,0,string-length(#SOURCE:@name)-4)"/>
						<qry:attribute name="text" value="$r/@name"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
