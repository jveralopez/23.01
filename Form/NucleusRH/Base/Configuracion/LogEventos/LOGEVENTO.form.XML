<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Configuracion.LogEventos.LOGEVENTO.MAIN.STD_REG.autoform" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" name="NucleusRH.Base.Configuracion.LogEventos.LOGEVENTO.form">
	<form:Help/>
	<form:Scripts/>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW" label="Crear Log de Evento"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT" label="Modificar Log de Evento"/>
				<form:Label nowrap="1" align="center" visible="SHOW" style="S3 LCol_w" name="GEN_SHOW" label="Consultar Log de Evento"/>
				<form:Label nowrap="1" align="center" style="S3 LCol_w" dynamic="1" name="OBJ" visible="SHOW|EDIT"/>
				<form:Label nowrap="1" align="center" style="S2 LCol_w" dynamic="1" name="PAR"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_cols">
			<form:Column name="main_col"/>
		</form:Columns>
		<form:Hidden name="HiLockREG"/>
		<form:Hidden name="PARENT" nvalue="#source:@PARENT"/>
		<form:Hidden name="ID" nvalue="#source:@ID"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" descrip="Aceptar" img="OK" label="Aceptar" visible="NEW|EDIT" startvalidate="1">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="BB1" width="20px"/>
				<form:Button visible="SHOW" descrip="Volver" img="BACK" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button name="CANCEL" descrip="Cancelar" img="CANCEL" label="Cancelar" visible="NEW|EDIT">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
