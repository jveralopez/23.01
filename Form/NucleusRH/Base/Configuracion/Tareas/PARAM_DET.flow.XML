<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" description="Flow para responder las acciones sobre las tareas." extends="NucleusRH.Base.Configuracion.Params.DETAIL.MAIN.STD.flow" name="NucleusRH.Base.Configuracion.Tareas.PARAM_DET.flow" default_action="LIST">
	<flow:info label="Flow para responder las acciones sobre las tareas."/>
	<flow:declare>
		<qry:define declare="&lt;DATA PARENT=&quot;301&quot; /&gt;" name="QRY_FIND">
			<qry:main doc="SOURCE">
				<DATA>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</DATA>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select 
	A.oi_param
from 
	CFG09_TAREAS as A
where 
	A.oi_tarea={$SOURCE/@PARENT}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PARENT" value="$r/@oi_param"/>
					<qry:attribute name="ID" value="$r/@oi_param"/>
					<qry:attribute name="ID" value="iif($SOURCE/@LIST='',@ID,$SOURCE/@LIST)"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="LIST">
			<doc:load-qry input-doc-path="#SOURCE:" qry="QRY_FIND" output-doc="SELECT"/>
			<flow:open-form mode="LIST" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusRH.Base.Configuracion.Params.DETAIL.MAIN.STD_LIST.autoform"/>
		</flow:action>
		<flow:action name="EDIT">
			<doc:load-qry input-doc-path="#SOURCE:" qry="QRY_FIND" output-doc="SELECT"/>
			<flow:open-form mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusRH.Base.Configuracion.Params.DETAIL.MAIN.STD_REG.autoform"/>
		</flow:action>
	</flow:main>
</flow:flow>
