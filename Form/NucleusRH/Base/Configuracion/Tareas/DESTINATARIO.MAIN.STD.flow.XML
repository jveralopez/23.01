<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN.STD.autoflow" default_action="ADD_OWNER" name="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN.STD.flow">
	<flow:info label="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN.STD.autoflow"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="PARENT"/>
		<doc:define name="SELECT">
			<DATA id=""/>
		</doc:define>
		<doc:define name="RS_c_mail"/>
		<qry:define name="QRY_c_mail">
			<qry:include name="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAILS"/>
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="SQL1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="ADD_MAIL">
			<doc:set-attribute to-attr-path="#SELECT:@PARENT" from-attr-path="#SOURCE:@GRAND"/>
			<flow:open-form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_MAIL.STD_REG.autoform" mode="NEW" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ADD_ETTY">
			<doc:set-attribute to-attr-path="#SELECT:@PARENT" from-attr-path="#SOURCE:@GRAND"/>
			<flow:open-form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_ETTY.STD_REG.autoform" mode="NEW" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ADD_MAIL_2">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_MAIL.STD_REG.autoform" mode="NEW" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ADD_ETTY_2">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_ETTY.STD_REG.autoform" mode="NEW" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="DEL_2">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO"/>
			<doc:load-object id-path="#SOURCE:@LIST" doc="DDO" load-child="1" load-all="1" class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO"/>
			<doc:delete-object doc-path="#DDO:"/>
			<doc:save-object doc="DDO" class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_ETTY.STD_REG.autoform" name="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_ETTY.STD_REG.autoform:NEW" extends="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN.STD_REG.autoform:NEW" mode="NEW" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="INT-CREATE">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO"/>
			<doc:set-attribute from-value="ETTY" to-attr-path="#DDO:@c_tipo"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_MAIL.STD_REG.autoform" name="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN_MAIL.STD_REG.autoform:NEW" extends="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO.MAIN.STD_REG.autoform:NEW" mode="NEW" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="INT-CREATE">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Configuracion.Tareas.DESTINATARIO"/>
			<doc:set-attribute from-value="MAIL" to-attr-path="#DDO:@c_tipo"/>
		</flow:action>
	</flow:form>
</flow:flow>
