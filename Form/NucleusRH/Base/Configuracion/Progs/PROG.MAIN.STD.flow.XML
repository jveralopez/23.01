<flow:flow xmlns:flow="nomad_engine.flow" extends="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.autoflow" default_action="LIST" name="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.flow">
	<flow:info label="NucleusRH.Base.Configuracion.Progs.PROG.MAIN.STD.autoflow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="ACTIVAR">
			<flow:exec-method class="NucleusRH.Base.Configuracion.Progs.PROG" method="Activate">
				<flow:param attr-path="#SOURCE:@PARENT" name="pOI" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DETENER">
			<flow:exec-method method="Inactivate" class="NucleusRH.Base.Configuracion.Progs.PROG">
				<flow:param attr-path="#SOURCE:@PARENT" name="pOI" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="TEST">
			<flow:exec-method method="Execute" class="NucleusRH.Base.Configuracion.Progs.PROG">
				<flow:param attr-path="#SOURCE:@PARENT" name="pOI" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
</flow:flow>
