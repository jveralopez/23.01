<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD.autoflow" default_action="LIST" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD.flow">
	<flow:info label="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD.autoflow"/>
	<flow:declare>
		<doc:define name="DOC_LOCAL">
			<PARAM/>
		</doc:define>
		<doc:define name="DOC_OUT"/>
		<qry:define declare="&lt;PARAM PARENT=&quot;12&quot;/&gt;" name="qry_grupo_evento">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_KEY" doc-path="#SOURCE:."/>
					<qry:append-doc name="PARAM" doc-path="."/>
					<qry:insert-select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO" doc-path="."/>
				</qry:element>
			</qry:main>
			<qry:select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO" doc="SOURCE">
				<qry:xquery>
					for $r in PATHSTORE('Event')/EVENT
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO2" doc="SOURCE">
				<qry:xquery>
					for $r in FILESTORE('Event\\{%=#SOURCE:@file%}')/GEVENT[contains(concat(',',upper-case(#PARAM:EVE/@d_eve_keyname),','),concat(',',upper-case(@key),','))]
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="text" value="$r/@label"/>
						<qry:attribute name="value" value="#SOURCE:@UUID"/>
					</option>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_KEY" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
	  SELECT
	  	CFG08_DETAIL.d_eve_keyname
	  FROM
	  	CFG07_PROG,
	  	CFG08_DETAIL
	  JOIN
	  	CFG07_PROG.oi_param INNER CFG08_DETAIL.oi_param
	  WHERE
			CFG07_PROG.oi_prog = {#PARAM:@PARENT}	AND
			len(CFG08_DETAIL.d_eve_keyname) &gt; 0
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<EVE>
						<qry:attribute name="hts:delete" value="'1'"/>
						<qry:attribute name="d_eve_keyname" value="iif(@d_eve_keyname!='',@d_eve_keyname + ',' + $r/@d_eve_keyname, $r/@d_eve_keyname)"/>
					</EVE>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="EDIT">
			<doc:set-attribute from-attr-path="#SOURCE:@ID" to-attr-path="#SELECT:@ID"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform"/>
		</flow:action>
	</flow:main>
	<flow:form mode="EDIT_X" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_X"/>
	<flow:form mode="EDIT_D" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_D"/>
	<flow:form mode="EDIT_S" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_S"/>
	<flow:form mode="EDIT_M" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_M"/>
	<flow:form mode="EDIT_A" extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_A"/>
	<flow:form extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" mode="EDIT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT">
		<flow:action name="on-open">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Configuracion.Progs.PROG_DET"/>
			<doc:load-object id-path="#SOURCE:@ID" doc="DDO" load-child="0" load-all="1" class="NucleusRH.Base.Configuracion.Progs.PROG_DET"/>
			<flow:call-action eq="D" if="#DDO:@c_tipo" action="EDIT_D"/>
			<flow:call-action eq="S" if="#DDO:@c_tipo" action="EDIT_S"/>
			<flow:call-action eq="M" if="#DDO:@c_tipo" action="EDIT_M"/>
			<flow:call-action eq="A" if="#DDO:@c_tipo" action="EDIT_A"/>
			<flow:call-action eq="X" if="#DDO:@c_tipo" action="EDIT_X"/>
			<flow:call-action eq="E" if="#DDO:@c_tipo" action="EDIT_E"/>
		</flow:action>
		<flow:action name="EDIT_D">
			<flow:close-form/>
			<flow:open-form mode="EDIT_D" parent-doc-path="#PARENT:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_S">
			<flow:close-form/>
			<flow:open-form mode="EDIT_S" parent-doc-path="#PARENT:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_M">
			<flow:close-form/>
			<flow:open-form mode="EDIT_M" parent-doc-path="#PARENT:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_A">
			<flow:close-form/>
			<flow:open-form mode="EDIT_A" parent-doc-path="#PARENT:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_X">
			<flow:close-form/>
			<flow:open-form mode="EDIT_X" parent-doc-path="#PARENT:" doc-path="#SOURCE:" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_E">
			<flow:close-form/>
			<flow:open-form mode="EDIT_E" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" parent-doc-path="#PARENT:" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.autoform:EDIT" form-class="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form" name="NucleusRH.Base.Configuracion.Progs.PROG_DET.MAIN.STD_REG.form:EDIT_E" mode="EDIT_E" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#DOC_LOCAL:@PARENT"/>
			<flow:log text="JP_DOCLOCAL" text-path="#DOC_LOCAL:"/>
			<doc:load-qry output-doc="DOC_OUT" input-doc-path="#DOC_LOCAL:" qry="qry_grupo_evento"/>
			<flow:attach-doc attach-id="GrupoEventos" doc-path="#DOC_OUT:"/>
		</flow:action>
	</flow:form>
</flow:flow>
