<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Configuracion.Mails.MAIL.MAIN.STD.autoflow" name="NucleusRH.Base.Configuracion.Alertas.MAIL.flow" description="Flow para responder las acciones sobre las alertas." default_action="LIST">
	<flow:info label="Flow para responder las acciones sobre las alertas."/>
	<flow:declare>
		<qry:define declare="&lt;DATA id=&quot;1&quot; /&gt;" name="QRY_FIND">
			<qry:main doc="SOURCE">
				<DATA>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
				</DATA>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select 
	A.oi_mail 
from 
	CFG01_ALERTAS as A
where 
	A.oi_alerta={$SOURCE/@PARENT}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="ID" value="$r/@oi_mail"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="SHOW">
			<doc:load-qry input-doc-path="#SOURCE:" qry="QRY_FIND" output-doc="SELECT"/>
			<flow:open-form mode="SHOW" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusRH.Base.Configuracion.Mails.MAIL.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT">
			<doc:load-qry input-doc-path="#SOURCE:" qry="QRY_FIND" output-doc="SELECT"/>
			<flow:open-form mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusRH.Base.Configuracion.Mails.MAIL.MAIN.STD_REG.form"/>
		</flow:action>
	</flow:main>
</flow:flow>
