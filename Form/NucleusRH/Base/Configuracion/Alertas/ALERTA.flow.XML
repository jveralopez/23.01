<flow:flow xmlns:flow="nomad_engine.flow" description="Flow para responder las acciones sobre las alertas." default_action="LIST" name="NucleusRH.Base.Configuracion.Alertas.ALERTA.flow">
	<flow:info label="Flow para responder las acciones sobre las alertas."/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="ACTIVAR">
			<flow:exec-method class="NucleusRH.Base.Configuracion.Alertas.ALERTA" method="Activate">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.String" mode="in" name="pOI_alerta"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DETENER">
			<flow:exec-method class="NucleusRH.Base.Configuracion.Alertas.ALERTA" method="Inactivate">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.String" mode="in" name="pOI_alerta"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="TEST">
			<flow:exec-method class="NucleusRH.Base.Configuracion.Alertas.ALERTA" method="Test">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.String" mode="in" name="pOI_alerta"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
</flow:flow>
