<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Sanciones.LegajoSanciones.SUSPENSION_PER.ALTA.form" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Interrumpir Suspensi&#243;n" name="GEN_NEW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_columnsSUSPENSION_PER">
			<form:Column name="main_columnsSUSPENSION_PERcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Sanci&#243;n Personal" nvalue="#source:@oi_sancion_per" name="oi_sancion_per"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha Inicio" nvalue="#source:@f_fechahora_ini" name="f_fechahora_ini">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Fin" nvalue="#source:@f_fechahora_fin" name="f_fechahora_fin">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox required="0" enabled="0" mask="###.###.##0" xsize="12" label="Cantidad D&#237;as" nvalue="#source:@e_dias_susp" name="e_dias_susp"/>
				<form:Line width="100%" name="linea1"/>
				<form:DateTime pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha Interrupci&#243;n" nvalue="#source:@f_fechahora_int" name="f_fechahora_int">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="f_validate" name="onValidate" runat="client"/>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Aceptar la Fecha de Interrupcion" img="OK" name="ACCEPT" visible="SHOW" label="Aceptar">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la Operacion" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function f_validate(myThis)
{
	if (myThis.GetXValue() &lt; Ctrl('f_fechahora_ini').GetXValue())
	{
		myThis.SetError("La fecha de Interrupci&#243;n debe ser mayor o igual a la fecha de Inicio.");
		return false;		
	}
	if (myThis.GetXValue() &gt;= Ctrl('f_fechahora_fin').GetXValue())
	{
		myThis.SetError("La fecha de Interrupci&#243;n debe ser menor a la fecha de Fin.");
		return false;		
	}
	return true;
}
	</form:Scripts>
</form:Form>
