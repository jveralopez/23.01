			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#PARENTSOURCE:DOC_DIG_SANP/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.Sanciones.LegajoSanciones.DOC_DIG_SANP.autoform"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:DOC_DIG_SANP/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST" form-class="NucleusRH.Base.Sanciones.LegajoSanciones.DOC_DIG_SANP.autoform"/>
			</flow:action>
			<flow:action name="load-child-LIST">
