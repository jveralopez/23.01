<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Sanciones.Motivos_Sanciones.MOTIVO_SANCION.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Sanciones.Motivos_Sanciones.MOTIVO_SANCION">
	<form:Title width="90%"/>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsMOTIVO_SANCION">
			<form:Column name="main_columnsMOTIVO_SANCIONcolumn1">
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_motivo_sancion" name="c_motivo_sancion"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_motivo_sancion" name="d_motivo_sancion">
					<form:Event runat="client" name="onchange" action="observacion"/>
				</form:TextBox>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n Corta" nvalue="#source:@d_motivo_corta" name="d_motivo_corta"/>
				<form:ComboBox queryname1="NucleusRH.Base.Sanciones.Sanciones.SANCION.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Sanci&#243;n Default" nvalue="#source:oi_sancion/@value" name="oi_sancion"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Cantidad Repeticiones" nvalue="#source:@e_cant_repeticion" name="e_cant_repeticion"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_motivo_sancion" name="o_motivo_sancion"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_motivo_sancion" name="c_motivo_sancion"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_motivo_sancion" name="d_motivo_sancion"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Sanci&#243;n Default" attrname="oi_sancion" name="oi_sancion"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Sanciones/Motivos_Sanciones/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Sanciones/Motivos_Sanciones/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Sanciones/Motivos_Sanciones/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Sanciones/Motivos_Sanciones/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function observacion()
{
	Ctrl('o_motivo_sancion').SetXValue(Trim(Ctrl('d_motivo_sancion').GetXValue()));
	
}

	</form:Scripts>
</form:Form>
