<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" doc="source" name="NucleusRH.Base.Sanciones.Reportes.Sanciones.filter.form">
	<form:Title>
		<form:Label label="001 - Sanciones" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="empresa"/>
					<form:Rower name="rwerfechas" label="Fecha" separation="5">
						<form:DateTime pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Ingreso Desde" mask="dd/mm/yyyy" nvalue="#source:@f_desde" name="f_desde">
							<form:SButtons>
								<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lbl_fecha_hasta" label="..."/>
						<form:DateTime pattern="YYYYMMDD" required="0" enabled="" descr="Fecha Ingreso Hasta" mask="dd/mm/yyyy" nvalue="#source:@f_hasta" name="f_hasta">
							<form:SButtons>
								<form:SButton descrip="Fecha de Ingreso" img="Calendar" visible="" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
					<form:ComboBox nvalue="#source:@oi_motivo_sancion" queryname1="NucleusRH.Base.Sanciones.Motivos_Sanciones.MOTIVO_SANCION.INFO" xsize="40" mode="QRY" required="0" label="Motivo Sanci&#243;n" name="oi_motivo_sancion" X-POLICY="./FORM/NucleusRH/Base/Sanciones/LegajoSanciones/SANCION_PER/form/oi_motivo_sancion"/>
					<form:ComboBox nvalue="#source:@oi_sancion" queryname1="NucleusRH.Base.Sanciones.Sanciones.SANCION.INFO" xsize="40" mode="QRY" required="0" label="Sanci&#243;n" name="oi_sancion" X-POLICY="./FORM/NucleusRH/Base/Sanciones/LegajoSanciones/SANCION_PER/form/oi_sancion"/>
					<form:ComboBox mode="OPT" required="0" nvalue="#source:@agrupacion" label="Agrupaci&#243;n" name="agrupacion">
						<options>
							<option text="Motivo Sancion" value="1"/>
							<option text="Sanci&#243;n" value="2"/>
						</options>
					</form:ComboBox>
					<form:Combo flow="NucleusRH.Base.Sanciones.Reportes.Sanciones.atribOrden.form" action="COMBO" required="0" nvalue="#source:@orden" name="orden" label="Orden" X-POLICY="./FORM/NucleusRH/Base/Personal/Reportes/LegajosPorEmpresa/filter/form/orden"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns visible="0" name="colsemps" width="100%"/>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
