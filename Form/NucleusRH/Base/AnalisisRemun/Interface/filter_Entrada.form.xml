<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.AnalisisRem.Interface.filter_Entrada.form" doc="source" extends="nomad.Base.interface.form" default_mode="filter_Entrada">
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#SOURCE:@oi_empresa" name="oi_empresa"/>
			<form:CheckBox label="Reemplazar datos Si/No" nvalue="#SOURCE:@chkReemplaza" name="chkReemplaza"/>
			<form:File nvalue="#SOURCE:@file_name" class="INTERFACES" filename="IntVarRemun.txt" required="1" source="1" name="filArchivo" label="Archivo de interface">
				<form:SButtons>
					<form:SButton enabled="" visible="" name="sbHelper" label="Buscar un archivo." img="search">
						<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
					</form:SButton>
				</form:SButtons>
			</form:File>
			<form:Container name="contTexto" rheight="400px" rwidth="902px" label="Aclaraciones" borderwidth="1">
				<form:RowAligner name="dddd">
					<form:Row name="a1">
						<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
						<form:Blank name="blank031"/>
					</form:Row>
					<form:Row name="a2">
						<form:Blank name="blank031"/>
						<form:Label label="Legajo;Periodo;SueldoBasico;Conformado;Adicionales;SujetoRetencion;NoSujetoRetencion;SueldoBruto;Descuentos;SueldoNeto;Contribuciones" name="formato1"/>
					</form:Row>
					<form:Row name="a3">
						<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
						<form:Blank name="blank031"/>
					</form:Row>
					<form:Row name="a4">
						<form:Blank name="blank031"/>
						<form:Label name="validacion1" label="- El legajo debe estar asociado a la empresa selecionada"/>
					</form:Row>
					<form:Row name="a5">
						<form:Blank name="blank031"/>
						<form:Label name="validacion2" label="- El per&#237;odo debe ser formato a&#241;o mes"/>
					</form:Row>
					<form:Row name="importe1">
						<form:Blank name="blank0341"/>
						<form:Label name="validacion31" label="- Los campos deben ser num&#233;ricos"/>
					</form:Row>
					<form:Row name="importe2">
						<form:Blank name="blank0341"/>
						<form:Label name="validacion31" label="* Ser num&#233;rico (entero o decimal)"/>
					</form:Row>
					<form:Row name="importe5">
						<form:Blank name="blank0341"/>
						<form:Label name="validacion32" label="* No debe contener letras o palabras ya que pueden agregarse valores indeseados"/>
					</form:Row>
					<form:Row name="importe3">
						<form:Blank name="blank0341"/>
						<form:Label name="validacion31" label="* El separador decimal debe ser punto"/>
					</form:Row>
					<form:Row name="importe4">
						<form:Blank name="blank0341"/>
						<form:Label name="validacion31" label="* Sin separador de miles"/>
					</form:Row>
					<form:Row name="a7">
						<form:Label style="M1 LCol_t" name="ejemplo" label="Ejemplo:"/>
						<form:Blank name="blank035"/>
					</form:Row>
					<form:Row name="a8">
						<form:Blank name="blank036"/>
						<form:Label name="ejemplo1" label="161;200907;10.000;2.000;12.000;8.000 ;8.000 ;99.000;-2.000;14.000;3.000"/>
					</form:Row>
					<form:Row name="a9">
						<form:Blank name="blank037"/>
						<form:Label name="ejemplo2" label="260;200907;20.000;4.000;24.000;99.000;16.000;32.000;-4.000;28.000;6.000"/>
					</form:Row>
					<form:Row name="a11">
						<form:Blank name="blank038"/>
						<form:Label name="ejemplo3" label="210;200907;30.000;6.000;36.000;24.000;24.000;48.000;-6.000;42.000;9.000"/>
					</form:Row>
				</form:RowAligner>
			</form:Container>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button label="Aceptar" img="ok" name="btnfilter_Entrada" descrip="Consultar los Legajos seleccionados" note="Consultar los Legajos seleccionados">
					<form:Event action="EJECUTAR_CLICK" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
		<form:RowAligner visible="aa" columns="3" name="botonera">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="" note="" img="ok" label="Aceptar" name="btnAccept" visible="" enabled="" X-POLICY="./FORM/NucleusRH/Base/AnalisisRemun/Interface/filter_Entrada/form/btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" img="cancel" label="Cancelar" name="btnCancel" visible="" enabled="" X-POLICY="./FORM/NucleusRH/Base/AnalisisRemun/Interface/filter_Entrada/form/btnCancel">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function EJECUTAR_CLICK()
{
	if (Ctrl("oi_empresa").GetXValue()=="") 
		{ alert("Debe seleccionar una Empresa"); return false; }

	if (Ctrl("filArchivo").GetXValue()=="") 
		{ alert("Debe seleccionar un archivo para procesar"); return false; }


	
	if (!Ctrl("main").Validate()) return false;
	
	Ctrl("main").DoEvent("Ejecutar");
	return true;
}
	</form:Scripts>
	<form:Event action="Ejecutar" name="Ejecutar" runat="server"/>
</form:Form>
