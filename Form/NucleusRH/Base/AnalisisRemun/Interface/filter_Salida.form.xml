<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.AnalisisRem.Interface.filter_Salida.form" doc="source" extends="nomad.Base.interface.form" default_mode="filter_Salida">
	<form:Center width="100%">
		<form:Blank visible="" width="100%" name="bl3"/>
		<form:Label style="M1 LCol_g" align="center" visible="" label="Criterios de B&#250;squeda" name="lbl22"/>
		<form:Blank visible="" width="100%" name="bl312"/>
		<form:RowAligner columns="1" name="RAFiltros">
			<form:Row name="Rcampo1">
				<form:ComboBox nvalue="#FILTERDATA:@oi_empresa" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" name="oi_empresa"/>
			</form:Row>
			<form:Row name="Rcampo1as">
				<form:DateTime nvalue="#SOURCE:@Periodo" name="periodo" label="Per&#237;odo" mask="dd/mm/yyyy" required="1" pattern="YYYYMM">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:Blank visible="" width="100%" name="bl33"/>
		<form:RowAligner name="RAFiltros1">
			<form:Row name="Rcampo2">
				<form:Grid idvalue="#SOURCE:@id" nvalue="#source:LIQUIDACIONES" proto="&lt;LIQUIDACION/&gt;" width="485px" doc="SOURCE" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="3" descrip="" note="" name="grdDatosLiq">
					<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.LM.COMPLEJO.NOSIM.FLOW" action="HELP">
						<helper-mess>
							{grdDatosLiq.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCE:@id" label="Empresa - Liquidaci&#243;n" name="oi_liquidacion" length="30" xsize="15" enabled="" required="0">
								<form:STexts>
									<form:SText name="txt1" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Liquidacion.Liquidacion.LIQUIDACION.NOSIM.Guia.flow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton name="SEARCH" label="Search" img="SEARCH">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blank11"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" label="Aceptar" img="ok" name="btnfilter_Salida" descrip="Consultar los Legajos seleccionados" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="btnBACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
		<form:RowAligner visible="aa" columns="3" name="botonera">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="" note="" img="ok" label="Aceptar" name="btnAccept" visible="" enabled="" X-POLICY="./FORM/NucleusRH/Base/AnalisisRemun/Interface/filter_Salida/form/btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" img="cancel" label="Cancelar" name="btnCancel" visible="" enabled="" X-POLICY="./FORM/NucleusRH/Base/AnalisisRemun/Interface/filter_Salida/form/btnCancel">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="Ejecutar" name="Ejecutar" runat="server"/>
</form:Form>
