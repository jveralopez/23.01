<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.AnalisisRemun.Interface.flow_Salida" default_action="initialize" extends="Nomad.Base.interface.batch.flow">
	<flow:info label="Flow para NucleusRH.Base.AnalisisRemun.Interface"/>
	<flow:declare>
		<qry:define declare="&lt;FILTRO oi_empresa=&quot;164&quot; c_estado=&quot;&quot; oi_tipo_liq=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN3=&quot;&quot; ATRIB_ORDEN4=&quot;&quot; ORDEN4=&quot;&quot; Periodo=&quot;200901&quot;&gt;&lt;LIQUIDACIONES /&gt;&lt;PERIODOS /&gt;&lt;/FILTRO&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:attribute name="Periodo" value="#SOURCE:FILTRO@id"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('select 
					t19.OI_LIQUIDACION, 
					t19.c_liquidacion, 
					t19.d_titulo,
					org03.c_empresa,
					t19.e_periodo 
					
					from 
					LIQ19_LIQUIDACION as t19, 
					ORG03_EMPRESAS as org03
					JOIN
					t19.OI_EMPRESA INNER org03.OI_EMPRESA 					
	        where 1=1       
	        and t19.l_simulacion = 0
	        {%? (#SOURCE:@oi_empresa!='')	{% and t19.oi_empresa= {%=#SOURCE:@oi_empresa %} %} {% %} %}
	        {%? (string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id)!='') {% AND t19.oi_liquidacion in ({%=string(#SOURCE:LIQUIDACIONES/LIQUIDACION/@id) %}) %} {%  %} %}
	        {%? (#SOURCE:@Periodo!='')	{% and t19.e_periodo= {%=#SOURCE:@Periodo %} %} {% %} %}
	        
	        order by 
        	oi_liquidacion	ASC')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_LIQUIDACION" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@OI_LIQUIDACION" name="id"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@c_liquidacion" name="c_liquidacion"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@d_titulo" name="d_titulo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS&gt;&#13;&#10; &lt;ROWS&gt;&#13;&#10; &lt;ROW id=&quot;1&quot;/&gt;&#13;&#10; &lt;/ROWS&gt;&#13;&#10;&lt;/DATOS&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.e_periodo as e_periodo, 
					t0.n_basico as n_basico, 
					t0.n_adicionales as n_adicionales, 
					t0.n_conformado as n_conformado, 
					t0.n_sujeto as n_sujeto, 
					t0.n_nosujeto as n_nosujeto, 
					t0.n_bruto as n_bruto, 
					t0.n_descuento as n_descuento, 
					t0.n_neto as n_neto, 
					t0.n_contribuciones as n_contribuciones, 
					t1.oi_personal_emp, 
					t1.e_numero_legajo as e_numero_legajo, 
					SEC.policy, t1.e_numero_legajo as CODE, 
					PER01_PERSONAL.d_ape_y_nom as TEXT, 
					t1.oi_empresa as oi_empresa, 
					t1.oi_personal as oi_personal 
					
					FROM 
					REM02_PERSONAL_EMP as t0,
					PER02_PERSONAL_EMP as t1, PER01_PERSONAL as PER01_PERSONAL,
					NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC
					 
					JOIN 
					t0.oi_personal_emp LEFT OUTER t1.oi_personal_emp,
					t1.oi_personal_emp LEFT OUTER SEC.id, 
					PER01_PERSONAL.oi_personal INNER t1.oi_personal 
					WHERE
    			{%? 
    				(string(#PARAM:ROWS/ROW/@id)!='') 
    				{% 
    					t1.oi_personal_emp IN ({%=string(#PARAM:ROWS/ROW/@id) %}) 
    				%} 
    				{% 1 = 2  %} 
    			%}
    			
					ORDER BY oi_personal_emp asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="ID-REM02_PERSONAL_EMP" value="$r/@oi_personal_emp"/>
						<qry:attribute name="e_periodo" value="$r/@e_periodo"/>
						<qry:attribute name="n_basico" value="$r/@n_basico"/>
						<qry:attribute name="n_adicionales" value="$r/@n_adicionales"/>
						<qry:attribute name="n_conformado" value="$r/@n_conformado"/>
						<qry:attribute name="n_sujeto" value="$r/@n_sujeto"/>
						<qry:attribute name="n_nosujeto" value="$r/@n_nosujeto"/>
						<qry:attribute name="n_bruto" value="$r/@n_bruto"/>
						<qry:attribute name="n_descuento" value="$r/@n_descuento"/>
						<qry:attribute name="n_neto" value="$r/@n_neto"/>
						<qry:attribute name="n_contribuciones" value="$r/@n_contribuciones"/>
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:attribute name="c_alternativo" value="$r/@B_c_alternativo"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
						<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
						<qry:insert-select doc-path="." name="FIND-PER-DESCR"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="FIND-PER-DESCR">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.e_numero_legajo AS COD, 
				PER01_PERSONAL.d_ape_y_nom AS DES 
				FROM 
				PER02_PERSONAL_EMP, PER01_PERSONAL			
				JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE PER02_PERSONAL_EMP.oi_personal_emp ={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="'[' + $r/@COD + '] ' + $r/@DES" name="descr"/>
					<qry:attribute value="$r/@DES" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<FILTRO oi_empresa="" c_estado="" oi_tipo_liq="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="" ATRIB_ORDEN4="" ORDEN4="">
				<LIQUIDACIONES/>
				<PERIODOS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="source">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.AnalisisRemun.Interface.filter_Salida.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.AnalisisRemun.Interface.filter_Salida.form" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.AnalisisRemun.Interface.filter_Salida.form:FILTER" mode="FILTER">
		<flow:action name="Ejecutar">
			<flow:log text-path="#SOURCE:" text="log__filter"/>
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#SOURCE:"/>
			<flow:log text-path="#QRY:" text="logQRY"/>
			<flow:exec-method class="NucleusRH.Base.AnalisisRemun.InterfaceOut_LegAnalisis.SALIDA" method="ejec_outRemun" priority="4" out-attr-path="#BATCHDOC:@batch-id">
				<flow:param name="par_oi_Empresa" type="Nomad.NSystem.String" attr-path="#SOURCE:@oi_empresa" mode="in"/>
				<flow:param attr-path="#SOURCE:@Periodo" name="par_Periodo" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="Doc_Liq" doc="QRY" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="NucleusRH.Base.AnalisisRemun.Interface.INTERFACE.batch.form" doc-path="#BATCHDOC:" mode="SHOW"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.AnalisisRemun.Interface.INTERFACE.batch.form" name="NucleusRH.Base.AnalisisRemun.Interface.INTERFACE.batch.form:SHOW" extends="Nomad.Base.interface.batch.form:SHOW" mode="SHOW" doc="SOURCE"/>
</flow:flow>
