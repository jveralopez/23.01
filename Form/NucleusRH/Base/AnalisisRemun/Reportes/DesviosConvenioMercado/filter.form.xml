<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="CONCEPTO.FILTRO" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Analisis de desvios de las remuneraciones por Convenio del Mercado" nowrap="1" align="center" style="S3 LCol_w" name="lbl"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="columnas">
			<form:Column width="100%" name="col1">
				<form:Blank name="tttt"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
				<form:ComboBox queryname1="NucleusRH.Base.AnalisisRemun.Convenios.CONVENIO.INFO" nvalue="#source:@oi_convenioMercado" label="Convenio Mercado" name="oi_convenioMercado" help-stop="1" xsize="40" mode="QRY" required="1"/>
				<form:ComboBox nvalue="#source:@diferencia" name="diferencia" mode="OPT" xsize="30" required="1" label="Diferencia">
					<options>
						<option text="Sueldo Basico" value="B"/>
						<option text="Adicionales" value="A"/>
						<option text="Conformado" value="C"/>
					</options>
					<form:Opts/>
				</form:ComboBox>
				<form:ComboBox nvalue="#source:@agrupar" mode="OPT" xsize="30" required="1" label="Agrupar por" name="agrupar">
					<options>
						<option text="Sin Agrupaci&#243;n" value="S"/>
						<option text="Convenio/Categoria" value="C"/>
						<option text="Grupos de Centros de Costos / Centros de Costos" value="G"/>
					</options>
					<form:Opts/>
					<form:Opts/>
				</form:ComboBox>
				<form:ComboBox help-stop="1" queryname1="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.INFO" label="Centro de Costo" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_ccosto" name="oi_ccosto"/>
				<form:DateTime nvalue="#source:@e_periodo" name="periodo" label="Per&#237;odo" mask="mm/yyyy" required="0" pattern="YYYYMM">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox nvalue="#source:@oi_convenioInterno" label="Convenio Interno" name="oi_convenioInterno" queryname1="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO" help-stop="1" xsize="40" mode="QRY" required="0"/>
				<form:Label label="Si usted coloca un convenio interno la comparacion se hara entre los dos convenios" name="aaa"/>
				<form:Label label="por medio de la secuencia de las categoria. Si usted no coloca un convenio interno" name="aaa1"/>
				<form:Label label="la comparacion se hara directamente con la categor#interna correspondiente de cada categoria del convenio del mercado." name="aaa2"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Filtrar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button name="CANCEL" img="back" label="Volver" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
