<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" doc="source" name="NucleusRH.Base.Seguridad.Organigramas.GRUPOS.form">
	<form:Help/>
	<form:Scripts>
		function Find()
{              
 	Ctrl("LIST").filter("",Ctrl("iter_search").GetCValue());
} 

                                   
function Validar()
{
 	if(Ctrl("LIST_CHECKS").CountRow() &gt; 0) 
		return true;
	else 
	{  
		alert("Debe seleccionar alg&#250;n Grupo");
		return false;
	}
}

	</form:Scripts>
	<form:Title>
		<form:Label label="Agregar Grupos a Estructura de Seguridad" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="95%">
		<form:Blank height="20px" name="blk1"/>
		<form:Columns name="C1">
			<form:Column name="C1" separation="2" align="center" valign="top">
				<form:TextBox visible="SHOW" xsize="50" length="100" name="iter_search" label="Buscar" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Column>
		</form:Columns>
		<form:Blank height="20px" name="blk2"/>
		<form:ListView arr-control="LIST_CHECKS" docname="RS" paging="1" rows="-250" name="LIST">
			<form:LVColumns>
				<form:LVColumn visible="0" align="left" sorteable="1" width="40px" type="string" label="Grupo" attrname="oi_grupo" name="oi_grupo"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_grupo" name="c_grupo"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_grupo" name="d_grupo"/>
			</form:LVColumns>
		</form:ListView>
		<form:HiddenArr name="LIST_CHECKS" nvalue="#CHECKS:" proto="&lt;ITEM /&gt;">
			<form:Attr source="@oi_grupo" name="id"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button img="ok" label="Guardar" name="ACCEPT">
					<form:Event action="Validar" name="onClick" runat="client"/>
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" label="Cancelar" name="CANCEL">
					<form:Event name="onclick" action="CANCEL" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<form:Resource declare="&lt;PARAM search=&quot;O&quot;/&gt;" name="qry:datosgru">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				SELECT 
					SEG02_GRUPOS.oi_grupo,
					SEG02_GRUPOS.c_grupo,
					SEG02_GRUPOS.d_grupo
				FROM 
					SEG02_GRUPOS
				WHERE
					SEG01_GRUPO_ESTR.oi_grupo_estr in ({%=#PARAM:@IDS%})	
				{%?($PARAM/@search!='')
 {% 
 	and contain(ucase(
	 	SEG02_GRUPOS.c_grupo
	 ), {upper-case($PARAM/@search)})
 %}
 {% 
 %}
%}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_grupo" name="id"/>
						<qry:attribute name="c_grupo" value="$r/@c_grupo"/>
						<qry:attribute name="d_grupo" value="$r/@d_grupo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;DATO oi_estructura=&quot;1201&quot;/&gt;" name="qry:gru">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				SELECT 
					SEG02_GRUPOS.oi_grupo
				FROM 
					SEG02_GRUPOS
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_grupo" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
