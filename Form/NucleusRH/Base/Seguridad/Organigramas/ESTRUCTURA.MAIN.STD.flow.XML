<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD.autoflow" default_action="LIST" name="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD.flow">
	<flow:info label="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD.autoflow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="ADD">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<doc:set-attribute to-attr-path="#SELECT:@c_estr_padre" from-attr-path="#SOURCE:@c_estr_padre"/>
			<flow:open-form mode="NEW" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD_REG.autoform"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENT" extends="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD_REG.autoform:NEW" mode="NEW" doc="SOURCE" form-class="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD_REG.autoform" name="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA.MAIN.STD_REG.form:NEW">
		<flow:action name="INT-CREATE">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Seguridad.Organigramas.ESTRUCTURA"/>
			<doc:set-attribute from-attr-path="#SELECT:@c_estr_padre" to-attr-path="#DDO:@c_estr_padre"/>
		</flow:action>
	</flow:form>
</flow:flow>
