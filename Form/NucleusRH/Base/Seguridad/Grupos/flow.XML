<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Seguridad.Grupos.autoflow" name="NucleusRH.Base.Seguridad.Grupos">
	<flow:info label="Flow para NucleusRH.Base.Seguridad.Grupos"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_grupo as oi_grupo, SEC.policy FROM SEG02_GRUPOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Seguridad.Grupos.GRUPO\') as SEC JOIN t0.oi_grupo LEFT OUTER SEC.id  ORDER BY oi_grupo asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_grupo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_grupo as oi_grupo, t0.c_grupo as c_grupo, t0.d_grupo as d_grupo, t0.oi_grupo_seguridad as oi_grupo_seguridad, t0.d_gruposeg as d_gruposeg, SEC.policy, t0.c_grupo as CODE, t0.d_grupo as TEXT FROM SEG02_GRUPOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Seguridad.Grupos.GRUPO\') as SEC JOIN t0.oi_grupo LEFT OUTER SEC.id  ORDER BY oi_grupo asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_grupo"/>
						<qry:attribute name="c_grupo" value="$r/@c_grupo"/>
						<qry:attribute name="d_grupo" value="$r/@d_grupo"/>
						<qry:attribute name="oi_grupo_seguridad" value="$r/@oi_grupo_seguridad"/>
						<qry:attribute name="d_gruposeg" value="$r/@d_gruposeg"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.filter.autoform" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:group Name="GRUPO">
		<flow:form form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.filter.autoform" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.filter.autoform:FILTER" extends="FILTER:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
				<flow:close-form/>
				<flow:call-action action="FILTER"/>
			</flow:action>
			<flow:action name="inits-DDO">
				<doc:new-object doc="DDO" class="NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.noreg.autoform"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform"/>
			</flow:action>
			<flow:action name="Load-FILTER">
				<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
			<flow:action name="Save-FILTER">
				<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSROOT:NOREG:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.noreg.autoform:EDIT" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#QRY:ROW[1]/@id" class="NucleusRH.Base.Seguridad.Grupos.GRUPO" doc="DDO"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.form:SHOW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform:LIST" extends="CLASSROOT:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" mode="LIST">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Seguridad.Grupos.GRUPO"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#FORM:ctrl[@id='LIST']/@xval" class="NucleusRH.Base.Seguridad.Grupos.GRUPO" doc="DDO"/>
			</flow:action>
			<flow:action name="save-DDO">
				<doc:save-object class="NucleusRH.Base.Seguridad.Grupos.GRUPO" doc="DDO"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#DDO:" class="NucleusRH.Base.Seguridad.Grupos.GRUPO" doc="DDO"/>
				<doc:save-object class="NucleusRH.Base.Seguridad.Grupos.GRUPO" doc="DDO"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.form:EDIT" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.form:NEW" form-class="NucleusRH.Base.Seguridad.Grupos.GRUPO.form" mode="NEW"/>
	</flow:group>
</flow:flow>
