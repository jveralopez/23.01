<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Seguridad.Grupos.GRUPO.autoform" doc="source" name="NucleusRH.Base.Seguridad.Grupos.GRUPO">
	<form:Help/>
	<form:Scripts>
		function SetValue()
{        
	if(Ctrl("oi_grupo_seguridad").GetXValue() != null)
	{
		Ctrl("d_gruposeg").SetXValue(Ctrl("oi_grupo_seguridad").GetCValue());
	}
}
	</form:Scripts>
	<resource name="INFO" declare="&lt;DATA  /&gt;">
		<qry:main doc="SOURCE">
			<ROWS>
				<qry:insert-select name="Nomad.Base.Login.Grupos.GRUPO.QUERY" doc-path="#SOURCE:."/>
			</ROWS>
		</qry:main>
		<qry:select name="Nomad.Base.Login.Grupos.GRUPO.QUERY" doc="SOURCE">
			<qry:out>
				<qry:if test="#SOURCE:@OI_FIND=''">
					<qry:then>
						<qry:insert-select name="Nomad.Base.Login.Grupos.GRUPO.QUERY.PATH" doc-path="#SOURCE:"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="FILE" value="#SOURCE:@oi_find+'.GRUPO.XML'"/>
						<qry:insert-select name="Nomad.Base.Login.Grupos.GRUPO.QUERY.DDO" doc-path="."/>
					</qry:else>
				</qry:if>
			</qry:out>
		</qry:select>
		<qry:select name="Nomad.Base.Login.Grupos.GRUPO.QUERY.PATH" doc="SOURCE">
			<qry:xquery>
				for $r in METHOD('Nomad.Base.Report.Listas.INDICE:SuperComboIndex({\'Nomad\\\\Base\\\\Login\\\\Grupos\'},{\'Nomad.Base.Login.Grupos.GRUPO.INFO\'},{#SOURCE:@TXT_FIND},{floor(#SOURCE:@START)},{floor(#SOURCE:@LEN)},{#SOURCE:@ORDERBY})')/*
			</qry:xquery>
			<qry:out>
				<qry:insert-element doc-path="$r/ROW"/>
			</qry:out>
		</qry:select>
		<qry:select name="Nomad.Base.Login.Grupos.GRUPO.QUERY.DDO" doc="SOURCE">
			<qry:xquery>
				for $r in FILE('Nomad\\Base\\Login\\Grupos\\{%=#SOURCE:@file%}')/GRUPO
			</qry:xquery>
			<qry:out>
				<ROW>
					<qry:attribute name="ID" value="$r/@id"/>
					<qry:attribute name="COD" value="$r/@COD"/>
					<qry:attribute name="DES" value="$r/@DES"/>
				</ROW>
			</qry:out>
		</qry:select>
	</resource>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsGRUPO">
			<form:Column name="main_columnsGRUPOcolumn1">
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_grupo" name="c_grupo"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_grupo" name="d_grupo"/>
				<form:ComboBox xsize="47" required="1" nvalue="#source:@oi_grupo_seguridad" label="Grupo de Seguridad" enabled="NEW|EDIT" name="oi_grupo_seguridad" queryname1="NucleusRH.Base.Seguridad.Grupos.GRUPO.INFO_GS" mode="QRY">
					<options/>
					<form:Event action="SetValue" name="onChange" runat="client"/>
				</form:ComboBox>
				<form:TextBox enabled="0" required="0" ysize="1" xsize="50" length="100" label="Descripci&#243;n GS" nvalue="#source:@d_gruposeg" name="d_gruposeg"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_grupo" name="c_grupo"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_grupo" name="d_grupo"/>
				<form:LVColumn attrname="d_gruposeg" label="Descripci&#243;n GS" name="d_gruposeg" align="left" sorteable="1" width="100px" type="string"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
</form:Form>
