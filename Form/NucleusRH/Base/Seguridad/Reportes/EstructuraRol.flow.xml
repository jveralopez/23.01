<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Liquidacion.Reporte.LegajosPorEmpresa">
	<flow:info label="Flow para NucleusRH.Base.Liquidacion.Reporte.LegajosPorEmpresa"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY"/>
		<doc:define name="PARAMETERS"/>
		<qry:define name="FILTER_ATRIB">
			<qry:main doc="SOURCE">
				<qry:element name="PARAMETERS">
					<qry:attribute type="Nomad.NSystem.String" value="" name="oi_empresa"/>
					<qry:attribute type="Nomad.NSystem.String" value="" name="oi_clase_org"/>
					<qry:attribute type="Nomad.NSystem.String" value="" name="oi_indic_activo"/>
					<qry:attribute type="Nomad.NSystem.String" value="" name="report"/>
					<qry:attribute type="Nomad.NSystem.String" value="" name="oi_tipo_personal"/>
					<qry:attribute type="Nomad.NSystem.String" value="'HTML'" name="salida"/>
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry output-doc="PARAMETERS" qry="FILTER_ATRIB"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="FILTER" form-class="NucleusRH.Base.Seguridad.Reportes.EstructuraRol.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Seguridad.Reportes.EstructuraRol.filter.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Seguridad.Reportes.EstructuraRol.filter.form" mode="FILTER">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Seguridad.Reportes.EstructuraRol" doc-path="#PARAMETERS:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Seguridad.Reportes.EstructuraRol" doc="PARAMETERS"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Seguridad.EstructuraRol.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#PARAMETERS:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="003 - Estructura Rol" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc doc-path="#PARAMETERS:" attach-id="ARRB"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
