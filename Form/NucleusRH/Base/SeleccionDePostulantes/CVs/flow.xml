<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.SeleccionDePostulantes.CVs.autoflow" default_action="initialize" name="CVs">
	<flow:info label="flow para CV"/>
	<flow:declare>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;  &lt;ROW id=&quot;4&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;9&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;8&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;7&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;1&quot; /&gt;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:ROWS" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
						CV.oi_cv, 
						CV.c_cv, 
						CV.d_ape_y_nom, 
						CV.c_sexo,
					 	CV.d_apellido,   
					 	CV.f_nacim,
					 	CV.f_estado
				FROM
					SDP01_CV AS CV				
				WHERE 
					CV.oi_cv in ({%=string(#SOURCE:ROW/@id) %})				
				ORDER BY 
					d_ape_y_nom ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_cv" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_cv" type="Nomad.NSystem.Int"/>
						<qry:attribute name="c_cv" value="$r/@c_cv" type="Nomad.NSystem.Int"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.Int"/>
						<qry:attribute name="f_estado" value="format_date($r/@f_estado, 'dd/mm/yyyy')"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;  &lt;ROW id=&quot;5&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;6&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;2&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;4&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;7&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;3&quot; /&gt;&#13;&#10;  &lt;ROW id=&quot;1&quot; /&gt;&#13;&#10;&lt;/ROWS&gt;" name="LIST">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					CV.oi_cv as oi_cv,
					CV.c_cv as c_cv, 
					CV.d_ape_y_nom as d_ape_y_nom,
					CV.d_apellido,   
					CV.f_nacim,
					CV.c_estado as c_estado, 
					CV.c_nro_doc as c_nro_doc, 
					CV.c_sexo as c_sexo, 
					CV.d_email as d_email
				FROM 
					SDP01_CV as CV
				WHERE
					CV.oi_cv in ({%=string(#SOURCE:ROWS/ROW/@id) %})				
				ORDER BY					
					d_ape_y_nom asc			
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_cv"/>
						<qry:attribute name="c_cv" value="$r/@c_cv"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
						<qry:attribute name="c_sexo" value="$r/@c_sexo"/>
						<qry:attribute name="d_email" value="$r/@d_email"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_empresa="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:group name="CV">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.filter.autoform:FILTER" mode="FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.filter.form" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.filter.form:FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
				<flow:load-user-data name="PER_IDsPersonas" doc="QRY"/>
				<flow:attach-doc attach-id="ARRB" doc-path="#QRY:"/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:load-user-data name="PER_IDsPersonas" doc="QRY"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-SHOW"/>
				<doc:assign-value from-path="#QRY:" to-doc="FILTERDATA"/>
			</flow:action>
			<flow:action name="ADD">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.noreg.autoform" mode="EDIT" extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.noreg.autoform:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.noreg.autoform">
			<flow:action name="ADD">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="goto-list">
				<flow:log text-path="#QRY:" text="ppqry"/>
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#QRY:"/>
				<flow:call-action action="open-flow-LIST"/>
			</flow:action>
			<flow:action name="goto-show">
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
		</flow:form>
		<flow:form mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form:SHOW" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.autoform:SHOW">
			<flow:action name="on-show"/>
			<flow:action name="ADD">
				<doc:new-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="NEWDDOROOT"/>
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form" mode="NEW" doc-path="#NEWDDOROOT:"/>
			</flow:action>
			<flow:action name="EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="ACTIVAR">
				<doc:set-attribute from-value="A" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="INACTIVO">
				<doc:set-attribute from-value="I" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="After-Change">
				<doc:iter-refresh/>
				<doc:iter-move value-path="#DDO:@id"/>
			</flow:action>
		</flow:form>
		<flow:form mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form:NEW" doc="SOURCE" parent-doc="PARENTSOURCE" extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.autoform:NEW"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form"/>
			</flow:action>
			<flow:action name="After-Change">
				<flow:log text="emiQRY" text-path="#QRY:"/>
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#QRY:"/>
				<flow:log text-path="#QRY_LIST:" text="emiQRY_LIST"/>
				<doc:set-attribute to-attr-path="#FORM:ctrl[@id='LIST']/@xval" from-attr-path="#DDO:@id"/>
			</flow:action>
			<flow:action name="After-Back">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#QRY:"/>
			</flow:action>
			<flow:action name="PARENT">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#QRY:"/>
			</flow:action>
			<flow:action name="ACTIVAR">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="A"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
			<flow:action name="INACTIVO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="I"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form" name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.form:EDIT" extends="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.autoform:EDIT" doc="SOURCE" parent-doc="PARENTSOURCE" mode="EDIT">
			<flow:action name="save-DDO">
				<flow:log text-path="#DDO:" text="LogPostulante"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" doc="DDO"/>
			</flow:action>
			<flow:action name="on-show"/>
		</flow:form>
	</flow:group>
	<flow:group Name="ESTUDIO_CV">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.autoform" mode="SHOW">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#PARENTSOURCE:ESTUDIO_CV/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.autoform:SHOW" doc-path="/ESTUDIO_CV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form" mode="SHOW"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.autoform:LIST_EDIT" doc-path="/ESTUDIO_CV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form:LIST_EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.autoform" mode="LIST_EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
				<flow:open-form iter-index="#PARENTSOURCE:ESTUDIO_CV/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.autoform:EDIT" doc-path="/ESTUDIO_CV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form:NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.ESTUDIO_CV.form" mode="NEW"/>
	</flow:group>
	<flow:group Name="EXPERIENCIA">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.autoform:LIST_EDIT" doc-path="/EXPERIENCIA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form:LIST_EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.autoform" mode="LIST_EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
				<flow:open-form iter-index="#PARENTSOURCE:EXPERIENCIA/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.autoform:EDIT" doc-path="/EXPERIENCIA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form:NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.CVs.EXPERIENCIA.form" mode="NEW"/>
	</flow:group>
