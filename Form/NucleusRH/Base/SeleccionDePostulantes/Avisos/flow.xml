<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.SeleccionDePostulantes.Avisos.autoflow" name="NucleusRH.Base.SeleccionDePostulantes.Avisos">
	<flow:info label="Flow para NucleusRH.Base.SeleccionDePostulantes.Avisos"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS c_estado="" f_alta_d="" f_alta_h="" ATRIB_ORDEN1="" ORDEN1="" ATRIB_ORDEN2="" ORDEN2="" ATRIB_ORDEN3="" ORDEN3="" ATRIB_ORDEN4="" ORDEN4=""/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_aviso=&quot;162&quot;/&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_aviso as oi_aviso, 
					SEC.policy 
				FROM 
					SDP05_AVISOS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO\') as SEC 
				JOIN 
					t0.oi_aviso LEFT OUTER SEC.id
				WHERE
					{%? 
						(#SOURCE:@oi_aviso!='')	
						{% t0.oi_aviso = {#SOURCE:@oi_aviso} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@c_estado_avi!='')	
						{% t0.c_estado = {#SOURCE:@c_estado_avi} AND %} 
						{% %} 
					%}
					  
					{%? 
						(#SOURCE:@f_alta_d!='')	
						{% t0.f_aviso &gt;= {#SOURCE:@f_alta_d} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@f_alta_h!='')	
						{% t0.f_aviso &lt;= {#SOURCE:@f_alta_h} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@c_sexo!='')	
						{% t0.c_sexo = {#SOURCE:@c_sexo} AND %} 
					{% %} 
					%}
					{%? 
						(#SOURCE:@c_tipo!='')	
						{% t0.c_tipo = {#SOURCE:@c_tipo} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_provincia!='')	
						{% t0.oi_provincia = {#SOURCE:@oi_provincia} AND %} 
					{% %} 
					%}
					{%? 
						(#SOURCE:@oi_localidad!='')	
						{% t0.oi_localidad = {#SOURCE:@oi_localidad} AND %} 
					{% %} 
					%}
					1 = 1  
				ORDER BY 
					oi_aviso asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_aviso"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_aviso=&quot;162&quot; c_estado=&quot;&quot; f_alta_d=&quot;&quot; f_alta_h=&quot;&quot; c_tipo=&quot;&quot; /&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Puestos.PUESTO.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PAIS.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.INFO"/>
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.Jerarquias.JERARQUIA.INFO"/>
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.Areas.AREA.INFO"/>
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.INFO"/>
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:DATOS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_aviso as oi_aviso, 
					t0.c_aviso as c_aviso, 
					t0.d_puesto as d_puesto, 
					t0.c_estado as c_estado, 
					t0.f_aviso as f_aviso, 
					t0.l_vehiculo as l_vehiculo, 
					t0.l_lic_conduc as l_lic_conduc, 
					t0.c_radicarse as c_radicarse, 
					t0.c_viajar as c_viajar,  
					t0.o_aviso as o_aviso,
					t0.l_envio_mail_ok as l_envio_mail_ok,
					t0.l_publicar as l_publicar,
					SEC.policy, t0.c_aviso as CODE, 
					t0.d_puesto as TEXT, 
					t0.oi_provincia as oi_provincia, 
					t0.oi_tipo_jor_lab as oi_tipo_jor_lab 
				FROM 
					SDP05_AVISOS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO\') as SEC 
				JOIN 
					t0.oi_aviso LEFT OUTER SEC.id
				WHERE
					{%? 
						(#SOURCE:@oi_aviso!='')	
						{% t0.oi_aviso = {#SOURCE:@oi_aviso} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@c_estado_avi!='')	
						{% t0.c_estado = {#SOURCE:@c_estado_avi} AND %} 
						{% %} 
					%}
				        
					{%? 
						(#SOURCE:@f_alta_d!='')	
						{% t0.f_aviso &gt;= {#SOURCE:@f_alta_d} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@f_alta_h!='')	
						{% t0.f_aviso &lt;= {#SOURCE:@f_alta_h} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@c_sexo!='')	
						{% t0.c_sexo = {#SOURCE:@c_sexo} AND %} 
					{% %} 
					%}
					{%? 
						(#SOURCE:@c_tipo!='')	
						{% t0.c_tipo = {#SOURCE:@c_tipo} AND %} 
						{% %} 
					%}
					{%? 
						(#SOURCE:@oi_provincia!='')	
						{% t0.oi_provincia = {#SOURCE:@oi_provincia} AND %} 
					{% %} 
					%}
					{%? 
						(#SOURCE:@oi_localidad!='')	
						{% t0.oi_localidad = {#SOURCE:@oi_localidad} AND %} 
					{% %} 
					%}
					1 = 1  	  
				ORDER BY 
					oi_aviso asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_aviso"/>
						<qry:attribute name="c_aviso" value="$r/@c_aviso"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="f_aviso" value="$r/@f_aviso"/>
						<qry:attribute name="l_vehiculo" value="iif($r/@l_vehiculo='1','1','0')"/>
						<qry:attribute name="l_lic_conduc" value="iif($r/@l_lic_conduc='1','1','0')"/>
						<qry:attribute name="c_radicarse" value="iif($r/@c_radicarse='1','1','0')"/>
						<qry:attribute name="c_viajar" value="iif($r/@c_viajar='1','1','0')"/>
						<qry:attribute name="o_aviso" value="$r/@o_aviso"/>
						<qry:attribute name="l_envio_mail_ok" value="iif($r/@l_envio_mail_ok='1','1','0')"/>
						<qry:attribute name="l_publicar" value="iif($r/@l_publicar='1','1','0')"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_provincia!=''">
							<qry:then>
								<qry:element name="oi_provincia">
									<qry:attribute name="OI_FIND" value="$r/@oi_provincia"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_provincia" value="'['+oi_provincia/ROW/@COD+'] '+oi_provincia/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_tipo_jor_lab!=''">
							<qry:then>
								<qry:element name="oi_tipo_jor_lab">
									<qry:attribute name="OI_FIND" value="$r/@oi_tipo_jor_lab"/>
									<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_jor_lab" value="'['+oi_tipo_jor_lab/ROW/@COD+'] '+oi_tipo_jor_lab/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="JOBS"/>
		<doc:define name="TAG"/>
		<qry:define declare="&lt;PARAM /&gt;" name="QRY_TAGS">
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.INFO" mode="CLASS"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<AVISO>
						<qry:attribute name="hts:delete" value="1"/>
						<qry:insert-select name="sql_aviso" doc-path="#SOURCE:."/>
					</AVISO>
					<TAGS>
						<qry:append-doc name="TAGS" doc-path="."/>
						<qry:attribute name="hts:delete" value="1"/>
						<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY"/>
					</TAGS>
					<qry:insert-select name="sql1" doc-path="."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:TAGS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute-doc doc="TAGS" name="_position" value="#TAGS:@_position + 1"/>
					<qry:element name="ROW">
						<qry:attribute name="label" value="$r/@DES"/>
						<qry:attribute name="codigo" value="$r/@COD"/>
						<qry:attribute name="value" value="../AVISO/ROW[@codigo = $r/@COD]/@value"/>
						<qry:attribute name="id" value="#TAGS:@_position"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="sql_aviso" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT      
			A.l_tag1,
			A.l_tag2,
			A.l_tag3,
			A.l_tag4,
			A.l_tag5,
			A.l_tag6,
			A.l_tag7,
			A.l_tag8,
			A.l_tag9,
			A.l_tag10
			
			FROM
			SDP05_AVISOS  as A
			WHERE A.oi_aviso = {#SOURCE:@id}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag01'"/>
						<qry:attribute name="value" value="$r/@l_tag1"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag02'"/>
						<qry:attribute name="value" value="$r/@l_tag2"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag03'"/>
						<qry:attribute name="value" value="$r/@l_tag3"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag04'"/>
						<qry:attribute name="value" value="$r/@l_tag4"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag05'"/>
						<qry:attribute name="value" value="$r/@l_tag5"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag06'"/>
						<qry:attribute name="value" value="$r/@l_tag6"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag07'"/>
						<qry:attribute name="value" value="$r/@l_tag7"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag08'"/>
						<qry:attribute name="value" value="$r/@l_tag8"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag09'"/>
						<qry:attribute name="value" value="$r/@l_tag9"/>
					</ROW>
					<ROW>
						<qry:attribute name="codigo" value="'l_tag10'"/>
						<qry:attribute name="value" value="$r/@l_tag10"/>
					</ROW>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="NUL"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:exec-method out-type="Nomad.NSystem.String" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#JOBS:@usa" method="UsaJobs"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="AVISO">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.filter.form:FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.filter.form" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:call-action else="AGREGARJOBS" eq="0" if="#JOBS:@usa" action="AGREGAR"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.noreg.autoform" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
			</flow:action>
			<flow:action name="AGREGAR">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="AGREGARJOBS">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISOJOBS.form" doc-path="#NEWDDOROOT:" mode="NEW"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="VALORES">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO"/>
				<doc:set-attribute from-attr-path="#DDO:@d_puesto" to-attr-path="#NEWDDOROOT:@d_puesto"/>
				<doc:set-attribute from-attr-path="#DDO:@c_sexo" to-attr-path="#NEWDDOROOT:@c_sexo"/>
				<doc:set-attribute from-attr-path="#DDO:oi_pais/@value" to-attr-path="#NEWDDOROOT:oi_pais/@value"/>
				<doc:set-attribute from-attr-path="#DDO:oi_provincia/@value" to-attr-path="#NEWDDOROOT:oi_provincia/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_localidad/@value" from-attr-path="#DDO:oi_localidad/@value"/>
				<doc:set-attribute from-attr-path="#DDO:oi_jerarquia/@value" to-attr-path="#NEWDDOROOT:oi_jerarquia/@value"/>
				<doc:set-attribute from-attr-path="#DDO:oi_area/@value" to-attr-path="#NEWDDOROOT:oi_area/@value"/>
				<doc:set-attribute from-attr-path="#DDO:@o_aviso" to-attr-path="#NEWDDOROOT:@o_aviso"/>
			</flow:action>
			<flow:action name="VAL">
				<flow:call-action action="VALORES"/>
				<flow:call-action action="open-flow-ADD"/>
			</flow:action>
			<flow:action name="PUBLICADO">
				<doc:set-attribute from-value="P" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="RECLUTANDO">
				<doc:set-attribute from-value="R" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="CANCELADO">
				<doc:set-attribute from-value="C" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="FINALIZADO">
				<doc:set-attribute from-value="F" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.form"/>
			</flow:action>
			<flow:action name="PUBLICADO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="P"/>
				<doc:set-attribute to-attr-path="#DDO:@f_cierre"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
			<flow:action name="RECLUTANDO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="R"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
			<flow:action name="CANCELADO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="C"/>
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='f_hoy']/@xval" to-attr-path="#DDO:@f_cierre"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
			<flow:action name="FINALIZADO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="F"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
