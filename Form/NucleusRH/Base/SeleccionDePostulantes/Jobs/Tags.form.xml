<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.Tags.form" default_mode="FILTER" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?">
