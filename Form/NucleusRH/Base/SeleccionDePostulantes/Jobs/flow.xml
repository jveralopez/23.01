<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.flow" name="NucleusRH.BaytonRH.Postulantes.Jobs.flow">
	<flow:info label="Flow de la sincronizacion de Jobs"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO/>
		</doc:define>
		<qry:define name="QRY_FECHA_CV">
			<qry:main>
				<qry:element name="DATOS">
					<qry:attribute name="f_hasta" value="format-date(current-date(),'yyyymmdd')"/>
					<qry:attribute name="f_desde" value="format-date('19900101','yyyymmdd')"/>
					<qry:insert-select name="f_ult_actual_CV"/>
				</qry:element>
			</qry:main>
			<qry:select name="f_ult_actual_CV">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'f_ult_actual_CV\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@d_valor!=''">
						<qry:then>
							<qry:attribute name="f_desde" value="format-date($r/@d_valor,'yyyymmdd')"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DATOS"/>
		<qry:define name="QRY_FECHA_POSTU">
			<qry:main>
				<qry:element name="DATOS">
					<qry:attribute name="f_hasta" value="format-date(current-date(),'yyyymmdd')"/>
					<qry:attribute name="f_desde" value="format-date('19900101','yyyymmdd')"/>
					<qry:insert-select name="f_ult_actual_POSTU"/>
				</qry:element>
			</qry:main>
			<qry:select name="f_ult_actual_POSTU">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'f_ult_actual_POSTU\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@d_valor!=''">
						<qry:then>
							<qry:attribute name="f_desde" value="format-date($r/@d_valor,'yyyymmdd')"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="QRY_FECHA_OL">
			<qry:main>
				<qry:element name="DATOS">
					<qry:attribute name="f_hasta" value="format-date(current-date(),'yyyymmdd')"/>
					<qry:attribute name="f_desde" value="format-date('19900101','yyyymmdd')"/>
					<qry:insert-select name="f_ult_actual_OL"/>
				</qry:element>
			</qry:main>
			<qry:select name="f_ult_actual_OL">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'f_ult_actual_OL\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@d_valor!=''">
						<qry:then>
							<qry:attribute name="f_desde" value="format-date($r/@d_valor,'yyyymmdd')"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="QRY_FECHA_POSTU_LEIDAS">
			<qry:main>
				<qry:element name="DATOS">
					<qry:attribute name="f_hasta" value="format-date(current-date(),'yyyymmdd')"/>
					<qry:attribute name="f_desde" value="format-date('19900101','yyyymmdd')"/>
					<qry:insert-select name="f_ult_actual_POSTU"/>
				</qry:element>
			</qry:main>
			<qry:select name="f_ult_actual_POSTU">
				<qry:xquery>
					for $r in sql('
				SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.d_valor
				FROM ORG26_PARAMETROS
				WHERE ORG26_PARAMETROS.c_parametro = \'f_ult_actual_POSTU_LEIDAS\'
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@d_valor!=''">
						<qry:then>
							<qry:attribute name="f_desde" value="format-date($r/@d_valor,'yyyymmdd')"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="COD">
			<ROWS/>
		</doc:define>
		<qry:define name="QRY_CODIFICADORA">
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.CODIFICADORAS.query" mode="EXTERN"/>
			<qry:main name="main" doc="SOURCE">
				<qry:insert-select name="qry_cod"/>
			</qry:main>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="codificadoras">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Codificadoras.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ofertaslaborales">
			<doc:load-qry output-doc="DATOS" qry="QRY_FECHA_OL"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_desde" from-attr-path="#DATOS:@f_desde"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_hasta" from-attr-path="#DATOS:@f_hasta"/>
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.OfertasLaborales.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="cvs">
			<doc:load-qry output-doc="DATOS" qry="QRY_FECHA_CV"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_desde" from-attr-path="#DATOS:@f_desde"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_hasta" from-attr-path="#DATOS:@f_hasta"/>
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.CVs.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="postulaciones">
			<doc:load-qry qry="QRY_FECHA_POSTU" output-doc="DATOS"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_desde" from-attr-path="#DATOS:@f_desde"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@f_hasta" from-attr-path="#DATOS:@f_hasta"/>
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Postulaciones.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="tags">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Tags.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Codificadoras.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.Codificadoras.form:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:log text-path="#COD:" text="facuSOURCE"/>
			<flow:exec-method method="ActualizarCodificadoras" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param name="xmlSeleccionados" type="Nomad.NSystem.Proxy.NomadXML" doc-path="#COD:" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<doc:load-qry output-doc="COD" qry="QRY_CODIFICADORA"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.OfertasLaborales.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.OfertasLaborales.form:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:log text-path="#SOURCE:" text="facuSOURCE"/>
			<flow:exec-method method="CrearOfertasLaborales" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param attr-path="#SOURCE:@f_desde" type="Nomad.NSystem.String" mode="in" name="pFechaDesde"/>
				<flow:param attr-path="#SOURCE:@f_hasta" type="Nomad.NSystem.String" mode="in" name="pFechaHasta"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.CVs.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.CVs.form:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:log text="facuSOURCE2" text-path="#SOURCE:"/>
			<flow:exec-method method="GuardarCVs" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param attr-path="#SOURCE:@f_desde" type="Nomad.NSystem.String" mode="in" name="pFechaDesde"/>
				<flow:param attr-path="#SOURCE:@f_hasta" type="Nomad.NSystem.String" mode="in" name="pFechaHasta"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Postulaciones.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.Postulaciones.form:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:log text-path="#SOURCE:" text="facuSOURCE"/>
			<flow:exec-method method="GuardarPostulaciones" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#BATCHDOC:@batch-id" priority="5">
				<flow:param attr-path="#SOURCE:@f_desde" type="Nomad.NSystem.String" mode="in" name="pFechaDesde"/>
				<flow:param attr-path="#SOURCE:@f_hasta" type="Nomad.NSystem.String" mode="in" name="pFechaHasta"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Jobs.Tags.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.Tags.form:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:exec-method method="ImportarTags" class="NucleusRH.Base.SeleccionDePostulantes.Jobs.JOBS" out-attr-path="#BATCHDOC:@batch-id" priority="5"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
