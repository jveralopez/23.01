<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.SeleccionDePostulantes.Jobs.OfertasLaborales.form" default_mode="FILTER" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Migraci&#243;n de Avisos" name="GEN_COPY" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="colums">
			<form:Column name="col">
				<form:Blank name="blk1"/>
				<form:Blank name="blk2"/>
				<form:HTMLPaste name="html1">
					<table>
						<tr>
							<td>
								<DIV class="M3 LCol_t" name="formato">
									Migraci&#243;n de Avisos en la web Jobs
								</DIV>
							</td>
						</tr>
					</table>
				</form:HTMLPaste>
				<form:Blank height="2mm" name="blk3"/>
				<form:HTMLPaste name="html2">
					<table>
						<tr>
							<td>
								<DIV class="M1 LCol_g" style="font-style: italic;" name="formato">
									Proceso que migra los Avisos que se hayan creado y/o actualizado en Nuclues RH dentro del rango de fechas especificado
								</DIV>
							</td>
						</tr>
					</table>
				</form:HTMLPaste>
				<form:Blank name="blk4"/>
				<form:Columns name="cols">
					<form:Column name="col1" separation="2" align="center" valign="top"/>
					<form:Column name="col2" separation="2" align="center" valign="top">
						<form:DateTime name="f_desde" nvalue="#source:@f_desde" label="Fecha desde" mask="dd/mm/yyyy" descr="Fecha Desde." required="0" pattern="YYYYMMDD">
							<form:SButtons>
								<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha Desde.">
									<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" label="Fecha hasta" mask="dd/mm/yyyy" descr="Fecha Hasta." required="0" pattern="YYYYMMDD">
							<form:SButtons>
								<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha Hasta.">
									<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Column>
					<form:Column name="col3" separation="2" align="center" valign="top"/>
				</form:Columns>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button name="btnEjecutar" descrip="Ejecutar actualizaci&#243;n de codificadoras" img="play" label="Ejecutar" enabled="" visible="" note="" startvalidate="1">
					<form:Event name="onclick" action="EJECUTAR" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
