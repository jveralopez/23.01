<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.BaytonRH.Postulantes.JobsBayton.CVs.form" default_mode="FILTER" doc="source" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Migraci&#243;n de CVs" name="GEN_COPY" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl2"/>
		<form:Columns name="colums">
			<form:Column name="col">
				<form:Blank name="blk1"/>
				<form:Blank name="blk2"/>
				<form:HTMLPaste name="html1">
					<table>
						<tr>
							<td>
								<DIV class="M3 LCol_t" name="formato">
									Migraci&#243;n de CVs
								</DIV>
							</td>
						</tr>
					</table>
				</form:HTMLPaste>
				<form:Blank height="2mm" name="blk3"/>
				<form:HTMLPaste name="html2">
					<table>
						<tr>
							<td>
								<DIV class="M1 LCol_g" style="font-style: italic;" name="formato">
									Proceso que migra todos los CVs dados de alta y/o editados en la web Jobs dentro del rango de fechas especificado
								</DIV>
							</td>
						</tr>
					</table>
				</form:HTMLPaste>
				<form:Blank name="blk4"/>
				<form:Columns name="cols">
					<form:Column name="col1" separation="2" align="center" valign="top"/>
					<form:Column name="col2" separation="2" align="center" valign="top">
						<form:DateTime name="f_desde" nvalue="#source:@f_desde" label="Fecha desde" mask="dd/mm/yyyy" descr="Fecha de Nacimiento." required="1" pattern="YYYYMMDD">
							<form:SButtons>
								<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento.">
									<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" label="Fecha hasta" mask="dd/mm/yyyy" descr="Fecha de Nacimiento." required="1" pattern="YYYYMMDD">
							<form:SButtons>
								<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha de Nacimiento.">
									<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Column>
					<form:Column name="col3" separation="2" align="center" valign="top"/>
				</form:Columns>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button name="btnEjecutar" descrip="Ejecutar actualizaci&#243;n de codificadoras" img="play" label="Ejecutar" enabled="" visible="" note="" startvalidate="0">
					<form:Event action="validar_fechas" name="onclick" runat="client"/>
					<form:Event name="onclick" action="EJECUTAR" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function validar_fechas()
{
	//alert(Ctrl('f_desde').GetXValue());
	//alert(Ctrl('f_hasta').GetXValue());
	 
	if(Ctrl('f_desde').GetXValue()=="")
	{
		alert("La Fecha desde es obligatoria.");		
		Ctrl('f_desde').SetFocus();
		return false;
	}
	
	if(Ctrl('f_hasta').GetXValue()=="")
	{
		alert("La Fecha hasta es obligatoria.");
		Ctrl('f_hasta').SetFocus();
		return false;
	}
	
	if(Ctrl('f_hasta').GetXValue()&lt;Ctrl('f_desde').GetXValue())
	{
		alert("La Fecha hasta no puede ser menor a la Fecha desde."); 
		Ctrl('f_desde').SetFocus();
		return false;
	}
	
	return true;
	
}
	</form:Scripts>
</form:Form>
