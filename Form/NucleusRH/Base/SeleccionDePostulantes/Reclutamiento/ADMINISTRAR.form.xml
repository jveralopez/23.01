	<form:Event action="SAVE" name="SAVE" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;ROWS&gt;&#13;&#10;  &lt;ROW id=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW id=&quot;27&quot;/&gt;&#13;&#10;  &lt;ROW id=&quot;46&quot;/&gt;&#13;&#10;  &lt;ROW id=&quot;28&quot;/&gt;&#13;&#10;  &lt;ROW id=&quot;47&quot;/&gt;&#13;&#10;  &lt;ROW id=&quot;4&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;" name="qry">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="spliter" doc-path="#SOURCE:ROWS/ROW"/>
					<qry:if test="@cnt!=''">
						<qry:then>
							<qry:insert-select name="sql1" doc-path="."/>
							<qry:attribute name="ois" value="''"/>
							<qry:attribute name="sep" value="''"/>
							<qry:attribute name="cnt" value="''"/>
						</qry:then>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT 
				REC.n_merito, 
				CV.oi_cv, 
				CV.d_ape_y_nom,
				REC.c_estado
			FROM 
				SDP14_RECLUTADOS as REC, 
				SDP01_CV as CV, 
				SDP05_AVISOS as AVISO
			JOIN 
				REC.oi_cv INNER CV.oi_cv,
				REC.oi_aviso INNER AVISO.oi_aviso
			WHERE 	
				CV.oi_cv IN ({%=#SOURCE:@ois%})
			ORDER BY 
				n_merito ASC, d_ape_y_nom ASC 
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_cv"/>
						<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
						<qry:attribute name="n_merito" value="number($r/@n_merito)"/>
						<qry:switch test="$r/@c_estado">
							<qry:case value="V">
								<qry:attribute name="c_estado" value="'Vigente'"/>
							</qry:case>
							<qry:case value="D">
								<qry:attribute name="c_estado" value="'Descartado'"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="c_estado" value="'Contratado'"/>
							</qry:default>
						</qry:switch>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="spliter" doc="SOURCE">
				<qry:out>
					<qry:attribute name="ois" value="@ois + @sep + #SOURCE:@id"/>
					<qry:attribute name="sep" value="','"/>
					<qry:attribute name="cnt" value="number(@cnt)+1"/>
					<qry:if test="@cnt=300">
						<qry:then>
							<qry:insert-select name="sql1" doc-path="."/>
							<qry:attribute name="ois" value="''"/>
							<qry:attribute name="sep" value="''"/>
							<qry:attribute name="cnt" value="''"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
