function Guardar()
{  	
 	Ctrl('cvs').DelAllRow();
 	for (key in arrA)
 	{ 
 		var rowCVs = Ctrl('cvs').AddRow();
 		rowCVs.SetAttr('id', key.substr(1));
 		rowCVs.SetAttr('n_merito', arrA[key].associatedELE.getAttribute("n_merito"));
 		rowCVs.SetAttr('c_estado', arrA[key].associatedELE.getAttribute("c_estado"));
 		
 	}
	Ctrl("main").DoEvent("SAVE");
}                             

function Find()
{
	Ctrl("list1").filter("",Ctrl("iter_search").GetCValue());
	Ctrl("list2").filter("",Ctrl("iter_search1").GetCValue());
}
