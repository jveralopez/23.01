		function ONLOAD()
{                
	CtrlEnabled("REPORTE1", false);
	arrA = new Array();
	arrB = new Array();
	ONLOAD_custom();
	enable_buttons();
		
	if (Ctrl("main").GetLastDoc("ARRA"))
	{                                
		arrA=init_qry(ELE2String(Ctrl("main").GetLastDoc("ARRA")));
		refreshList("list1", arrA);
	}
	
	if (Ctrl("main").GetLastDoc("ARRB"))
	{
		arrB = string2array(ELE2String(Ctrl("main").GetLastDoc("ARRB"))); 
		refreshList("list2", arrB);
	}
}

function enable_custom_buttons()
{
	if (Ctrl("list1"))
		CtrlEnabled("list1_REPORTE1"    , Ctrl("list1").TotalRowsCount()?true:false);		
	if (Ctrl("list2"))
		CtrlEnabled("list2_REPORTE"    , Ctrl("list2").TotalRowsCount()?true:false);
	
	if (Ctrl('list1').GetSelectAttrValue('c_estado') != 'Vigente')	
	{ 
		CtrlEnabled("DEL",false);
		CtrlEnabled("DEL_ALL",false);		
	}	
	else 
	{		     
		CtrlEnabled("DEL",true);	
	}
}

