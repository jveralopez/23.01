						<form:NumberBox nvalue="#source:@edad_desde" length="7" precision="0" xsize="7" name="edad_desde"/>
						<form:Label label="..." name="lbl_hasta"/>
						<form:NumberBox nvalue="#source:@edad_hasta" length="7" precision="0" xsize="7" name="edad_hasta"/>
					</form:Rower>
					<form:ComboBox xsize="40" mode="OPT" required="0" descr="Sexo (M | F)." label="Sexo" nvalue="#source:@c_sexo" name="c_sexo">
						<options>
							<option text="Masculino" value="M"/>
							<option text="Femenino" value="F"/>
						</options>
					</form:ComboBox>
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Estados_Civiles.ESTADO_CIVIL.INFO" xsize="40" mode="QRY" required="0" label="Estado Civil" nvalue="#source:@oi_estado_civil" name="oi_estado_civil"/>
					<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Paises.PAIS.INFO" queryname1="NucleusRH.Base.Organizacion.Paises.PROVINCIA.INFO" nvalue="#source:@oi_provincia" name="oi_provincia" label="Pa&#237;s - Provincia" xsize="20" mode="QRY" required="0"/>
					<form:TextBox nvalue="#source:@d_localidad" label="Localidad" name="d_localidad"/>
					<form:Rower name="fdesdehastaact" label="Actualizaci&#243;n CV" separation="5" required="0">
						<form:DateTime xsize="10" name="f_desdeact" nvalue="#source:@f_desdeact" pattern="YYYYMMDD" required="0" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lblfechasact" label="..."/>
						<form:DateTime xsize="10" nvalue="#source:@f_hastaact" name="f_hastaact" pattern="YYYYMMDD" required="0" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
					<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.INFO" nvalue="#source:@oi_tipo_jor_lab" label="Tipo Jornada Laboral" name="oi_tipo_jor_lab" xsize="30" mode="QRY" required="0" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_localidad">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_localidad/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_localidad"/>
						</form:Policies>
					</form:ComboBox>
					<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL.INFO" xsize="40" mode="QRY" required="0" label="Situaci&#243;n Laboral" nvalue="#source:@oi_sit_laboral" name="oi_sit_laboral" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/CVs/CV/form/oi_sit_laboral">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/CVs/CV/form/oi_sit_laboral/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/CVs/CV/form/oi_sit_laboral"/>
						</form:Policies>
					</form:ComboBox>
					<form:Rower label="Remuneraci&#243;n" name="rwerremun" separation="5">
						<form:NumberBox nvalue="#source:@remun_desde" name="remun_desde" length="7" xsize="7"/>
						<form:Label label="..." name="lbl_hasta"/>
						<form:NumberBox nvalue="#source:@remun_hasta" name="remun_hasta" length="7" xsize="7"/>
					</form:Rower>
					<form:ComboBox label="&#193;rea Inter&#233;s" queryname1="NucleusRH.Base.SeleccionDePostulantes.Areas.AREA.INFO" xsize="40" mode="QRY" required="0" nvalue="#source:@oi_area" name="oi_area" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area"/>
						</form:Policies>
					</form:ComboBox>
					<form:ComboBox visible="0" queryname1="NucleusRH.Base.SeleccionDePostulantes.CVs.POSTULACIONES.INFO" name="oi_postulacion" nvalue="#source:@oi_postulacion" label="Postulaci&#243;n" xsize="40" mode="QRY" required="0" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area">
						<form:Policies>
							<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area/HAB"/>
							<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Avisos/AVISO/form/oi_area"/>
						</form:Policies>
					</form:ComboBox>
					<form:TextBox visible="0" label="Antig&#252;edad" nvalue="#source:@c_antiguedad" name="c_antiguedad"/>
					<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Areas_Experiencia.AREA_EXP.INFO" nvalue="#source:@oi_area_exp" name="oi_area_exp" label="&#193;rea de Experiencia" xsize="40" mode="QRY" required="0"/>
					<form:TextBox nvalue="#source:@d_empresaExp" label="Empresa de Experiencia" name="d_empresaExp" required="0" ysize="1" xsize="43" length="30"/>
				</form:Column>
				<form:Column align="right" name="col2" separation="1" valign="top">
					<form:Blank name="blanco30"/>
					<form:Label style="M1 LCol_t" label="M&#233;ritos" name="lblmeritos"/>
					<form:Blank name="blanco40"/>
					<form:Grid width="100%" nvalue="#source:ROWS" rows="7" doc="SOURCEGRILLA" idvalue="#SOURCEGRILLA:@id" label="M&#233;ritos" name="grdMerito" note="" descrip="" allowhelper="0" allowdelall="0" allownew="0" allowdel="0" paging="1" enabled="">
						<form:GColumns>
							<form:GColumn label="M&#233;rito" allow_order="0">
								<form:ComboBox enabled="0" label="M&#233;rito" queryname1="NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO.INFO" nvalue="#SOURCEGRILLA:@id" name="oi_merito" xsize="45" mode="QRY" required="0" X-POLICY="./FORM/NucleusRH/Base/Evaluacion2/Evaluacion/ASIGNACION/filter/form/oi_evento">
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Evaluacion2/Evaluacion/ASIGNACION/filter/form/oi_evento/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/Evaluacion2/Evaluacion/ASIGNACION/filter/form/oi_evento"/>
									</form:Policies>
								</form:ComboBox>
								<form:NumberBox width="5" xsize="5" required="0" label="Ponderaci&#243;n" name="n_merito" nvalue="#SOURCEGRILLA:@n_merito"/>
							</form:GColumn>
						</form:GColumns>
					</form:Grid>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:Hidden nvalue="#source:@h_edad_desde" required="0" name="h_edad_desde"/>
		<form:Hidden nvalue="#source:@h_edad_hasta" required="0" name="h_edad_hasta"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="5" name="botones">
			<form:Row name="filaBotones">
				<form:Button name="btnEjecutar" startvalidate="1" descrip="Ejecutar la consulta" note="" img="play" enabled="" label="Ejecutar">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl8"/>
				<form:Button descrip="vuelve al menu principal" note="" img="back" label="Volver" name="btnVolver" visible="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function hiddenedad()
{   
  var ed = Ctrl('edad_desde').GetXValue();
  var eh = Ctrl('edad_hasta').GetXValue();

  var a = new Date();
  a.setFullYear(a.getFullYear()-eh);
  a = datetime2str(a);
  var b = new Date();
  b.setFullYear(b.getFullYear()-ed);
  b = datetime2str(b);

  Ctrl('h_edad_desde').SetXValue('');
  Ctrl('h_edad_hasta').SetXValue('');

  if(ed!="")
  {
    Ctrl('h_edad_desde').SetXValue(a);
  }
  if(eh!="")
  {
    Ctrl('h_edad_hasta').SetXValue(b);
  }   
  
}
	</form:Scripts>
</form:Form>
