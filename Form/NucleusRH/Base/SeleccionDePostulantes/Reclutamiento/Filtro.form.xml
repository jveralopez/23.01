			</form:Policies>
		</form:VGroup>
		<form:VGroup label="Criterios de selecci&#243;n para el Reclutamiento" nvalue="#source:@grecluta" border="1" width="98%" collapse="1" name="vgroupDatosRec" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/CambiosTurnos/filter/form/vgroupDatosPers">
