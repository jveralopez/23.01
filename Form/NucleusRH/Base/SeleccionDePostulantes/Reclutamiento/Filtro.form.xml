			</form:Policies>
			<form:Columns width="100%" height="100%" name="columnas">
				<form:Column width="50%" name="col1" separation="1" align="left" valign="top">
					<form:Blank name="blanco10"/>
					<form:Label style="M1 LCol_t" label="Filtros" name="lblfiltro"/>
					<form:Blank name="blanco20"/>
					<form:CheckBox nvalue="#source:@l_incluir_post" label="Postulado" name="l_incluir_post"/>
					<form:CheckBox nvalue="#source:@l_incluir_inactivos" name="l_incluir_inactivos" label="Inactivos"/>
