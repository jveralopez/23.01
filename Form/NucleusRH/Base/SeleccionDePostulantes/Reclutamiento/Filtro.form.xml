	</form:Title>
	<form:Center height="70%" width="100%">
		<form:Blank name="blanco2"/>
		<form:VGroup width="98%" label="Criterios de selecci&#243;n de Avisos" nvalue="#source:@gaviso" border="1" name="vgroupDatosAviso" collapse="1" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Reporte/CambiosTurnos/filter/form/vgroupDatosCustom">
