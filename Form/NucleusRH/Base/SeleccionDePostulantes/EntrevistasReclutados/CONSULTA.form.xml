<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.CONSULTA" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:Label label="Registrar Entrevista Reclutado" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCONSULTAS">
			<form:Column separation="2" valign="top" align="center" name="main_columnsCONSULTAcolumn1">
				<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.INFO" label="Aviso" xsize="50" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#DATOS:@oi_aviso" name="oi_aviso"/>
				<form:Blank height="2" name="bl1"/>
				<form:ComboBox prev="oi_aviso" where1="SDP14_RECLUTADOS.c_estado = 'V'" nvalue="#source:oi_reclutado/@xval" queryname1="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.INFO" label="Reclutado" xsize="50" mode="QRY" required="1" enabled="NEW|EDIT" name="oi_reclutado">
					<form:Event action="loadent" name="onchange" runat="client"/>
				</form:ComboBox>
				<form:ComboBox visible="0" where1="isnull(SDP14_RECLUTA_ENTREV.f_entrevista)" nvalue="#source:@oi_recluta_entrev" queryname1="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.INFO" prev="oi_reclutado" enabled="NEW|EDIT" help-stop="0" xsize="50" mode="QRY" required="1" label="Entrevista" name="oi_entrevista" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/oi_entrevista">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/oi_entrevista/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/oi_entrevista"/>
					</form:Policies>
				</form:ComboBox>
				<form:ComboBox docname="RS" help-stop="0" where1="isnull(SDP14_RECLUTA_ENTREV.f_entrevista)" enabled="NEW|EDIT" label="Tipo - Entrevista" queryname1="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.INFO" xsize="50" mode="DOC" required="1" nvalue="#source:@oi_recluta_entrev" name="oi_entrevista"/>
				<form:DateTime enabled="NEW|EDIT" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" label="Fecha Entrevista" nvalue="#source:@f_entrevista" name="f_entrevista" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/f_entrevista">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/f_entrevista/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/f_entrevista"/>
					</form:Policies>
				</form:DateTime>
				<form:TextBox enabled="NEW|EDIT" required="0" ysize="1" xsize="50" length="100" label="Entrevistador" nvalue="#source:@d_entrevistador" name="d_entrevistador" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/d_entrevistador">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/d_entrevistador/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/d_entrevistador"/>
					</form:Policies>
				</form:TextBox>
				<form:NumberBox enabled="NEW|EDIT" required="0" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" nvalue="#source:@n_valor" name="n_valor" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/n_valor">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/n_valor/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/n_valor"/>
					</form:Policies>
				</form:NumberBox>
				<form:TextBox enabled="NEW|EDIT" required="0" ysize="6" xsize="50" length="2000" label="Comentarios" nvalue="#source:@t_comentario" name="t_comentario" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/t_comentario">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/t_comentario/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTA_ENTREV/form/t_comentario"/>
					</form:Policies>
				</form:TextBox>
				<form:Hidden name="guardado" nvalue="#auxdoc:@guardado"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button descrip="Guarda los cambios realizados" label="Guardar" startvalidate="1" visible="NEW|EDIT" img="save" name="SAVE">
					<form:Event action="ValDates" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" visible="NEW|EDIT|DELETE" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ValDates()
{
	Ctrl('main').DoEvent("guardar"); 
	Ctrl("oi_reclutado").SetXValue(""); 
	Ctrl("oi_entrevista").SetXValue("");
	Ctrl("f_entrevista").SetCValue("");
	Ctrl("d_entrevistador").SetCValue("");
	Ctrl("n_valor").SetCValue("");
	Ctrl("t_comentario").SetCValue("");
}
function loadent()
{
	if (Ctrl("oi_reclutado").GetXValue() == "")
	{
		Ctrl("oi_entrevista").setOptions("&lt;ROWS/&gt;");
		return;
	}
	
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
	var qry = Ctrl("main").getResource("qry_ent");
	
	var result = nSQL.Get(qry, "&lt;DATA id=\"" + Ctrl("oi_reclutado").GetXValue() + "\"/&gt;");
	Ctrl("oi_entrevista").setOptions(result);
}

function form_onpostbind()
{
	if (Ctrl("guardado").GetXValue()== "1")
	{
		Ctrl("guardado").SetXValue("");
		alert("La entrevista fue registrada correctamente");
		Ctrl("main").DoEvent("NEW");
	}
}
	</form:Scripts>
	<form:Event name="guardar" action="SAVE" runat="server"/>
	<form:Resources>
		<form:Resource name="qry_ent">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_ENT" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_ENT" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  SDP14_RECLUTA_ENTREV.oi_recluta_entrev as ID,
  SDP13_ENTREVISTAS.c_entrevista as COD,
  SDP13_ENTREVISTAS.d_entrevista as DES,
  SDP14_RECLUTA_ENTREV.oi_reclutado as PARENT
from
  SDP14_RECLUTA_ENTREV,
  SDP13_ENTREVISTAS
join
  SDP14_RECLUTA_ENTREV.OI_ENTREVISTA inner SDP13_ENTREVISTAS.OI_ENTREVISTA 
Where
	isnull(SDP14_RECLUTA_ENTREV.f_entrevista) and
	{%?(#SOURCE:@id!='') {% PARENT={#SOURCE:@id} %} {% 1=2 %} %}
order by DES asc
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="option">
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@DES" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="form_onpostbind" name="onpostbind" runat="client"/>
	<form:Event action="NEW" name="NEW" runat="server"/>
</form:Form>
