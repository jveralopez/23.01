<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.flow" extends="Nomad.Base.flow">
	<flow:info label="Entrevistas Reclutados"/>
	<flow:declare>
		<doc:define name="PARAM">
			<DATOS/>
		</doc:define>
		<doc:define name="auxdoc"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:new-object class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" doc="DDO"/>
			<flow:open-form doc-path="#PARAM:" form-class="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.CONSULTA.form" mode="NEW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.CONSULTA.form" name="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.CONSULTA.form:NEW" doc="SOURCE" parent-doc="PARENTSOURCE" mode="NEW">
		<flow:action name="SAVE">
			<doc:load-object id-path="#FORM:ctrl[@id='oi_reclutado']/@xval" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" doc="DDO"/>
			<flow:exec-method class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" this-doc="DDO" method="CargarEntrevista">
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="1" to-attr-path="#auxdoc:@guardado"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="NEW">
			<flow:exit-flow next-action="initialize" next-flow="NucleusRH.Base.SeleccionDePostulantes.EntrevistasReclutados.flow" return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
