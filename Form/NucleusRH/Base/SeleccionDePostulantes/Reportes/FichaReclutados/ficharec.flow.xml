<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Base.SeleccionDePostulantes.Reportes.FichaReclutados" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.SeleccionDePostulantes.Reportes.FichaReclutados"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAMS/>
		</doc:define>
		<doc:define name="PARAMETERS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Reportes.FichaReclutados.ficharec.filter.form" doc-path="#FILTERDATA:" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Reportes.FichaReclutados.ficharec.filter.form" name="NucleusRH.Base.SeleccionDePostulantes.Reportes.FichaReclutados.ficharec.filter.form" mode="EDIT" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.SeleccionDePostulantes.FichaRec.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="202 - Ficha del Reclutado" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="NucleusRH.Base.SeleccionDePostulantes.Reportes.FichaReclutados.ficharec" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="NucleusRH.Base.SeleccionDePostulantes.Reportes.FichaReclutados.ficharec" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
