<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Postulantes.Reportes.postulaciones.filter" doc="source">
	<form:Title>
		<form:Label label="201 - Reclutados por Aviso" help-stop="1" name="lbl_titulo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="bl3" width="90%" visible=""/>
		<form:Columns name="columns1">
			<form:Column name="col1">
				<form:Blank name="blnk001"/>
				<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.INFO" nvalue="#SOURCE:@oi_aviso" name="aviso" xsize="50" mode="QRY" required="1" label="Aviso"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" label="Estado" nvalue="#source:@c_estado" name="c_estado" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTADO/form/c_estado">
					<options>
						<option text="Vigente" value="V"/>
						<option text="Contratado" value="C"/>
						<option text="Descartado" value="D"/>
					</options>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTADO/form/c_estado/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/Reclutados/RECLUTADO/form/c_estado"/>
					</form:Policies>
				</form:ComboBox>
				<form:CheckBox label="Excluir Descartados" nvalue="#source:@l_excluir" name="l_excluir"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="ACCEPT" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
