					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Hasta" nvalue="#source:@f_hasta" name="f_hasta" pattern="YYYYMMDD" required="0" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
					<form:SButtons>
