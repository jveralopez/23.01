}       
         
function ValidaFec()
{ 
        
	if (Ctrl("oi_aviso").GetXValue()!="")
	{ 
		Ctrl("f_postulacion").SetEnabled(true);
	}  
	else 
	{ 
		Ctrl("f_postulacion").SetEnabled(false);
		Ctrl("f_postulacion").SetXValue("0");
	}  
}
