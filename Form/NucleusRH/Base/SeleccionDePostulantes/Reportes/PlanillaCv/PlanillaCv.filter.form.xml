	<form:Scripts>
		function LoadForm()
{
	var loc;
	loc = (window.location + "").substr(0,(window.location + "").indexOf("Skins"));
	Ctrl('location').SetXValue(loc);
	//Verifica Fecha Postulaci&#243;n
	ValidaFec();	
}

function toggleAll(me)
{
	var col = me.m_Parent.m_Parent;
	
	if (me.GetXValue()=="0")
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{ 
				if(col.GetChild(i).GetEnabled(true))
				{
				col.GetChild(i).SetXValue("0");
				}
			} catch(err){}
		}
	}
	else
	{
		for (i=1; i&lt;col.GetChildLength(); i++)
		{
			try
			{ 
				if(col.GetChild(i).GetEnabled(true))
				{
				col.GetChild(i).SetXValue("1");
			  }
			} catch(err){}
		}
	}
}              

function hiddenedad()
{   
  var ed = Ctrl('edad_desde').GetXValue();
  var eh = Ctrl('edad_hasta').GetXValue();

  var a = new Date();
  a.setFullYear(a.getFullYear()-eh);
  a = datetime2str(a);
  var b = new Date();
  b.setFullYear(b.getFullYear()-ed);
  b = datetime2str(b);

  Ctrl('h_edad_desde').SetXValue('');
  Ctrl('h_edad_hasta').SetXValue('');

  if(ed!="")
  {
    Ctrl('h_edad_desde').SetXValue(a);
  }
  if(eh!="")
  {
    Ctrl('h_edad_hasta').SetXValue(b);
  }   
  
}   

function internal_load()
{ 
  hiddenedad();  
  var auxArr;  
	auxArr = exec_qry();	
	if (auxArr==null)	
	 return;
	arrB = auxArr; 
	remove(arrB, arrA);	
	refreshList("list2", arrB);
}

