	<form:Scripts>
		function REPORTE() 
{   
	var idCV;
	var oi_cv;				
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();

	if(Ctrl('LIST'))
	{
		oi_cv = nSQL.GetOBJ(Ctrl("main").getResource("getOiCV"), "&lt;PARAM oi_reclutado=\""+Ctrl('LIST').GetSelectAttrValue('id')+"\" /&gt;");
		idCV = oi_cv.id;
		Ctrl("oi_reclutado_list").SetXValue(oi_cv.oi_reclutado); 
		//alert("oi_reclutado:"+oi_cv.oi_reclutado);
	}
	else
	{
		idCV = Ctrl('oi_cv').GetXValue();
		//alert("oi_reclutado:"+Ctrl("oi_reclutado_show").GetXValue());
	}
	
		
	open("../../../ReportViewer.aspx?ut="+GetProxy().UserToken()+String.fromCharCode(38)+"file=NucleusRH.Base.SeleccionDePostulantes.CV.rpt"+String.fromCharCode(38)+"id="+idCV, '', 'channelmode=no,directories=no,fullscreen=no,location=no,menubar=no,resizable=yes,scrollbars=yes,status=no,titlebar=no,toolbar=no,left=0,top=0,width='+(screen.width-12)+',height='+(screen.height-60));
	return true;
}

function LoadForm()
{             
	
	CargarFecha();
  clickLista();
 
	if (Ctrl('main').GetMode()=="SHOW")
  {
    //Vigente 
    
    if (Ctrl('c_estado').GetCValue() == "Vigente")
    {
      CtrlEnabled('DESCARTADO',true);
      CtrlEnabled('EDIT',true);
      CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
    }
    //Descartado
    if (Ctrl('c_estado').GetCValue() == "Descartado")
    {
      CtrlEnabled('DESCARTADO',false);
      CtrlEnabled('EDIT',true);
      CtrlEnabled('RECLUTA_ENTREV',false);
      CtrlEnabled('RECLUTA_EXA',false);
    }
    //Contratado
    if (Ctrl('c_estado').GetCValue() == "Contratado")
    {
      CtrlEnabled('DESCARTADO',false);
      CtrlEnabled('EDIT',false); 
      CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
    }  
  }
  if (Ctrl('main').GetMode()=="LIST")
  {
    //Vigente
    if (Ctrl('c_estado').GetCValue() == "Vigente")
    {
      CtrlEnabled('DESCARTADO',true);
      CtrlEnabled('EDIT',true);
      CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
    }
    //Descartado
    if (Ctrl('c_estado').GetCValue() == "Descartado")
    {
      CtrlEnabled('DESCARTADO',false);
      CtrlEnabled('EDIT',true);
      CtrlEnabled('RECLUTA_ENTREV',false);
      CtrlEnabled('RECLUTA_EXA',false);
    }                                 
    //Contratado
    if (Ctrl('c_estado').GetCValue() == "Contratado")
    {
      CtrlEnabled('DESCARTADO',false);
      CtrlEnabled('EDIT',false);
      CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
    }  
  }
}

function DescartarReclutado()
{ 
	Ctrl("f_estado").SetXValue(datetime2str(new Date()));
	Ctrl("main").DoEvent("SetDescartar");                  	
}

function CargarFecha()
{                               
	if (Ctrl('main').GetMode() != "LIST")
	{
		if (Ctrl('f_estado') != null &amp;&amp; Ctrl('f_estado').GetCValue() == "")
			{                                         
				Ctrl('f_estado').SetTypedValue(new Date());
			}
		CtrlEnabled('f_estado', true); 
	}
	
	Ctrl("f_estado_hid").SetXValue(datetime2str(new Date())); 
	
}
   
function clickLista()
{
  if (Ctrl('main').GetMode() == 'LIST') 
	{ 
	  if(Ctrl('LIST').GetSelectAttrValue('c_estado') == 'Vigente')
		{	
			CtrlEnabled('DESCARTADO',true);
			CtrlEnabled('EDIT',true);	
			CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
		}	
		if(Ctrl('LIST').GetSelectAttrValue('c_estado') == 'Contratado')
		{	
			CtrlEnabled('DESCARTADO',false);  
			CtrlEnabled('EDIT',false);  
			CtrlEnabled('RECLUTA_ENTREV',true);
      CtrlEnabled('RECLUTA_EXA',true);	
		}
		if(Ctrl('LIST').GetSelectAttrValue('c_estado') == 'Descartado')
		{	
			CtrlEnabled('DESCARTADO',false);
			CtrlEnabled('EDIT',true);
			CtrlEnabled('RECLUTA_ENTREV',false);
      CtrlEnabled('RECLUTA_EXA',false);
		}	                              
	}  
}
	</form:Scripts>
	<form:Event action="LoadForm" name="onload" runat="client"/>
	<form:Event name="SetDescartar" action="DESCARTADO" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_reclutado=&quot;1&quot;/&gt;" name="getOiCV">
			<qry:main doc="SOURCE">
				<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			SELECT 
				SDP14_RECLUTADOS.oi_cv,
				SDP14_RECLUTADOS.oi_reclutado					
			FROM 
				SDP14_RECLUTADOS
			WHERE 
				SDP14_RECLUTADOS.oi_reclutado = {#SOURCE:@oi_reclutado}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_cv" name="id"/>
						<qry:attribute value="$r/@oi_reclutado" name="oi_reclutado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
