			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:RECLUTA_EXA/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST_EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.autoform:EDIT" doc-path="/RECLUTA_EXA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form"/>
