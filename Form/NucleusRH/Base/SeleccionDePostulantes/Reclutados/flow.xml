		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.filter.form:FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.filter.form" mode="FILTER">
			<flow:action name="on-show">
