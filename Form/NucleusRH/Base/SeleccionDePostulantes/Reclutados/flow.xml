<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.autoflow" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS/>
		</doc:define>
		<qry:define declare="&lt;DATOS oi_aviso=&quot;1&quot; c_estado=&quot;&quot; oi_reclutado=&quot;&quot; l_excluir=&quot;&quot; c_cv_visto=&quot;N&quot; /&gt;" name="FILTER">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
SELECT 
t0.oi_reclutado as oi_reclutado, 
SEC.policy 
FROM 

SDP14_RECLUTADOS as t0,
NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO\') as SEC 
JOIN 
t0.oi_reclutado LEFT OUTER SEC.id
WHERE
 	{%? 
(#SOURCE:@c_estado='V')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@c_estado='D')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@c_estado='C')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}       
{%?
(#SOURCE:@l_excluir ='1') 
{% t0.c_estado!= \'D\' AND %} 
{% %} 
%}
{%? 
(#SOURCE:@oi_aviso!='')	
{% t0.oi_aviso = {#SOURCE:@oi_aviso} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@oi_reclutado!='')	
{% t0.oi_reclutado = {#SOURCE:@oi_reclutado} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@c_cv_visto = 'V')	
{% t0.l_visto = 1 AND %} 
{% %} 
%}       
{%? 
(#SOURCE:@c_cv_visto = 'N')	
{% t0.l_visto = 0 AND %} 
{% %} 
%}
1=1    
ORDER BY 
oi_reclutado asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclutado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS oi_aviso=&quot;1&quot; c_estado=&quot;&quot; oi_reclutado=&quot;&quot; l_excluir=&quot;1&quot; c_cv_visto=&quot;&quot; /&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.INFO"/>
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.INFO"/>
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
SELECT 
t0.oi_reclutado as oi_reclutado, 
t0.c_estado as c_estado, 
t0.f_estado as f_estado,
t0.l_visto as l_visto,


t0.n_merito as n_merito, 
SEC.policy, 
SDP01_CV.c_cv as CODE, 
SDP01_CV.d_ape_y_nom as TEXT, 
t0.oi_aviso as oi_aviso, 
t0.oi_cv as oi_cv 
FROM 
SDP14_RECLUTADOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO\') as SEC, 
SDP01_CV 
JOIN 
t0.oi_reclutado LEFT OUTER SEC.id , 
t0.oi_cv LEFT OUTER SDP01_CV.oi_cv 
WHERE  					 
{%? 
(#SOURCE:@c_estado='V')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@c_estado='D')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@c_estado='C')	
{% t0.c_estado = {#SOURCE:@c_estado} AND %} 
{% %} 
%}       

{%? 
(#SOURCE:@oi_aviso!='')	
{% t0.oi_aviso = {#SOURCE:@oi_aviso} AND %} 
{% %} 
%}
{%? 
(#SOURCE:@oi_reclutado!='')	
{% t0.oi_reclutado = {#SOURCE:@oi_reclutado} AND %} 
{% %} 
%}     
{%?
(#SOURCE:@l_excluir ='1') 
{% t0.c_estado!= \'D\' AND %} 
{% %} 
%}
  {%? 
(#SOURCE:@c_cv_visto = 'V')	
{% t0.l_visto = 1 AND %} 
{% %} 
%}       
{%? 
(#SOURCE:@c_cv_visto = 'N')	
{% t0.l_visto = 0 AND %} 
{% %} 
%}     					
1 = 1
ORDER BY 
oi_reclutado asc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclutado"/>
						<qry:switch test="$r/@c_estado">
							<qry:case value="V">
								<qry:attribute name="c_estado" value="'Vigente'"/>
							</qry:case>
							<qry:case value="D">
								<qry:attribute name="c_estado" value="'Descartado'"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="c_estado" value="'Contratado'"/>
							</qry:default>
						</qry:switch>
						<qry:attribute name="f_estado" value="$r/@f_estado"/>
						<!--qry:attribute name="f_contratacion" value="$r/@f_contratacion"/-->
						<qry:attribute name="n_merito" value="$r/@n_merito"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_aviso!=''">
							<qry:then>
								<qry:element name="oi_aviso">
									<qry:attribute name="OI_FIND" value="$r/@oi_aviso"/>
									<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_aviso" value="'['+oi_aviso/ROW/@COD+'] '+oi_aviso/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_cv!=''">
							<qry:then>
								<qry:element name="oi_cv">
									<qry:attribute name="OI_FIND" value="$r/@oi_cv"/>
									<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.CVs.CV.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_cv" value="'['+oi_cv/ROW/@COD+'] '+oi_cv/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:attribute name="l_visto" value="$r/@l_visto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="AVISO"/>
		<qry:define declare="&lt;DATOS oi_aviso=&quot;3&quot; c_estado=&quot;&quot; oi_reclutado=&quot;&quot; l_excluir=&quot;&quot; /&gt;" name="QRY_AVISO">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT 
		AVISO.c_aviso,
		AVISO.d_puesto
	FROM 
		SDP05_AVISOS AS AVISO
	
	WHERE  					 
			AVISO.oi_aviso = {#SOURCE:@oi_aviso}						
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="aviso" value="'['+$r/@c_aviso + '] ' + $r/@d_puesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.filter.form"/>
		</flow:action>
		<flow:action name="adm-reclutados">
			<doc:new-object doc="DDO" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_reclutado" to-attr-path="#FILTERDATA:@oi_reclutado"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_aviso" to-attr-path="#FILTERDATA:@oi_aviso"/>
			<doc:load-qry qry="QRY_AVISO" output-doc="AVISO" input-doc-path="#FILTERDATA:"/>
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.noreg.autoform"/>
		</flow:action>
	</flow:main>
