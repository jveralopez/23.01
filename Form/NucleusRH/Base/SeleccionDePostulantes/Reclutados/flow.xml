		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.autoform:SHOW" doc-path="/RECLUTA_ENTREV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form" mode="SHOW"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.autoform:LIST" doc-path="/RECLUTA_ENTREV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form" mode="LIST"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
