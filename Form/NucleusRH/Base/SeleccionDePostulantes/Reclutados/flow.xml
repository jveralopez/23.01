			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.autoform:SHOW" doc-path="/RECLUTA_EXA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form" mode="SHOW"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.autoform:LIST" doc-path="/RECLUTA_EXA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.form" mode="LIST"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
