			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.autoform:EDIT" doc-path="/RECLUTA_ENTREV[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form:NEW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form" mode="NEW"/>
