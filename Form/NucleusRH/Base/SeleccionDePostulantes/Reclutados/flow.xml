			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form"/>
			</flow:action>
			<flow:action name="DESCARTADO">
				<doc:set-attribute from-value="D" to-attr-path="#SOURCE:@c_estado"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" doc="SOURCE"/>
				<flow:call-action action="load-DDO"/>
			</flow:action>
			<flow:action name="VerCV">
				<flow:exec-method method="VerCV" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO">
					<flow:param attr-path="#FORM:ctrl[@id='oi_reclutado_show' ]/@xval" type="Nomad.NSystem.Int" mode="in" name="oi_reclutado"/>
				</flow:exec-method>
				<flow:call-action action="After-Change"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form"/>
			</flow:action>
			<flow:action name="DESCARTADO">
				<flow:call-action action="load-DDO"/>
				<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="D"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" doc="DDO"/>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
			<flow:action name="VerCV">
				<flow:exec-method method="VerCV" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO">
					<flow:param attr-path="#FORM:ctrl[@id='oi_reclutado_list' ]/@xval" type="Nomad.NSystem.Int" mode="in" name="oi_reclutado"/>
				</flow:exec-method>
				<flow:call-action action="After-Change"/>
				<flow:call-action action="on-show"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.form" mode="EDIT"/>
	</flow:group>
	<flow:group Name="RECLUTA_ENTREV">
		<flow:form name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.form:SHOW" extends="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.noreg.autoform" mode="SHOW">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#PARENTSOURCE:RECLUTA_ENTREV/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#PARENTSOURCE:RECLUTA_ENTREV/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_ENTREV.form"/>
