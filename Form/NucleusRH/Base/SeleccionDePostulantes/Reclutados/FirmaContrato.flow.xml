<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRh.Base.SeleccionDePostulantes.ReclutadosFirmaContrato.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATO/>
		</doc:define>
		<doc:define name="DATA_FIRMA">
			<ROW oi_empresa="" oi_aviso="" oi_reclutado="" oi_puesto="" oi_posicion="" f_ingreso="" e_numero_legajo="" oi_tipo_personal="" oi_ctro_costo="" oi_calendario="" o_personal_emp=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#DATA_FIRMA:" parent-doc-path="#FILTERDATA:" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form extends="FILTER:FILTER" parent-doc="PARENTSOURCE" mode="FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.filter.form" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.filter.form:FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:log text-path="#SOURCE:" text="CHUEKLOG"/>
		</flow:action>
		<flow:action name="inits-DDO"/>
		<flow:action name="new-DDO"/>
		<flow:action name="open-flow-SHOW"/>
		<flow:action name="open-flow-ADD">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.form" doc-path="#SOURCE:" mode="NEW" parent-doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="open-flow-LIST"/>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="FILTER">
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="open-flow-ADD"/>
		</flow:action>
	</flow:form>
	<flow:form extends="CLASSROOT:NEW" name="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.form:NEW" mode="NEW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.FirmaContrato.form">
		<flow:action name="on-show"/>
		<flow:action name="SAVE">
			<flow:log text-path="#SOURCE:" text="chueksave"/>
			<flow:exec-method class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" method="FirmarContrato" priority="5" out-attr-path="#BATCHDOC:@batch-id">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
				<flow:param type="Nomad.NSystem.String" attr-path="#SOURCE:@caso" name="caso" mode="in"/>
				<flow:param attr-path="#SOURCE:@per_emp_ant" type="Nomad.NSystem.String" mode="in" name="per_emp_ant"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
