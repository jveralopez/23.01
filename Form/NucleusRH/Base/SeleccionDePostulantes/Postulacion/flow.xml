<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.SeleccionDePostulantes.Postulacion.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para NucleusRH.Base.Personal.Reportes.AptitudesVsPuesto"/>
	<flow:declare>
		<doc:define name="DDO"/>
		<doc:define name="NEWDDO"/>
		<doc:define name="QRY">
			<DATOS ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_empresa="">
				<PERSONAS/>
			</DATOS>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS oi_aviso="">
				<PERSONAS/>
			</DATOS>
		</doc:define>
		<doc:define name="PARAM"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Postulacion.filtro.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.Postulacion.filtro.form" name="NucleusRH.Base.SeleccionDePostulantes.Postulacion.filtro.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<flow:load-user-data name="SDP_IDsCVs" doc="QRY"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#QRY:"/>
			<flow:call-action action="Load-FILTER"/>
			<doc:set-attribute from-value="0" to-attr-path="#FILTERDATA:@l_mail"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:load-user-data name="SDP_IDsCVs" doc="QRY"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#QRY:" text="emiQRY"/>
			<flow:log text-path="#FILTERDATA:" text="emiFILTERDATA"/>
			<flow:exec-method method="PostulacionMasiva" class="NucleusRH.Base.SeleccionDePostulantes.CVs.CV" out-attr-path="#BATCHDOC:@batch-id" priority="5" out-type="String">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" name="param" doc="QRY" mode="in"/>
				<flow:param type="Nomad.NSystem.String" attr-path="#FILTERDATA:@oi_aviso" mode="in" name="oi_aviso"/>
				<flow:param attr-path="#FILTERDATA:@l_mail" type="Nomad.NSystem.Boolean" mode="in" name="l_mail"/>
			</flow:exec-method>
			<flow:call-action action="open-flow-BATCH"/>
		</flow:action>
		<flow:action name="open-flow-BATCH">
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.SeleccionDePostulantes.Postulacion" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.SeleccionDePostulantes.Postulacion" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
