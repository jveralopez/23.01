<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.flow" extends="Nomad.Base.flow">
	<flow:info label="Registro de Ex&#225;menes y Factores"/>
	<flow:declare>
		<doc:define class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA" name="DDO"/>
		<doc:define class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO" name="DDOROOT"/>
		<doc:define name="DATOS">
			<ROW oi_aviso="" oi_reclutado="" oi_examen="" f_examen="" n_resultado="" t_comentario=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form" mode="NEW" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form" name="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form:NEW" doc="SOURCE" parent-doc="PARENTSOURCE" mode="NEW">
		<flow:action name="NEXT">
			<doc:load-object id-path="#FORM:ctrl[@id='oi_reclutado']/@xval" doc="DDOROOT" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO"/>
			<flow:log text-path="#DDOROOT:" text="emig1"/>
			<flow:log text-path="#DATOS:" text="emig2"/>
			<flow:open-form parent-doc-path="#DDOROOT:RECLUTA_EXA/RECLUTA_EXA[@id={#DATOS:@oi_examen}]/FACT_EXA_REC" doc-path="#DDOROOT:" mode="FACTOR" form-class="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form"/>
			<flow:log text-path="#PARENTSOURCE:" text="EMIPARENTSOURCE"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="After-Save">
			<flow:log text-path="#DATOS:" text="EMIDATOS"/>
			<doc:set-attribute to-attr-path="#DATOS:@oi_reclutado"/>
			<doc:set-attribute to-attr-path="#DATOS:@oi_examen"/>
			<doc:set-attribute to-attr-path="#DATOS:@f_examen"/>
			<doc:set-attribute to-attr-path="#DATOS:@d_resultado"/>
			<doc:set-attribute to-attr-path="#DATOS:@n_valor"/>
			<doc:set-attribute to-attr-path="#DATOS:@t_comentario"/>
			<flow:call-action action="msg"/>
		</flow:action>
		<!--flow:action name="new-DDO">
		<doc:new-object class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA" doc="NEWDDOROOT"/>
		<flow:log text="EMIDDO" text-path="#NEWDDOROOT:"/>
	</flow:action-->
		<flow:action name="msg">
			<flow:message message="El examen fue registrado correctamente"/>
		</flow:action>
	</flow:form>
	<flow:form mode="FACTOR" name="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form:FACTOR" form-class="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form" doc="SOURCE" parent-doc="PARENTSOURCE">
		<!--flow:action name="SAVE">
		<doc:save-object doc="SOURCE" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO"/>
		<flow:close-form next-action="After-Save"/>
		<flow:message message="El examen fue registrado correctamente"/>
	</flow:action>
	<flow:action name="BACK">
		<flow:closeform/>
	</flow:action-->
		<flow:action name="SAVE">
			<flow:log text-path="#FORM:" text="emipp"/>
			<flow:call-action action="Save-Recluta_exa"/>
			<doc:save-object doc="SOURCE" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO"/>
			<flow:call-action action="BACK-save"/>
		</flow:action>
		<flow:action name="BACK-save">
			<flow:closeform/>
			<flow:close-form next-action="After-Save"/>
		</flow:action>
		<!--flow:action name="SAVE">
		<flow:call-action action="save-DDO"/>
		<flow:close-form next-action="After-Change"/>
	</flow:action>
	<flow:action name="save-DDO">
		<doc:load-object doc="DDO" class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA" id-path="#DDO:@id"/>
		<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA" doc="DDO"/>
	</flow:action-->
		<flow:action name="Save-Recluta_exa">
			<doc:set-attribute to-attr-path="#PARENTSOURCE:../@f_examen" from-attr-path="#DATOS:@f_examen"/>
			<doc:set-attribute to-attr-path="#PARENTSOURCE:../@d_resultado" from-attr-path="#DATOS:@d_resultado"/>
			<doc:set-attribute to-attr-path="#PARENTSOURCE:../@n_valor" from-attr-path="#DATOS:@n_valor"/>
			<doc:set-attribute to-attr-path="#PARENTSOURCE:../@t_comentario" from-attr-path="#DATOS:@t_comentario"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:closeform/>
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
