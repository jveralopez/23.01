<form:Form xmlns:form="nomad_engine.form" default_mode="FACTOR" name="NucleusRH.Base.SeleccionDePostulantes.ExamenesReclutados.REGISTRO.form" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:Label label="Registrar Ex&#225;menes Reclutado" nowrap="1" align="center" style="S3 LCol_w" name="GEN_NEW"/>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner width="100%" visible="0" name="buttonlinks">
			<form:Row name="row_top">
				<form:Columns note="=== Iterador ===&#13;&#10;El [[wiki:Nomad.Generico.Iterador.wiki|iterador]] es una grupo de controles utizados para la navegacion entre los distintos registros filtrados." help-stop="1" width="100%" name="columns1">
					<form:Column width="50%" align="left" name="col1">
						<form:RowAligner name="rowsiter" align="left">
							<form:Row name="rowiter">
								<form:Button visible="SHOW" name="ITERATOR_FIRST" label="" img="first" descrip="Primer Registro" note="Ir al primer Registro" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_FIRST">
									<form:Event runat="server" name="onclick" action="ITER:FIRST"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_FIRST/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_FIRST"/>
									</form:Policies>
								</form:Button>
								<form:Button visible="SHOW" name="ITERATOR_PREV" label="" img="prev" descrip="Anterior Registro" note="Ir al Registro Anterior" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_PREV">
									<form:Event runat="server" name="onclick" action="ITER:PREV"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_PREV/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_PREV"/>
									</form:Policies>
								</form:Button>
								<form:TextBox nvalue="#iter-cursor:@position" visible="SHOW" name="iter_position" length="4" xsize="4" ysize="1" descr="Indica o setea la posicion." required="False" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_position">
									<form:Event runat="server" name="OnChange" action="ITER:MOVETO"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_position/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_position"/>
									</form:Policies>
								</form:TextBox>
								<form:Button visible="SHOW" name="ITERATOR_NEXT" label="" img="next" descrip="Proximo Registro" note="Ir al Registro Proximo" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_NEXT">
									<form:Event runat="server" name="onclick" action="ITER:NEXT"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_NEXT/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_NEXT"/>
									</form:Policies>
								</form:Button>
								<form:Button visible="SHOW" name="ITERATOR_LAST" label="" img="last" descrip="Ultimo Registro" note="Ir al Ultimo Registro" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_LAST">
									<form:Event runat="server" name="onclick" action="ITER:LAST"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_LAST/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/ITERATOR_LAST"/>
									</form:Policies>
								</form:Button>
								<form:TextBox nvalue="#iter-cursor:@size" visible="SHOW" name="iter_size" length="4" xsize="4" ysize="1" descr="Indica o setea el size." enabled="0" required="False" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_size">
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_size/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_size"/>
									</form:Policies>
								</form:TextBox>
								<form:Blank width="20px" visible="SHOW" name="blank_rowtop2"/>
								<form:CheckBox enabled="0" img="lock" name="LockREG" visible="SHOW" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LockREG">
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LockREG/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LockREG"/>
									</form:Policies>
								</form:CheckBox>
								<form:Blank width="20px" visible="LIST" name="blank_rowtop1"/>
								<form:TextBox visible="LIST" xsize="50" length="100" name="iter_search" label="Buscar" ysize="1" descr="Busca." X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_search">
									<form:Event runat="client" name="onpressenter" action="Find"/>
									<form:SButtons>
										<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
											<form:Event runat="client" name="onclick" action="Find"/>
										</form:SButton>
									</form:SButtons>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_search/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/iter_search"/>
									</form:Policies>
								</form:TextBox>
							</form:Row>
						</form:RowAligner>
					</form:Column>
					<form:Column width="50%" align="right" name="col2">
						<form:RowAligner name="rowsprint" align="right">
							<form:Row name="rowprint">
								<form:Button label="Imprimir" visible="LIST" descrip="Imprimir la pantalla de lista" img="print" name="PRINT" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/PRINT">
									<form:Event action="Imprimir" name="onclick" runat="client"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/PRINT/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/PRINT"/>
									</form:Policies>
								</form:Button>
								<form:Button label="Registro" enabled="LIST" visible="SHOW|LIST" descrip="Muestra el registro seleccionado" img="binocular" name="MOSTRAR" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/MOSTRAR">
									<form:Event action="SHOW" name="onclick" runat="server"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/MOSTRAR/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/MOSTRAR"/>
									</form:Policies>
								</form:Button>
								<form:Button visible="SHOW|LIST" enabled="SHOW" img="properties" descrip="Muestra los registros en modo lista" label="Lista" name="LISTA" X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LISTA">
									<form:Event name="showList" action="LIST" runat="server"/>
									<form:Event name="onclick" runat="client" action="ToList"/>
									<form:Policies>
										<form:Updateable X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LISTA/HAB"/>
										<form:Visible X-POLICY="./FORM/NucleusRH/Base/SeleccionDePostulantes/ExamenesReclutados/REGISTRO/form/LISTA"/>
									</form:Policies>
								</form:Button>
							</form:Row>
						</form:RowAligner>
					</form:Column>
				</form:Columns>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="lb1"/>
		<form:Columns width="60%" visible="SHOW|EDIT|DELETE|NEW|FACTOR" name="main_columnsEXAMEN_FACT">
			<form:Column valign="top" align="center" separation="2" name="main_columnsEXAMEN_FACTcolumn1">
				<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO.INFO" label="Aviso" xsize="50" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#DATOS:@oi_aviso" name="oi_aviso"/>
				<form:Blank height="2" name="bl1"/>
				<form:ComboBox where1="SDP14_RECLUTADOS.c_estado = 'V'" prev="oi_aviso" queryname1="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTADO.INFO" label="Reclutado" xsize="50" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#DATOS:@oi_reclutado" name="oi_reclutado">
					<form:SButtons/>
				</form:ComboBox>
				<form:ComboBox where1="isnull(SDP14_RECLUTA_EXA.f_examen)" prev="oi_reclutado" queryname1="NucleusRH.Base.SeleccionDePostulantes.Reclutados.RECLUTA_EXA.INFO" xsize="50" mode="QRY" required="1" enabled="NEW|EDIT" label="Ex&#225;men" nvalue="#DATOS:@oi_examen" name="oi_examen"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Ex&#225;men" nvalue="#DATOS:@f_examen" name="f_examen">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox length="1500" required="0" enabled="NEW|EDIT" ysize="6" xsize="50" label="Resultado" nvalue="#DATOS:@d_resultado" name="d_resultado"/>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" nvalue="#DATOS:@n_valor" name="n_valor"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="6" xsize="50" length="1500" label="Comentarios" nvalue="#DATOS:@t_comentario" name="t_comentario"/>
				<form:Container visible="FACTOR" descrip="Factores" label="Factores" name="CONT_FACT">
					<form:Grid nvalue="#PARENTSOURCE:" idvalue="#source:@id" visible="FACTOR" allowdel="0" allownew="0" paging="1" rows="5" name="MAIN_GRID" doc="source">
						<form:GColumns>
							<form:GColumn name="gcolsel">
								<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
							</form:GColumn>
							<form:GColumn name="gcoloi_factor_examen">
								<form:ComboBox queryname1="NucleusRH.Base.SeleccionDePostulantes.Examenes.FACTOR_EXAMEN.INFO" xsize="30" mode="QRY" required="1" enabled="NEW|EDIT" label="Factor" nvalue="#source:oi_factor_examen/@value" name="oi_factor_examen"/>
							</form:GColumn>
							<form:GColumn name="gcold_resultado">
								<form:TextBox required="0" ysize="1" xsize="50" length="100" label="Resultado" nvalue="#source:@d_resultado" name="d_resultado"/>
							</form:GColumn>
						</form:GColumns>
					</form:Grid>
				</form:Container>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button label="Siguiente" descrip="Pantalla siguiente" startvalidate="1" visible="NEW|EDIT" img="next" name="NEXT">
					<form:Event action="NEXT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Guarda los cambios realizados" label="Guardar" startvalidate="1" visible="FACTOR" img="save" name="SAVE">
					<form:Event action="ValDates" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="NEW|EDIT|DELETE" descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="FACTOR" note="Vuelve a la pantalla anterior del formulario" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ValDates()
{
	Ctrl('main').DoEvent("guardar"); 
	Ctrl("oi_reclutado").SetXValue(""); 
	Ctrl("oi_examen").SetXValue("");
	Ctrl("f_examen").SetCValue("");
	Ctrl("d_resultado").SetCValue("");
	Ctrl("n_valor").SetCValue("");
	Ctrl("t_comentario").SetCValue("");
}
	</form:Scripts>
	<form:Event name="guardar" action="SAVE" runat="server"/>
</form:Form>
