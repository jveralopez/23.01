	<form:Scripts>
		&#13;&#10;&#13;&#10;function val_convenio (me)
{
	if (me.GetXValue() == '1')
	{
		if (Ctrl('oi_categoria').GetCValue() == "")
		{
			me.SetError("El puesto es de convenio y requiere cargar una categoria");
			return false;
		}		
	}
	else
	{
		if (Ctrl('oi_banda_sal').GetCValue() == "")
		{
			me.SetError("El puesto es fuera de convenio y requiere cargar una banda salarial");
			return false;
		}		
	}
	return true;
}

function set_controls()
{
	if (Ctrl('l_convenio'))
	{
		if (Ctrl('l_convenio').GetXValue() == '1')
		{		
			Ctrl('oi_banda_sal').SetCValue("");		
			CtrlEnabled('oi_banda_sal', false);
