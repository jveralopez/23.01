<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO" extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Costos" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Costos" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Costos" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Costos" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_item_costo">
					<form:ComboBox queryname2="NucleusRH.Base.SeleccionDePostulantes.Tipos_Costos.TIPO_COSTO.INFO" queryname1="NucleusRH.Base.SeleccionDePostulantes.Tipos_Costos.ITEM_COSTO.INFO" xsize="30" mode="QRY" required="0" enabled="NEW|EDIT" label="Tipo Costo - Item Costo" nvalue="#source:oi_item_costo/@value" name="oi_item_costo">
						<form:Event action="SetCosto" name="onchange" runat="client"/>
					</form:ComboBox>
				</form:GColumn>
				<form:GColumn name="gcoln_costo">
					<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Monto del Costo" nvalue="#source:@n_costo" name="n_costo"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/SeleccionDePostulantes/Puestos/COSTO_PUESTO/NEW" visible="EDIT|LIST_EDIT" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/SeleccionDePostulantes/Puestos/COSTO_PUESTO/DELETE" visible="EDIT|LIST_EDIT" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SetCosto()
{                                                    
	var item_costo = Ctrl("MAIN_GRID").GetCellSelectedXValue("oi_item_costo");
	
	var valor;				
	np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
		
	valor = nSQL.GetOBJ(Ctrl("main").getResource("QRY_COSTO"), "&lt;PARAM oi_item_costo=\""+item_costo+"\" /&gt;"); 		
  var MyControl = Ctrl("MAIN_GRID").GetCellSelectedControl("n_costo");
	MyControl.SetXValue(valor.n_costo);
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_puesto=&quot;723&quot; oi_item_costo=&quot;2&quot;/&gt;" name="QRY_COSTO">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:attribute name="oi_puesto" value="''"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					COSTO.n_costo
				FROM 
					SDP11_ITEMS_COSTO AS COSTO
				WHERE 
					COSTO.oi_item_costo = {#SOURCE:@oi_item_costo}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@n_costo" name="n_costo"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
