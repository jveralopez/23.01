<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.flow" extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.autoflow">
	<flow:info label="Flow para NucleusRH.Base.SeleccionDePostulantes.Puestos"/>
	<flow:declare>
		<doc:define name="PUESTO">
			<PUESTO oi_puesto=""/>
		</doc:define>
		<doc:define name="FILTERDATA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS/>
			</FILTRO>
		</doc:define>
		<doc:define name="FILTERDATA_ORGANIGRAMA">
			<FILTRO ORDEN3="" ATRIB_ORDEN3="" ORDEN2="" ATRIB_ORDEN2="" ORDEN1="" ATRIB_ORDEN1="" oi_categorias="" oi_bandas_sal="" oi_empresa="" ID="x">
				<PUESTOS>
					<PUESTO id=""/>
				</PUESTOS>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;185&quot; ID=&quot;x&quot; oi_banda_sal=&quot;&quot; oi_categoria=&quot;&quot;&gt;&#13;&#10;  &lt;PUESTOS&gt;&#13;&#10;    &lt;PUESTO id=&quot;687&quot; /&gt;&#13;&#10;  &lt;/PUESTOS&gt;&#13;&#10;&lt;/FILTRO&gt;&#13;&#10;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:FILTRO" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG04_PUESTOS.oi_puesto, 
					ORG04_PUESTOS.c_puesto, 
					ORG04_PUESTOS.d_puesto,	
					ORG03_EMPRESAS.c_empresa
	    	FROM 
	    		ORG04_PUESTOS, ORG03_EMPRESAS
     			{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    			{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN 
      		ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
      		{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
       	  {%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 
      		1=1 
      		{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa={#SOURCE:@oi_empresa} %} {% %} %}        
       	  {%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
       	  {%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
        	{%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
	  			{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     			oi_puesto ASC
    	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@oi_puesto" type="Nomad.NSystem.Int"/>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
					NMD_SECURITY.policy 
				FROM 
					NMD_SECURITY 
				WHERE 
					NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
					AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO ORDEN3=&quot;&quot; ATRIB_ORDEN3=&quot;&quot; ORDEN2=&quot;&quot; ATRIB_ORDEN2=&quot;&quot; ORDEN1=&quot;&quot; ATRIB_ORDEN1=&quot;&quot; oi_categorias=&quot;&quot; oi_bandas_sal=&quot;&quot; oi_empresa=&quot;185&quot; ID=&quot;x&quot; oi_banda_sal=&quot;&quot; oi_categoria=&quot;&quot;&gt;&#13;&#10;  &lt;PUESTOS&gt;&#13;&#10;    &lt;PUESTO id=&quot;687&quot; /&gt;&#13;&#10;  &lt;/PUESTOS&gt;&#13;&#10;&lt;/FILTRO&gt;&#13;&#10;" name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('	
			  SELECT 
			  	ORG04_PUESTOS.oi_puesto, 
			  	ORG04_PUESTOS.c_puesto, 
			  	ORG04_PUESTOS.d_puesto, 
			  	ORG04_PUESTOS.oi_empresa, 
			  	ORG03_EMPRESAS.c_empresa,
			  	SDP10_PUESTOS.l_usa_plantilla
 		  	FROM 
 		  		ORG04_PUESTOS, ORG03_EMPRESAS, SDP10_PUESTOS
     			{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG17_BANDAS_SAL %} {% %} %}
    			{%? (#SOURCE:@oi_categoria!='') {% ,ORG18_CATEGORIAS %} {% %} %}
      	JOIN 
      		ORG04_PUESTOS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
      		ORG04_PUESTOS.oi_puesto LEFT OUTER SDP10_PUESTOS.oi_puesto
      		{%? (#SOURCE:@oi_banda_sal!='') {% ,ORG04_PUESTOS.oi_banda_sal INNER ORG17_BANDAS_SAL.oi_banda_sal  %} {% %} %}
       	  {%? (#SOURCE:@oi_categoria!='') {% ,ORG04_PUESTOS.oi_categoria INNER ORG18_CATEGORIAS.oi_categoria  %} {% %} %}        	      	
      	WHERE 
      		1=1 
      		{%? (#SOURCE:@oi_empresa!='')	  {% AND ORG03_EMPRESAS.oi_empresa  ={#SOURCE:@oi_empresa} %} {% %} %}        
        	{%? (#SOURCE:@oi_banda_sal!='') {% AND ORG04_PUESTOS.oi_banda_sal ={#SOURCE:@oi_banda_sal} %} {% %} %}
        	{%? (#SOURCE:@oi_categoria!='') {% AND ORG04_PUESTOS.oi_categoria ={#SOURCE:@oi_categoria} %} {% %} %}        	
        	{%? (string(#SOURCE:PUESTOS/PUESTO/@id)!='') {% AND ORG04_PUESTOS.oi_puesto in ({%=string(#SOURCE:PUESTOS/PUESTO/@id) %}) %} {%  %} %}
	      ORDER BY 
	  			{%? (#SOURCE:@ATRIB_ORDEN1!='')	{% {%=#SOURCE:@ATRIB_ORDEN1%} {%? (#SOURCE:@ORDEN1!='') {% {%=#SOURCE:@ORDEN1%}, %} {% ASC, %}	%} %} {% %} %}
     			oi_puesto ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_puesto"/>
						<qry:attribute name="c_puesto" value="$r/@c_puesto"/>
						<qry:attribute name="d_puesto" value="$r/@d_puesto"/>
						<!--qry:attribute name="utiliza_plantilla" value="$r/@utiliza_plantilla" type="Nomad.NSystem.Int"/-->
						<qry:attribute name="l_usa_plantilla" value="iif($r/@l_usa_plantilla='1','Si', 'No')"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:insert-select doc-path="." name="SECURITY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="SECURITY">
				<qry:xquery>
					for $r in sql('
				SELECT
				NMD_SECURITY.policy 
				FROM NMD_SECURITY 
				WHERE NMD_SECURITY.class=\'NucleusRH.Base.Organizacion.Puestos.PUESTO\' 
				AND NMD_SECURITY.id={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ID OI_ESTRUCTURA=&quot;178&quot; /&gt;" name="GET_PUESTO">
			<qry:main doc="SOURCE">
				<qry:element name="PUESTO">
					<qry:insert-select name="QRY_PUESTO" doc-path="#SOURCE:ID"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_PUESTO" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
				SELECT 
					ORG04_POSICIONES.oi_puesto
				FROM 
					ORG04_POSICIONES
				WHERE 
					ORG04_POSICIONES.oi_unidad_org in 
					(SELECT 
						ORG02_ESTRUCTURAS.oi_unidad_org
					 FROM 
					 	ORG02_ESTRUCTURAS WHERE ORG02_ESTRUCTURAS.oi_estructura = {%=#SOURCE:@OI_ESTRUCTURA%})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_puesto" value="$r/@oi_puesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ORGANIGRAMA">
			<doc:load-qry output-doc="PUESTO" qry="GET_PUESTO" input-doc-path="#SOURCE:"/>
			<doc:set-attribute from-attr-path="#PUESTO:@oi_puesto" to-attr-path="#FILTERDATA_ORGANIGRAMA:PUESTOS/PUESTO/@id"/>
			<doc:assign-value from-path="#FILTERDATA_ORGANIGRAMA:" to-doc="FILTERDATA"/>
			<doc:load-qry input-doc-path="#FILTERDATA:" qry="FILTER" output-doc="QRY"/>
			<doc:new-object class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO" doc="DDO"/>
			<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.noreg.autoform" parent-doc-path="#QRY:" doc-path="#DDO:" iter-index="#QRY:ROW/@value" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="PUESTO">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.filter.autoform:FILTER" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.filter.form" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="FILTER">
				<flow:log text-path="#FILTERDATA:" text="PPFILTER"/>
				<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.autoform:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form:SHOW" mode="SHOW" doc="SOURCE" parent-doc="PARENTSOURCE">
			<flow:action name="EDIT">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" doc-path="#DDO:" mode="EDIT"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.autoform:LIST" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" doc-path="#DDO:" mode="EDIT"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.autoform:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form:EDIT" parent-doc="PARENTSOURCE" mode="EDIT" doc="SOURCE">
			<flow:action name="save-DDO">
				<flow:log text="ppddoCV" text-path="#DDO:"/>
				<doc:save-object class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO" doc="DDO"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.noreg.autoform" extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.PUESTO.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group Name="COSTO_PUESTO">
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.autoform" mode="SHOW">
			<flow:action name="on-move-iterator">
				<flow:open-form iter-index="#PARENTSOURCE:COSTO_PUESTO/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form:SHOW" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form" mode="SHOW"/>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.noreg.autoform" mode="EDIT">
			<flow:action name="on-move-iterator">
				<flow:open-form iter-index="#PARENTSOURCE:COSTO_PUESTO/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form"/>
			</flow:action>
			<flow:action name="ADD">
				<doc:new-object doc="NEWDDO" class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO"/>
				<doc:add-object doc-path="#NEWDDO:" parent-doc-path="#PARENTSOURCE:"/>
				<flow:open-form iter-index="#PARENTSOURCE:COSTO_PUESTO/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form:EDIT" form-class="NucleusRH.Base.SeleccionDePostulantes.Puestos.COSTO_PUESTO.form" mode="EDIT"/>
	</flow:group>
</flow:flow>
