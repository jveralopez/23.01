function CallLogin(obj)
{                        
	switch (obj.m_ID)
	{        
		case "actualizarCV": getFormInMain("Nomad.Base.Login.Entidades.autoflow"     , "initialize", "", false); break;
		/*		
		repetir por cada opci#		*/
		default:
			alert(obj.m_ID);
	}
}

function CallWindows(obj)
{                        
