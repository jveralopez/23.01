<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto">
		Flow para Nomad.Base.Liquidacion.NovedadesLiquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS salida="HTML" report="" oi_presupuesto="" oi_escenario="" l_incluir="">
				<ROWS/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto.filtro.form" name="NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto.filtro.form:EDIT" parent-doc="PARENTSOURCE" mode="FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action else="pp2" eq="1" if="#SOURCE:@l_incluir" action="pp1"/>
			<doc:set-attribute from-value="005 - Listado de Novedades por Escenario" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="pp1">
			<flow:exec-method method="ExecReportHTML" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Presupuesto.NovedadesPresupuestoDetalle.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="pp2">
			<flow:exec-method method="ExecReportHTML" class="Nomad.Base.Report.GeneralReport.REPORT" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Presupuesto.NovedadesPresupuesto.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
		</flow:action>
	</flow:form>
</flow:flow>
