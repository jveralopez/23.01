<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="NucleusRH.Base.Presupuesto.Reportes.NovedadesPresupuesto.filtro.form" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Title>
		<form:Label label="005 - Listado de Novedades por Escenario" name="lbl" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:Columns height="100%" width="100%" name="cols1">
			<form:Column width="100%" name="Coltipo" separation="2" align="right" valign="top">
				<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.INFO" nvalue="#source:@oi_presupuesto" label="Presupuesto" name="oi_presupuesto" xsize="40" mode="QRY" required="1"/>
				<form:ComboBox prev="oi_presupuesto" xsize="40" nvalue="#source:@oi_escenario" name="oi_escenario" label="Escenario" queryname1="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.INFO" mode="QRY" required="1"/>
				<form:CheckBox label="Listar Detalle" nvalue="#source:@l_incluir" name="l_incluir"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="blk12"/>
		<form:Grid width="480px" nvalue="#source:ROWS" proto="&lt;ROW/&gt;" name="grdvariable" note="" descrip="" rows="3" allowhelper="0" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" doc="SOURCE">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.Novedades.NOVEDAD.INFO" nvalue="#SOURCE:@id" label="Variable" name="oi_variable" xsize="70" mode="QRY" required="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
