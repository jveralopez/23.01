<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano.flow">
	<flow:info label="Flow para NucleusRH.Base.Presupuesto.Reportes.PorEstructura"/>
	<flow:declare>
		<doc:define name="REPORTDOM"/>
		<doc:define name="FILTER">
			<DATA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano.filtro.form" doc-path="#FILTER:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano.filtro.form" name="NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano.filtro.form:FILTER" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Presupuesto.ReportePorEstructuraPlano.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTER:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="003 - Reporte por Estructura (plano)" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano" doc-path="#FILTER:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.PorEstructuraPlano" doc="FILTER"/>
		</flow:action>
	</flow:form>
</flow:flow>
