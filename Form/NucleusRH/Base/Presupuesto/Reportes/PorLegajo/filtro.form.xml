<form:Form xmlns:form="nomad_engine.form" name="filtro.reporte.novedadesliquidacion" extends="nomad.Base.report.filtro.form" doc="source">
	<form:Scripts>
		function clearLiq()
{
	Ctrl('oi_liquidacion').SetCValue('');
}
	</form:Scripts>
	<form:Title>
		<form:Label name="lbl" label="Reporte por Legajo" visible="" align="center" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.INFO" xsize="40" mode="QRY" required="1" label="Presupuesto" nvalue="#source:@oi_presupuesto" name="oi_presupuesto"/>
		<form:Blank name="blk12"/>
		<form:ComboBox prev="oi_presupuesto" queryname1="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.INFO" xsize="30" mode="QRY" required="1" label="Escenario" nvalue="#source:@oi_escenario" name="oi_escenario"/>
		<form:Blank name="blk127"/>
		<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.INFO" xsize="40" mode="QRY" required="1" label="Estructura Reporte" nvalue="#source:@oi_est_reporte" name="oi_est_reporte"/>
	</form:Center>
	<form:Bottom width="60%">
		<form:RowAligner columns="3" name="botonera">
			<form:Row name="fila">
				<form:Button label="Filtrar" descrip="" note="" startvalidate="1" img="ok" visible="" enabled="" name="btnAccept">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button descrip="" note="" label="Volver" name="btnCancel" img="back" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
