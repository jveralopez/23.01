<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="Nomad.Base.Presupuesto.Reportes.PorLegajo">
	<flow:info label="Flow para Nomad.Base.Presupuesto.Reportes.PorLegajo">
		Flow para Nomad.Base.Presupuesto.Reportes.PorLegajo
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA salida="HTML"/>
		</doc:define>
		<qry:define name="qry_obtener_estructura">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:attribute name="oi_escenario" value="#SOURCE:DATA/@oi_escenario"/>
					<qry:insert-select doc-path="#SOURCE:DATA" name="qry_Obtener"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_Obtener" doc="SOURCE">
				<qry:xquery>
					for $r in sql ('
	SELECT E.oi_est_reporte 
FROM PRE03_ESCENARIOS AS E
WHERE e.oi_escenario = {#SOURCE:@oi_escenario}
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_est_reporte" value="$r/@oi_est_reporte"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute from-value="0" to-attr-path="#FILTERDATA:@desdeEscenario"/>
			<flow:open-form parent-doc-path="#SOURCE:" form-class="NucleusRH.Base.Presupuesto.Reportes.PorLegajo.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="initializeEscenario">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_escenario" to-attr-path="#FILTERDATA:@oi_escenario"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_est_reporte" to-attr-path="#FILTERDATA:@oi_est_reporte"/>
			<doc:load-qry qry="qry_obtener_estructura" output-doc="FILTERDATA" input-doc-path="#FILTERDATA:"/>
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@desdeEscenario"/>
			<flow:exec-method class="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE" method="RepPorLegajo" out-attr-path="#BATCHDOC:@batch-id" priority="1">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<flow:open-form mode="SHOW" form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" form-class="NucleusRH.Base.Presupuesto.Reportes.PorLegajo.filtro.form" name="NucleusRH.Base.Presupuesto.Reportes.PorLegajo.filtro.form:EDIT" mode="FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.PorLegajo" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Presupuesto.Reportes.PorLegajo" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE" method="RepPorLegajo" out-attr-path="#BATCHDOC:@batch-id" priority="1">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="Reporte por Legajo" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form parent-doc-path="#PARENTSOURCE:" form-class="Nomad.base.HTML_XLS.form" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" form-class="Nomad.base.HTML_XLS.form" name="Nomad.base.HTML_XLS.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="BACK">
			<flow:log text-path="#FILTERDATA:" text="egg80"/>
			<flow:call-action else="volver" eq="1" if="#FILTERDATA:@desdeEscenario" action="exit"/>
		</flow:action>
		<flow:action name="exit">
			<flow:log text-path="#PARENTSOURCE:" text="egg81"/>
			<flow:exit-flow return-path="#PARENTSOURCE:" next-action="initializeLegajo" next-flow="NucleusRH.Base.Presupuesto.Escenarios.flow"/>
		</flow:action>
		<flow:action name="volver">
			<flow:log text-path="#FILTERDATA:" text="egg82"/>
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
