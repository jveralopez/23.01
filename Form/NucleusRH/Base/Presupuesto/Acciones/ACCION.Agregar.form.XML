<form:Form xmlns:form="nomad_engine.form" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Presupuesto.Acciones.ACCION">
	<form:Help>
		<form:Help-title text="Acciones sobre el Presupuesto" name="TITLE"/>
		<form:Help-descr text="Aqui se registran las Acciones sobre el Presupuesto" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Crear Acciones sobre el Presupuesto" name="GEN_NEW"/>
				<form:Label visible="Paso1" nowrap="1" align="center" style="S3 LCol_w" label="Paso 1" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="PASO2" style="S3 LCol_w" label="Paso 2" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="PASO3" style="S3 LCol_w" label="Paso 3" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#TITULO:@DESC" name="lblTitulo"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right width="200px"/>
	<form:Center width="95%">
		<form:Columns name="main_columnsACCION">
			<form:Column name="main_columnsACCIONcolumn1">
				<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.INFO" xsize="40" mode="QRY" required="1" enabled="0" label="Presupuesto" nvalue="#FILTERDATA:@id" name="oi_presupuesto"/>
				<form:ComboBox enabled="0" prev="oi_presupuesto" queryname1="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.INFO" xsize="30" mode="QRY" required="1" label="Escenario" nvalue="#source:oi_escenario/@value" name="oi_escenario"/>
				<form:NumberBox required="1" enabled="0" mask="###.###.##0" xsize="12" label="C&#243;digo" nvalue="#source:@e_accion" name="e_accion"/>
				<form:TextBox required="1" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_accion" name="d_accion"/>
				<form:ComboBox prev="oi_escenario" queryname1="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO" xsize="20" mode="QRY" required="1" label="Detalle de Aplicacion" nvalue="#source:oi_detalle_pres/@value" name="oi_detalle_pres"/>
				<form:ComboBox prev="oi_escenario" queryname1="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO" xsize="20" mode="QRY" required="0" label="Detalle Base" nvalue="#source:oi_base/@value" name="oi_base"/>
				<form:NumberBox required="1" mask="###.###.##0.00" xsize="15" precision="3" label="Monto/Porcentaje" nvalue="#source:@n_valor" name="n_valor"/>
				<form:TextBox required="0" descr="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_accion" name="o_accion"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="blank_rowList"/>
		<form:ListView docname="TIPOS" name="TIPOS" paging="1" rows="10">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="C&#243;digo" attrname="e_tipo_accion" name="e_tipo_accion"/>
				<form:LVColumn align="left" sorteable="1" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." width="100px" type="string" label="Descripci&#243;n" attrname="d_tipo_accion" name="d_tipo_accion"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Monto Fijo" attrname="l_monto_fijo" name="l_monto_fijo"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Base Fija" attrname="l_base_fija" name="l_base_fija"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" img="next" label="Siguiente" name="Siguiente" descrip="Siguiente">
					<form:Event action="Acceptar" name="onclick" runat="client"/>
					<form:Event action="Siguiente" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="back" mess="&#191;Est&#225; seguro que desa eliminar el registro?" descrip="Volver" label="Volver" name="Back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		var SELROW;

function Acceptar()
{
	SELROW = Ctrl('TIPOS').GetXValue();
	if(Ctrl('TIPOS').GetSelectAttrValue('l_base_fija')==1)
	{                                                       
		if (Ctrl('oi_base').GetXValue()=='')
		{
			alert("Debe cargar el detalle base");
			return false;
		}             
	}			
	return true;
}
	</form:Scripts>
</form:Form>
