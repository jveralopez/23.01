<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="NucleusRH.Base.Presupuesto.Acciones.autoflow" name="NucleusRH.Base.Presupuesto.Acciones">
	<flow:info label="Flow para NucleusRH.Base.Presupuesto.Acciones"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA id=""/>
		</doc:define>
		<doc:define name="TITULO">
			<DATA id="" CODE="" DESC=""/>
		</doc:define>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t0.oi_accion as oi_accion, 
				SEC.policy FROM 
				PRE09_ACCIONES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Acciones.ACCION\') as SEC 
			JOIN 
				t0.oi_accion LEFT OUTER SEC.id  
			where 
				t0.oi_escenario = {#PARAM:@id_esce}
			ORDER BY 
				oi_accion asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_accion"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusRH.Base.Presupuesto.TiposAccion.TIPO_ACCION.INFO"/>
			<qry:include name="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO"/>
			<qry:include name="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t0.oi_accion as oi_accion, 
				t0.e_accion as e_accion, 
				t0.d_accion as d_accion, 
				t0.n_valor as n_valor, 
				
				t0.d_formula as d_formula, 
				SEC.policy, 
				t0.e_accion as CODE, 
				t0.d_accion as TEXT, 
				t0.oi_escenario as oi_escenario, 
				t0.oi_tipo_accion as oi_tipo_accion, 
				t0.oi_detalle_pres as oi_detalle_pres, 
				t0.oi_base as oi_base 
			FROM 
				PRE09_ACCIONES as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Acciones.ACCION\') as SEC 
			JOIN 
				t0.oi_accion LEFT OUTER SEC.id  
			where 
				t0.oi_escenario = {#PARAM:@id_esce}
			ORDER BY 
				oi_accion asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_accion"/>
						<qry:attribute name="e_accion" value="$r/@e_accion"/>
						<qry:attribute name="d_accion" value="$r/@d_accion"/>
						<qry:attribute name="n_valor" value="$r/@n_valor"/>
						<qry:attribute name="d_formula" value="$r/@d_formula"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_tipo_accion!=''">
							<qry:then>
								<qry:element name="oi_tipo_accion">
									<qry:attribute name="OI_FIND" value="$r/@oi_tipo_accion"/>
									<qry:insert-select name="NucleusRH.Base.Presupuesto.TiposAccion.TIPO_ACCION.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_accion" value="'['+oi_tipo_accion/ROW/@COD+'] '+oi_tipo_accion/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_detalle_pres!=''">
							<qry:then>
								<qry:element name="oi_detalle_pres">
									<qry:attribute name="OI_FIND" value="$r/@oi_detalle_pres"/>
									<qry:insert-select name="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_detalle_pres" value="'['+oi_detalle_pres/ROW/@COD+'] '+oi_detalle_pres/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_base!=''">
							<qry:then>
								<qry:element name="oi_base">
									<qry:attribute name="OI_FIND" value="$r/@oi_base"/>
									<qry:insert-select name="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_base" value="'['+oi_base/ROW/@COD+'] '+oi_base/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="TIPOS_ACCIONES"/>
		<qry:define name="qry_tipos_acciones" declare="&lt;DATA id_esce=&quot;1&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="TIPOS">
					<qry:insert-select name="sql1" doc-path=""/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT 
	T.oi_tipo_accion,
	T.e_tipo_accion,
	T.d_tipo_accion,
	T.d_formula, 
	T.l_monto_fijo, 
	T.l_base_fija
FROM 
	PRE10_TIPO_ACCION AS T
Order by         
	e_tipo_accion asc
	
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="TIPO">
						<qry:attribute name="id" value="$r/@oi_tipo_accion"/>
						<qry:attribute name="oi_tipo_accion" value="$r/@oi_tipo_accion"/>
						<qry:attribute name="e_tipo_accion" value="$r/@e_tipo_accion"/>
						<qry:attribute name="d_tipo_accion" value="$r/@d_tipo_accion"/>
						<qry:attribute name="d_formula" value="$r/@d_formula"/>
						<qry:attribute name="l_monto_fijo" value="$r/@l_monto_fijo"/>
						<qry:attribute name="l_base_fija" value="$r/@l_base_fija"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PERSONAS_INCLUIDAS">
			<DATOS>
				<ROWS/>
			</DATOS>
		</doc:define>
		<qry:define declare="&lt;ACCION nmd-status=&quot;~i,d_accion,n_valor,&quot; e_accion=&quot;Autom&#225;tico&quot; descr=&quot;Nuevo&quot; d_accion=&quot;6&quot; n_valor=&quot;6.00&quot; o_accion=&quot;&quot;&gt;&#13;&#10;&lt;oi_escenario nmd-agr=&quot;1&quot; value=&quot;1&quot; nmd-status=&quot;~u,value,&quot; /&gt;&#13;&#10;&lt;oi_tipo_accion nmd-agr=&quot;1&quot; value=&quot;1&quot; nmd-status=&quot;~u,value,&quot; /&gt;&#13;&#10;&lt;oi_detalle_pres nmd-agr=&quot;1&quot; value=&quot;6&quot; nmd-status=&quot;~u,value,&quot; /&gt;&#13;&#10;&lt;oi_base nmd-agr=&quot;1&quot; value=&quot;6&quot; nmd-status=&quot;~u,value,&quot; /&gt;&#13;&#10;&lt;ACC_CONC nmd-col=&quot;1&quot; /&gt;&#13;&#10;&lt;ACC_LEG nmd-col=&quot;1&quot; /&gt;&#13;&#10;&lt;/ACCION&gt;&#13;&#10;" name="qry_obt_conceptos">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:element name="ROWS">
						<qry:insert-select name="sql1" doc-path="#SOURCE:ACCION/oi_tipo_accion"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT
	T.oi_tacc_conc,
	T.oi_tipo_accion,
	T.oi_concepto
FROM
	PRE10_TACC_CONC AS T
	WHERE T.oi_tipo_accion = {#PARAM:@value}
	
	
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_concepto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="CONCEPTOS_INCLUIDOS"/>
		<doc:define name="IDSLegajos"/>
		<qry:define declare="&lt;DATA id_esce=&quot;1&quot;/&gt;" name="qry_titulo_esce">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT 
	O.d_empresa, 
	P.d_presupuesto, 
	E.e_numero, E.C_ESTADO
FROM 
	PRE03_ESCENARIOS AS E, 
	PRE12_PRESUPUESTO AS P, 
	ORG03_EMPRESAS AS O
WHERE 
	E.oi_presupuesto = P.oi_presupuesto
	AND
	P.oi_empresa = O.oi_empresa
	AND
	E.oi_escenario = {#PARAM:@id_esce}
	
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@oi_escenario"/>
					<qry:attribute name="C_ESTADO" value="$r/@C_ESTADO"/>
					<qry:attribute name="DESC" value="$r/@d_empresa + '-' + $r/@d_presupuesto + '-' + $r/@e_numero"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define class="NucleusRH.Base.Presupuesto.Legajos.LEGAJO" name="DDOLegajo"/>
		<doc:define name="REPORTE">
			<DATA/>
		</doc:define>
		<qry:define declare="&lt;DATA id_esce=&quot;9&quot; /&gt;" name="UBICACION">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:." name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="SQL1">
				<qry:xquery>
					for $r in SQL(
'maxsize 1
	select 
		PRE11_NIVELES.oi_nivel,
		PRE11_NIVELES.e_orden,
		PRE06_EST_REPORTE.oi_nodo
	from
		PRE06_EST_REPORTE, 
		PRE11_NIVELES, 
		PRE03_ESCENARIOS
	join              
		PRE06_EST_REPORTE.oi_est_reporte inner PRE03_ESCENARIOS.oi_est_reporte,
		PRE11_NIVELES.oi_def_reporte inner PRE06_EST_REPORTE.oi_def_reporte
	where
		PRE03_ESCENARIOS.oi_escenario={#SOURCE:@id_esce}
	order by
		e_orden desc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_nivel" value="$r/@oi_nivel"/>
					<qry:attribute name="oi_nodo" value="$r/@oi_nodo"/>
					<qry:insert-select doc-path="." name="SQL2"/>
					<qry:attribute name="oi_nivel" value="''"/>
					<qry:attribute name="oi_nodo" value="''"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="SQL2">
				<qry:xquery>
					for $r in SQL(
'select 
		PRE06_NODOS.oi_nodo,
		PRE06_NODOS.oi_nivel,
		PRE06_NODOS.d_nodo,
		PRE06_NODOS.c_valor_iden
	from
		PRE06_NODOS
	where
		PRE06_NODOS.oi_nodo_padre={#SOURCE:@oi_nodo}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="@oi_nivel=$r/@oi_nivel">
						<qry:then>
							<qry:element name="option">
								<qry:attribute name="value" value="$r/@c_valor_iden"/>
								<qry:attribute name="text" value="$r/@d_nodo"/>
							</qry:element>
						</qry:then>
					</qry:if>
					<qry:insert-select doc-path="$r" name="SQL2"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="UBICACION"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:set-attribute from-attr-path="#SOURCE:@Modo" to-attr-path="#FILTERDATA:@Modo"/>
			<doc:set-attribute from-attr-path="#SOURCE:@nivel" to-attr-path="#FILTERDATA:@nivel"/>
			<doc:set-attribute from-attr-path="#SOURCE:@id" to-attr-path="#FILTERDATA:@id"/>
			<doc:set-attribute from-attr-path="#SOURCE:@id_esce" to-attr-path="#FILTERDATA:@id_esce"/>
			<doc:set-attribute from-attr-path="#SOURCE:@Modo_esce" to-attr-path="#FILTERDATA:@Modo_esce"/>
			<doc:set-attribute from-value="M" to-attr-path="#FILTERDATA:@LoadDDO_esce"/>
			<doc:load-qry output-doc="TITULO" input-doc-path="#SOURCE:" qry="qry_titulo_esce"/>
