			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Acciones.ACCION.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Presupuesto.Acciones.ACCION.form"/>
			</flow:action>
			<flow:action name="Load-FILTER"/>
			<flow:action name="Save-FILTER"/>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Presupuesto.Acciones.ACCION.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Presupuesto.Acciones.ACCION.noreg.form:EDIT" form-class="NucleusRH.Base.Presupuesto.Acciones.ACCION.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Acciones.ACCION"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@id_esce" to-attr-path="#NEWDDOROOT:oi_escenario/@value"/>
			</flow:action>
