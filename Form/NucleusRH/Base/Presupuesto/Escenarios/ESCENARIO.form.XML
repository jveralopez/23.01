	<form:Scripts>
		var SELROW;

function onLoad()
{
	if (Ctrl('main').GetMode()=="NEW")
	{
		Ctrl('f_alta').SetXValue(datetime2str(Now()));
	}
	if (Ctrl('main').GetMode()=="SHOW")
	{ 
		if (Ctrl('c_estado').GetXValue()=="A" || Ctrl('c_estado').GetXValue()=="R")
		{   
			CtrlEnabled('INCORPORARLEGAJOS', false);
			CtrlEnabled('APROBARESCENARIO', false);
			CtrlEnabled('RECHAZARESCENARIO', false);
			CtrlEnabled('EDIT', false);
			CtrlEnabled('DELETE', false);
		}
		if (Ctrl('c_estado').GetXValue()=="P")
		{             
			CtrlEnabled('INCORPORARLEGAJOS', true);
			CtrlEnabled('APROBARESCENARIO', true);
			CtrlEnabled('RECHAZARESCENARIO', true);
			CtrlEnabled('EDIT', true);
			CtrlEnabled('DELETE', true);
		}
	}                                
	if (Ctrl('main').GetMode()=="LIST")
	{
	  
	  SELROW = Ctrl('LIST').GetXValue();
		if (Ctrl('LIST').GetSelectAttrValue('c_estado')=="A" || Ctrl('LIST').GetSelectAttrValue('c_estado')=="R")
		{                     
			CtrlEnabled('INCORPORARLEGAJOS', false);
			CtrlEnabled('APROBARESCENARIO', false);
			CtrlEnabled('RECHAZARESCENARIO', false);
			CtrlEnabled('EDIT', false);
			CtrlEnabled('DELETE', false);
		}
		if (Ctrl('LIST').GetSelectAttrValue('c_estado')=="P")
		{                     
			CtrlEnabled('INCORPORARLEGAJOS', true);
			CtrlEnabled('APROBARESCENARIO', true);
			CtrlEnabled('RECHAZARESCENARIO', true);
			CtrlEnabled('EDIT', true);
			CtrlEnabled('DELETE', true);
		}
	}
	return true;
}      

function ListClick()
{ 
	var img;
	
	if (Ctrl("LIST"))
	{
		img=Ctrl("LIST").GetSelectAttrValue("img").toUpperCase().split("/");
		img=img[img.length-1].split(".")[0];
		
		switch(img)
		{
			case "LOCK":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKDEL":
				CtrlEnabled("EDIT"  ,true );
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKEDIT":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",true );
			break;
			default:
				CtrlEnabled("EDIT"  ,true);
				CtrlEnabled("DELETE",true);
			break;
		}
	}
	
	if ((Ctrl("LockREG")) &amp;&amp; (Ctrl("HiLockREG"))) 
	{                  
		
		Ctrl("LockREG").SetXValue(Ctrl("HiLockREG").GetXValue());
		CtrlEnabled("EDIT"  ,Ctrl("LockREG").GetXValue()!="1");
		CtrlEnabled("DELETE",Ctrl("LockREG").GetXValue()!="1");
	}
onLoad();
}
	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
</form:Form>
