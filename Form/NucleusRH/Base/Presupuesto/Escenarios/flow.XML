<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Presupuesto.Escenarios.autoflow" name="NucleusRH.Base.Presupuesto.Escenarios">
	<flow:info label="Flow para NucleusRH.Base.Presupuesto.Escenarios"/>
	<flow:declare>
		<doc:define name="PRESUPUESTO">
			<DATA id=""/>
		</doc:define>
		<qry:define declare="&lt;DATA id=&quot;1&quot; /&gt;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('            
			SELECT 
				t0.oi_escenario as oi_escenario, 
				SEC.policy 
				
			FROM 
				PRE03_ESCENARIOS as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO\') as SEC 
				JOIN t0.oi_escenario LEFT OUTER SEC.id  
				where 
					 t0.oi_presupuesto = {#PARAM:@id}
				ORDER BY oi_escenario asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_escenario"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA id=&quot;1&quot; /&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
				t0.oi_escenario as oi_escenario, 
				t0.e_numero as e_numero, 
				t0.c_estado as c_estado, 
				t0.e_seguimiento as e_seguimiento, 
				t0.f_alta as f_alta, 
				t0.f_aprobacion as f_aprobacion, 
				SEC.policy, t0.e_numero as CODE, 
				t0.e_numero as TEXT, 
				t0.oi_presupuesto as oi_presupuesto, 
				t0.oi_def_reporte as oi_def_reporte, 
				t0.oi_est_reporte as oi_est_reporte 
			FROM 
				PRE03_ESCENARIOS as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO\') as SEC 
			JOIN 
				t0.oi_escenario LEFT OUTER SEC.id  
			WHERE
				t0.oi_presupuesto = {#PARAM:@id}
			ORDER BY 
				e_numero asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_escenario"/>
						<qry:attribute name="e_numero" value="$r/@e_numero"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="e_seguimiento" value="$r/@e_seguimiento"/>
						<qry:attribute name="f_alta" value="$r/@f_alta"/>
						<qry:attribute name="f_aprobacion" value="$r/@f_aprobacion"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<DATA id=""/>
		</doc:define>
		<qry:define declare="&lt;DATA id=&quot;1&quot;/&gt;" name="qry_titulo">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT
	P.oi_presupuesto,
	P.c_presupuesto,
	P.d_presupuesto,
	P.c_estado,
	P.oi_empresa,
	E.c_empresa, 
	E.d_empresa
FROM
	PRE12_PRESUPUESTO AS P, ORG03_EMPRESAS AS E
JOIN
	P.oi_empresa INNER E.oi_empresa
WHERE
	P.oi_presupuesto = {#PARAM:@id}
	
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@oi_escenario"/>
					<qry:attribute name="DESC" value="$r/@d_empresa + '-' + $r/@d_presupuesto"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="TITULO">
			<DATA id="" CODE="" DESC=""/>
		</doc:define>
		<qry:define declare="&lt;DATA id_pres_aprob=&quot;1&quot; /&gt;" name="qry_aprobar">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('            
			SELECT 
				t0.oi_escenario as oi_escenario				
				,t0.e_seguimiento as e_seguimiento, t0.oi_presupuesto
			FROM 
				PRE03_ESCENARIOS as t0,
				PRE03_ESCENARIOS as t1			
			where    
				t0.e_seguimiento = t1.e_seguimiento  
				and
				t0.oi_presupuesto = t1.oi_presupuesto
				and
				t1.oi_escenario = {#PARAM:@id_pres_aprob}
				and
				not(t0.oi_escenario = {#PARAM:@id_pres_aprob})
			ORDER BY oi_escenario asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_escenario"/>
						<qry:attribute name="e_seguimiento" value="$r/@e_seguimiento"/>
						<qry:attribute name="oi_presupuesto" value="$r/@oi_presupuesto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="APROBAR"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:log text-path="#SOURCE:" text="egg3"/>
			<doc:set-attribute from-attr-path="#SOURCE:@id" to-attr-path="#FILTERDATA:@id"/>
			<doc:set-attribute from-attr-path="#SOURCE:@Modo" to-attr-path="#FILTERDATA:@Modo"/>
			<doc:set-attribute from-attr-path="#SOURCE:@nivel" to-attr-path="#FILTERDATA:@nivel"/>
			<doc:set-attribute from-value="M" to-attr-path="#FILTERDATA:@LoadDDO_esce"/>
			<flow:log text-path="#FILTERDATA:" text="egg4"/>
			<doc:load-qry output-doc="TITULO" input-doc-path="#SOURCE:" qry="qry_titulo"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.filter.autoform"/>
		</flow:action>
		<flow:action name="initializeLegajo">
			<flow:log text-path="#SOURCE:" text="egg11"/>
			<doc:set-attribute from-attr-path="#SOURCE:@Modo" to-attr-path="#FILTERDATA:@Modo"/>
			<doc:set-attribute from-attr-path="#SOURCE:@nivel" to-attr-path="#FILTERDATA:@nivel"/>
			<doc:set-attribute from-attr-path="#SOURCE:@id_esce" to-attr-path="#FILTERDATA:@id_esce"/>
			<doc:set-attribute from-attr-path="#SOURCE:@id" to-attr-path="#FILTERDATA:@id"/>
			<doc:set-attribute from-attr-path="#SOURCE:@Modo_esce" to-attr-path="#FILTERDATA:@Modo_esce"/>
			<doc:set-attribute from-value="E" to-attr-path="#FILTERDATA:@LoadDDO_esce"/>
			<flow:log text-path="#FILTERDATA:" text="egg8"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.filter.autoform"/>
		</flow:action>
	</flow:main>
	<flow:group Name="ESCENARIO">
		<flow:form name="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.filter.form:FILTER" extends="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.filter.autoform" mode="FILTER">
			<flow:action name="new-DDO">
				<flow:exec-method method="CrearEscenario" out-type="Nomad.NSystem.Object" out-doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO">
					<flow:param attr-path="#FILTERDATA:@id" type="Nomad.NSystem.String" mode="in" name="oi_presupuesto"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.noreg.autoform"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="Load-FILTER"/>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.noreg.form:EDIT" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<!--doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO"/>
	<doc:set-attribute from-attr-path="#FILTERDATA:@id" to-attr-path="#NEWDDOROOT:oi_presupuesto/@value"/-->
				<flow:exec-method method="CrearEscenario" out-type="Nomad.NSystem.Object" out-doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO">
					<flow:param attr-path="#FILTERDATA:@id" type="Nomad.NSystem.String" mode="in" name="oi_presupuesto"/>
				</flow:exec-method>
				<flow:log text-path="#NEWDDOROOT:" text="egg40"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="After-Back">
				<flow:exit-flow next-action="initializeEsce" next-flow="NucleusRH.Base.Presupuesto.Presupuestos.flow" return-path="#FILTERDATA:"/>
			</flow:action>
			<flow:action name="BACK">
				<flow:exit-flow next-action="initializeEsce" next-flow="NucleusRH.Base.Presupuesto.Presupuestos.flow" return-path="#FILTERDATA:"/>
			</flow:action>
			<flow:action name="load-DDO_legajo">
				<doc:load-object id-path="#FILTERDATA:@id_esce" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO" doc="DDO"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<flow:call-action if="#FILTERDATA:@LoadDDO_esce" else="load-DDO_legajo" eq="M" action="load-DDO"/>
				<flow:call-action if="#FILTERDATA:@Modo_esce" eq="S" else="goto-list" action="goto-show"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form:SHOW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form" mode="SHOW">
			<flow:action name="new-DDO">
				<!--doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO"/>
	<doc:set-attribute from-attr-path="#FILTERDATA:@id" to-attr-path="#NEWDDOROOT:oi_presupuesto/@value"/-->
				<flow:exec-method method="CrearEscenario" out-type="Nomad.NSystem.Object" out-doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO">
					<flow:param attr-path="#FILTERDATA:@id" type="Nomad.NSystem.String" mode="in" name="oi_presupuesto"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="CALL:LEGAJOS">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="S" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:exit-flow return-path="#PRESUPUESTO:" next-action="initialize" next-flow="NucleusRH.Base.Presupuesto.Legajos.flow"/>
			</flow:action>
			<flow:action name="CALL:ACCIONES">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="S" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:exit-flow return-path="#PRESUPUESTO:" next-action="initialize" next-flow="NucleusRH.Base.Presupuesto.Acciones.flow"/>
			</flow:action>
			<flow:action name="CALL:INCORPORAR">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="S" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:exit-flow return-path="#PRESUPUESTO:" next-action="initializeIncorporar" next-flow="NucleusRH.Base.Presupuesto.Legajos.flow"/>
			</flow:action>
			<flow:action name="CALL:DUPLICAR">
				<flow:exec-method priority="3" out-attr-path="#BATCHDOC:@batch-id" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO" method="DuplicarEscenario">
					<flow:param attr-path="#DDO:@id" type="Nomad.NSystem.String" mode="in" name="oi_escenario"/>
				</flow:exec-method>
				<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
			<flow:action name="CALL:APROBAR">
				<doc:set-attribute to-attr-path="#FILTERDATA:@id_pres_aprob" from-attr-path="#DDO:@id"/>
				<doc:load-qry input-doc-path="#FILTERDATA:" output-doc="APROBAR" qry="qry_aprobar"/>
				<flow:exec-method this-doc="DDO" method="AprobarEscenario" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO">
					<flow:param doc="APROBAR" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlPresupuestos"/>
				</flow:exec-method>
			</flow:action>
			<flow:action name="CALL:RECHAZAR">
				<flow:open-form doc-path="#DDO:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.Rechazar.form"/>
			</flow:action>
			<flow:action name="CALL:REPORTE">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="S" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<doc:set-attribute to-attr-path="#PRESUPUESTO:@oi_escenario" from-attr-path="#DDO:@id"/>
				<flow:exit-flow next-flow="NucleusRH.Base.Presupuesto.Reportes.PorEstructura.flow" return-path="#PRESUPUESTO:" next-action="initializeEscenario"/>
			</flow:action>
			<flow:action name="DELETE">
				<flow:exec-method priority="3" out-attr-path="#BATCHDOC:@batch-id" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO" method="EliminarEscenario">
					<flow:param attr-path="#DDO:@id" type="Nomad.NSystem.String" mode="in" name="oi_escenario"/>
				</flow:exec-method>
				<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form:LIST" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form" mode="LIST">
			<flow:action name="new-DDO">
				<flow:exec-method method="CrearEscenario" out-type="Nomad.NSystem.Object" out-doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO">
					<flow:param attr-path="#FILTERDATA:@id" type="Nomad.NSystem.String" mode="in" name="oi_presupuesto"/>
				</flow:exec-method>
				<!--doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO"/>
	<doc:set-attribute from-attr-path="#FILTERDATA:@id" to-attr-path="#NEWDDOROOT:oi_presupuesto/@value"/-->
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.form"/>
			</flow:action>
			<flow:action name="CALL:DETALLE_PRES">
				<flow:call-action action="load-DDO"/>
				<flow:open-form iter-index="#DDO:DETALLES/DETALLE_PRES/@id" parent-doc-path="#DDO:DETALLES" doc-path="#DDO:DETALLES" mode="SHOW" form-class="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.noreg.autoform"/>
			</flow:action>
			<flow:action name="CALL:LEGAJOS">
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="L" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:log text-path="#PRESUPUESTO:" text="egg13"/>
				<flow:exit-flow return-path="#PRESUPUESTO:" next-action="initialize" next-flow="NucleusRH.Base.Presupuesto.Legajos.flow"/>
			</flow:action>
			<flow:action name="CALL:ACCIONES">
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@Modo" to-attr-path="#PRESUPUESTO:@Modo"/>
				<doc:set-attribute from-attr-path="#FILTERDATA:@nivel" to-attr-path="#PRESUPUESTO:@nivel"/>
				<doc:set-attribute from-value="L" to-attr-path="#PRESUPUESTO:@Modo_esce"/>
				<flow:log text-path="#PRESUPUESTO:" text="egg14"/>
				<flow:exit-flow return-path="#PRESUPUESTO:" next-action="initialize" next-flow="NucleusRH.Base.Presupuesto.Acciones.flow"/>
			</flow:action>
			<flow:action name="CALL:INCORPORAR">
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='LIST']/@xval" to-attr-path="#PRESUPUESTO:@id_esce"/>
				<doc:set-attribute from-attr-path="#DDO:oi_presupuesto/@value" to-attr-path="#PRESUPUESTO:@id"/>
