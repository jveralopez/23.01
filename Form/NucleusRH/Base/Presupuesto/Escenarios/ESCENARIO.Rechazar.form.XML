<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.rechazar" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Help>
		<form:Help-title text="Escenarios" name="TITLE"/>
		<form:Help-descr text="Tabla donde se registran los Escenarios." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Rechazar Escenarios" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
				<form:Label dynamic="1" nvalue="#TITULO:@DESC" name="lblTitulo"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsESCENARIO">
			<form:Column name="main_columnsESCENARIOcolumn1">
				<form:Blank name="bl1"/>
				<form:TextBox required="1" ysize="4" xsize="50" length="1000" label="Motivo de Rechazo" nvalue="#source:@o_rechazo" name="o_rechazo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" visible="NEW|EDIT" img="save" label="Guardar" name="SAVE" X-POLICY="./FORM/NucleusRH/Base/Presupuesto/Escenarios/ESCENARIO/Rechazar/form/SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" visible="NEW|EDIT|DELETE" img="cancel" label="Cancelar" name="CANCEL" X-POLICY="./FORM/NucleusRH/Base/Presupuesto/Escenarios/ESCENARIO/Rechazar/form/CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
