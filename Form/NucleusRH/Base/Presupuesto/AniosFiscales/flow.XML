	<flow:declare>
		<qry:define name="LIST:NucleusRH.Base.Presupuesto.AniosFiscales.PERIODO_FISCAL">
			<qry:include name="NucleusRH.Base.Presupuesto.TiposPeriodo.TIPO_PERIODO.INFO"/>
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:./PERIODO_FISCAL[substring_before(@nmd-status,',')!='~d' and substring_before(@nmd-status,',')!='~x']" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in #PARAM:
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:attribute name="e_periodo_fiscal" value="$r/@e_periodo_fiscal"/>
						<qry:attribute name="c_corta" value="$r/@c_corta"/>
						<qry:attribute name="d_periodo_fiscal" value="$r/@d_periodo_fiscal"/>
						<qry:attribute name="l_afecto_total" value="$r/@l_afecto_total"/>
						<qry:attribute name="pepe" value="$r/@e_periodo"/>
						<qry:attribute name="e_periodo" value="format_date($r/@e_periodo + '01','mm/yyyy')"/>
						<qry:attribute name="e_orden" value="$r/@e_orden"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/oi_tipo_periodo/@value!=''">
							<qry:then>
								<qry:element name="oi_tipo_periodo">
									<qry:attribute name="OI_FIND" value="$r/oi_tipo_periodo/@value"/>
									<qry:insert-select name="NucleusRH.Base.Presupuesto.TiposPeriodo.TIPO_PERIODO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_periodo" value="'['+oi_tipo_periodo/ROW/@COD+'] '+oi_tipo_periodo/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
