<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Presupuesto.Interface.NovedadesPorLegajo.flow" extends="Nomad.Base.flow" description="Flow para la carga de interfaces de novedades por legajo" default_action="initialize">
	<flow:info label="Flow para la carga de interfaces de novedades por legajo"/>
	<flow:declare>
		<doc:define name="DATOSLIQ">
			<DOC/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="Int_NovedadPersona_Ent" doc="DATOSLIQ"/>
			<doc:set-attribute to-attr-path="#DATOSLIQ:@file_name" from-value=""/>
			<flow:open-form doc-path="#DATOSLIQ:" form-class="NucleusRH.Base.Presupuesto.Interface.NovedadesPorLegajo.SeleccionArchivo.form" mode="EDIT"/>
		</flow:action>
	</flow:main>
	<flow:group name="SeleccionArchivo">
		<flow:form form-class="NucleusRH.Base.Presupuesto.Interface.NovedadesPorLegajo.SeleccionArchivo.form" name="NucleusRH.Base.Presupuesto.Interface.NovedadesPorLegajo.SeleccionArchivo.form" doc="SOURCE" mode="EDIT">
			<flow:action name="VOLVER">
				<flow:exit-flow return-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="EJECUTAR">
				<flow:save-user-data doc-path="#SOURCE:" name="Int_NovedadPersona_Ent"/>
				<flow:exec-method class="NucleusRH.Base.Presupuesto.InterfaceNovedadesPorLegajo.ENTRADA" out-attr-path="#SOURCE:@batch-id" priority="5" method="ImportarNovedades">
					<flow:param attr-path="#SOURCE:@oi_escenario" type="Nomad.NSystem.String" mode="in" name="poi_escenario"/>
				</flow:exec-method>
				<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group name="VisualizacionArchivo">
		<flow:form doc="SOURCE" mode="SHOW" form-class="NucleusRH.Base.Liquidacion.Interface.Variables.NovedadPersona_Ent.VisualizarArchivo.form" name="NucleusRH.Base.Liquidacion.Interface.Variables.NovedadPersona_Ent.VisualizarArchivo.form">
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="PROCESAR"/>
		</flow:form>
	</flow:group>
</flow:flow>
