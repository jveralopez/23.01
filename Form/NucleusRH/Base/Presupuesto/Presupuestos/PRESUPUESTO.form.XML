<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO">
	<form:Help>
		<form:Help-title text="Presupuesto" name="TITLE"/>
		<form:Help-descr text="Tabla donde se registran los presupuestos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Presupuesto" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Presupuesto" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Presupuesto" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Presupuesto" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsPRESUPUESTO">
			<form:Column name="main_columnsPRESUPUESTOcolumn1">
				<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.AniosFiscales.ANIO_FISCAL.INFO" xsize="40" mode="QRY" required="1" enabled="NEW" label="Anio Fiscal" nvalue="#source:oi_anio_fiscal/@value" name="oi_anio_fiscal"/>
				<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Empresa" nvalue="#source:oi_empresa/@value" name="oi_empresa"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_presupuesto" name="c_presupuesto"/>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_presupuesto" name="d_presupuesto"/>
				<form:ComboBox xsize="40" mode="OPT" required="1" enabled="0" descr="C&#243;digo del Curso. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="Estado" nvalue="#source:@c_estado" name="c_estado">
					<options>
						<option text="Abierto" value="A"/>
						<option text="Pendiente" value="P"/>
						<option text="Cerrado" value="C"/>
					</options>
				</form:ComboBox>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Alta" nvalue="#source:@f_alta" name="f_alta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Cierre" nvalue="#source:@f_cierre" name="f_cierre">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox nvalue="#source:@e_seguimiento" name="e_seguimiento" required="0" enabled="0" mask="###.###.##0" xsize="12" label="Nivel de Seguimiento Actual"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_presupuesto" name="o_presupuesto"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Anio Fiscal" attrname="oi_anio_fiscal" name="oi_anio_fiscal"/>
				<form:LVColumn additional="&lt;combo action=&quot;COMBO&quot; flow=&quot;NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="combo" label="Empresa" attrname="oi_empresa" name="oi_empresa"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_presupuesto" name="c_presupuesto"/>
				<form:LVColumn align="left" sorteable="1" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." width="100px" type="string" label="Descripci&#243;n" attrname="d_presupuesto" name="d_presupuesto"/>
				<form:LVColumn additional="&lt;OPTS&gt;&lt;OPT value=&quot;A&quot; text=&quot;Abierto&quot; /&gt;&lt;OPT value=&quot;P&quot; text=&quot;Pendiente&quot; /&gt;&lt;OPT value=&quot;C&quot; text=&quot;Cerrado&quot; /&gt;&lt;/OPTS&gt;" align="left" sorteable="1" descr="C&#243;digo del Curso. Puede ser un alfanum&#233;rico de hasta 30 caracteres." width="50px" type="enum" label="Estado" attrname="c_estado" name="c_estado"/>
				<form:LVColumn visible="0" help-stop="1" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Alta" attrname="f_alta" name="f_alta"/>
				<form:LVColumn visible="0" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha de Cierre" attrname="f_cierre" name="f_cierre"/>
				<form:LVColumn visible="0" attrname="e_seguimiento" name="e_seguimiento" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Nivel de Seguimiento Actual"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Presupuesto/Presupuestos/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Presupuesto/Presupuestos/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Presupuesto/Presupuestos/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Presupuesto/Presupuestos/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Right name="Dependencias">
		<form:VGroup background="1" label="Acciones" collapse="1" width="100%" name="vgChilds">
			<form:Link enabled="SHOW|LIST" allowimg="1" policy="NucleusRH/Base/Presupuesto/Escenarios/READ" descrip="Escenarios del presupuesto" label="Administrar Escenarios" name="ESCENARIOS">
				<form:Event policy="NucleusRH/Base/Presupuesto/Escenarios/READ" action="CALL:ESCENARIOS" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Scripts>
		function onLoad()
{
	if (Ctrl('main').GetMode()=="NEW")
	{
		Ctrl('f_alta').SetXValue(datetime2str(Now()));
		Ctrl('e_seguimiento').SetXValue(0);
		
		return true;
	}
	return true;
}
	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
</form:Form>
