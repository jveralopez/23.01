				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Presupuesto/Legajos/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Presupuesto/Legajos/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onLoad()
{              
	if (Ctrl('main').GetMode()=="SHOW"||Ctrl('main').GetMode()=="LIST")
	{ 
		
		if (Ctrl('ESCENARIO_c_estado').GetXValue()=="A" || Ctrl('ESCENARIO_c_estado').GetXValue()=="R")
		{   
			CtrlEnabled('EDIT', false);
			CtrlEnabled('DELETE', false);
		}
		if (Ctrl('ESCENARIO_c_estado').GetXValue()=="P")
		{             
			CtrlEnabled('EDIT', true);
			CtrlEnabled('DELETE', true);
		}
	}                                
return true;
}

function ListClick()
{ 
	var img;
	
	if (Ctrl("LIST"))
	{
		img=Ctrl("LIST").GetSelectAttrValue("img").toUpperCase().split("/");
		img=img[img.length-1].split(".")[0];
		
		switch(img)
		{
			case "LOCK":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKDEL":
				CtrlEnabled("EDIT"  ,true );
				CtrlEnabled("DELETE",false);
			break;
			case "LOCKEDIT":
				CtrlEnabled("EDIT"  ,false);
				CtrlEnabled("DELETE",true );
			break;
			default:
				CtrlEnabled("EDIT"  ,true);
				CtrlEnabled("DELETE",true);
			break;
		}
	}
	
	if ((Ctrl("LockREG")) &amp;&amp; (Ctrl("HiLockREG"))) 
	{                  
		
		Ctrl("LockREG").SetXValue(Ctrl("HiLockREG").GetXValue());
		CtrlEnabled("EDIT"  ,Ctrl("LockREG").GetXValue()!="1");
		CtrlEnabled("DELETE",Ctrl("LockREG").GetXValue()!="1");
	}
onLoad();
}
	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
	<form:Right width="200px">
		<form:VGroup name="vgChildsACCIONES" background="1" label="Acciones" collapse="1" width="100%" X-POLICY="./FORM/NucleusRH/Base/Presupuesto/Legajos/LEGAJO/form/vgChildsLEGAJO">
			<form:Link name="CALLREPORTE" allowimg="1" label="Reporte" X-POLICY="./FORM/NucleusRH/Base/Presupuesto/Legajos/LEGAJO/form/NOV_LEGAJO">
				<form:Event action="CALL:REPORTE" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
</form:Form>
