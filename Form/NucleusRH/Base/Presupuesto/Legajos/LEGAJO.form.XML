				<form:DateTime pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha de Egreso" nvalue="#source:@f_egreso" name="f_egreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Antiguedad reconocida" nvalue="#source:@f_antiguedad" name="f_antiguedad">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
