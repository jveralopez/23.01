				<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.GruposPersonas.GRUPO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Grupo" nvalue="#source:oi_grupo/@value" name="oi_grupo"/>
				<form:NumberBox required="1" enabled="NEW|EDIT" descr="C&#243;digo del Curso. Puede ser un alfanum&#233;rico de hasta 30 caracteres." mask="###.###.##0" xsize="12" label="Legajo" nvalue="#source:@e_numero_legajo" name="e_numero_legajo"/>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Nombre y Apellido" nvalue="#source:@d_legajo" name="d_legajo"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha de Ingreso" nvalue="#source:@f_ingreso" name="f_ingreso">
