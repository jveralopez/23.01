<form:Form xmlns:form="nomad_engine.form" default_mode="NEW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Presupuesto.Legajos.LEGAJO">
	<form:Help>
		<form:Help-title text="Legajos" name="TITLE"/>
		<form:Help-descr text="Aqui se registran todos los legajos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Incorporar personas al escenario:" nowrap="1" align="center" style="S3 LCol_w" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#TITULO:@DESC" name="lblTitulo"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsLEGAJO">
			<form:Column name="main_columnsLEGAJOcolumn1">
				<form:ComboBox enabled="NEW" queryname1="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.INFO" xsize="40" mode="QRY" required="1" label="Presupuesto" nvalue="#INCORPORAR:@oi_presupuesto" name="oi_presupuesto"/>
				<form:ComboBox nvalue="#INCORPORAR:@oi_escenario" prev="oi_presupuesto" enabled="NEW" label="Escenario" queryname1="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.INFO" xsize="30" mode="QRY" required="1" name="oi_escenario"/>
				<form:ComboBox prev="oi_escenario" name="oi_detalle_desde" label="Detalle del escenario Desde" queryname1="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO" xsize="20" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#INCORPORAR:@oi_detalle_desde"/>
				<form:ComboBox visible="0" prev="oi_escenario" name="oi_detalle_hasta" label="Detalle del escenario Hasta" queryname1="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO" xsize="20" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#INCORPORAR:@oi_detalle_hasta"/>
				<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.GruposPersonas.GRUPO.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Grupo" nvalue="#INCORPORAR:@oi_grupo" name="oi_grupo"/>
				<form:ComboBox queryname1="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Modalidad" nvalue="#INCORPORAR:@oi_modalidad" name="oi_modalidad"/>
				<form:ComboBox enabled="NEW|EDIT" queryname1="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO" xsize="30" mode="QRY" required="1" label="Convenio" name="oi_convenio"/>
				<form:ComboBox enabled="NEW|EDIT" prev="oi_convenio" queryname1="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.INFO" xsize="30" mode="QRY" required="1" label="Categor&#237;a" nvalue="#INCORPORAR:@oi_categoria" name="oi_categoria"/>
				<form:NumberBox required="1" enabled="NEW|EDIT" descr="C&#243;digo del Curso. Puede ser un alfanum&#233;rico de hasta 30 caracteres." mask="###.###.##0" xsize="12" label="Legajo" nvalue="#INCORPORAR:@e_numero_legajo" name="e_numero_legajo"/>
				<form:TextBox required="1" enabled="NEW|EDIT" descr="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." ysize="1" xsize="50" length="100" label="Nombre y Apellido" nvalue="#INCORPORAR:@d_legajo" name="d_legajo"/>
				<form:ComboBox docname="UBICACION" nvalue="#INCORPORAR:@c_ultimo_nivel" name="c_ultimo_nivel" xsize="40" mode="DOC" required="1" enabled="NEW|EDIT" label="Ubicacion"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Ingreso" nvalue="#INCORPORAR:@f_ingreso" name="f_ingreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Egreso" nvalue="#INCORPORAR:@f_egreso" name="f_egreso">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha de Antiguedad reconocida" nvalue="#INCORPORAR:@f_antiguedad" name="f_antiguedad">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox visible="0" required="1" enabled="0" ysize="1" xsize="50" length="100" label="Posicion en el escenario" nvalue="#INCORPORAR:@e_posicion" name="e_posicion"/>
				<form:TextBox required="0" enabled="NEW|EDIT" descr="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#INCORPORAR:@o_legajo" name="o_legajo"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button img="next" descrip="Va a la pantalla Siguiente" name="Siguiente" label="Siguiente">
					<form:Event action="Siguiente" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Vuelve a la pantalla anterior" img="back" label="Volver" name="Back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
