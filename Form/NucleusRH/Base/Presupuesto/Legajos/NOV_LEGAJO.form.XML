<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Presupuesto.Legajos.NOV_LEGAJO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Presupuesto.Legajos.NOV_LEGAJO">
	<form:Help>
		<form:Help-title text="Novedades del legajo" name="TITLE"/>
		<form:Help-descr text="Aqui se registran todos las novedades de un legajo en un detalle del presupuesto." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Center width="95%">
		<form:ComboBox label="Presupuesto" name="oi_presupuesto" queryname1="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.INFO" xsize="30" mode="QRY" required="1" enabled="0" nvalue="#FILTERDATA:@id"/>
		<form:ComboBox prev="oi_presupuesto" queryname1="NucleusRH.Base.Presupuesto.Escenarios.ESCENARIO.INFO" xsize="30" mode="QRY" required="1" enabled="0" label="Escenario" nvalue="#FILTERDATA:@id_esce" name="oi_escenario"/>
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_novedad">
					<form:ComboBox queryname1="NucleusRH.Base.Presupuesto.Novedades.NOVEDAD.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Novedad" nvalue="#source:oi_novedad/@value" name="oi_novedad"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_detalle_pres">
					<form:ComboBox prev="oi_escenario" queryname1="NucleusRH.Base.Presupuesto.Escenarios.DETALLE_PRES.INFO" xsize="20" mode="QRY" required="0" enabled="NEW|EDIT" label="Detalle Presupuesto" nvalue="#source:oi_detalle_pres/@value" name="oi_detalle_pres"/>
				</form:GColumn>
				<form:GColumn name="gcoln_valor">
					<form:NumberBox required="1" enabled="NEW|EDIT" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" nvalue="#source:@n_valor" name="n_valor"/>
				</form:GColumn>
				<form:GColumn name="gcolo_det_concepto">
					<form:TextBox required="0" enabled="NEW|EDIT" descr="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" ysize="1" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_det_concepto" name="o_det_concepto"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
</form:Form>
