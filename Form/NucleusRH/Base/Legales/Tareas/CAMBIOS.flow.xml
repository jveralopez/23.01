<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="open_externo_estado" name="NucleusRH.Base.Legales.Tareas.CAMBIOS">
	<flow:info label="NucleusRH.Base.Legales.Tareas."/>
	<flow:declare>
		<doc:define name="DDO_HIST_ESTADO"/>
		<doc:define name="DOC_RESULT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="open_externo_estado">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_tarea" to-attr-path="#DDO_HIST_ESTADO:@oi_tarea"/>
			<flow:log text="LuchoTarea" text-path="#DDO_HIST_ESTADO:"/>
			<flow:log text="LuchoTareaaaa" text-path="#SOURCE:"/>
			<flow:call-action else="open_estado_tarea" action="open_estado_tarea_especial" eq="13" if="#SOURCE:@tipo_tarea"/>
		</flow:action>
		<flow:action name="open_estado_tarea">
			<flow:open-form doc-path="#DDO_HIST_ESTADO:" form-class="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form" mode="NEW"/>
		</flow:action>
		<flow:action name="open_estado_tarea_especial">
			<flow:open-form mode="ESTADO-ESPECIAL" doc-path="#DDO_HIST_ESTADO:" form-class="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form"/>
		</flow:action>
	</flow:main>
	<flow:group name="ESTADOS">
		<flow:form mode="NEW" name="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form:NEW" form-class="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form" doc="SOURCE">
			<flow:action name="ACEPTAR">
				<flow:log text-path="#SOURCE:" text="LUCIANO_ESTADOT"/>
				<flow:exec-method class="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA" method="SAVE_ESTADO_TAREA">
					<flow:param doc="SOURCE" name="HIST_DATOS_TAREA" mode="in" type="Nomad.NSystem.Proxy.NomadXML"/>
				</flow:exec-method>
				<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
				<flow:log text-path="#DOC_RESULT:" text="LuchoSalida"/>
				<flow:exit-flow return-path="#DOC_RESULT:"/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:exit-flow return-path="#DOC_RESULT:"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form:ESTADO-ESPECIAL" mode="ESTADO-ESPECIAL" form-class="NucleusRH.Base.Legales.Tareas.ESTADOTAREA.form" doc="SOURCE">
			<flow:action name="ACEPTAR">
				<flow:log text-path="#DATOS_TAREA:" text="LUCIANO_ESTADOT"/>
				<flow:exec-method class="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA" method="SAVE_ESTADO_TAREA">
					<flow:param doc="SOURCE" name="HIST_DATOS_TAREA" mode="in" type="Nomad.NSystem.Proxy.NomadXML"/>
				</flow:exec-method>
				<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
				<flow:exit-flow return-path="#DOC_RESULT:"/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:exit-flow return-path="#DOC_RESULT:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
