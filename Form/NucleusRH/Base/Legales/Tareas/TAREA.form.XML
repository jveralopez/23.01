	</form:Scripts>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
	<form:Resources>
		<form:Resource name="get_default">
			<qry:main doc="SOURCE" name="">
				<qry:element name="PARAM">
					<qry:insert-select name="getDefault" doc-path=""/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="getDefault">
				<qry:xquery>
					for $r in SQL
			(' 
			   SELECT P.d_valor
	       FROM ORG26_PARAMETROS AS P
	       WHERE P.c_modulo = \'LEG\'
	       AND P.c_parametro= \'DefaultEstadoTarea\' 
	       AND P.d_clase = \'NucleusRH.Base.Legales\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="def" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource name="getOiPedidoLF">
			<qry:main doc="SOURCE">
				<qry:element name="DATA">
					<qry:insert-select name="qryOiPedidoLF" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qryOiPedidoLF" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				LEG61_PEDIDOS_LF.oi_pedido_lf
			
			FROM
				LEG61_PEDIDOS_LF
			
			WHERE
				LEG61_PEDIDOS_LF.oi_tarea = {#PARAM:@oi_tarea}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_pedido_lf" value="$r/@oi_pedido_lf"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_tarea=&quot;2922&quot;/&gt;" name="get_Carpeta">
			<qry:main doc="SOURCE">
				<qry:element name="CARPETA">
					<qry:insert-select name="qry_oicarpeta" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_oicarpeta">
				<qry:xquery>
					for $r in SQL('
				
				SELECT
				C.oi_carpeta
				
				FROM
				LEG01_CARPETAS as C,
				LEG03_TAREAS as T
				
				JOIN
				T.oi_carpeta INNER C.oi_carpeta
				
				WHERE
				T.oi_tarea = {#PARAM:@oi_tarea}
				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_carpeta" value="$r/@oi_carpeta"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_tarea=&quot;2935&quot;/&gt;" name="getCodTipoTarea">
			<qry:main doc="SOURCE">
				<qry:element name="TIPO">
					<qry:insert-select name="qryCodTipoTarea" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qryCodTipoTarea" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				LEG35_TIPOS_TAREAS.c_tipo_tarea
			
			FROM
				LEG03_TAREAS,
				LEG35_TIPOS_TAREAS
			
			JOIN
				LEG03_TAREAS.oi_tipo_tarea INNER LEG35_TIPOS_TAREAS.oi_tipo_tarea
			
			WHERE
				LEG03_TAREAS.oi_tarea = {#PARAM:@oi_tarea}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_tipo_tarea" value="$r/@c_tipo_tarea"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
