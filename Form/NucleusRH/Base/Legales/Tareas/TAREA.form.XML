var objTemporal = new Object();

objTemporal.processResult = function (pResult) 
{
	var xmlResult = new NomadXML(pResult);
	if (xmlResult) 
	{ 
	 	if (xmlResult.GetAttr("accept") == "1")
	 	{	 	
			if(Ctrl('main').GetMode() == "LIST")
			{
        Ctrl('main').DoEvent('REFRESH-LIST');
			}
			
			if(Ctrl('main').GetMode() == "SHOW")
			{ 
				Ctrl('main').DoEvent('REFRESH-LIST');
			}
		}
	}
}

function onLoad() 
{		       
	if(Ctrl('main').GetMode()=="NEW-ADMIN" || Ctrl('main').GetMode()=="NEW-USER")	 
	{	
		Ctrl("nro_tarea").SetXValue("En construcci&#243;n");	
		Ctrl('f_alta').SetXValue(datetime2str(Now())); 	
	
		if(Ctrl('primer_new').GetXValue()=="1")
		{
		//Seteo el valor por defecto
		var nSQL = GetProxy().SQLService();	 		 
		var objDefault = nSQL.GetOBJ(Ctrl("main").getResource("get_default"),'');
		Ctrl('oi_estado_tarea').SetXValue(objDefault.def);	                     
		}	
	}
	
	if(Ctrl('main').GetMode()=="LIST" || Ctrl('main').GetMode()=="SHOW")	 
	{
		getCodTipoTarea();
		deshabilitarBotones();
	}
	
	if(Ctrl('main').GetMode()=="EDIT")
	{
		getCodTipoTarea();
		if(c_tipo_tarea=="13")
		{
			deshabilitarControles();
		}
	}
		
	if(Ctrl('main').GetMode()=="LIST-PLF")
	{		
  	if (GetRow(Ctrl('LIST').GetXValue(),"c_estado_tarea")=="1") CtrlEnabled("CUMPLIDA", true);
		else CtrlEnabled("CUMPLIDA", false);
  
		//Ctrl("listarr").DelAllRow();
		//Ctrl("LIST").Refresh();
	}
	/*if(Ctrl('main').GetMode()=="SHOW")
	{ 
		getCodTipoTarea();
		deshabilitarBotones();
	} */
}

function getCodTipoTarea()
{
	if(Ctrl('main').GetMode()=="SHOW" || Ctrl('main').GetMode()=="EDIT")
		var id = Ctrl('id').GetXValue();
	if(Ctrl('main').GetMode()=="LIST")
		var id = Ctrl('LIST').GetXValue();
	
	var nSQL = GetProxy().SQLService();
	var param = "&lt;DATA oi_tarea=\""+id+"\" /&gt;"; 
	var objRec = nSQL.GetOBJ(Ctrl("main").getResource("getCodTipoTarea"),param);
	c_tipo_tarea = objRec.c_tipo_tarea;
}

function deshabilitarBotones()
{
	CtrlEnabled("EDIT"  ,true);
	CtrlEnabled("DELETE",true);
	CtrlEnabled("CAMBIO",true);
	  
  if(c_tipo_tarea=="12")
  {
  	CtrlEnabled("EDIT"  ,false);
  	CtrlEnabled("DELETE",false);
  	CtrlEnabled("CAMBIO",false);  	
  }
  if(c_tipo_tarea=="13")
	{	  	
		CtrlEnabled("DELETE",false);
	}	 
}

function deshabilitarControles()
{
	CtrlEnabled("d_tarea",false);
	CtrlEnabled("f_tarea",false);
	CtrlEnabled("oi_tipo_tarea",false);
	CtrlEnabled("oi_clasif_sujeto",false);
	CtrlEnabled("d_lugar_tarea",false);
	CtrlEnabled("f_vto_tarea",false);
	CtrlEnabled("o_tarea",false);
}

function CustomListClick()
{	
  ListClick();
  if (Ctrl('main').GetMode()=="LIST-PLF")
  {
  	if (GetRow(Ctrl('LIST').GetXValue(),"c_estado_tarea")=="1") CtrlEnabled("CUMPLIDA", true);
		else CtrlEnabled("CUMPLIDA", false);
  }
  else
  {
  	getCodTipoTarea();
  	deshabilitarBotones();
  }
}

function confirmacion() 
{
	if(confirm("Para continuar se deben guardar los datos de la TAREA. &#191;Desea continuar?"))
		Ctrl('main').DoEvent("SAVE:DOCUMENTO");
	else
		return false;
} 

function ValidaFechas()
{     
	if(Ctrl('main').GetMode()=="NEW-ADMIN" || Ctrl('main').GetMode()=="NEW-USER" || Ctrl('main').GetMode()=="EDIT") 
	{
	  if(Ctrl('f_tarea').GetReadXValue() &gt; Ctrl('f_vto_tarea').GetReadXValue() )
	  {
	   alert('La fecha de vencimiento de la tarea debe ser superior a la fecha de la misma.')
	   return false;
	  }
	  else {return true;} 
	} 
  
  else {return true;}  
}

function estado_tarea_validate(p)
{ 
	var estado = p.GetCValue().substring(0,1);
	
	if(Ctrl('main').GetMode()=="EDIT" &amp;&amp; c_tipo_tarea=="13" &amp;&amp; estado!="1" &amp;&amp; estado!="3" &amp;&amp; estado!="4")
	{			
		p.SetError("Este tipo de tarea solo puede cambiar al estado Cumplida o Cancelada");
		return false;
	}
	return true;
}

function save_onclick()
{
   if(Ctrl('oi_estado_tarea').GetXValue()=="3")
   {
     Ctrl('main').DoEvent('CIERRE');
     return false;
   }
   return true;
}

function getOiPedidoLF()
{
	var id = Ctrl('LIST').GetXValue();
	
	var nSQL = GetProxy().SQLService();
	var param = "&lt;DATA oi_tarea=\""+id+"\" /&gt;"; 
	var objRec = nSQL.GetOBJ(Ctrl("main").getResource("getOiPedidoLF"),param);
  
  Ctrl('oi_pedido_lf').SetXValue(objRec.oi_pedido_lf);
  
  return true;
}

function cumplida_onclick()
{	 
	Ctrl('main').DoEvent('GET-RECIBOS');
	var xmlRecibos = Ctrl('main').GetLastDocXML('RECIBOS');
	if(xmlRecibos.GetChilds().length==0)
		alert('No puede pasar la Tarea a cumplida ya que no se encontraron recibos para el Actor de la Carpeta');
	else
		Ctrl('main').DoEvent('OPEN-CUMPLIDA');
}

function GetRow(id, AttrName) { 

	for (var j=0; j&lt;Ctrl("LIST").TotalRowsCount(); j++) {    
		if (id == Ctrl("LIST").GetAttrValue(j, 'id')) {
			var row = Ctrl("LIST").GetAttrValue(j, AttrName);
			return row;                                     
		}     
	}
}   
