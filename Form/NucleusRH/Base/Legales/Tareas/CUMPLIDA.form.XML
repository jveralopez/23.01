<form:Form xmlns:form="nomad_engine.form" doc="SOURCE" name="NucleusRH.Base.Legales.Tareas.CUMPLIDA.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Pasar tarea a Cumplida" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Hidden name="oi_tarea" nvalue="#SOURCE:@oi_tarea"/>
		<form:Blank name="blk01"/>
		<form:ComboBox xsize="30" label="Recibo" name="n_recibo" required="1" nvalue="#SOURCE:@n_recibo" docname="RECIBOS" mode="DOC">
			<options/>
		</form:ComboBox>
		<form:Blank name="blk02"/>
		<form:TextBox name="cambio_estado_obs" nvalue="#DATOS_TAREA:@cambio_estado_obs" length="1000" ysize="10" xsize="40" required="0" label="Observaciones"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button startvalidate="1" label="Aceptar" img="ok" name="ACEPTAR">
					<form:Event action="ACEPTAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
