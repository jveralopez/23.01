<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER-PLF" name="NucleusRH.Base.Legales.Tareas.TAREA.filter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="nomad.filter.form" doc="source">
	<form:Help>
		<form:Help-title text="Tareas de la Carpeta" name="TITLE"/>
		<form:Help-descr text="Tareas de la carpeta" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label visible="!FILTER-PLF" nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Tareas de la Carpeta" name="GEN_FILTER"/>
				<form:Label name="GEN_FILTER_PLF" label="Filtrar Tareas de Liquidaci&#243;n Final" visible="FILTER-PLF" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="90%">
		<form:Columns name="main_columnsTAREA">
			<form:Column name="main_columnsTAREAcolumn1">
				<form:ComboBox queryname2="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA" xsize="30" mode="QRY" required="0" label="Carpeta" nvalue="#source:@oi_carpeta" name="oi_carpeta"/>
				<form:TextBox visible="!FILTER-PLF" label="ID - Descripci&#243;n" required="0" ysize="1" xsize="50" length="100" nvalue="#source:@d_tarea" name="d_tarea"/>
				<form:Rower label="Fecha Desde" name="rwerfechas" separation="5">
					<form:DateTime nvalue="#source:@f_tarea_d" name="f_tarea_d" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="Fecha Hasta" name="sd"/>
					<form:DateTime nvalue="#source:@f_tarea_h" name="f_tarea_h" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:DateTime visible="0" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha" nvalue="#source:@f_tarea" name="f_tarea">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.INFO" xsize="40" mode="QRY" required="0" label="Estado Tarea" nvalue="#source:@oi_estado_tarea" name="oi_estado_tarea"/>
				<form:ComboBox visible="!FILTER-PLF" queryname1="NucleusRH.Base.Legales.Tipos_Tarea.TIPO_TAREA.INFO" xsize="40" mode="QRY" required="0" label="Tipo Tarea" nvalue="#source:@oi_tipo_tarea" name="oi_tipo_tarea"/>
				<form:ComboBox visible="!FILTER-PLF" queryname1="NucleusRH.Base.Legales.Sujetos.CLASIF_SUJETO.INFO_TAREAS" xsize="30" mode="QRY" required="0" label="Responsable" nvalue="#source:@oi_clasif_sujeto" name="oi_clasif_sujeto"/>
				<form:TextBox visible="!FILTER-PLF" required="0" ysize="1" xsize="50" length="100" label="Lugar" nvalue="#source:@d_lugar_tarea" name="d_lugar_tarea"/>
				<form:Rower separation="10" label="Fecha Vencimiento Tarea Desde" name="rower_fechas">
					<form:DateTime name="f_vto_tarea_desde" nvalue="#source:@f_vto_tarea_desde" label="Fecha Vencimiento Tarea Desde" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="Fecha Vencimiento Tarea Hasta" name="lbl_rower"/>
					<form:DateTime name="f_vto_tarea_hasta" nvalue="#source:@f_vto_tarea_hasta" label="Fecha Vencimiento Tarea Hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button visible="!FILTER-PLF" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{ 
	if(Ctrl('main').GetMode()=="FILTER-PLF")	 
	{		
		if(Ctrl("f_tarea_d").GetXValue()=="")
		{
			var f_desde = new Date();		
			f_desde.setMonth(f_desde.getMonth() - 1);
			Ctrl("f_tarea_d").SetXValue(date2str(f_desde));
		}
		if(Ctrl("oi_estado_tarea").GetXValue()=="")
		{
			Ctrl("oi_estado_tarea").SetXValue("1");
		}
	}
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
