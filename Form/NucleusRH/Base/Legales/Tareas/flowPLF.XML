<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Legales.Tareas.flowPLF" default_action="initialize" extends="NucleusRH.Base.Legales.Tareas.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Legales.Tareas"/>
	<flow:declare>
		<qry:define declare="&lt;FILTER oi_carpeta=&quot;&quot; d_tarea=&quot;&quot; f_tarea_d=&quot;20120202&quot; f_tarea_h=&quot;20130202&quot; oi_estado_tarea=&quot;&quot; oi_tipo_tarea=&quot;&quot; oi_clasif_sujeto=&quot;&quot; &#13;&#10;d_lugar_tarea=&quot;&quot; f_vto_tarea_desde=&quot;&quot; f_vto_tarea_hasta=&quot;&quot; rol=&quot;&quot; /&gt;" name="COUNT">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<ROW>
						<qry:insert-select doc-path="#PARAM:FILTER" name="sql1"/>
					</ROW>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			 
					SELECT 
						COUNT(t0.oi_tarea) AS cant1
						{%?(#PARAM:@rol='USER') {% ,\'./ROLE/LEGALES_USER\' AS POLICY %} {% %} %}						 
					
					FROM 
						LEG03_TAREAS AS t0,
						LEG35_TIPOS_TAREAS AS tt
						{%?(#PARAM:@rol='USER') {% ,LEG01_CARPETAS AS C %} {% %} %}				 
					
					JOIN
						t0.oi_tipo_tarea INNER tt.oi_tipo_tarea
						{%?(#PARAM:@rol='USER') {% ,t0.oi_carpeta INNER C.oi_carpeta %}	{% %} %}			
					
					WHERE
						tt.c_tipo_tarea = 12
						{%?(#PARAM:@oi_carpeta!='') {% AND t0.oi_carpeta = {#PARAM:@oi_carpeta} %} {% %} %}
						{%?(#PARAM:@d_tarea!='') {% AND CONTAIN(t0.d_tarea, \'{%=#PARAM:@d_tarea%}\') %} {% %} %}
						{%?(#PARAM:@f_tarea_d!='') {% AND t0.f_tarea &gt;= {#PARAM:@f_tarea_d} %} {% %} %}
						{%?(#PARAM:@f_tarea_h!='') {% AND t0.f_tarea &lt;  {Datetime(Number(Datetime(#PARAM:@f_tarea_h))+1)} %} {% %} %}
						{%?(#PARAM:@oi_estado_tarea!='') {% AND t0.oi_estado_tarea = {#PARAM:@oi_estado_tarea} %} {% %} %}
						{%?(#PARAM:@oi_tipo_tarea!='') {% AND t0.oi_tipo_tarea = {#PARAM:@oi_tipo_tarea} %} {% %} %}
						{%?(#PARAM:@oi_clasif_sujeto!='') {% AND t0.oi_clasif_sujeto = {#PARAM:@oi_clasif_sujeto} %} {% %} %}
						{%?(#PARAM:@d_lugar_tarea!='') {% AND CONTAIN(t0.d_lugar_tarea, \'{%=#PARAM:@d_lugar_tarea%}\') %} {% %} %}
						{%?(#PARAM:@f_vto_tarea_desde!='') {% AND t0.f_vto_tarea &gt;= {#PARAM:@f_vto_tarea_desde} %} {% %} %}
						{%?(#PARAM:@f_vto_tarea_hasta!='') {% AND t0.f_vto_tarea &lt;= {Datetime(Number(Datetime(#PARAM:@f_vto_tarea_hasta))+1)} %} {% %} %}
						{%?(#PARAM:@rol='USER')
							{% AND C.oi_ubicacion IN
								(
									SELECT LEG58_SEGURIDAD.oi_ubicacion	
					 				FROM LEG58_SEGURIDAD
					  			WHERE LEG58_SEGURIDAD.oi_usuario_sys = \'{%=$proxy/@ETTY%}\'
				  			)
				  		%} {% %}
				  	%}
			  		
			  ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cant" value="$r/@cant1"/>
					<qry:attribute name="exito" value="iif(@cant&gt;=300,'0','1')"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTER oi_carpeta=&quot;&quot; d_tarea=&quot;&quot; f_tarea_d=&quot;&quot; f_tarea_h=&quot;&quot; oi_estado_tarea=&quot;&quot; oi_tipo_tarea=&quot;&quot; oi_clasif_sujeto=&quot;&quot; &#13;&#10;d_lugar_tarea=&quot;&quot; f_vto_tarea_desde=&quot;&quot; f_vto_tarea_hasta=&quot;&quot; rol=&quot;USER&quot; /&gt;" name="FILTER">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:FILTER" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			
					MAXSIZE 300 
					
					SELECT 
						t0.oi_tarea AS oi_tarea
						{%?(#PARAM:@rol='USER') {% ,\'./ROLE/LEGALES_USER\' AS POLICY %} {% %} %}
									 
					FROM 
						LEG03_TAREAS AS t0,
						LEG35_TIPOS_TAREAS AS tt
						{%?(#PARAM:@rol='USER') {% ,LEG01_CARPETAS as C %} {% %} %}	
				  
				  JOIN
				  	t0.oi_tipo_tarea INNER tt.oi_tipo_tarea
						{%?(#PARAM:@rol='USER') {% ,t0.oi_carpeta INNER C.oi_carpeta %} {% %} %}	 			
			
					WHERE
						tt.c_tipo_tarea = 12
						{%?(#PARAM:@oi_carpeta!='') {% AND t0.oi_carpeta = {#PARAM:@oi_carpeta} %} {% %} %}
						{%?(#PARAM:@d_tarea!='') {% AND CONTAIN(t0.d_tarea, \'{%=#PARAM:@d_tarea%}\') %} {% %} %}
						{%?(#PARAM:@f_tarea_d!='') {% AND t0.f_tarea &gt;= {#PARAM:@f_tarea_d} %} {% %} %}
						{%?(#PARAM:@f_tarea_h!='') {% AND t0.f_tarea &lt;  {Datetime(Number(Datetime(#PARAM:@f_tarea_h))+1)} %} {% %} %}
						{%?(#PARAM:@oi_estado_tarea!='') {% AND t0.oi_estado_tarea = {#PARAM:@oi_estado_tarea} %} {% %} %}
						{%?(#PARAM:@oi_tipo_tarea!='') {% AND t0.oi_tipo_tarea = {#PARAM:@oi_tipo_tarea} %} {% %} %}
						{%?(#PARAM:@oi_clasif_sujeto!='') {% AND t0.oi_clasif_sujeto = {#PARAM:@oi_clasif_sujeto} %} {% %} %}
						{%?(#PARAM:@d_lugar_tarea!='') {% AND CONTAIN(t0.d_lugar_tarea, \'{%=#PARAM:@d_lugar_tarea%}\') %} {% %} %}
						{%?(#PARAM:@f_vto_tarea_desde!='') {% AND t0.f_vto_tarea &gt;= {#PARAM:@f_vto_tarea_desde} %} {% %} %}
						{%?(#PARAM:@f_vto_tarea_hasta!='') {% AND t0.f_vto_tarea &lt;= {Datetime(Number(Datetime(#PARAM:@f_vto_tarea_hasta))+1)} %} {% %} %}
						{%?(#PARAM:@rol='USER')
				 			{% AND C.oi_ubicacion IN
				 				(
				 					SELECT LEG58_SEGURIDAD.oi_ubicacion
			 						FROM LEG58_SEGURIDAD
			  					WHERE LEG58_SEGURIDAD.oi_usuario_sys = \'{%=$proxy/@ETTY%}\'
			  				)
				  		%} {% %}
						%}			
			
					ORDER BY
						oi_tarea ASC

				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_tarea"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&lt;ROW id=&quot;105&quot; /&gt;&lt;ROW id=&quot;504&quot; /&gt;&lt;ROW id=&quot;903&quot; /&gt;&lt;/ROWS&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA"/>
			<qry:include name="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.INFO"/>
			<qry:include name="NucleusRH.Base.Legales.Tipos_Tarea.TIPO_TAREA.INFO"/>
			<qry:include name="NucleusRH.Base.Legales.Sujetos.CLASIF_SUJETO.INFO"/>
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:ROWS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			
					SELECT 
						t0.oi_tarea AS oi_tarea, 
						t0.d_tarea AS d_tarea, 
						t0.f_tarea AS f_tarea, 
						t0.d_lugar_tarea AS d_lugar_tarea, 
						t0.f_vto_tarea AS f_vto_tarea, 			 
						t0.oi_tarea AS CODE, 
						t0.d_tarea AS TEXT, 
						t0.oi_carpeta AS oi_carpeta, 
						t0.oi_estado_tarea AS oi_estado_tarea, 
						t0.oi_tipo_tarea AS oi_tipo_tarea, 
						t0.oi_clasif_sujeto AS oi_clasif_sujeto,
						t0.f_alta AS f_alta,
						E.c_empresa,
						E.d_empresa,
						C.c_carpeta,
						C.d_carpeta				 
					 
					FROM 
						ORG03_EMPRESAS AS E,
						LEG01_CARPETAS AS C,
						LEG03_TAREAS AS t0,
						LEG35_TIPOS_TAREAS AS tt

					JOIN
						C.oi_empresa INNER E.oi_empresa,
						C.oi_carpeta INNER t0.oi_carpeta,
						t0.oi_tipo_tarea INNER tt.oi_tipo_tarea
					 
					WHERE
						C.oi_estado_carpeta != 11
						AND tt.c_tipo_tarea = 12						
						{%?(string(#PARAM:ROW/@id)!='')
							{% AND t0.oi_tarea IN ({%=string(#PARAM:ROW/@id)%}) %}
							{% AND t0.oi_tarea IN (0) %}
						%}					
					 
					ORDER BY
						oi_tarea ASC

				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_tarea"/>
						<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
						<qry:attribute name="f_tarea" value="$r/@f_tarea"/>
						<qry:attribute name="d_lugar_tarea" value="$r/@d_lugar_tarea"/>
						<qry:attribute name="f_vto_tarea" value="$r/@f_vto_tarea"/>
						<qry:attribute name="f_alta" value="$r/@f_alta"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="empresa" value="'[' + $r/@c_empresa +']' + ' - ' + $r/@d_empresa"/>
						<qry:attribute name="oi_carpeta" value="'[' + $r/@c_carpeta +']' + ' - ' + $r/@d_carpeta"/>
						<!--qry:if test="$r/@oi_carpeta!=''">
<qry:then>
<qry:element name="oi_carpeta">
<qry:attribute name="OI_FIND" value="$r/@oi_carpeta"/>
<qry:insert-select name="NucleusRH.Base.Legales.Carpetas.CARPETA.QUERY" doc-path="."/>
</qry:element>
<qry:attribute name="oi_carpeta" value="'['+oi_carpeta/ROW/@COD+'] '+oi_carpeta/ROW/@DES"/>
</qry:then>
</qry:if-->
						<qry:if test="$r/@oi_estado_tarea!=''">
							<qry:then>
								<qry:element name="oi_estado_tarea">
									<qry:attribute name="OI_FIND" value="$r/@oi_estado_tarea"/>
									<qry:insert-select name="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_estado_tarea" value="'['+oi_estado_tarea/ROW/@COD+'] '+oi_estado_tarea/ROW/@DES"/>
								<qry:attribute name="c_estado_tarea" value="oi_estado_tarea/ROW/@COD"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_tipo_tarea!=''">
							<qry:then>
								<qry:element name="oi_tipo_tarea">
									<qry:attribute name="OI_FIND" value="$r/@oi_tipo_tarea"/>
									<qry:insert-select name="NucleusRH.Base.Legales.Tipos_Tarea.TIPO_TAREA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_tarea" value="'['+oi_tipo_tarea/ROW/@COD+'] '+oi_tipo_tarea/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_clasif_sujeto!=''">
							<qry:then>
								<qry:insert-select doc-path="$r" name="sql2"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in sql('
			
				SELECT 
				  CLA.d_clasif_suj,
				  SUJ.d_sujeto
				  
				FROM 
					LEG40_CLASIF_SUJ AS CSU,
					LEG40_SUJETOS AS SUJ,
					LEG41_CLASIF AS CLA
					
				JOIN
					CSU.oi_sujeto INNER SUJ.oi_sujeto,
					CSU.oi_clasif_suj INNER CLA.oi_clasif_suj
					
				WHERE
				 CSU.oi_clasif_sujeto = {#PARAM:@oi_clasif_sujeto}

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_clasif_sujeto" value="'['+$r/@d_clasif_suj+'] ' + $r/@d_sujeto"/>
				</qry:out>
			</qry:select>
		</qry:define>
