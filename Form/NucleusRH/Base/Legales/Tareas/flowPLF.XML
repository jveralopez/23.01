		<doc:define class="NucleusRH.Base.Legales.Documentos.DOCUMENTO" name="DDO_DOC"/>
		<qry:define declare="&lt;TAREA descr=&quot;[103] reunion de concil.&quot; f_vto_tarea=&quot;20120531120000&quot; d_lugar_tarea=&quot;qweqweqweqweqweqweqweqe&quot; f_tarea=&quot;20120530105153&quot; d_tarea=&quot;reunion de concil.&quot; id=&quot;108&quot; o_tarea=&quot;&quot;&gt;&#13;&#10;&#9;&lt;oi_carpeta value=&quot;112&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_estado_tarea value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_tipo_tarea value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_clasif_sujeto value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&lt;/TAREA&gt;" name="FILTER_DOCS">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:TAREA" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
			ld.oi_documento,
			ld.f_doc_dig
			FROM 
			LEG03_TAREAS as t0,
			LEG05_DOCUMENTOS as ld
			JOIN 
			t0.oi_tarea INNER ld.oi_tarea
			WHERE
			t0.oi_tarea = {#PARAM:@id}
			ORDER BY 
			f_doc_dig desc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_documento"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define class="NucleusRH.Base.Legales.Documentos.DOCUMENTO" name="NEWDDOROOTDOC"/>
		<qry:define declare="&lt;TAREA descr=&quot;[108] test test test&quot; o_tarea=&quot;fdsafasfas&quot; f_vto_tarea=&quot;20120613152800&quot; d_lugar_tarea=&quot;asdasdasdasd&quot; f_tarea=&quot;20120613&quot; d_tarea=&quot;test test test&quot; id=&quot;108&quot;&gt;&#13;&#10;&#9;&lt;oi_carpeta value=&quot;112&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_estado_tarea value=&quot;4&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_tipo_tarea value=&quot;3&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_clasif_sujeto value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&lt;/TAREA&gt;" name="LISTDOC">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:TAREA" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
			ld.oi_documento,
			ld.d_doc_dig,
			ld.f_doc_dig,
			ld.o_doc_dig,
			ld.oi_doc_digital,
			ld.oi_carpeta,
			ld.oi_tarea,
			lt.d_tarea,
			lc.d_carpeta,
			ldd.o_doc_digital
			FROM 
			LEG03_TAREAS as lt,
			LEG05_DOCUMENTOS as ld,
			LEG01_CARPETAS as lc,
			LEG37_DOC_DIGITAL as ldd
			JOIN 
			lt.oi_tarea INNER ld.oi_tarea,
			ld.oi_doc_digital INNER ldd.oi_doc_digital,
			lt.oi_carpeta INNER lc.oi_carpeta
			WHERE
			lt.oi_tarea = {#PARAM:@id}
			ORDER BY 
			f_doc_dig desc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_documento"/>
						<qry:attribute name="d_doc_dig" value="$r/@d_doc_dig"/>
						<qry:attribute name="f_doc_dig" value="$r/@f_doc_dig"/>
						<qry:attribute name="o_doc_dig" value="$r/@o_doc_dig"/>
						<qry:attribute name="oi_doc_digital" value="$r/@o_doc_digital"/>
						<qry:attribute name="oi_carpeta" value="$r/@d_carpeta"/>
						<qry:attribute name="oi_tarea" value="$r/@d_tarea"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="QRY_LIST_DOC"/>
		<qry:define declare="&lt;TAREA descr=&quot;[103] reunion de concil.&quot; f_vto_tarea=&quot;20120531120000&quot; d_lugar_tarea=&quot;qweqweqweqweqweqweqweqe&quot; f_tarea=&quot;20120530105153&quot; d_tarea=&quot;reunion de concil.&quot; id=&quot;108&quot; o_tarea=&quot;&quot;&gt;&#13;&#10;&#9;&lt;oi_carpeta value=&quot;112&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_estado_tarea value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_tipo_tarea value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&#9;&lt;oi_clasif_sujeto value=&quot;1&quot; nmd-agr=&quot;1&quot; /&gt;&#13;&#10;&lt;/TAREA&gt;" name="CANT_DOCS">
			<qry:main doc="PARAM" maxdeep="2">
