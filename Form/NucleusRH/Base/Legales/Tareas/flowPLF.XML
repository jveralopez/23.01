		<qry:define name="GetDatosTareaEstado3" declare="&lt;PARAM oi_tarea=&quot;2229&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS_TAREA">
					<qry:insert-select name="qry_tipo_tarea" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_tipo_tarea">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				LEG03_TAREAS.oi_estado_tarea,
				LEG03_TAREAS.oi_tarea,
				LEG35_TIPOS_TAREAS.c_tipo_tarea				
			  
			FROM
				LEG35_TIPOS_TAREAS,
				LEG03_TAREAS
			
			JOIN
				LEG03_TAREAS.oi_tipo_tarea INNER LEG35_TIPOS_TAREAS.oi_tipo_tarea 
			
			WHERE
			  LEG03_TAREAS.oi_tarea = {#PARAM:@oi_tarea}
			
			')/ROWS/ROW
