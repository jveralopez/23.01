				<doc:save-object doc="DDO_DOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="--------------------------------------------"/>
			<flow:action name="on-show"/>
			<flow:action name="After-Change">
				<doc:iter-refresh/>
				<doc:iter-last/>
			</flow:action>
			<flow:action name="After-Back"/>
			<flow:action name="SAVE">
				<flow:call-action action="save-DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
			<flow:action name="DELETE">
				<flow:call-action action="delete-DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:close-form next-action="After-Cancel"/>
			</flow:action>
			<flow:action name="PARENT"/>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form:NEW" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form" mode="NEW">
			<flow:action name="save-DDO">
				<doc:save-object doc="NEWDDOROOTDOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
				<doc:load-object id-path="#NEWDDOROOTDOC:@id" doc="DDO_DOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="--------------------------------------------"/>
			<flow:action name="on-show">
				<flow:log text-path="#DDO:" text="logNEW1"/>
				<doc:set-attribute from-attr-path="#DDO:oi_carpeta/@value" to-attr-path="#SOURCE:oi_carpeta/@value"/>
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#SOURCE:oi_tarea/@value"/>
			</flow:action>
			<flow:action name="After-Back"/>
			<flow:action name="After-Change"/>
			<flow:action name="SAVE">
				<flow:call-action action="save-DDO"/>
				<flow:close-form next-action="BACK"/>
				<flow:log text-path="#DDO:" text="logDOC"/>
				<doc:load-qry output-doc="QRY_DOCS" input-doc-path="#DDO:" qry="FILTER_DOCS"/>
				<flow:open-form iter-index="#QRY_DOCS:ROW/@id" parent-doc-path="#QRY_DOCS:" doc-path="#DDO_DOC:" mode="EDIT" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.noreg.autoform"/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:close-form next-action="After-Back"/>
			</flow:action>
			<flow:action name="PARENT"/>
		</flow:form>
	</flow:group>
</flow:flow>
