				<flow:close-form next-action="goto-list"/>
			</flow:action>
			<flow:action name="ADMIN">
				<flow:call-action action="open-flow-PROPERTIES"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form:LIST" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form" mode="LIST">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOTDOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object doc="DDO_DOC" id-path="#FORM:ctrl[@id='LIST']/@xval" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="save-DDO">
				<doc:save-object doc="DDO_DOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#DDO_DOC:" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO" doc="DDO"/>
				<doc:save-object doc="DDO_DOC" class="NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO_DOC:" mode="EDIT" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOTDOC:" mode="NEW" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form"/>
			</flow:action>
			<flow:action name="open-flow-PROPERTIES">
				<flow:open-form parent-doc-path="#DDO:" doc-path="#DDO:" mode="SHOW" form-class="Nomad.Base.properties.form"/>
			</flow:action>
			<flow:action name="--------------------------------------------"/>
			<flow:action name="on-open">
				<doc:set-attribute from-attr-path="#DDO_DOC:@id" to-attr-path="#FORM:ctrl[@id='LIST']/@xval"/>
			</flow:action>
			<flow:action name="on-show">
				<flow:log text="logSHOW" text-path="#QRY_LIST_DOC:"/>
				<flow:attach-doc doc-path="#QRY_LIST_DOC:" attach-id="RS"/>
			</flow:action>
			<flow:action name="on-empty-iterator">
				<flow:close-form next-action="empty"/>
			</flow:action>
			<flow:action name="After-Change">
				<doc:load-qry output-doc="QRY_LIST_DOC" qry="LISTDOC" input-doc-path="#DDO:"/>
				<doc:set-attribute from-attr-path="#DDO_DOC:@id" to-attr-path="#FORM:ctrl[@id='LIST']/@xval"/>
			</flow:action>
			<flow:action name="After-Back">
				<doc:load-qry output-doc="QRY_LIST_DOC" qry="LISTDOC" input-doc-path="#DDO:"/>
			</flow:action>
			<flow:action name="After-Cancel">
				<flow:call-action action="After-Change"/>
			</flow:action>
			<flow:action name="ADD">
				<flow:call-action action="new-DDO"/>
				<flow:call-action action="open-flow-ADD"/>
			</flow:action>
			<flow:action name="EDIT">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="open-flow-EDIT"/>
			</flow:action>
			<flow:action name="DELETE">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="delete-DDO"/>
				<doc:load-qry output-doc="QRY_LIST_DOC" qry="LISTDOC" input-doc-path="#DDO:"/>
				<flow:attach-doc doc-path="#QRY_LIST_DOC:" attach-id="RS"/>
				<doc:load-qry output-doc="QRY_DOCS" qry="FILTER_DOCS" input-doc-path="#DDO:"/>
				<doc:iter-refresh/>
			</flow:action>
			<flow:action name="BACK">
				<flow:close-form next-action="After-Back"/>
			</flow:action>
			<flow:action name="PARENT">
				<doc:load-qry output-doc="QRY_LIST_DOC" qry="LISTDOC" input-doc-path="#DDO:"/>
			</flow:action>
			<flow:action name="SHOW">
				<flow:call-action action="load-DDO"/>
				<flow:close-form next-action="goto-show"/>
			</flow:action>
			<flow:action name="ADMIN">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="open-flow-PROPERTIES"/>
			</flow:action>
		</flow:form>
		<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form:EDIT" form-class="NucleusRH.Base.Legales.Documentos.DOCUMENTO.form" mode="EDIT">
			<flow:action name="save-DDO">
