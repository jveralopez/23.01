<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="open_externo_estado" name="NucleusRH.Base.Legales.Carpetas.CAMBIOS">
	<flow:info label="NucleusRH.Base.Legales.Carpetas.CAMBIOS"/>
	<flow:declare>
		<doc:define name="DDO_HIST_ESTADO"/>
		<doc:define name="DDO_HIST_TIPO_CAR"/>
		<doc:define name="DOC_RESULT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="open_externo_estado">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_carpeta" to-attr-path="#DDO_HIST_ESTADO:@oi_carpeta"/>
			<flow:open-form doc-path="#DDO_HIST_ESTADO:" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form" mode="NEW"/>
		</flow:action>
		<flow:action name="open_externo_tipo">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_carpeta" to-attr-path="#DDO_HIST_TIPO_CAR:@oi_carpeta"/>
			<!--doc:set-attribute from-attr-path="#SOURCE:@oi_carpeta" to-attr-path="#DDO_HIST_TIPO_CAR:@oi_carpeta"/-->
			<flow:open-form doc-path="#DDO_HIST_TIPO_CAR:" form-class="NucleusRH.Base.Legales.Carpetas.TIPO_CARPETA.form" mode="NEW"/>
		</flow:action>
		<flow:action name="open_externo_baja">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_carpeta" to-attr-path="#DDO_HIST_ESTADO:@oi_carpeta"/>
			<flow:open-form mode="BAJA" doc-path="#DDO_HIST_ESTADO:" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form"/>
		</flow:action>
		<flow:action name="open_externo_reapertura">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_carpeta" to-attr-path="#DDO_HIST_ESTADO:@oi_carpeta"/>
			<flow:open-form mode="REAPERTURA" doc-path="#DDO_HIST_ESTADO:" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="NEW" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form" name="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form:NEW" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Legales.Estados.ESTADO" method="SAVE_ESTADO_CARPETA">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="SOURCE" mode="in" name="DDO_HIST_ESTADO"/>
				<flow:param attr-path="#SOURCE:@oi_carpeta" type="Nomad.NSystem.String" mode="in" name="strOiCarpeta"/>
			</flow:exec-method>
			<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="NEW" form-class="NucleusRH.Base.Legales.Carpetas.TIPO_CARPETA.form" name="NucleusRH.Base.Legales.Carpetas.TIPO_CARPETA.form:NEW" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Legales.TiposCarpeta.TIPO_CARPETA" method="SAVE_TIPO_CARPETA">
				<flow:param name="DDO_HIST_TIPO_CAR" doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
				<flow:param attr-path="#SOURCE:@oi_carpeta" type="Nomad.NSystem.String" mode="in" name="strOiCarpeta"/>
			</flow:exec-method>
			<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BAJA" name="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form:BAJA" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Legales.Carpetas.CARPETA" method="BAJA_CARPETA">
				<flow:param attr-path="#SOURCE:@oi_carpeta" type="Nomad.NSystem.String" mode="in" name="pstrOiCarpeta"/>
				<flow:param attr-path="#SOURCE:@o_hisest_carpeta" type="Nomad.NSystem.String" mode="in" name="pstrMotivo"/>
				<flow:param attr-path="#SOURCE:@oi_causal" type="Nomad.NSystem.String" mode="in" name="pstrOiCausal"/>
			</flow:exec-method>
			<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form:REAPERTURA" mode="REAPERTURA" form-class="NucleusRH.Base.Legales.Carpetas.ESTADO_CARPETA.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method method="REAPERTURA_CARPETA" class="NucleusRH.Base.Legales.Carpetas.CARPETA">
				<flow:param attr-path="#SOURCE:@oi_carpeta" type="Nomad.NSystem.String" mode="in" name="pstrOiCarpeta"/>
				<flow:param attr-path="#SOURCE:@o_hisest_carpeta" type="Nomad.NSystem.String" mode="in" name="pstrMotivo"/>
			</flow:exec-method>
			<doc:set-attribute from-value="1" to-attr-path="#DOC_RESULT:@accept"/>
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#DOC_RESULT:"/>
		</flow:action>
	</flow:form>
</flow:flow>
