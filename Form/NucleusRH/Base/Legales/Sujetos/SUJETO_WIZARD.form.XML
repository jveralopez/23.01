<form:Form xmlns:form="nomad_engine.form" default_mode="EDIT" name="NucleusRH.Base.Legales.Sujetos.SUJETO_WIZARD" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Help>
		<form:Help-title text="Sujetos" name="TITLE"/>
		<form:Help-descr name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Sujetos" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Sujetos" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Sujetos" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Sujetos" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Right visible="0" width="200px">
		<form:VGroup background="1" label="Dependencias" collapse="1" width="100%" name="vgChildsSUJETO">
			<form:Link allowimg="1" policy="NucleusRH/Base/Legales/Sujetos/CLASIF_SUJETO/READ" label="Clasificaciones del Sujeto" name="CLASIF_SUJ">
				<form:Event policy="NucleusRH/Base/Legales/Sujetos/CLASIF_SUJETO/EDIT" action="CALL:CLASIF_SUJETO" name="onclick" runat="server"/>
			</form:Link>
		</form:VGroup>
	</form:Right>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsSUJETO">
			<form:Column name="main_columnsSUJETOcolumn1">
				<form:TextBox nvalue="#NEWDDOSUJETO:@c_sujeto" required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" name="c_sujeto"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#NEWDDOSUJETO:@d_sujeto" name="d_sujeto"/>
				<form:ComboBox visible="0" queryname1="NucleusRH.Base.Personal.Legajo.PERSONAL.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Persona" nvalue="#NEWDDOSUJETO:oi_personal/@value" name="oi_personal">
					<form:SButtons>
						<form:SButton name="add_persona" img="add">
							<form:Event action="ADD_PERSONA" name="onclick" runat="server"/>
						</form:SButton>
					</form:SButtons>
				</form:ComboBox>
				<form:ComboBox visible="0" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Empresa" nvalue="#NEWDDOSUJETO:oi_empresa/@value" name="oi_empresa"/>
				<form:ComboBox visible="0" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" xsize="30" mode="QRY" required="0" enabled="NEW|EDIT" label="Ubicaci&#243;n" nvalue="#NEWDDOSUJETO:oi_ubicacion/@value" name="oi_ubicacion"/>
				<form:TextBox visible="0" required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo de enlace" nvalue="#NEWDDOSUJETO:@c_enlace" name="c_enlace"/>
				<form:TextBox visible="0" required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#NEWDDOSUJETO:@o_sujeto" name="o_sujeto"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT|SHOW|EDIT|NEW" name="blank_rowList"/>
		<form:Grid visible="EDIT|SHOW|NEW" doc="PARENTSOURCE" idvalue="#PARENTSOURCE:@id" nvalue="#PARENTSOURCE:" allowdel="0" allownew="0" paging="1" rows="8" name="MAIN_GRID">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label="" name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_clasif_suj">
					<form:ComboBox queryname1="NucleusRH.Base.Legales.Clasif_Suj.CLASIF_SUJ.INFO_WIZARD" nvalue="#PARENTSOURCE:oi_clasif_suj/@value" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Clasificaci&#243;n" name="oi_clasif_suj"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_sujeto" name="c_sujeto"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_sujeto" name="d_sujeto"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Persona" attrname="oi_personal" name="oi_personal"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Empresa" attrname="oi_empresa" name="oi_empresa"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Ubicaci&#243;n" attrname="oi_ubicacion" name="oi_ubicacion"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo de enlace" attrname="c_enlace" name="c_enlace"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" visible="NEW|EDIT" img="save" label="Guardar" name="SAVE" X-POLICY="./FORM/NucleusRH/Base/Legales/Sujetos/SUJETO_WIZARD/form/SAVE">
					<form:Event action="SAVE" name="onclick" runat="client"/>
				</form:Button>
				<form:Button label="Agregar Clasificaci&#243;n" visible="NEW|EDIT|LIST_EDIT" descrip="Agregar un Registro" img="new" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Eliminar Clasificaci&#243;n" visible="NEW|EDIT|LIST_EDIT" mess="&#191;Est&#225; seguro que desa eliminar el registro?" descrip="Eliminar un Registro" img="del" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SAVE()
{
	if(Ctrl('MAIN_GRID').TotalRowsCount() == 0)
	{
		alert("El sujeto debe tener al menos una clasificaci&#243;n.");
		return false;
	}
		
		var cantV=0;
		  
		for(var i=0;i&lt;Ctrl('MAIN_GRID').TotalRowsCount();i++)
			{          
		 
			if(Ctrl('MAIN_GRID').GetCellXValue('oi_clasif_suj',i)=='')
				{
		 
				cantV++;
				}			
			}
	    
		if(cantV==Ctrl('MAIN_GRID').TotalRowsCount())
			{
			   
			  alert("El sujeto debe tener al menos una clasificaci&#243;n.");
				return false;
			}		
	
	
	Ctrl("main").DoEvent("SAVE");
}         



 
	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
</form:Form>
