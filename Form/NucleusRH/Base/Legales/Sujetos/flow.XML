<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Legales.Sujetos.flow" extends="NucleusRH.Base.Legales.Sujetos.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Legales.Sujetos"/>
	<flow:declare>
		<qry:define declare="&lt;ROW c_sujeto=&quot;ll&quot;/&gt;" name="FILTER">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:ROW" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
			t0.oi_sujeto as oi_sujeto,
			t0.c_sujeto as c_sujeto
			FROM 
			LEG40_SUJETOS as t0,                                     
			LEG40_CLASIF_SUJ as lcs
			JOIN 
			t0.oi_sujeto LEFT OUTER lcs.oi_sujeto
			WHERE
			1=1			
			{%?(#PARAM:@c_sujeto!='') {% AND CONTAIN(t0.c_sujeto, \'{%=#PARAM:@c_sujeto%}\') %} {% %} %}
			{%?(#PARAM:@d_sujeto!='') {% AND CONTAIN(t0.d_sujeto, \'{%=#PARAM:@d_sujeto%}\') %} {% %} %}
			{%?(#PARAM:@oi_clasif_suj!='') {% AND lcs.oi_clasif_suj={%=#PARAM:@oi_clasif_suj%} %} {% %} %}
			GROUP BY
			t0.oi_sujeto,
			t0.c_sujeto
			ORDER BY 
			c_sujeto asc ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_sujeto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROW oi_clasif_suj = &quot;2&quot; /&gt;" name="LIST">
			<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO"/>
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:ROW" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			SELECT 
			t0.oi_sujeto as oi_sujeto, 
			t0.c_sujeto as c_sujeto, 
			t0.d_sujeto as d_sujeto, 
			t0.c_enlace as c_enlace,
			t0.d_email as d_email,
			t0.c_sujeto as CODE, 
			t0.d_sujeto as TEXT, 
			t0.oi_personal as oi_personal, 
			t0.oi_empresa as oi_empresa, 
			t0.oi_ubicacion as oi_ubicacion 
			FROM 
			LEG40_SUJETOS as t0,                                     
			LEG40_CLASIF_SUJ as lcs
			JOIN 
			t0.oi_sujeto LEFT OUTER lcs.oi_sujeto
			WHERE
			1=1			
			{%?(#PARAM:@c_sujeto!='') {% AND CONTAIN(t0.c_sujeto, \'{%=#PARAM:@c_sujeto%}\') %} {% %} %}
			{%?(#PARAM:@d_sujeto!='') {% AND CONTAIN(t0.d_sujeto, \'{%=#PARAM:@d_sujeto%}\') %} {% %} %}
			{%?(#PARAM:@oi_clasif_suj!='') {% AND lcs.oi_clasif_suj={%=#PARAM:@oi_clasif_suj%} %} {% %} %}
			GROUP BY
			t0.oi_sujeto, t0.c_sujeto, t0.d_sujeto, t0.c_enlace,t0.d_email, t0.oi_personal, t0.oi_empresa, t0.oi_ubicacion
			ORDER BY 
			c_sujeto asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_sujeto"/>
						<qry:attribute name="c_sujeto" value="$r/@c_sujeto"/>
						<qry:attribute name="d_sujeto" value="$r/@d_sujeto"/>
						<qry:attribute name="c_enlace" value="$r/@c_enlace"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_personal!=''">
							<qry:then>
								<qry:element name="oi_personal">
									<qry:attribute name="OI_FIND" value="$r/@oi_personal"/>
									<qry:insert-select name="NucleusRH.Base.Personal.Legajo.PERSONAL.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_personal" value="'['+oi_personal/ROW/@COD+'] '+oi_personal/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:attribute name="d_email" value="$r/@d_email"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_ubicacion!=''">
							<qry:then>
								<qry:element name="oi_ubicacion">
									<qry:attribute name="OI_FIND" value="$r/@oi_ubicacion"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.UBICACION.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_ubicacion" value="'['+oi_ubicacion/ROW/@COD+'] '+oi_ubicacion/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTERDATA">
			<ROW d_sujeto=""/>
		</doc:define>
	</flow:declare>
