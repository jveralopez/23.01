<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="Nomad.combo.flow" name="NucleusRH.Base.Legales.Sujetos.SUJETO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Legales.Sujetos.SUJETO"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_sujeto as ID, t.c_sujeto as CODE, t.d_sujeto as TEXT, SEC.policy  FROM LEG40_SUJETOS as t, NMD_SECURITY(class=\'NucleusRH.Base.Legales.Sujetos.SUJETO\') as SEC JOIN t.oi_sujeto LEFT OUTER SEC.id  ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@CODE+'-'+$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
