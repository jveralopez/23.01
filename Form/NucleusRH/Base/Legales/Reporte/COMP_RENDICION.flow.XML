<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.flow" extends="Nomad.Base.flow">
	<flow:info label="Reporde de Comprobantes Rendidos"/>
	<flow:declare>
		<doc:define name="REPORTDOM"/>
		<doc:define name="FILTER">
			<ROW/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.filter.form" name="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.filter.form:FILTER" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="FILTER">
			<flow:call-action eq="HTML" if="#FILTER:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTER:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen template-file="NucleusRH.Base.Legales.Comprobantes.rpt" ext="html" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
			<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.form" doc-path="#REPORTDOM:" mode="REPORT"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen template-file="NucleusRH.Base.Legales.Comprobantes.rpt" ext="xls" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
			<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.form" doc-path="#REPORTDOM:" mode="REPORT"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.form" name="NucleusRH.Base.Legales.Reporte.COMP_RENDICION.form:REPORT" doc="SOURCE" mode="REPORT">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
