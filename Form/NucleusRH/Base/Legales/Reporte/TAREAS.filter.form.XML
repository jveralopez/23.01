<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Legales.Reporte.TAREAS.filter" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Help>
		<form:Help-title text="Reclamos" name="TITLE"/>
		<form:Help-descr text="En esta tabla se guardan todos los reclamos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Tareas" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER">
					<form:Event action="FILTER" runat="server" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER"/>
					</form:Policies>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Center>
		<form:Columns visible="FILTER" name="main_columnsADELANTO">
			<form:Column name="main_columnsADELANTOcolumn1">
				<form:Blank name="blank"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" nvalue="#FILTER:@oi_empresa" name="oi_empresa" label="Empresa" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA" prev="oi_empresa" xsize="40" mode="QRY" label="Carpeta" nvalue="#FILTER:@oi_carpeta" name="oi_carpeta"/>
				<form:TextBox required="0" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#FILTER:@d_tarea" name="d_tarea"/>
				<form:Rower label="Fecha Desde" name="rwerfechas" separation="5">
					<form:DateTime nvalue="#FILTER:@f_tarea_d" name="f_tarea_d" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label label="Fecha Hasta" name="sd"/>
					<form:DateTime nvalue="#FILTER:@f_tarea_h" name="f_tarea_h" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.INFO" xsize="40" mode="QRY" required="0" label="Estado Tarea" nvalue="#FILTER:@oi_estado_tarea" name="oi_estado_tarea"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Tipos_Tarea.TIPO_TAREA.INFO" xsize="40" mode="QRY" required="0" label="Tipo Tarea" nvalue="#FILTER:@oi_tipo_tarea" name="oi_tipo_tarea"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Sujetos.CLASIF_SUJETO.INFO_TAREAS" xsize="30" mode="QRY" required="0" label="Responsable" nvalue="#FILTER:@oi_clasif_sujeto" name="oi_clasif_sujeto"/>
				<form:TextBox required="0" ysize="1" xsize="50" length="100" label="Lugar" nvalue="#FILTER:@d_lugar_tarea" name="d_lugar_tarea"/>
				<form:Rower separation="10" label="Fecha Vencimiento Tarea Desde" name="rower_fechas">
					<form:DateTime name="f_vto_tarea_desde" nvalue="#FILTER:@f_vto_tarea_d" label="Fecha Vencimiento Tarea Desde" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="Fecha Vencimiento Tarea Hasta" name="lbl_rower"/>
					<form:DateTime name="f_vto_tarea_hasta" nvalue="#FILTER:@f_vto_tarea_h" label="Fecha Vencimiento Tarea Hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:Combo required="1" nvalue="#FILTER:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
					<form:Opts name="aaa">
						<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
						<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
					</form:Opts>
				</form:Combo>
			</form:Column>
		</form:Columns>
	</form:Center>
</form:Form>
