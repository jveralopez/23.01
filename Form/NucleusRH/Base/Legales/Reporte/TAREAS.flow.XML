<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.Legales.Reportes">
	<flow:info label="Flow para NucleusRH.Base.QuejasyReclamos.Reclamos"/>
	<flow:declare>
		<doc:define name="REPORTDOM"/>
		<doc:define name="ENTRADA">
			<ROW llamado_desde=""/>
		</doc:define>
		<doc:define name="CLASE">
			<ROW clase=""/>
		</doc:define>
		<doc:define name="FILTER">
			<ROW/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.TAREAS.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:group name="TAREAS">
		<flow:form form-class="NucleusRH.Base.Legales.Reporte.TAREAS.filter.form" name="NucleusRH.Base.Legales.Reporte.TAREAS.filter.form:FILTER" doc="SOURCE" mode="FILTER">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:log text-path="#FILTER:" text="log-filter"/>
				<flow:call-action eq="HTML" if="#FILTER:@salida" action="ACCEPTHTML"/>
				<flow:call-action eq="EXCEL" if="#FILTER:@salida" action="ACCEPTEXCEL"/>
			</flow:action>
			<flow:action name="ACCEPTHTML">
				<flow:html-gen template-file="NucleusRH.Base.Legales.Tareas.rpt" ext="html" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.TAREAS.form" doc-path="#REPORTDOM:" mode="REPORT"/>
			</flow:action>
			<flow:action name="ACCEPTEXCEL">
				<flow:html-gen template-file="NucleusRH.Base.Legales.Tareas.rpt" ext="xls" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form form-class="NucleusRH.Base.Legales.Reporte.TAREAS.form" doc-path="#REPORTDOM:" mode="REPORT"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.Legales.Reporte.TAREAS.form" name="NucleusRH.Base.Legales.Reporte.TAREAS.form:REPORT" doc="SOURCE" mode="REPORT">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
