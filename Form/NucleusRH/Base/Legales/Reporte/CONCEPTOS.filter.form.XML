<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Legales.Reporte.CONCEPTOS.filter.form" default_mode="FILTER" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Filtrar Adelantos" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns visible="FILTER" name="main_columns">
			<form:Column name="column1">
				<form:Blank name="blank1"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" nvalue="#FILTER:@oi_empresa" name="oi_empresa" label="Empresa" xsize="40" mode="QRY" required="0"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA" prev="oi_empresa" xsize="40" mode="QRY" label="Carpeta" nvalue="#FILTER:@oi_carpeta" name="oi_carpeta"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Adelantos.ADELANTO.INFO_PORCARPETA" prev="oi_carpeta" xsize="40" mode="QRY" label="Anticipo" nvalue="#FILTER:@oi_adelanto" name="oi_adelanto"/>
				<form:Blank name="blank2"/>
				<form:DateTime label="Fecha Adelanto Desde" name="f_adel_desde" nvalue="#FILTER:@f_adel_desde" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha Adelanto Hasta" name="f_adel_hasta" nvalue="#FILTER:@f_adel_hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="blank3"/>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.EstadosAnt.ESTADO_ANT.INFO" xsize="40" mode="QRY" label="Estado Anticipo" nvalue="#FILTER:@oi_estado_ant" name="oi_estado_ant"/>
				<form:ComboBox nvalue="#FILTER:@oi_clasif_sujeto" queryname1="NucleusRH.Base.Legales.Sujetos.CLASIF_SUJETO.INFO_ADELANTO" label="Responsable" name="oi_clasif_sujeto" xsize="40" mode="QRY"/>
				<form:CheckBox nvalue="#FILTER:@adelantos_anulados" name="adelantos_anulados" label="Mostrar Anulados"/>
				<form:Blank name="blank4"/>
				<form:Combo required="1" nvalue="#FILTER:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
					<form:Opts name="aaa">
						<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
						<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
					</form:Opts>
				</form:Combo>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok">
					<form:Event action="FILTER" runat="server" name="onclick"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts/>
</form:Form>
