	</form:Center>
	<form:Scripts>
		function FILTER() {
	if(Ctrl('main').GetMode()=="FILTER")	{
		var np, nSQL, docReclamo;
		np = new NomadProxy("", ut);
		nSQL = np.SQLService();
		docRtdo = new NomadXML(nSQL.Get(Ctrl("main").getResource("qrycount"), "&lt;PARAM id=\""+Ctrl("c_origen").GetXValue()+"\" /&gt;"));				
		if(docRtdo.GetAttr("cantidad") &gt; 10000) {
			alert("Super&#243; el l&#237;mite de registros permitidos. Por favor afine la b&#250;squeda.");
			return false;	
		}             
		else
			Ctrl('main').DoEvent('FILTER');
	}                                
	else
		Ctrl('main').DoEvent('FILTER');
}   

function onLoad()
{
	Ctrl('l_activo').SetXValue('1');
	Ctrl('l_rendido').SetXValue('0');
	Ctrl('l_rendido_parcial').SetXValue('1');
	
	//no_transf_gp_onclick();
} 

function btnFILTER_onClick()
{ 

if((Ctrl('l_activo').GetXValue()=='0') &amp;&amp; (Ctrl('l_rendido').GetXValue()=='0') &amp;&amp; (Ctrl('l_rendido_parcial').GetXValue()=='0') )
	{
 	alert('Indique al menos un Estado de Anticipo'); 	
 	return false;
	}             
	else
	{
	return true;
	}
	
}


function no_transf_gp_onclick()
{
	if (Ctrl('l_no_transf_gp').GetXValue()==1)
	{
		Ctrl('f_transf_gp_hasta').SetCValue('');
		Ctrl('f_transf_gp_desde').SetCValue('');
		CtrlEnabled('f_transf_gp_hasta',false);
		CtrlEnabled('f_transf_gp_desde',false);
	}
	else
	{
		CtrlEnabled('f_transf_gp_hasta',true);
		CtrlEnabled('f_transf_gp_desde',true);
	}

}
	</form:Scripts>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM id=&quot;PEN&quot; /&gt;" name="qrycount">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				SELECT
					COUNT(QYR01_RECLAMOS.oi_reclamo) as cantidad
				FROM
					QYR01_RECLAMOS
				WHERE
					{%? (#PARAM:@id ='PEN') 
						{% QYR01_RECLAMOS.c_estado != \'Reclamo finalizado\'	%}  
						{% 
							{%? (#PARAM:@id ='CER') 
							{% QYR01_RECLAMOS.c_estado = \'Reclamo finalizado\'	%}  
							{% 1=1  %} 
							%}
						%} 
					%}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cantidad" value="$r/@cantidad"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
</form:Form>
