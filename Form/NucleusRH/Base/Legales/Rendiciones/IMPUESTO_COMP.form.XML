	</form:Scripts>
	<form:Resources>
		<form:Resource name="GetPorcentaje">
			<qry:main name="main" doc="SOURCE">
				<qry:element name="PORCENTAJE">
					<qry:insert-select name="qryPorcentaje" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qryPorcentaje" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				
				SELECT
					LEG62_IMPUESTOS.n_porcentaje
				
				FROM
					LEG62_IMPUESTOS
					
				WHERE
					LEG62_IMPUESTOS.oi_impuesto = {$PARAM/@oi_impuesto}
				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="n_porcentaje" value="$r/@n_porcentaje"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
