	<form:Scripts>
		function impuesto_onchange()
{		
	var nSQL, xmlParam, objPorc;	
	var oi_impuesto = Ctrl('oi_impuesto').GetXValue();
	
	if (oi_impuesto!='')
	{	
	  nSQL = GetProxy().SQLService();	 
		xmlParam = new NomadXML('DATA');
		xmlParam.SetAttr('oi_impuesto',oi_impuesto);				
		objPorc = nSQL.GetOBJ(Ctrl("main").getResource("GetPorcentaje"),xmlParam.ToString()); 
  	Ctrl('n_alicuota').SetCValue(Number(objPorc.n_porcentaje).toFixed(2));
	}
	else
	{
		Ctrl('n_alicuota').SetXValue();
	}	
}


