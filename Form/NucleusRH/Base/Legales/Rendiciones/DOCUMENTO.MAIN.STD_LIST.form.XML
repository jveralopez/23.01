<form:Form xmlns:form="nomad_engine.form" doc="source" extends="NucleusRH.Base.Legales.Rendiciones.DOCUMENTO.MAIN.STD_LIST.autoform" name="NucleusRH.Base.Legales.Rendiciones.DOCUMENTO.MAIN.STD_LIST.form" default_mode="SHOW">
	<form:Help/>
	<form:Scripts>
		function btnDescargar_onClick()
{
   
   window.open("../../../ToDownLoad.aspx?modo=DB&amp;file_id=" + Ctrl('LIST').GetSelectAttrValue("id_doc_dig") + "&amp;class=NucleusRH.Base.Legales.DocumentosDigitales.HEAD");
	
	
}
	</form:Scripts>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Agregar un Registro" img="application_add.gif" label="Agregar" name="ADD" visible="0">
					<form:Event action="RegAdd" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Modificar el Registro" img="application_edit.gif" label="Modificar" name="EDIT" visible="0">
					<form:Event action="RegEdit" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Eliminar un Registro" img="application_delete.gif" label="Eliminar" name="DELETE" visible="0">
					<form:Event action="RegDelete" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="!SELECT" name="btnDescargar" label="Descargar" descrip="Descargar el archivo adjunto" mess="" img="disk.gif">
					<form:Event action="btnDescargar_onClick" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
