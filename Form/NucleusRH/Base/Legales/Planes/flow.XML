<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Legales.Planes.flow" extends="NucleusRH.Base.Legales.Planes.autoflow">
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				
				SELECT
					t0.oi_plan as oi_plan
					
				FROM
					LEG62_PLANES as t0
				
				WHERE 
					{%? (#PARAM:@oi_empresa!='')
						{% t0.oi_empresa={#PARAM:@oi_empresa} %}
						{% 1=1 %}
					%}
				
				ORDER BY
					oi_plan asc
				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_plan"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			
			SELECT
				t0.oi_plan as oi_plan,
				t0.c_plan as c_plan,
				t0.d_plan as d_plan,
				t0.c_plan as CODE,
				t0.d_plan as TEXT,
				t0.oi_empresa as oi_empresa
			
			FROM
				LEG62_PLANES as t0
			
			WHERE 
				{%? (#PARAM:@oi_empresa!='')
					{% t0.oi_empresa={#PARAM:@oi_empresa} %}
					{% 1=1 %}
				%}
			
			ORDER BY
				oi_plan asc
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_plan"/>
						<qry:attribute name="c_plan" value="$r/@c_plan"/>
						<qry:attribute name="d_plan" value="$r/@d_plan"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Legales.Planes.PLAN.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:group Name="PLAN">
		<flow:form extends="NucleusRH.Base.Legales.Planes.PLAN.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Legales.Planes.PLAN.filter.form:FILTER" form-class="NucleusRH.Base.Legales.Planes.PLAN.filter.form" mode="FILTER"/>
	</flow:group>
</flow:flow>
