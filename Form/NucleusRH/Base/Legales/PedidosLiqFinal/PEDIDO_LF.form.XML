		var RS;

function onload()
{
	RS = Ctrl('main').GetLastDocXML('RS');
  
  if (Ctrl('main').GetMode()=='SHOW')
	{
		GetCliente();
	}
  
	if (Ctrl('main').GetMode()=='NEW')
	{
		//Sugerir la sucursal de la carpeta		
		Ctrl('oi_ubicacion').SetXValue(Ctrl('oi_ubicacion_car').GetXValue());		
	}
	
	if (Ctrl('main').GetMode()!='APROBAR')
	{		
		Ctrl('lbl_titulo').SetText(Ctrl('titulo_car').GetXValue());
	}
		
	if (Ctrl('main').GetMode()=='LIST_EDIT')
	{		
		if (Ctrl('permiso_plf').GetXValue()=="1") //Carpeta abierta, tipo = 2 y estado != 11
		{
			//Puede agregar un pedido
			CtrlEnabled('ADD', true);
			
			//Pero si hay alguno Pendiente, Aprobado o Cumplido entonces no puede			
			for (var cur=RS.FirstChild(); cur!=null; cur=cur.Next())
			{				
				if (cur.GetAttr("c_estado")=="P" || cur.GetAttr("c_estado")=="AP" || cur.GetAttr("c_estado")=="C")
				{					
					CtrlEnabled('ADD', false);
					break;					
				}							
			}
		}
		else //Carpeta cerrada o tipo != 2 o estado = 11
		{
			//No puede agregar un pedido
			CtrlEnabled('ADD', false);			
		}
	}
	
	HabilitarBotones();	
}

function CustomListClick()
{
	ListClick();  
  HabilitarBotones();    
}

function HabilitarBotones()
{
	//MODO SHOW
	if (Ctrl('main').GetMode()=='SHOW')
	{
		//Si existe la tarea asociada puede consultarla
		if (Ctrl("oi_tarea").GetXValue()!="")
		{
			CtrlEnabled('TAREA', true);
		}
		else
		{
			CtrlEnabled('TAREA', false);
		}
	}
	
	//MODO LIST_EDIT	
	if (Ctrl('main').GetMode()=='LIST_EDIT')
	{		
		if (RS.FirstChild() == null) //NO HAY REGISTROS		
		{
			CtrlEnabled('SHOW', false);
			CtrlEnabled('APROBAR', false);
			CtrlEnabled('RECHAZAR', false);
			CtrlEnabled('ANULAR', false);
			CtrlEnabled('DOC_PEDIDO_LF', false);			
			CtrlEnabled('TAREA', false);
			CtrlEnabled('REPORTE', false);
		}
		else //HAY REGISTROS
		{
			CtrlEnabled('SHOW', true);
			CtrlEnabled('DOC_PEDIDO_LF', true);			
			CtrlEnabled('REPORTE', true);
					
			//Puede aprobar o anular el pedido seleccionado si esta Pendiente	
			if (Ctrl("LIST").GetSelectAttrValue("c_estado")=="P")
			{	
				CtrlEnabled('APROBAR', true);
				CtrlEnabled('ANULAR', true);			
			}
			else
			{
				CtrlEnabled('APROBAR', false);
				CtrlEnabled('ANULAR', false);
			}
		
			//Puede rechazar el pedido seleccionado si esta Pendiente o Aprobado
			if (Ctrl("LIST").GetSelectAttrValue("c_estado")=="P" || Ctrl("LIST").GetSelectAttrValue("c_estado")=="AP")
			{
				CtrlEnabled('RECHAZAR', true);
			}
			else
			{
				CtrlEnabled('RECHAZAR', false);
			}
	
			//Si existe la tarea asociada puede consultarla
			if (Ctrl("LIST").GetSelectAttrValue("oi_tarea")!="")
			{
				CtrlEnabled('TAREA', true);
			}
			else
			{
				CtrlEnabled('TAREA', false);
			}
		}	
	}	
	
	//MODO APROBAR
	if (Ctrl('main').GetMode()=='APROBAR')
	{
		if (RS.FirstChild() == null) //NO HAY REGISTROS		
		{
			CtrlEnabled('SHOW', false);
			CtrlEnabled('APROBARMASIVO', false);
			CtrlEnabled('RECHAZARMASIVO', false);			
			CtrlEnabled('DOC_PEDIDO_LF', false);			
			CtrlEnabled('REPORTE', false);
			CtrlEnabled('REP_CARPETA', false);						
		}
		else //HAY REGISTROS
		{
			CtrlEnabled('SHOW', true);
			CtrlEnabled('APROBARMASIVO', true);
			CtrlEnabled('RECHAZARMASIVO', true);						
			CtrlEnabled('DOC_PEDIDO_LF', true);			
			CtrlEnabled('REPORTE', true);
			CtrlEnabled('REP_CARPETA', true);						
			
			/*
			//Puede aprobar o rechazar si hay pedidos seleccionados
			if (Ctrl("listarr").CountRow() == 0)
			{						
				CtrlEnabled('APROBARMASIVO', false);
				CtrlEnabled('RECHAZARMASIVO', false);						
			}
			else
			{			
				CtrlEnabled('APROBARMASIVO', true);
				CtrlEnabled('RECHAZARMASIVO', true);			
			}
			*/	
		}
	}	
}

function GetCliente()
{
	var nSQL = GetProxy().SQLService();
	var oi_carpeta = Ctrl("oi_carpeta").GetXValue();  
  var xmlParam = new NomadXML("CARPETA");
  xmlParam.SetAttr("oi_carpeta", oi_carpeta);
  
  var objResult = nSQL.GetOBJ(Ctrl("main").getResource("GetCliente"), xmlParam.ToString());
		
	Ctrl('oi_cliente').SetCValue(objResult.oi_cliente);
}

function tarea_onclick()
{
	var id, xmlParam;  
  if(Ctrl('main').GetMode()=='LIST_EDIT' || Ctrl('main').GetMode()=='APROBAR') id = Ctrl("LIST").GetSelectAttrValue("oi_tarea");
  else if(Ctrl('main').GetMode()=='SHOW') id = Ctrl("oi_tarea").GetXValue();  
  xmlParam = new NomadXML("TAREA");
  xmlParam.SetAttr("oi_tarea", id);
  getFormInMain("NucleusRH.Base.Legales.Tareas.flow", "tarea_pedido_lf", xmlParam.ToString(), false);	
}

function monto_inicial_validate(p)
{
	if (Number(p.GetXValue())&lt;=0)
	{
		p.SetError("El monto inicial debe ser mayor a cero.");
		return false;
	}
	return true;
}

function reporte_carpeta()
{
	var id, xmlParam;  
  id = Ctrl("LIST").GetSelectAttrValue("oi_car");  
  xmlParam = new NomadXML("CARPETA");
  xmlParam.SetAttr("oi_carpeta", id);
  getFormInMain("NucleusRH.Base.Legales.Carpetas.flow", "reporte_externo", xmlParam.ToString(), false);
}

function aprobar()
{
	myNewFlow("help_aprobar");
}

function rechazar()
{
	myNewFlow("help_rechazar");
}

function anular()
{
	myNewFlow("help_anular");
}

function myNewFlow(action)
{
	var xmlParam = new NomadXML("PLF");
	
	if (Ctrl('main').GetMode()=='LIST_EDIT')
	{		
		var id = Ctrl("LIST").GetXValue();
		if (action=="help_anular")
		{				
			xmlParam.SetAttr("oi_pedido_lf", id);
		}
		else
		{
			var xmlRows = xmlParam.AddTailElement("ROWS");
			var xmlRow = xmlRows.AddTailElement("ROW");
  		xmlRow.SetAttr("oi_pedido_lf", id);  		
  	}
  }
  else if (Ctrl('main').GetMode()=='APROBAR')
  {                

  	var tarea= Ctrl("LIST").GetSelectAttrValue("oi_tarea");
  	xmlParam.SetAttr("oi_tarea", tarea); 

  	
  	var xmlRows = xmlParam.AddTailElement("ROWS");
  	for (var i=0; i&lt;Ctrl("listarr").CountRow(); i++) 
		{
			var xmlRow = xmlRows.AddTailElement("ROW");
			var id = Ctrl("listarr").GetRow(i).GetAttr("id");						
			xmlRow.SetAttr("oi_pedido_lf", id);
			
		}		
  }
  
	openNewFlow("NucleusRH.Base.Legales.PedidosLiqFinal.flow", action, xmlParam.ToString(), new ObjtectResult(), "S");
}

function ObjtectResult()
{
	this.processResult = function(xmlIn)
	{
		var xmlResult;		
		xmlResult = new NomadXML(xmlIn);		
		if (xmlResult.GetAttr("action")=="ACEPTAR")
		{
			if (xmlResult.GetAttr("error")!="")
				alert(xmlResult.GetAttr("error"));				
			else
				Ctrl("main").DoEvent("load-list");
				desmarcar();				
		}
		
		if (xmlResult.GetAttr("action")=="ACEPTARRechazar")
		{
			if (xmlResult.GetAttr("error")!="")
				alert(xmlResult.GetAttr("error"));				
			else
				Ctrl("main").DoEvent("load-list");
				desmarcar();				
		}
	}
	
	
	
}

function save_onclick()
{
	var mensaje = '';	
	var acuerdo = Ctrl('n_monto_total').GetXValue();
	var reclamo = Ctrl('n_monto_inicial').GetXValue();

	if(acuerdo=="") mensaje += 'No existen montos de acuerdo.\n';
	else if(Number(acuerdo)==0) mensaje += 'El monto de acuerdo debe ser mayor a 0.\n';
	if(reclamo=="") mensaje += 'No existen montos de reclamo.\n';
	else if(Number(reclamo)==0) mensaje += 'El monto de reclamo debe ser mayor a 0.\n';
	
	if(acuerdo!="" &amp;&amp; reclamo!="" &amp;&amp; Number(acuerdo)&gt;Number(reclamo))
		mensaje += 'El monto de acuerdo debe ser menor o igual que el monto de reclamo.';
	
	if(mensaje!='')
	{
		alert('No se puede guardar el Pedido de Liquidaci&#243;n Final:\n' + mensaje);
		return false;
	}
	
	return true;
}

function aprobar_masivo()
{
	if (Ctrl("listarr").CountRow() == 0)
	{
		alert("Debe elegir algun Pedido de Liquidaci&#243;n Final para aprobar.");
		return;
	}
	
	for (var i=0; i&lt;Ctrl("listarr").CountRow(); i++) 
	{		
		var row = Ctrl("listarr").GetRow(i);
		var estado = GetRow(row.GetAttr("id"),"c_estado");				
		if (estado!="P")
		{
			alert("Solo puede aprobar Pedidos de Liquidaci&#243;n Final en estado Pendiente.");	
			return;
		}		
	}
		
	myNewFlow("help_aprobar");
}

function rechazar_masivo()
{
	if (Ctrl("listarr").CountRow() == 0)
	{
		alert("Debe elegir algun Pedido de Liquidaci&#243;n Final para rechazar.");
		return;
	}
	
	for (var i=0; i&lt;Ctrl("listarr").CountRow(); i++) 
	{		
		var row = Ctrl("listarr").GetRow(i);
		var estado = GetRow(row.GetAttr("id"),"c_estado");
	
		if (estado!="P" &amp;&amp; estado!="AP")
		{
			alert("Solo puede rechazar Pedidos de Liquidaci&#243;n Final en estado Pendiente o Aprobado.");	
			return;
		}		
	}
	
	myNewFlow("help_rechazar");
}

function GetRow(id, AttrName) { 

	for (var j=0; j&lt;Ctrl("LIST").TotalRowsCount(); j++) {    
		if (id == Ctrl("LIST").GetAttrValue(j, 'id')) {
			var row = Ctrl("LIST").GetAttrValue(j, AttrName);
			return row;                                     
		}     
	}
}

function marcar()
{
	var objLista = Ctrl("LIST");
	
	Ctrl("listarr").DelAllRow();
	
	for (i=0; i&lt;objLista.shownRegs.length; i++)
		Ctrl("listarr").AddRow().SetAttr("id",objLista.shownRegs[i].attributes.getNamedItem("id").value);
		
	objLista.Refresh();		
}

function desmarcar()
{      
	Ctrl("listarr").DelAllRow();	
	Ctrl("LIST").Refresh();	
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
	<form:Event name="load-list" action="load-list" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;DATA oi_carpeta='601' /&gt;" name="GetCliente">
			<qry:main doc="SOURCE">
				<qry:insert-select name="SQL1" doc-path="#SOURCE:."/>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('			

			SELECT			   
			  CLI01_CLIENTES.c_cliente as COD, 
			  CLI01_CLIENTES.d_razon_social as DES
			  
			FROM 
			  LEG01_CARPETAS,
			  LEG40_SUJETOS,
			  CLI01_CLIENTES
			  
  		JOIN
  			LEG01_CARPETAS.oi_sujeto INNER LEG40_SUJETOS.oi_sujeto,
				LEG40_SUJETOS.d_custom_2 INNER CLI01_CLIENTES.oi_cliente		  	
		  	 
			WHERE
				LEG01_CARPETAS.oi_carpeta = {#SOURCE:@oi_carpeta}				
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<CLIENTE>
						<qry:attribute name="oi_cliente" value="'['+$r/@COD+'] '+$r/@DES"/>
					</CLIENTE>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
