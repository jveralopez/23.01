<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.filter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" extends="nomad.filter.form" doc="source">
	<form:Help>
		<form:Help-title text="Pedidos de Liquidaci&#243;n Final" name="TITLE"/>
		<form:Help-descr text="Tareas de la carpeta" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Filtrar Pedidos de Liquidaci&#243;n Final" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="90%">
		<form:Columns name="columns">
			<form:Column name="column1">
				<form:ComboBox nvalue="#source:@oi_carpeta" where1="LEG01_CARPETAS.oi_tipo_carpeta=2" queryname2="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA" xsize="30" mode="QRY" required="0" label="Carpeta" name="oi_carpeta"/>
				<form:ComboBox nvalue="#source:@c_estado" xsize="30" mode="OPT" required="0" label="Estado" name="c_estado">
					<options>
						<option text="Pendiente" value="P"/>
						<option text="Anulado" value="A"/>
						<option text="Aprobado" value="AP"/>
						<option text="Rechazado" value="R"/>
						<option text="Cumplido" value="C"/>
					</options>
				</form:ComboBox>
				<form:Rower separation="10" name="rower_fechas">
					<form:Label style="S2 LCol_g" label="Fecha desde" name="lbl_f_desde"/>
					<form:DateTime nvalue="#source:@f_desde" name="f_desde" label="Fecha desde" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="Fecha hasta" name="lbl_f_hasta"/>
					<form:DateTime nvalue="#source:@f_hasta" name="f_hasta" label="Fecha hasta" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
			</form:Column>
			<form:ComboBox nvalue="#source:@c_estado" enabled="0" xsize="30" mode="OPT" required="1" label="Estado" name="c_estado">
				<options>
					<option text="Pendiente" value="P"/>
					<option text="Anulado" value="A"/>
					<option text="Aprobado" value="AP"/>
					<option text="Rechazado" value="R"/>
					<option text="Cumplido" value="C"/>
				</options>
			</form:ComboBox>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos">
					<form:Event runat="server" name="onclick" action="FILTER"/>
				</form:Button>
				<form:Button visible="0" name="ADD"/>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
