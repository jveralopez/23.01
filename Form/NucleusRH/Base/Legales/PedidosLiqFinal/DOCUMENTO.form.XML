<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Legales.PedidosLiqFinal.DOCUMENTO.autoform" name="NucleusRH.Base.Legales.PedidosLiqFinal.DOCUMENTO.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:Grid idvalue="#source:@id" visible="EDIT|SHOW" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#source:" name="MAIN_GRID" doc="source">
			<form:GColumns>
				<form:GColumn name="gcolsel">
					<form:Link allowimg="1" note="Selecciona el registro" descrip="Selecciona el registro" img="link2" label=" " name="sel"/>
				</form:GColumn>
				<form:GColumn name="gcold_doc_dig">
					<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_doc_dig" name="d_doc_dig"/>
				</form:GColumn>
				<form:GColumn name="gcolf_doc_dig">
					<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha" nvalue="#source:@f_doc_dig" name="f_doc_dig">
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="gcolo_doc_dig">
					<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="1000" label="Observaci&#243;n" nvalue="#source:@o_doc_dig" name="o_doc_dig"/>
				</form:GColumn>
				<form:GColumn name="gcoloi_doc_dig">
					<form:File nvalue="#source:oi_doc_digital/@value" source="0" required="1" name="oi_doc_digital" label="Documento Digital" enabled="NEW|EDIT" class="NucleusRH.Base.Legales.DocumentosDigitales.HEAD">
						<form:SButtons>
							<form:SButton visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
							<form:SButton visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
								<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:File>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
</form:Form>
