<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Legales.PedidosLiqFinal.flow" extends="NucleusRH.Base.Legales.PedidosLiqFinal.autoflow">
	<flow:declare>
		<doc:define class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF" name="DDO_PLF"/>
		<doc:define name="PEDIDOS_LF"/>
		<doc:define name="INFO_CARPETA"/>
		<doc:define name="XML_RESULT">
			<RESULT/>
		</doc:define>
		<doc:define name="XML_ERROR"/>
		<doc:define name="XML_REPORT"/>
		<doc:define name="REPORT">
			<DATA empty-attr=""/>
		</doc:define>
		<qry:define name="PLF_CARPETA">
			<qry:include name="Nomad.Base.Login.Entidades.ENTIDAD.INFO"/>
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				
					SELECT
						LEG61_PEDIDOS_LF.oi_pedido_lf AS oi_pedido_lf,
						LEG61_PEDIDOS_LF.c_pedido_lf,
						LEG61_PEDIDOS_LF.f_crea,
						LEG61_PEDIDOS_LF.c_usr_crea,
						LEG61_PEDIDOS_LF.c_estado,
						LEG61_PEDIDOS_LF.n_monto_total,
						LEG61_PEDIDOS_LF.n_monto_inicial,
						LEG61_PEDIDOS_LF.n_porcentaje,
						LEG61_PEDIDOS_LF.f_nec_fondos,
						LEG61_PEDIDOS_LF.f_anula,
						LEG61_PEDIDOS_LF.f_aprueba,
						LEG61_PEDIDOS_LF.f_rechaza,
						LEG61_PEDIDOS_LF.f_cumple,
						LEG61_PEDIDOS_LF.oi_tarea,
						SEC.policy						
						
					FROM
						LEG61_PEDIDOS_LF,
						NMD_SECURITY(class=\'NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF\') AS SEC
					
					JOIN
						LEG61_PEDIDOS_LF.oi_pedido_lf LEFT OUTER SEC.id
					
					WHERE
						LEG61_PEDIDOS_LF.oi_carpeta = {#PARAM:@oi_carpeta}
					
					ORDER BY
						oi_pedido_lf ASC
				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_pedido_lf"/>
						<qry:attribute name="c_pedido_lf" value="$r/@c_pedido_lf"/>
						<qry:attribute name="f_crea" value="$r/@f_crea"/>
						<x>
							<qry:attribute name="FILE" value="$r/@c_usr_crea+'.ENTIDAD.XML'"/>
							<qry:insert-select name="Nomad.Base.Login.Entidades.ENTIDAD.QUERY.DDO" doc-path="."/>
						</x>
						<qry:attribute name="c_usr_crea" value="iif(./x/ROW/@DES!='',./x/ROW/@DES,$r/@c_usr_crea)"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="n_monto_total" value="$r/@n_monto_total"/>
						<qry:attribute name="n_monto_inicial" value="$r/@n_monto_inicial"/>
						<qry:attribute name="n_porcentaje" value="$r/@n_porcentaje"/>
						<qry:attribute name="f_nec_fondos" value="$r/@f_nec_fondos"/>
						<qry:attribute name="f_anula" value="$r/@f_anula"/>
						<qry:attribute name="f_aprueba" value="$r/@f_aprueba"/>
						<qry:attribute name="f_rechaza" value="$r/@f_rechaza"/>
						<qry:attribute name="f_cumple" value="$r/@f_cumple"/>
						<qry:attribute name="oi_tarea" value="$r/@oi_tarea"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;PARAM oi_carpeta=601/&gt;" name="PLF_APROBAR">
			<qry:include name="Nomad.Base.Login.Entidades.ENTIDAD.INFO"/>
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
					
					SELECT
						LEG61_PEDIDOS_LF.oi_pedido_lf AS oi_pedido_lf,
						LEG61_PEDIDOS_LF.c_pedido_lf,
						LEG61_PEDIDOS_LF.f_crea,
						LEG61_PEDIDOS_LF.c_usr_crea,
						LEG61_PEDIDOS_LF.c_estado,
						LEG61_PEDIDOS_LF.n_monto_total,
						LEG61_PEDIDOS_LF.n_monto_inicial,
						LEG61_PEDIDOS_LF.n_porcentaje,
						LEG61_PEDIDOS_LF.d_pago,
						LEG61_PEDIDOS_LF.f_nec_fondos,
						LEG61_PEDIDOS_LF.f_aprueba,						
						LEG61_PEDIDOS_LF.oi_carpeta,
						LEG61_PEDIDOS_LF.oi_tarea,						
						LEG01_CARPETAS.c_carpeta,
						LEG01_CARPETAS.d_carpeta,
						ORG03_EMPRESAS.c_empresa,
						ORG03_EMPRESAS.d_empresa,
						ORG03_UBICACIONES.c_ubicacion,
						ORG03_UBICACIONES.d_ubicacion,
						CLI01_CLIENTES.c_cliente,
						CLI01_CLIENTES.d_razon_social						
					
					FROM
						LEG61_PEDIDOS_LF,
						LEG01_CARPETAS,
						ORG03_EMPRESAS,
						ORG03_UBICACIONES,
						LEG40_SUJETOS,
						CLI01_CLIENTES
						
					JOIN
						LEG61_PEDIDOS_LF.oi_carpeta INNER LEG01_CARPETAS.oi_carpeta,
						LEG01_CARPETAS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa,
						LEG61_PEDIDOS_LF.oi_ubicacion INNER ORG03_UBICACIONES.oi_ubicacion,
						LEG01_CARPETAS.oi_sujeto INNER LEG40_SUJETOS.oi_sujeto,
						LEG40_SUJETOS.d_custom_2 INNER CLI01_CLIENTES.oi_cliente
					
					WHERE
						1=1
						{%?($PARAM/@oi_carpeta!='')
							{%
								AND LEG61_PEDIDOS_LF.oi_carpeta = {$PARAM/@oi_carpeta}
							%}
							{% %}
						%}						
						{%?($PARAM/@c_estado!='')
							{%
								AND LEG61_PEDIDOS_LF.c_estado = {$PARAM/@c_estado}
							%}
							{% %}
						%}
						{%?($PARAM/@f_desde!='')
							{%
								AND LEG61_PEDIDOS_LF.f_crea &gt;= {$PARAM/@f_desde}
							%}
							{% %}
						%}
						{%?($PARAM/@f_hasta!='')
							{%
								AND LEG61_PEDIDOS_LF.f_crea &lt;= {$PARAM/@f_hasta}
							%}
							{% %}
						%}
					
					ORDER BY
						oi_pedido_lf ASC
						
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_pedido_lf"/>
						<qry:attribute name="c_pedido_lf" value="$r/@c_pedido_lf"/>
						<qry:attribute name="f_crea" value="$r/@f_crea"/>
						<x>
							<qry:attribute name="FILE" value="$r/@c_usr_crea+'.ENTIDAD.XML'"/>
							<qry:insert-select name="Nomad.Base.Login.Entidades.ENTIDAD.QUERY.DDO" doc-path="."/>
						</x>
						<qry:attribute name="c_usr_crea" value="iif(./x/ROW/@DES!='',./x/ROW/@DES,$r/@c_usr_crea)"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="n_monto_total" value="$r/@n_monto_total"/>
						<qry:attribute name="n_monto_inicial" value="$r/@n_monto_inicial"/>
						<qry:attribute name="n_porcentaje" value="$r/@n_porcentaje"/>
						<qry:attribute name="d_pago" value="$r/@d_pago"/>
						<qry:attribute name="f_nec_fondos" value="$r/@f_nec_fondos"/>
						<qry:attribute name="f_aprueba" value="$r/@f_aprueba"/>
						<qry:attribute name="oi_tarea" value="$r/@oi_tarea"/>
						<qry:attribute name="oi_empresa" value="'['+$r/@c_empresa+'] '+$r/@d_empresa"/>
						<qry:attribute name="oi_carpeta" value="'['+$r/@c_carpeta+'] '+$r/@d_carpeta"/>
						<qry:attribute name="oi_car" value="$r/@oi_carpeta"/>
						<qry:attribute name="oi_ubicacion" value="'['+$r/@c_ubicacion+'] '+$r/@d_ubicacion"/>
						<qry:attribute name="oi_cliente" value="'['+$r/@c_cliente+'] '+$r/@d_razon_social"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATA oi_carpeta=&quot;306&quot;/&gt;" name="INFO_CARPETA">
			<qry:main doc="PARAM">
				<qry:element name="INFO_CARPETA">
					<qry:insert-select name="qry_info_carpeta" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_info_carpeta" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				ORG03_EMPRESAS.oi_empresa,
				ORG03_EMPRESAS.c_empresa,
				ORG03_EMPRESAS.d_empresa,
				LEG01_CARPETAS.oi_carpeta,
				LEG01_CARPETAS.c_carpeta,
				LEG01_CARPETAS.d_carpeta,				
				LEG01_CARPETAS.oi_ubicacion,
				LEG01_CARPETAS.l_cerrado,
				LEG42_TIPO_CARPETA.c_tipo_carpeta,
				LEG31_ESTADOS.c_estado
			
			FROM
				ORG03_EMPRESAS,
				LEG01_CARPETAS,				
				LEG42_TIPO_CARPETA,
				LEG31_ESTADOS
			
			JOIN
				ORG03_EMPRESAS.oi_empresa INNER LEG01_CARPETAS.oi_empresa,
				LEG01_CARPETAS.oi_tipo_carpeta INNER LEG42_TIPO_CARPETA.oi_tipo_carpeta,
				LEG01_CARPETAS.oi_estado_carpeta INNER LEG31_ESTADOS.oi_estado			  
			  
			WHERE
				{%? (#PARAM:oi_carpeta/@value!='')
					{% LEG01_CARPETAS.oi_carpeta = {#PARAM:oi_carpeta/@value} %}
					{% LEG01_CARPETAS.oi_carpeta = {#PARAM:@oi_carpeta} %}
				%}			
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@l_cerrado = '0' AND $r/@c_tipo_carpeta = '2' AND $r/@c_estado != '11'">
						<qry:then>
							<qry:attribute name="permiso_plf" value="1"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="permiso_plf" value="0"/>
						</qry:else>
					</qry:if>
					<qry:attribute name="oi_empresa" value="$r/@oi_empresa"/>
					<qry:attribute name="oi_ubicacion" value="$r/@oi_ubicacion"/>
					<qry:attribute name="titulo" value="'Carpeta: [' + $r/@c_empresa + '] - ' + $r/@d_empresa + ' - [' + $r/@c_carpeta + '] - ' + $r/@d_carpeta"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="COUNT">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<ROW>
						<qry:insert-select doc-path="#PARAM:FILTER" name="sql1"/>
					</ROW>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			 
			SELECT 
			COUNT(t0.oi_pedido_lf) as cant1
			{%?(#PARAM:@rol='USER')
				 {% ,\'./ROLE/LEGALES_USER\' as POLICY  %}
					{% %}
				%}
				 
			FROM 
			LEG61_PEDIDOS_LF as t0
			{%?(#PARAM:@rol='USER')
				 {% 
				  ,LEG01_CARPETAS as C
				  %}
					{% %}
				%}		
		 
			
			{%?(#PARAM:@rol='USER')
				 {%
				 JOIN
				 t0.oi_carpeta INNER C.oi_carpeta
				 %}
					{% %}
				%}	 
			
			WHERE
			1=1		
			
			{%?(#PARAM:@oi_carpeta!='') {% AND t0.oi_carpeta = {#PARAM:@oi_carpeta} %} {% %} %}
			{%?(#PARAM:@f_desde!='') {% AND t0.f_crea &gt;= {#PARAM:@f_desde} %} {% %} %}
			{%?(#PARAM:@f_hasta!='') {% AND t0.f_crea &lt;  {Datetime(Number(Datetime(#PARAM:@f_hasta))+1)} %} {% %} %}
			{%?(#PARAM:@c_estado!='') {% AND t0.c_estado = {#PARAM:@c_estado} %} {% %} %}			
			
			{%?(#PARAM:@rol='USER')
				 {% 
				  
				  AND C.oi_ubicacion IN (SELECT LEG58_SEGURIDAD.oi_ubicacion 
	
			 												FROM LEG58_SEGURIDAD
			  											WHERE LEG58_SEGURIDAD.oi_usuario_sys = \'{%=$proxy/@ETTY%}\')					  
				  %}
					{% %}
				%}		
			
			  
			  ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cant" value="$r/@cant1"/>
					<qry:attribute name="exito" value="iif(@cant&gt;=300,'0','1')"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="CANT"/>
		<qry:define declare="&lt;!--&lt;PLF&gt;&lt;ROWS&gt;&lt;ROW oi_pedido_lf=&quot;801&quot; /&gt;&lt;/ROWS&gt;&lt;/PLF&gt;--&gt;&#13;&#10;&lt;!--&lt;PLF oi_tarea=&quot;&quot;&gt;&lt;ROWS&gt;&lt;ROW oi_pedido_lf=&quot;802&quot; /&gt;&lt;/ROWS&gt;&lt;/PLF&gt;--&gt;&#13;&#10;&#13;&#10;&lt;PLF oi_tarea=&quot;2506&quot;&gt;&lt;ROWS&gt;&lt;ROW oi_pedido_lf=&quot;607&quot;/&gt;&lt;ROW oi_pedido_lf=&quot;608&quot;/&gt;&lt;ROW oi_pedido_lf=&quot;609&quot;/&gt;&lt;ROW oi_pedido_lf=&quot;817&quot;/&gt;&lt;/ROWS&gt;&lt;/PLF&gt;&#13;&#10;&lt;!--&lt;PLF oi_pedido_lf=&quot;801&quot;/&gt;--&gt;&#13;&#10;&lt;!--&lt;PARAM oi_pedido_lf=&quot;701&quot; oi_tarea=&quot;2229&quot;/&gt;--&gt; " name="GetDatosTareaEstado4">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:PLF" name="PLF"/>
				<qry:element name="ROWS">
					<qry:element name="IDS">
						<qry:attribute name="hts:delete" value="1"/>
						<qry:insert-select name="spliter" doc-path="#PLF:ROWS/ROW"/>
						<qry:if test="@cnt!=''">
							<qry:then>
								<qry:element name="ROW">
									<qry:attribute name="oi_pedido_lf" value="../@ois"/>
								</qry:element>
								<qry:attribute name="ois" value="''"/>
								<qry:attribute name="sep" value="''"/>
								<qry:attribute name="cnt" value="''"/>
							</qry:then>
						</qry:if>
						<qry:append-doc name="LEGS" doc-path="."/>
					</qry:element>
					<qry:insert-select name="qry_pedido_lf" doc-path="#LEGS:ROW"/>
				</qry:element>
			</qry:main>
			<qry:select name="spliter" doc="SOURCE">
				<qry:out>
					<qry:attribute name="ois" value="@ois + @sep + #SOURCE:@oi_pedido_lf"/>
					<qry:attribute name="sep" value="','"/>
					<qry:attribute name="cnt" value="number(@cnt)+1"/>
					<qry:if test="@cnt=20">
						<qry:then>
							<qry:element name="ROW">
								<qry:attribute name="oi_pedido_lf" value="../@ois"/>
							</qry:element>
							<qry:attribute name="ois" value="''"/>
							<qry:attribute name="sep" value="''"/>
							<qry:attribute name="cnt" value="''"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="qry_tipo_tarea">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				LEG03_TAREAS.oi_estado_tarea,
				LEG03_TAREAS.oi_tarea,
				LEG35_TIPOS_TAREAS.c_tipo_tarea				
			  
			FROM
				LEG35_TIPOS_TAREAS,
				LEG03_TAREAS
			
			JOIN
				LEG03_TAREAS.oi_tipo_tarea INNER LEG35_TIPOS_TAREAS.oi_tipo_tarea 
			
			WHERE
			  LEG03_TAREAS.oi_tarea = {$SOURCE/@oi_tarea}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="c_tipo_tarea" value="$r/@c_tipo_tarea"/>
						<qry:attribute name="oi_estado_tarea" value="$r/@oi_estado_tarea"/>
						<qry:attribute name="oi_tarea" value="$r/@oi_tarea"/>
						<qry:attribute name="oi_estado_tarea_nuevo" value="'4'"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_pedido_lf" doc="PLF">
				<qry:xquery>
					for $r in SQL('
			
			SELECT 
			LEG61_PEDIDOS_LF.oi_tarea, 
			LEG61_PEDIDOS_LF.c_estado
			
			FROM 
			LEG61_PEDIDOS_LF 
			
			WHERE 
			LEG61_PEDIDOS_LF.oi_pedido_lf in ({%=$PLF/@oi_pedido_lf%})
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@oi_tarea = ''">
						<qry:then>
							<qry:element name="ROW">
								<qry:attribute name="oi_estado_tarea_nuevo" value="'1'"/>
							</qry:element>
						</qry:then>
						<qry:else>
							<qry:insert-select name="qry_tipo_tarea" doc-path="$r"/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DATOS_TAREA"/>
		<doc:define name="PARAM_DATOS_TAREA"/>
		<doc:define name="NIGERIA">
			<RESULT/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="open_externo">
			<flow:open-form doc-path="#SOURCE:" mode="LIST_EDIT" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.form"/>
		</flow:action>
		<flow:action name="aprobar_plf">
			<flow:open-form form-class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
		<flow:action name="aprobar_plf_bak">
			<flow:open-form doc-path="#SOURCE:" mode="APROBAR" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.form"/>
		</flow:action>
		<flow:action name="help_aprobar">
			<flow:log text-path="#SOURCE:" text="LUCIANO_ID"/>
			<flow:open-form mode="APROBAR" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.OBS_ESTADOS_PLF.form" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="help_rechazar">
			<flow:log text-path="#SOURCE:" text="LUCIANO_ID"/>
			<flow:open-form mode="RECHAZAR" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.OBS_ESTADOS_PLF.form" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="help_anular">
			<flow:open-form mode="ANULAR" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.OBS_ESTADOS_PLF.form" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:group Name="PEDIDO_LF">
		<flow:form name="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.form:LIST_EDIT" mode="LIST_EDIT" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.form" doc="SOURCE">
			<flow:action name="on-show">
				<flow:call-action action="info-carpeta"/>
				<flow:call-action action="load-list"/>
			</flow:action>
			<flow:action name="info-carpeta">
				<doc:load-qry output-doc="INFO_CARPETA" input-doc-path="#SOURCE:" qry="INFO_CARPETA"/>
			</flow:action>
			<flow:action name="load-list">
				<doc:load-qry input-doc-path="#SOURCE:" qry="PLF_CARPETA" output-doc="PEDIDOS_LF"/>
				<flow:attach-doc doc-path="#PEDIDOS_LF:" attach-id="RS"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object doc="DDO_PLF" id-path="#FORM:ctrl[@id='LIST']/@xval" class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF"/>
			</flow:action>
			<flow:action name="SHOW">
				<flow:call-action action="load-DDO"/>
				<flow:open-form doc-path="#DDO_PLF:" mode="SHOW" form-class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF.form"/>
			</flow:action>
			<flow:action name="ADD">
				<flow:exec-method out-type="Nomad.NSystem.Object" class="NucleusRH.Base.Legales.PedidosLiqFinal.PEDIDO_LF" out-doc="DDO_PLF" method="NEW_PEDIDO_LF">
					<flow:param attr-path="#SOURCE:@oi_carpeta" type="Nomad.NSystem.String" name="oi_carpeta" mode="in"/>
				</flow:exec-method>
				<flow:call-action action="ADD-ERROR" else="OPEN-NEW" eq="0" if="#DDO_PLF:@n_monto_total"/>
			</flow:action>
			<flow:action name="ADD-ERROR">
				<flow:call-action action="load-list"/>
