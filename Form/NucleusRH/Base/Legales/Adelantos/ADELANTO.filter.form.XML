<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER-MASIVA" extends="NucleusRH.Base.Legales.Adelantos.ADELANTO.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Legales.Adelantos.ADELANTO">
	<form:Help>
		<form:Help-title text="Adelantos" name="TITLE"/>
		<form:Help-descr text="Adelantos" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Adelantos" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns name="main_columnsADELANTO">
			<form:Column name="main_columnsADELANTOcolumn1">
				<form:Blank name="blank"/>
				<form:ComboBox visible="FILTER|FILTER-MASIVA" queryname2="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_CARPETA" xsize="30" mode="QRY" label="Carpeta" nvalue="#FILTERDATA:@oi_carpeta" name="oi_carpeta"/>
				<form:ComboBox visible="FILTER|FILTER-MASIVA" nvalue="#FILTERDATA:@oi_clasif_sujeto" queryname1="NucleusRH.Base.Legales.Sujetos.CLASIF_SUJETO.INFO_ADELANTO" label="Responsable" name="oi_clasif_sujeto" xsize="40" mode="QRY"/>
				<form:ComboBox visible="FILTER|FILTER-MASIVA" queryname1="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_UBICACION" queryname2="NucleusRH.Base.Legales.Seguridad.LEG_SEG.INFO_EMPRESA" label="Sucursal Solicitante" xsize="30" mode="QRY" required="0" nvalue="#FILTERDATA:@oi_ubicacion" name="oi_ubicacion"/>
				<form:ComboBox visible="FILTER" queryname1="NucleusRH.Base.Legales.EstadosAnt.ESTADO_ANT.INFO" xsize="40" mode="QRY" label="Estado Anticipo" nvalue="#FILTERDATA:@oi_estado_ant" name="oi_estado_ant"/>
				<form:ComboBox visible="FILTER" queryname1="NucleusRH.Base.Legales.TiposAdelanto.TIPO_ADELANTO.INFO" xsize="40" mode="QRY" required="0" label="Tipo Adelanto" nvalue="#FILTERDATA:@oi_tipo_adelanto" name="oi_tipo_adelanto"/>
				<form:Rower visible="FILTER|FILTER-MASIVA" label="Fecha Desde" name="rwerfechas" separation="5">
					<form:DateTime nvalue="#FILTERDATA:@f_adelanto_d" name="f_adelanto_d" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label label="Fecha Hasta" name="sd"/>
					<form:DateTime nvalue="#FILTERDATA:@f_adelanto_h" name="f_adelanto_h" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER-MASIVA" name="ra1">
			<form:Row name="r1">
				<form:Button name="FILTER-MASIVA" label="Filtrar" startvalidate="1" img="ok" visible="FILTER-MASIVA">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Button name="BACK-MASIVA" label="Volver" img="back" visible="FILTER-MASIVA">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
