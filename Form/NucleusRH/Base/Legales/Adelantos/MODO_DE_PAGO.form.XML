<form:Form xmlns:form="nomad_engine.form" extends="nomad.childGrid.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Legales.Adelantos.MODO_DE_PAGO">
	<form:Help>
		<form:Help-title text="Modos de Pago" name="TITLE"/>
		<form:Help-descr name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Modos de Pago" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Modos de Pago" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Modos de Pago" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Modos de Pago" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
