	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" policy="NucleusRH/Base/Legales/Adelantos/MODO_DE_PAGO/NEW" visible="NEW" descrip="Aceptar" img="ok" label="Aceptar">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" policy="NucleusRH/Base/Legales/Adelantos/MODO_DE_PAGO/DELETE" visible="NEW" descrip="Cancelar" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
