<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO_DIG.guia" extends="Nomad.combo.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Legales.Documentos.DOCUMENTO"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t.oi_doc_digital as ID, 
					t.oi_doc_digital as CODE, 
					t.o_doc_digital as TEXT
				FROM 
					LEG37_DOC_DIGITAL as t
				ORDER BY 
					CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@CODE+'-'+$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
