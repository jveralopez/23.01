<form:Form xmlns:form="nomad_engine.form" default_mode="NEW" extends="NucleusRH.Base.Legales.Documentos.DOCUMENTO.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO">
	<form:Help>
		<form:Help-title text="Documentos Digitalesas" name="TITLE"/>
		<form:Help-descr name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Documentos Digitales" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Documentos Digitales" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Documentos Digitales" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Documentos Digitales" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsDOCUMENTO">
			<form:Column name="main_columnsDOCUMENTOcolumn1">
				<form:File source="0" required="1" nvalue="#source:oi_doc_digital/@value" name="oi_doc_digital" label="Documento Digital" enabled="NEW|EDIT" class="NucleusRH.Base.Legales.DocumentosDigitales.HEAD">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="search" label="sbHelper" name="sbHelper">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
						<form:SButton visible="EDIT|NEW" img="eliminate" label="sbClean" name="sbClean">
							<form:Event action="CLEAR_VALUES" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
				<form:ComboBox queryname1="NucleusRH.Base.Legales.Carpetas.CARPETA.INFO_POREMPRESA" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" enabled="0" xsize="30" mode="QRY" required="1" label="Carpeta" nvalue="#source:oi_carpeta/@value" name="oi_carpeta"/>
				<form:ComboBox enabled="0" queryname1="NucleusRH.Base.Legales.Tareas.TAREA.INFO" xsize="40" mode="QRY" required="1" label="Tarea" nvalue="#source:oi_tarea/@value" name="oi_tarea"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_doc_dig" name="d_doc_dig"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha" nvalue="#source:@f_doc_dig" name="f_doc_dig">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaci&#243;n" nvalue="#source:@o_doc_dig" name="o_doc_dig"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<!--form:Event action="ListClick" name="OnClick" runat="client"/>
	<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/-->
			<form:LVColumns>
				<form:LVColumn type="string" align="left" sorteable="1" width="50px" label="Documento Digital" attrname="oi_doc_digital" name="oi_doc_digital"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Carpeta" attrname="oi_carpeta" name="oi_carpeta"/>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Tarea" attrname="oi_tarea" name="oi_tarea"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_doc_dig" name="d_doc_dig"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha" attrname="f_doc_dig" name="f_doc_dig"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/Legales/Documentos/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Legales/Documentos/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/Legales/Documentos/DELETE" visible="SHOW|LIST|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Legales/Documentos/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
				<form:Button order-change="POST:ADMIN" visible="SHOW|LIST" img="back" policy="NucleusRH/Base/Legales/Documentos/DELETE" descrip="Volver" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function onload()
{
	if(Ctrl('main').GetMode() == "NEW")
		Ctrl('f_doc_dig').SetXValue(datetime2str(Now()));
}
	</form:Scripts>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
