				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_personal_emp as oi_personal_emp, 
					t1.oi_personal_emp as B_oi_personal_emp, 
					t1.e_numero_legajo as B_e_numero_legajo, 
					SEC.policy, 
					t1.e_numero_legajo as CODE, 
					PER01_PERSONAL.d_ape_y_nom as TEXT, 
					t1.oi_empresa as oi_empresa, 
					t1.oi_personal as oi_personal 
				FROM 
					MED04_PERSONAL as t0,
					PER02_PERSONAL_EMP as t1,
					NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC, 
					PER01_PERSONAL 
				JOIN 
					t0.oi_personal_emp RIGHT OUTER t1.oi_personal_emp,
					t1.oi_personal_emp LEFT OUTER SEC.id,
					t1.oi_personal LEFT OUTER PER01_PERSONAL.oi_personal 
				WHERE                                                                            
					t1.oi_personal_emp in ({%=string(#SOURCE:ROWS/ROW/@id) %})
				ORDER BY 
					oi_personal_emp asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="ID-MED04_PERSONAL" value="$r/@oi_personal_emp"/>
						<qry:attribute name="id" value="$r/@B_oi_personal_emp"/>
						<qry:attribute name="e_numero_legajo" value="$r/@B_e_numero_legajo"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_personal!=''">
							<qry:then>
								<qry:element name="oi_personal">
									<qry:attribute name="OI_FIND" value="$r/@oi_personal"/>
									<qry:insert-select name="NucleusRH.Base.Personal.Legajo.PERSONAL.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_personal" value="'['+oi_personal/ROW/@COD+'] '+oi_personal/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:insert-select doc-path="." name="FIND-PER-DESCR"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="FIND-PER-DESCR">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.e_numero_legajo AS COD, 
				PER01_PERSONAL.d_ape_y_nom AS DES 
				FROM 
				PER02_PERSONAL_EMP, PER01_PERSONAL			
				JOIN PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE PER02_PERSONAL_EMP.oi_personal_emp ={#PARAM:@id}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="'[' + $r/@COD + '] ' + $r/@DES" name="descr"/>
					<qry:attribute value="$r/@DES" name="text"/>
				</qry:out>
			</qry:select>
