					<qry:insert-select doc-path="#SOURCE:PERSONAL_EMP" name="RS1"/>
					<qry:attribute value="'0'" name="oi_horario"/>
					<qry:attribute value="'0'" name="oi_escuadra"/>
					<qry:insert-select doc-path="#SOURCE:PERSONAL_EMP/HORARIOSPERS" name="RS2"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT
				PER01_PERSONAL.d_apellido,
				PER01_PERSONAL.d_nombres,
				PER01_PERSONAL.d_ape_y_nom,
				PER01_PERSONAL.oi_tipo_documento,
				PER01_PERSONAL.c_nro_documento,
				PER01_PERSONAL.c_personal,
				PER01_PERSONAL.c_sexo,
				PER01_PERSONAL.oi_foto
			FROM
				PER01_PERSONAL, PER02_PERSONAL_EMP
			JOIN
				PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
			WHERE
				PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@id} 
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@d_apellido" name="d_apellido"/>
					<qry:attribute value="$r/@d_nombres" name="d_nombres"/>
					<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
					<qry:attribute value="$r/@oi_tipo_documento" name="oi_tipo_documento"/>
					<qry:attribute value="$r/@c_nro_documento" name="c_nro_documento"/>
					<qry:attribute value="$r/@c_personal" name="c_personal"/>
					<qry:attribute value="$r/@c_sexo" name="c_sexo"/>
					<qry:attribute value="$r/@oi_foto" name="oi_foto"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:HORARIOPERS[@f_fechaInicio&lt;=String(now()) AND (@f_fechafin&gt;=String(now()) OR @f_fechafin='')]
				</qry:xquery>
				<qry:out>
					<qry:attribute value="iif($r/oi_horario/@value!='',$r/oi_horario/@value,'0')" name="oi_horario"/>
					<qry:attribute value="iif($r/oi_escuadra/@value!='',$r/oi_escuadra/@value,'0')" name="oi_escuadra"/>
					<qry:attribute value="iif($r/@f_fechaInicio!='',$r/@f_fechaInicio,'0')" name="f_fechaInicio"/>
				</qry:out>
			</qry:select>
		</qry:define>
