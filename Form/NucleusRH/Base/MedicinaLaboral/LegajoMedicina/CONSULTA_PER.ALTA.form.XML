<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.MedicinaLaboral.LegajoMedicina.CONSULTA_PER.ALTA.form" default_mode="SHOW" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Informar Fecha de Alta" name="GEN_NEW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsLICENCIA_PER">
			<form:Column name="main_columnsCONSULTA_PERcolumn1">
				<form:NumberBox visible="0" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="OID Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
				<form:DateTime pattern="YYYYMMDDHHMM" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha-Hora Consulta" nvalue="#source:@f_fechahora_cons" name="f_fechahora_cons">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.MotivosConsulta.MOTIVO_CONSULTA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Motivo Consulta" nvalue="#source:oi_motivo_consulta/@value" name="oi_motivo_consulta"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Baja" nvalue="#source:@f_baja" name="f_baja">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Prevista Alta" nvalue="#source:@f_prev_alta" name="f_prev_alta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.Enfermedades.ENFERMEDAD.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Enfermedad" nvalue="#source:oi_enfermedad/@value" name="oi_enfermedad"/>
				<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Pr&#243;xima Consulta" nvalue="#source:@f_prox_consulta" name="f_prox_consulta">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_consulta_per" name="o_consulta_per"/>
				<form:Line width="100%" name="linea1"/>
				<form:DateTime pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha de Alta" nvalue="#source:@f_alta" name="f_alta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
					<form:Event action="f_alta_validate" name="onValidate" runat="client"/>
				</form:DateTime>
				<form:NumberBox required="0" mask="###.###.##0" xsize="12" label="D&#237;as Perdidos" nvalue="#source:@e_dias_perdidos" name="e_dias_perdidos"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Aceptar la Fecha de Interrupcion" img="OK" name="ACCEPT" visible="SHOW" label="Aceptar">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la Operacion" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function f_alta_validate(myThis)
{
	if (myThis.GetXValue() &lt; Ctrl('f_baja').GetXValue())
	{
		myThis.SetError("La fecha de Alta debe ser mayor o igual a la fecha de Baja.");
		return false;
	}
	return true;
}
	</form:Scripts>
</form:Form>
