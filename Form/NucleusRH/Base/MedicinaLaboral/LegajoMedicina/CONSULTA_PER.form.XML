}

 function validarResultado()
{
	this.processResult = function(XML)
	{                 
		var myRESULT=new NomadXML(XML);   
	
		Ctrl("valid").SetXValue(myRESULT.GetAttr("valid"));
		Ctrl("alert").SetXValue(myRESULT.GetAttr("alert"));
	}
}

function ChangeSelect()
{
	if(Ctrl("LIST").GetSelectAttrValue("licencia")=="1")
	{
		if(Ctrl("LIST").GetSelectAttrValue("f_alta")!="")	
			CtrlEnabled("ALTA", false);	
		else
			CtrlEnabled("ALTA", true);  
	}
	else
		CtrlEnabled("ALTA", false);
}        

function ValDel(me)
{		                          
	if(Ctrl("oi_licencia").GetXValue() != "")	
	{
		var licencia;				
 		np = new NomadProxy("", ut);
 		var nSQL = np.SQLService();   
 		licencia = nSQL.GetOBJ(Ctrl("main").getResource("QRY_LICENCIA"), "&lt;PARAM oi_licencia=\""+Ctrl("oi_licencia").GetXValue()+"\" /&gt;"); 		
		
		if (!confirm("El registro se encuentra asociado con una licencia en el m&#243;dulo de Personal con fecha de inicio: " + licencia.f_inicio +" y fecha de fin "+ licencia.f_fin + ". Confirma la eliminaci&#243;n?"))
		{
			me.SetError('La operaci&#243;n no ha sido completada');
			return false;
		}
		Ctrl("listdels").AddRow().SetAttr("id",(Ctrl("oi_licencia").GetXValue()));
	}
	return true;	
}

function CalcularDias()
{
 	if (Ctrl('f_alta').GetXValue() != "" &amp;&amp; Ctrl('f_baja').GetXValue() != "")
 	{ 		
 		if (Ctrl('f_alta').GetXValue() &gt;= Ctrl('f_baja').GetXValue())
 		{
 			Ctrl('e_dias_perdidos').SetTypedValue(DiffDays(Ctrl('f_alta').TypedValue(), Ctrl('f_baja').TypedValue()));
 		} 
 		else
 			alert("La fecha de alta del empleado debe ser mayor a la fecha de baja");
 			return false; 
  }
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_licencia=&quot;171&quot; /&gt;" name="QRY_LICENCIA">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_LICEN_PER.f_inicio, 
					PER02_LICEN_PER.f_fin,
					PER02_LICEN_PER.o_licencia_per
				FROM 
					PER02_LICEN_PER
				WHERE 
					PER02_LICEN_PER.oi_licencia_per = {#SOURCE:@oi_licencia}
		 ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="format_date($r/@f_inicio, 'dd/mm/yyyy')" name="f_inicio"/>
					<qry:attribute value="format_date($r/@f_fin, 'dd/mm/yyyy')" name="f_fin"/>
					<qry:attribute value="$r/@o_licencia_per" name="o_licencia_per"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event name="onvalidate" action="ValModif" runat="client"/>
</form:Form>
