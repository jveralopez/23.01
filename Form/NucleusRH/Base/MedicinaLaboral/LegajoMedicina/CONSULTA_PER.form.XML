	<form:Scripts>
		function LoadForm()
{             
 	if(Ctrl("LIST"))
		ChangeSelect();
	else
	{		
		
		if (Ctrl('main').GetMode()!="NEW")
		{  
			Ctrl('licencia').SetXValue("0");
			if(Ctrl('oi_licencia').GetXValue() != ""  &amp;&amp; Ctrl('oi_licencia').GetXValue() != "0")
			{
				Ctrl('licencia').SetXValue("1");
				CtrlEnabled("f_fechahora_cons", false);			
				CtrlEnabled("f_prev_alta", false);
				if(Ctrl('f_alta').GetXValue() != "")
					CtrlEnabled("ALTA", false);
				else
					CtrlEnabled("ALTA", true);
			}
			else
				CtrlEnabled("ALTA", false);				
		}
		
	if(Ctrl('f_alta'))
		Ctrl('f_alta_med').SetXValue(Ctrl('f_alta').GetXValue());
 	if(Ctrl('f_baja'))
		Ctrl('f_baja_med').SetXValue(Ctrl('f_baja').GetXValue());
	} 
}
           
