<form:Form xmlns:form="nomad_engine.form" default_mode="NEW" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.MedicinaLaboral.ConsultasMedicas.CONSULTA">
	<form:Title width="90%">
		<form:Label label="Registrar Consulta M&#233;dica" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsCONSULTAS">
			<form:Column separation="2" valign="top" align="center" name="main_columnsCONSULTAcolumn1">
				<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="30" mode="QRY" required="1" enabled="NEW|EDIT" label="Empresa - Legajo" nvalue="#source:@oi_personal_emp" name="oi_personal_emp"/>
				<form:CheckBox required="1" label="Generar Licencia?" name="licencia"/>
				<form:DateTime pattern="YYYYMMDDHHMM" required="1" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha-Hora Consulta" nvalue="#source:@f_fechahora_cons" name="f_fechahora_cons">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.MotivosConsulta.MOTIVO_CONSULTA.INFO" xsize="40" mode="QRY" required="1" enabled="NEW|EDIT" label="Motivo Consulta" nvalue="#source:@oi_motivo_consulta" name="oi_motivo_consulta"/>
				<form:Hidden name="auxiliar_fechahora" nvalue="#source:@auxiliar_fechahora"/>
			</form:Column>
		</form:Columns>
		<form:Tab name="tab">
			<form:Panels>
				<form:Panel label="Consulta" name="consulta">
					<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="colsconsulta">
						<form:Column name="colconsulta" separation="2" align="center" valign="top">
							<form:DateTime pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha Prevista Alta" nvalue="#source:@f_prev_alta" name="f_prev_alta">
								<form:SButtons>
									<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
								<form:Event name="onchange" action="CalcularDias" runat="client"/>
							</form:DateTime>
							<form:DateTime label="Fecha Baja Empleado" pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" nvalue="#source:@f_baja" name="f_baja">
								<form:SButtons>
									<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
								<form:Event name="onchange" action="CalcularDias" runat="client"/>
							</form:DateTime>
							<form:DateTime label="Fecha Alta Empleado" pattern="YYYYMMDD" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" nvalue="#source:@f_alta" name="f_alta">
								<form:SButtons>
									<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
								<form:Event name="onchange" action="CalcularDias" runat="client"/>
							</form:DateTime>
							<form:NumberBox required="0" enabled="0" mask="###.###.##0" xsize="12" label="D&#237;as Perdidos" nvalue="#source:@e_dias_perdidos" name="e_dias_perdidos"/>
							<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.Enfermedades.ENFERMEDAD.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Enfermedad" nvalue="#source:@oi_enfermedad" name="oi_enfermedad"/>
							<form:DateTime label="Fecha-Hora Pr&#243;xima Consulta" pattern="YYYYMMDDHHMM" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" nvalue="#source:@f_prox_consulta" name="f_prox_consulta">
								<form:SButtons>
									<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:DateTime>
							<form:CheckBox label="Enviar mail al legajo" enabled="NEW|EDIT" nvalue="#source:@l_envio_mail" name="l_envio_mail"/>
							<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_consulta_per" name="o_consulta_per"/>
						</form:Column>
					</form:Columns>
				</form:Panel>
				<form:Panel label="Visita" name="visita">
					<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="colsvisita">
						<form:Column name="colvisita" separation="2" align="center" valign="top">
							<form:DateTime pattern="YYYYMMDDHHMM" required="0" enabled="NEW|EDIT" mask="dd/mm/yyyy" label="Fecha-Hora Visita" nvalue="#source:@f_fechahora_visita" name="f_fechahora_visita">
								<form:SButtons>
									<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:DateTime>
							<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.Medicos.MEDICO.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="M&#233;dico" nvalue="#source:@oi_medico" name="oi_medico"/>
							<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Domicilio Atenci&#243;n" nvalue="#source:@d_domicilio" name="d_domicilio"/>
							<form:ComboBox queryname1="NucleusRH.Base.Personal.Tipos_Domicilio.TIPO_DOMICILIO.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Tipo Domicilio" nvalue="#source:@oi_tipo_domicilio" name="oi_tipo_domicilio"/>
							<form:ComboBox queryname1="NucleusRH.Base.MedicinaLaboral.LugaresAtencion.LUGAR_ATENCION.INFO" xsize="40" mode="QRY" required="0" enabled="NEW|EDIT" label="Lugar Atenci&#243;n" nvalue="#source:@oi_lugar_atencion" name="oi_lugar_atencion"/>
							<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Medicaci&#243;n" nvalue="#source:@o_medicacion" name="o_medicacion"/>
							<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaciones" nvalue="#source:@o_detalle_cons" name="o_detalle_cons"/>
						</form:Column>
					</form:Columns>
				</form:Panel>
			</form:Panels>
		</form:Tab>
		<form:Hidden visible="" name="licvalue"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button descrip="Guarda los cambios realizados" label="Guardar" startvalidate="1" visible="NEW|EDIT" img="save" name="SAVE">
					<form:Event action="ValDates" name="onclick" runat="client"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" visible="NEW|EDIT|DELETE" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SetNow()
{
    momentoActual = new Date();                              
    return momentoActual;
}

function CARGARFECHAHORA()
{ 
 	if(Ctrl('auxiliar_fechahora').GetXValue() == "1")
 	{
 		 Ctrl('f_fechahora_cons').SetTypedValue(SetNow());
 	}
}

function ValDates()
{
	
	if(Ctrl('f_prox_consulta').GetXValue() == "" &amp;&amp;  Ctrl('l_envio_mail').GetXValue() == "1") {
		alert("No se puede seleccionar 'Env&#237;o de mail' si no carga una fecha de p&#243;xima consulta");
		return false;
	}
				
	Ctrl('licvalue').SetXValue("0");
	if(Ctrl('licencia'))
	{
		if(Ctrl('licencia').GetXValue() != "1")
		{
			if (confirm("La licencia correspondiente a la consulta no ser&#225; generada. &#191;Desea continuar de todas maneras?"))
				Ctrl('licvalue').SetXValue("0");
			else
				return false;
		}
		else
		{			
			Ctrl('licvalue').SetXValue("1");
			if(Ctrl("f_baja").GetXValue() == "")
			{
				alert("No se ha ingresado la fecha de baja");
				return false;
			}
			if (Ctrl("f_alta").GetXValue() == "" &amp;&amp; Ctrl("f_prev_alta").GetXValue() == "")
			{
		 		alert("No se ha ingresado la fecha prevista de alta o fecha de alta");
		 		return false;
			}
		}
	}

	//se hizo para validar que si se carga algun campo de la solapa visita si o si debe estar cargado el campo f_fechahora_visita
  if(Ctrl('f_fechahora_visita').GetXValue() == "")
  {	
  	if(	 Ctrl('oi_medico').GetXValue() != "" 
  		|| Ctrl('d_domicilio').GetXValue() != ""
  		|| Ctrl('oi_tipo_domicilio').GetXValue() != ""
  		|| Ctrl('oi_lugar_atencion').GetXValue() != ""
  		|| Ctrl('o_medicacion').GetXValue() != ""
  		|| Ctrl('o_detalle_cons').GetXValue() != "")
  	{ 
  		if (confirm("No se ingres&#243; la fecha y hora de la visita. &#191;Desea ingresar la fecha y hora actual?"))
			{
				Ctrl('f_fechahora_visita').SetTypedValue(SetNow());
				return false; 
			}
			else
			{
				return false;
			}	
  	}
	}
	
	Ctrl('main').DoEvent("guardar");
} 

function CalcularDias()
{  
  var alta = "";
  var baja = "";
  
  if(Ctrl('f_prev_alta').GetXValue() != "")
  	alta = Ctrl('f_prev_alta').TypedValue();  
  if(Ctrl('f_alta').GetXValue() != "")
  	alta = Ctrl('f_alta').TypedValue();
  if(Ctrl('f_baja').GetXValue() != "")  
  	baja = Ctrl('f_baja').TypedValue();  
 	
 	if (baja != "" &amp;&amp; alta != "")
 	{ 		
 		if (alta &gt;= baja)
 		{
 			Ctrl('e_dias_perdidos').SetTypedValue(DiffDays(alta, baja));
 		}
 		else
 			alert("La fecha de alta del empleado debe ser mayor a la fecha de baja");
 			return false; 
 	}
 	else
 		Ctrl('e_dias_perdidos').SetXValue("");
}
	</form:Scripts>
	<form:Event action="CARGARFECHAHORA" name="OnLoad" runat="client"/>
	<form:Event name="guardar" action="SAVE" runat="server"/>
</form:Form>
