<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" default_action="initialize" name="NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form parent-doc="PARENTSOURCE" name="NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes.filter.form:FILTER" form-class="NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes.filter.form" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.MedicinaLaboral.Reportes.VencimientosExamenes" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="RepVencimientoExamenes" class="NucleusRH.Base.MedicinaLaboral.LegajoMedicina.PERSONAL_EMP" out-attr-path="#BATCHDOC:@batch-id" priority="1">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="param"/>
			</flow:exec-method>
			<doc:set-attribute from-value="002 - Vencimientos de Ex&#225;menes" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
