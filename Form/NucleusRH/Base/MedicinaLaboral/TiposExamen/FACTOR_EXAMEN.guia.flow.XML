<flow:flow name="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.flow" extends="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="Flow guia para NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN"/>
	<flow:main doc="SOURCE">
		<flow:action name="HELP">
			<doc:assign-value from-path="#SOURCE:" to-doc="PARAMIN"/>
			<doc:load-qry qry="HELP" output-doc="RS" input-doc-path="#SOURCE:"/>
			<flow:call-action action="OPEN-GUIA"/>
		</flow:action>
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#RS:" mode="SHOW" form-class="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_factor_examen as ID, 
				t.c_factor_examen as CODE, 
				t.d_factor_examen as TEXT				
				FROM MED10_FACTORES as t 
				WHERE t.oi_factor_examen={#SOURCE:helper-mess/@ID} 
				AND t.oi_examen = {#SOURCE:helper-mess/@oi_examen}  
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_examen=&quot;1&quot; text=&quot;&quot; id=&quot;&quot; code=&quot;01&quot; /&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_factor_examen as ID, 
				t.c_factor_examen as CODE, 
				t.d_factor_examen as TEXT				
				FROM MED10_FACTORES as t 
				WHERE t.c_factor_examen={#SOURCE:helper-mess/@code} 
				AND t.oi_examen={#SOURCE:helper-mess/@oi_examen}   
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess oi_examen=&quot;2&quot; text=&quot;&quot; id=&quot;&quot; code=&quot;&quot; /&gt;" name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:element name="ROWS">
						<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_factor_examen as ID, 
				t.c_factor_examen as CODE, 
				t.d_factor_examen as TEXT 				
				FROM MED10_FACTORES as t 
				WHERE  t.oi_examen = {#SOURCE:helper-mess/@oi_examen}   
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="PRELOAD">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="HM"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:helper-mess" name="RS2"/>
					<qry:insert-select doc-path="." name="RS3"/>
					<qry:element name="ROWS">
						<qry:insert-select doc-path=".." name="RS1"/>
					</qry:element>
					<qry:attribute value="substring(#HM:@TEXT,1+string_length(./@TEXT))" name="FILTER"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS3">
				<qry:xquery>
					for $r in sql('SELECT t.oi_examen as ID, t.c_examen as CODE, t.d_examen as TEXT, t.oi_tipo_examen as PID FROM MED10_EXAMENES as t WHERE t.oi_examen={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute type="Nomad.NSystem.Int" value="$r/@PID" name="PID"/>
					<qry:insert-select doc-path="." name="RS4"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS4">
				<qry:xquery>
					for $r in sql('SELECT t.oi_tipo_examen as ID, t.c_tipo_examen as CODE, t.d_tipo_examen as TEXT, SEC.policy  FROM MED10_TIPOS_EXAMEN as t, NMD_SECURITY(class=\'NucleusRH.Base.MedicinaLaboral.TiposExamen.TIPO_EXAMEN\') as SEC JOIN t.oi_tipo_examen LEFT OUTER SEC.id  WHERE t.oi_tipo_examen={#SOURCE:@PID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CODE+'-'+#SOURCE:@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT+'-'+#SOURCE:@TEXT" name="text"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('select t.oi_examen from MED10_FACTORES as t where t.oi_factor_examen={#SOURCE:@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_examen" name="PARENTID"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('SELECT t.oi_factor_examen as ID, t.c_factor_examen as CODE, t.d_factor_examen as TEXT, t.oi_examen as PID FROM MED10_FACTORES as t WHERE  t.oi_examen={#SOURCE:@PARENTID} ORDER BY CODE asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code1"/>
						<qry:attribute value="$r/@TEXT" name="text1"/>
						<qry:attribute value="#SOURCE:@CODE+'-'+$r/@CODE" name="code"/>
						<qry:attribute value="#SOURCE:@TEXT+'-'+$r/@TEXT" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.autoform:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.form:SHOW" form-class="NucleusRH.Base.MedicinaLaboral.TiposExamen.FACTOR_EXAMEN.guia.form">
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#RS:ROWS" attach-id="RS"/>
		</flow:action>
		<flow:action name="RELOAD_QUERY">
			<doc:load-qry output-doc="RS" input-doc-path="#SOURCE:" qry="HELP"/>
			<flow:attach-doc doc-path="#RS:ROWS" attach-id="RS"/>
		</flow:action>
	</flow:form>
</flow:flow>
