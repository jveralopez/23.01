<form:Form xmlns:form="nomad_engine.form" name="LISTA_MULTIPLE_CODIGO_COMPLEJO" doc="SOURCE" default_mode="SHOW">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" style="S3 LCol_w" nowrap="1" label="Lista de Selecci&#243;n M&#250;ltiple"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns name="ColumnsHead">
			<form:Column name="ColumnHead">
				<form:Combo name="oi_padre" label="Empresa" required="0" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO">
					<form:Event name="onchange" action="RELOAD_QUERY" runat="server"/>
				</form:Combo>
				<form:Blank name="blnk1"/>
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:Event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
			</form:Column>
		</form:Columns>
		<form:FKInput requiered="1" descr="Seleccion del padre generico" xsize="10" length="30" label="Parent Label" nvalue="#SOURCE:@parentid" name="PARENTID" visible="0">
			<form:STexts>
				<form:SText xsize="40" name="txt1"/>
			</form:STexts>
			<form:Helper name="unknown" help="HELP" x2c="X2C" c2x="C2X">
				<helper-mess text="{PARENTID.Text.1}" id="{PARENTID.XVal}" code="{PARENTID.CVal}"/>
			</form:Helper>
			<form:SButtons>
				<form:SButton img="SEARCH" label="Search" name="SEARCH">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
			<form:Event runat="server" action="RELOAD_QUERY" name="onReceiveData"/>
		</form:FKInput>
		<form:Grid rows="10" allowdel="0" allownew="0" paging="1" doc="ROW" idvalue="#ROW:@ID" name="GRID" nvalue="#SOURCE:FILTRO2/ROWS">
			<form:GColumns>
				<form:GColumn name="Col1">
					<form:CheckBox name="seleccionados" nvalue="#ROW:@check" label="" enabled="" required="0"/>
				</form:GColumn>
				<form:GColumn name="Col2">
					<form:TextBox length="12" enabled="0" note="Codigo" descr="Codigo" ysize="1" xsize="8" label="C&#243;digo" nvalue="#ROW:@CODE" name="CODE"/>
				</form:GColumn>
				<form:GColumn name="Col3">
					<form:TextBox enabled="0" note="Descripcion" descr="Descripcion" ysize="1" xsize="40" length="40" label="Descripci&#243;n" nvalue="#ROW:@TEXT" name="TEXT"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function FilterGrid()
{
	Ctrl("GRID").FilterElements("","");
	if (Ctrl("buscar").GetCValue()!="") Ctrl("GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
}
	</form:Scripts>
</form:Form>
