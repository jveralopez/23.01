<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.QuejasyReclamos.Oficinas.autoflow" name="NucleusRH.Base.QuejasyReclamos.Oficinas">
	<flow:info label="Flow para NucleusRH.Base.QuejasyReclamos.Oficinas"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_oficina as oi_oficina, SEC.policy FROM QYR08_OFICINAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA\') as SEC JOIN t0.oi_oficina LEFT OUTER SEC.id  ORDER BY oi_oficina asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_oficina"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO"/>
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_oficina as oi_oficina, t0.c_oficina as c_oficina, t0.d_oficina as d_oficina, t0.l_inactiva as l_inactiva, SEC.policy, t0.c_oficina as CODE, t0.d_oficina as TEXT, t0.oi_ubicacion as oi_ubicacion FROM QYR08_OFICINAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA\') as SEC JOIN t0.oi_oficina LEFT OUTER SEC.id  ORDER BY oi_oficina asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_oficina"/>
						<qry:attribute name="c_oficina" value="$r/@c_oficina"/>
						<qry:attribute name="d_oficina" value="$r/@d_oficina"/>
						<qry:attribute name="l_inactiva" value="iif($r/@l_inactiva='1','1','0')"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_ubicacion!=''">
							<qry:then>
								<qry:element name="oi_ubicacion">
									<qry:attribute name="OI_FIND" value="$r/@oi_ubicacion"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.UBICACION.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_ubicacion" value="'['+oi_ubicacion/ROW/@COD+'] '+oi_ubicacion/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.filter.autoform"/>
		</flow:action>
	</flow:main>
	<flow:group Name="OFICINA">
		<flow:form extends="FILTER:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.filter.autoform:FILTER" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.filter.autoform" mode="FILTER">
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
				<flow:close-form/>
				<flow:call-action action="FILTER"/>
			</flow:action>
			<flow:action name="inits-DDO">
				<doc:new-object doc="DDO" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.noreg.autoform"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="Load-FILTER">
				<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
			<flow:action name="Save-FILTER">
				<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
		</flow:form>
		<flow:form extends="CLASSROOT:NOREG:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.noreg.autoform:EDIT" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.noreg.autoform" mode="EDIT">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#QRY:ROW[1]/@id" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA" doc="DDO"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="goto-list"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form:SHOW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="DELETE">
				<flow:comment>
					ESTE METODO BORRA LA UNIDAD_ORG CORRESPONDIENTE A LA OFICINA ELIMINADA
				</flow:comment>
				<flow:exec-method method="Borrar_UniOrg" this-doc="DDO"/>
				<doc:load-qry output-doc="QRY" input-doc-path="#FILTERDATA:" qry="FILTER"/>
				<doc:iter-refresh/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form:LIST" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form" mode="LIST">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#FORM:ctrl[@id='LIST']/@xval" class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA" doc="DDO"/>
			</flow:action>
			<flow:action name="save-DDO">
				<doc:save-object class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA" doc="DDO"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<flow:exec-method method="Borrar_UniOrg" this-doc="DDO"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form:EDIT" form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form" mode="EDIT">
			<flow:action name="SAVE">
				<doc:save-object class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA" doc="DDO"/>
				<flow:comment>
					ESTE METODO ACTUALIZA LA UNIDAD_ORG CORRESPONDIENTE A LA OFICINA EDITADA
				</flow:comment>
				<flow:exec-method method="Editar_UniOrg" this-doc="DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
			<flow:action name="DELETE">
				<flow:comment>
					ESTE METODO BORRA LA UNIDAD_ORG CORRESPONDIENTE A LA OFICINA ELIMINADA
				</flow:comment>
				<flow:exec-method method="Borrar_UniOrg" this-doc="DDO"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form" extends="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.form:NEW" mode="NEW">
			<flow:action name="SAVE">
				<flow:comment>
					ESTE METODO CREA LA UNIDAD_ORG CORRESPONDIENTE A LA OFICINA CREADA
				</flow:comment>
				<flow:exec-method method="Crear_UniOrg" this-doc="NEWDDOROOT"/>
				<doc:save-object class="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA" doc="NEWDDOROOT"/>
				<flow:close-form next-action="After-Change"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
