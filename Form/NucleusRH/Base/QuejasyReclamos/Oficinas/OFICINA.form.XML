<form:Form xmlns:form="nomad_engine.form" extends="nomad.rootIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA">
	<form:Help>
		<form:Help-title text="Oficinas de Solucion" name="TITLE"/>
		<form:Help-descr text="Registra las oficinas de solucion" name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Oficinas de Solucion" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Oficinas de Solucion" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Oficinas de Solucion" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Oficinas de Solucion" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsOFICINA">
			<form:Column name="main_columnsOFICINAcolumn1">
				<form:FKInput visible="0" required="0" enabled="NEW|EDIT" xsize="15" length="30" label="Unidad Organizativa" nvalue="#source:oi_unidad_org/@value" name="oi_unidad_org">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="C&#243;digo" nvalue="#source:@c_oficina" name="c_oficina"/>
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Descripci&#243;n" nvalue="#source:@d_oficina" name="d_oficina"/>
				<form:ComboBox queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Organizacion.Empresas.UBICACION.INFO" xsize="30" mode="QRY" required="0" enabled="NEW|EDIT" label="Ubicaci&#243;n" nvalue="#source:oi_ubicacion/@value" name="oi_ubicacion"/>
				<form:CheckBox required="1" enabled="NEW|EDIT" label="Inactiva" nvalue="#source:@l_inactiva" name="l_inactiva"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observacion" nvalue="#source:@o_oficina" name="o_oficina"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Ubicaci&#243;n" attrname="oi_ubicacion" name="oi_ubicacion"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Organizacion.Unidades_Organizativas.UNIDAD_ORG.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Unidad Organizativa" attrname="oi_unidad_org" name="oi_unidad_org"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_oficina" name="c_oficina"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_oficina" name="d_oficina"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" align="center" sorteable="1" width="20px" type="bool" label="Inactiva" attrname="l_inactiva" name="l_inactiva"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusRH/Base/QuejasyReclamos/Oficinas/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/QuejasyReclamos/Oficinas/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusRH/Base/QuejasyReclamos/Oficinas/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/QuejasyReclamos/Oficinas/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
