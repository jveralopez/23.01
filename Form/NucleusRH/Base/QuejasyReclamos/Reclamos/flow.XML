		<qry:define declare="&lt;ROW t_historico=&quot;&quot; n_historico=&quot;&quot; oi_oficina=&quot;19&quot; l_rechazado=&quot;0&quot;/&gt;" name="GetOficina">
			<qry:main doc="PARAM">
				<qry:insert-select name="sql1" doc-path="#PARAM:ROW"/>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
					SELECT 
						QYR08_OFICINAS.c_oficina
					FROM 
						QYR08_OFICINAS
					WHERE 
						QYR08_OFICINAS.oi_oficina = {#PARAM:@oi_oficina}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="c_oficina" value="'OFI:'+$r/@c_oficina"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
