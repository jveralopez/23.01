<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.QuejasyReclamos.Reclamos.RECLAMO.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.QuejasyReclamos.Reclamos.RECLAMO">
	<form:Help>
		<form:Help-title text="Reclamos" name="TITLE"/>
		<form:Help-descr text="En esta tabla se guardan todos los reclamos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" style="S3 LCol_w" label="Filtrar Reclamos" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER">
					<form:Event action="setFechas" runat="client" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/FILTER"/>
					</form:Policies>
				</form:Button>
				<form:Button label="Iniciar Nuevo Reclamo" name="ADD" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/ADD">
					<form:Event action="NEW_REC" runat="client" name="onclick"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/ADD/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/ADD"/>
					</form:Policies>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Center>
		<form:Columns name="columnas">
			<form:Column name="col2" separation="2" align="center" valign="top">
				<form:TextBox nvalue="#FILTER:@oi_reclamo" label="N&#176; Reclamo" name="oi_reclamo"/>
				<form:ComboBox queryname1="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA.INFO" label="Tipo de asunto" xsize="40" mode="QRY" nvalue="#FILTER:@oi_tipo_problema" name="oi_tipo_problema"/>
				<form:DateTime pattern="YYYYMMDD" label="Fecha desde" name="desde" descr="Fecha de Nacimiento." mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="" descrip="Fecha de Nacimiento." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDD" label="Fecha Hasta" name="hasta" descr="Fecha de Nacimiento." mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton visible="" descrip="Fecha de Nacimiento." img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox nvalue="#FILTER:@c_asunto" ysize="1" xsize="30" length="30" label="Asunto" name="c_asunto"/>
				<form:TextBox nvalue="#FILTER:@t_reclamo" length="4000" name="t_reclamo" label="Descripci&#243;n" ysize="8" xsize="50"/>
				<form:ComboBox nvalue="#FILTER:@d_usuario" label="Usuario de Carga" queryname1="Nomad.Base.Login.Entidades.ENTIDAD.INFO" mode="QRY" xsize="40" name="d_usuario">
					<options/>
				</form:ComboBox>
				<form:ComboBox label="Sistema - M&#243;dulo" queryname2="NucleusRH.Base.QuejasyReclamos.Sistemas.SISTEMA.INFO" queryname1="NucleusRH.Base.QuejasyReclamos.Sistemas.MODULO.INFO" xsize="30" mode="QRY" required="0" nvalue="#FILTER:@oi_modulo" name="oi_modulo"/>
				<form:ComboBox nvalue="#FILTER:@n_criticidad" xsize="40" mode="OPT" label="Criticidad" name="n_criticidad">
					<options>
						<option text="-" value="0"/>
						<option text="Muy Baja" value="1"/>
						<option text="Baja" value="2"/>
						<option text="Normal" value="3"/>
						<option text="Alta" value="4"/>
						<option text="Muy Alta" value="5"/>
					</options>
				</form:ComboBox>
				<form:ComboBox nvalue="#FILTER:@c_estado" xsize="40" mode="OPT" label="Estado" name="c_estado">
					<options>
						<option text="A Clasificar" value="CLA"/>
						<option text="An&#225;lisis de Resoluci&#243;n" value="RES"/>
						<option text="Derivado" value="DER"/>
						<option text="En espera de conformidad" value="CON"/>
					</options>
				</form:ComboBox>
				<form:Hidden nvalue="#CLASE:@user" name="user"/>
				<form:Hidden name="f_desde" nvalue="#FILTER:@f_desde"/>
				<form:Hidden name="f_hasta" nvalue="#FILTER:@f_hasta"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function NEW_REC () {
	openNewFlow("NucleusRH.Base.QuejasyReclamos.Workflow.Reclamo.autoflow","NEW-WF","&lt;DATA d_usuario=\""+Ctrl('user').GetXValue()+"\" Etapa=\"Inicial\" WF=\""+GetProxy().AppName()+".NucleusRH.Base.QuejasyReclamos.Reclamo\" /&gt;",null,"L");
}

function setFechas() {
	if(Ctrl('desde').GetXValue() != "")                     
		Ctrl('f_desde').SetXValue(Ctrl('desde').GetXValue() + "000000");
	if(Ctrl('hasta').GetXValue() != "")                     
		Ctrl('f_hasta').SetXValue(Ctrl('hasta').GetXValue() + "235959");  
	Ctrl('main').DoEvent("FILTER");
}
	</form:Scripts>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
</form:Form>
