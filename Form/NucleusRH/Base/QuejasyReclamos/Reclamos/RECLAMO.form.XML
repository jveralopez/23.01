		function NEW_REC () {
	openNewFlow("NucleusRH.Base.QuejasyReclamos.Workflow.Reclamo.autoflow","NEW-WF","&lt;DATA d_usuario=\""+Ctrl('user').GetXValue()+"\" Etapa=\"Inicial\" WF=\""+GetProxy().AppName()+".NucleusRH.Base.QuejasyReclamos.Reclamo\" /&gt;",new ObjetoActualizador(),"L");
}                                                                                                                                                                                                                                               

function ObjetoActualizador() {
	this.processResult = function(){
	Ctrl('REFRESH').DoEvent('onclick');
	}
}
