<form:Form xmlns:form="nomad_engine.form" default_mode="EDIT" name="NucleusRH.Base.QuejasyReclamos.Reclamos.SELECCION" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Help>
		<form:Help-title text="Reclamos" name="TITLE"/>
		<form:Help-descr text="En esta tabla se guardan todos los reclamos." name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Selecci&#243;n de Oficina para la Derivaci&#243;n Masiva de Reclamos" visible="EDIT" nowrap="1" align="center" style="S3 LCol_w" name="GEN_EDIT"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="EDIT" width="100%" name="main_columnsRECLAMO2">
			<form:Column visible="EDIT" height="150px" width="100%" name="main_columnsRECLAMOcolumn3" separation="2" align="center" valign="top">
				<form:Blank name="bllist"/>
				<form:ComboBox queryname1="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.INFO1" nvalue="#HISTORICO:@oi_oficina" label="Selecci&#243;n de Oficina a la cual derivar" xsize="40" mode="QRY" required="1" name="oi_oficina" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina"/>
					</form:Policies>
				</form:ComboBox>
				<form:TextBox nvalue="#HISTORICO:@t_historico" name="t_historico" length="4000" label="Motivo" required="0" ysize="8" xsize="50"/>
				<form:Hidden nvalue="#HISTORICO:@c_oficina" name="c_oficina"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button label="Confirmar Derivaci&#243;n" mess="Confirma la derivaci&#243;n masiva?" infomess="0" name="DERIVAR" descrip="Derivar masivamente los reclamos seleccionados." startvalidate="1" img="ok" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE"/>
					</form:Policies>
					<form:Event action="SetValues" name="onclick" runat="client"/>
				</form:Button>
				<form:Button startvalidate="0" img="back" label="Volver" name="BACK" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/form/SAVE"/>
					</form:Policies>
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SetValues() {
	if(Ctrl('oi_oficina').GetXValue() != "") {
		//tiro en el flow el qry para setear el c_oficina a la WFI
		//var c_oficina = Ctrl('oi_oficina').GetCValue().split('-');      
	  //var param = "OFI:"+c_oficina[0].toString()+'-'+c_oficina[1].toString()+'-'+c_oficina[2].toString();         
	  //Ctrl('c_oficina').SetXValue(param);
		Ctrl('main').DoEvent('DERIVAR');
	}
	else {
		alert("Debe seleccionar una oficina para derivar el reclamo");
		return false;
	}	
}
	</form:Scripts>
	<form:Event action="DERIVAR" name="DERIVAR" runat="server"/>
</form:Form>
