<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO">
