				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/RECLAMO/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Center>
		<form:Columns name="columnas">
			<form:Column visible="FILTER" name="col2" separation="2" align="center" valign="top">
				<form:Blank name="blk2"/>
				<form:ComboBox label="Estado Reclamos" required="0" nvalue="#FILTER:@origen" xsize="40" mode="OPT" name="c_origen">
					<options>
						<option text="Pendientes" value="PEN"/>
						<option text="Cerrados" value="CER"/>
					</options>
				</form:ComboBox>
				<form:ComboBox nvalue="#FILTER:@n_criticidad" xsize="40" mode="OPT" label="Criticidad" name="n_criticidad">
					<options>
						<option text="-" value="0"/>
						<option text="Muy Baja" value="1"/>
						<option text="Baja" value="2"/>
						<option text="Normal" value="3"/>
						<option text="Alta" value="4"/>
						<option text="Muy Alta" value="5"/>
					</options>
				</form:ComboBox>
				<form:ComboBox queryname1="NucleusRH.Base.QuejasyReclamos.Oficinas.OFICINA.INFO" xsize="40" mode="QRY" required="0" label="Oficina" nvalue="#FILTER:@oi_oficina" name="oi_oficina" X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/QuejasyReclamos/Reclamos/SOL_RECLAMO/autoform/oi_oficina"/>
					</form:Policies>
				</form:ComboBox>
				<form:Combo required="1" nvalue="#FILTER:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
					<form:Opts name="aaa">
						<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
						<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
					</form:Opts>
				</form:Combo>
			</form:Column>
			<form:Column visible="FILTER_ORG" name="col3" separation="2" align="center" valign="top">
				<form:Blank name="blk2"/>
				<form:ComboBox label="Nivel de Dependencia Funcional" nvalue="#FILTER:@c_nivel" xsize="40" mode="OPT" name="c_nivel">
					<options>
						<option text="Nivel 1" value="1"/>
						<option text="Nivel 2" value="2"/>
						<option text="Nivel 3" value="3"/>
						<option text="Todos" value="4"/>
					</options>
				</form:ComboBox>
				<form:ComboBox label="Estado Reclamos" nvalue="#FILTER:@c_origen" required="1" xsize="40" mode="OPT" name="c_origen">
					<options>
						<option text="Derivados" value="DER"/>
						<option text="Creados" value="CRE"/>
					</options>
				</form:ComboBox>
				<form:Combo required="1" nvalue="#FILTER:@salida" name="salida" label="Formato de Salida" descrip="Indica el formato de salida del Reporte">
					<form:Opts name="aaa">
						<OPT value="HTML" name="HTML" descrip="HTML" text="HTML" code="HTML"/>
						<OPT value="EXCEL" name="EXCEL" descrip="EXCEL" text="EXCEL" code="EXCEL"/>
					</form:Opts>
				</form:Combo>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function FILTER() {
	if(Ctrl('main').GetMode()=="FILTER")	{
		var np, nSQL, docReclamo;
		np = new NomadProxy("", ut);
		nSQL = np.SQLService();
		docRtdo = new NomadXML(nSQL.Get(Ctrl("main").getResource("qrycount"), "&lt;PARAM id=\""+Ctrl("c_origen").GetXValue()+"\" /&gt;"));				
		if(docRtdo.GetAttr("cantidad") &gt; 10000) {
			alert("Super&#243; el l&#237;mite de registros permitidos. Por favor afine la b&#250;squeda.");
			return false;	
		}             
		else
			Ctrl('main').DoEvent('FILTER');
	}                                
	else
		Ctrl('main').DoEvent('FILTER');
}
	</form:Scripts>
	<form:Event action="FILTER" name="FILTER" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM id=&quot;PEN&quot; /&gt;" name="qrycount">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				SELECT
					COUNT(QYR01_RECLAMOS.oi_reclamo) as cantidad
				FROM
					QYR01_RECLAMOS
				WHERE
					{%? (#PARAM:@id ='PEN') 
						{% QYR01_RECLAMOS.c_estado != \'Reclamo finalizado\'	%}  
						{% 
							{%? (#PARAM:@id ='CER') 
							{% QYR01_RECLAMOS.c_estado = \'Reclamo finalizado\'	%}  
							{% 1=1  %} 
							%}
						%} 
					%}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cantidad" value="$r/@cantidad"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
