<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.QuejasyReclamos.Reportes">
	<flow:info label="Flow para NucleusRH.Base.QuejasyReclamos.Reclamos"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_reclamo as oi_reclamo, SEC.policy FROM QYR01_RECLAMOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Reclamos.RECLAMO\') as SEC JOIN t0.oi_reclamo LEFT OUTER SEC.id  ORDER BY oi_reclamo asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclamo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA.INFO"/>
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_reclamo as oi_reclamo, t0.f_reclamo as f_reclamo, t0.d_usuario as d_usuario, t0.c_estado as c_estado, t0.f_ult_estado as f_ult_estado, t0.c_nivel1 as c_nivel1, t0.c_nivel2 as c_nivel2, t0.c_nivel3 as c_nivel3, t0.c_nivel4 as c_nivel4, SEC.policy, t0.oi_reclamo as CODE, t0.oi_reclamo as TEXT, t0.oi_tipo_problema as oi_tipo_problema FROM QYR01_RECLAMOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Reclamos.RECLAMO\') as SEC JOIN t0.oi_reclamo LEFT OUTER SEC.id  ORDER BY oi_reclamo asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_reclamo"/>
						<qry:attribute name="f_reclamo" value="$r/@f_reclamo"/>
						<qry:attribute name="d_usuario" value="$r/@d_usuario"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="f_ult_estado" value="$r/@f_ult_estado"/>
						<qry:attribute name="c_nivel1" value="$r/@c_nivel1"/>
						<qry:attribute name="c_nivel2" value="$r/@c_nivel2"/>
						<qry:attribute name="c_nivel3" value="$r/@c_nivel3"/>
						<qry:attribute name="c_nivel4" value="$r/@c_nivel4"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_tipo_problema!=''">
							<qry:then>
								<qry:element name="oi_tipo_problema">
									<qry:attribute name="OI_FIND" value="$r/@oi_tipo_problema"/>
									<qry:insert-select name="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_problema" value="'['+oi_tipo_problema/ROW/@COD+'] '+oi_tipo_problema/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="REPORTDOM"/>
		<doc:define name="ENTRADA">
			<ROW llamado_desde=""/>
		</doc:define>
		<qry:define name="getClass">
			<qry:main maxdeep="2">
				<qry:element name="ROW">
					<qry:attribute name="class" value="#PROXY:@app + '.NucleusRH.Base.QuejasyReclamos.Reclamo'"/>
					<qry:attribute name="user" value="#PROXY:@user"/>
				</qry:element>
			</qry:main>
		</qry:define>
		<doc:define name="CLASE">
			<ROW clase=""/>
		</doc:define>
		<doc:define name="FILTER">
			<ROW/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form"/>
		</flow:action>
		<flow:action name="initialize_org">
			<flow:open-form mode="FILTER_ORG" doc-path="#SOURCE:" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="RECLAMO">
		<flow:form form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form:FILTER" mode="FILTER">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:call-action eq="HTML" if="#FILTER:@salida" action="ACCEPTHTML"/>
				<flow:call-action eq="EXCEL" if="#FILTER:@salida" action="ACCEPTEXCEL"/>
			</flow:action>
			<flow:action name="ACCEPTHTML">
				<flow:html-gen ext="html" template-file="NucleusRH.Base.QuejasyReclamos.Reclamos.rpt" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form doc-path="#REPORTDOM:" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" mode="REPORT"/>
			</flow:action>
			<flow:action name="ACCEPTEXCEL">
				<flow:html-gen ext="xls" template-file="NucleusRH.Base.QuejasyReclamos.Reclamos.rpt" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form doc-path="#REPORTDOM:" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" mode="REPORT"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form:REPORT" mode="REPORT">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group name="REPORTE_ORGANIGRAMA">
		<flow:form name="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form:FILTER_ORG" mode="FILTER_ORG" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.filter.form" doc="SOURCE">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:call-action eq="HTML" if="#FILTER:@salida" action="ACCEPTHTML"/>
				<flow:call-action eq="EXCEL" if="#FILTER:@salida" action="ACCEPTEXCEL"/>
			</flow:action>
			<flow:action name="ACCEPTHTML">
				<flow:html-gen template-file="NucleusRH.Base.QuejasyReclamos.Reclamos_org.rpt" ext="html" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form doc-path="#REPORTDOM:" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" mode="REPORT"/>
			</flow:action>
			<flow:action name="ACCEPTEXCEL">
				<flow:html-gen template-file="NucleusRH.Base.QuejasyReclamos.Reclamos_org.rpt" ext="xls" out-file-path="#REPORTDOM:@report" input-doc-path="#FILTER:"/>
				<flow:open-form doc-path="#REPORTDOM:" form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" mode="REPORT"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form" doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Reportes.RECLAMO.form:REPORT" mode="REPORT">
			<flow:action name="on-show"/>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
