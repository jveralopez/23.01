<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.flow" extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.flow"/>
	<flow:declare>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT t0.oi_tipohora as oi_tipohora, 
				t0.c_tipohora as c_tipohora, 
				t0.d_tipohora as d_tipohora, 
				t0.e_sumariza_pre as e_sumariza_pre, 
				t0.e_sumariza_aus as e_sumariza_aus,
				t0.c_color as c_color,
				t0.e_bloqueo as e_bloqueo,  
				t0.c_tipohora as CODE, 
				t0.d_tipohora as TEXT ,
				t0.l_def_turno as l_def_turno
				FROM TTA01_TIPOHORAS as t0 
				ORDER BY oi_tipohora asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_tipohora"/>
						<qry:attribute name="c_tipohora" value="$r/@c_tipohora"/>
						<qry:attribute name="d_tipohora" value="$r/@d_tipohora"/>
						<qry:attribute name="e_sumariza_pre" value="$r/@e_sumariza_pre"/>
						<qry:attribute name="e_sumariza_aus" value="$r/@e_sumariza_aus"/>
						<qry:attribute name="c_color" value="$r/@c_color"/>
						<qry:attribute name="e_bloqueo" value="$r/@e_bloqueo"/>
						<qry:attribute name="l_def_turno" value="$r/@l_def_turno"/>
						<qry:insert-select name="qry_bloqueo_0" doc-path="$r/.[@e_bloqueo=0]"/>
						<qry:insert-select name="qry_bloqueo_1" doc-path="$r/.[@e_bloqueo=1]"/>
						<qry:insert-select name="qry_bloqueo_2" doc-path="$r/.[@e_bloqueo=2]"/>
						<qry:insert-select name="qry_bloqueo_3" doc-path="$r/.[@e_bloqueo=3]"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_0">
				<qry:out>
					<qry:attribute name="img" value=""/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_1">
				<qry:out>
					<qry:attribute name="img" value="'Listas/LOCKEDIT.ICO'"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_2">
				<qry:out>
					<qry:attribute name="img" value="'Listas/LOCKDEL.ICO'"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_bloqueo_3">
				<qry:out>
					<qry:attribute name="img" value="'Listas/LOCK.ICO'"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="SHOW">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.autoform" next-action="SHOW" mode="HORARIO" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:group Name="TIPOHORA">
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form" extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form:LIST" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form"/>
			</flow:action>
			<flow:action name="After-Color">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<doc:set-attribute to-attr-path="#FORM:ctrl[@id='LIST']/@xval" from-attr-path="#DDO:@id"/>
				<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form:NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.form" mode="NEW"/>
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.autoform" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.form:HORARIO" mode="HORARIO" parent-doc="PARENTSOURCE" doc="SOURCE">
			<flow:action name="on-show"/>
			<flow:action name="SHOW">
				<doc:new-object class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA" doc="DDO"/>
				<doc:new-object class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA" doc="NEWDDOROOT"/>
				<doc:assign-value from-path="#SOURCE:" to-doc="QRY"/>
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.noreg.autoform" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT"/>
			</flow:action>
			<flow:action name="After-Back">
				<flow:exit-flow return-path="#QRY:"/>
			</flow:action>
			<flow:action name="After-Change">
				<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#retdoc:@id"/>
				<flow:exit-flow return-path="#QRY:"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
