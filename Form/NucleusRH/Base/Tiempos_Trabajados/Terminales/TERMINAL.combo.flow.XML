<flow:flow extends="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.guia.autoflow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL"/>
	<flow:declare>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
SELECT 
	es.oi_estructura as ID
FROM 
	ORG02_ESTRUCTURAS as es               
WHERE
	es.oi_estructura in (SELECT t.oi_estructura FROM TTA05_TERMINALES as t)
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="''" name="text"/>
						<qry:insert-select name="RS2" doc-path="$r"/>
						<qry:attribute value="substring(./@text,1)" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
SELECT 
	t.d_terminal as txt
FROM 
	TTA05_TERMINALES as t
WHERE
	t.oi_estructura = {#SOURCE:@id}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="./@text+','+$r/@txt" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
SELECT 
	es.oi_estructura as ID
FROM 
	ORG02_ESTRUCTURAS as es               
WHERE
	es.oi_estructura in (SELECT t.oi_estructura FROM TTA05_TERMINALES as t)
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@ID" name="code"/>
						<qry:attribute value="''" name="text"/>
						<qry:insert-select name="RS2" doc-path="$r"/>
						<qry:attribute value="substring(./@text,1)" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql('
SELECT 
	t.d_terminal as txt
FROM 
	TTA05_TERMINALES as t
WHERE
	t.oi_estructura = {#SOURCE:@id}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="./@text+','+$r/@txt" name="text"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry output-doc="RS" qry="COMBO"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
</flow:flow>
