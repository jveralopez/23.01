<form:Form xmlns:form="nomad_engine.form" extends="Nomad.Report.form" name="CONC_VAL.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Detalle de Horas y Conceptos" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
				<form:Label label="Detalle de Horas y Conceptos" nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT"/>
				<form:Label label="Detalle de Horas y Conceptos" nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" name="GEN_DEL"/>
				<form:Label label="Detalle de Horas y Conceptos" nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%" height="100%">
		<form:UrlControl fileid="{XValue}.htm" filegroup="TEMP" border="0" height="100%" width="100%" enabled="false" name="UrlControl02" label="UrlControl" note="" descrip="" nvalue="#source:@report"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowAligner1" columns="3">
			<form:Row name="row1">
				<form:Button visible="0" name="BUT_LEFT" descrip="Bot&#243;n utilizado en los heredados" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/CONC_VAL/form/BUT_LEFT"/>
				<form:Button label="Imprimir" enabled="" visible="" name="PRINT" img="print" note="Imprimir el Reporte" descrip="Imprimir el Reporte" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/CONC_VAL/form/PRINT">
					<form:Event action="PrintHTML" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="0" name="BUT_CENTER" descrip="Bot&#243;n utilizado en los heredados" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/CONC_VAL/form/BUT_CENTER"/>
				<form:Button enabled="" visible="" name="BACK" label="Volver" img="back" note="Volver a la pantalla anterior" descrip="Volver al formulario anterior" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/CONC_VAL/form/BACK">
