			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function PrintHTML()
{  
	const iframe = document.getElementById(Ctrl('UrlControl02').m_ID+"_FRAME"); 
	iframe.contentWindow.focus(); 
	iframe.contentWindow.print(); 
	//ShowFile("TEMP\\" + Ctrl('UrlControl02').GetXValue() + ".htm?print=2",Ctrl('UrlControl02').GetXValue() + ".htm?print=1");
	//Ctrl('UrlControl02').Print();
	//FUNCION Ctrl().Print() esta fuera de uso ya que quedo obsoleta
}
	</form:Scripts>
</form:Form>
