<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion_Personas.VAL_VAR.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Datos de Novedad" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Datos de Novedad" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Datos de Novedad" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Datos de Novedad" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PERLIQ:@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:Grid proto="NucleusRH.Base.Tiempos_Trabajados.Liquidacion_Personas.VAL_VAR" idvalue="#source:@id" width="1020px" doc="source" allowdelall="1" allowdel="1" allownew="1" nvalue="#source:" paging="1" rows="10" name="grdnov">
			<form:GColumns>
				<form:GColumn name="colVar">
					<form:ComboBox queryname1="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.INFO" xsize="40" mode="QRY" required="1" label="Variable" nvalue="#source:oi_variable/@value" name="oi_variable"/>
				</form:GColumn>
				<form:GColumn name="colClave">
					<form:DateTime label="Clave" pattern="YYYYMMDD" required="0" name="e_clave" nvalue="#source:@e_clave">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="colValor">
					<form:NumberBox required="1" mask="###.###.##0.00" xsize="15" precision="3" label="Valor" nvalue="#source:@n_valor" name="n_valor"/>
				</form:GColumn>
				<form:GColumn name="colObs">
					<form:TextBox required="0" ysize="1" xsize="50" length="50" label="Observaciones" nvalue="#source:@o_val_vargn" name="o_val_vargn"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" img="save" label="Guardar" name="SAVE" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/LIQUIDACIONPERS/autoform/SAVE">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar la operacion actual." mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" img="cancel" label="Cancelar" name="CANCEL" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion_Personas/LIQUIDACIONPERS/autoform/CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
