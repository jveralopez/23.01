<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.BUSCAR2.form" name="ConceptosCalculadosfilter" doc="source">
	<form:Title>
		<form:Label label="Conceptos Calculados" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup width="90%" nvalue="#source:@gcustom" border="1" label="Criterios de ejecuci&#243;n" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="cols2">
				<form:Column align="left" valign="top" name="col21">
					<form:Combo required="1" nvalue="#source:@formato" label="Formato" name="formato">
						<form:Opts>
							<OPT name="NucleusRH" text="NucleusRH" code="N" value="N"/>
							<OPT name="Opus" text="Opus" code="OPUS" value="OPUS"/>
							<OPT name="Payroll" text="Payroll" code="P" value="P"/>
						</form:Opts>
					</form:Combo>
					<form:ComboBox queryname1="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1" label="Procesamiento" nvalue="#source:@oi_liquidacion" name="oi_liquidacion"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button descrip="Genera el archivo en funci&#243;n de los par&#225;metros ingresados" label="Ejecutar" img="ok" name="EXECUTE" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Ejecutar()
{ 	 
	FillArray(100);
	Ctrl("main").DoEvent("ok");	 		
}

function ObjtectResult()
{        
	this.processResult= function(xmlin)
	{    
	}
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_liquidacion=&quot;40&quot;/&gt;" name="qry_externo">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:/PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			 		SELECT 
			 			TTA10_LIQUIDACPERS.oi_personal_emp,
				    SEC.policy
					FROM 
						TTA10_LIQUIDACPERS,
						NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC
					JOIN TTA10_LIQUIDACPERS.oi_personal_emp LEFT OUTER SEC.id						
					WHERE 
						TTA10_LIQUIDACPERS.oi_liquidacion = {#SOURCE:@oi_liquidacion}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:params>
				##oi_liquidacion##
			</qry:params>
		</form:Resource>
	</form:Resources>
	<form:Event action="ACCEPT" name="ok" runat="server"/>
	<form:Event action="PREVIEW" runat="server" name="view"/>
</form:Form>
