<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.filter.form">
	<form:Title name="titulo">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label descrip="Filtrar Novedades por Legajo" label="Filtrar Novedades por Legajo" align="center" dynamic="0" nowrap="1" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank height="20" name="blk01"/>
		<form:Columns name="columns">
			<form:Column name="column" separation="2" align="center" valign="top">
				<form:ComboBox nvalue="#source:@oi_personal_emp" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" name="oi_personal_emp" label="Legajo" visible=""/>
				<form:DateTime nvalue="#source:@f_desde" mask="dd/mm/yyyy" pattern="YYYYMMDD" name="f_desde" prev="" label="Fecha desde" visible="" max="" min="">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime label="Fecha hasta" name="f_hasta" nvalue="#source:@f_hasta" mask="dd/mm/yyyy" pattern="YYYYMMDD" prev="" visible="" max="" min="">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" visible="" img="Calendar" descrip="">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox nvalue="#source:@tipo_hora" queryname1="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO" label="Tipo de Hora" name="tipohora" mode="QRY" xsize="40">
					<options/>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="FILTER" startvalidate="1" note="Filtra las Novedades por Legajo" descrip="Filtra las Novedades por Legajo" img="OK" label="Filtrar">
					<form:Event action="FILTER" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Agregar un Registro" img="application_add.gif" label="Agregar" name="ADD" visible="!SELECT" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Personal/NOVEDAD/list/form/ADD">
					<form:Event action="RegAdd" name="onclick" runat="client"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Personal/NOVEDAD/list/form/ADD/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Personal/NOVEDAD/list/form/ADD"/>
					</form:Policies>
				</form:Button>
				<form:Button note="Vuelve a la pantalla anterior" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function RegAdd()
{
  if (Ctrl("ADD")?false:true) return false;
  if (!Ctrl("ADD").GetEnabled()) return false;

  Ctrl("main").DoEvent("ADD"   );
  return true;
}
	</form:Scripts>
	<form:Event action="ADD" name="ADD" runat="server"/>
</form:Form>
