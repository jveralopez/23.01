<flow:flow default_action="HELP" name="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form" extends="Nomad.simple.guia.flow">
	<flow:info label="Flow guia para NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia.form" mode="SHOW" doc-path="#RS:" parent-doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define declare="&lt;helper-mess ID=&quot;1&quot;/&gt;" name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT TTA02_HORARIOS.oi_horario AS ID, 
				TTA02_HORARIOS.c_horario AS CODE, 
				TTA02_HORARIOS.d_horario AS TEXT,  
				TTA02_HORARIOS.d_tipohorario AS tipo 
				FROM TTA02_HORARIOS 
				WHERE TTA02_HORARIOS.c_estado=\'C\' 
				AND TTA02_HORARIOS.oi_horario={#SOURCE:helper-mess/@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="value" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="code" value="$r/@CODE" type="Nomad.NSystem.String"/>
					<qry:attribute name="text" value="$r/@TEXT" type="Nomad.NSystem.String"/>
					<qry:attribute name="sTipoHorario" value="$r/@tipo" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;helper-mess code=&quot;0816&quot;/&gt;" name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc name="INDOC" doc-path="#SOURCE:helper-mess"/>
				<qry:element name="ROW">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT TTA02_HORARIOS.oi_horario AS ID, 
				TTA02_HORARIOS.c_horario AS CODE, 
				TTA02_HORARIOS.d_horario AS TEXT ,  
				TTA02_HORARIOS.d_tipohorario AS tipo 
				FROM TTA02_HORARIOS 
				WHERE TTA02_HORARIOS.c_estado=\'C\' 
				AND TTA02_HORARIOS.c_horario={substring_before(#INDOC:@CODE,\'-\')} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="SUB_SEARCH" value="''" type="Nomad.NSystem.String"/>
					<qry:attribute name="PARENTID" value="''" type="Nomad.NSystem.String"/>
					<qry:attribute name="id" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="value" value="$r/@ID" type="Nomad.NSystem.Int"/>
					<qry:attribute name="code" value="$r/@CODE" type="Nomad.NSystem.String"/>
					<qry:attribute name="text" value="$r/@TEXT" type="Nomad.NSystem.String"/>
					<qry:attribute name="sTipoHorario" value="$r/@tipo" type="Nomad.NSystem.String"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT TTA02_HORARIOS.oi_horario AS ID,
				TTA02_HORARIOS.c_horario AS CODE, 
				TTA02_HORARIOS.d_horario AS TEXT,
				TTA02_HORARIOS.d_tipohorario AS tipo 
				FROM TTA02_HORARIOS  
				WHERE TTA02_HORARIOS.c_estado=\'C\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="value" value="$r/@ID" type="Nomad.NSystem.Int"/>
						<qry:attribute name="code" value="$r/@CODE" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="$r/@TEXT" type="Nomad.NSystem.String"/>
						<qry:attribute name="sTipoHorario" value="$r/@tipo" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="Nomad.simple.guia.form:SHOW" name="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia.form" mode="SHOW" doc="SOURCE" parent-doc="INVAL">
		<flow:action name="on-show">
			<doc:assign-mapping dir-apply="a-&gt;b" a-doc="INVAL" b-doc="FORM">
				<map docA="A" docB="B">
					<link A="#A:@id" B="#B:ctrl[@id='GRID']/@selectedRow"/>
				</map>
			</doc:assign-mapping>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exit-flow return-path="#RS:ROW[@id='{#FORM:ctrl[@id='GRID']/@selectedRow}']"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#INVAL:"/>
		</flow:action>
	</flow:form>
</flow:flow>
