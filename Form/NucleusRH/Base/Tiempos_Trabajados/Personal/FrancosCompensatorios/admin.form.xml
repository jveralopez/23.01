<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Personal.FrancosCompensatorios.admin.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1" visible="0"/>
			<form:Row name="row2">
				<form:Label label="Edici&#243;n de Compensatorios" nowrap="1" align="center" style="S3 LCol_w" name="GEN_NEW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Columns width="100%" name="main_columnsCONSULTAS">
			<form:Column separation="2" valign="top" align="center" name="main_columnsCONSULTAcolumn1">
				<form:Blank name="bl1"/>
				<form:ComboBox enabled="0" nvalue="#source:@oi_personal_emp" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO" xsize="40" mode="QRY" required="1" label="Empresa - Legajo" name="oi_personal_emp">
					<form:Event action="ChangePer" name="onchange" runat="client"/>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
		<form:Line width="100%" name="line"/>
		<form:Blank name="bl1050"/>
		<form:Grid idvalue="#DATAGRID:@oi_compen" name="grdCOMP" nvalue="#source:ROWS" allowhelper="0" width="500px" proto="&lt;ROW/&gt;" doc="DATAGRID" allowdelall="0" allowdel="0" allownew="0" paging="1" rows="10">
			<form:GColumns>
				<form:GColumn name="colFechaFranco">
					<form:DateTime name="fecha_franco" label="Fecha Franco" nvalue="#DATAGRID:@f_franco_comp" xsize="10" enabled="0" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy"/>
				</form:GColumn>
				<form:GColumn name="colFechaCompen">
					<form:DateTime name="fecha_comp" label="Fecha Comp." nvalue="#DATAGRID:@f_compen" xsize="10" enabled="0" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy"/>
				</form:GColumn>
				<form:GColumn name="colComp">
					<form:NumberBox label="Compensado" precision="2" nvalue="#DATAGRID:@n_compen" required="1" length="3" width="3" xsize="2" name="cant_comp"/>
				</form:GColumn>
				<form:GColumn name="colDel">
					<form:CheckBox nvalue="#DATAGRID:@del" name="delete" label="Eliminar"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row2">
				<form:Button startvalidate="1" note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="save" label="Guardar" name="SAVE" order-change="FIRST">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button startvalidate="0" note="Volver a la pantalla anterior" descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
