<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia" doc="SOURCE">
	<form:scripts>
		function FilterGrid()
		{
			Ctrl("GRID").FilterElements("","");
			if (Ctrl("buscar").GetCValue()!="") Ctrl("GRID").FilterElements(Ctrl("buscar").GetCValue(),"");
		}
	</form:scripts>
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label name="GEN" label="Seleccion de Horarios" style="S3 LCol_w" nowrap="1"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:RowAligner name="buttonlinks" visible="SHOW">
			<form:row name="row_top">
				<form:TextBox name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
					<form:event runat="client" name="onpressenter" action="FilterGrid"/>
					<form:sbuttons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
							<form:event runat="client" name="onclick" action="FilterGrid"/>
						</form:SButton>
					</form:sbuttons>
				</form:TextBox>
			</form:row>
		</form:RowAligner>
		<form:Blank name="blank_iter01"/>
		<form:Grid name="GRID" nvalue="#SOURCE:" idvalue="#ROW:@id" doc="ROW" rows="8" paging="1" allownew="0" allowdel="0">
			<form:GColumns>
				<form:GColumn name="col1">
					<form:link name="LINK" label=" " img="link2" descrip="Codigo" allowimg="1"/>
				</form:GColumn>
				<form:GColumn name="col2">
					<form:TextBox name="CODE" nvalue="#ROW:@code" label="Codigo" length="8" xsize="8" ysize="1" descr="Codigo" note="Codigo" enabled="0"/>
				</form:GColumn>
				<form:GColumn name="col3">
					<form:TextBox name="TEXT" nvalue="#ROW:@text" label="Descripcion" length="40" xsize="40" ysize="1" descr="Descripcion" note="Descripcion" enabled="0"/>
				</form:GColumn>
				<form:GColumn name="col4">
					<form:TextBox nvalue="#ROW:@sTipoHorario" name="tipo" label="Tipo" length="40" xsize="2" ysize="1" descr="Tipo" note="Tipo" enabled="0"/>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:row name="rowbottom">
				<form:button name="ACCEPT" label="Aceptar" img="OK" descrip="Aceptar" note="Aceptar">
					<form:event runat="server" name="onclick" action="ACCEPT"/>
				</form:button>
				<form:button name="CANCEL" label="Cancelar" img="CANCEL" descrip="Cancelar" note="Cancelar">
					<form:event runat="server" name="onclick" action="CANCEL"/>
				</form:button>
			</form:row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
