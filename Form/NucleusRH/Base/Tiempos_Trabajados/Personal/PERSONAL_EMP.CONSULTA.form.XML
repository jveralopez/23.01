	<form:Scripts>
		function ValidarLargoLegajo()
{	
	if (Ctrl('largo_legajo').GetXValue() =='')
	{
		Ctrl('largo_legajo').SetXValue('0');
	}
	if (Ctrl('e_nro_legajo_reloj').GetXValue() != '')
	{ 	
		if(Ctrl('e_nro_legajo_reloj').GetXValue().length &gt; Ctrl('largo_legajo').GetXValue()) 
		{	
			Ctrl('e_nro_legajo_reloj').SetError('La cantidad de caracteres del n&#250;mero de legajo reloj no puede ser mayor a ' + Ctrl('largo_legajo').GetXValue());			
			return false
		}
	}
	return true;
}

function Load()
{
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();
	
	var ct;				
	ct = nSQL.GetOBJ(Ctrl("main").getResource("QRY_CT"), "");
		
	if(ct.value == "0")
		CtrlEnabled("CAMBIOTURNO", false);
	else
		CtrlEnabled("CAMBIOTURNO", true);	
}

function nombreyapellido ()
{
	Ctrl('d_apellido').SetXValue(Trim(Ctrl('d_apellido').GetXValue()));
	Ctrl('d_nombres').SetXValue(Trim(Ctrl('d_nombres').GetXValue()));
	Ctrl('d_ape_y_nom').SetCValue(Ctrl('d_apellido').GetCValue()+', '+Ctrl('d_nombres').GetCValue());		
}

function codigo()
{
	var mp, nSQL, docPar;
	np = new NomadProxy("", ut);
	nSQL = np.SQLService();  
	docPar = nSQL.GetOBJ(Ctrl("main").getResource("qry:TIPODOC"), "&lt;PARAM id=\""+Ctrl("oi_tipo_documento").GetXValue()+"\" /&gt;");	
	Ctrl('c_personal').SetCValue(docPar.cod.toString()+Ctrl('c_nro_documento').GetCValue());		
}

function LoadEmpresa(me)
{
	var legajo;		
	var np = new NomadProxy("", ut);
	var nSQL = np.SQLService();

	if (me.GetCValue() != "")
	{		
		legajo = nSQL.GetOBJ(Ctrl("main").getResource("QRY_NRO_LEGAJO"), "&lt;PARAM oi_empresa=\""+Ctrl("oi_empresa").GetXValue()+"\" /&gt;"); 		
		Ctrl("e_numero_legajo").SetXValue(legajo.e_numero_legajo);		
	}
	else
		Ctrl('e_numero_legajo').SetCValue("");
}       

//Navegabilidad a Legajo Empresa   
function verLegajo()
{                                   
	if(Ctrl("main").GetMode()=="LIST")     
		getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+Ctrl("LIST").GetSelectAttrValue("id").toString()+"\" /&gt;", false);    
	else
		getFormInMain("NucleusRH.Base.Personal.LegajoEmpresa.flow", "ORGANIGRAMA",  "&lt;LEGAJO VALUE=\""+Ctrl("oi_personal_emp").GetXValue()+"\" /&gt;", false); 	
}
     
//Navegabilidad a Horario   
function verHorario()
{                             
	var np = new NomadProxy("",ut);
	var nSQL = np.SQLService();
	var horario;             
	
	if(Ctrl("main").GetMode()=="LIST")
		horario = nSQL.GetOBJ(Ctrl("main").getResource("QRY_HORARIO"),"&lt;PARAM oi_personal_emp=\""+Ctrl("LIST").GetSelectAttrValue("id").toString()+"\" /&gt;");
	else
		horario = nSQL.GetOBJ(Ctrl("main").getResource("QRY_HORARIO"),"&lt;PARAM oi_personal_emp=\""+Ctrl("oi_personal_emp").GetXValue()+"\" /&gt;");
	
	if(horario.oi_horario)
		getFormInMain("NucleusRH.Base.Tiempos_Trabajados.Horarios.flow", "filterHorario",  "&lt;ROWS&gt;&lt;ROW id=\""+horario.oi_horario.toString()+"\" /&gt;&lt;/ROWS&gt;", false); 
	else
		alert("El Legajo TTA seleccionado no tiene un horario definido.");
	
}
	</form:Scripts>
