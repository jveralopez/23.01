	<form:Resources>
		<form:Resource name="QRY_CT">
			<qry:main>
				<qry:element name="CT">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					COUNT(TTA02_HORARIOS.oi_horario) as cont
				FROM
					TTA02_HORARIOS
				WHERE 
					TTA02_HORARIOS.l_cambio_turno = 1
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="value" value="$r/@cont"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM id=&quot;4&quot;/&gt;" name="qry:TIPODOC">
			<qry:main doc="PARAM">
				<qry:element name="DATO">
					<qry:insert-select doc-path="#PARAM:/PARAM" name="qry_tipo_doc"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_tipo_doc">
				<qry:xquery>
					for $r in sql('
					SELECT PER20_TIPOS_DOC.c_tipo_documento
					FROM PER20_TIPOS_DOC WHERE PER20_TIPOS_DOC.oi_tipo_documento = {#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cod" value="$r/@c_tipo_documento" type="Nomad.NSystem.Int"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_empresa=&quot;9&quot;/&gt;" name="QRY_NRO_LEGAJO">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
					<qry:insert-select name="RS2" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT MAX(PER02_PERSONAL_EMP.e_numero_legajo) AS e_numero_legajo
				FROM PER02_PERSONAL_EMP
				WHERE PER02_PERSONAL_EMP.oi_empresa = {#SOURCE:@oi_empresa}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="e_numero_legajo" value="Number($r/@e_numero_legajo) + 1"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG03_EMPRESAS.l_contratista,
				ORG03_EMPRESAS.oi_art
				FROM ORG03_EMPRESAS
				WHERE ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}				
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="l_contratista" value="$r/@l_contratista"/>
					<qry:attribute name="oi_art" value="$r/@oi_art"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;PARAM oi_personal_emp=&quot;11977&quot;/&gt;" name="QRY_HORARIO">
			<qry:main doc="SOURCE">
				<qry:element name="HORARIO">
					<qry:insert-select name="RS1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					TTA04_PERSONAL.oi_hor_planilla
				FROM 
					TTA04_PERSONAL
				WHERE 
					TTA04_PERSONAL.oi_personal_emp = {#SOURCE:@oi_personal_emp} 
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_horario" value="$r/@oi_hor_planilla"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
