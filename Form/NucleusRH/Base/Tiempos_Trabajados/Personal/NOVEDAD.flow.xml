<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD.flow" name="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.flow">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.flow:initialize"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO legajo=""/>
		</doc:define>
		<doc:define name="DOC"/>
	</flow:declare>
	<flow:main doc="PARAMIN">
		<flow:action name="initialize">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD"/>
			<flow:open-form mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.filter.form" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.filter.form" mode="FILTER" name="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.filter.form:FILTER">
		<flow:action name="FILTER">
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action action="open-flow-LIST"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.list.form" doc-path="#FILTERDATA:" mode="LIST"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ADD">
			<flow:open-form doc-path="#FILTERDATA:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD_REG.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.MAIN.STD_LIST.autoform:LIST" name="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.list.form:LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Personal.NOVEDAD.list.form" mode="LIST" doc="SOURCE"/>
</flow:flow>
