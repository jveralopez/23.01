<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Tiempos_Trabajados.Personal.interface.form">
	<form:Help/>
	<form:Scripts/>
	<form:Title>
		<form:Label label="Importaci&#243;n de Cambio de Turnos" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank name="b1"/>
		<form:Blank name="b2"/>
		<form:File filename="INTturnos.dat" descrip="Selecciona el archivo a subir" name="file" label="Archivo" note="" required="1" class="INTERFACES" source="1">
			<form:SButtons>
				<form:SButton descrip="Selecciona el archivo a subir" enabled="" visible="" name="sbHelper" label="Buscar archivo" img="search">
					<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
				</form:SButton>
			</form:SButtons>
		</form:File>
		<form:Blank name="b3"/>
		<form:Container height="400px" width="680px" rheight="400px" rwidth="700px" label="Aclaraciones" name="cc" borderwidth="1">
			<form:RowAligner name="ra">
				<form:Row name="a1">
					<form:Label style="M1 LCol_t" name="formato" label="El formato del archivo es:"/>
					<form:Blank name="blank031"/>
				</form:Row>
				<form:Row name="a2">
					<form:Blank name="blank031"/>
					<form:Label label="Empresa;Legajo;FechaDesde;FechaHasta;Horario;Escuadra" name="formato1"/>
				</form:Row>
				<form:Row name="a3">
					<form:Label style="M1 LCol_t" name="validacion" label="Validaciones:"/>
					<form:Blank name="blank031"/>
				</form:Row>
				<form:Row name="a7">
					<form:Blank name="blank034"/>
					<form:Label label="- La Empresa debe existir en el Sistema" name="validacion1"/>
				</form:Row>
				<form:Row name="a6">
					<form:Blank name="blank034"/>
					<form:Label label="- El legajo debe existir en la Empresa" name="validacion2"/>
				</form:Row>
				<form:Row name="a8">
					<form:Blank name="blank034"/>
					<form:Label label="- El legajo debe tener asignado un n&#250;mero de legajo reloj" name="validacion3"/>
				</form:Row>
				<form:Row name="a5">
					<form:Blank name="blank031"/>
					<form:Label name="validacion4" label="- El horario debe existir en el Sistema"/>
				</form:Row>
				<form:Row name="a9">
					<form:Blank name="blank031"/>
					<form:Label label="- La escuadra debe ser v&#225;lida para el horario" name="validacion5"/>
				</form:Row>
			</form:RowAligner>
		</form:Container>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="fila6">
				<form:Button enabled="" visible="" name="btnAceptar" label="Ejecutar" img="play" note="Ejecuta la busqueda" descrip="Acepta los datos ingresados y ejecuta el formulario">
					<form:Event action="EXECUTE" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl8" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
