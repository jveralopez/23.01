<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.flow">
	<flow:info label="Flow para Interfaces Novedades"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAM EMPRESA=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="PARAMIN">
		<flow:action name="initialize">
			<flow:load-user-data name="NucleusRH.Base.Tiempos_Trabajados.Personal.InterfaceNOV" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EXECUTE">
			<flow:save-user-data name="NucleusRH.Base.Tiempos_Trabajados.Personal.InterfaceNOV" doc-path="#FILTERDATA:"/>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES" method="ImportarNovedades" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id">
				<flow:param attr-path="#FORM:ctrl[@id='oi_terminal']/@xval" type="Nomad.NSystem.String" mode="in" name="terminal"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
