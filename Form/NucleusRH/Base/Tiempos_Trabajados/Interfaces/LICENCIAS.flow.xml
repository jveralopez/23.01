		<doc:define name="FILTERDATA">
			<PARAM EMPRESA=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="NucleusRH.Base.Tiempos_Trabajados.Personal.Interface" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.LICENCIAS.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
	</flow:main>
