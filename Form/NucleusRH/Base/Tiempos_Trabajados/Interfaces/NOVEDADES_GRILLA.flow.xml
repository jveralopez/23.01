<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES_GRILLA.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para Interfaces Novedades grilla"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<PARAM EMPRESA=""/>
		</doc:define>
		<doc:define name="PAGE">
			<PAGE oi_terminal="" num="0"/>
		</doc:define>
		<doc:define name="BLANK">
			<PAGE oi_terminal="" num="0"/>
		</doc:define>
		<doc:define name="NADA">
			<PAGE oi_terminal="" num="0">
				<ROWS/>
			</PAGE>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES_GRILLA.form" doc-path="#PAGE:" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES_GRILLA.form" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES_GRILLA.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="EXECUTE">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="Execute" out-attr-path="#BATCHDOC:@batch-id" out-type="String" priority="7"/>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<flow:log text-path="#NADA:" text="NADA"/>
			<!--<doc:assign-ref from-path="#NADA:" to-doc="PAGE"/>-->
			<doc:assign-value from-path="#NADA:" to-doc="PAGE"/>
			<flow:log text-path="#PAGE:" text="PAGE"/>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Refresh">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="ToPage">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute from-attr-path="#FORM:ctrl[@id='topage']/@xval" to-attr-path="#BLANK:@num"/>
			<doc:assign-value to-doc="PAGE" from-path="#BLANK:"/>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Clean">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="Clean">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<flow:action name="Reset">
			<doc:assign-value to-doc="PAGE" from-path="#BLANK:"/>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="SincronizarPagina">
				<flow:param doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="xmlParam"/>
			</flow:exec-method>
		</flow:action>
		<!--<flow:action name="IMPORT_FILE">
		<flow:open-form form-class="NucleusRH.Base.Liquidacion.Interface.InterfazGenericaFILE.form" mode="SHOW" doc-path="#FILTERDATA:"/>
	</flow:action>-->
		<flow:action name="UPLOAD">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form" doc-path="#FILTERDATA:" mode="SHOW"/>
		</flow:action>
		<flow:action name="BACKINT"/>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.NOVEDADES.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="BACKINT">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EXECUTE">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.NovedadesGrilla.ENTRADA" method="ImportarNovedades" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id">
				<flow:param name="oi_terminal" attr-path="#FORM:ctrl[@id='oi_terminal']/@xval" type="Nomad.NSystem.String" mode="in"/>
				<flow:param name="xmlParam" doc="PAGE" type="Nomad.NSystem.Proxy.NomadXML" mode="inout"/>
			</flow:exec-method>
			<flow:open-form doc-path="#BATCHDOC:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
	</flow:form>
	<flow:form mode="BATCH" name="nomad.base.batchtolist.form:BATCH" form-class="nomad.base.batchtolist.form" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:close-form next-action="BACKINT"/>
		</flow:action>
	</flow:form>
</flow:flow>
