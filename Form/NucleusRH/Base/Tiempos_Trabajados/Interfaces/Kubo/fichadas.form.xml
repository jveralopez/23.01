<form:Form xmlns:form="nomad_engine.form" doc="source" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.Kubo.form">
	<form:Title>
		<form:Label label="Interfaz de Obtencion de Fichadas Nucleus Doc" style="S3 LCol_w" nowrap="1" name="lblTitulo"/>
	</form:Title>
	<form:Center width="60%">
		<form:Columns width="10%" name="ColsCenter">
			<form:Column valign="top" separation="0" align="center" width="10%" name="col01">
				<form:Blank name="blank02"/>
				<form:DateTime required="1" pattern="YYYYMMDD" label="Fecha desde" name="fecha" nvalue="#source:@fecha">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha Desde.">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="fecha_hasta" required="0" pattern="YYYYMMDD" label="Fecha hasta" nvalue="#source:@fecha_hasta">
					<form:SButtons>
						<form:SButton name="Calendar" label="Calendar" img="Calendar" descrip="Fecha Hasta">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="raBotonera">
			<form:Row name="row1">
				<form:Button label="Ejecutar" startvalidate="1" img="play" name="butEjecutar">
					<form:Event action="Validar" name="onclick" runat="client"/>
				</form:Button>
				<form:Button label="Volver" img="back" name="butVolver">
					<form:Event action="VOLVER" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Validar()
{
  if (Ctrl('fecha_hasta').GetXValue() != "")
  {
		if (Ctrl('fecha').GetXValue() &gt; Ctrl('fecha_hasta').GetXValue())
		{
		 	alert("La Fecha Desde no puede ser mayor que la Fecha Hasta.");
			return false;
		}
	}
  
	Ctrl("main").DoEvent("EJECUTAR");
} 

function onload()
{
 	Ctrl("fecha").SetXValue("");			
 	Ctrl("fecha_hasta").SetXValue("");			
}
	</form:Scripts>
	<form:Event action="EJECUTAR" name="EJECUTAR" runat="server"/>
	<form:Event action="onload" name="onload" runat="client"/>
</form:Form>
