<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.Kubo.flow" extends="Nomad.Base.flow" description="Flow para la carga de Fotos del Personal." default_action="initialize">
	<flow:info label="Flow para intercambio de datos con ndoc"/>
	<flow:main doc="SOURCE">
		<flow:action name="FICHADAS">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.Kubo.fichadas.form" doc-path="#SOURCE:" mode="FICHADA"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Interfaces.Kubo.fichadas.form" name="NucleusRH.Base.Tiempos_Trabajados.Interfaces.Kubo.fichadas.form:FICHADA" mode="FICHADA" doc="SOURCE">
		<flow:action name="VOLVER">
			<flow:close-form/>
		</flow:action>
		<flow:action name="EJECUTAR">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.Kubo.ApiKubo" method="ObtenerFichadas" out-attr-path="#SOURCE:@batch-id" priority="5">
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" name="xmlParam" mode="in"/>
			</flow:exec-method>
			<flow:open-form doc-path="#SOURCE:" mode="BATCH" form-class="nomad.base.batchtolist.form"/>
		</flow:action>
	</flow:form>
</flow:flow>
