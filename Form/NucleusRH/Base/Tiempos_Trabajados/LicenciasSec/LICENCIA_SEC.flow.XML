<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tiempos_Trabajados.LicenciasSec.LICENCIA_SEC.flow">
	<flow:declare>
		<doc:define name="XML_RESULT">
			<RESULT/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="ValidarLicencia">
			<flow:exec-method method="ValidarLicenciaSec" out-doc="XML_RESULT" class="NucleusRH.Base.Tiempos_Trabajados.LicenciasSec.LICENCIA_SEC" out-type="Nomad.NSystem.Proxy.NomadXML">
				<flow:param attr-path="#SOURCE:@oi_personal_emp" mode="in" name="oi_personal_emp" type="Nomad.NSystem.Int"/>
				<flow:param attr-path="#SOURCE:@oi_licencia_rol" mode="in" name="oi_licencia_rol" type="Nomad.NSystem.Int"/>
				<flow:param attr-path="#SOURCE:@f_inicio" type="Nomad.NSystem.DateTime" mode="in" name="f_inicio"/>
				<flow:param attr-path="#SOURCE:@f_fin" type="Nomad.NSystem.DateTime" mode="in" name="f_fin"/>
				<flow:param attr-path="#SOURCE:@e_cant_dias" mode="in" name="dias" type="Nomad.NSystem.Int"/>
				<flow:param attr-path="#SOURCE:@e_anio_corresp" mode="in" name="anio" type="Nomad.NSystem.Int"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#XML_RESULT:"/>
		</flow:action>
		<flow:action name="ValidarDelete">
			<flow:exec-method out-doc="XML_RESULT" class="NucleusRH.Base.Tiempos_Trabajados.LicenciasSec.LICENCIA_SEC" out-type="Nomad.NSystem.Proxy.NomadXML" method="ValidarDelete">
				<flow:param attr-path="#SOURCE:@ID" name="ID" type="Nomad.NSystem.String" mode="in"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#XML_RESULT:"/>
		</flow:action>
	</flow:main>
</flow:flow>
