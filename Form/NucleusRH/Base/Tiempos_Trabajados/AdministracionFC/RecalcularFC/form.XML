<form:Form xmlns:form="nomad_engine.form" default_mode="LIST" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.RecalcularFC.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Recalcular Francos Compensatorios" nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns width="100%" name="columnas">
			<form:Column valign="middle" width="100%" name="col2" separation="5" align="center">
				<form:ListView arr-control="listArr" visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
					<form:Event action="ListClick" name="OnClick" runat="client"/>
					<form:LVColumns>
						<form:LVColumn attrname="empresa" width="100px" name="empresa" label="Empresa" type="string" align="left" sorteable="1"/>
						<form:LVColumn attrname="legajo" width="100px" name="legajo" label="Legajo" type="string" align="left" sorteable="1"/>
						<form:LVColumn label="Fecha registro" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" attrname="f_registro_fc" name="f_registro_fc"/>
						<form:LVColumn additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Saldo" attrname="n_saldo" name="n_saldo"/>
						<form:LVColumn attrname="n_cant_aprob" name="n_cant_aprob" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Cantidad Aprobada"/>
						<form:LVColumn attrname="n_consumidos" name="n_consumidos" additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Consumidos"/>
					</form:LVColumns>
					<form:SButtons>
						<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
							<form:Event action="unmark" name="OnClick" runat="client"/>
						</form:SButton>
						<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
							<form:Event action="mark" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:ListView>
				<form:HiddenArr nvalue="#CHECKS:" proto="&lt;ROW /&gt;" name="listArr">
					<form:Attr source="@id" name="id"/>
				</form:HiddenArr>
			</form:Column>
		</form:Columns>
		<form:Hidden name="fecha_vencimiento" nvalue="#source:@fecha_vencimiento"/>
		<form:Blank name="blank1"/>
		<form:Hidden name="id" nvalue="#source:@id"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button img="page.gif" mess="&#191;Est&#225; seguro que desea blanquear el saldo?" descrip="Blanquear Saldo" label="Blanquear Saldo" name="BLANC" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW">
					<form:Event action="BLANC" name="onclick" runat="client"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desea recalcular los Francos Compensatorios?" img="refresh" label="Recalcular FC" descrip="Recalcular FC" name="RECALC" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW">
					<form:Event action="RECALC" name="onclick" runat="client"/>
				</form:Button>
				<form:Button label="Volver" name="BACK" img="back" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW" visible="SHOW|LIST" descrip="Volver">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources/>
	<form:Scripts>
		function ListClick()
{
	Ctrl("id").SetXValue(Ctrl("LIST").GetSelectAttrValue("id")); 
}                       

function BLANC()
{            
	if(Ctrl("listArr").CountRow()==0)
	{
		alert("Debe seleccionar al menos un registro.");
		return false;
	}   
	else
	{    
		Ctrl('main').DoEvent("BLANC");
	} 
}   

function RECALC()
{      
	if(Ctrl("listArr").CountRow()==0)
	{
		alert("Debe seleccionar al menos un registro.");
		return false;
	}  
	else 
	{
		Ctrl('main').DoEvent("RECALC");   
	}
}   
   
function unmark()
{	
	Ctrl("listArr").DelAllRow(); 
	Ctrl("LIST").SetXValue("");
}         

function mark()                                                
{   
	for(var X=0;X&lt;Ctrl("LIST").TotalRowsCount();X++)  
		Ctrl("listArr").AddRow().SetAttr("id",Ctrl("LIST").GetAttrValue(X,"id"));
	
	Ctrl("LIST").Refresh();      
}
	</form:Scripts>
	<form:Event name="BLANC" action="BLANC" runat="server"/>
	<form:Event name="RECALC" action="RECALC" runat="server"/>
</form:Form>
