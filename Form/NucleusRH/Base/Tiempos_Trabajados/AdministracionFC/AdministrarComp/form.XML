<form:Form xmlns:form="nomad_engine.form" default_mode="LIST" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.AdministrarComp.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Administraci&#243;n de Compensaciones" nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns width="100%" name="columnas">
			<form:Column valign="middle" width="100%" name="col2" separation="5" align="center">
				<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
					<form:Event action="ListClick" name="OnClick" runat="client"/>
					<form:LVColumns>
						<form:LVColumn attrname="empresa" width="100px" name="empresa" label="Empresa" type="string" align="left" sorteable="1"/>
						<form:LVColumn attrname="legajo" width="100px" name="legajo" label="Legajo" type="string" align="left" sorteable="1"/>
						<form:LVColumn label="Fecha Compensaci&#243;n" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" attrname="f_comp" name="f_comp"/>
						<form:LVColumn additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Cantidad Compensada" attrname="n_cant_comp" name="n_cant_comp"/>
						<form:LVColumn additional="&lt;OPTS&gt;&lt;OPT value=&quot;CD&quot; text=&quot;Al comienzo del d&#237;a&quot; /&gt;&lt;OPT value=&quot;FD&quot; text=&quot;Al final del d&#237;a&quot; /&gt;&lt;OPT value=&quot;CM&quot; text=&quot;En cualquier momento&quot; /&gt;&lt;/OPTS&gt;" align="left" sorteable="1" width="50px" type="enum" label="Rango" attrname="c_rango" name="c_rango"/>
						<form:LVColumn label="Fecha registro" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" attrname="f_registro_fc" name="f_registro_fc"/>
						<form:LVColumn align="left" sorteable="1" width="40px" type="string" label="Banco Hora" attrname="oi_banco_hora" name="oi_banco_hora"/>
						<form:LVColumn label="Fecha saldado" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" attrname="f_registro_s" name="f_registro_s"/>
						<form:LVColumn label="Fecha blanqueo" additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" attrname="f_blanqueo" name="f_blanqueo"/>
					</form:LVColumns>
				</form:ListView>
			</form:Column>
		</form:Columns>
		<form:Hidden name="fecha_vencimiento" nvalue="#source:@fecha_vencimiento"/>
		<form:Blank name="blank1"/>
		<form:Hidden name="id" nvalue="#source:@id"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" descrip="Eliminar un Registro" label="Eliminar" name="DELETE" img="del" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW">
					<form:Event action="Eliminar" name="onclick" runat="client"/>
				</form:Button>
				<form:Button img="search" descrip="Ejecutar Reporte" label="Reporte" name="REPORT" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW">
					<form:Event action="report" name="onclick" runat="server"/>
				</form:Button>
				<form:Button label="Volver" name="BACK" img="back" policy="NucleusRH/Base/Tiempos_Trabajados/AdministracionFC/NEW" visible="SHOW|LIST" descrip="Volver">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources/>
	<form:Scripts>
		function onLoad()
{                  
	Ctrl("id").SetXValue(Ctrl("LIST").GetSelectAttrValue("id")); 
    
}

function ListClick()
{
	Ctrl("id").SetXValue(Ctrl("LIST").GetSelectAttrValue("id")); 
  
}                       

function Eliminar()
{
	Ctrl('main').DoEvent("DELETE");   
}
	</form:Scripts>
	<form:Event name="DELETE" action="DELETE" runat="server"/>
	<form:Event name="onLoad" action="onLoad" runat="client"/>
</form:Form>
