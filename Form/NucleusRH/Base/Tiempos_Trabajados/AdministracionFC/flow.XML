<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.flow" extends="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.autoflow">
	<flow:declare>
		<qry:define name="COUNT">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
			
			MAXSIZE 301
			SELECT
				COUNT(t0.oi_registro_fc) as cant
			FROM
				TTA20_REGISTRO_FC as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC\') as SEC
			JOIN
				t0.oi_registro_fc LEFT OUTER SEC.id
			WHERE
				1=1
				{%?($PARAM/@oi_personal_emp != '') {% AND t0.oi_personal_emp = {$PARAM/@oi_personal_emp} %} {% %} %}
				{%?($PARAM/@oi_banco_hora != '') {% AND t0.oi_banco_hora = {$PARAM/@oi_banco_hora} %} {% %} %}
				{%?($PARAM/@f_desde != '') {% AND t0.f_registro_fc &gt;= {$PARAM/@f_desde} %} {% %} %}
				{%?($PARAM/@f_hasta != '') {% AND t0.f_registro_fc &lt;= {$PARAM/@f_hasta} %} {% %} %}
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:if test="$r/@cant &gt;= 1 and $r/@cant &lt;= 300">
							<qry:then>
								<qry:attribute name="list" value="1"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="list" value="0"/>
							</qry:else>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="FILTER">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('

			SELECT
				t0.oi_registro_fc as oi_registro_fc,
				SEC.policy
			FROM
				TTA20_REGISTRO_FC as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC\') as SEC
			JOIN
				t0.oi_registro_fc LEFT OUTER SEC.id
			WHERE
				1=1
				{%?($PARAM/@oi_personal_emp != '') {% AND t0.oi_personal_emp = {$PARAM/@oi_personal_emp} %} {% %} %}
				{%?($PARAM/@oi_banco_hora != '') {% AND t0.oi_banco_hora = {$PARAM/@oi_banco_hora} %} {% %} %}
				{%?($PARAM/@f_desde != '') {% AND t0.f_registro_fc &gt;= {$PARAM/@f_desde} %} {% %} %}
				{%?($PARAM/@f_hasta != '') {% AND t0.f_registro_fc &lt;= {$PARAM/@f_hasta} %} {% %} %}
			ORDER BY
				oi_registro_fc asc
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_registro_fc"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.INFO"/>
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('

			SELECT
				t0.oi_registro_fc as oi_registro_fc,
				t0.f_registro_fc as f_registro_fc,
				t0.n_cant_gen as n_cant_gen,
				t0.n_cant_aprob as n_cant_aprob,
				t0.n_cant_aprob_ant as n_cant_aprob_ant,
				t0.n_consumidos as n_consumidos,
				t0.n_saldo as n_saldo,
				t0.l_aprob as l_aprob,
				t0.l_reaprob as l_reaprob,
				t0.f_registro_s as f_registro_s,
				t0.f_blanqueo as f_blanqueo,
				SEC.policy,
				t0.f_registro_fc as CODE,
				t0.f_registro_fc as TEXT,
				t0.oi_banco_hora as oi_banco_hora,
				t0.oi_personal_emp as oi_personal_emp,
				TTA21_BANCO_HORA.c_unidad_tiempo
			FROM
				TTA20_REGISTRO_FC as t0,
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC\') as SEC,
				TTA21_BANCO_HORA
			JOIN
				t0.oi_registro_fc LEFT OUTER SEC.id,
				t0.oi_banco_hora LEFT OUTER TTA21_BANCO_HORA.oi_banco_hora   
			WHERE
				1=1
				{%?($PARAM/@oi_personal_emp != '') {% AND t0.oi_personal_emp = {$PARAM/@oi_personal_emp} %} {% %} %}
				{%?($PARAM/@oi_banco_hora != '') {% AND t0.oi_banco_hora = {$PARAM/@oi_banco_hora} %} {% %} %}
				{%?($PARAM/@f_desde != '') {% AND t0.f_registro_fc &gt;= {$PARAM/@f_desde} %} {% %} %}
				{%?($PARAM/@f_hasta != '') {% AND t0.f_registro_fc &lt;= {$PARAM/@f_hasta} %} {% %} %}
			ORDER BY
				oi_registro_fc asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_registro_fc"/>
						<qry:attribute name="f_registro_fc" value="$r/@f_registro_fc"/>
						<qry:attribute name="n_cant_gen" value="$r/@n_cant_gen"/>
						<qry:attribute name="n_cant_aprob" value="$r/@n_cant_aprob"/>
						<qry:attribute name="n_cant_aprob_ant" value="$r/@n_cant_aprob_ant"/>
						<qry:attribute name="n_consumidos" value="$r/@n_consumidos"/>
						<qry:attribute name="n_saldo" value="$r/@n_saldo"/>
						<qry:attribute name="l_aprob" value="iif($r/@l_aprob='1','1','0')"/>
						<qry:attribute name="l_reaprob" value="iif($r/@l_reaprob='1','1','0')"/>
						<qry:attribute name="f_registro_s" value="$r/@f_registro_s"/>
						<qry:attribute name="f_blanqueo" value="$r/@f_blanqueo"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_banco_hora_l" value="$r/@oi_banco_hora"/>
						<qry:if test="$r/@oi_banco_hora!=''">
							<qry:then>
								<qry:element name="oi_banco_hora">
									<qry:attribute name="OI_FIND" value="$r/@oi_banco_hora"/>
									<qry:insert-select name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_banco_hora" value="'['+oi_banco_hora/ROW/@COD+'] '+oi_banco_hora/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<!--qry:attribute name="c_unidad_tiempo" value="iif($r/@c_unidad_tiempo = 'M', 'M - Minutos', 'H - Horas')"/-->
						<qry:switch test="$r/@c_unidad_tiempo">
							<qry:case value="H">
								<qry:attribute name="c_unidad_tiempo" value="'H - Horas'"/>
							</qry:case>
							<qry:case value="M">
								<qry:attribute name="c_unidad_tiempo" value="'M - Minutos'"/>
							</qry:case>
							<qry:default>
								<qry:attribute name="c_unidad_tiempo" value="''"/>
							</qry:default>
						</qry:switch>
						<qry:if test="$r/@c_unidad_tiempo!='M'">
							<qry:then>
								<qry:attribute name="t_cant_gen" value="concat(fill-left(floor(number(@n_cant_gen)),'0',2),':',fill-left(round(number(@n_cant_gen)*60.0) mod 60,'0',2))"/>
								<qry:attribute name="t_cant_aprob" value="concat(fill-left(floor(number(@n_cant_aprob)),'0',2),':',fill-left(round(number(@n_cant_aprob)*60.0) mod 60,'0',2))"/>
								<qry:attribute name="t_cant_aprob_ant" value="concat(fill-left(floor(number(@n_cant_aprob_ant)),'0',2),':',fill-left(round(number(@n_cant_aprob_ant)*60.0) mod 60,'0',2))"/>
								<qry:attribute name="t_consumidos" value="concat(fill-left(floor(number(@n_consumidos)),'0',2),':',fill-left(round(number(@n_consumidos)*60.0) mod 60,'0',2))"/>
								<qry:attribute name="t_saldo" value="concat(fill-left(floor(number(@n_saldo)),'0',2),':',fill-left(round(number(@n_saldo)*60.0) mod 60,'0',2))"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="t_cant_gen" value="concat(fill-left(floor(number(@n_cant_gen) div 60),'0',2),':',fill-left(number(@n_cant_gen) mod 60,'0',2))"/>
								<qry:attribute name="t_cant_aprob" value="concat(fill-left(floor(number(@n_cant_aprob) div 60),'0',2),':',fill-left(number(@n_cant_aprob) mod 60,'0',2))"/>
								<qry:attribute name="t_cant_aprob_ant" value="concat(fill-left(floor(number(@n_cant_aprob_ant) div 60),'0',2),':',fill-left(number(@n_cant_aprob_ant) mod 60,'0',2))"/>
								<qry:attribute name="t_consumidos" value="concat(fill-left(floor(number(@n_consumidos) div 60),'0',2),':',fill-left(number(@n_consumidos) mod 60,'0',2))"/>
								<qry:attribute name="t_saldo" value="concat(fill-left(floor(number(@n_saldo) div 60),'0',2),':',fill-left(number(@n_saldo) mod 60,'0',2))"/>
							</qry:else>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST:NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.COMP_FC">
			<qry:main doc="PARAM" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:./COMP_FC[substring_before(@nmd-status,',')!='~d' and substring_before(@nmd-status,',')!='~x']" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in #PARAM:
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:attribute name="f_comp" value="$r/@f_comp"/>
						<qry:attribute name="n_cant_comp" value="$r/@n_cant_comp"/>
						<qry:attribute name="c_rango" value="$r/@c_rango"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:insert-select name="sql2" doc-path="$r"/>
						<qry:if test="@c_unidad_tiempo!='M'">
							<qry:then>
								<qry:attribute name="t_cant_comp" value="concat(fill-left(floor(number($r/@n_cant_comp)),'0',2),':',fill-left(round(number($r/@n_cant_comp)*60.0) mod 60,'0',2))"/>
							</qry:then>
							<qry:else>
								<qry:attribute name="t_cant_comp" value="concat(fill-left(floor(number($r/@n_cant_comp) div 60),'0',2),':',fill-left(number($r/@n_cant_comp) mod 60,'0',2))"/>
							</qry:else>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in sql('
			SELECT 
				TTA21_BANCO_HORA.c_unidad_tiempo
			FROM 
				TTA20_REGISTRO_FC,
				TTA21_BANCO_HORA
			JOIN 
				TTA20_REGISTRO_FC.oi_banco_hora LEFT OUTER TTA21_BANCO_HORA.oi_banco_hora
			WHERE   
				TTA20_REGISTRO_FC.oi_registro_fc = {$PARAM/@oi_registro_fc}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_unidad_tiempo" value="$r/@c_unidad_tiempo"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="BANCOHORAS"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="REGISTRO_FC">
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC.filter.autoform:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC.filter.form" mode="FILTER">
			<flow:action name="on-show"/>
			<flow:action name="open-flow-LIST">
				<flow:open-form next-action="open-flow-LIST" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC.noreg.autoform"/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:call-action action="Save-FILTER"/>
				<doc:load-qry output-doc="QRY" qry="COUNT" input-doc-path="#FILTERDATA:"/>
				<flow:call-action else="FILTER-SHOW" action="FILTER-LIST" eq="1" if="#QRY:ROW/@list"/>
			</flow:action>
			<flow:action name="FILTER-LIST">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="open-flow-LIST"/>
			</flow:action>
			<flow:action name="FILTER-SHOW">
				<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="open-flow-SHOW"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
