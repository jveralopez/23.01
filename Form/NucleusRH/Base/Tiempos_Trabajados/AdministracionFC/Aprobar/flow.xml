<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.flow" default_action="initialize" extends="Nomad.Base.flow">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<ROWS/>
			</FILTRO>
		</doc:define>
		<qry:define declare="&lt;FILTRO&gt;&#13;&#10;&#9;&lt;ROWS&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;15958&quot;/&gt;&#13;&#10;&#9;&lt;/ROWS&gt;           &#13;&#10;&lt;/FILTRO&gt;" name="LIST">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('   
			
					SELECT 		
						TTA20_REGISTRO_FC.oi_personal_emp,
						TTA20_REGISTRO_FC.oi_banco_hora,
						TTA21_BANCO_HORA.c_banco_hora,
						TTA21_BANCO_HORA.d_banco_hora,  
						MAX(TTA20_REGISTRO_FC.oi_registro_fc) as oi_registro_fc,
						SUM(TTA20_REGISTRO_FC.n_saldo) as n_saldo
					FROM 
						TTA20_REGISTRO_FC, 
						TTA21_BANCO_HORA
					JOIN
					    TTA20_REGISTRO_FC.oi_banco_hora INNER TTA21_BANCO_HORA.oi_banco_hora
					WHERE 
						TTA20_REGISTRO_FC.l_aprob=0
						AND TTA20_REGISTRO_FC.oi_personal_emp in ({%=string(#SOURCE:FILTRO/ROWS/ROW/@id) %})	
						AND TTA20_REGISTRO_FC.f_registro_fc &gt;= {Datetime(#SOURCE:FILTRO/@f_desde)} 
						AND TTA20_REGISTRO_FC.f_registro_fc &lt;= {Datetime(#SOURCE:FILTRO/@f_hasta)} 				
                    GROUP BY 
                    	TTA20_REGISTRO_FC.oi_personal_emp,
						TTA20_REGISTRO_FC.oi_banco_hora,
						TTA21_BANCO_HORA.c_banco_hora,
						TTA21_BANCO_HORA.d_banco_hora
						
     	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_registro_fc" name="id"/>
						<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
						<qry:attribute value="concat('[',$r/@c_banco_hora,'] ',$r/@d_banco_hora)" name="oi_banco_hora"/>
						<qry:attribute value="$r/@n_saldo" name="n_saldo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="QRY_LIST"/>
		<doc:define name="DOC">
			<DOC>
				<IDS/>
				<APROBADOS/>
			</DOC>
		</doc:define>
		<qry:define name="COUNT" declare="&lt;FILTRO&gt;&#13;&#10;&#9;&lt;ROWS&gt;&#13;&#10;&#9;&#9;&lt;ROW id=&quot;15958&quot;/&gt;&#13;&#10;&#9;&lt;/ROWS&gt;           &#13;&#10;&lt;/FILTRO&gt;">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="RESULT">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('   
			
					SELECT 		
						COUNT(TTA20_REGISTRO_FC.oi_registro_fc) as count
					FROM 
						TTA20_REGISTRO_FC, 
						TTA21_BANCO_HORA
					JOIN
					    TTA20_REGISTRO_FC.oi_banco_hora INNER TTA21_BANCO_HORA.oi_banco_hora
					WHERE 
						TTA20_REGISTRO_FC.l_aprob=0
						AND TTA20_REGISTRO_FC.oi_personal_emp in ({%=string(#SOURCE:FILTRO/ROWS/ROW/@id) %})	
						AND TTA20_REGISTRO_FC.f_registro_fc &gt;= {Datetime(#SOURCE:FILTRO/@f_desde)} 
						AND TTA20_REGISTRO_FC.f_registro_fc &lt;= {Datetime(#SOURCE:FILTRO/@f_hasta)} 				
						
     	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/@count"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="QRY_COUNT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar" doc="FILTERDATA"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#FILTERDATA:ROWS"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:load-qry input-doc-path="#FILTERDATA:" output-doc="QRY_LIST" qry="LIST"/>
			<doc:load-qry output-doc="QRY_COUNT" qry="COUNT" input-doc-path="#FILTERDATA:"/>
			<doc:set-attribute to-attr-path="#DOC:@f_desde" from-attr-path="#SOURCE:@f_desde"/>
			<doc:set-attribute to-attr-path="#DOC:@f_hasta" from-attr-path="#SOURCE:@f_hasta"/>
			<flow:call-action eq="0" action="noreg" if="#QRY_COUNT:@count" else="open-flow-LIST"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DOC:" mode="LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.form"/>
		</flow:action>
		<flow:action name="noreg">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.noreg.form" doc-path="#SOURCE:" mode="EDIT"/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.form:LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.form" mode="LIST">
		<flow:action name="CANCELAR">
			<flow:close-form next-action="on-show"/>
		</flow:action>
		<flow:action name="APROBAR">
			<flow:exec-method priority="3" out-attr-path="#BATCHDOC:@batch-id" class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.REGISTRO_FC" method="AprobarFC">
				<flow:param doc-path="#DOC:APROBADOS" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="aprobados"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
		</flow:action>
	</flow:form>
	<flow:form mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.noreg.form" name="NucleusRH.Base.Tiempos_Trabajados.AdministracionFC.Aprobar.noreg.form:EDIT" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form next-action="on-show"/>
		</flow:action>
	</flow:form>
</flow:flow>
