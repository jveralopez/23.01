<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.autoflow" default_action="initialize" name="NucleusRH.Base.Tiempos_Trabajados.Turnos">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.Turnos"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_turno as oi_turno,
					t0.c_turno
				FROM 
					TTA14_TURNOS as t0 
				ORDER BY 
					c_turno asc
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_turno"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_turno as oi_turno, 
					t0.c_turno as c_turno, 
					t0.d_turno as d_turno, 
					t0.c_color as c_color, 
					t0.c_turno as CODE, 
					t0.d_turno as TEXT, 
					t0.c_estado as c_estado  
					FROM 
						TTA14_TURNOS as t0 
					ORDER BY c_turno asc
			 ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="img" value="iif($r/@c_estado='C','Listas/LOCK.ICO','')"/>
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_turno"/>
						<qry:attribute name="c_turno" value="$r/@c_turno"/>
						<qry:attribute name="d_turno" value="$r/@d_turno"/>
						<qry:attribute name="c_color" value="$r/@c_color"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="retdoc">
			<retdoc id=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="SHOW">
			<flow:open-form next-action="SHOW" mode="HORARIO" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.autoform" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form mode="EDIT" extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.autoform">
		<flow:action name="open-flow-SHOW">
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="open-flow-ADD">
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="open-flow-LIST">
			<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form:NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form" mode="NEW"/>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form:EDIT" extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form" mode="EDIT"/>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form:SHOW" extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form" mode="SHOW">
		<flow:action name="open-flow-EDIT">
			<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="open-flow-ADD">
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="CLOSE">
			<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="C"/>
			<flow:call-action action="save-DDO"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form:LIST" extends="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form" mode="LIST">
		<flow:action name="open-flow-EDIT">
			<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="open-flow-ADD">
			<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.form"/>
		</flow:action>
		<flow:action name="CLOSE">
			<flow:call-action action="load-DDO"/>
			<doc:set-attribute to-attr-path="#DDO:@c_estado" from-value="C"/>
			<flow:call-action action="save-DDO"/>
			<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
			<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
			<doc:load-qry output-doc="QRY" qry="FILTER" input-doc-path="#FILTERDATA:"/>
			<doc:iter-refresh/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.noreg.autoform:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.noreg.autoform" mode="EDIT">
		<flow:action name="on-show">
			<flow:close-form/>
			<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form"/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.noreg.autoform:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.noreg.autoform" mode="SHOW">
		<flow:action name="on-show">
			<flow:close-form/>
			<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form"/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="#PARENTSOURCE:" mode="EDIT" doc="#SOURCE:" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form">
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#DDO:TURNOS_DET" attach-id="RS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SAVE">
			<flow:exec-method this-doc="DDO" method="ActualizarTurnos">
				<flow:param attr-path="#FORM:ctrl[@id='RES']/@xval" type="Nomad.NSystem.String" mode="in" name="RES"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form parent-doc="#PARENTSOURCE:" mode="SHOW" doc="#SOURCE:" name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNODET.form">
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#DDO:TURNOS_DET" attach-id="RS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.form:HORARIO" mode="HORARIO" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.autoform">
		<flow:action name="on-show"/>
		<flow:action name="SHOW">
			<doc:new-object doc="DDO" class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO"/>
			<doc:new-object doc="NEWDDOROOT" class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO"/>
			<doc:assign-value from-path="#SOURCE:" to-doc="QRY"/>
			<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Turnos.TURNO.noreg.autoform"/>
		</flow:action>
		<flow:action name="After-Back">
			<flow:exit-flow return-path="#retdoc:"/>
		</flow:action>
		<flow:action name="After-Change">
			<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#retdoc:@id"/>
			<flow:exit-flow return-path="#retdoc:"/>
		</flow:action>
	</flow:form>
</flow:flow>
