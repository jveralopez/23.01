<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.Base.flow" name="NucleusRH.Base.Tiempos_Trabajados.CambioTurno.flow">
	<flow:info label="flow para NucleusRH.Base.Tiempos_Trabajados.VerificarFichadas"/>
	<flow:declare>
		<doc:define name="DATAGRID">
			<ROWS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#DATAGRID:" form-class="NucleusRH.Base.Tiempos_Trabajados.CambioTurno.CAMBIOTURNO.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.CambioTurno.CAMBIOTURNO.form:SHOW" mode="SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.CambioTurno.CAMBIOTURNO.form">
		<flow:action name="EXECUTE">
			<flow:exec-method priority="5" out-attr-path="#BATCHDOC:@batch-id" class="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP" method="CargarCambioTurno">
				<flow:param doc="DATAGRID" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
