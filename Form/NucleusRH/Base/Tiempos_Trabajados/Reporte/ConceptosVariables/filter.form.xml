<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" name="ReporteConceptosVariables" doc="source">
	<form:Title>
		<form:Label label="Conceptos por Variables" name="lbl" style="S3 LCol_w"/>
	</form:Title>
	<form:Center>
		<form:Blank height="30" name="blk01" width="100%" visible=""/>
		<form:Combo name="c_tipo_variable" label="Tipo de Variable" nvalue="#source:@c_tipo_variable">
			<form:Opts name="opciones">
				<OPT text="Auxiliar" value="AUX"/>
				<OPT text="Persona Acumulador" value="PERACC"/>
				<OPT text="Persona Fijo" value="PERFIJ"/>
				<OPT text="Persona Novedad" value="PERNOV"/>
				<OPT text="Procesamiento Novedad" value="LIQNOV"/>
				<OPT text="Tipo de Hora" value="TIPHOR"/>
			</form:Opts>
		</form:Combo>
		<form:Blank height="15" name="blk02" width="100%" visible=""/>
		<form:ComboBox name="oi_tipohora" label="Tipo de Hora" nvalue="#source:@oi_tipohora" queryname1="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO" xsize="40" mode="QRY" required="0"/>
		<form:Blank height="15" name="blk03" width="100%" visible=""/>
		<form:Combo name="c_tipo_dato" label="Tipo de Dato" nvalue="#source:@c_tipo_dato">
			<form:Opts name="opciones">
				<OPT text="Decimal" value="double"/>
				<OPT text="Entero" value="int"/>
				<OPT text="Fecha" value="DateTime"/>
				<OPT text="L&#243;gico" value="bool"/>
			</form:Opts>
		</form:Combo>
		<form:Blank height="15" name="blk04" width="100%" visible=""/>
		<form:CheckBox name="l_con_conceptos" label="Con Conceptos" nvalue="#source:@l_con_conceptos"/>
		<form:Blank height="15" name="blk05" width="100%" visible=""/>
		<form:CheckBox label="Conceptos Activos" name="l_conceptos_activos" nvalue="#source:@l_conceptos_activos"/>
		<form:Blank height="15" name="blk06" width="100%" visible=""/>
		<form:TextBox name="d_variable" xsize="40" label="Variable (descripci&#243;n)" nvalue="#source:@d_variable"/>
		<form:Blank height="15" name="blk07" width="100%" visible=""/>
		<form:ComboBox name="oi_variable" queryname1="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.INFO" nvalue="#source:@oi_variable" label="Variable" xsize="40" mode="QRY" required="0"/>
		<form:Hidden nvalue="#PROXY:DATA/@USER" name="user"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botonera" columns="3">
			<form:Row name="row">
				<form:Button enabled="" visible="" startvalidate="1" img="ok" name="btnAceptar" label="Aceptar" descrip="">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="blk08" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts/>
</form:Form>
