<form:Form name="FiltroCalendarEsp" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label label="Seleccionar Filtro Reporte Calendario Esperanza Horaria" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="85%">
		<form:Label visible="" style="S3 LCol_g" align="center" label="Criterios de Busqueda" name="lbl"/>
		<form:Blank visible="" width="100px" name="bl1111"/>
		<form:RowAligner name="rowfecha">
			<form:Row name="row1">
				<form:DateTime name="f_des" nvalue="#FILTERDATA:@f_des" label="Fecha Inicio" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event runat="client" name="onvalidate" action="VALIDARRANGOFECHA"/>
				</form:DateTime>
				<form:Blank width="100px" visible="" name="bl1"/>
				<form:DateTime min="" name="f_has" nvalue="#FILTERDATA:@f_has" label="Fecha Fin" mask="dd/mm/yyyy" enabled="" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event runat="client" name="onvalidate" action="VALIDARRANGOFECHAF"/>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="blk2"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo name="oi_empresa" nvalue="#FILTERDATA:@oi_empresa" label="Empresa" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
				<form:FKInput nvalue="#FILTERDATA:@oi_horario" required="1" xsize="15" length="30" label="Horario" name="oi_horario">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank name="blk3"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function VALIDARRANGOFECHA(myThis)
				{ 	
					if (myThis.TypedValue() &gt; Ctrl("f_has").TypedValue())
						{
							myThis.SetError('La fecha de inicio es mayor que la fecha de fin');
							return false;						
						}					
						else return true;												
				}					

    

function VALIDARRANGOFECHAF(myThis)
				{ 
					if (Ctrl("f_des").TypedValue() == "" &amp;&amp; myThis.TypedValue()  != "")
						{
							myThis.SetError('El rango de fechas especificado no es correcto');
							return false;						
						}					
						else return true;												
				}

function SetTime()
{
	Ctrl('f_des').SetTypedValue(Now());
	Ctrl('f_has').SetTypedValue(Now());		
}
	</form:Scripts>
	<form:Event action="SetTime" name="onload" runat="client"/>
</form:Form>
