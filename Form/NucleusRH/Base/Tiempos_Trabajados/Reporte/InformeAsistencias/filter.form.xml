<form:Form xmlns:form="nomad_engine.form" name="InformeAsistenciafilter" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" doc="source">
	<form:Title>
		<form:Label label="103 - Informe de Asistencias" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo visible="0" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:CheckBox label="Fichadas Anuladas" nvalue="#source:@anuladas" name="anuladas"/>
				</form:Column>
				<form:Column label="Informaci&#243;n a mostrar" name="col2ext" valign="top" align="left">
					<form:CheckBox label="Presencias" nvalue="#source:@presencias" name="presencias"/>
					<form:CheckBox label="Tardanzas y Retiros Anticipados" nvalue="#source:@tardanzas" name="tardanzas"/>
					<form:CheckBox label="Ausencias" nvalue="#source:@ausencias" name="ausencias"/>
					<form:CheckBox nvalue="#source:@licencias" label="Francos / Licencias" name="lic"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Scripts/>
</form:Form>
