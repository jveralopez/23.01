<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Tiempos_Trabajados.Reportes.Legajo.flow" extends="NucleusRH.Base.Personal.Reportes.Legajo.flow" default_action="initialize">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo.filter.form" doc-path="#PARAMETERS:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo.filter.form" doc="PARAMETERS" name="NucleusRH.Base.Tiempos_Trabajados.Legajo.form:FILTER" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="PARAMETROS" text-path="#PARAMETERS:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Tiempos_Trabajados.Legajo.rpt" input-doc-path="#PARAMETERS:" out-file-path="#PARAMETERS:@report"/>
			<flow:open-form doc-path="#PARAMETERS:" mode="REPORT" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo.form"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo" doc="PARAMETERS"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo" doc-path="#PARAMETERS:"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusRH.Base.Personal.Reportes.Legajo.form:REPORT" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo.form" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.Legajo.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
