	<form:Scripts>
		function sel4()		
		{
			if (Ctrl('Horarios').GetCValue() =="0")
			{
				
				Ctrl('Horarios').SetCValue(1);
				Ctrl('Novedades').SetCValue(1);
				Ctrl('Licencias').SetCValue(1);
				Ctrl('Autorizaciones').SetCValue(1);
				Ctrl('Tarjetas').SetCValue(1);
			}else
			{				
				Ctrl('Horarios').SetCValue(0);
				Ctrl('Novedades').SetCValue(0);
				Ctrl('Licencias').SetCValue(0);
				Ctrl('Autorizaciones').SetCValue(0);
				Ctrl('Tarjetas').SetCValue(0);
			}			
		}
