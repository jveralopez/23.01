<form:Form name="Novedadesfilter" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Esperanza Horaria del Personal" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Columns name="columsewew">
			<form:Column name="ewcol43">
				<form:Combo nvalue="#FILTERDATA:@FormatRPT" action="COMBO" required="1" flow="Nomad.Base.report.cboFormatRpt.enum" name="Formato" label="Formato del Reporte"/>
			</form:Column>
		</form:Columns>
		<form:RowAligner visible="FILTER" name="rowfecha">
			<form:Row name="row1">
				<form:DateTime nvalue="#FILTERDATA:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl1" width="75px" visible=""/>
				<form:DateTime name="f_hasta" nvalue="#FILTERDATA:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" nvalue="#FILTERDATA:@oi_empresa" name="oi_empresa"/>
				<form:Combo name="oi_clase_org" nvalue="#FILTERDATA:@oi_clase_org" label="Clase" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO">
					<form:Event runat="client" name="onchange" action="VALIDAR"/>
				</form:Combo>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl4123dsdsww44" width="100%" visible=""/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="4" descrip="" note="" name="grdEstructura">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Estructura Organizativa" cache="no" required="0" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank name="bl4123" width="100%" visible=""/>
		<form:Grid name="grdPersonal" note="" descrip="" rows="4" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.GUIA_COMPLEJO.FLOW" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Empresa - Legajo" required="0" enabled="" xsize="15" length="30" nvalue="#SOURCEGRILLA:oi_personal_emp/@value" name="oi_personal_emp">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
