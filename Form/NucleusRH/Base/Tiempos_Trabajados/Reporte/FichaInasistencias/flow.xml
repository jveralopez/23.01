<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.base.HTML_XLS.flow" name="Ficha de Inasistencias">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO/>
		</doc:define>
		<doc:define name="LEGAJO">
			<LEGAJO/>
		</doc:define>
		<qry:define declare="&lt;FILTRO oi_personal_emp=&quot;11565&quot; /&gt;" name="QRY_DESCR">
			<qry:main doc="SOURCE">
				<qry:element name="DESCR">
					<qry:insert-select name="QRY_DESCR" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_DESCR" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom
				FROM PER01_PERSONAL, PER02_PERSONAL_EMP
				JOIN PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal 
				WHERE PER02_PERSONAL_EMP.oi_personal_emp = {#SOURCE:@oi_personal_emp}
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="descr" value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom"/>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.filter.form">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#FILTERDATA:" name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="FILTERDATA" name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:load-qry input-doc-path="#FILTERDATA:" output-doc="LEGAJO" qry="QRY_DESCR"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.FICHAINASISTENCIAS.form" parent-doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.FICHAINASISTENCIAS.form" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.FichaInasistencias.FICHAINASISTENCIAS.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
