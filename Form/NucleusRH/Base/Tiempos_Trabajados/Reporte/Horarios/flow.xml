<flow:flow extends="Nomad.Base.flow" name="ReporteHorarios" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="ReporteHorarios"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="" oi_estructura="" oi_empresa="" f_des="" f_has="" c_estado="">
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Horarios.filter.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.Horarios.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Horarios.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:assign-mapping a-doc="FORM" b-doc="FILTERDATA" dir-apply="a-&gt;b">
				<map docA="A" docB="B">
					<submap path-docA="#A:ctrl[@id='grdPersonal']/rows" path-docB="#B:PERSONAS">
						<map docA="A" docB="B">
							<link A="#A:columns/ctrl[@id='oi_personal_emp']/@xval" B="#B:@id"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<PERSONA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:log text-path="#FILTERDATA:" text="ppfilterdata"/>
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.Horarios\horarios.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
