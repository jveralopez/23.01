<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="ReporteCompensaciones">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<PERSONAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Compensaciones.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.Compensaciones.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Compensaciones.filter.form">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.Compensaciones" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.Compensaciones" doc="SOURCE"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.Compensaciones.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="207 - Listado de Compensaciones" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc doc-path="#FILTERDATA:PERSONAS" attach-id="ARRB"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
