<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="Nomad.base.HTML_XLS.flow" name="ReporteProcesoAsistencias">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="" ausencias="1" presencias="1" tardanzas="1" licencias="1">
				<ROWS/>
				<TH/>
			</FILTRO>
		</doc:define>
		<qry:define name="QRY_HT">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="HT"/>
				</qry:element>
			</qry:main>
			<qry:select name="HT" doc="">
				<qry:xquery>
					for $r in SQL('select T.oi_grupo_th as id, T.d_grupo_th as des from TTA13_GRUPOS_TH as T')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@id" name="id"/>
						<qry:attribute value="$r/@des" name="des"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="HT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry qry="QRY_HT" output-doc="HT"/>
			<flow:log text-path="#HT:" text="JOCHE"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ProcesoAsistencias.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.ProcesoAsistencias.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ProcesoAsistencias.filter.form">
		<flow:action name="on-show">
			<flow:attach-doc attach-id="HT" doc-path="#HT:"/>
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.IAP" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.IAP" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="CreateReportAssistencia" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.ESPERANZAPER">
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
