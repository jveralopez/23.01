<form:Form xmlns:form="nomad_engine.form" name="InformeAsistenciafilter" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" doc="source">
	<form:Title>
		<form:Label label="Informe de Asistencias y Horas Procesadas" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:DateTime name="f_hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Column>
				<form:Column label="Informaci&#243;n a mostrar" name="col2ext" valign="top" align="left">
					<form:ListView docname="HT" arr-control="HT" nvalue="#source:@selected" rows="4" width="300px" label="Tipos de Horas" name="TiposHoras">
						<form:LVColumns>
							<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Tipo de Hora" name="des"/>
						</form:LVColumns>
						<form:SButtons>
							<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
								<form:Event action="FullHT" name="OnClick" runat="client"/>
							</form:SButton>
							<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
								<form:Event action="ClearHT" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:ListView>
					<form:HiddenArr nvalue="#source:TH" proto="&lt;H /&gt;" name="HT">
						<form:Attr name="id"/>
					</form:HiddenArr>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup visible="0" nvalue="#source:@gformat" border="1" width="90%" collapse="1" label="Selecci&#243;n de formato de salida" name="vgroupFormat"/>
	</form:Center>
	<form:Scripts>
		function SetTodo()
{
	Ctrl("presencias").SetXValue("1");
	Ctrl("ausencias").SetXValue("1");
	Ctrl("tardanzas").SetXValue("1");	
}

function UnSetTodo()
{
	if ( Ctrl("presencias").GetXValue() != "1" || Ctrl("ausencias").GetXValue() != "1" ||	Ctrl("tardanzas").GetXValue()	!= "1")
	{
		Ctrl("todo").SetXValue("0");	
	}
}

function ClearHT()
{
	Ctrl("HT").DelAllRow();
	Ctrl("TiposHoras").Refresh();
}

function FullHT()
{
	Ctrl("HT").DelAllRow();     
	for (var t=0; t&lt;Ctrl("TiposHoras").TotalRowsCount(); t++)
		Ctrl("HT").AddRow().SetAttr("id", Ctrl("TiposHoras").GetAttrValue(t, "id"));
	
	Ctrl("TiposHoras").Refresh();
}
	</form:Scripts>
</form:Form>
