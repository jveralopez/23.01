<flow:flow name="vhora" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow guia para vhora.combo"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry qry="COMBO" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:element name="OPT">
						<qry:attribute name="value" value="&apos;S&apos;" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="&apos;S&apos;" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="&apos;Sector&apos;" type="Nomad.NSystem.String"/>
					</qry:element>
					<qry:element name="OPT">
						<qry:attribute name="value" value="&apos;C&apos;" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="&apos;C&apos;" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="&apos;Categoria&apos;" type="Nomad.NSystem.String"/>
					</qry:element>									
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
</flow:flow>


