<flow:flow extends="Nomad.Base.Report.flow" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" xmlns:flow="nomad_engine.flow">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.flow"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<ROWS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form:FILTER" doc="PARAMETERS" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" mode="FILTER">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text="ppsourcerep" text-path="#SOURCE:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#SOURCE:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#SOURCE:@salida" action="ACCEPTEXCEL"/>
			<flow:open-form form-class="Nomad.report.form" doc-path="#FILTERDATA:" mode="REPORT"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte" doc="SOURCE"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen template-file="NucleusRH.Base.Tiempos_Trabajados.NombreReporte.rpt" ext="html" input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="Nomad.report.form" doc-path="#FILTERDATA:" mode="REPORT"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen template-file="NucleusRH.Base.Tiempos_Trabajados.NombreReporte.rpt" ext="xls" input-doc-path="#FILTERDATA:" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="Nomad.report.form" doc-path="#FILTERDATA:" mode="REPORT"/>
		</flow:action>
	</flow:form>
</flow:flow>
