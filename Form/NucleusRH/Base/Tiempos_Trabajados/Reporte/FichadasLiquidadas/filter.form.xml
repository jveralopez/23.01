<form:Form doc="source" xmlns:form="nomad_engine.form" name="PlanillaHorariosfilter">
	<form:Title>
		<form:Label label="Fichadas Procesadas" visible="" style="S3 LCol_w" align="center" name="lbl"/>
	</form:Title>
	<form:Center>
		<form:Label visible="" style="S3 LCol_g" align="center" label="Criterios de B&#250;squeda" name="lbl"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo nvalue="#FILTERDATA:@FormatRPT" action="COMBO" required="1" flow="Nomad.Base.report.cboFormatRpt.enum" name="Formato" label="Formato del Reporte"/>
				<form:Combo name="oi_clase_org" nvalue="#FILTERDATA:@oi_clase_org" label="Clase" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
				<form:FKInput label="Empresa - Procesamiento" nvalue="#FILTERDATA:@oi_liquidacion" name="oi_liquidacion" xsize="15" required="1" length="30">
					<form:STexts>
						<form:SText xsize="50"/>
					</form:STexts>
					<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.autoflow">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput required="0" xsize="15" length="30" label="Pa&#237;s - Provincia - Localidad" nvalue="#FILTERDATA:@oi_localidad" name="oi_localidad">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput nvalue="#FILTERDATA:@oi_convenio" required="0" xsize="15" length="30" label="Convenio" name="oi_convenio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput required="0" xsize="15" length="30" label="Convenio - Categoria" nvalue="#FILTERDATA:@oi_categoria" name="oi_categoria">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CATEGORIA.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:RowAligner visible="FILTER" name="rowfecha">
			<form:Row name="row1">
				<form:DateTime nvalue="#FILTERDATA:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl1" width="90px" visible=""/>
				<form:DateTime nvalue="#FILTERDATA:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:Blank visible="" width="100%" name="bl4123"/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="4" descrip="" note="" name="grdEstructura">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Estructura Organizativa" cache="no" required="0" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank visible="" width="100%" name="bl114123"/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="4" descrip="" note="" name="grdPersonal">
			<form:Helper xmlns:form="nomad_engine.form" action="HELP" name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.GUIA_COMPLEJO.FLOW">
				<helper-mess>
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Empresa - Legajo" name="oi_personal_emp" nvalue="#SOURCEGRILLA:oi_personal_emp/@value" length="30" xsize="15" enabled="" required="0">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttons2" visible="FILTER">
			<form:Row name="row_top2">
				<form:Button startvalidate="1" img="ok" descrip="Generar Reporte" note="" label="Aceptar" name="btnAceptar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Blank visible="" width="50%" name="bl9"/>
				<form:Button descrip="Vuelve al menu principal sin ejecutar el formulario" note="Vuelve a la pantalla anterior" img="back" label="Volver" name="btnCAncelar" visible="" enabled="">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
