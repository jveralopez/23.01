<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" doc="source" name="GrupoTHProcesadosfilter">
	<form:Title>
		<form:Label label="Grupo de Tipos de Horas Procesados" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:FKInput label="Procesamiento" nvalue="#FILTERDATA:@oi_liquidacion" name="oi_liquidacion" xsize="15" required="1" length="30">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.flow">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
					<form:Combo label="Grupo de Tipo de Hora" flow="NucleusRH.Base.Tiempos_Trabajados.Grupos_TiposHora.Grupo_TH.Combo.autoflow" name="oi_grupo_th" nvalue="#FILTERDATA:@oi_grupo_th" enabled="" required="1" action="COMBO"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
</form:Form>
