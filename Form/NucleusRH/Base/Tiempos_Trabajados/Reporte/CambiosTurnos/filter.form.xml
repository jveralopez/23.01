<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.BUSCAR2.form" name="CambiosTurnos" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="104 - Cambios de Turnos" name="lbl_titulo" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blank1"/>
		<form:VGroup nvalue="#source:@gcustom" border="1" width="90%" label="Criterios de selecci&#243;n particulares" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo visible="0" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:Rower separation="5" required="1" name="fdesdehasta" label="Fecha Desde - Hasta">
						<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lblfechas" label="..."/>
						<form:DateTime nvalue="#source:@f_hasta" name="f_hasta" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column name="colemptta" valign="middle" align="left">
					<form:RowAligner name="rwalemp">
						<form:Row name="rowemp">
							<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@empresa" name="empresa"/>
							<form:SButton name="empreq" img="lock"/>
						</form:Row>
					</form:RowAligner>
				</form:Column>
				<form:Column visible="0" valign="middle" name="colemp" align="left">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="1" label="Empresa" nvalue="#source:@empresa" name="empresa"/>
				</form:Column>
			</form:Columns>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
