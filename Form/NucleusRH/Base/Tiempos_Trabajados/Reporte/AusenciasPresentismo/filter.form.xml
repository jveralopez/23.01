<form:Form name="ReportePresentismoAusenciafilter" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label name="lbl" label="Ausentes y Presentes" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="85%">
		<form:Label name="lbl" label="Criterios de Busqueda" align="center" style="S3 LCol_g" visible=""/>
		<form:Blank name="bl1111" width="100px" visible=""/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo nvalue="#FILTERDATA:@FormatRPT" action="COMBO" required="1" flow="Nomad.Base.report.cboFormatRpt.enum" name="Formato" label="Formato del Reporte"/>
				<form:Combo label="Organigrama" action="COMBO" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" required="1" enabled="" nvalue="#FILTERDATA:@oi_clase_org" name="oi_clase_org"/>
				<form:Combo flow="NucleusRH.Base.Tiempos_Trabajados.Reporte.SITUACION.enum.flow" label="Condici&#243;n" action="COMBO" required="0" enabled="" nvalue="#FILTERDATA:@condicion" name="condicion"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="111bl114123" visible="" width="100%"/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdEstructura">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Estructura Organizativa" cache="no" required="0" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
		<form:Blank visible="" width="100%" name="bl114123"/>
		<form:Grid name="grdPersonal" note="" descrip="" rows="3" allowhelper="1" allowdelall="1" allownew="1" allowdel="1" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
			<form:Helper name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.GUIA_COMPLEJO.FLOW" action="HELP" xmlns:form="nomad_engine.form">
				<helper-mess>
					{grdPersonal.Nodes}
				</helper-mess>
			</form:Helper>
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Empresa - Legajo" required="0" enabled="" xsize="15" length="30" nvalue="#SOURCEGRILLA:oi_personal_emp/@value" name="oi_personal_emp">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
