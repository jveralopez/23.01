<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" extends="Nomad.base.HTML_XLS.flow" name="ReporteConceptosLegajos">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_clase_org="">
				<ROWS/>
				<CONC/>
				<LIQS/>
			</FILTRO>
		</doc:define>
		<qry:define name="QRY_CONC">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="CONC"/>
				</qry:element>
			</qry:main>
			<qry:select name="CONC" doc="">
				<qry:xquery>
					for $r in SQL('			
					SELECT 
						TTA15_CONCEPTOS.oi_concepto as id,
						TTA15_CONCEPTOS.d_concepto as des,
						TTA15_CONCEPTOS.e_mostrar
					FROM 
						TTA15_CONCEPTOS
					WHERE 
						TTA15_CONCEPTOS.e_mostrar != 0
					ORDER BY 
						e_mostrar ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@id" name="id"/>
						<qry:attribute value="$r/@des" name="des"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="CONC"/>
		<qry:define declare="&lt;FILTRO oi_clase_org=&quot;&quot; ausencias=&quot;1&quot; presencias=&quot;1&quot; tardanzas=&quot;1&quot; licencias=&quot;1&quot; gcustom=&quot;&quot; f_desde=&quot;20100201&quot; f_hasta=&quot;20100228&quot; oi_liquidacion=&quot;47&quot; agrupa=&quot;1&quot; selected=&quot;1&quot; gpers=&quot;&quot; empresa=&quot;196&quot; activos=&quot;1&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; legajo_desde=&quot;&quot; legajo_hasta=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; oi_centro_costo=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; legajo_reloj_desde=&quot;&quot; legajo_reloj_hasta=&quot;&quot; chksinreloj=&quot;&quot; tarjeta_desde=&quot;&quot; tarjeta_hasta=&quot;&quot; chksintarjeta=&quot;&quot; oi_horario=&quot;&quot; oi_escuadra=&quot;&quot; tipo=&quot;&quot;&gt;&#13;&#10;  &lt;ROWS /&gt;&#13;&#10;  &lt;CONC nmd-col=&quot;1&quot;&gt;&#13;&#10;    &lt;C id=&quot;1&quot; /&gt;&#13;&#10;    &lt;C id=&quot;2&quot; /&gt;&#13;&#10;    &lt;C id=&quot;3&quot; /&gt;&#13;&#10;  &lt;/CONC&gt;&#13;&#10;&lt;/FILTRO&gt;&#13;&#10;" name="QRY_FILTERDOC">
			<qry:main doc="SOURCE">
				<qry:element name="FILTRO">
					<qry:attribute name="oi_liquidacion" value="#SOURCE:FILTRO/@oi_liquidacion"/>
					<qry:attribute name="f_desde" value="#SOURCE:FILTRO/@f_desde"/>
					<qry:attribute name="f_hasta" value="#SOURCE:FILTRO/@f_hasta"/>
					<qry:attribute name="agrupa" value="#SOURCE:FILTRO/@agrupa"/>
					<qry:attribute name="empresa" value="#SOURCE:FILTRO/@empresa"/>
					<qry:attribute name="chkPuestoActual" value="#SOURCE:FILTRO/@chkPuestoActual"/>
					<qry:attribute name="chkPosicionActual" value="#SOURCE:FILTRO/@chkPosicionActual"/>
					<qry:attribute name="chkDepartamentoActual" value="#SOURCE:FILTRO/@chkDepartamentoActual"/>
					<qry:attribute name="chkSectorActual" value="#SOURCE:FILTRO/@chkSectorActual"/>
					<qry:attribute name="chkUbicacionActual" value="#SOURCE:FILTRO/@chkUbicacionActual"/>
					<qry:attribute name="chkCtroCostoActual" value="#SOURCE:FILTRO/@chkCtroCostoActual"/>
					<qry:attribute name="detalle" value="#SOURCE:FILTRO/@detalle"/>
					<qry:attribute name="nulos" value="#SOURCE:FILTRO/@nulos"/>
					<qry:attribute name="formato_hora" value="#SOURCE:FILTRO/@formato_hora"/>
					<qry:element name="ROWS">
						<qry:insert-select name="LEGS" doc-path="#SOURCE:FILTRO"/>
					</qry:element>
					<qry:element name="CONC">
						<qry:insert-select name="CONC" doc-path="#SOURCE:FILTRO"/>
					</qry:element>
					<qry:element name="LIQS">
						<qry:insert-select name="LIQS" doc-path="#SOURCE:FILTRO"/>
					</qry:element>
					y:attribute name="oi_liquidacion" value="#SOURCE:FILTRO/@oi_liquidacion"/&gt;
				</qry:element>
			</qry:main>
			<qry:select name="LEGS" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@id" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="CONC" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:CONC/C
				</qry:xquery>
				<qry:out>
					<qry:element name="C">
						<qry:attribute value="$r/@id" name="id"/>
						<qry:insert-select name="CONDESC" doc-path="."/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="CONDESC" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('			
				SELECT 						
					TTA15_CONCEPTOS.d_concepto,
					TTA15_CONCEPTOS.c_concepto,
					TTA15_CONCEPTOS.c_coleccion,
					TTA15_CONCEPTOS.c_unidad
				FROM 
					TTA15_CONCEPTOS
				WHERE 
					TTA15_CONCEPTOS.oi_concepto = {#SOURCE:@id}					
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@d_concepto" name="DES"/>
					<qry:attribute value="$r/@c_concepto" name="c_concepto"/>
					<qry:attribute value="$r/@d_concepto" name="d_concepto"/>
					<qry:attribute value="$r/@c_coleccion" name="c_coleccion"/>
					<qry:attribute value="$r/@c_unidad" name="c_unidad"/>
				</qry:out>
			</qry:select>
			<qry:select name="LIQS" doc="SOURCE">
				<qry:xquery>
					for $r in #SOURCE:LIQS/PROC
				</qry:xquery>
				<qry:out>
					<qry:element name="PROC">
						<qry:attribute value="$r/@id" name="id"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry qry="QRY_CONC" output-doc="CONC"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ConceptosLegajos.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.ConceptosLegajos.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ConceptosLegajos.filter.form">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.ConceptosLegajos" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.ConceptosLegajos" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text-path="#FILTERDATA:" text="JP_FILTERDATA"/>
			<doc:load-qry output-doc="FILTERDATA" input-doc-path="#FILTERDATA:" qry="QRY_FILTERDOC"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.ConceptosLegajosHTML.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="208 - Conceptos por Legajos" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc attach-id="CONC" doc-path="#CONC:"/>
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc doc-path="#FILTERDATA:ROWS" attach-id="ARRB"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
