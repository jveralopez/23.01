<form:Form name="LegajosTTA" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label label="Seleccionar Filtro Reporte Planilla Legajos Tiempos Trabajados" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Label visible="" style="S3 LCol_g" align="center" label="Criterios de B&#250;squeda" name="lbl"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo label="Empresa" name="oi_empresa" nvalue="#FILTERDATA:@oi_empresa" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" action="COMBO"/>
				<form:FKInput nvalue="#FILTERDATA:@oi_convenio" required="0" xsize="15" length="30" label="Convenio" name="oi_convenio">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.Guia.autoflow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
