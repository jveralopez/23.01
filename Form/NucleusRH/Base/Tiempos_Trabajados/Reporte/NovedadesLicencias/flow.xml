<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="ReporteNovedadesLicencias">
	<flow:declare>
		<qry:define name="QRY_TIPHORA">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="TIPHORA"/>
				</qry:element>
			</qry:main>
			<qry:select name="TIPHORA" doc="">
				<qry:xquery>
					for $r in SQL('			
					SELECT 
						TTA01_TIPOHORAS.oi_tipohora as id,
						TTA01_TIPOHORAS.d_tipohora as des
					FROM 
						TTA01_TIPOHORAS
					ORDER BY 
						des ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@id" name="id"/>
						<qry:attribute value="$r/@des" name="des"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="TIPHORA"/>
		<doc:define name="FILTERDATA">
			<FILTRO>
				<PERSONAS/>
				<TIPHORA/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<doc:load-qry output-doc="TIPHORA" qry="QRY_TIPHORA"/>
			<flow:log text-path="#TIPHORA:" text="EMITIPHORA"/>
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.NovedadesLicencias.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.NovedadesLicencias.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.NovedadesLicencias.filter.form">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.NovedadesLicencias2" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.NovedadesLicencias2" doc="SOURCE"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.NovedadesLicencias.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="102.b - Novedades y Licencias asignadas al Personal" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#TIPHORA:" attach-id="TIPHORA"/>
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
