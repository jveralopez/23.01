<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter3.form" name="NovedadesLicencias" doc="source">
	<form:Title>
		<form:Label label="102.b - Novedades y Licencias asignadas al Personal" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo visible="0" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:Combo label="Tipo de Novedad" nvalue="#source:@tipo" required="1" name="tipo" descrip="Indica el tipo de novedad a listar">
						<form:Opts name="aaa">
							<OPT name="Todos" descrip="Todos" text="Todos" value="T" code="T"/>
							<OPT name="Ausencias" descrip="Ausencias" text="Ausencias" value="A" code="A"/>
							<OPT name="Presencias" descrip="Presencias" text="Presencias" code="P" value="P"/>
						</form:Opts>
					</form:Combo>
					<form:Blank name="lb1"/>
					<form:Rower separation="5" required="1" name="fdesdehasta" label="Fecha Desde - Hasta">
						<form:DateTime nvalue="#source:@f_desde" name="f_desde" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lblfechas" label="..."/>
						<form:DateTime nvalue="#source:@f_hasta" name="f_hasta" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
					<form:Combo visible="0" flow="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.combo.autoflow" action="COMBO" nvalue="#source:@oi_tipohora" name="oi_tipohora" label="Tipo de Hora" required="0" descrip="Filtrar por Tipo de Hora"/>
				</form:Column>
				<form:Column label="Informaci&#243;n a mostrar" name="col2ext" valign="top" align="left">
					<form:TextBox xsize="35" length="100" name="iter_search" ysize="1" descr="Busca." X-POLICY="./FORM/NucleusRH/Base/Organizacion/Escalas/ESCALA/autoform/iter_search">
						<form:Event runat="client" name="onpressenter" action="Find"/>
						<form:SButtons>
							<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
								<form:Event runat="client" name="onclick" action="Find"/>
							</form:SButton>
						</form:SButtons>
					</form:TextBox>
					<form:ListView arr-control="TIPHORA" docname="TIPHORA" label="Tipos de Hora" name="TiposHoras" nvalue="#source:@selected" rows="5" width="350px">
						<form:LVColumns>
							<form:LVColumn label="Tipo de Hora" width="100%" attrname="des" type="string" sorteable="1" name="des"/>
						</form:LVColumns>
						<form:SButtons>
							<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
								<form:Event action="FullTIPHORA" name="OnClick" runat="client"/>
							</form:SButton>
							<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
								<form:Event action="ClearTIPHORA" name="OnClick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:ListView>
					<form:HiddenArr name="TIPHORA" nvalue="#source:TIPHORA" proto="&lt;C /&gt;">
						<form:Attr name="id"/>
					</form:HiddenArr>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Scripts>
		function Find()
{
	Ctrl("TiposHoras").filter("",Ctrl("iter_search").GetCValue());
}

function ClearTIPHORA()
{
	Ctrl("TIPHORA").DelAllRow();
	Ctrl("TiposHoras").Refresh();
}

function FullTIPHORA()
{
	Ctrl("TIPHORA").DelAllRow();     
	for (var t=0; t&lt;Ctrl("TiposHoras").TotalRowsCount(); t++)
		Ctrl("TIPHORA").AddRow().SetAttr("id", Ctrl("TiposHoras").GetAttrValue(t, "id"));
	
	Ctrl("TiposHoras").Refresh();
}

function Ejecutar()
{ 
  if(Ctrl("TIPHORA").CountRow()==0)
	{             
 		alert("Un tipo de hora es requerido.");
 		return false;
 	}

  //Lo que hace el base            
 	if (arrFILTER.length==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}
 	
 	FillArray(50);
	Ctrl("main").DoEvent("FILTER");

}
	</form:Scripts>
</form:Form>
