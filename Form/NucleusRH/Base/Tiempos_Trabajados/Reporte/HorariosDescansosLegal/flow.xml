		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="CreateReportHorarioDescansoLegal" class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.ESPERANZAPER" out-attr-path="#BATCHDOC:@batch-id" priority="9">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.HorariosDescansosLegal.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
