		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.HorariosDescansosLegal.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.HorariosDescansosLegal.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
