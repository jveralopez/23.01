<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" extends="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.BUSCAR.form" doc="source">
	<form:Title>
		<form:Label label="T&#237;tulo del Reporte" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column visible="0" valign="middle" name="colemp" align="left"/>
				<form:Column name="colemptta" valign="middle" align="left">
					<form:RowAligner name="rwalemp">
						<form:Row name="rowemp">
							<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@empresa" name="empresa"/>
							<form:SButton name="empreq" img="lock"/>
						</form:Row>
					</form:RowAligner>
				</form:Column>
			</form:Columns>
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
				<form:Column valign="top" align="center" name="col2">
					<form:ListView arr-control="list2arr" width="480px" rows="6" name="list2"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:HiddenArr nvalue="#source:ROWS" proto="&lt;ROW id=&quot;&quot;/&gt;" name="legajos">
			<form:Attr name="id"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el reporte con el criterio seleccionado" label="Aceptar" img="ok" name="ACCEPT" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Ejecutar()
{               
 	if (Ctrl("list2").TotalRowsCount()==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}
 	
 	Ctrl('legajos').DelAllRow();
 	for (key in arrB) Ctrl('legajos').AddRow().SetAttr('id', key.substr(1));
 	
	Ctrl("main").DoEvent("FILTER");
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
</form:Form>
