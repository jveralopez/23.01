<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter2.form" doc="source" name="HorasProcesadasfilter">
	<form:Title>
		<form:Label label="201 - Horas Procesadas" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column name="col1ext" valign="top" align="left">
					<form:Combo visible="0" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
					<form:ComboBox nvalue="#FILTERDATA:@oi_liquidacion" queryname1="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="1" label="Procesamiento" name="oi_liquidacion"/>
					<form:Combo label="Grupo de Tipo de Hora" flow="NucleusRH.Base.Tiempos_Trabajados.Grupos_TiposHora.Grupo_TH.Combo.autoflow" name="oi_grupo_th" nvalue="#FILTERDATA:@oi_grupo_th" enabled="" required="0" action="COMBO"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_liquidacion=&quot;1&quot;/&gt;" name="qry_externo">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('			
				SELECT 
					TTA10_LIQUIDACPERS.oi_personal_emp
				FROM 
					TTA10_LIQUIDACPERS
				WHERE 
					TTA10_LIQUIDACPERS.oi_liquidacion = {#SOURCE:@oi_liquidacion}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:params>
				##oi_liquidacion##
			</qry:params>
		</form:Resource>
	</form:Resources>
</form:Form>
