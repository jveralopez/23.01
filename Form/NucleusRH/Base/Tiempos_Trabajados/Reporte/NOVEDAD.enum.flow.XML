<flow:flow extends="Nomad.combo.flow" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry output-doc="RS" qry="COMBO"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT TTA01_TIPOHORAS.oi_tipohora, 
				TTA01_TIPOHORAS.c_tipohora, 
				TTA01_TIPOHORAS.d_tipohora 
				FROM TTA01_TIPOHORAS 
				WHERE TTA01_TIPOHORAS.l_afectanov=1
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OPT">
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipohora" name="id"/>
						<qry:attribute type="Nomad.NSystem.Int" value="$r/@oi_tipohora" name="value"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@C_tipohora" name="code"/>
						<qry:attribute type="Nomad.NSystem.String" value="$r/@D_tipohora" name="text"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
</flow:flow>
