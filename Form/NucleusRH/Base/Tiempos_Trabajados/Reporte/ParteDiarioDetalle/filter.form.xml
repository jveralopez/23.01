<form:Form xmlns:form="nomad_engine.form" extends="NucleusRH.Base.Tiempos_Trabajados.Reporte.filter.form" name="ParteDiarioDetalle" doc="source">
	<form:Title>
		<form:Label label="105.b - Parte Diario de Asistencias Detallado" name="lbl_titulo" visible="" style="S3 LCol_w" align="center"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup label="Criterios de selecci&#243;n de par&#225;metros para el reporte" nvalue="#source:@gcustom" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns name="colsext" width="100%">
				<form:Column valign="middle" name="col1ext" align="left">
					<form:DateTime xsize="0" label="Fecha" nvalue="#source:@f_fecha" name="f_fecha" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:CheckBox label="Agregar detalle de horarios y fichadas" name="chkDetalleHoras" nvalue="#source:@chkDetalleHoras"/>
					<form:Combo visible="0" descrip="Indica el Organigrama que se utilizar&#225; para realizar el agrupamiento de la informaci&#243;n" label="Organigrama" name="oi_clase_org" nvalue="#source:@oi_clase_org" enabled="" required="0" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup order-change="PREV:vgroupDatosPers" label="Criterios de selecci&#243;n de datos adicionales" name="vgroupDatosAdicionales" nvalue="#source:@gcus2" border="1" width="90%" collapse="1">
			<form:Columns name="colsadic" width="100%">
				<form:Column align="left" name="coladic1" valign="top">
					<form:Label style="S3 LCol_g" label="Estructura Organizativa:" name="estrorg"/>
					<form:Line name="ln1"/>
					<form:CheckBox label="Puesto Actual" name="chkPuestoActual" nvalue="#source:@chkPuestoActual"/>
					<form:CheckBox name="chkPosicionActual" label="Posici&#243;n Actual" nvalue="#source:@chkPosicionActual"/>
					<form:CheckBox label="Departamento Actual" name="chkDepartamentoActual" nvalue="#source:@chkDepartamentoActual"/>
					<form:CheckBox label="Sector Actual" name="chkSectorActual" nvalue="#source:@chkSectorActual"/>
				</form:Column>
				<form:Row name="rowemp"/>
				<form:Column align="left" name="coladic2" valign="top">
					<form:Label style="S3 LCol_g" label="Otros Atributos:" name="estrotros" lines="B"/>
					<form:Line name="ln2"/>
					<form:CheckBox nvalue="#source:@chkCtroCostoActual" label="Centro de Costo Actual" name="chkCtroCostoActual"/>
					<form:CheckBox nvalue="#source:@chkUbicacionActual" name="chkUbicacionActual" label="Ubicaci&#243;n Actual"/>
				</form:Column>
				<form:Column width="50%" align="left" name="coladic3" valign="top"/>
			</form:Columns>
			<form:Blank name="blk3"/>
			<form:Rower separation="15" name="rower">
				<form:Button img="table_check" label="Marcar Todos" name="btnTodos">
					<form:Event action="CheckearTodos" name="onclick" runat="client"/>
				</form:Button>
				<form:Button img="table_uncheck" label="Desmarcar Todos" name="btnDesmarcar">
					<form:Event action="DescheckearTodos" name="onclick" runat="client"/>
				</form:Button>
			</form:Rower>
		</form:VGroup>
	</form:Center>
	<form:Scripts>
		&#13;&#10;&#13;&#10;function CheckearTodos()
{
    chequear('1');
}                       

function DescheckearTodos()
{
    chequear('0');
}                  

function chequear(opcion)
{                                        
Ctrl('chkPuestoActual').SetXValue(opcion);  
Ctrl('chkPosicionActual').SetXValue(opcion);
Ctrl('chkDepartamentoActual').SetXValue(opcion);
Ctrl('chkSectorActual').SetXValue(opcion);
Ctrl('chkUbicacionActual').SetXValue(opcion);
Ctrl('chkCtroCostoActual').SetXValue(opcion);
}
	</form:Scripts>
</form:Form>
