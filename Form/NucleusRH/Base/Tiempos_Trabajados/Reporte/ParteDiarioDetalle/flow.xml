<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="ParteDiario">
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO chkDetalle="1">
				<ROWS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ParteDiarioDetalle.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.ParteDiarioDetalle.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Reporte.ParteDiarioDetalle.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.ParteDiarioDetalle" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Reporte.ParteDiarioDetalle" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<doc:set-attribute from-attr-path="#FILTERDATA:@f_fecha" to-attr-path="#FILTERDATA:@f_desde"/>
			<doc:set-attribute from-attr-path="#FILTERDATA:@f_fecha" to-attr-path="#FILTERDATA:@f_hasta"/>
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@chkDetalle"/>
			<doc:set-attribute from-value="1" to-attr-path="#FILTERDATA:@ausencias"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@presencias" from-value="1"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@tardanzas" from-value="1"/>
			<doc:set-attribute to-attr-path="#FILTERDATA:@licencias" from-value="1"/>
			<flow:exec-method method="CreateReportAssistencia" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.ESPERANZAPER">
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="105 b - Parte Diario de Asistencias detallado" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
