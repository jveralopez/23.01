<flow:flow extends="Nomad.Base.report.Crystal.flow" xmlns:flow="nomad_engine.form" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" name="ReportePresencias">
	<flow:info label="ReportePresencias"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO agrupar="E">
				<EMPRESAS/>
				<TERMINALES/>
				<TIPOSPERS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Presencias.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.Presencias.filter.form:FILTER" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.Presencias.filter.form">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<submap path-docB="#B:EMPRESAS" path-docA="#A:ctrl[@id='grdEmpresa']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_empresa']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<EMPRESA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<submap path-docB="#B:TERMINALES" path-docA="#A:ctrl[@id='grdTerminal']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_terminal']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<TERMINAL id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<submap path-docB="#B:TIPOSPERS" path-docA="#A:ctrl[@id='grdTipoPersonal']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_tipo_personal']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<TIPOPER id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:log text="ppfilterdata" text-path="#FILTERDATA:"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTpdf" eq="PDF"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTxls" eq="XLS"/>
			<flow:call-action if="#FILTERDATA:@FormatRPT" action="ACCEPTrtf" eq="RTF"/>
		</flow:action>
		<flow:action name="ACCEPTpdf">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.Presencias\Presencias.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTxls">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.Presencias\PresenciasXLS.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTrtf">
			<flow:exec-method out-attr-path="#FILTERDATA:@batch-id" out-type="String" priority="5" method="execute" class="Nomad.NSystem.Crystal.NmdCrystalBatch">
				<flow:param value="NucleusRH.Base.Tiempos_Trabajados.Presencias\PresenciasRTF.def" name="report-name" mode="in" type="Nomad.NSystem.String"/>
				<flow:param name="report-param" mode="in" type="Nomad.NSystem.Object" doc="FILTERDATA"/>
				<flow:param attr-path="#FILTERDATA:@file-name" name="report-file" mode="in" type="Nomad.NSystem.String"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batch.report.form" mode="BATCH" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:form>
</flow:flow>
