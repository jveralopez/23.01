<form:Form name="LegajosOrganigramafilter" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label label="Seleccionar Filtro Reporte Legajos sin Horario Vigente Asignado" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Label visible="" style="S3 LCol_g" align="center" label="Criterios de B&#250;squeda" name="lbl"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo label="Organigrama" name="oi_clase_org" nvalue="#FILTERDATA:@oi_clase_org" enabled="" required="1" flow="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG.Combo.autoflow" action="COMBO"/>
				<form:DateTime label="Fecha de Vigencia" name="f_fecha" nvalue="#FILTERDATA:@f_fecha" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
		<form:Blank visible="" width="100%" name="bl4123"/>
		<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="4" descrip="" note="" name="grdEstructura">
			<form:GColumns>
				<form:GColumn allow_order="0">
					<form:FKInput label="Estructura Organizativa" cache="no" required="0" enabled="" xsize="15" length="30" nvalue="#FILTERDATA:@oi_estructura" name="oi_estructura">
						<form:STexts>
							<form:SText xsize="50"/>
						</form:STexts>
						<form:Helper help="HELP" x2c="X2C" c2x="C2X" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
							<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton img="SEARCH" label="Search" name="SEARCH" enabled="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
			</form:GColumns>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="LoadForm" name="onload" runat="client"/>
	<form:Scripts>
		function LoadForm()
{
	Ctrl('f_fecha').SetXValue(datetime2str(Now()));
}
	</form:Scripts>
</form:Form>
