<flow:flow name="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.flow" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow para Nomad.Base.Liquidacion.NovedadesLiquidacion">
		Flow para Nomad.Base.Liquidacion.NovedadesLiquidacion
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO f_fecha="" oi_clase_org="">
				<ESTRUCTURAS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.filter.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.filter.form" mode="FILTER" doc="SOURCE">
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:assign-mapping dir-apply="a-&gt;b" b-doc="FILTERDATA" a-doc="FORM">
				<map docB="B" docA="A">
					<submap path-docB="#B:ESTRUCTURAS" path-docA="#A:ctrl[@id='grdEstructura']/rows">
						<map docB="B" docA="A">
							<link B="#B:@id" A="#A:columns/ctrl[@id='oi_estructura']/@xval"/>
						</map>
						<ProtoA/>
						<ProtoB>
							<ESTRUCTURA id=""/>
						</ProtoB>
					</submap>
				</map>
			</doc:assign-mapping>
			<flow:log text="ppfilterdata" text-path="#FILTERDATA:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:html-gen template-file="NucleusRH.Base.Tiempos_Trabajados.LegajosSinHorario.rpt" input-doc-path="#FILTERDATA:" out-file-path="#SOURCE:@report"/>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.Report.form" mode="REPORT" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosSinHorario" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Personal.Reporte.LegajosSinHorario" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.Report.form:REPORT" form-class="NucleusRH.Base.Tiempos_Trabajados.Reporte.LegajosSinHorario.Report.form" mode="REPORT" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form next-action="BACK"/>
		</flow:action>
	</flow:form>
</flow:flow>
