<flow:flow name="MOSTRAR" xmlns:flow="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form">
	<flow:info label="Flow guia para MOSTRAR.combo"/>
	<flow:main doc="SOURCE">
		<flow:action name="COMBO">
			<doc:load-qry qry="COMBO" output-doc="RS"/>
			<flow:exit-flow return-path="#RS:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="RS"/>
		<qry:define name="COMBO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:element name="OPT">
						<qry:attribute name="value" value="'D'" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="'D'" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="'Detalle'" type="Nomad.NSystem.String"/>
					</qry:element>
					<qry:element name="OPT">
						<qry:attribute name="value" value="'R'" type="Nomad.NSystem.String"/>
						<qry:attribute name="code" value="'R'" type="Nomad.NSystem.String"/>
						<qry:attribute name="text" value="'Resumen'" type="Nomad.NSystem.String"/>
					</qry:element>
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
</flow:flow>
