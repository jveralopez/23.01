<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.AGREGAR2.form" default_mode="LIST" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.ADMINISTRAR.form" doc="source" parent-doc="PARENTSOURCE">
	<form:Title>
		<form:Label style="S3 LCol_w" label="Administraci&#243;n de Legajos en Procesamiento" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup width="100%" nvalue="#source:@gcustom" border="1" label="Datos del Procesamiento" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="cols2">
				<form:Column align="left" valign="top" name="col21">
					<form:FKInput nvalue="#DDO:@id" enabled="0" label="Procesamiento" name="oi_liquidacion" length="30" xsize="15" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
					</form:FKInput>
					<form:Hidden nvalue="#DDO:@f_fechainicio" name="f_fechainicio"/>
					<form:Hidden nvalue="#DDO:@f_fechafin" name="f_fechafin"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup width="90%" nvalue="#source:@gpers" border="1" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column visible="0" valign="middle" name="colemp" align="left"/>
				<form:Column name="colemptta" valign="middle" align="left">
					<form:RowAligner name="rwalemp">
						<form:Row name="rowemp">
							<form:ComboBox nvalue="#DDO:oi_empresa/@value" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" name="empresa"/>
							<form:SButton name="empreq" img="lock"/>
						</form:Row>
					</form:RowAligner>
				</form:Column>
			</form:Columns>
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button img="save" descrip="Guarda los cambios realizados" label="Guardar" name="SAVE" note="Consultar los Legajos seleccionados">
					<form:Event action="Guardar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button descrip="Volver a la pantalla anterior" img="back" label="Volver" name="BACK" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Guardar()
{               
	FillArray(100);
	Ctrl("main").DoEvent("SAVE");	 		
}
	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM f_fechainicio=&quot;20101001&quot; f_fechafin=&quot;20101031&quot; fichadas=&quot;1&quot;/&gt;" name="qry_externo">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:/PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
					SELECT 
						PER02_PERSONAL_EMP.oi_personal_emp,
				    SEC.policy
					FROM 
						TTA04_HORARIOSPERS, PER02_PERSONAL_EMP,
						NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC						
					JOIN 
						TTA04_HORARIOSPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				    PER02_PERSONAL_EMP.oi_personal_emp LEFT OUTER SEC.id						
					WHERE 					
						TTA04_HORARIOSPERS.f_fechainicio &lt;= {DateTime(#SOURCE:@f_fechafin)}
						AND (TTA04_HORARIOSPERS.f_fechafin &gt;= {DateTime(#SOURCE:@f_fechainicio)}
						OR ISNULL(TTA04_HORARIOSPERS.f_fechafin))
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
						<qry:attribute name="policy" value="$r/@policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:params>
				##f_fechainicio,f_fechafin##
			</qry:params>
		</form:Resource>
	</form:Resources>
</form:Form>
