<form:Form name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.Blanquear.form" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Procesamiento de Horas - Blanquear Legajos" nowrap="1" name="lblTitulo" style="S3 LCol_w"/>
				<form:Label nvalue="#source:@descr" dynamic="1" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Hidden nvalue="#SOURCE:@id" name="oi_liquidacion"/>
		<form:RowAligner name="GRILLAS">
			<form:Row name="GRILLASROWS2">
				<form:Blank visible="" width="100%" name="bl0024d"/>
				<form:CheckBox name="blanquearRI" nvalue="" label="Blanquear si Tiene Recibos Impresos" enabled="" required="0" visible="0"/>
			</form:Row>
			<form:Row name="GRILLASROWS3">
				<form:Blank visible="" width="100%" name="bl0204d"/>
				<form:CheckBox name="blanquearAH" nvalue="" label="Blanquear si Tiene Acreditacion de Haberes" enabled="" required="0" visible="0"/>
			</form:Row>
			<form:Row name="GRILLASROWS4">
				<form:Blank visible="" width="100%" name="b2l004d"/>
				<form:CheckBox visible="0" name="blanquearTodos" label="Blanquear Ignorando todo" enabled="" required="0"/>
			</form:Row>
			<form:Row name="GRILLASROWS5">
				<form:Blank visible="" width="100%" name="bl2004d"/>
				<form:RowAligner columns="3" name="datos">
					<form:Row name="dato">
						<form:CheckBox name="todos" nvalue="" label="Todos" enabled="" required="0"/>
						<form:CheckBox name="excluir" nvalue="" label="Excluir" enabled="" required="0"/>
					</form:Row>
				</form:RowAligner>
			</form:Row>
			<form:Row name="GRILLASROWS6">
				<form:Label label="Personas Inicializadas" style="M1" align="center" name="lbS"/>
				<form:Label style="M1" align="center" label="Personas a Blanquear/a no Blanquear" name="lblS"/>
			</form:Row>
			<form:Row name="GRILLASROWS7">
				<form:Grid doc="SOURCEGRI" nvalue="#PERSONASINI:" idvalue="#SOURCEGRI:@id" enabled="" paging="1" allowdel="0" allownew="0" allowdelall="0" allowhelper="0" rows="8" descrip="" note="" name="grdDatosPersonaInicializadas">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCEGRI:@id" enabled="0" name="oi_personal_emp" label="Legajo" length="30" xsize="10" required="0">
								<form:STexts>
									<form:SText enabled="0" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.BLANQUEAR.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess oi_liquidacion="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Grid doc="SOURCEGRILLA" nvalue="" idvalue="" enabled="" paging="1" allowdel="0" allownew="0" allowdelall="1" allowhelper="1" rows="8" descrip="" note="" name="grdDatosPersona">
					<form:Helper xmlns:form="nomad_engine.form" action="HELP" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.BLANQUEAR.LM.guia.flow">
						<helper-mess oi_liquidacion="{oi_liquidacion.ReadXValue}">
							{grdDatosPersona.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput name="oi_personal_emp" nvalue="" label="Personal" length="30" xsize="10" enabled="0" required="0">
								<form:STexts>
									<form:SText xsize="50"/>
								</form:STexts>
								<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.BLANQUEAR.guia.flow">
									<helper-mess oi_liquidacion="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton name="SEARCH" visible="0" label="Search" img="SEARCH">
										<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner columns="1" name="botones">
			<form:Row name="filaBotones">
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/Liquidacion/EDIT" name="SAVE" label="Guardar" img="save" descrip="" note="" visible="EDIT|NEW|SHOW">
					<form:Event runat="server" name="onclick" action="SAVE"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/Liquidacion/READ" name="VISTAPREVIA" label="Vista Previa" img="search" note="" visible="">
					<form:Event runat="server" name="onclick" action="VISTAPREVIA"/>
				</form:Button>
				<form:Button label="Volver" name="BACK" img="back" descrip="" note="" visible="EDIT|NEW|SHOW">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
