<form:Form extends="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.BUSCAR.form" name="Interface" doc="source" xmlns:form="nomad_engine.form">
	<form:Title>
		<form:Label label="Generar Archivo de Horas Trabajadas" style="S3 LCol_w" name="lbl_titulo"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup nvalue="#source:@gcustom" label="Criterios de selecci&#243;n de par&#225;metros para el Proceso" border="1" width="90%" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="1">
				<form:Column align="center" valign="middle" name="2" separation="2">
					<form:Combo required="1" nvalue="#source:@formato" label="Formato" name="formato">
						<form:Opts>
							<OPT name="NucleusRH" text="NucleusRH" code="N" value="N"/>
						</form:Opts>
					</form:Combo>
					<form:Rower label="Fecha Desde - Hasta" separation="5" required="1" name="finifin">
						<form:DateTime nvalue="#source:@f_ini" name="f_ini" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Label name="lblfechas" label="..."/>
						<form:DateTime nvalue="#source:@f_fin" name="f_fin" pattern="YYYYMMDD" required="1" descr="Fecha de Inicio del Horario para una Persona" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Rower>
					<form:Combo flow="NucleusRH.Base.Tiempos_Trabajados.Grupos_TiposHora.GRUPO_TH.combo.autoflow" action="COMBO" nvalue="#source:@oi_grupo_th" label="Grupo de Tipo de Hora" name="oi_grupo_th"/>
					<form:Blank visible="" width="100%" name="bl2"/>
					<form:Grid proto="&lt;TH/&gt;" nvalue="#source:THS" idvalue="#SOURCEGRILLA:@id" width="483px" doc="SOURCEGRILLA" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="1" rows="4" descrip="" note="" name="grdTipoHora">
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.LM.guia.flow" xmlns:form="nomad_engine.form" action="HELP">
							<helper-mess>
								{grdTipoHora.Nodes}
							</helper-mess>
						</form:Helper>
						<form:GColumns>
							<form:GColumn allow_order="0">
								<form:FKInput label="Tipo de Hora" nvalue="#SOURCEGRILLA:@id" name="oi_tipohora" length="30" xsize="15" enabled="" required="0">
									<form:STexts>
										<form:SText name="txt1" xsize="50"/>
									</form:STexts>
									<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
										<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
									</form:Helper>
									<form:SButtons>
										<form:SButton enabled="" name="SEARCH" label="Search" img="SEARCH">
											<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
										</form:SButton>
									</form:SButtons>
								</form:FKInput>
							</form:GColumn>
						</form:GColumns>
					</form:Grid>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers">
			<form:Columns width="100%" name="columns1">
				<form:Column visible="0" valign="top" align="center" name="col1"/>
				<form:Column visible="0" valign="middle" align="center" name="colbuttons"/>
			</form:Columns>
		</form:VGroup>
		<form:HiddenArr nvalue="#source:ROWS" proto="&lt;ROW id=&quot;&quot;/&gt;" name="legajos">
			<form:Attr name="id"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button descrip="Genera el archivo en funci&#243;n de los par&#225;metros ingresados" label="Ejecutar" img="ok" name="EXECUTE" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="search" descrip="Previsualizar el resultado de la ejecuci&#243;n" label="Vista Previa" name="PREVIEW" note="Volver al Menu princial">
					<form:Event action="Preview" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Preview()
{               
 	if (Ctrl("list2").TotalRowsCount()==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	} 	
 	Ctrl('legajos').DelAllRow();
 	for (key in arrB) Ctrl('legajos').AddRow().SetAttr('id', key.substr(1));	
	
	var param = "&lt;FILTRO f_ini=\""+Ctrl("f_ini").GetXValue() +"\" f_fin=\""+Ctrl("f_fin").GetXValue()+"\"&gt;&lt;ROWS&gt;";
	for (key in arrB) param = param + "&lt;ROW id=\""+key.substr(1) +"\"/&gt;";
	param = param + "&lt;/ROWS&gt;&lt;THS&gt;"
	
	for (i=0;i&lt;Ctrl("grdTipoHora").TotalRowsCount();i++)
	{
		param = param + "&lt;TH id=\""+Ctrl("grdTipoHora").GetCellXValue("oi_tipohora",i) +"\"/&gt;";
	}
	param = param + "&lt;/THS&gt;&lt;/FILTRO&gt;"		
	
	openNewFlowWait('NucleusRH.Base.Tiempos_Trabajados.Liquidacion.INTERFACE.guia.flow',"HELP",param,new ObjtectResult(),"");
}

function Ejecutar()
{               
 	if (Ctrl("list2").TotalRowsCount()==0)
 	{             
 		alert("No hay legajos filtrados.");
 		return false;
 	}
 	
 	Ctrl('legajos').DelAllRow();
 	for (key in arrB) Ctrl('legajos').AddRow().SetAttr('id', key.substr(1));
 	
	Ctrl("main").DoEvent("ok");
}

function ObjtectResult()
{        
	this.processResult= function(xmlin)
		{    
		}
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="ok" runat="server"/>
	<form:Event action="PREVIEW" runat="server" name="view"/>
</form:Form>
