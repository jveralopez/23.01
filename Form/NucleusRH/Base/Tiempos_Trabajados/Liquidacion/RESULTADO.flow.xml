<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.Liquidacion"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA oi_liquidacion="" oi_personal_emp=""/>
		</doc:define>
		<doc:define name="LIQPER">
			<DATA oi_liquidacionpers=""/>
		</doc:define>
		<qry:define declare="&lt;DATA oi_liquidacion=&quot;42&quot; oi_personal_emp=&quot;11565&quot;/&gt;" name="QRY_LIQPER">
			<qry:main doc="SOURCE">
				<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT TTA10_LIQUIDACPERS.oi_liquidacionpers
				FROM TTA10_LIQUIDACPERS
				WHERE TTA10_LIQUIDACPERS.oi_personal_emp = {#SOURCE:@oi_personal_emp}
				AND TTA10_LIQUIDACPERS.oi_liquidacion = {#SOURCE:@oi_liquidacion} 
		')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="DATA">
						<qry:attribute name="oi_liquidacionpers" value="$r/@oi_liquidacionpers"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:load-user-data name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO" doc="FILTERDATA"/>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="show">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.form" mode="SHOW" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.filter.form:FILTER" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
		<flow:action name="VISUALIZAR">
			<doc:load-qry output-doc="LIQPER" input-doc-path="#FILTERDATA:" qry="QRY_LIQPER"/>
			<flow:save-user-data doc-path="#FILTERDATA:" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO"/>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.form" mode="SHOW" doc-path="#LIQPER:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.form" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.RESULTADO.form:SHOW" mode="SHOW" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show"/>
	</flow:form>
</flow:flow>
