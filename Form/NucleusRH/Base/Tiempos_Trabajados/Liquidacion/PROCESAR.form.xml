<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.BUSCAR2.form" name="Procesar" doc="source">
	<form:Title>
		<form:Label name="lbl_titulo" label="Procesamiento de Horas - Procesar" nowrap="1" style="S3 LCol_w"/>
		<form:Label nvalue="#source:@descr" dynamic="1" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
	</form:Title>
	<form:Center width="100%">
		<form:VGroup width="90%" nvalue="#source:@gcustom" border="1" label="Criterios de ejecuci&#243;n" name="vgroupDatosCustom" collapse="1">
			<form:Columns width="100%" name="cols2">
				<form:Column align="left" valign="top" name="col21">
					<form:FKInput nvalue="#DDO:@id" enabled="0" label="Procesamiento" name="oi_liquidacion" length="30" xsize="15" required="0">
						<form:STexts>
							<form:SText name="txt1" xsize="50"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
					</form:FKInput>
					<form:CheckBox label="Ejecuci&#243;n Parcial?" required="1" nvalue="#source:@parcial" name="parcial"/>
					<form:CheckBox label="Forzar reproceso?" required="1" nvalue="#source:@reprocesar" name="reprocesar"/>
				</form:Column>
			</form:Columns>
		</form:VGroup>
		<form:VGroup nvalue="#source:@gpers" border="1" width="90%" collapse="1" label="Criterios de selecci&#243;n de personas" name="vgroupDatosPers" X-POLICY="./FORM/NucleusRH/Base/Tiempos_Trabajados/Liquidacion/PROCESAR/form/vgroupDatosPers">
			<form:Columns name="colsemps" width="100%">
				<form:Column visible="0" valign="middle" name="colemp" align="left"/>
				<form:Column name="colemptta" valign="middle" align="left">
					<form:RowAligner name="rwalemp">
						<form:Row name="rowemp">
							<form:ComboBox nvalue="#DDO:oi_empresa/@value" queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" name="empresa"/>
							<form:SButton name="empreq" img="lock"/>
						</form:Row>
					</form:RowAligner>
				</form:Column>
			</form:Columns>			
		</form:VGroup>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button descrip="Ejecutar el Proceso de Verificaci&#243;n de Fichadas para el rango de fechas y los Legajos seleccionados" label="Ejecutar" img="ok" name="EXECUTE" note="Consultar los Legajos seleccionados">
					<form:Event action="Ejecutar" runat="client" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Ejecutar()
{ 	 
	FillArray(100);
	Ctrl("main").DoEvent("FILTER");	 		
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="FILTER" runat="server"/>
	<form:Resources>
		<form:Resource declare="&lt;PARAM oi_liquidacion=&quot;40&quot;/&gt;" name="qry_externo">
			<qry:main name="qry" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:/PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			 		SELECT 
			 			TTA10_LIQUIDACPERS.oi_personal_emp,
				    SEC.policy
					FROM 
						TTA10_LIQUIDACPERS,
						NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC
					JOIN TTA10_LIQUIDACPERS.oi_personal_emp LEFT OUTER SEC.id						
					WHERE 
						TTA10_LIQUIDACPERS.oi_liquidacion = {#SOURCE:@oi_liquidacion}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_personal_emp"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:params>
				##oi_liquidacion##
			</qry:params>
		</form:Resource>
	</form:Resources>
</form:Form>
