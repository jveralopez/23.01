<form:Form xmlns:form="nomad_engine.form" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.form" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.autoform" default_mode="" doc="source">
	<form:Center>
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="M1 LCol_g" visible=""/>
		<form:Blank name="bl2" width="100%" visible=""/>
		<form:Columns name="cols1">
			<form:Column name="col1">
				<form:Rower label="Empresa" name="rw1">
					<form:ComboBox queryname1="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="40" mode="QRY" required="0" label="Empresa" nvalue="#source:@oi_empresa" name="oi_empresa"/>
					<form:SButton name="empreq" img="lock"/>
				</form:Rower>
				<form:ComboBox label="Procesamiento de Horas" nvalue="#source:@oi_liquidacion" queryname1="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.INFO" xsize="40" mode="QRY" required="0" name="oi_liquidacion"/>
				<form:ComboBox xsize="40" mode="OPT" required="0" descr="Estado del Procesamiento" label="Estado" nvalue="#source:@c_estado" name="c_estado">
					<options>
						<option text="Abierto" value="abi"/>
						<option text="Inicializado" value="ini"/>
						<option text="Procesado" value="pro"/>
						<option text="Cerrado" value="cer"/>
						<option text="Congelado" value="con"/>
					</options>
				</form:ComboBox>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER">
					<form:Event runat="client" name="onclick" action="Filter"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Filter()
{ 
	if(Ctrl('empreq').GetEnabled() &amp;&amp; Ctrl('oi_empresa').GetXValue() == '')
	{
		alert('La Empresa es requerida');
		return false;
	}
	Ctrl('main').DoEvent("Filtrar");
}
	</form:Scripts>
	<form:Event runat="server" name="Filtrar" action="FILTER"/>
</form:Form>
