<form:Form name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.inicializar.form" xmlns:form="nomad_engine.form" doc="source" parent-doc="PARENTSOURCE">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Procesamiento de Horas - Inicializar Legajos" nowrap="1" name="lblTitulo" visible="EDIT" style="S3 LCol_w"/>
				<form:Label label="Procesamiento de Horas - Legajos Inicializados" nowrap="1" name="lblTitulo" visible="SHOW" style="S3 LCol_w"/>
				<form:Label nvalue="#source:@descr" dynamic="1" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="90%">
		<form:Blank name="bldd" width="100%" visible=""/>
		<form:RowAligner name="GRILLAS">
			<form:Row name="GRILLASROWS2">
				<form:Blank name="bl0024d" width="100%" visible=""/>
				<form:RowAligner name="datos" columns="3" visible="EDIT">
					<form:Row name="dato">
						<form:CheckBox required="0" enabled="" label="Todos" nvalue="" name="todos"/>
						<form:CheckBox required="0" enabled="" label="Excluir" nvalue="" name="excluir"/>
					</form:Row>
				</form:RowAligner>
			</form:Row>
			<form:Row name="row2">
				<form:Label name="lbS" label="Personas Inicializadas" visible="EDIT" align="center" style="M1"/>
				<form:Label name="lblS" visible="EDIT" label="Personas a Incluir/Excluir" align="center" style="M1"/>
			</form:Row>
			<form:Row name="row3">
				<form:Grid visible="EDIT" idvalue="#SOURCEGRILLAINI:@id" nvalue="#PERSONASINI:" doc="SOURCEGRILLAINI" name="grdDatosPersonaInicializadas" note="" descrip="" rows="8" allowhelper="0" allowdelall="0" allownew="0" allowdel="0" paging="1" enabled="">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput nvalue="#SOURCEGRILLAINI:@id" required="0" xsize="10" length="30" label="Legajo" name="oi_personal_emp">
								<form:STexts>
									<form:SText enabled="0" xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.INICIALIZAR.guia.flow" c2x="C2X" x2c="X2C" help="HELP">
									<helper-mess oi_liquidacion="{oi_liquidacion.ReadXValue}" code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
								</form:Helper>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn>
							<form:Link descrip="Ver horas procesadas de la persona" allowimg="1" img="ok" label="" name="LINK">
								<form:Event runat="server" name="onclick" action="VERHORAS"/>
							</form:Link>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
				<form:Grid name="grdDatosPersona" visible="EDIT" note="" rows="8" allowhelper="1" allowdelall="1" allownew="0" allowdel="0" paging="1" enabled="" idvalue="" nvalue="" doc="SOURCEGRILLA">
					<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.INICIALIZAR.LM.guia.flow" action="HELP" xmlns:form="nomad_engine.form">
						<helper-mess oi_liquidacion="{oi_liquidacion.ReadXValue}">
							{grdDatosPersona.Nodes}
						</helper-mess>
					</form:Helper>
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:FKInput required="0" enabled="" xsize="10" length="30" label="Legajo" nvalue="" name="oi_personal_emp">
								<form:STexts>
									<form:SText xsize="50"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.INICIALIZAR.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" oi_liquidacion="{oi_liquidacion.ReadXValue}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton img="SEARCH" label="Search" visible="0" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Row>
		</form:RowAligner>
		<form:Hidden nvalue="#source:@id" name="oi_liquidacion"/>
		<form:ListView sortdirection="1" width="75%" rows="15" name="LIST" visible="SHOW" docname="RS">
			<form:LVColumns>
				<form:LVColumn sorteable="1" align="left" width="200px" visible="SHOW" type="string" name="personal" label="Legajo" attrname="personal"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="2">
			<form:Row name="filaBotones">
				<form:Button descrip="Mostrar datos de Horas Procesadas del Legajo" label="Horas Procesadas" name="HORAS" visible="SHOW" note="Guardar los Cambios en la Base de Datos" img="ok">
					<form:Event runat="server" name="onclick" action="VERHORAS"/>
				</form:Button>
				<form:Button visible="NEW|EDIT" note="Guardar los Cambios en la Base de Datos" descrip="Guardar los Cambios en la Base de Datos" img="save" label="Guardar" name="SAVE" mess="Desea Guardar los Cambios?">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Ver personas inicializadas en el Procesamiento de Horas" visible="NEW|EDIT" note="" img="search" label="Vista Previa" name="VISTAPREVIA">
					<form:Event action="VISTAPREVIA" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Blanquear personas del Procesamiento de Horas" visible="NEW|EDIT" note="" img="group_del" label="Blanquear" name="BLANQUEAR">
					<form:Event action="BLANQUEAR" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Vovler a la pantalla anterior" visible="" note="" img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
