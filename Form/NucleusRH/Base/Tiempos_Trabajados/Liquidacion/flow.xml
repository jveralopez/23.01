<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="initialize" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.flow" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.autoflow">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.Liquidacion"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_empresa="" c_estado="" oi_liquidacion=""/>
		</doc:define>
		<qry:define declare="&lt;FILTRO oi_empresa=&quot;&quot; c_estado=&quot;&quot; oi_liquidacion=&quot;&quot;/&gt;&#13;&#10;&#9;" name="FILTER">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT TTA09_LIQUIDACION.oi_liquidacion, TTA09_LIQUIDACION.c_liquidacion, 
					TTA09_LIQUIDACION.d_liquidacion, ORG03_EMPRESAS.c_empresa
					FROM TTA09_LIQUIDACION, ORG03_EMPRESAS 
	        JOIN TTA09_LIQUIDACION.OI_EMPRESA LEFT OUTER ORG03_EMPRESAS.OI_EMPRESA 	        
	        WHERE 1=1
	        {%? (#SOURCE:@oi_empresa!='')	{% AND TTA09_LIQUIDACION.oi_empresa = {#SOURCE:@oi_empresa} %} {% %} %}
	        {%? (#SOURCE:@c_estado!='')	{% AND TTA09_LIQUIDACION.c_estado = {#SOURCE:@c_estado} %} {% %} %}
	        {%? (#SOURCE:@oi_liquidacion!='')	{% AND TTA09_LIQUIDACION.oi_liquidacion = {#SOURCE:@oi_liquidacion} %} {% %} %}	        
	        ORDER BY oi_liquidacion ASC
       	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_liquidacion" name="value"/>
						<qry:attribute value="$r/@oi_liquidacion" name="id"/>
						<qry:attribute value="$r/@c_liquidacion" name="c_liquidacion"/>
						<qry:attribute value="$r/@d_liquidacion" name="d_liquidacion"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;FILTRO oi_empresa=&quot;9&quot; c_estado=&quot;&quot; oi_liquidacion=&quot;10&quot;/&gt;&#13;&#10;&#9;" name="LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
					SELECT TTA09_LIQUIDACION.oi_liquidacion, TTA09_LIQUIDACION.oi_empresa,
					TTA09_LIQUIDACION.c_liquidacion, 
					TTA09_LIQUIDACION.d_liquidacion, TTA09_LIQUIDACION.f_fechainicio, 
					TTA09_LIQUIDACION.f_fechafin, TTA09_LIQUIDACION.c_estado, ORG03_EMPRESAS.c_empresa
					FROM TTA09_LIQUIDACION, ORG03_EMPRESAS 
	        JOIN TTA09_LIQUIDACION.oi_empresa LEFT OUTER ORG03_EMPRESAS.oi_empresa
	        WHERE 1 = 1
	        {%? (#SOURCE:@oi_empresa!='')	{% AND TTA09_LIQUIDACION.oi_empresa= {#SOURCE:@oi_empresa} %} {% %} %}
	        {%? (#SOURCE:@c_estado!='')	{% AND TTA09_LIQUIDACION.c_estado= {#SOURCE:@c_estado} %} {% %} %}
	        {%? (#SOURCE:@oi_liquidacion!='')	{% AND TTA09_LIQUIDACION.oi_liquidacion = {#SOURCE:@oi_liquidacion} %} {% %} %}	        
	        ORDER BY oi_liquidacion	ASC
        ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:if test="$r/@oi_empresa!=''">
							<qry:then>
								<qry:element name="oi_empresa">
									<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
									<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:attribute value="$r/@oi_liquidacion" name="value"/>
						<qry:attribute value="$r/@oi_liquidacion" name="id"/>
						<qry:attribute value="$r/@c_liquidacion" name="c_liquidacion"/>
						<qry:attribute value="$r/@d_liquidacion" name="d_liquidacion"/>
						<qry:attribute value="$r/@f_fechainicio" name="f_fechainicio"/>
						<qry:attribute value="$r/@f_fechafin" name="f_fechafin"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;LIQUIDACION descr=&quot;[022007] Primera quincena de Febrero_Legajo 3&quot; c_estado=&quot;pro&quot; f_fechafin=&quot;20070215&quot; d_liquidacion=&quot;Primera quincena de Febrero_Legajo 3&quot; f_fechainicio=&quot;20070201&quot; c_liquidacion=&quot;022007&quot; id=&quot;47&quot;&gt;&lt;oi_empresa value=&quot;9&quot; nmd-agr=&quot;1&quot; /&gt;&lt;/LIQUIDACION&gt;" name="INI_QRY">
			<qry:main doc="SOURCE">
				<qry:element name="DATOS">
					<qry:attribute value="#SOURCE:LIQUIDACION/@id" name="ID"/>
					<qry:element name="PERSONAS">
						<qry:insert-select name="RS1" doc-path="#SOURCE:LIQUIDACION"/>
						<qry:if test="@cant!=''">
							<qry:then>
								<qry:element name="ROW">
									<qry:attribute name="cant" value="../@cant"/>
									<qry:attribute name="VALUES" value="substring(../@values,1)"/>
								</qry:element>
								<qry:attribute value="''" name="cant"/>
								<qry:attribute value="''" name="values"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					TTA10_LIQUIDACPERS.oi_personal_emp
				FROM 
					TTA10_LIQUIDACPERS					
				WHERE
					TTA10_LIQUIDACPERS.oi_liquidacion = {#SOURCE:@id}  					
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@cant)+1" name="cant"/>
					<qry:attribute value="@values+','+$r/@oi_personal_emp" name="values"/>
					<qry:if test="@cant='100'">
						<qry:then>
							<qry:element name="ROW">
								<qry:attribute name="cant" value="../@cant"/>
								<qry:attribute name="VALUES" value="substring(../@values,1)"/>
							</qry:element>
							<qry:attribute value="''" name="cant"/>
							<qry:attribute value="''" name="values"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PERSONAS"/>
		<qry:define declare="&lt;DATA oi_personal_emp=&quot;34&quot; oi_liquidacion=&quot;201&quot; /&gt;" name="QRY_PARAM_LIQ">
			<qry:main doc="SOURCE">
				<FILTRO parcial="1" reprocesar="1">
					<PERSONAS>
						<ROW>
							<qry:attribute name="VALUES" value="#SOURCE:DATA/@oi_personal_emp"/>
						</ROW>
					</PERSONAS>
				</FILTRO>
			</qry:main>
		</qry:define>
		<doc:define name="PROCESAR">
			<FILTRO>
				<PERSONAS/>
			</FILTRO>
		</doc:define>
		<doc:define name="PARAM">
			<DATA/>
		</doc:define>
		<doc:define name="DATOS"/>
		<qry:define declare="&lt;FILTRO VALUES=&quot;19743&quot; CONC=&quot;1000,1327,1001,1003,1026,1020,1021,1004,1005,1006,1007,1008,1009,1010,1011,1012,1013,1014,1015,1016,1017,1018,1019,1024,1025&quot; f_hasta=&quot;20200215&quot; f_desde=&quot;20200201&quot; oi_liquidacion=&quot;201&quot;/&gt;&#13;&#10;" name="qry_datos">
			<qry:include name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion_Personas.LIQUIDACIONPERS.QRY_HORAS_MANUAL"/>
			<qry:main doc="PARAM" maxdeep="3">
				<DATOS>
					<qry:create-doc name="PEPE"/>
					<qry:insert-select name="MAIN" doc-path="#PARAM:" to-element="$PEPE"/>
					<AUX>
						<qry:insert-select name="LEG" doc-path="."/>
					</AUX>
					<!--qry:insert-element doc-path="$PEPE/qry:no-show/LEG"/-->
					<CON>
						<qry:insert-select name="CON"/>
					</CON>
					<DETALLE>
						<qry:insert-select name="DET" doc-path="."/>
					</DETALLE>
					<MENSUAL>
						<qry:insert-select name="MES" doc-path="."/>
					</MENSUAL>
					<qry:attribute name="idrep" value="#PROXY:@TOKEN + '_' + ./AUX/LEG/@oip"/>
				</DATOS>
			</qry:main>
			<qry:select name="LEG" doc="PARAM">
				<qry:xquery>
					for $r in $PEPE/qry:no-show/LEG
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="DET" doc="PARAM">
				<qry:xquery>
					for $r in $PEPE/qry:no-show/LEG/DET
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="MES" doc="PARAM">
				<qry:xquery>
					for $r in $PEPE/qry:no-show/LEG/CONMEN
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="CON">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					TTA15_CONCEPTOS.oi_concepto,
					TTA15_CONCEPTOS.d_concepto,
					TTA15_CONCEPTOS.c_concepto,
					TTA15_CONCEPTOS.c_coleccion,
					TTA15_CONCEPTOS.e_mostrar,
					TTA15_CONCEPTOS.c_unidad
				FROM 
					TTA15_CONCEPTOS
				WHERE 
					TTA15_CONCEPTOS.e_mostrar != 0
					AND TTA15_CONCEPTOS.l_activo != 0 
				ORDER BY 
					e_mostrar ASC
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="C">
						<qry:attribute value="$r/@oi_concepto" name="id"/>
						<qry:attribute value="$r/@d_concepto" name="d_concepto"/>
						<qry:attribute value="$r/@c_concepto" name="c_concepto"/>
						<qry:attribute value="$r/@c_coleccion" name="c_coleccion"/>
						<qry:attribute value="$r/@c_unidad" name="c_unidad"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FILTRO">
			<FILTRO/>
		</doc:define>
		<qry:define name="qry_set_params" declare="&lt;DATA oi_personal_emp=&quot;&quot; oi_liquidacion=&quot;155&quot; /&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="FILTRO">
					<qry:attribute name="oi_liquidacion" value="#SOURCE:DATA/@oi_liquidacion"/>
					<qry:insert-select name="RS1" doc-path="#SOURCE:DATA"/>
					<qry:insert-select name="RS2"/>
					<qry:attribute name="VALUES" value="#SOURCE:DATA/@oi_personal_emp"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					TTA09_LIQUIDACION.f_fechainicio,
					TTA09_LIQUIDACION.f_fechafin
				FROM 
					TTA09_LIQUIDACION					
				WHERE
					TTA09_LIQUIDACION.oi_liquidacion = {#SOURCE:@oi_liquidacion}  					
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@f_fechainicio" name="f_desde"/>
					<qry:attribute value="$r/@f_fechafin" name="f_hasta"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in SQL('
				SELECT 
						TTA15_CONCEPTOS.oi_concepto,
						TTA15_CONCEPTOS.d_concepto as des,
						TTA15_CONCEPTOS.e_mostrar
					FROM 
						TTA15_CONCEPTOS
					WHERE 
						TTA15_CONCEPTOS.e_mostrar != 0
						AND TTA15_CONCEPTOS.l_activo != 0 
					ORDER BY 
						e_mostrar ASC
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="@CONC != ''">
						<qry:then>
							<qry:attribute value="@CONC +','+$r/@oi_concepto" name="CONC"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@oi_concepto" name="CONC"/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="SETREP">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#PARAM:@oi_personal_emp"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_liquidacion" to-attr-path="#PARAM:@oi_liquidacion"/>
			<doc:load-qry qry="qry_set_params" output-doc="FILTRO" input-doc-path="#PARAM:"/>
			<doc:load-qry qry="qry_datos" input-doc-path="#FILTRO:" output-doc="DATOS"/>
			<doc:save-file name="Procesamiento" name-ext="#DATOS:@idrep" group="TEMP" doc-path="#DATOS:"/>
			<flow:exit-flow return-path="#DATOS:"/>
		</flow:action>
		<flow:action name="PROC_PER">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#PARAM:@oi_personal_emp"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_liquidacion" to-attr-path="#PARAM:@oi_liquidacion"/>
			<doc:set-attribute from-attr-path="#SOURCE:@idrep" to-attr-path="#PARAM:@idrep"/>
			<doc:load-qry output-doc="PROCESAR" input-doc-path="#PARAM:" qry="QRY_PARAM_LIQ"/>
			<flow:exec-method out-attr-path="#BATCHDOC:@batch-id" out-type="String" class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion_Personas.LIQUIDACIONPERS" method="EjecutarLiquidacion" priority="9">
				<flow:param attr-path="#SOURCE:@oi_liquidacion" name="pintoi_liquidacion" type="Nomad.NSystem.Int" mode="in"/>
				<flow:param doc="PROCESAR" type="Nomad.NSystem.Object" name="pobjParams" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQ_REP.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="SAVE">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_personal_emp" to-attr-path="#PARAM:@oi_personal_emp"/>
			<doc:set-attribute from-attr-path="#SOURCE:@oi_liquidacion" to-attr-path="#PARAM:@oi_liquidacion"/>
			<doc:set-attribute from-attr-path="#SOURCE:@idrep" to-attr-path="#PARAM:@idrep"/>
			<flow:exec-method method="SaveManual" class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion_Personas.LIQUIDACIONPERS">
				<flow:param attr-path="#SOURCE:@idrep" type="Nomad.NSystem.String" mode="in" name="repid"/>
			</flow:exec-method>
			<flow:call-action action="SETREP"/>
		</flow:action>
	</flow:main>
	<flow:group name="LIQUIDACION">
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.form" mode="FILTER" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.filter.autoform:FILTER" doc="SOURCE">
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="on-show">
				<flow:call-action action="inits-DDO"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.noreg.form:EDIT" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.noreg.autoform:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.noreg.autoform" doc="SOURCE" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_estado" from-value="abi"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
		</flow:form>
		<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form:SHOW" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.autoform:SHOW" doc="SOURCE" mode="SHOW" parent-doc="PARENTSOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
			</flow:action>
			<flow:action name="LEGAJOS">
				<doc:load-qry output-doc="PERSONAS" qry="INI_QRY" input-doc-path="#SOURCE:"/>
				<flow:open-form doc-path="#PERSONAS:" parent-doc-path="#SOURCE:" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.ADMINISTRAR.form" mode="LIST"/>
			</flow:action>
			<flow:action name="PROCESAR">
				<flow:open-form doc-path="#PROCESAR:" parent-doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.PROCESAR.form"/>
			</flow:action>
			<flow:action name="CERRAR">
				<flow:exec-method this-doc="DDO" class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION" method="CerrarLiquidacion" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id"/>
				<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
			</flow:action>
			<flow:action name="CALL:LIQUIDACIONPERS">
				<!--doc:load-qry output-doc="PERSONAS" qry="LIQUIDACIONPERS" input-doc-path="#SOURCE:"/-->
				<flow:open-form doc-path="#SOURCE:" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.PERSONAS.form" parent-doc-path="#SOURCE:" mode="LIST"/>
			</flow:action>
			<flow:action name="CONGELAR">
				<flow:exec-method method="CongelarLiquidacion" this-doc="DDO" class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id"/>
				<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
			</flow:action>
			<flow:action name="DESCONGELAR">
				<flow:exec-method method="DescongelarLiquidacion" this-doc="DDO" class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id"/>
				<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form:LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form" mode="LIST">
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.form"/>
