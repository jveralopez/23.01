<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.autoflow" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_liquidacion as ID, 
				t.c_liquidacion as CODE, 
				t.d_liquidacion as TEXT,
				EMP.d_empresa as EMP, 
				SEC.policy 
				FROM TTA09_LIQUIDACION as t, 
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION\') as SEC,
				ORG03_EMPRESAS as EMP
				JOIN t.oi_liquidacion LEFT OUTER SEC.id,
				t.oi_empresa LEFT OUTER EMP.oi_empresa
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@EMP" name="emp"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.autoform:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Liquidacion.LIQUIDACION.guia.form"/>
</flow:flow>
