<form:Form xmlns:form="nomad_engine.form" name="NOVEDADES" doc="source">
	<form:Title>
		<form:Label label="Planilla de carga de Novedades" name="lbl_titulo" style="S3 LCol_w"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="bl1"/>
		<form:Columns name="cols">
			<form:Column name="col" separation="2" align="center" valign="top">
				<form:Combo required="1" flow="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.combo.autoflow" action="COMBO" label="Terminal" name="oi_terminal"/>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl2"/>
		<form:Grid width="1020px" proto="&lt;ROW/&gt;" doc="DATAGRID" allowdelall="1" allowdel="1" allownew="1" nvalue="#source:" paging="1" rows="10" name="grdnovedades">
			<form:GColumns>
				<form:GColumn name="colLegajo">
					<form:FKInput label="Empresa - Legajo" name="oi_personal_emp" nvalue="#DATAGRID:@oi_personal_emp" length="30" xsize="7" visible="" required="1">
						<form:STexts>
							<form:SText descrip="Legajos por Empresa" name="txt1" xsize="35"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton descrip="Selecci&#243;n de Legajos por Empresa" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn name="colFechaDesde">
					<form:DateTime xsize="17" pattern="YYYYMMDDHHMM" label="Fecha Hora Desde" required="1" mask="dd/mm/yyyy" nvalue="#DATAGRID:@desde" name="desde">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="colFechaHasta">
					<form:DateTime xsize="17" pattern="YYYYMMDDHHMM" label="Fecha Hora Hasta" required="1" mask="dd/mm/yyyy" nvalue="#DATAGRID:@hasta" name="hasta">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:GColumn>
				<form:GColumn name="colTipoHora">
					<form:FKInput label="Tipo de Hora" name="oi_tipohora" nvalue="#DATAGRID:@oi_tipohora" length="30" xsize="7" visible="" required="1">
						<form:STexts>
							<form:SText visible="0" descrip="Legajos por Empresa" name="txt1" xsize="35"/>
						</form:STexts>
						<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
							<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
						</form:Helper>
						<form:SButtons>
							<form:SButton descrip="Selecci&#243;n de Legajos por Empresa" name="SEARCH" label="Search" img="SEARCH">
								<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
							</form:SButton>
						</form:SButtons>
					</form:FKInput>
				</form:GColumn>
				<form:GColumn name="colDescripcion">
					<form:TextBox nvalue="#DATAGRID:@d_novedad" required="1" ysize="1" xsize="35" length="100" label="Descripci&#243;n" name="d_novedad"/>
				</form:GColumn>
			</form:GColumns>
			<form:SButtons>
				<form:SButton descrip="Duplicar un registro" label="Duplicar" img="duplicate" name="duplicate">
					<form:Event action="duplicate" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:Grid>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="rowaligner1">
			<form:Row name="row1">
				<form:Button startvalidate="1" descrip="Ejecutar el Proceso de Verificaci&#243;n de Fichadas para el rango de fechas y los Legajos seleccionados" label="Ejecutar" img="ok" name="EXECUTE" note="Consultar los Legajos seleccionados">
					<form:Event action="EXECUTE" runat="server" name="onclick"/>
				</form:Button>
				<form:Button img="back" label="Volver" name="BACK" descrip="Volver al Menu princial" note="Volver al Menu princial">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function duplicate()
{
	if (Ctrl('grdnovedades').TotalRowsCount() !=0)
	{
		var per = Ctrl('grdnovedades').GetCellSelectedXValue('oi_personal_emp');
		var desde = Ctrl('grdnovedades').GetCellSelectedXValue('desde');
		var hasta = Ctrl('grdnovedades').GetCellSelectedXValue('hasta');
		var th = Ctrl('grdnovedades').GetCellSelectedXValue('oi_tipohora');
		var descr = Ctrl('grdnovedades').GetCellSelectedXValue('d_novedad');		
		
		Ctrl('grdnovedades').AddNew();
				
		var objctrl = Ctrl('grdnovedades').GetCellSelectedControl('oi_personal_emp');
		objctrl.SetXValue(per);		
		objctrl = Ctrl('grdnovedades').GetCellSelectedControl('desde');
		objctrl.SetXValue(desde);
		objctrl = Ctrl('grdnovedades').GetCellSelectedControl('hasta');
		objctrl.SetXValue(hasta);
		objctrl = Ctrl('grdnovedades').GetCellSelectedControl('oi_tipohora');
		objctrl.SetXValue(th);
		objctrl = Ctrl('grdnovedades').GetCellSelectedControl('d_novedad');
		objctrl.SetXValue(descr);
	}	
}
	</form:Scripts>
</form:Form>
