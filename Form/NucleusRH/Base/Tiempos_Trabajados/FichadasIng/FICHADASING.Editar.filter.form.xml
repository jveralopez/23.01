<form:Form xmlns:form="nomad_engine.form" name="filtroingreso" doc="source">
	<form:Title width="90%">
		<form:Label label="Editar fichadas" name="lbl1" style="S3 LCol_W" align="center" visible="FILTER"/>
	</form:Title>
	<form:Center width="85%">
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="M1 LCol_g" visible=""/>
		<form:Blank name="bl2" width="100%" visible=""/>
		<form:Columns name="columns10" width="90%">
			<form:Column width="90%" name="Column10">
				<form:ComboBox nvalue="#FILTERDATA:@oi_personal_emp" queryname1="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO_CONF" queryname2="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO" xsize="35" mode="QRY" required="1" label="Empresa - Legajo" name="oi_personal_emp"/>
				<form:DateTime name="f_ini_m" nvalue="#FILTERDATA:@f_ini" label="Fecha Desde" mask="dd/mm/yyyy" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar_m" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event runat="client" name="onvalidate" action="VALIDAR"/>
				</form:DateTime>
				<form:DateTime label="Fecha Hasta" name="f_fin_m" nvalue="#FILTERDATA:@f_fin" mask="dd/mm/yyyy" required="1" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar_m" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
					<form:Event runat="client" name="onvalidate" action="VALIDAR"/>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons1">
			<form:Row name="row_top1">
				<form:Button descrip="Accede a la fichadas del Legajo para el rango de fechas seleccionado" policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/NEW" enabled="" visible="" name="btnIngresar" label="Aceptar" note="" img="ok" startvalidate="1">
					<form:Event name="onclick" action="FILTER" runat="server"/>
				</form:Button>
				<form:Button descrip="Volver al Menu Principal" enabled="" visible="" name="btnVolver" label="Volver" note="" img="back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function VALIDAR(myThis)
{						
	if (Ctrl('f_ini_m').GetXValue() &gt; Ctrl('f_fin_m').GetXValue())
	{
		myThis.SetError('El rango de fechas especificado no es correcto');
		return false;						
	}						
	
	if (Ctrl('f_ini_m').GetXValue() == "" &amp;&amp; Ctrl('f_fin_m').GetXValue() != "")
	{
		myThis.SetError('El rango de fechas especificado no es correcto');
		return false;						
	}	

	if (Ctrl('f_ini_m').GetXValue() != "" &amp;&amp; Ctrl('f_fin_m').GetXValue() == "")
	{
		myThis.SetError('El rango de fechas especificado no es correcto');
		return false;						
	}	  								
	return true;
}
	</form:Scripts>
</form:Form>
