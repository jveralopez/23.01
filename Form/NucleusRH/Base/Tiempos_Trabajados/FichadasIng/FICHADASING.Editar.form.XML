<form:Form name="FICHADASING.manual.form" doc="source" xmlns:form="nomad_engine.form" default_mode="SHOW">
	<form:Title width="90%">
		<form:Label name="lbl1" style="S3 LCol_W" align="center" visible="FILTER|SHOW" label="Edici&#243;n de Fichadas"/>
		<form:Label name="lbl2" label="Edici&#243;n de Fichadas" style="S3 LCol_W" align="center" visible="EDIT"/>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="bl1111" width="100px" visible=""/>
		<form:RowAligner visible="FILTER|SHOW|EDIT" name="rowfecha">
			<form:Row name="row1">
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NO" mask="dd/mm/yyyy" label="Fecha Inicio" nvalue="#FILTERDATA:@f_ini" name="f_ini">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="NO">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Blank name="bl1" width="100px" visible=""/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="NO" mask="dd/mm/yyyy" label="Fecha Fin" nvalue="#FILTERDATA:@f_fin" name="f_fin">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="NO">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Row>
		</form:RowAligner>
		<form:RowAligner name="rowper" visible="">
			<form:Row name="row2">
				<form:FKInput name="oi_personal_emp" nvalue="#FILTERDATA:@oi_personal_emp" label="Personal" length="30" xsize="15" visible="" required="1" enabled="FILTER">
					<form:STexts>
						<form:SText name="txt12" xsize="50"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.PERSONAL_EMP.guia.autoflow" c2x="C2X" x2c="X2C" help="HELP">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="FILTER" name="SEARCH" label="Search" img="SEARCH" enabled="FILTER">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Row>
		</form:RowAligner>
		<form:Blank name="bl32222" width="100px" visible=""/>
		<form:ListView rows="10" name="listFICHADAS" docname="RS" width="95%" visible="SHOW">
			<form:LVColumns>
				<form:LVColumn sorteable="1" additional="dd/mm/yyyy HH:MM:SS" type="datetime" label="Fecha-Hora" name="f_fechahora" attrname="f_fechahora"/>
				<form:LVColumn sorteable="1" label="Origen" type="string" attrname="origen" name="origen"/>
				<form:LVColumn additional="Listas/check.ico|Listas/uncheck.ico" sorteable="1" label="Anulada?" align="center" type="bool" name="l_anulada" attrname="l_anulada"/>
				<form:LVColumn type="string" name="o_observaciones" label="Observaciones" attrname="o_observaciones"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER|SHOW|EDIT" name="buttons">
			<form:Row name="row_top1">
				<form:Button label="Esperanza" img="search" name="btnEsperanza" descrip="Ver Esperanza" note="" visible="SHOW" enabled="">
					<form:Event action="get_fecha" name="onclick" runat="client"/>
					<form:Event name="onclick" action="VER" runat="extern">
						<form:helpper action="HELP" name="NucleusRH.Base.Tiempos_Trabajados.Personal.ESPERANZAPER.guia.flow">
							<FILTRO f_des="{f_ini.ReadXValue}" f_has="{f_fin.ReadXValue}" oi_personal_emp="{oi_personal_emp.ReadXValue}"/>
						</form:helpper>
					</form:Event>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/NEW" enabled="" visible="SHOW" name="btnAgregar" label="Agregar" note="" descrip="Agregar Nuevo Valor" img="new" startvalidate="0">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/EDIT" enabled="" visible="SHOW" name="btnModificar" label="Modificar" note="" descrip="Modificar Valor" img="edit" startvalidate="0">
					<form:Event action="CHANGE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="FILTER|SHOW" name="btnVolver" label="Volver" note="" descrip="Volver al Menu" img="back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/EDIT" enabled="EDIT" visible="EDIT" name="btnGuardar" label="Guardar" note="" descrip="Guardar Valor" img="save" startvalidate="0">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="EDIT" visible="EDIT" name="btnCancelar" label="Cancelar" note="" descrip="Cancelar la transacci&#243;n" img="cancel" infomess="0" mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/SECURITY" visible="SHOW" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function get_fecha()
{
	var fecha = str2date(Ctrl('listFICHADAS').GetSelectAttrValue('f_fechahora'));	
	Ctrl('f_fin').SetXValue(date2str(AddDays(fecha, 2)));
	Ctrl('f_ini').SetXValue(date2str(AddDays(fecha, -2)));	
	return true;
}
	</form:Scripts>
</form:Form>
