<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.autoflow" name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA.flow">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA.flow"/>
	<flow:declare>
		<qry:define name="qry_params">
			<qry:main>
				<qry:element name="PARAMS">
					<qry:insert-select name="PreEditFic"/>
					<qry:insert-select name="PosEditFic"/>
					<qry:insert-select name="EditMyFic"/>
				</qry:element>
			</qry:main>
			<qry:select name="PreEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PreEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PreEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="PosEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PosEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PosEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="EditMyFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'EditMyFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="EditMyFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PARAM"/>
		<doc:define name="FILTERDATA">
			<FILTRO oi_horario_nuevo="" f_inicio="" oi_horario_ant="" oi_escuadra_ant="" oi_empresa="" oi_clase_org="" oi_estructura="" oi_escuadra="" f_fin="" c_estado="" o_horariopers="">
				<ROWS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING" priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id" method="IngresoMasivo">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="FILTERDATA"/>
				<flow:param attr-path="#PARAM:@EditMyFic" type="Nomad.NSystem.Boolean" mode="in" name="EditMyFic"/>
			</flow:exec-method>
			<flow:call-action action="Save-FILTER"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.FichadasIng.MASIVA" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<doc:load-qry output-doc="PARAM" qry="qry_params"/>
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
	</flow:form>
</flow:flow>
