						<qry:attribute name="text" value="&apos;Terminal&apos;" type="Nomad.NSystem.String"/>
					</qry:element>
					<qry:element name="OPT">
						<qry:attribute name="value" value="&apos;M&apos;" type="Nomad.NSystem.String"/>
