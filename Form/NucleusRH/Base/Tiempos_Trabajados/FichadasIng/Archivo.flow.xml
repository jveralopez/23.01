<flow:flow extends="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.autoflow" default_action="initialize" name="IngFichadas" xmlns:qry="nomad_engine.form" xmlns:doc="nomad_engine.form" xmlns:flow="nomad_engine.form">
	<flow:info label="IngFichadas"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Archivo.filter.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Archivo.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Archivo.filter.form" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exec-method priority="9" out-type="String" out-attr-path="#BATCHDOC:@batch-id" method="ImportarFichadas" class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING">
				<flow:param attr-path="#FORM:ctrl[@id='cboTerminalarchivo']/@xval" mode="in" name="oi_terminal" type="Nomad.NSystem.Int"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
