<form:Form name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Archivo.filter.form" doc="source" xmlns:form="nomad_engine.form">
	<form:Center width="85%">
		<form:Label style="S3" align="center" name="lbl2" label="Criterio de Ingreso"/>
		<form:Columns name="columns10" width="80%">
			<form:Column name="Column10" width="80%">
				<form:Line width="100%" name="linea1"/>
				<form:Combo required="1" action="COMBO" flow="NucleusRH.Base.Tiempos_Trabajados.Terminales.TERMINAL.combo.autoflow" note="" label="Terminal" nvalue="#FILTERDATA:@oi_terminal" name="cboTerminalarchivo"/>
				<form:File descrip="Selecciona el archivo a subir" name="file" label="Archivo" note="" required="1" class="INTERFACES" filename="regist.dat" source="1">
					<form:SButtons>
						<form:SButton descrip="Selecciona el archivo a subir" enabled="" visible="" name="sbHelper" label="Buscar archivo" img="search">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:File>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons1">
			<form:Row name="row_top1">
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/FichadasIng/NEW" enabled="" visible="" name="btnIngresar" label="Ingresar" note="" descrip="Ingresa las fichadas" img="ok" startvalidate="1">
					<form:Event name="onclick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" note="" descrip="Volver al Menu" img="back">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Title width="90%">
		<form:Label label="Ingreso Fichadas - Archivo" name="lbl1" style="S3 LCol_W" align="center" visible="FILTER"/>
	</form:Title>
	<form:Scripts>
		&#9;&#13;&#10;&#9;
	</form:Scripts>
</form:Form>
