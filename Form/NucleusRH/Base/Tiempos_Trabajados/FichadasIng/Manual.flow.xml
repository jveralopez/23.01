<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.flow" extends="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.FichadasIng"/>
	<flow:declare>
		<qry:define declare="&lt;ELEMENTO id=&quot;687&quot; entrada=&quot;1&quot; fechahora=&quot;20071016133000&quot; id_personal_emp=&quot;62&quot; id_terminal=&quot;1&quot;&gt;&#13;&#10;&lt;ROWS&gt;&#13;&#10;&lt;ROW id=&quot;1&quot; entrada=&quot;1&quot; fechahora=&quot;20071016133000&quot; id_personal_emp=&quot;62&quot; id_terminal=&quot;1&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;&lt;/ELEMENTO&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ELEMENTO">
					<qry:insert-select doc-path="#SOURCE:" name="qry1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry1">
				<qry:xquery>
					for $r in #PARAM:ELEMENTO
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="" type="Nomad.NSystem.Int"/>
					<qry:attribute name="entrada" value="" type="Nomad.NSystem.Int"/>
					<qry:attribute name="fechahora" value="" type="Nomad.NSystem.Int"/>
					<qry:attribute name="id_personal_emp" value="" type="Nomad.NSystem.Int"/>
					<qry:attribute name="id_terminal" value="" type="Nomad.NSystem.Int"/>
					<qry:element name="ROWS">
						<qry:attribute name="cont" value="0" type="Nomad.NSystem.Int"/>
						<qry:append-doc name="AUX" doc-path="."/>
						<qry:insert-select doc-path="#PARAM:" name="qry2"/>
						<qry:attribute name="cont" value="''" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry2">
				<qry:xquery>
					for $r in #PARAM:ELEMENTO[@id!='']
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id" type="Nomad.NSystem.Int"/>
						<qry:attribute name="entrada" value="$r/@entrada" type="Nomad.NSystem.Int"/>
						<qry:attribute name="fechahora" value="$r/@fechahora" type="Nomad.NSystem.Int"/>
						<qry:attribute name="id_personal_emp" value="$r/@id_personal_emp" type="Nomad.NSystem.Int"/>
						<qry:attribute name="id_terminal" value="$r/@id_terminal" type="Nomad.NSystem.Int"/>
					</qry:element>
					<qry:insert-select doc-path="#PARAM:" name="qry3"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry3">
				<qry:xquery>
					for $r in #PARAM:ELEMENTO/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="cont" value="#AUX:@cont + 1" type="Nomad.NSystem.Int"/>
					<qry:insert-select doc-path="$r/.[#AUX:@cont &lt; 3]" name="qry4"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry4">
				<qry:out>
					<qry:insert-element doc-path="#PARAM:"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="LIST">
			<ELEMENTO id="" entrada="" fechahora="" id_personal_emp="" id_terminal="">
				<ROWS/>
			</ELEMENTO>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS f_fechahora="" c_tipo="" oi_empresa="">
				<oi_personal_emp value=""/>
				<oi_terminal value=""/>
			</DATOS>
		</doc:define>
		<qry:define name="qry_params">
			<qry:main>
				<qry:element name="PARAMS">
					<qry:insert-select name="PreEditFic"/>
					<qry:insert-select name="PosEditFic"/>
					<qry:insert-select name="EditMyFic"/>
				</qry:element>
			</qry:main>
			<qry:select name="PreEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PreEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PreEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="PosEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PosEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PosEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="EditMyFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'EditMyFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="EditMyFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PARAM"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Manual.form" mode="NEW"/>
		</flow:action>
	</flow:main>
	<flow:group name="FICHADASING">
		<flow:form name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Manual.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Manual.form" extends="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" mode="NEW">
			<flow:action name="save-DDO">
				<doc:save-object class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING" doc="NEWDDOROOT"/>
			</flow:action>
			<flow:action name="FICHAR">
				<flow:call-action action="set-FILTER"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="set-USER"/>
				<flow:call-action action="save-DDO"/>
				<flow:call-action action="set-LIST"/>
				<flow:call-action action="on-show"/>
				<flow:call-action action="new-DDO"/>
			</flow:action>
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="Load-FILTER">
				<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Manual" doc="SOURCE"/>
			</flow:action>
			<flow:action name="Save-FILTER">
				<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING.Manual" doc-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="on-open">
				<doc:load-qry output-doc="PARAM" qry="qry_params"/>
				<flow:call-action action="Load-FILTER"/>
				<flow:call-action action="new-DDO"/>
			</flow:action>
			<flow:action name="new-DDO">
				<doc:new-object class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING" doc="NEWDDOROOT"/>
				<doc:set-attribute from-value="M" to-attr-path="#NEWDDOROOT:@c_origen"/>
				<doc:set-attribute from-value="P" to-attr-path="#NEWDDOROOT:@c_estado"/>
				<doc:set-attribute from-attr-path="#SOURCE:oi_terminal/@value" to-attr-path="#NEWDDOROOT:oi_terminal/@value"/>
			</flow:action>
			<flow:action name="set-LIST">
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@id" to-attr-path="#LIST:@id"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@c_tipo" to-attr-path="#LIST:@entrada"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:@f_fechahora" to-attr-path="#LIST:@fechahora"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:oi_personal_emp/@value" to-attr-path="#LIST:@id_personal_emp"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:oi_terminal/@value" to-attr-path="#LIST:@id_terminal"/>
			</flow:action>
			<flow:action name="on-show">
				<doc:load-qry output-doc="LIST" input-doc-path="#LIST:" qry="LIST"/>
				<flow:attach-doc doc-path="#LIST:ROWS" attach-id="RS"/>
				<flow:log text="ppPROXY" text-path="#PROXY:"/>
			</flow:action>
			<flow:action name="set-FILTER">
				<doc:set-attribute to-attr-path="#SOURCE:@f_fechahora" from-attr-path="#NEWDDOROOT:@f_fechahora"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:oi_personal_emp/@value" to-attr-path="#SOURCE:oi_personal_emp/@value"/>
				<doc:set-attribute from-attr-path="#NEWDDOROOT:oi_terminal/@value" to-attr-path="#SOURCE:oi_terminal/@value"/>
			</flow:action>
			<flow:action name="set-USER">
				<doc:set-attribute from-attr-path="#PROXY:DATA/@USER" to-attr-path="#NEWDDOROOT:@d_user_create"/>
				<doc:set-attribute from-attr-path="#FORM:ctrl[@id='now']/@xval" to-attr-path="#NEWDDOROOT:@f_create"/>
			</flow:action>
		</flow:form>
	</flow:group>
</flow:flow>
