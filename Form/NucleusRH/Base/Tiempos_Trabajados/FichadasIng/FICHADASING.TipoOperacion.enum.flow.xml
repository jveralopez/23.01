<flow:flow xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form" xmlns:flow="nomad_engine.form" name="">
  <flow:info label="Flow guia para IngFichadasTipo.combo"/>
  <flow:main doc="SOURCE">
    <flow:action name="COMBO">
      <doc:load-qry output-doc="RS" qry="COMBO"/>
      <flow:exit-flow return-path="#RS:"/>
    </flow:action>
  </flow:main>
  <flow:declare>
    <doc:define name="RS"/>
     <qry:define name="COMBO">
    
      <qry:main doc="SOURCE">
        <qry:element name="ROWS">
        
          <qry:element name="OPT">
            <qry:attribute type="Nomad.NSystem.String" value="'1'" name="value"/>
            <qry:attribute type="Nomad.NSystem.String" value="'1'" name="code"/>
            <qry:attribute type="Nomad.NSystem.String" value="'Entrada'" name="text"/>
          </qry:element>
        
          <qry:element name="OPT">
            <qry:attribute type="Nomad.NSystem.String" value="'0'"       name="value"/>
            <qry:attribute type="Nomad.NSystem.String" value="'0'"       name="code"/>
            <qry:attribute type="Nomad.NSystem.String" value="'Salida'" name="text"/>
          </qry:element>

        </qry:element>
      </qry:main>
    </qry:define>
  </flow:declare>
</flow:flow>
