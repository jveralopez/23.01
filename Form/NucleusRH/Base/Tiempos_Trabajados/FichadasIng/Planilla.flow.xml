<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" extends="Nomad.Base.flow" name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.Planilla.flow">
	<flow:info label="flow para NucleusRH.Base.Tiempos_Trabajados.VerificarFichadas"/>
	<flow:declare>
		<doc:define name="DATAGRID">
			<ROWS/>
		</doc:define>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11140&quot; fecha=&quot;20091218141300&quot; c_tipo=&quot;E&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11565&quot; fecha=&quot;20090914080000&quot; c_tipo=&quot;E&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11565&quot; fecha=&quot;20090914160000&quot; c_tipo=&quot;S&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11566&quot; fecha=&quot;20090914080000&quot; c_tipo=&quot;E&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11566&quot; fecha=&quot;20090914160000&quot; c_tipo=&quot;S&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11567&quot; fecha=&quot;20090914080000&quot; c_tipo=&quot;E&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11567&quot; fecha=&quot;20090914160000&quot; c_tipo=&quot;S&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11568&quot; fecha=&quot;20090914080000&quot; c_tipo=&quot;E&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;  &lt;ROW oi_personal_emp=&quot;11568&quot; fecha=&quot;20090914160000&quot; c_tipo=&quot;S&quot; oi_terminal=&quot;1&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;&#13;&#10;" name="SETIDS">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="id" value="1"/>
					<qry:insert-select name="QRY1" doc-path="#PARAM:ROWS"/>
					<qry:attribute name="id" value="''"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY1" doc="PARAM">
				<qry:xquery>
					for $r in #PARAM:ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="../@id"/>
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="fecha" value="$r/@fecha"/>
						<qry:attribute name="c_tipo" value="$r/@c_tipo"/>
						<qry:attribute name="oi_terminal" value="$r/@oi_terminal"/>
					</qry:element>
					<qry:attribute name="id" value="./@id + 1"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="qry_params">
			<qry:main>
				<qry:element name="PARAMS">
					<qry:insert-select name="PreEditFic"/>
					<qry:insert-select name="PosEditFic"/>
					<qry:insert-select name="EditMyFic"/>
				</qry:element>
			</qry:main>
			<qry:select name="PreEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PreEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PreEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="PosEditFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'PosEditFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="PosEditFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
			<qry:select name="EditMyFic">
				<qry:xquery>
					for $r in SQL('
				SELECT
					ORG26_PARAMETROS.d_valor
				FROM 
					ORG26_PARAMETROS
				WHERE
					ORG26_PARAMETROS.c_parametro = \'EditMyFic\'
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="EditMyFic" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="PARAM"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#DATAGRID:" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.PLANILLA.form" mode="SHOW"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.PLANILLA.form:SHOW" mode="SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" form-class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.PLANILLA.form">
		<flow:action name="on-show">
			<doc:load-qry output-doc="PARAM" qry="qry_params"/>
			<flow:call-action action="Load-FILTER"/>
			<doc:load-qry output-doc="DATAGRID" input-doc-path="#DATAGRID:" qry="SETIDS"/>
		</flow:action>
		<flow:action name="EXECUTE">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.FichadasIng.FICHADASING" priority="5" out-attr-path="#BATCHDOC:@batch-id" method="CargarFichadas">
				<flow:param doc="DATAGRID" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="param"/>
				<flow:param attr-path="#PARAM:@EditMyFic" type="Nomad.NSystem.Boolean" mode="in" name="EditMyFic"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.PlanillaFichadas" doc-path="#DATAGRID:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.PlanillaFichadas" doc="DATAGRID"/>
		</flow:action>
	</flow:form>
</flow:flow>
