<form:Form name="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.filter.form" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:Label label="Seleccionar Filtro Generaci&#243;n de Esperanza por Empresa" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center width="85%">
		<form:Label name="lbl" label="Criterios de B&#250;squeda" align="center" style="S3 LCol_g" visible=""/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:Combo action="COMBO" flow="NucleusRH.Base.Organizacion.Empresas.EMPRESA.Combo.autoflow" required="1" enabled="" label="Empresa" name="oi_empresa"/>
				<form:DateTime name="f_ini" nvalue="#FILTERDATA:@f_ini" label="Fecha Desde" mask="dd/mm/yyyy" enabled="" required="0" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime name="f_fin" nvalue="#FILTERDATA:@f_fin" label="Fecha Hasta" mask="dd/mm/yyyy" enabled="" required="0" pattern="YYYYMMDD">
					<form:SButtons>
						<form:SButton visible="" name="Calendar" label="Calendar" img="Calendar">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/Esperanzaper/NEW" enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="bl9" width="50%" visible=""/>
				<form:Button enabled="" visible="" name="btnCAncelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
