<flow:flow name="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.flow.xml" default_action="initialize" extends="Nomad.Base.flow" xmlns:flow="nomad_engine.form" xmlns:doc="nomad_engine.form" xmlns:qry="nomad_engine.form">
	<flow:info label="NucleusRH.Base.Timepos_Trabajados.Esperanzaper.flow"/>
	<flow:declare>
		<doc:define name="ESPERANZAPERSONA">
			<DATOS>
				<FILTRO oi_clase_org="" oi_estructura="" oi_empresa="" f_ini="" f_fin="" esperanza_horaria="1">
					<PERSONAS/>
				</FILTRO>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.filter.form" doc-path="#SOURCE:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.filter.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="FILTER">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:set-attribute to-attr-path="#ESPERANZAPERSONA:/FILTRO/@oi_empresa" from-attr-path="#FORM:ctrl[@id='oi_empresa']/@xval"/>
			<doc:set-attribute to-attr-path="#ESPERANZAPERSONA:/FILTRO/@f_ini" from-attr-path="#FORM:ctrl[@id='f_ini']/@xval"/>
			<doc:set-attribute to-attr-path="#ESPERANZAPERSONA:/FILTRO/@f_fin" from-attr-path="#FORM:ctrl[@id='f_fin']/@xval"/>
			<flow:log text-path="#ESPERANZAPERSONA:" text="LogFiltroBatch"/>
			<flow:exec-method method="GenEsperanzaHoraria" priority="9" out-attr-path="#BATCHDOC:@batch-id" class="NucleusRH.Base.Tiempos_Trabajados.Esperanzaper.ESPERANZAPER" type="Nomad.NSystem.Object">
				<flow:param doc="ESPERANZAPERSONA" type="Nomad.NSystem.Object" mode="in" name="pobjParams"/>
			</flow:exec-method>
			<flow:open-form form-class="nomad.base.batch.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
