<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.flow" extends="Nomad.Base.flow" default_action="initialize">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.flow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.filter.form" mode="FILTER" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.filter.form:FILTER" mode="FILTER" doc="SOURCE" parent-doc="PARENTSOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method class="NucleusRH.Base.Tiempos_Trabajados.Fichadas_NI.Fichadas_NI" priority="9" out-attr-path="#BATCHDOC:@batch-id" method="ProcesarFichadas"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
