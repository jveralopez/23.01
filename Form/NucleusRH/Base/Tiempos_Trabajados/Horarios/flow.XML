<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" default_action="initialize" name="NucleusRH.Base.Tiempos_Trabajados.Horarios" extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.autoflow">
	<flow:declare>
		<qry:define declare="&lt;ROWS&gt; &#13;&#10;&#9;&lt;ROW id=&quot;46&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;" name="FILTER">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_horario as oi_horario,
					t0.c_horario, 
					SEC.policy 
				FROM 
					TTA02_HORARIOS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO\') as SEC JOIN t0.oi_horario LEFT OUTER SEC.id  
				WHERE
					1=1
					{%? (string(#SOURCE:ROWS/ROW/@id)!='') {% AND t0.oi_horario in ({%=string(#SOURCE:ROWS/ROW/@id) %}) %} {%  %} %}
				ORDER BY 
					c_horario asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_horario"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;ROWS&gt; &#13;&#10;&#9;&lt;ROW id=&quot;46&quot;/&gt;&#13;&#10;&lt;/ROWS&gt;" name="LIST">
			<qry:main doc="SOURCE" maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_horario as oi_horario, 
					t0.c_horario as c_horario, 
					t0.d_horario as d_horario, 
					t0.e_dias as e_dias, 
					t0.d_tipohorario as d_tipohorario, 
					t0.c_estado as c_estado, 
					t0.l_controla_fic as l_controla_fic,
					t0.l_convenio as l_convenio,  
					t0.c_color as c_color, 
					t0.c_horario as CODE, 
					t0.d_horario as TEXT 
				FROM 
					TTA02_HORARIOS as t0  
				WHERE
					1=1
					{%? (string(#SOURCE:ROWS/ROW/@id)!='') {% AND t0.oi_horario in ({%=string(#SOURCE:ROWS/ROW/@id) %}) %} {%  %} %}	
				ORDER BY 
					c_horario asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_horario"/>
						<qry:attribute name="c_horario" value="$r/@c_horario"/>
						<qry:attribute name="d_horario" value="$r/@d_horario"/>
						<qry:attribute name="e_dias" value="$r/@e_dias"/>
						<qry:attribute name="d_tipohorario" value="$r/@d_tipohorario"/>
						<qry:attribute name="e_iniciodia" value="$r/@e_iniciodia"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="l_controla_fic" value="$r/@l_controla_fic"/>
						<qry:attribute name="l_convenio" value="$r/@l_convenio"/>
						<qry:attribute name="img" value="iif($r/@c_estado='C','Listas/LOCK.ICO','')"/>
						<qry:attribute name="c_color" value="$r/@c_color"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="filterHorario">
			<doc:assign-value from-path="#SOURCE:" to-doc="FILTERDATA"/>
			<doc:load-qry input-doc-path="#FILTERDATA:" qry="FILTER" output-doc="QRY"/>
			<doc:new-object class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO" doc="DDO"/>
			<flow:open-form mode="EDIT2" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.autoform" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:"/>
		</flow:action>
	</flow:main>
	<flow:group Name="HORARIO">
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.autoform:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.autoform" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.form:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#NEWDDOROOT:" mode="NEW"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.autoform:NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="NEW">
			<flow:action name="save-DDO">
				<flow:exec-method method="AgregarEscuadras" class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO" this-doc="NEWDDOROOT">
					<flow:param attr-path="#FORM:ctrl[@id='cantesc']/@xval" type="Nomad.NSystem.Int" mode="in" name="esc"/>
				</flow:exec-method>
				<doc:save-object class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO" doc="NEWDDOROOT"/>
				<doc:load-object id-path="#NEWDDOROOT:@id" class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO" doc="DDO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.autoform:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" mode="EDIT">
			<flow:action name="CALL:DETALLE">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form" mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.autoform:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#DDO:" mode="EDIT"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#NEWDDOROOT:" mode="NEW"/>
			</flow:action>
			<flow:action name="CALL:DETALLE">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form" mode="SHOW" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
			</flow:action>
			<flow:action name="CLOSE">
				<flow:exec-method method="CerrarHorario" this-doc="DDO"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.autoform:LIST" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form:LIST" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" parent-doc="PARENTSOURCE" doc="SOURCE" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#DDO:" mode="EDIT"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#NEWDDOROOT:" mode="NEW"/>
			</flow:action>
			<flow:action name="CALL:DETALLE">
				<flow:call-action action="load-DDO"/>
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form" mode="SHOW" parent-doc-path="#DDO:" doc-path="#DDO:"/>
			</flow:action>
			<flow:action name="CLOSE">
				<flow:call-action action="load-DDO"/>
				<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
				<flow:exec-method method="CerrarHorario" this-doc="DDO"/>
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
			</flow:action>
			<flow:action name="After-Duplicar">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<doc:set-attribute to-attr-path="#FORM:ctrl[@id='LIST']/@xval" from-attr-path="#DDO:@id"/>
				<flow:attach-doc attach-id="RS" doc-path="#QRY_LIST:"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.autoform:EDIT" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.form:EDIT2" mode="EDIT2" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.noreg.autoform" parent-doc="PARENTSOURCE" doc="SOURCE">
			<flow:action name="open-flow-SHOW">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" doc-path="#NEWDDOROOT:" mode="NEW"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="goto-show"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group Name="HORARIO_DET">
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" mode="EDIT">
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="CANCEL">
				<flow:close-form/>
			</flow:action>
			<flow:action name="ACCEPT">
				<flow:exec-method method="ActualizarHorario" this-doc="DDO">
					<flow:param attr-path="#FORM:ctrl[@id='TUR']/@xval" type="Nomad.NSystem.String" mode="in" name="TUR"/>
					<flow:param attr-path="#FORM:ctrl[@id='EST']/@xval" type="Nomad.NSystem.String" mode="in" name="EST"/>
					<flow:param attr-path="#FORM:ctrl[@id='ESQ']/@xval" type="Nomad.NSystem.String" mode="in" name="ESQ"/>
				</flow:exec-method>
				<flow:close-form/>
			</flow:action>
			<flow:action name="on-show">
				<flow:attach-doc attach-id="RS" doc-path="#DDO:"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO_DET.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
			<flow:action name="BACK">
				<flow:close-form/>
			</flow:action>
			<flow:action name="on-show">
				<flow:attach-doc attach-id="RS" doc-path="#DDO:"/>
			</flow:action>
		</flow:form>
	</flow:group>
	<flow:group Name="ESCUADRA">
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.autoform:LIST_EDIT" doc-path="/ESCUADRA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form:LIST_EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.autoform" mode="LIST_EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.noreg.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-EDIT">
				<flow:open-form iter-index="#PARENTSOURCE:ESCUADRA/@id" parent-doc-path="#PARENTSOURCE:" doc-path="#PARENTSOURCE:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.autoform:EDIT" doc-path="/ESCUADRA[@id='{#iter-cursor:@value}']" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form" mode="EDIT">
			<flow:action name="open-flow-ADD">
				<flow:open-form parent-doc-path="#PARENTSOURCE:" doc-path="#NEWDDO:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form:NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.form" mode="NEW"/>
	</flow:group>
</flow:flow>
