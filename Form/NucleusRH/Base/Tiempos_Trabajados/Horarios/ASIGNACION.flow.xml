<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.autoflow" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.flow">
	<flow:info label="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.flow"/>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<FILTRO oi_horario_nuevo="" f_inicio="" oi_horario_ant="" oi_escuadra_ant="" oi_empresa="" oi_clase_org="" oi_estructura="" oi_escuadra="" f_fin="" c_estado="" o_horariopers="">
				<ROWS/>
			</FILTRO>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.filter.form" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.filter.form:FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.filter.form" doc="SOURCE">
		<flow:action name="ACCEPT">
			<flow:exec-method priority="5" out-type="String" out-attr-path="#BATCHDOC:@batch-id" method="AsignacionMasiva" class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO">
				<flow:param type="Nomad.NSystem.Proxy.NomadXML" doc="FILTERDATA" mode="in" name="FILTERDATA"/>
			</flow:exec-method>
			<flow:call-action action="Save-FILTER"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc attach-id="ARRB" doc-path="#SOURCE:ROWS"/>
		</flow:action>
	</flow:form>
</flow:flow>
