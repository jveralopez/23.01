<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.autoflow" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia">
	<flow:info label="Flow guia para NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO"/>
	<flow:main doc="SOURCE">
		<flow:action name="OPEN-GUIA">
			<flow:open-form parent-doc-path="#SOURCE:" doc-path="#SOURCE:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.form"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<qry:define name="X2C">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_horario as ID, 
				t.c_horario as CODE, 
				t.d_horario as TEXT, 
				t.d_tipohorario as tipo,
				SEC.policy  
				FROM TTA02_HORARIOS as t, 
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO\') as SEC 
				JOIN t.oi_horario LEFT OUTER SEC.id  
				WHERE t.oi_horario={#SOURCE:helper-mess/@ID} 				
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@tipo" name="tipo"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="C2X">
			<qry:main doc="SOURCE">
				<qry:append-doc doc-path="#SOURCE:helper-mess" name="INDOC"/>
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_horario as ID, 
				t.c_horario as CODE, 
				t.d_horario as TEXT,
				t.d_tipohorario as tipo, 
				SEC.policy  
				FROM TTA02_HORARIOS as t, 
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO\') as SEC 
				JOIN t.oi_horario LEFT OUTER SEC.id  
				WHERE t.c_horario={substring_before(#INDOC:@CODE,\'-\')} 				
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@policy" name="policy"/>
					<qry:attribute value="''" name="SUB_SEARCH"/>
					<qry:attribute value="''" name="PARENTID"/>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@ID" name="value"/>
					<qry:attribute value="$r/@CODE" name="code"/>
					<qry:attribute value="$r/@TEXT" name="text"/>
					<qry:attribute value="$r/@tipo" name="tipo"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="HELP">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
				SELECT t.oi_horario as ID, 
				t.c_horario as CODE, 
				t.d_horario as TEXT, 
				t.d_tipohorario as tipo,
				SEC.policy  
				FROM TTA02_HORARIOS as t, 
				NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO\') as SEC 
				JOIN t.oi_horario LEFT OUTER SEC.id  				
				ORDER BY CODE asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@ID" name="value"/>
						<qry:attribute value="$r/@CODE" name="code"/>
						<qry:attribute value="$r/@TEXT" name="text"/>
						<qry:attribute value="$r/@tipo" name="tipo"/>
						<qry:attribute value="$r/@policy" name="policy"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.autoform:SHOW" parent-doc="INVAL" doc="SOURCE" mode="SHOW" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.form"/>
</flow:flow>
