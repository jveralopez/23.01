<form:Form default_mode="SHOW" extends="nomad.filter.form" name="NucleusRH.Base.Tiempos_Trabajados.Horarios.ASIGNACION.VistaPrevia.form" xmlns:form="nomad_engine.form" doc="source">
	<form:Title>
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" label="Asignaci&#243;n Masiva de Horarios - Vista Previa" name="lbl" align="center" style="S3 LCol_w" visible=""/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Blank name="bl1" width="100%" visible=""/>
		<form:Columns name="Cols1">
			<form:Column name="Cl1">
				<form:FKInput enabled="0" nvalue="#FILTERDATA:@oi_horario_nuevo" label="Horario Nuevo" name="oi_horario_nuevo" required="1" descr="Horario asignado a una Persona" xsize="15" length="30">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.HORARIOPERS.HORARIOS.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" descrip="Nuevo Horario a Asignar" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:FKInput enabled="0" nvalue="#FILTERDATA:@oi_escuadra" required="0" xsize="15" length="30" label="Escuadra" name="oi_escuadra">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusRH.Base.Tiempos_Trabajados.Personal.HorarioEscuadra.guia.flow" help="HELP" x2c="X2C" c2x="C2X" cache="no">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" oi_horario="{oi_horario_nuevo.ReadXValue}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="0" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl2" width="100%" visible=""/>
		<form:ListView width="90%" paging="1" rows="-250" docname="RS" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.guia.autoflow&quot; /&gt;" align="left" sorteable="0" descr="c&#243;digo persona" width="40px" type="fk" label="Legajo" attrname="oi_personal_emp" name="oi_personal_emp"/>
				<form:LVColumn label="Horario Anterior" additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIO.guia.autoflow&quot; /&gt;" align="left" sorteable="0" descr="c&#243;digo persona" width="40px" type="fk" attrname="oi_horario_ant" name="oi_horario_ant"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusRH.Base.Tiempos_Trabajados.Horarios.ESCUADRA.guia.autoflow&quot; /&gt;" attrname="oi_escuadra_ant" label="Escuadra Anterior" align="left" sorteable="0" descr="c&#243;digo persona" width="40px" type="fk" name="oi_escuadra_ant"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="botones" columns="5">
			<form:Row name="filaBotones">
				<form:Button enabled="" visible="" name="btnVolver" label="Volver" img="back" note="" descrip="vuelve al menu principal">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
