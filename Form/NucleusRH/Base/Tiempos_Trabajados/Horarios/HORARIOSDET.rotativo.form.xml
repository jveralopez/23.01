<form:Form name="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIOSDET.rotativo" default_mode="SHOW" extends="nomad.childIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Crear Definicion de D&#237;as para Horario Rotativo" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
				<form:Label label="Modificar Definicion de D&#237;as para Horario Rotativo" nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT"/>
				<form:Label label="Eliminar Definicion de D&#237;as para Horario Rotativo" nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" name="GEN_DEL"/>
				<form:Label label="Consultar Definicion de D&#237;as para Horario Rotativo" nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#source:../../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner visible="0" name="buttonlinks"/>
		<form:Blank name="bl3" width="100%"/>
		<form:Columns visible="EDIT" name="ColumnaDefa">
			<form:Column name="uno">
				<form:FKInput label="Unidad Organizativa por defecto" name="oi_uorg" length="30" xsize="15" enabled="NEW|EDIT" required="0">
					<form:STexts>
						<form:SText name="txt1" xsize="50"/>
					</form:STexts>
					<form:Helper c2x="C2X" x2c="X2C" help="HELP" name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow">
						<helper-mess code="{this.CVal}" id="{this.XVal}" text="{this.Text.1}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="NEW|EDIT" enabled="NEW|EDIT" name="SEARCH" label="Search" img="SEARCH">
							<form:Event runat="client" name="onclick" action="SHOW_HELPER"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
			</form:Column>
		</form:Columns>
		<form:Blank name="bl4" width="100%"/>
		<form:Columns name="main_columnsHORARIOSDET">
			<form:Column name="main_columnsHORARIOSDETcolumn1">
				<form:Grid name="grdDatos" idvalue="#source:@id" allowdel="0" allownew="0" paging="1" rows="8" nvalue="#PARENTSOURCE:" doc="source">
					<form:GColumns>
						<form:GColumn name="col11111">
							<form:Link name="LINK" label="" img="link2" descrip="" allowimg="1"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT" allow_order="1">
							<form:TextBox enabled="EDIT" required="1" xsize="8" length="3" label="Posici&#243;n" nvalue="#source:@e_posicion" name="e_posicion"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:DateTime xsize="5" length="4" nvalue="#source:@f_hora_inicio" name="f_hora_inicio" pattern="HHMM" required="1" label="Hora Inicio" enabled="NEW|EDIT"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:DateTime xsize="5" length="4" nvalue="#source:@f_hora_fin" name="f_hora_fin" pattern="HHMM" label="Hora Fin" enabled="NEW|EDIT"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:Combo name="cboTDoc" xsize="10" nvalue="#source:oi_tipo_hs_norm/@value" label="Normal" note="" descrip="" flow="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.combo.autoflow" action="COMBO" enabled="NEW|EDIT" required="1"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:Combo name="cboThora2" nvalue="#source:oi_tipo_hs_dom/@value" note="" descrip="" flow="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.combo.autoflow" action="COMBO" enabled="NEW|EDIT" required="1" label="Domingo"/>
						</form:GColumn>
						<form:GColumn visible="NEW|SHOW|EDIT">
							<form:Combo enabled="NEW|EDIT" name="cboThora3" nvalue="#source:oi_tipo_hs_fer/@value" note="" flow="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.combo.autoflow" action="COMBO" required="1" label="Feriado"/>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:Combo name="cboThora4" nvalue="#source:oi_tipo_hs_domfer/@value" note="" descrip="" flow="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.combo.autoflow" action="COMBO" enabled="NEW|EDIT" required="1" label="Domingo Feriado"/>
						</form:GColumn>
						<form:GColumn visible="NEW|SHOW|EDIT">
							<form:FKInput label="Unidad Organizativa" required="1" enabled="NEW|EDIT" xsize="10" length="30" nvalue="#source:oi_estructura/@value" name="oi_unidad_org">
								<form:STexts>
									<form:SText xsize="40" name="txt1"/>
								</form:STexts>
								<form:Helper name="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
									<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}"/>
								</form:Helper>
								<form:SButtons>
									<form:SButton enabled="NEW|EDIT" visible="NEW|EDIT" img="SEARCH" label="Search" name="SEARCH">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:FKInput>
						</form:GColumn>
						<form:GColumn visible="SHOW|EDIT">
							<form:Combo enabled="NEW|EDIT" name="c_eval" nvalue="#source:@c_eval" label="Eval&#250;a Feriado" descr="Eval&#250;a feriado (Anterior, Posterior o Igual). Por ejemplo, si se trabaja desde el 24/05 a las 22 hasta el 25/05 a las 6, y este atributo dice Posterior, se pagan todas las Horas como Feriado." required="0" flow="NucleusRH.Base.Tiempos_Trabajados.Horarios.HORARIOSDET.c_eval.Combo.autoflow" action="COMBO"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row visible="0" name="row1"/>
			<form:Row name="row2">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1" visible="NEW">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/Horarios/NEW" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro" note="Agregar el Registro" visible="EDIT">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button policy="NucleusRH/Base/Tiempos_Trabajados/Horarios/DELETE" mess="Esta seguro que desea eliminar el registro?" name="DELETE" label="Eliminar" img="del" descrip="Eliminar el Registro" note="Eliminar el Registro" visible="EDIT">
					<form:Event runat="server" name="onclick" action="DELETE"/>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario" visible="NEW">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="EDIT" img="duplicate" label="Duplicar" name="Duplicar">
					<form:Event name="onclick" runat="server" action="DUPLICAR"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
