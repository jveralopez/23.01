<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.flow" extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.autoflow">
	<flow:info label="Flow para NucleusRH.Base.Tiempos_Trabajados.Conceptos"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_concepto as oi_concepto, 
					t0.oi_concepto as e_secuencia, 
					SEC.policy 
				FROM 
					TTA15_CONCEPTOS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO\') as SEC 
				JOIN 
					t0.oi_concepto LEFT OUTER SEC.id  
				ORDER BY e_secuencia asc, oi_concepto asc
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_concepto"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					t0.oi_concepto as oi_concepto, 
					t0.c_concepto as c_concepto, 
					t0.d_concepto as d_concepto, 
					t0.c_coleccion as c_coleccion, 
					t0.c_unidad as c_unidad, 
					t0.e_mostrar as e_mostrar, 
					t0.l_activo as l_activo, 
					t0.e_secuencia as e_secuencia, 
					t0.c_externo as c_externo, 
					SEC.policy, 
					t0.c_concepto as CODE, 
					t0.d_concepto as TEXT 
				FROM 
					TTA15_CONCEPTOS as t0,
					NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO\') as SEC 
				JOIN 
					t0.oi_concepto LEFT OUTER SEC.id  
				ORDER BY e_secuencia asc, oi_concepto asc
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_concepto"/>
						<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
						<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
						<qry:attribute name="c_coleccion" value="$r/@c_coleccion"/>
						<qry:attribute name="c_unidad" value="$r/@c_unidad"/>
						<qry:attribute name="e_mostrar" value="$r/@e_mostrar"/>
						<qry:attribute name="l_activo" value="iif($r/@l_activo='1','1','0')"/>
						<qry:attribute name="e_secuencia" value="$r/@e_secuencia"/>
						<qry:attribute name="c_externo" value="$r/@c_externo"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#SOURCE:" mode="FILTER" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.filter.autoform"/>
		</flow:action>
	</flow:main>
	<flow:group Name="CONCEPTO">
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.noreg.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.autoform" extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.autoform:LIST" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form:LIST" mode="LIST">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.autoform:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form:SHOW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form" mode="SHOW">
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form:EDIT" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form" mode="EDIT"/>
		<flow:form extends="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.autoform:NEW" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form:NEW" form-class="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.form" mode="NEW"/>
	</flow:group>
</flow:flow>
