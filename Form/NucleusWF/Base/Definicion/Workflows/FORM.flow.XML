<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="EditFormula" name="NucleusWF.Base.Definicion.Workflows.FORM">
	<flow:info label="Flow guia para NucleusWF.Base.Definicion.Organigramas.ESTRUCTURA"/>
	<flow:declare>
		<doc:define name="PARENT"/>
		<doc:define name="METHOD"/>
		<doc:define name="SELECT"/>
		<doc:define name="AUX"/>
		<qry:define name="FIND-WF">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</ROWS>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  WRK01_FORMS.oi_wf
from
  WRK01_FORMS
where             
	 WRK01_FORMS.oi_form={$SOURCE/@PARENT}
  			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="wf" value="$r/@oi_wf"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define class="NucleusWF.Base.Definicion.Workflows.FORM" name="DDO"/>
		<doc:define name="DATOS">
			<DATA/>
		</doc:define>
		<doc:define name="DATA">
			<DATA search="" id="" chk_node="0" chk_text="0" chk_form="0" chk_script="1"/>
		</doc:define>
		<doc:define name="REPORTDOM"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="DETAIL">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="AUX" qry="FIND-WF"/>
			<doc:set-attribute from-attr-path="#AUX:@wf" to-attr-path="#SELECT:@WF"/>
			<flow:open-form mode="DETAIL" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.FORM.form"/>
		</flow:action>
		<flow:action name="FieldUpDown">
			<flow:exec-method out-type="Nomad.NSystem.String" out-attr-path="#METHOD:@error" class="NucleusWF.Base.Definicion.Workflows.FIELD" method="UpDown">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlParam"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#METHOD:"/>
		</flow:action>
		<flow:action name="FieldDelete">
			<flow:exec-method class="NucleusWF.Base.Definicion.Workflows.FIELD" out-type="Nomad.NSystem.String" out-attr-path="#METHOD:@error" method="Delete">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlParam"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#METHOD:"/>
		</flow:action>
		<flow:action name="GroupUpDown">
			<flow:exec-method class="NucleusWF.Base.Definicion.Workflows.FORM_GROUP" out-type="Nomad.NSystem.String" out-attr-path="#METHOD:@error" method="UpDown">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlParam"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#METHOD:"/>
		</flow:action>
		<flow:action name="GroupDelete">
			<flow:exec-method class="NucleusWF.Base.Definicion.Workflows.FORM_GROUP" out-type="Nomad.NSystem.String" out-attr-path="#METHOD:@error" method="Delete">
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlParam"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#METHOD:"/>
		</flow:action>
		<flow:action name="EditFormula">
			<flow:open-form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form" mode="FORMULA" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="EditProceso">
			<flow:open-form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form" mode="PROCESO" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="EditEvent">
			<flow:open-form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form" mode="EVENT" parent-doc-path="#SOURCE:" doc-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusWF.BaseNucleusWF.Base.Definicion.Workflows.FORM.form:DETAIL" mode="DETAIL" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.FORM.form">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SCRIPTS">
			<doc:new-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<doc:load-object id-path="#SOURCE:@PARENT" class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO" load-child="0" load-all="1"/>
			<flow:open-form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form" mode="SCRIPT" parent-doc-path="#SOURCE:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="EDIT_SCRIPTS">
			<doc:new-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<doc:load-object id-path="#SOURCE:@PARENT" class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO" load-child="0" load-all="1"/>
			<flow:log text-path="#DDO:" text="chueka-EDIT"/>
			<flow:open-form form-class="NucleusWF.Base.Definicion.Workflows.EDIT_SCRIPTS.form" mode="EDIT_SCRIPTS" parent-doc-path="#SOURCE:" doc-path="#SELECT:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form" name="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form:FORMULA" mode="FORMULA" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exec-method out-attr-path="#SOURCE:@o_compilado" out-type="Nomad.NSystem.String" class="NucleusWF.Base.Definicion.Workflows.WF" method="CompileExpresion">
				<flow:param attr-path="#SOURCE:@o_formula" type="Nomad.NSystem.String" mode="in" name="txtDATA"/>
			</flow:exec-method>
			<doc:set-attribute from-value="ACCEPT" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form" name="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form:PROCESO" mode="PROCESO" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exec-method out-attr-path="#SOURCE:@o_compilado" out-type="Nomad.NSystem.String" class="NucleusWF.Base.Definicion.Workflows.WF" method="CompileMethod">
				<flow:param attr-path="#SOURCE:@o_formula" type="Nomad.NSystem.String" mode="in" name="txtDATA"/>
			</flow:exec-method>
			<doc:set-attribute from-value="ACCEPT" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusWF.BaseNucleusWF.Base.Definicion.Workflows.FORM.form:SCRIPT" mode="SCRIPT" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.FORM.form">
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SAVE">
			<flow:log text-path="#DDO:" text="chueka2"/>
			<doc:save-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Definicion.Workflows.EDIT_SCRIPTS.form" name="NucleusWF.BaseNucleusWF.Base.Definicion.Workflows.EDIT_SCRIPTS.form:EDIT_SCRIPTS" mode="EDIT_SCRIPTS" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SAVE">
			<flow:call-action action="FUNCIONES" eq="root" if="#DATOS:@desde"/>
			<flow:call-action action="FORM-GROUP" eq="fg" if="#DATOS:@desde"/>
			<flow:call-action action="FORM-FIELD" eq="ff" if="#DATOS:@desde"/>
			<flow:call-action eq="" action="MSG" if="#DATOS:@desde"/>
			<doc:save-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<!--flow:close-form/-->
			<flow:call-action action="on-show"/>
		</flow:action>
		<flow:action name="FUNCIONES">
			<doc:set-attribute from-attr-path="#DATOS:@script" to-attr-path="#DDO:@o_scripts_1"/>
			<doc:set-attribute from-attr-path="#DATOS:@script1" to-attr-path="#DDO:@o_scripts_2"/>
			<doc:set-attribute from-attr-path="#DATOS:@script2" to-attr-path="#DDO:@o_scripts_3"/>
			<doc:set-attribute from-attr-path="#DATOS:@script3" to-attr-path="#DDO:@o_scripts_4"/>
			<flow:log text="log-funciones-1" text-path="#DDO:"/>
			<flow:log text="log-funciones-2" text-path="#DATOS:"/>
		</flow:action>
		<flow:action name="FORM-GROUP">
			<doc:new-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<doc:load-object id-path="#SOURCE:@PARENT" class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO" load-child="1" load-all="1"/>
			<doc:set-attribute from-attr-path="#DATOS:@script" to-attr-path="#DDO:/FORM_GROUPS/FORM_GROUP[@id='{#DATOS:@IdScript}']/@o_onchange"/>
			<flow:log text="log-GROUP-1" text-path="#DDO:"/>
			<flow:log text="log-GROUP-2" text-path="#DATOS:"/>
		</flow:action>
		<flow:action name="FORM-FIELD">
			<doc:new-object class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO"/>
			<doc:load-object id-path="#SOURCE:@PARENT" class="NucleusWF.Base.Definicion.Workflows.FORM" doc="DDO" load-child="1" load-all="1"/>
			<flow:call-action action="OnValidate" else="OnChange" eq="onValidate" if="#DATOS:@function"/>
			<flow:log text="log-FIELD-1" text-path="#DDO:"/>
			<flow:log text="log-FIELD-2" text-path="#DATOS:"/>
		</flow:action>
		<flow:action name="MSG">
			<flow:message message="No se puede realizar la operaci&#243;n."/>
		</flow:action>
		<flow:action name="OnValidate">
			<doc:set-attribute from-attr-path="#DATOS:@script" to-attr-path="#DDO:/FORM_GROUPS/FORM_GROUP[@id='{#DATOS:@IdParent}']/FORM_FIELDS/FIELD[@id='{#DATOS:@IdScript}']/@o_onvalidate"/>
		</flow:action>
		<flow:action name="OnChange">
			<doc:set-attribute from-attr-path="#DATOS:@script" to-attr-path="#DDO:/FORM_GROUPS/FORM_GROUP[@id='{#DATOS:@IdParent}']/FORM_FIELDS/FIELD[@id='{#DATOS:@IdScript}']/@o_onchange"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="FILTER">
			<doc:set-attribute from-attr-path="#DDO:@id" to-attr-path="#DATA:@id"/>
			<flow:html-gen template-file="NucleusWF.Base.Definicion.Search.rpt" input-doc-path="#DATA:" out-file-path="#REPORTDOM:@report"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form" name="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form:SCRIPT" mode="SCRIPT" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show">
			<doc:set-attribute from-attr-path="#DDO:@o_scripts_1" to-attr-path="#SOURCE:@o_scripts_1"/>
			<doc:set-attribute from-attr-path="#DDO:@o_scripts_2" to-attr-path="#SOURCE:@o_scripts_2"/>
			<doc:set-attribute from-attr-path="#DDO:@o_scripts_3" to-attr-path="#SOURCE:@o_scripts_3"/>
			<doc:set-attribute from-attr-path="#DDO:@o_scripts_4" to-attr-path="#SOURCE:@o_scripts_4"/>
		</flow:action>
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#SOURCE:@ACTION"/>
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:set-attribute from-attr-path="#SOURCE:@o_scripts_1" to-attr-path="#DDO:@o_scripts_1"/>
			<doc:set-attribute from-attr-path="#SOURCE:@o_scripts_2" to-attr-path="#DDO:@o_scripts_2"/>
			<doc:set-attribute from-attr-path="#SOURCE:@o_scripts_3" to-attr-path="#DDO:@o_scripts_3"/>
			<doc:set-attribute from-attr-path="#SOURCE:@o_scripts_4" to-attr-path="#DDO:@o_scripts_4"/>
			<doc:save-object doc="DDO" class="NucleusWF.Base.Definicion.Workflows.FORM"/>
			<doc:set-attribute from-value="ACCEPT" to-attr-path="#SOURCE:@ACTION"/>
			<flow:close-form/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form" name="NucleusWF.Base.Definicion.Workflows.FORMULA-JS.form:EVENT" mode="EVENT" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:set-attribute from-value="ACCEPT" to-attr-path="#SOURCE:@ACTION"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
