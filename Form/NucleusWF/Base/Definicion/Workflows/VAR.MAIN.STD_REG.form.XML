				<form:ComboBox enabled="!SHOW" xsize="40" mode="DOC" name="d_type_fk" nvalue="#DDO:@d_type_fk" required="0" label="Origen" docname="d_type_fk"/>
				<form:CheckBox visible="NEW_MAIN|EDIT_MAIN|NEW_HIST|EDIT_HIST" enabled="!SHOW" label="Mostrar Consola" nvalue="#DDO:@l_show_console" name="l_show_console" required="1"/>
				<form:CheckBox visible="NEW_HIST|EDIT_HIST" enabled="!SHOW" label="Copiar al Pasar" nvalue="#DDO:@l_hist_copy" name="l_hist_copy" required="1"/>
				<form:CheckBox visible="NEW_HIST|EDIT_HIST" enabled="!SHOW" label="Copiar al Delegar" nvalue="#DDO:@l_deleg_copy" name="l_deleg_copy" required="1"/>
				<form:Blank height="10px" name="sep1"/>
				<form:Label visible="NEW_MAIN|EDIT_MAIN" style="S2 LCol_g" dynamic="0" descrip="Valor Inicial/Formula Inicial" label="Valor Inicial/Formula Inicial" name="labFORMULA"/>
				<form:Hidden name="o_formula" nvalue="#DDO:@o_formula"/>
				<form:Hidden name="o_compilado" nvalue="#DDO:@o_compilada"/>
				<form:Hidden name="oi_workflow" nvalue="#source:@oi_workflow"/>
				<form:UrlControl default="../../../Controls/Edit/EDIT-NOMAD.htm?WIDTH=70&amp;HEIGHT=15&amp;ONLOAD=parent.InitEditor(g_objEditor)" visible="NEW_MAIN|EDIT_MAIN" border="0" label="Valor Inicial/Formula Inicial" height="300px" width="550px" name="repFORMULA" direct="1">
					<form:SButtons>
						<form:SButton enabled="!SHOW" img="SEARCH" descrip="Editar la Formula" label="Editar la Formula" name="HELP_FORMULA">
							<form:Event action="EditFormula" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:UrlControl>
			</form:Column>
		</form:Columns>
		<form:Hidden name="HiLockREG" nvalue="#source:@LOCK"/>
		<form:Hidden name="PARENT" nvalue="#source:@PARENT"/>
		<form:Hidden name="ID" nvalue="#source:@ID"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="SHOW" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" visible="SHOW" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="!SHOW" name="ACCEPT" descrip="Aceptar" img="OK" label="Aceptar" startvalidate="1">
					<form:Event action="SAVE" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank name="BB1" width="20px"/>
				<form:Button visible="SHOW" descrip="Volver" img="BACK" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="!SHOW" name="CANCEL" descrip="Cancelar" img="CANCEL" label="Cancelar">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		var CFG;
var TIT=null;
var T2T=null;

///////////////////////////////////////////////////////////////////////////////          
//EVENTOS
function OnLoad()
{                
	//Cargo la Configuracion
	CFG=new NomadXML(Ctrl("main").getResource("QRY_CFG"));

	//Modifico los Recursos
	ReplaceResource("QRY_IDS_OBJECT");
	ReplaceResource("QRY_IDS_PARENT");
	
	//Actualizo el Titulo
	if ((Ctrl("PAR"))&amp;&amp; (CFG.GetAttr("RESOURCE-PARENT")!="") &amp;&amp; (Ctrl("PARENT").GetXValue()!=""))
	{
		if (TIT==null)
			TIT=GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_IDS_PARENT"), '&lt;PARAM IDS="'+Ctrl("PARENT").GetXValue()+'"/&gt;');

		if (TIT!=null) TIT=TIT.FirstChild();
		if (TIT!=null &amp;&amp; TIT.GetAttr("descr")!="")
			Ctrl("PAR").SetXValue(" ("+TIT.GetAttr("descr")+")");
	}

	if ((Ctrl("OBJ"))&amp;&amp; (CFG.GetAttr("RESOURCE-OBJECT")!="") &amp;&amp; (Ctrl("ID").GetXValue()!=""))
	{
		if (T2T==null)
			T2T=GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_IDS_OBJECT"), '&lt;PARAM IDS="'+Ctrl("ID").GetXValue()+'"/&gt;');

		if (T2T!=null) T2T=T2T.FirstChild();
		if (T2T!=null &amp;&amp; T2T.GetAttr("descr")!="")
			Ctrl("OBJ").SetXValue(" '"+T2T.GetAttr("descr")+"'");
	}        
	
	EnableControls();
}

function ReplaceResource(recID)
{
	var recValue=Ctrl("main").getResource(recID);
	recValue=Replace(recValue,"#RESOURCE-PARENT#",CFG.GetAttr("RESOURCE-PARENT"));
	recValue=Replace(recValue,"#RESOURCE-OBJECT#",CFG.GetAttr("RESOURCE-OBJECT"  ));
	
	Ctrl("main").setResource(recValue, recID);
}

function EnableControls()
{                        
	CtrlEnabled("d_type_fk",Ctrl("c_type").GetXValue()=="fk");
}

function EditFormula()
{
	var PARAM=new NomadXML("PARAM");
	
	PARAM.SetAttr("oi_workflow",Ctrl("oi_workflow").GetXValue());
	PARAM.SetAttr("o_formula"  ,Ctrl("o_formula"  ).GetXValue());
	PARAM.SetAttr("o_compilado",Ctrl("o_compilado").GetXValue());
	
	
	openNewFlowWait("NucleusWF.Base.Definicion.Workflows.FORM.flow","EditFormula",PARAM.ToString(),new objRefreshList(), "L");
}

function objRefreshList()
{
	this.processResult = function(xml)
	{
		var PARAM=new NomadXML(xml);
		if (PARAM.GetAttr("ACTION")=="ACCEPT")
		{
			Ctrl("o_formula"  ).SetXValue(PARAM.GetAttr("o_formula"  ));
			Ctrl("o_compilado").SetXValue(PARAM.GetAttr("o_compilado"));
			
			g_objEdit.SetText(Ctrl("o_formula").GetXValue());
		}
	}
}

var g_objEdit;
function InitEditor(objEdit)
{
  //Consulta VARIABLES
  var nSQL = GetProxy().SQLService();
 	var xml=nSQL.GetXML(Ctrl("main").getResource("VARIABLES"), "&lt;DATA oi_workflow=\""+Ctrl("oi_workflow").GetXValue()+"\" /&gt;");
 	
 	//Agrega las VARIABLES
 	for (cur=xml.FirstChild(); cur!=null; cur=cur.Next())
 		objEdit.Syntax.AddVariable(cur.GetAttr("name"));
 	
 	//Agrego el CODIGO                             
 	objEdit.SetText(Ctrl("o_formula").GetXValue());
 	objEdit.ReadOnly();
 	
 	//Guardo el Objeto
 	g_objEdit=objEdit;
}
	</form:Scripts>
	<form:Resources>
		<form:Resource declare="" name="QRY_IDS_OBJECT">
			<qry:include name="#RESOURCE-OBJECT#"/>
			<qry:main maxdeep="2" doc="PARAMIN">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAMIN:/PARAM"/>
				</qry:element>
			</qry:main>
		</form:Resource>
		<form:Resource declare="" name="QRY_IDS_PARENT">
			<qry:include name="#RESOURCE-PARENT#"/>
			<qry:main maxdeep="2" doc="PARAMIN">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAMIN:/PARAM"/>
				</qry:element>
			</qry:main>
		</form:Resource>
		<form:Resource name="QRY_CFG">
			<CFG resource-object="NucleusWF.Base.Definicion.Workflows.VAR.INFO_IDS_LIST" resource-parent="NucleusWF.Base.Definicion.Workflows.VAR_GROUP.INFO_IDS_LIST"/>
		</form:Resource>
		<form:Resource name="VARIABLES" declare="&lt;DATA oi_workflow=&quot;1306&quot; im=&quot;707&quot; /&gt;">
			<qry:include name="NucleusWF.Base.Definicion.Workflows.WF.VariablesInternas"/>
			<qry:main name="" doc="PARAM">
				<rows>
					<qry:append-doc name="DATAIN" doc-path="#PARAM:."/>
					<qry:create-doc name="INTERNAL"/>
					<qry:insert-select name="InternalVars" to-element="$INTERNAL"/>
					<qry:insert-select name="INTERNAL-GRUPOS"/>
					<qry:insert-select name="INTERNAL"/>
					<qry:insert-select name="GRUPOS"/>
					<qry:insert-select name="VARIABLES"/>
					<qry:if test="$DATAIN/@im!=''">
						<qry:then>
							<qry:insert-select name="PARAMETROS"/>
						</qry:then>
						<qry:else/>
					</qry:if>
				</rows>
			</qry:main>
			<qry:select name="INTERNAL-GRUPOS">
				<qry:xquery>
					for $r in $INTERNAL/GROUP
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('@',$r/@name)"/>
					</row>
				</qry:out>
			</qry:select>
			<qry:select name="INTERNAL">
				<qry:xquery>
					for $r in $INTERNAL/GROUP/VAR
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('@',$r/../@name,'.',$r/@name)"/>
					</row>
				</qry:out>
			</qry:select>
			<qry:select name="GRUPOS">
				<qry:xquery>
					for $r in SQL('
select
WRK01_GROUPS.oi_var_group, 
WRK01_GROUPS.c_var_group
from
WRK01_GROUPS
where                   
WRK01_GROUPS.oi_wf={$DATAIN/@oi_workflow}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('@',$r/@c_var_group)"/>
					</row>
				</qry:out>
			</qry:select>
			<qry:select name="VARIABLES">
				<qry:xquery>
					for $r in SQL('
select
WRK01_VARS.oi_var, 
WRK01_GROUPS.c_var_group,
WRK01_VARS.c_var,
WRK01_VARS.d_var,
WRK01_VARS.c_type
from
WRK01_VARS, WRK01_GROUPS
where                   
WRK01_VARS.oi_var_group=WRK01_GROUPS.oi_var_group and
WRK01_GROUPS.oi_wf={$DATAIN/@oi_workflow}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var)"/>
					</row>
					<qry:switch test="$r/@c_type">
						<qry:case value="enum">
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Val')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Valor')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Cod')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Code')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Codigo')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Description')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Descr')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Txt')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Text')"/>
							</row>
						</qry:case>
						<qry:case value="fk">
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Val')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Valor')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Cod')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Code')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Codigo')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Description')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Descr')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Txt')"/>
							</row>
							<row>
								<qry:attribute name="name" value="concat('@',$r/@c_var_group,'.',$r/@c_var,'.Text')"/>
							</row>
						</qry:case>
					</qry:switch>
				</qry:out>
			</qry:select>
			<qry:select name="PARAMETROS">
				<qry:xquery>
					for $r in SQL('
select
WRK04_PARAMS.oi_param,
WRK04_PARAMS.c_param,
WRK04_PARAMS.d_param,
WRK04_PARAMS.c_type
from
WRK04_PARAMS
where     
isNull(WRK04_PARAMS.oi_param_x) and
WRK04_PARAMS.oi_int_mag={$DATAIN/@im}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('#',$r/@c_param)"/>
					</row>
					<qry:switch test="$r/@c_type">
						<qry:case value="array">
							<qry:insert-select name="STRUCT" doc-path="$r"/>
						</qry:case>
						<qry:case value="struct">
							<qry:insert-select name="STRUCT" doc-path="$r"/>
						</qry:case>
					</qry:switch>
				</qry:out>
			</qry:select>
			<qry:select name="STRUCT" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
WRK04_PARAM_STRUCT.oi_struct,
WRK04_PARAMS.c_param,
WRK04_PARAM_STRUCT.c_struct,
WRK04_PARAM_STRUCT.d_struct,
WRK04_PARAM_STRUCT.c_type
from
WRK04_PARAM_STRUCT, WRK04_PARAMS
where                           
WRK04_PARAMS.oi_param=WRK04_PARAM_STRUCT.oi_param and 
WRK04_PARAMS.oi_param={$SOURCE/@oi_param}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<row>
						<qry:attribute name="name" value="concat('#',$r/@c_param,'.',$r/@c_struct)"/>
					</row>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="OnLoad" name="OnLoad" runat="client"/>
</form:Form>
