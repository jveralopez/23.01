<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="EDIT_MAIN" extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="Nomad.Base.Login.Cuentas.CUENTA">
