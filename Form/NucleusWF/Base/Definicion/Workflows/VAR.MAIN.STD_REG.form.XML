						<option value="bool" text="L&#243;gico"/>
						<option value="int" text="Entero"/>
						<option value="double" text="N&#250;mero"/>
						<option value="date" text="Fecha"/>
						<option value="string" text="Cadena"/>
						<option value="enum" text="Enumeracion"/>
						<option value="fk" text="Item de Lista"/>
