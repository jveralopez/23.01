<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="EDIT" doc="source" name="NucleusWF.Base.Definicion.Workflows.FORMULA-NMD.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Edicion de Formulas" nowrap="1" align="center" style="S3 LCol_w" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%" height="100%">
		<form:Columns name="COLS" width="100%" height="100%">
			<form:Column name="C1" width="55%" separation="2" align="center" valign="top">
				<form:Label style="S3 LCol_g" dynamic="0" label="Formula/Proceso" name="lblFormula"/>
				<form:UrlControl border="0" default="../../../Controls/Edit/EDIT-NOMAD.htm?WIDTH=75&amp;HEIGHT=25&amp;ONLOAD=parent.InitEditor(g_objEditor)" height="450px" name="formula" width="100%"/>
			</form:Column>
			<form:Column name="C2" width="45%" separation="2" align="center" valign="top">
				<form:Div height="200px" label="Objetos y Funciones" name="divHELP" border="1" width="100%"/>
				<form:Wiki home="wiki:NucleusWF.Base.Definicion.NomadFormula.wiki" mail-mode="N" share-mode="N" form-mode="N" flow-mode="N" window-mode="N" goto-mode="I" height="250px" name="wikiHELP" label="Detalle de la funcion" border="1" width="100%">
					<form:SButtons>
						<form:SButton label="Previo" descrip="Previo" name="PREV" img="PREV">
							<form:Event action="Back" name="onclick" runat="object"/>
						</form:SButton>
						<form:SButton label="Proximo" descrip="Proximo" name="NEXT" img="NEXT">
							<form:Event action="Next" name="onclick" runat="object"/>
						</form:SButton>
						<form:SButton label="Indice" descrip="Indice" name="HOME" img="HOME">
							<form:Event action="Home" name="onclick" runat="object"/>
						</form:SButton>
						<form:Blank width="5px" name="sep1"/>
						<form:Blank width="5px" name="sep2"/>
						<form:SButton label="Modificar" visible="EDIT" name="EDIT" img="EDIT" descrip="Modificar">
							<form:Event name="onclick" action="Edit" runat="object"/>
						</form:SButton>
					</form:SButtons>
				</form:Wiki>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#source:@oi_workflow" name="oi_workflow"/>
		<form:Hidden nvalue="#source:@oi_process" name="oi_process"/>
		<form:Hidden nvalue="#source:@im" name="im"/>
		<form:Hidden nvalue="#source:@o_formula" name="txtFORMULA"/>
		<form:Hidden name="frmSELECT"/>
		<form:Hidden name="c_wf" nvalue="#source:@c_wf"/>
		<form:Hidden name="c_process" nvalue="#source:@c_process"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Aceptar" img="ok" label="Aceptar" name="ACCEPT">
					<form:Event action="preACCEPT" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Cancelar" img="cancel" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Resources>
		<form:Resource declare="&lt;DATA mode=&quot;PAR&quot; oi_workflow=&quot;303&quot; oi_process=&quot;&quot; im=&quot;OPUS.ALTARECIVO&quot; c_wf=&quot;SUBWF&quot; c_process=&quot;CALL&quot;/&gt;" name="HELP">
			<qry:include name="NucleusWF.Base.Definicion.Workflows.WF.VariablesInternas"/>
			<qry:main name="" doc="PARAM">
				<tree>
					<qry:append-doc name="DATAIN" doc-path="#PARAM:."/>
					<qry:switch test="substring-before($DATAIN/@mode,'/')">
						<!-- RAIZ -->
						<qry:case value="ROOT">
							<group imgClose="REP-HIDDEN.ico" imgOpen="REP-HIDDEN.ico" id="VAR" label="Variables" tag=""/>
							<qry:if test="$DATAIN/@im!='' or $DATAIN/@oi_process!=''  or $DATAIN/@c_process!=''">
								<qry:then>
									<group imgClose="REP-FIL.ico" imgOpen="REP-FIL.ico" id="PAR" label="Parametros" tag=""/>
								</qry:then>
							</qry:if>
							<group imgClose="REP-FORMULA.ico" imgOpen="REP-FORMULA.ico" id="FUN" label="Funciones" tag=""/>
						</qry:case>
						<!-- GRUPO DE PARAMETROS -->
						<qry:case value="PAR">
							<qry:switch test="substring-after($DATAIN/@mode,'/')">
								<!-- GRUPO DE PARAMETROS -->
								<qry:case value="">
									<qry:if test="$DATAIN/@im!=''">
										<qry:then>
											<qry:insert-select name="GRUPO-PARAMETROS-IM"/>
										</qry:then>
									</qry:if>
									<qry:if test="$DATAIN/@oi_process!=''  or $DATAIN/@c_process!=''">
										<qry:then>
											<qry:insert-select name="GRUPO-PARAMETROS-PROCESS"/>
										</qry:then>
									</qry:if>
								</qry:case>
								<qry:default>
									<qry:insert-select name="PARAMETROS"/>
								</qry:default>
							</qry:switch>
						</qry:case>
						<!-- GRUPO DE VARIABLES -->
						<qry:case value="VAR">
							<qry:switch test="substring-after($DATAIN/@mode,'/')">
								<!-- GRUPO DE VARIABLES -->
								<qry:case value="">
									<qry:create-doc name="INTERNAL"/>
									<qry:insert-select name="InternalVars" to-element="$INTERNAL"/>
									<qry:insert-select name="GRUPO-VARIABLES-INTERNAS"/>
									<qry:insert-select name="GRUPO-VARIABLES"/>
								</qry:case>
								<qry:default>
									<qry:create-doc name="INTERNAL"/>
									<qry:insert-select name="InternalVars" to-element="$INTERNAL"/>
									<qry:insert-select name="VARIABLES-INTERNAS"/>
									<qry:insert-select name="VARIABLES"/>
								</qry:default>
							</qry:switch>
						</qry:case>
						<!-- GRUPO DE FUNCIONES -->
						<qry:case value="FUN">
							<!-- GRUPO DE FUNCIONES -->
							<qry:if test="substring-after($DATAIN/@mode,'/')=''">
								<qry:then>
									<group imgClose="REP-FORMULA.ico" imgOpen="REP-FORMULA.ico" id="ALL" label="Todas" tag=""/>
									<group imgClose="book-open.ico" imgOpen="book-open.ico" id="CONV" label="Conversion" tag=""/>
									<group imgClose="CheckBox.ico" imgOpen="CheckBox.ico" id="LOGIC" label="Logicas" tag=""/>
									<group imgClose="NumberBox.ico" imgOpen="NumberBox.ico" id="NUMBER" label="Numericas" tag=""/>
									<group imgClose="DateTime.ICO" imgOpen="DateTime.ICO" id="DATE" label="Fecha/Horas" tag=""/>
									<group imgClose="TextBox.ico" imgOpen="TextBox.ico" id="TEXT" label="Texto" tag=""/>
									<group imgClose="HiddenArr.ico" imgOpen="HiddenArr.ico" id="COLL" label="Colleciones" tag=""/>
									<group imgClose="organigrama0.ico" imgOpen="organigrama0.ico" id="CTRL" label="Control" tag=""/>
								</qry:then>
							</qry:if>
							<!-- GRUPO DE CONVERSION -->
							<qry:if test="substring-after($DATAIN/@mode,'/')='CONV' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="CheckBox.ico" id="IsNull" label="IsNull" tag="wiki:NucleusWF.Base.Definicion.Formulas.ISNULL.wiki"/>
									<item img="CheckBox.ico" id="ToBoolean" label="ToBoolean" tag="wiki:NucleusWF.Base.Definicion.Formulas.TOBOOLEAN.wiki"/>
									<item img="NumberBox.ico" id="ToNumber" label="ToNumber" tag="wiki:NucleusWF.Base.Definicion.Formulas.TONUMBER.wiki"/>
									<item img="DateTime.ico" id="ToDateTime" label="ToDateTime" tag="wiki:NucleusWF.Base.Definicion.Formulas.TODATETIME.wiki"/>
									<item img="TextBox.ico" id="ToString" label="ToString" tag="wiki:NucleusWF.Base.Definicion.Formulas.TOSTRING.wiki"/>
									<item img="TextBox.ico" id="Format" label="Format" tag="wiki:NucleusWF.Base.Definicion.Formulas.FORMAT.wiki"/>
								</qry:then>
							</qry:if>
							<!-- FUNCIONES LOGICAS -->
							<qry:if test="substring-after($DATAIN/@mode,'/')='LOGIC' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="CheckBox.ico" id="True" label="True" tag="wiki:NucleusWF.Base.Definicion.Formulas.TRUE.wiki"/>
									<item img="CheckBox.ico" id="False" label="False" tag="wiki:NucleusWF.Base.Definicion.Formulas.FALSE.wiki"/>
									<item img="CheckBox.ico" id="Not" label="Not" tag="wiki:NucleusWF.Base.Definicion.Formulas.NOT.wiki"/>
								</qry:then>
							</qry:if>
							<!-- FUNCIONES NUMERICAS -->
							<qry:if test="substring-after($DATAIN/@mode,'/')='NUMBER' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="NumberBox.ico" id="Abs" label="Abs" tag="wiki:NucleusWF.Base.Definicion.Formulas.ABS.wiki"/>
									<item img="NumberBox.ico" id="Neg" label="Neg" tag="wiki:NucleusWF.Base.Definicion.Formulas.NEG.wiki"/>
									<item img="NumberBox.ico" id="Inv" label="Inv" tag="wiki:NucleusWF.Base.Definicion.Formulas.INV.wiki"/>
									<item img="NumberBox.ico" id="Ceil" label="Ceil" tag="wiki:NucleusWF.Base.Definicion.Formulas.CEIL.wiki"/>
									<item img="NumberBox.ico" id="Floor" label="Floor" tag="wiki:NucleusWF.Base.Definicion.Formulas.FLOOR.wiki"/>
									<item img="NumberBox.ico" id="Round" label="Round" tag="wiki:NucleusWF.Base.Definicion.Formulas.ROUND.wiki"/>
								</qry:then>
							</qry:if>
							<!-- FUNCIONES de Fechas -->
							<qry:if test="substring-after($DATAIN/@mode,'/')='DATE' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="DateTime.ico" id="Now" label="Now" tag="wiki:NucleusWF.Base.Definicion.Formulas.NOW.wiki"/>
									<item img="DateTime.ico" id="Date" label="Date" tag="wiki:NucleusWF.Base.Definicion.Formulas.DATE.wiki"/>
									<item img="DateTime.ico" id="Time" label="Time" tag="wiki:NucleusWF.Base.Definicion.Formulas.TIME.wiki"/>
									<item img="NumberBox.ico" id="Year" label="Year" tag="wiki:NucleusWF.Base.Definicion.Formulas.YEAR.wiki"/>
									<item img="NumberBox.ico" id="Month" label="Month" tag="wiki:NucleusWF.Base.Definicion.Formulas.MONTH.wiki"/>
									<item img="NumberBox.ico" id="Day" label="Day" tag="wiki:NucleusWF.Base.Definicion.Formulas.DAY.wiki"/>
									<item img="NumberBox.ico" id="WDay" label="WDay" tag="wiki:NucleusWF.Base.Definicion.Formulas.WDAY.wiki"/>
									<item img="NumberBox.ico" id="Hour" label="Hour" tag="wiki:NucleusWF.Base.Definicion.Formulas.HOUR.wiki"/>
									<item img="NumberBox.ico" id="Minute" label="Minute" tag="wiki:NucleusWF.Base.Definicion.Formulas.MINUTE.wiki"/>
									<item img="NumberBox.ico" id="Second" label="Second" tag="wiki:NucleusWF.Base.Definicion.Formulas.SECOND.wiki"/>
								</qry:then>
							</qry:if>
							<!-- FUNCIONES de Textos -->
							<qry:if test="substring-after($DATAIN/@mode,'/')='TEXT' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="NumberBox.ico" id="Len" label="Len" tag="wiki:NucleusWF.Base.Definicion.Formulas.LEN.wiki"/>
									<item img="TextBox.ico" id="SubStr" label="SubStr" tag="wiki:NucleusWF.Base.Definicion.Formulas.SUBSTR.wiki"/>
									<item img="TextBox.ico" id="Left" label="Left" tag="wiki:NucleusWF.Base.Definicion.Formulas.LEFT.wiki"/>
									<item img="TextBox.ico" id="Right" label="Right" tag="wiki:NucleusWF.Base.Definicion.Formulas.RIGHT.wiki"/>
									<item img="TextBox.ico" id="Normalize" label="Normalize" tag="wiki:NucleusWF.Base.Definicion.Formulas.NORMALIZE.wiki"/>
									<item img="TextBox.ico" id="UCase" label="UCase" tag="wiki:NucleusWF.Base.Definicion.Formulas.UCASE.wiki"/>
									<item img="TextBox.ico" id="LCase" label="LCase" tag="wiki:NucleusWF.Base.Definicion.Formulas.LCASE.wiki"/>
									<item img="CheckBox.ico" id="Contains" label="Contains" tag="wiki:NucleusWF.Base.Definicion.Formulas.CONTAINS.wiki"/>
									<item img="CheckBox.ico" id="StartWith" label="StartWith" tag="wiki:NucleusWF.Base.Definicion.Formulas.STARTWITH.wiki"/>
									<item img="CheckBox.ico" id="EndWith" label="EndWith" tag="wiki:NucleusWF.Base.Definicion.Formulas.ENDWITH.wiki"/>
									<item img="TextBox.ico" id="SubStrBefore" label="SubStrBefore" tag="wiki:NucleusWF.Base.Definicion.Formulas.SUBSTRBEFORE.wiki"/>
									<item img="TextBox.ico" id="SubStrAfter" label="SubStrAfter" tag="wiki:NucleusWF.Base.Definicion.Formulas.SUBSTRAFTER.wiki"/>
									<item img="TextBox.ico" id="PadLeft" label="PadLeft" tag="wiki:NucleusWF.Base.Definicion.Formulas.PADLEFT.wiki"/>
									<item img="TextBox.ico" id="PadRight" label="PadRight" tag="wiki:NucleusWF.Base.Definicion.Formulas.PADRIGHT.wiki"/>
									<item img="TextBox.ico" id="Replace" label="Replace" tag="wiki:NucleusWF.Base.Definicion.Formulas.REPLACE.wiki"/>
								</qry:then>
							</qry:if>
							<!-- FUNCIONES de Colleciones-->
							<qry:if test="substring-after($DATAIN/@mode,'/')='COLL' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="Hidden.ico" id="SetItemCursor" label="SetItemCursor" tag="wiki:NucleusWF.Base.Definicion.Formulas.SETITEMCURSOR.wiki"/>
									<item img="NumberBox.ico" id="DetItemCursor" label="DetItemCursor" tag="wiki:NucleusWF.Base.Definicion.Formulas.GETITEMCURSOR.wiki"/>
									<item img="NumberBox.ico" id="GetLength" label="GetLength" tag="wiki:NucleusWF.Base.Definicion.Formulas.GETLENGTH.wiki"/>
									<item img="Hidden.ico" id="AddItem" label="AddItem" tag="wiki:NucleusWF.Base.Definicion.Formulas.ADDITEM.wiki"/>
									<item img="Hidden.ico" id="DelItem" label="DelItem" tag="wiki:NucleusWF.Base.Definicion.Formulas.DELITEM.wiki"/>
									<item img="Hidden.ico" id="ClearItems" label="ClearItems" tag="wiki:NucleusWF.Base.Definicion.Formulas.CLEARITEMS.wiki"/>
								</qry:then>
							</qry:if>
							<!-- ELEMENTOS DE CONTROL-->
							<qry:if test="substring-after($DATAIN/@mode,'/')='CTRL' or substring-after($DATAIN/@mode,'/')='ALL'">
								<qry:then>
									<item img="organigrama0.ico" id="if" label="if" tag="wiki:NucleusWF.Base.Definicion.Formulas.IF.wiki"/>
									<item img="organigrama0.ico" id="foreach" label="foreach" tag="wiki:NucleusWF.Base.Definicion.Formulas.FOREACH.wiki"/>
									<item img="organigrama0.ico" id="for" label="for" tag="wiki:NucleusWF.Base.Definicion.Formulas.FOR.wiki"/>
									<item img="organigrama0.ico" id="while" label="while" tag="wiki:NucleusWF.Base.Definicion.Formulas.WHILE.wiki"/>
									<item img="organigrama0.ico" id="do" label="do" tag="wiki:NucleusWF.Base.Definicion.Formulas.DO.wiki"/>
									<item img="organigrama0.ico" id="break" label="break" tag="wiki:NucleusWF.Base.Definicion.Formulas.BREAK.wiki"/>
									<item img="organigrama0.ico" id="return" label="return" tag="wiki:NucleusWF.Base.Definicion.Formulas.RETURN.wiki"/>
								</qry:then>
							</qry:if>
						</qry:case>
					</qry:switch>
				</tree>
			</qry:main>
			<qry:select name="GRUPO-VARIABLES-INTERNAS">
				<qry:xquery>
					for $r in $INTERNAL/GROUP
				</qry:xquery>
				<qry:out>
					<group>
						<qry:attribute name="id" value="$r/@name"/>
						<qry:attribute name="label" value="concat('@',$r/@name)"/>
						<qry:attribute name="imgClose" value="'Hidden.ico'"/>
						<qry:attribute name="imgOpen" value="'Hidden.ico'"/>
					</group>
				</qry:out>
			</qry:select>
			<qry:select name="GRUPO-VARIABLES">
				<qry:xquery>
					for $r in SQL('
select
WRK01_GROUPS.oi_var_group,
WRK01_GROUPS.c_var_group,
WRK01_GROUPS.d_var_group,
WRK01_GROUPS.c_mode
from
WRK01_GROUPS
where
WRK01_GROUPS.oi_wf={$DATAIN/@oi_workflow}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<group tag="">
						<qry:attribute name="id" value="$r/@c_var_group"/>
						<qry:attribute name="label" value="concat('[',$r/@c_var_group,'] ',$r/@d_var_group)"/>
						<qry:switch test="$r/@c_mode">
							<qry:case value="MAIN">
								<qry:attribute name="imgClose" value="'Hidden.ico'"/>
								<qry:attribute name="imgOpen" value="'Hidden.ico'"/>
							</qry:case>
							<qry:case value="HIST">
								<qry:attribute name="imgClose" value="'Hidden.ico'"/>
								<qry:attribute name="imgOpen" value="'Hidden.ico'"/>
							</qry:case>
							<qry:case value="AUX">
								<qry:attribute name="imgClose" value="'Hidden.ico'"/>
								<qry:attribute name="imgOpen" value="'Hidden.ico'"/>
							</qry:case>
							<qry:case value="CHILD">
								<qry:attribute name="imgClose" value="'HiddenArr.ico'"/>
								<qry:attribute name="imgOpen" value="'HiddenArr.ico'"/>
							</qry:case>
							<qry:case value="ARRAUX">
								<qry:attribute name="imgClose" value="'HiddenArr.ico'"/>
								<qry:attribute name="imgOpen" value="'HiddenArr.ico'"/>
							</qry:case>
						</qry:switch>
					</group>
				</qry:out>
			</qry:select>
			<qry:select name="VARIABLES-INTERNAS">
				<qry:xquery>
					for $r in $INTERNAL/GROUP[@name=substring-after($DATAIN/@mode,'/')]/VAR
				</qry:xquery>
				<qry:out>
					<item>
						<qry:attribute name="id" value="$r/@name"/>
						<qry:attribute name="label" value="concat('[@',$r/../@name,'.',$r/@name,'] ',$r/@label)"/>
						<qry:attribute name="imgClose" value="'Hidden.ico'"/>
						<qry:attribute name="imgOpen" value="'Hidden.ico'"/>
						<qry:switch test="$r/@type">
							<qry:case value="bool">
								<qry:attribute name="img" value="'CheckBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.BOOL.wiki'"/>
							</qry:case>
							<qry:case value="int">
								<qry:attribute name="img" value="'NumberBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.INT.wiki'"/>
							</qry:case>
							<qry:case value="double">
								<qry:attribute name="img" value="'NumberBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.DOUBLE.wiki'"/>
							</qry:case>
							<qry:case value="date">
								<qry:attribute name="img" value="'DateTime.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.DATE.wiki'"/>
							</qry:case>
							<qry:case value="string">
								<qry:attribute name="img" value="'TextBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.STRING.wiki'"/>
							</qry:case>
							<qry:case value="enum">
								<qry:attribute name="img" value="'Combo.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.ENUM.wiki'"/>
							</qry:case>
							<qry:case value="fk">
								<qry:attribute name="img" value="'FKInput.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.FK.wiki'"/>
							</qry:case>
							<qry:case value="text">
								<qry:attribute name="img" value="'TextBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.TEXT.wiki'"/>
							</qry:case>
							<qry:case value="file">
								<qry:attribute name="img" value="'Image.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.FILE.wiki'"/>
							</qry:case>
						</qry:switch>
					</item>
				</qry:out>
			</qry:select>
			<qry:select name="VARIABLES">
				<qry:xquery>
					for $r in SQL('
select
WRK01_VARS.oi_var, 
WRK01_GROUPS.c_var_group,
WRK01_VARS.c_var,
WRK01_VARS.d_var,
WRK01_VARS.c_type
from
WRK01_VARS, WRK01_GROUPS
where                   
WRK01_VARS.oi_var_group=WRK01_GROUPS.oi_var_group and
WRK01_GROUPS.oi_wf={$DATAIN/@oi_workflow} and
WRK01_GROUPS.c_var_group={substring-after($DATAIN/@mode,\'/\')}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<item>
						<qry:attribute name="id" value="$r/@c_var"/>
						<qry:attribute name="label" value="concat('[@',$r/@c_var_group,'.',$r/@c_var,'] ',$r/@d_var)"/>
						<qry:switch test="$r/@c_type">
							<qry:case value="bool">
								<qry:attribute name="img" value="'CheckBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.BOOL.wiki'"/>
							</qry:case>
							<qry:case value="int">
								<qry:attribute name="img" value="'NumberBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.INT.wiki'"/>
							</qry:case>
							<qry:case value="double">
								<qry:attribute name="img" value="'NumberBox.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.DOUBLE.wiki'"/>
							</qry:case>
							<qry:case value="date">
								<qry:attribute name="img" value="'DateTime.ico'"/>
								<qry:attribute name="tag" value="'wiki:NucleusWF.Base.Definicion.Variables.DATE.wiki'"/>
							</qry:case>
