var arrType=new Array();


function ShowIntelicence(type, word)
{    
	var KeySHOW=null, t, GroupArr, GroupNext, key;
	
	switch(type)
	{
		case "KEYWORD":
			KeySHOW="FUN/ALL/"+word;
			break;
			
		case "VAR":               
			if (word.substr(0,1)=="@")
			{
				KeySHOW="VAR";
			} else
			if (word.substr(0,1)=="#")
			{              
				KeySHOW="PAR";
			} else
				return;
			
			if (word.length&gt;1)	
				KeySHOW=KeySHOW+"/"+Replace(word.substr(1),'.','/');
			break; 
			
		default:
			return;
	}
	
	KeySHOW=KeySHOW.split("/");
	GroupArr=HELP_TREE; GroupNext=null;
	
	for (t=0; t&lt;KeySHOW.length &amp;&amp; GroupArr!=null; t++)
	{
		
		GroupNext=null;
		for (key in GroupArr.Groups)
		{        
			objGroup=GroupArr.Groups[key];

			if (objGroup.Id==KeySHOW[t])
			{
				if (!objGroup.isExpanded)
					HELP_TREE.ExpandGroup(objGroup, false);  
				GroupNext=objGroup;
			} else
			if (objGroup.isExpanded)
			{   
				HELP_TREE.ContractGroup(objGroup);
			}
		}        
		
		//Busco Items
		if (GroupNext==null)           
		{
			for (key in GroupArr.Items)
			{        
				objItem=GroupArr.Items[key];
	
				if (objItem.Id==KeySHOW[t] &amp;&amp; Ctrl("frmSELECT").GetXValue()!=objItem.FullId)
					HELP_TREE.ClickItem(objItem.FullId);
			}        
		}
		
		GroupArr=GroupNext;
	}

}
