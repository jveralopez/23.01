				<qry:element name="ROW">
					<qry:attribute name="e_order" value="0"/>
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT
				MAX(FIELD.e_order) as e_order
			FROM
				WRK01_FORM_GROUPS as FRM_GRP,
				WRK01_FORM_FIELDS as FIELD
			JOIN
				FRM_GRP.oi_form_group LEFT OUTER FIELD.oi_form_group
