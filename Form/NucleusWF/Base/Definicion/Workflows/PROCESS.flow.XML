				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_role"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="PUBLICAR">
			<flow:exec-method out-attr-path="#SELECT:@batch-id" priority="4" method="Publicar" class="NucleusWF.Base.Definicion.Workflows.WF">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_wf"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batchtolist.form" mode="BATCH" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ACT_ELIMINAR">
			<flow:exec-method out-attr-path="#SELECT:@batch-id" priority="4" method="Eliminar" class="NucleusWF.Base.Definicion.Workflows.WF">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_wf"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batchtolist.form" mode="BATCH" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ACT_FINALIZAR">
			<flow:exec-method method="Finalizar" out-attr-path="#SELECT:@batch-id" priority="4" class="NucleusWF.Base.Definicion.Workflows.WF">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_wf"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batchtolist.form" mode="BATCH" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ACT_DETENER">
			<flow:exec-method method="Detener" out-attr-path="#SELECT:@batch-id" priority="4" class="NucleusWF.Base.Definicion.Workflows.WF">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_wf"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.batchtolist.form" mode="BATCH" parent-doc-path="#SELECT:" doc-path="#SELECT:"/>
		</flow:action>
		<flow:action name="ACT_ACTIVAR">
			<flow:exec-method method="Activar" out-attr-path="#SELECT:@batch-id" priority="4" class="NucleusWF.Base.Definicion.Workflows.WF">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_wf"/>
