			<doc:load-qry input-doc-path="#SOURCE:" output-doc="AUX" qry="FIND-WF"/>
			<doc:set-attribute from-attr-path="#AUX:@wf" to-attr-path="#SELECT:@WF"/>
			<flow:open-form mode="DESIGN" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.PROCESS.form"/>
		</flow:action>
		<flow:action name="NODE_DEL">
