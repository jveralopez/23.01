	</flow:main>
	<flow:form name="NucleusWF.Base.Definicion.Workflows.PROCESS.form:DESIGN" mode="DESIGN" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.PROCESS.form">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="FILTER">
			<doc:set-attribute from-attr-path="#SOURCE:@WF" to-attr-path="#DATA:@id"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#DATA:@oi_process"/>
			<flow:log text-path="#DATA:" text="chueka-DATA"/>
			<flow:html-gen template-file="NucleusWF.Base.Definicion.Search.rpt" input-doc-path="#DATA:" out-file-path="#REPORTDOM:@report"/>
		</flow:action>
		<flow:action name="REFRESH_SEARCH">
			<flow:call-action action="FILTER"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="Nomad.base.batchtolist.form" name="Nomad.base.batchtolist.form:BATCH" mode="BATCH" parent-doc="PARENT" doc="SOURCE">
		<flow:action name="on-show"/>
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SELECT:"/>
		</flow:action>
	</flow:form>
</flow:flow>
