			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="NODE_DOWN">
			<flow:exec-method method="NodeDOWN" class="NucleusWF.Base.Definicion.Workflows.PROCESS">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_process"/>
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_node"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="NODE_UP">
			<flow:exec-method method="NodeUP" class="NucleusWF.Base.Definicion.Workflows.PROCESS">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_process"/>
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_node"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ROLE_INICIA">
			<flow:exec-method method="RoleInicia" class="NucleusWF.Base.Definicion.Workflows.PROCESS">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_process"/>
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_role"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ROLE_NO_INICIA">
			<flow:exec-method method="RoleNoInicia" class="NucleusWF.Base.Definicion.Workflows.PROCESS">
