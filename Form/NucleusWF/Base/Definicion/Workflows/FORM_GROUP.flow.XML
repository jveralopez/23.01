<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusWF.Base.Definicion.Workflows.FORM_GROUP" default_action="DEBUG">
	<flow:info label="Flow guia para NucleusWF.Base.Definicion.Organigramas.ESTRUCTURA"/>
	<flow:declare>
		<doc:define name="PARENT"/>
		<doc:define name="METHOD"/>
		<doc:define name="SELECT">
			<ROW/>
		</doc:define>
		<qry:define declare="&lt;PARAMS ID=&quot;&quot; PARENT=&quot;305&quot; MODE=&quot;MAIN&quot; /&gt;" name="GetActionGroup">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute name="start" value="iif(substring(#SOURCE:./@MODE,0,1)='B', 'B', 'M')"/>
					<qry:append-doc name="DOC" doc-path="."/>
					<qry:attribute name="order" value="0"/>
					<qry:append-doc name="ORDER" doc-path="."/>
					<qry:insert-select doc-path="#SOURCE:." name="sql0"/>
					<qry:insert-select doc-path="#SOURCE:." name="sql1"/>
					<qry:insert-select doc-path="#SOURCE:." name="sql2"/>
					<qry:attribute name="c_order" value="iif(./@order=0,#DOC:@start+fill-left(Number(./@order),0,4),./@c_order)"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql0">
				<qry:xquery>
					for $r in SQL('
			SELECT
				WRK.d_template
			FROM
				WRK01_FORMS as WRK
			WHERE
				WRK.oi_form = {#PARAM:@PARENT} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="d_template" value="$r/@d_template"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT
				WRK.d_template,
				FRM_GRP.c_order
			FROM
				WRK01_FORMS as WRK,
				WRK01_FORM_GROUPS as FRM_GRP
			JOIN
				WRK.oi_form LEFT OUTER FRM_GRP.oi_form
			WHERE
				WRK.oi_form = {#PARAM:@PARENT} AND
				STARTWITH(FRM_GRP.c_order,\'{%=#DOC:@start%}\')
			GROUP BY 
				WRK.d_template, 
				FRM_GRP.c_order
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="order" value="Number(substring($r/@c_order,1,4))"/>
					<qry:attribute name="d_template" value="$r/@d_template"/>
					<qry:if test="./@order&gt;=#ORDER:@order">
						<qry:then>
							<qry:attribute name="c_order" value="#DOC:@start+fill-left(Number(./@order)+1,0,4)"/>
							<qry:attribute name="order" value="Number(substring(./@c_order,1,4))"/>
							<qry:append-doc name="ORDER" doc-path="."/>
						</qry:then>
						<qry:else/>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in FILESTORE('Html\\{%=./@d_template%}')/html:html/html:xslt/xsl:template[@name='COMBO_GROUPMODES']/OPT[@value=#PARAM:@MODE]
				</qry:xquery>
				<qry:out>
					<qry:attribute name="text" value="$r/@text"/>
					<qry:attribute name="action" value="$r/@action-group"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="FORM_MODE"/>
		<doc:define name="DDO"/>
		<qry:define declare="&lt;PARAMS PARENT=&quot;10&quot; ID=&quot;2&quot; /&gt;" name="GetMode">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#SOURCE:PARAMS" name="sql1"/>
					<qry:insert-select doc-path="." name="sql2"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT
				WRK.d_template,
				FRM_GRP.c_mode
			FROM
				WRK01_FORMS as WRK,
				WRK01_FORM_GROUPS as FRM_GRP
			JOIN
				FRM_GRP.oi_form INNER WRK.oi_form
			WHERE
				FRM_GRP.oi_form_group = {#PARAM:@ID}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="d_template" value="$r/@d_template"/>
					<qry:attribute name="c_mode" value="$r/@c_mode"/>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in FILESTORE('Html\\{%=#PARAM:@d_template%}')/html:html/html:xslt/xsl:template[@name='COMBO_GROUPMODES']/OPT[@value=#PARAM:@c_mode]
				</qry:xquery>
				<qry:out>
					<qry:attribute name="text" value="$r/@text"/>
					<qry:attribute name="action" value="$r/@action-group"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;PARAMS PARENT=&quot;206&quot; MODE=&quot;GRID&quot; /&gt;" name="GRUPOS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAMS"/>
				</ROWS>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  WRK01_GROUPS.c_var_group,
  WRK01_GROUPS.d_var_group
from
  WRK01_GROUPS,
  WRK01_FORMS                          
join
	WRK01_FORMS.oi_wf INNER WRK01_GROUPS.oi_wf
where             
	 WRK01_FORMS.oi_form={$SOURCE/@PARENT} AND
	 WRK01_GROUPS.c_mode IN (\'CHILD\', \'ARRAUX\')
  			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="value" value="$r/@c_var_group"/>
						<qry:attribute name="text" value="$r/@d_var_group"/>
					</option>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="GRUPOS"/>
		<doc:define name="REPORTES"/>
		<qry:define name="REPORTES" declare="&lt;PARAMS PARENT=&quot;206&quot; MODE=&quot;GRID&quot; /&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="sql-textos" doc-path="#SOURCE:PARAMS"/>
					<qry:insert-select name="sql-fijos" doc-path="#SOURCE:PARAMS"/>
					<qry:insert-select name="sql-reportes" doc-path="#SOURCE:PARAMS"/>
				</ROWS>
			</qry:main>
			<qry:select name="sql-textos" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  WRK01_NODE_TEXTS.c_text,
  WRK01_NODE_TEXTS.c_tipo
from
  WRK01_NODE_TEXTS,
  WRK01_FORMS                          
join
	WRK01_FORMS.oi_wf INNER WRK01_NODE_TEXTS.oi_wf
where             
	 WRK01_FORMS.oi_form={$SOURCE/@PARENT} AND
	 WRK01_NODE_TEXTS.c_tipo in (\'WIKI\', \'TXT\')
  			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="value" value="concat(iif($r/@c_tipo='WIKI','WIKI','TEXT'),'/',$r/@c_text)"/>
						<qry:attribute name="text" value="$r/@c_text"/>
					</option>
				</qry:out>
			</qry:select>
			<qry:select name="sql-fijos" doc="SOURCE">
				<qry:out>
					<option value="NOMAD" text="Reporte Nomad"/>
					<option value="URL" text="URL Externa"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql-reportes">
				<qry:xquery>
					for $r in FS('./APP/{%=#PROXY:@app%}/HTML')/LIST/FILE[contains(upper_case(@name),'.GEN.') or contains(upper_case(@name),'.LOG.')]
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql-reportes-2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="sql-reportes-2">
				<qry:xquery>
					for $r in FILESTORE('HTML/{%=#SOURCE:@name %}')/html:html
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="value" value="#SOURCE:@name"/>
						<qry:attribute name="text" value="$r/@name"/>
						<qry:attribute name="params" value="$r/html:xslt/xsl:template[@name='GADGET_PARAM']/param/@name"/>
					</option>
				</qry:out>
			</qry:select>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
