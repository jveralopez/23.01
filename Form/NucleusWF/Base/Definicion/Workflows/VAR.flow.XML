<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="DESIGN" extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD.autoflow" name="NucleusWF.Base.Definicion.Workflows.VAR.flow">
	<flow:info label="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD.autoflow"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="DESIGN">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form mode="DESIGN" parent-doc-path="#SOURCE:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.form"/>
		</flow:action>
		<flow:action name="EDIT">
			<doc:set-attribute from-attr-path="#SOURCE:@ID" to-attr-path="#SELECT:@ID"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<doc:set-attribute from-value="0" to-attr-path="#SELECT:@CALL"/>
			<doc:new-object doc="PARENT" class="NucleusWF.Base.Definicion.Workflows.VAR_GROUP"/>
			<doc:load-object id-path="#SOURCE:@PARENT" doc="PARENT" load-child="0" load-all="1" class="NucleusWF.Base.Definicion.Workflows.VAR_GROUP"/>
			<flow:call-action eq="MAIN" if="#PARENT:@c_mode" action="EDIT_MAIN"/>
			<flow:call-action eq="HIST" if="#PARENT:@c_mode" action="EDIT_HIST"/>
			<flow:call-action eq="0" if="#SELECT:@CALL" action="EDIT_DEFAULT"/>
		</flow:action>
		<flow:action name="ADD">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<doc:set-attribute from-value="0" to-attr-path="#SELECT:@CALL"/>
			<doc:new-object doc="PARENT" class="NucleusWF.Base.Definicion.Workflows.VAR_GROUP"/>
			<doc:load-object id-path="#SOURCE:@PARENT" doc="PARENT" load-child="0" load-all="1" class="NucleusWF.Base.Definicion.Workflows.VAR_GROUP"/>
			<flow:call-action eq="MAIN" if="#PARENT:@c_mode" action="ADD_MAIN"/>
			<flow:call-action eq="HIST" if="#PARENT:@c_mode" action="ADD_HIST"/>
			<flow:call-action eq="0" if="#SELECT:@CALL" action="ADD_DEFAULT"/>
		</flow:action>
		<flow:action name="ADD_MAIN">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-value="1" to-attr-path="#SELECT:@CALL"/>
			<flow:open-form mode="NEW_MAIN" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="ADD_HIST">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-value="1" to-attr-path="#SELECT:@CALL"/>
			<flow:open-form mode="NEW_HIST" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="ADD_DEFAULT">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form mode="NEW_OTHER" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_MAIN">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-value="1" to-attr-path="#SELECT:@CALL"/>
			<flow:open-form mode="EDIT_MAIN" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_HIST">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-value="1" to-attr-path="#SELECT:@CALL"/>
			<flow:open-form mode="EDIT_HIST" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="EDIT_DEFAULT">
			<doc:set-attribute from-attr-path="#SOURCE:@oi_workflow" to-attr-path="#SELECT:@oi_workflow"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form mode="EDIT_OTHER" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
		</flow:action>
		<flow:action name="UP">
			<flow:exec-method method="MOVE" class="NucleusWF.Base.Definicion.Workflows.VAR">
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_var"/>
				<flow:param value="UP" type="Nomad.NSystem.String" mode="in" name="pos"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DW">
			<flow:exec-method method="MOVE" class="NucleusWF.Base.Definicion.Workflows.VAR">
				<flow:param attr-path="#SOURCE:@ID" type="Nomad.NSystem.Int" mode="in" name="oi_var"/>
				<flow:param value="DOWN" type="Nomad.NSystem.String" mode="in" name="pos"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form mode="DESIGN" name="NucleusWF.Base.Definicion.Workflows.VAR.form:DESIGN" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.VAR.form">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="SHOW">
			<flow:open-form mode="SHOW" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="ADD">
			<flow:open-form mode="NEW" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="EDIT">
			<flow:open-form mode="EDIT" parent-doc-path="#SOURCE:" doc-path="#SOURCE:" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform"/>
		</flow:action>
		<flow:action name="DELETE">
			<flow:call-action action="INT-DELETE"/>
		</flow:action>
		<flow:action name="INT-DELETE">
			<doc:new-object doc="DDO" class="NucleusWF.Base.Definicion.Workflows.VAR"/>
			<doc:load-object id-path="#SOURCE:@ID" doc="DDO" load-child="1" load-all="1" class="NucleusWF.Base.Definicion.Workflows.VAR"/>
			<doc:delete-object doc-path="#DDO:"/>
			<doc:save-object doc="DDO" class="NucleusWF.Base.Definicion.Workflows.VAR"/>
		</flow:action>
	</flow:form>
	<flow:form extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:NEW" name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:NEW_MAIN" parent-doc="PARENT" doc="SOURCE" mode="NEW_MAIN" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
	<flow:form extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:NEW" name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:NEW_HIST" parent-doc="PARENT" doc="SOURCE" mode="NEW_HIST" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
	<flow:form name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:NEW_OTHER" mode="NEW_OTHER" extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:NEW" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
	<flow:form extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:EDIT" mode="EDIT_MAIN" name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:EDIT_MAIN" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
	<flow:form extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:EDIT" mode="EDIT_HIST" name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:EDIT_HIST" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
	<flow:form extends="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.autoform:EDIT" mode="EDIT_OTHER" name="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form:EDIT_OTHER" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Workflows.VAR.MAIN.STD_REG.form"/>
</flow:flow>
