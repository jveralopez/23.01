<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="ADDDEL" extends="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD.autoflow" name="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD.flow">
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="ADDDEL">
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#SELECT:@PARENT"/>
			<flow:open-form mode="ADDDEL" parent-doc-path="#SELECT:" doc-path="#SELECT:" form-class="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD_LIST.form"/>
		</flow:action>
		<flow:action name="CHANGE">
			<flow:exec-method method="EstructuraADDDEL" class="NucleusWF.Base.Definicion.Organigramas.ORGANIGRAMA">
				<flow:param attr-path="#SOURCE:@PARENT" type="Nomad.NSystem.Int" mode="in" name="oi_estructura"/>
				<flow:param type="Nomad.NSystem.String" attr-path="#SOURCE:@LIST" mode="in" name="oi_entidades"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:main>
	<flow:form extends="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD_LIST.autoform:LIST" mode="ADDDEL" parent-doc="PARENT" doc="SOURCE" form-class="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD_LIST.form" name="NucleusWF.Base.Definicion.Organigramas.ENTIDAD_ESTR.MAIN.STD_LIST.form:ADDDEL">
		<flow:action name="on-show"/>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
