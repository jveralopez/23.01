<form:Form xmlns:form="nomad_engine.form" default_mode="LIST" doc="source" name="NucleusWF.Base.Definicion.Organigramas.ESTRUCTURA.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="B&#250;squeda de Personas en Organigrama" nowrap="1" align="center" style="S3 LCol_w" name="GEN"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%" height="100%">
		<form:Columns height="100%" width="95%" name="CC">
			<form:Column width="100%" height="100%" name="C1" separation="2" align="center" valign="top">
				<form:Blank height="5px" name="blank1"/>
				<form:Label align="left" label="Buscar Persona" name="BUSCAR_LBL" width="100%" style="S2 LCol_g" dynamic="0"/>
				<form:TextBox nvalue="#SOURCE:@BUSCAR" name="BUSCAR" length="64" xsize="64" ysize="1" descr="Texto a Buscar" required="False">
					<form:Event action="OnSearch" runat="client" name="onpressenter"/>
					<form:SButtons>
						<form:SButton descrip="Buscar Registros" name="Search" label="Buscar" img="search">
							<form:Event action="OnSearch" runat="client" name="onclick"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
				<form:Blank height="5px" name="blank2"/>
				<form:ListView rows="-250" width="100%" docname="RS" name="LIST">
					<form:LVColumns>
						<form:LVColumn type="string" visible="0" name="id" attrname="id"/>
						<form:LVColumn attrname="entidad" type="string" label="Entidad" name="entidad"/>
						<form:LVColumn attrname="ubicacion" type="string" label="Ubicacion" name="ubicacion"/>
					</form:LVColumns>
				</form:ListView>
			</form:Column>
		</form:Columns>
		<form:Hidden nvalue="#SOURCE:@PARENT" name="PARENT"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button label="Volver" descrip="Volver" img="back" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function OnSearch()
{
	Ctrl("main").DoEvent("SEARCH");
}
	</form:Scripts>
	<form:Event action="SEARCH" name="SEARCH" runat="server"/>
</form:Form>
