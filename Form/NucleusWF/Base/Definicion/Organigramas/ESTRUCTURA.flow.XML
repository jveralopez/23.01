	<flow:info label="Flow guia para NucleusWF.Base.Definicion.Organigramas.ESTRUCTURA"/>
	<flow:declare>
		<doc:define name="PARENT"/>
		<doc:define name="SELECT">
			<DATA id=""/>
		</doc:define>
		<qry:define name="MAXCODE" declare="&lt;DATA PARENT=&quot;103&quot; /&gt;">
			<qry:main doc="SOURCE">
				<ROW max-value="1">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</ROW>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  max(right(\'0000000000\'||WRK05_ESTRUCTURA.c_estructura,10)) as cod
from
  WRK05_ESTRUCTURA
where             
	 WRK05_ESTRUCTURA.oi_organigrama={$SOURCE/@PARENT}
  			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="max-value" value="number($r/@cod)+1"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="AUX"/>
		<qry:define name="ROLES" declare="&lt;DATA PARENT=&quot;103&quot; /&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATA"/>
				</ROWS>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  WRK05_ROLES.c_role,
  WRK05_ROLES.d_role
from
  WRK05_ROLES
where               
	WRK05_ROLES.c_role!=\'OWNER\' and
	WRK05_ROLES.oi_organigrama={$SOURCE/@PARENT}
  			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="value" value="$r/@c_role"/>
						<qry:attribute name="text" value="$r/@d_role"/>
					</option>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="ROLES"/>
	</flow:declare>
