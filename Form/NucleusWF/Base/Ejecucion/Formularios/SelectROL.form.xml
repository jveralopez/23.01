<form:Form xmlns:form="nomad_engine.form" doc="source" default_mode="SHOW" name="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form">
	<form:Help/>
	<form:Title name="SecTIT">
		<form:RowAligner name="RT">
			<form:Row name="R1">
				<form:Label label="Iniciar un Workflow - " style="M1 LCol_w" dynamic="0" name="lblTITLE"/>
				<form:Label dynamic="1" nvalue="#source:@label" style="M1 LCol_w" label="Iniciar la Solicitud" name="lblSolName"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center name="SecCenter">
		<form:Hidden nvalue="#source:@oi_wf" descrip="wf" label="wf" name="oi_wf"/>
		<form:Blank height="30px" name="B1"/>
		<form:Label name="lblLeyend1" style="M1 LCol_g" dynamic="0" label="Existe mas de un ROL para iniciar este Workflow, "/>
		<form:Label name="lblLeyend2" style="M1 LCol_g" dynamic="0" label="seleccione el Rol/Actor que desea utilizar."/>
		<form:Blank height="30px" name="B2"/>
		<form:ComboBox docname="ROLES" mode="DOC" nvalue="#source:@c_rol" label="Actor/Rol" name="c_rol">
			<options/>
		</form:ComboBox>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="RA">
			<form:Row name="R1">
				<form:Button img="Ok" descrip="Aceptar" label="Aceptar" name="ACCEPT">
					<form:Event name="OnClick" action="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Esta seguro que quiere cancelar la Operacion?" img="cancel" descrip="Cancelar" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="OnClick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
