<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" default_action="DEBUG" name="NucleusWF.Base.Ejecucion.Formularios.ShowForm.flow">
	<flow:info label="Valida si un usuario puede resolver un WF y retorna una pantalla con la instancia o un mensaje."/>
	<flow:declare>
		<doc:define name="PRUEBAS">
			<DATA oi_thread="103" oi_node="513"/>
		</doc:define>
		<doc:define name="QRYResult"/>
		<qry:define declare="&lt;DATA oi_wf=&quot;805&quot; DEBUG=&quot;0&quot; ETTY=&quot;001AA0E914F9-4EE6463C019B-00012FD810CF&quot;/&gt;" name="SelectROL">
			<qry:main doc="SOURCE">
				<WF>
					<qry:attribute name="oi_wf" value="#SOURCE:./@oi_wf"/>
					<qry:attribute name="wf" value="#SOURCE:./@wf"/>
					<qry:attribute name="ETTY" value="#SOURCE:./@ETTY"/>
					<qry:if test="@ETTY=''">
						<qry:then>
							<qry:attribute name="ETTY" value="$PROXY/@ETTY"/>
						</qry:then>
					</qry:if>
					<qry:if test="@oi_wf=''">
						<qry:then>
							<qry:insert-select doc-path="." name="WF-FIND"/>
						</qry:then>
					</qry:if>
					<qry:insert-select doc-path="." name="WF"/>
					<ROLES>
						<qry:insert-select doc-path=".." name="ROLES"/>
					</ROLES>
					<qry:attribute name="count" value="count(ROLES/option)"/>
					<qry:attribute name="c_rol" value="ROLES/option/@value"/>
				</WF>
			</qry:main>
			<qry:select name="WF-FIND" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select       
	WFA.oi_wf,
	WFA.c_wf,
	WFA.d_wf
from
	wrk01_wf as WF,
	wrk01_wf as WFA
join
	WF.c_wf inner WFA.c_wf,
	WF.e_version_pub inner WFA.e_version
where           
	WF.c_estado=\'R\' and WF.l_automatica=0 and WF.c_wf={$SOURCE/@wf}			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_wf" value="$r/@oi_wf"/>
				</qry:out>
			</qry:select>
			<qry:select name="WF" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select       
	WF.d_wf
from
	wrk01_wf as WF
where
	WF.oi_wf={$SOURCE/@oi_wf}			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="label" value="$r/@d_wf"/>
				</qry:out>
			</qry:select>
			<qry:select name="ROLES" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select
  WP.oi_wf,
  WP.c_wf,
  WP.d_wf,
  RP.c_rol,
  OA.d_role
from
  wrk01_wf as WP,
  wrk01_process as PP,
  wrk01_roles_pro as RP,
  wrk05_organigramas as OG,
  wrk05_organigramas as OP,
  wrk05_estructura as EP,
  wrk05_entidad_estr as HP,
  WRK05_ROLES as OA

where
  PP.oi_wf=WP.oi_wf and
  PP.oi_process=RP.oi_process and
  RP.l_iniciar=1 and 
  OG.oi_organigrama = WP.oi_organigrama and
  OG.c_organigrama = OP.c_organigrama and
  OG.e_version_pub = OP.e_version and
  OG.l_automatica = 0 and
  OP.oi_organigrama = EP.oi_organigrama and
  OP.oi_organigrama = OA.oi_organigrama and
  EP.oi_estructura = HP.oi_estructura and
  HP.oi_entidad={$SOURCE/@ETTY} and
  EP.c_role=RP.c_rol and
  EP.c_role=OA.c_role and
	WP.oi_wf={$SOURCE/@oi_wf}	
group by
  WP.oi_wf,
  WP.c_wf,
  WP.d_wf,
  RP.c_rol,
  OA.d_role
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<option>
						<qry:attribute name="value" value="$r/@c_rol"/>
						<qry:attribute name="text" value="$r/@d_role"/>
					</option>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DEBUG">
			<DATA oi_thread="5506" oi_node="4078" DEBUG="1" ETTY="001AA0E914F9-4EE6463C019B-00012FD810CF"/>
		</doc:define>
		<qry:define name="SelectPASO" declare="&lt;DATA oi_thread=&quot;1500&quot; /&gt;">
			<qry:main doc="SOURCE">
				<WF>
					<qry:insert-select doc-path="#SOURCE:." name="DATOS"/>
				</WF>
			</qry:main>
			<qry:select name="DATOS" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
select       
	TH.oi_node,
	IT.e_pasos
from          
	wrk02_threads as TH,  
	wrk02_instances as IT
join
	TH.oi_instance inner IT.oi_instance
where                  
	TH.c_estado=\'WP\' and
	TH.oi_thread={$SOURCE/@oi_thread}			
	
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_node" value="$r/@oi_node"/>
					<qry:attribute name="e_pasos" value="$r/@e_pasos"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="CRC"/>
		<qry:define name="QRY_CRC">
			<qry:main doc="SOURCE">
				<qry:element name="CRC">
					<qry:attribute name="crc" value="nmd_crc(concat('PARAMS:file=NucleusWF.Base.Ejecucion.WaitProcess.rpt|oi_instance=',#SOURCE:DATA/@oi_instance))"/>
				</qry:element>
			</qry:main>
		</qry:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="RESOLVE">
			<flow:open-form doc-path="#SOURCE:" mode="EDIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form"/>
		</flow:action>
		<flow:action name="CREATE">
			<doc:load-qry output-doc="QRYResult" input-doc-path="#SOURCE:" qry="SelectROL"/>
			<doc:set-attribute from-attr-path="#QRYResult:@oi_wf" to-attr-path="#SOURCE:@oi_wf"/>
			<flow:call-action action="CREATE-ERROR" else="CREATE-OK" if="#QRYResult:@count" eq="0"/>
		</flow:action>
		<flow:action name="CREATE-ERROR">
			<doc:set-attribute from-value="La solicitud no puede ser Iniciada por el Usuario Actual." to-attr-path="#SOURCE:@mess"/>
			<flow:open-form form-class="NucleusWF.Base.Ejecucion.Formularios.ShowMess.form" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="CREATE-OK">
			<flow:call-action action="CREATE-WAIT" else="CREATE-ROLE" if="#QRYResult:@count" eq="1"/>
		</flow:action>
		<flow:action name="CREATE-ROLE">
			<doc:set-attribute from-attr-path="#QRYResult:@label" to-attr-path="#SOURCE:@label"/>
			<flow:open-form form-class="NucleusWF.Base.Ejecucion.Formularios.SelectROL.form" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="CREATE-WAIT">
			<doc:set-attribute from-attr-path="#QRYResult:@c_rol" to-attr-path="#SOURCE:@c_rol"/>
			<doc:set-attribute from-attr-path="#QRYResult:@label" to-attr-path="#SOURCE:@label"/>
			<flow:open-form form-class="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="DEBUG">
			<flow:open-form doc-path="#DEBUG:" mode="EDIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form:EDIT" doc="SOURCE" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form" mode="EDIT">
		<flow:action name="CLOSE-FORM">
			<flow:close-form/>
		</flow:action>
		<flow:action name="PASS">
			<flow:exec-method class="NucleusWF.Base.Ejecucion.Instancias.INSTANCE" method="Pass">
				<flow:param attr-path="#SOURCE:@oi_thread" type="Nomad.NSystem.Int" mode="in" name="pintThread"/>
				<flow:param type="Nomad.NSystem.Int" attr-path="#SOURCE:@paso" mode="in" name="pintPaso"/>
				<flow:param attr-path="#SOURCE:@ETTY" type="Nomad.NSystem.String" mode="in" name="Etty"/>
			</flow:exec-method>
			<flow:close-form/>
		</flow:action>
		<flow:action name="PASS-AND-WAIT">
			<flow:exec-method class="NucleusWF.Base.Ejecucion.Instancias.INSTANCE" method="Pass">
				<flow:param attr-path="#SOURCE:@oi_thread" type="Nomad.NSystem.Int" mode="in" name="pintThread"/>
				<flow:param type="Nomad.NSystem.Int" attr-path="#SOURCE:@paso" mode="in" name="pintPaso"/>
				<flow:param attr-path="#SOURCE:@ETTY" type="Nomad.NSystem.String" mode="in" name="Etty"/>
			</flow:exec-method>
			<flow:open-form mode="SHOW-AND-WAIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form" doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DELEGATE"/>
	</flow:form>
	<flow:form mode="SHOW" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowMess.form" name="NucleusWF.Base.Ejecucion.Formularios.ShowMess.form:SHOW" doc="SOURCE">
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Ejecucion.Formularios.SelectROL.form" name="NucleusWF.Base.Ejecucion.Formularios.SelectROL.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:close-form/>
			<flow:open-form form-class="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form" doc-path="#SOURCE:" mode="SHOW"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:attach-doc doc-path="#QRYResult:ROLES" attach-id="ROLES"/>
		</flow:action>
	</flow:form>
	<flow:form form-class="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form" name="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form:SHOW" mode="SHOW" doc="SOURCE">
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:exec-method out-type="Nomad.NSystem.String" out-attr-path="#SOURCE:@oi_instance" class="NucleusWF.Base.Ejecucion.Instancias.INSTANCE" method="CREAR">
				<flow:param type="Nomad.NSystem.String" attr-path="#SOURCE:@oi_wf" name="oi_wf" mode="in"/>
				<flow:param type="Nomad.NSystem.String" attr-path="#SOURCE:@c_rol" name="c_rol" mode="in"/>
				<flow:param type="Nomad.NSystem.Int" attr-path="#SOURCE:@DEBUG" name="debug" mode="in"/>
				<flow:param type="Nomad.NSystem.String" attr-path="#SOURCE:@ETTY" name="etty" mode="in"/>
				<flow:param doc="SOURCE" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="params"/>
			</flow:exec-method>
			<doc:load-qry output-doc="CRC" input-doc-path="#SOURCE:" qry="QRY_CRC"/>
			<flow:log text-path="#SOURCE:" text="DENISLOG"/>
		</flow:action>
		<flow:action name="FINISH-WAIT">
			<flow:close-form/>
			<flow:open-form doc-path="#SOURCE:" mode="EDIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form:SHOW-AND-WAIT" mode="SHOW-AND-WAIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowWAIT.form" doc="SOURCE">
		<flow:action name="EXIT">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="FINISH-WAIT">
			<flow:close-form/>
			<flow:open-form doc-path="#SOURCE:" mode="EDIT" form-class="NucleusWF.Base.Ejecucion.Formularios.ShowForm.form"/>
		</flow:action>
		<flow:action name="on-show">
			<doc:load-qry output-doc="CRC" input-doc-path="#SOURCE:" qry="QRY_CRC"/>
		</flow:action>
	</flow:form>
</flow:flow>
