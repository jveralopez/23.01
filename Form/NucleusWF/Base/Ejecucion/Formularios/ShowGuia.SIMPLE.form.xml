<form:Form xmlns:form="nomad_engine.form" doc="source" default_mode="SHOW" name="NucleusWF.Base.Ejecucion.Formularios.ShowMess.form">
	<form:Help/>
	<form:Scripts>
		function OnLoad()
{    
	//Ctrl("btnAccept").SetEnabled(Ctrl("RS").shownRegs.length==0?false:true);
}

function FilterGrid()
{    
	Ctrl("RS").filter("",Ctrl("buscar").GetCValue());
	Ctrl("btnAccept").SetEnabled(Ctrl("RS").shownRegs.length==0?false:true);
}
	</form:Scripts>
	<form:Title width="100%" name="secTittle">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nvalue="#source:@label" dynamic="1" label="Seleccione una Opcion" name="labTitle" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%" height="100%" name="SecCenter">
		<form:Columns width="100%" height="90%" name="colsCenter">
			<form:Column width="100%" height="90%" name="colCenter" separation="2" align="center" valign="top">
				<form:Blank height="20px" name="B1"/>
				<form:RowAligner name="buttonlinks" visible="SHOW">
					<form:Row name="row_top">
						<form:TextBox nvalue="#ITEMList:@search" name="buscar" label="Buscar" length="32" xsize="32" ysize="1" descr="Texto a Buscar" required="False">
							<form:Event runat="server" name="onpressenter" action="FILTER"/>
							<form:SButtons>
								<form:SButton name="Search" label="Buscar" img="search" descrip="Buscar los Registros.">
									<form:Event runat="server" name="onclick" action="FILTER"/>
								</form:SButton>
							</form:SButtons>
						</form:TextBox>
					</form:Row>
				</form:RowAligner>
				<form:Blank height="20px" name="B2"/>
				<form:ListView visible="0" nvalue="#source:@VAL" width="90%" rows="-250" docname="RS" name="RS">
					<form:LVColumns>
						<form:LVColumn attrname="DES" type="string" width="100%" sorteable="1" align="left" descrip="Descripci&#243;n" label="Descripci&#243;n" name="DES"/>
					</form:LVColumns>
				</form:ListView>
				<form:UrlControl height="100%" border="1" width="90%" nvalue="#REPORTDOM:@report" enabled="false" name="UrlControl02" label="UrlControl" descrip="" direct="1" X-POLICY="./FORM/NucleusRH/BaytonRH/Cliente/Reportes/InformeGestionComercial/form/UrlControl02"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="100%" name="SecBottom">
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="0" img="ok" descrip="Aceptar la Seleccion" label="Aceptar" name="btnAccept">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" descrip="Cancelar la Seleccion" name="btnCancel" label="Cancelar">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
				<form:Hidden nvalue="#SOURCE:@VAL" name="hid_val"/>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event name="OnLoad" action="OnLoad" runat="client"/>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
</form:Form>
