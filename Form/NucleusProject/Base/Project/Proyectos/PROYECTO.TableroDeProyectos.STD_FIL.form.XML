				<form:ComboBox xsize="40" mode="QRY" name="oi_recurso" prev="" nvalue="#source:@oi_recurso" required="0" label="L&#237;der de proyecto" descrip="L&#237;der de proyecto" enabled="" visible="" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" where1=""/>
