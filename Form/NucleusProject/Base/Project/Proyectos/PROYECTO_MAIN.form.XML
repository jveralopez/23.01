	<form:Resources>
		<form:Resource declare="&lt;DATA id=&quot;1925&quot;/&gt;" name="qryAvances">
			<qry:main doc="SOURCE">
				<ROW>
					<qry:insert-select name="IDS" doc-path="$SOURCE/DATA"/>
				</ROW>
			</qry:main>
			<qry:select name="IDS" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT 
		  PRY01_AVANCES.oi_avance as ID, 
		  PRY01_AVANCES.oi_proyecto as PRY, 
		  PRY01_AVANCES.o_avance as DES,
		  PRY01_AVANCES.f_avance as f_avance, 
		  PRY01_AVANCES.c_estado as c_estado,
		  PRY01_AVANCES.oi_recurso as oi_recurso,  
	    PRY05_RECURSOS.c_recurso as c_recurso,
      PER01_PERSONAL.d_ape_y_nom as nomb_y_ape

	
		FROM  
		PRY01_AVANCES,
		PRY05_RECURSOS,
    PER01_PERSONAL 
    
  join      
  PRY01_AVANCES.oi_recurso inner PRY05_RECURSOS.oi_recurso, 
  PRY05_RECURSOS.OI_PERSONAL inner PER01_PERSONAL.OI_PERSONAL
		
		WHERE    
		PRY01_AVANCES.oi_proyecto = {$PARAM/@id}
		AND PRY01_AVANCES.f_avance IN 
									(
								  select MAX(PRY01_AVANCES.f_avance) as fecha
								  FROM PRY01_AVANCES  
								  WHERE PRY01_AVANCES.oi_proyecto = {%=$PARAM/@id%}
		  						) 		  
		
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@DES" name="o_avance"/>
					<qry:attribute value="$r/@f_avance" name="f_avance"/>
					<qry:attribute value="$r/@c_estado" name="c_estado_avance"/>
					<qry:attribute value="'['+$r/@c_recurso+']'+' '+$r/@nomb_y_ape" name="c_recurso"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource name="qryRecursoLogueado">
			<qry:main doc="PARAM">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="SQL1">
				<qry:xquery>
					for $r in SQL('
			SELECT 
				P.oi_personal, R.oi_recurso
			FROM
				PER01_PERSONAL as P,
				PRY05_RECURSOS as R
			JOIN
				P.oi_personal inner R.oi_personal
			WHERE               
				P.oi_usuario_sistema = {#PROXY:@ETTY}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id_per" value="$r/@oi_personal"/>
					<qry:attribute name="oi_recurso" value="$r/@oi_recurso"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
