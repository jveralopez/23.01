	<form:Scripts>
		//propone fecha actual para modo new, habilita/deshabilita boton eliminar informe segun su posicion en la lista
function ONLOADCUS()
{   
  //Cuando abre el formulario en modo NEW
  if (Ctrl('main').GetMode() == 'NEW')
  {           
  //recupero el oi_proyecto para obtener informacion del mismo
  var nSQL = GetProxy().SQLService();	 	 
  var id = Ctrl('hid_oi_proyecto').GetXValue();
  var param = "&lt;DATA id=\""+id+"\" /&gt;";        
 
  //Recupero los datos del Proyecto
  var objProyecto = nSQL.GetOBJ(Ctrl("main").getResource("qryInfoProyecto"),param);
  
  //Asigno los valores a los controles
  if(objProyecto.oi_proyecto!=null)
  {Ctrl('oi_proyecto').SetXValue(objProyecto.id);} 
  if(objProyecto.oi_cliente!=null)
  {Ctrl('oi_cliente').SetXValue(objProyecto.oi_cliente);}
  if(objProyecto.oi_recurso!=null)
  {Ctrl('oi_recurso_asig').SetXValue(objProyecto.oi_recurso);}
  if(objProyecto.f_inicio!=null)
  {Ctrl('f_inicio').SetXValue(objProyecto.f_inicio);}
  if(objProyecto.f_fin!=null)
  {Ctrl('f_fin').SetXValue(objProyecto.f_fin);}
  if(objProyecto.f_inicio_est!=null)
  {Ctrl('f_inicio_est').SetXValue(objProyecto.f_inicio_est);}
  if(objProyecto.f_fin_est!=null)
  {Ctrl('f_fin_est').SetXValue(objProyecto.f_fin_est);}
  if(objProyecto.e_estimado!=null)
  {Ctrl('e_estimado').SetXValue(objProyecto.e_estimado);}
  if(objProyecto.e_imputado!=null)
  {Ctrl('e_imputado').SetXValue(objProyecto.e_imputado);}
  if(objProyecto.e_duracion!=null)
  {Ctrl('e_duracion').SetXValue(objProyecto.e_duracion);} 
  
  
  //Setea la fecha de avance, como fecha de hoy                    
  Ctrl('f_avance').SetTypedValue(new Date());  
  
  return;
  }
  
  //Cuando abre el formulario en modo SHOW y el avance no tiene cargados los datos del proyecto
  if (Ctrl('main').GetMode() == 'SHOW' &amp;&amp; Ctrl('oi_recurso_asig').GetXValue()=='')
  {              
  //recupero el oi_proyecto para obtener informacion del mismo
  var nSQL = GetProxy().SQLService();	 	 
  var id = Ctrl('oi_proyecto').GetXValue();
  var param = "&lt;DATA id=\""+id+"\" /&gt;";        
 
  //Recupero los datos del Proyecto
  var objProyecto = nSQL.GetOBJ(Ctrl("main").getResource("qryInfoProyecto"),param);
  
  //Agrega el valor del cliente dado que no esta cargado en la BBDD
  if(objProyecto.oi_cliente!=null)
  {Ctrl('oi_cliente').SetXValue(objProyecto.oi_cliente);}
  
  return;
  }                
  
  
	var ult = 0;
	if (Ctrl('LIST'))
	{
		if (Ctrl('LIST').GetXValue() == Ctrl('LIST').GetAttrValue(Ctrl('LIST').TotalRowsCount()-1, 'id'))
		{
			ult = 1;
		}
	}	
	else
	{
		if (Ctrl('iter-position').GetXValue() == Ctrl('iter-size').GetXValue())
		{
			ult = 1;
		}
	}
	
	
	CtrlEnabled('DELETE', false);
	
	if (ult == 1)
	{
		CtrlEnabled('DELETE', true);
	}
	
	
	
} 


//Valida que no se cree un informe con fecha anterior a la ultima
function VALIDAFECHA()
{   
   //recupero el oi_proyecto para obtener el recurso de fechas
	 var nSQL = GetProxy().SQLService();	 	 
	 var id = Ctrl('hid_oi_proyecto').GetXValue();
	 var param = "&lt;DATA id=\""+id+"\" /&gt;";        

		 
	//Recupero los datos del ultimo informe
	var objAvance = nSQL.GetOBJ(Ctrl("main").getResource("qryFechas"),param);   
	
	//si hay informes cargados   
	if(objAvance.f_avance!=null)  
	{
	  
	  if (objAvance.f_avance&gt;Ctrl('f_avance').GetXValue()) 
	  {
	    alert('Existen informes con fecha posterior a la ingresada.');   
	    return false; 
	  } 
	  else {return true;}
	} 
	
	else 
	{ 
	   return true; 
	}  
	
}
            
//Valida que al menos se haya cargado un campo dentro del Detalle del Proyecto            
function VALIDADETALLE()
{
     var det1=Ctrl('o_req_finalizados').GetXValue();
     var det2=Ctrl('o_req_proceso').GetXValue();
     var det3=Ctrl('o_req_faltantes').GetXValue();
     var det4=Ctrl('o_estado_planif').GetXValue();
     var det5=Ctrl('o_porc_avance').GetXValue();
     var det6=Ctrl('o_iden_riesgos').GetXValue();
     var det7=Ctrl('o_pasos_seguir').GetXValue();
     if (det1!='' || det2!='' || det3!='' || det4!='' || det5!='' || det6!='' || det7!='')     
     	{return true;}
     else
     	{
         alert('Debe completar al menos uno de los campos en el detalle del avance.');  
         Ctrl('o_req_finalizados').SetFocus();
         return false;
     	}
}

//Hace la validacion de la fecha y del detalle de avance
function VALIDACIONGENERAL()
{   
	if(VALIDAFECHA() &amp;&amp; VALIDADETALLE())
	{
	return true
	}
	else
	{
	return false;
	}   

}

function ImprimirAvance()
{   
	paramReport= "&lt;DATA oi_avance=\""+Ctrl("LIST").GetSelectAttrValue("id")+"\" /&gt;"; 
	appendFormInMain("NucleusProject.Base.Project.Reportes.Avances.ReporteAvance.flow", "REPORT_AVANCE", paramReport, false);

}
