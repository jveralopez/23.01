		<form:Resource declare="&lt;DATA id=&quot;1729&quot;/&gt;" name="qryFechas">
			<qry:main doc="SOURCE">
				<ROW>
					<qry:insert-select name="IDS" doc-path="$SOURCE/DATA"/>
				</ROW>
			</qry:main>
			<qry:select name="IDS" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT 
		  PRY01_AVANCES.oi_avance as ID, 
		  PRY01_AVANCES.oi_proyecto as PRY,
		  PRY01_AVANCES.oi_recurso as oi_recurso,  
		  PRY01_AVANCES.o_avance as DES,
		  PRY01_AVANCES.f_avance as f_avance, 
		  PRY01_AVANCES.c_estado as c_estado
		
		FROM  
		PRY01_AVANCES
		
		WHERE    
		PRY01_AVANCES.oi_proyecto = {$PARAM/@id}
		AND PRY01_AVANCES.f_avance IN 
									(
								  select MAX(PRY01_AVANCES.f_avance) as fecha
								  FROM PRY01_AVANCES  
								  WHERE PRY01_AVANCES.oi_proyecto = {%=$PARAM/@id%}
		  						) 		  
		
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@ID" name="id"/>
					<qry:attribute value="$r/@DES" name="o_avance"/>
					<qry:attribute value="$r/@f_avance" name="f_avance"/>
					<qry:attribute value="$r/@c_estado" name="c_estado_avance"/>
					<qry:attribute value="$r/@oi_recurso" name="oi_recurso"/>
				</qry:out>
			</qry:select>
		</form:Resource>
		<form:Resource declare="&lt;DATA id=&quot;1928&quot;/&gt;" name="qryInfoProyecto">
			<qry:main doc="SOURCE">
				<ROW>
					<qry:insert-select name="INFO" doc-path="$SOURCE/DATA"/>
				</ROW>
			</qry:main>
			<qry:select name="INFO" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT
			PRY01_PROYECTOS.oi_proyecto,
			PRY01_PROYECTOS.oi_recurso,
			PRY01_PROYECTOS.f_inicio,
			PRY01_PROYECTOS.f_fin,
			PRY01_PROYECTOS.f_inicio_est,
			PRY01_PROYECTOS.f_fin_est,
			PRY03_UND_TIEMPO.e_minutos,
			PRY01_PROYECTOS.oi_cliente,
			PRY01_PROYECTOS.e_estimado
			
			FROM
			PRY01_PROYECTOS,
			PRY03_UND_TIEMPO
			
			JOIN
			PRY01_PROYECTOS.oi_unidad_tiempo LEFT OUTER PRY03_UND_TIEMPO.oi_unidad_tiempo
			
			
			WHERE
			PRY01_PROYECTOS.oi_proyecto={#PARAM:@id} 

			 
			 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_proyecto" name="id"/>
					<qry:attribute value="$r/@oi_proyecto" name="oi_proyecto"/>
					<qry:attribute value="$r/@oi_recurso" name="oi_recurso"/>
					<qry:insert-select name="CLIENTE" doc-path="$r"/>
					<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
					<qry:attribute name="f_fin" value="$r/@f_fin"/>
					<qry:attribute name="f_inicio_est" value="$r/@f_inicio_est"/>
					<qry:attribute name="f_fin_est" value="$r/@f_fin_est"/>
					<qry:if test="$r/@e_minutos!=''">
						<qry:then>
							<qry:attribute name="e_estimado" value="(number($r/@e_estimado * $r/@e_minutos) div 60)"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="e_estimado" value="0"/>
						</qry:else>
					</qry:if>
					<qry:if test="$r/@f_fin_est!='' AND $r/@f_inicio_est!=''">
						<qry:then>
							<qry:attribute name="e_duracion" value="(datetime($r/@f_fin_est)-datetime($r/@f_inicio_est)) div 30"/>
						</qry:then>
					</qry:if>
					<qry:attribute name="e_imputado" value="0"/>
					<qry:insert-select name="IMPUTAR" doc-path="."/>
					<qry:insert-select name="IMPUTAR_HIJOS" doc-path="."/>
					<qry:if test="@oi_cliente=''">
						<qry:then>
							<qry:attribute name="oi_cliente" value="$r/@oi_cliente"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="CLIENTE" doc="PARAM">
				<qry:xquery>
					for $r in SQL('	
SELECT 
	pc.oi_cliente AS oi_cliente

FROM 
	PRY01_PROYECTOS AS pp, 
    PRY08_CLIENTES AS pc
JOIN

	pp.oi_cliente LEFT OUTER pc.oi_cliente 

WHERE
	pp.oi_proyecto = {#PARAM:@oi_proyecto}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@oi_cliente" name="oi_cliente"/>
				</qry:out>
			</qry:select>
			<qry:select name="IMPUTAR" doc="PARAM">
				<qry:xquery>
					for $r in SQL('          
SELECT 
	pt2.e_duracion
	, put1.e_minutos
FROM 
	PRY02_TAREAS as pt
	, PRY04_TRABAJOS as pt2
	, PRY03_UND_TIEMPO AS put1
JOIN
	pt2.oi_tarea INNER pt.oi_tarea
	, put1.oi_unidad_tiempo INNER pt2.oi_unidad_tiempo 
WHERE 
	pt.oi_proyecto = {#PARAM:@oi_proyecto} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="e_imputado" value="number(@e_imputado) + ($r/@e_duracion * $r/@e_minutos) div 60"/>
				</qry:out>
			</qry:select>
			<qry:select name="IMPUTAR_HIJOS" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			SELECT p.oi_proyecto
			
			FROM
			PRY01_PROYECTOS as pp,
			PRY01_PROYECTOS as p
			
			JOIN
			pp.oi_proyecto INNER p.oi_proyecto_parent
			
			WHERE
			pp.oi_proyecto = {#PARAM:@oi_proyecto}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_proyecto" value="$r/@oi_proyecto"/>
					<qry:if test="$r/@oi_proyecto!=''">
						<qry:then>
							<qry:insert-select name="IMPUTAR" doc-path="."/>
							<qry:insert-select name="IMPUTAR_HIJOS" doc-path="."/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
