<form:Form xmlns:form="nomad_engine.form" default_mode="FINALIZEMAIL" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusProject.Base.Project.Proyectos.PROYECTO">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label visible="FINALIZE|FINALIZEMAIL" label="Finalizar el proyecto" name="FINALIZE" nowrap="1" align="center" style="S3 LCol_w"/>
				<form:Label visible="ANULE" label="Anular el proyecto" name="ANULE" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%" height="100%">
		<form:Columns height="100%" width="100%" name="main_columnsPROYECTO">
			<form:Column valign="top" align="center" separation="0" name="main_col1">
				<form:Blank name="blkcol1_01"/>
				<form:TextBox visible="ANULE|FINALIZE|FINALIZEMAIL" nvalue="#source:@o_motivo" ysize="10" label="Motivo de finalizaci&#243;n / anulaci&#243;n" required="1" xsize="80" length="1000" name="o_motivo"/>
				<form:Blank name="blkcol1_02"/>
				<form:Line visible="FINALIZEMAIL" name="line1"/>
				<form:Blank name="blkcol1_03"/>
				<form:Label visible="FINALIZEMAIL" style="M1 LCol_t" label="Envio de mails a responsables:" name="Mails"/>
				<form:Blank name="blkcol1_04"/>
				<form:CheckBox label="Lider de Proyecto" visible="FINALIZEMAIL" name="Lider de Proyecto" required="1" nvalue="#source:@l_lider_proy"/>
				<form:CheckBox label="Lider de Proyecto Cliente" nvalue="#source:@l_lider_proy_cli" name="Lider de Proyecto Cliente" visible="FINALIZEMAIL" required="1"/>
				<form:CheckBox label="Responsable de Calidad" nvalue="#source:@l_respon_calidad" name="Responsable de Calidad" visible="FINALIZEMAIL" required="1"/>
				<form:CheckBox label="Contacto del Cliente" name="Contacto del Cliente" nvalue="#source:@l_contacto_cli" visible="FINALIZEMAIL" required="1"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom width="100%">
		<form:RowAligner name="RA">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1" X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/ACCEPT">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/ACCEPT/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/ACCEPT"/>
					</form:Policies>
				</form:Button>
				<form:Button name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario" X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/CANCEL">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/CANCEL/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA_TRAZA/autoform/CANCEL"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Event action="onLoad" name="onLoad" runat="client"/>
	<form:Scripts>
		function onLoad()
{
	Ctrl('o_motivo').SetXValue("");  
	Ctrl('Lider de Proyecto').SetXValue(0);
	Ctrl('Lider de Proyecto Cliente').SetXValue(0);
	Ctrl('Responsable de Calidad').SetXValue(0);
	Ctrl('Contacto del Cliente').SetXValue(0);
}
	</form:Scripts>
</form:Form>
