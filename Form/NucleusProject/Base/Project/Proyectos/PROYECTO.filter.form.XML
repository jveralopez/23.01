<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" extends="NucleusProject.Base.Project.Proyectos.PROYECTO.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusProject.Base.Project.Proyectos.PROYECTO">
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col1">
				<form:Rower label="Fecha de inicio desde - hasta" separation="5" name="rowerFechaInicio">
					<form:DateTime label="Fecha inicio desde" nvalue="#source:@f_inicio_desde" name="f_inicio_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="-" name="guion1"/>
					<form:DateTime label="Fecha inicio hasta" nvalue="#source:@f_inicio_hasta" name="f_inicio_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:Rower label="Fecha de fin desde - hasta" separation="5" name="rowerFechaFin">
					<form:DateTime nvalue="#source:@f_fin_desde" label="Fecha fin desde" name="f_fin_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
					<form:Label style="S2 LCol_g" label="-" name="guion2"/>
					<form:DateTime nvalue="#source:@f_fin_hasta" label="Fecha fin hasta" name="f_fin_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
						<form:SButtons>
							<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
								<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
							</form:SButton>
						</form:SButtons>
					</form:DateTime>
				</form:Rower>
				<form:TextBox xsize="40" nvalue="#source:@c_proyecto" label="Codigo" name="c_proyecto"/>
				<form:TextBox length="100" xsize="40" nvalue="#source:@d_proyecto" label="Descripci&#243;n" name="d_proyecto"/>
				<form:ComboBox queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" xsize="40" mode="QRY" required="0" label="Lider de Proyecto" nvalue="#source:@oi_recurso" name="oi_recurso" X-POLICY="./FORM/NucleusProject/Base/Project/Proyectos/PROYECTO_MAIN_NEW/form/oi_recurso"/>
				<form:ComboBox queryname1="NucleusProject.Base.Project.Clientes.CLIENTE.INFO" xsize="40" mode="QRY" required="0" label="Cliente" nvalue="#source:@oi_cliente" name="oi_cliente" X-POLICY="./FORM/NucleusProject/Base/Project/Proyectos/PROYECTO_MAIN_NEW/form/oi_cliente"/>
				<form:Blank name="fdsafasdfas"/>
				<form:Columns name="colListas">
					<form:Column name="colEstado" separation="2" align="center" valign="top">
						<form:ListView arr-control="EST" docname="EST" nvalue="#source:@selected" rows="8" width="300px" label="Estados" name="Estados">
							<form:LVColumns>
								<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Estado" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
									<form:Event action="FullEST" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
									<form:Event action="ClearEST" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr nvalue="#source:EST" proto="&lt;C /&gt;" name="EST">
							<form:Attr name="id"/>
						</form:HiddenArr>
					</form:Column>
					<form:Column name="colTiposProyectos" separation="2" align="center" valign="top">
						<form:ListView docname="TPROYS" arr-control="TPROYS" label="Tipos de proyectos" name="TiposProyectos" nvalue="#source:@selected" rows="8" width="300px">
							<form:LVColumns>
								<form:LVColumn attrname="des" label="Tipo de proyecto" width="100%" type="string" sorteable="1" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
									<form:Event action="FullTPROYS" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
									<form:Event action="ClearTPROYS" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr nvalue="#source:TPROYS" name="TPROYS" proto="&lt;C /&gt;">
							<form:Attr name="id"/>
						</form:HiddenArr>
					</form:Column>
				</form:Columns>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}

function ClearTPROYS()
{
	Ctrl("TPROYS").DelAllRow();
	Ctrl("TiposProyectos").Refresh();
}

function FullTPROYS()
{
	Ctrl("TPROYS").DelAllRow();     
	for (var t=0; t&lt;Ctrl("TiposProyectos").TotalRowsCount(); t++)
		Ctrl("TPROYS").AddRow().SetAttr("id", Ctrl("TiposProyectos").GetAttrValue(t, "id"));
	
	Ctrl("TiposProyectos").Refresh();
}
	</form:Scripts>
</form:Form>
