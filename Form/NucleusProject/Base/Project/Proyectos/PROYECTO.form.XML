		function tarea()
{     

	var id;
	var MyRetVal=new NomadXML();
	if(Ctrl('hid_oi_proyecto').GetXValue() != "")
		id = Ctrl('hid_oi_proyecto').GetXValue();
	else
		id=0;
	
	if(Ctrl('main').GetMode() == "LIST")
		id = Ctrl("LIST").GetSelectAttrValue("id");
	
	if(Ctrl('main').GetMode() == "SHOW" || Ctrl('main').GetMode() == "LIST")
		openNewFlow("NucleusProject.Base.Project.Tareas.MAIN_NEW.flow","initialize_view",'&lt;DATA id="'+id+'" /&gt;',MyRetVal,"L");
	else
		openNewFlow("NucleusProject.Base.Project.Tareas.MAIN_NEW.flow","initialize_edit",'&lt;DATA id="'+id+'" /&gt;',MyRetVal,"L");
}

function SYNC()
{
	if(Ctrl('main').GetMode()=='SHOW')
	{
		param='&lt;DATA id="' +Ctrl('hid_oi_proyecto').GetXValue()+'"/&gt;';
		openNewFlow("NucleusProject.Base.Project.Proyectos.NEWMAIN.flow","sincronizar",param,new ObjetoActualizador(),"L");
	}
	
	if(Ctrl('main').GetMode()=='LIST')
	{
		if(Ctrl('LIST').GetSelectAttrValue('id')!='')
		{
			param='&lt;DATA id="' +Ctrl('LIST').GetSelectAttrValue('id')+'"/&gt;';
			alert(param);
			openNewFlow("NucleusProject.Base.Project.Proyectos.NEWMAIN.flow","sincronizar",param,new ObjetoActualizador(),"L");
		}
	}
}

function ObjetoActualizador() 
{
	this.processResult = function(strResult)
	{  
		Ctrl('main').DoEvent("REFRESH");		
	}
}        

function ListClick()
{   
	if(Ctrl("main").GetMode() == 'LIST')
	{
		if(Ctrl("LIST").GetSelectAttrValue("c_estado") != 'F' &amp;&amp; Ctrl("LIST").GetSelectAttrValue("c_estado") != 'A')
		{
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true);
			CtrlEnabled("EDIT", true);
		}
		else 
		{
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("EDIT", false);
		}
		if(Ctrl("LIST").GetSelectAttrValue("oi_tipo_proyecto") != '[PROY] Proyecto')
		{  
			CtrlEnabled("Informes",false);
			CtrlEnabled("ADDINF",false);
		}
		else
		{       
			CtrlEnabled("Informes",true);
			CtrlEnabled("ADDINF",true);
		}
	}
}   

function OnLoadCus()
{
	if(Ctrl("main").GetMode() == 'SHOW')
	{   
		if(Ctrl("c_estado").GetXValue() == 'F' || Ctrl("c_estado").GetXValue() == 'A')
		{
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("EDIT", false);
		}
		
		if(Ctrl("oi_tipo_proyecto").GetXValue() != 1)
		{  
			CtrlEnabled("Informes",false);
			CtrlEnabled("ADDINF",false);
		}  	
	    
	    
	 //Completo campos de Informe de avance
	 var nSQL = GetProxy().SQLService();	 	 
	 var id = Ctrl('hid_oi_proyecto').GetXValue();		
	 var param = "&lt;DATA id=\""+id+"\" /&gt;";        
	
		 
	//Recupero los datos del ultimo informe
	var objAvance = nSQL.GetOBJ(Ctrl("main").getResource("qryAvances"),param);
	
	if(objAvance.f_avance!=null)
	{     
	//Seteo los controles del form con los valores del atributo del objeto avance	
	Ctrl('f_avance').SetXValue(objAvance.f_avance);
	Ctrl('usuario_avance').SetXValue(objAvance.c_recurso); 
	Ctrl('o_avance').SetXValue(objAvance.o_avance);
	Ctrl('c_estado_avance').SetXValue(objAvance.c_estado_avance);
	} 
	else 
  	{
	  Ctrl('f_avance').SetCValue("");
	  Ctrl('usuario_avance').SetCValue("");  
	  Ctrl('o_avance').SetCValue("");
	  Ctrl('c_estado_avance').SetCValue("");
    }
	
  } 
	
	if(Ctrl("main").GetMode() == 'LIST')
	{
		if(Ctrl("LIST").GetSelectAttrValue("c_estado") != 'F' &amp;&amp; Ctrl("LIST").GetSelectAttrValue("c_estado") != 'A')
		{
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true); 
			CtrlEnabled("EDIT", true);
		}
		else 
		{
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("EDIT", false);
		}
		
		if(Ctrl("LIST").GetSelectAttrValue("oi_tipo_proyecto") != '[PROY] Proyecto')
		{  
			CtrlEnabled("Informes",false);
			CtrlEnabled("ADDINF",false);
		}
		else
		{       
			CtrlEnabled("Informes",true);
			CtrlEnabled("ADDINF",true);
		}	
	}
}  

