	<form:Scripts>
		function OnLoad()
{
	switch(Ctrl("c_estado").GetXValue())
	{
		case "I":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,true);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("TEMPLATE",Ctrl("oi_proyecto_parent").GetXValue()==""?true:false);
		break
		
		case "T":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true); 
			CtrlEnabled("TEMPLATE",false);
		break;

		case "F":
		case "A":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("TEMPLATE",false);
		break;
		
		case "L":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,true);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("TEMPLATE",false);
		break;

		default:
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,true );
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
			CtrlEnabled("TEMPLATE",false);
		break;
	}
}

function oi_proyectoReport()
{
	this.processResult = function(XML)
	{                 
		var myRESULT=new NomadXML(XML);
		Ctrl("oi_proyecto_C" ).SetXValue(myRESULT.GetAttr("oi_proyecto"));
	}
}

function Clearoi_proyecto()
{
	Ctrl("oi_proyecto_C").SetXValue("");
}

function Findoi_proyecto()
{                    
	//Comentado para llamar al traer el mismo arbol de proyecto que en el item de menu de proyecto viejo.-
	//openNewFlowWait("NucleusProject.Base.Project.Proyectos.PROYECTO.guia.flow","HELP",'&lt;DATA oi_proyecto="'+Ctrl("oi_proyecto_C").GetXValue()+'" ESTADOS="ITL" /&gt;',new oi_proyectoReport(),"S");
	openNewFlowWait("NucleusProject.Base.Project.Proyectos.PROYECTO.guia.flow","HELP_NEW",'&lt;DATA oi_proyecto="'+Ctrl("oi_proyecto_C").GetXValue()+'" ESTADOS="ITL" /&gt;',new oi_proyectoReport(),"S");
}

function validaCentroCosto()
{

 if(Ctrl('oi_cliente').GetXValue() != "")
	{
		if (Ctrl('oi_cliente').GetXValue() == 1 &amp;&amp; Ctrl('oi_centro_costo').GetXValue() == "") 
		{
		  alert('El valor es requerido'); 
		  Ctrl('oi_centro_costo').SetFocus();
		  return false;
		}
		else
		  return true;
	}
  else
  return true;	
}

//Funcion que realiza validaciones de negocio al guardar
function validaGuardar()
{   
	if(Ctrl('main').GetMode()=="NEW" || Ctrl('main').GetMode()=="EDIT")
	{
		if(Ctrl('oi_tipo_proyecto').GetXValue()=="1")
		{  
			if(Ctrl('oi_lider_proy_cli').GetXValue()=="")
		    	{
		    	alert('El valor es requerido'); 
		  		Ctrl('oi_lider_proy_cli').SetFocus();
		  		return false;
		    	}
		    
		    if(Ctrl('oi_respon_calidad').GetXValue()=="")
		    	{
		    	alert('El valor es requerido'); 
		  		Ctrl('oi_respon_calidad').SetFocus();
		  		return false;
		    	}        
		    	
		    return validaCentroCosto();
		}
		else
			return validaCentroCosto();
		
		
	}
	else 
	return true;

}
