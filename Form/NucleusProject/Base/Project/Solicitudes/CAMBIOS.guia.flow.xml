<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" xmlns:qry="nomad_engine.qry" name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.flow">
	<flow:info label="Flow guia para NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.flow"/>
	<flow:main doc="SOURCE">
		<flow:action name="CERRAR">
			<flow:log text-path="#SOURCE:" text="jprSOURCE"/>
			<flow:open-form mode="CERRAR" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc-path="#SOURCE:" parent-doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="DERIVAR">
			<flow:open-form mode="DERIVAR" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc-path="#SOURCE:" parent-doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="RECHAZAR">
			<flow:open-form mode="RECHAZAR" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc-path="#SOURCE:" parent-doc-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="CERRAR_GADGET">
			<doc:load-object doc="DDO" class="NucleusProject.Base.Project.Solicitudes.SOLICITUD" id-path="#SOURCE:@id" load-child="1" load-all="1"/>
			<doc:set-attribute to-attr-path="#DDO:@o_motivo"/>
			<flow:open-form mode="CERRAR_GADGET" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc-path="#DDO:"/>
		</flow:action>
	</flow:main>
	<flow:declare>
		<doc:define name="NADA"/>
		<doc:define name="CERRAR"/>
		<qry:define declare="&lt;ROWS nmd-col=&quot;1&quot;&gt;&#13;&#10;&#9;&lt;ROW title=&quot;      0.00&quot; img=&quot;Listas/cross.gif&quot; oi_error=&quot;[MEDIA] MEDIA&quot; oi_recurso=&quot;[jprizzo] RIZZO, JUAN PABLO&quot; oi_clasificacion=&quot;[NUE] Nuevos Requerimientos&quot; oi_origen=&quot;[] &quot; oi_modulo=&quot;[PER] NUCLEUSRH - Administraci&#243;n del Personal&quot; d_aplicacion=&quot;NucleusRH&quot; nom_cliente=&quot;Bayton S.A.&quot; oi_contacto=&quot;[5] Alan Venn&quot; TEXT=&quot;ANALISIS DE CLICK VIEW&quot; CODE=&quot;2012 0014&quot; d_solicitud=&quot;ANALISIS DE CLICK VIEW&quot; c_estado=&quot;3&quot; f_estado=&quot;20121017&quot; f_solicitud=&quot;20121017&quot; c_solicitud=&quot;2012 0014&quot; id=&quot;1295&quot; check=&quot;1&quot; o_motivo=&quot;Motivo de cierre de la solicitud&quot; /&gt;&#13;&#10;&#9;&lt;ROW title=&quot;      0.00&quot; img=&quot;Listas/cross.gif&quot; oi_error=&quot;[MEDIA] MEDIA&quot; oi_recurso=&quot;[jprizzo] RIZZO, JUAN PABLO&quot; oi_clasificacion=&quot;[ATE] Atenci&#243;n Telef&#243;nica / Mail&quot; oi_origen=&quot;[] &quot; oi_modulo=&quot;[MIG] MIGRACION - MIGRACION&quot; d_aplicacion=&quot;NucleusRH&quot; nom_cliente=&quot;Bayton S.A.&quot; oi_contacto=&quot;[148] Juan Pablo Rizzo&quot; TEXT=&quot;TEST&quot; CODE=&quot;2012 0012&quot; d_solicitud=&quot;TEST&quot; c_estado=&quot;3&quot; f_estado=&quot;20121015&quot; f_solicitud=&quot;20121015&quot; c_solicitud=&quot;2012 0012&quot; id=&quot;1199&quot; check=&quot;0&quot; o_motivo=&quot;Motivo&quot; /&gt;&#13;&#10;&lt;/ROWS&gt;" name="FILTER_UNCHECK">
			<qry:main maxdeep="2" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_check" doc-path="#SOURCE:./ROW[@check='1']"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_check">
				<qry:xquery>
					for $r in #PARAM:
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:attribute name="o_motivo" value="$r/@o_motivo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="DERIVAR"/>
		<doc:define name="RECHAZAR"/>
		<doc:define class="NucleusProject.Base.Project.Solicitudes.SOLICITUD" name="DDO"/>
		<doc:define name="RESULT">
			<RESULT result=""/>
		</doc:define>
	</flow:declare>
	<flow:form parent-doc="PARENTSOURCE" mode="CERRAR" name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form:ESTADO" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc="SOURCE">
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#NADA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text="jprSOURCE" text-path="#SOURCE:"/>
			<doc:load-qry output-doc="CERRAR" input-doc-path="#SOURCE:" qry="FILTER_UNCHECK"/>
			<flow:exec-method method="CerrarSolicitudes" class="NucleusProject.Base.Project.Solicitudes.SOLICITUD">
				<flow:param doc-path="#CERRAR:" name="solicitudesSeleccionadas" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form:DERIVAR" mode="DERIVAR" parent-doc="PARENTSOURCE" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc="SOURCE">
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#NADA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="DERIVAR" input-doc-path="#SOURCE:" qry="FILTER_UNCHECK"/>
			<flow:exec-method method="DerivarSolicitudes" class="NucleusProject.Base.Project.Solicitudes.SOLICITUD">
				<flow:param doc-path="#DERIVAR:" name="solicitudesSeleccionadas" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form:RECHAZAR" mode="RECHAZAR" parent-doc="PARENTSOURCE" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc="SOURCE">
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#NADA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<doc:load-qry output-doc="RECHAZAR" input-doc-path="#SOURCE:" qry="FILTER_UNCHECK"/>
			<flow:exec-method method="RechazarSolicitudes" class="NucleusProject.Base.Project.Solicitudes.SOLICITUD">
				<flow:param doc-path="#RECHAZAR:" name="solicitudesSeleccionadas" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form:CERRAR_GADGET" mode="CERRAR_GADGET" form-class="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc="SOURCE">
		<flow:action name="CANCEL">
			<doc:set-attribute from-value="CANCEL" to-attr-path="#RESULT:@result"/>
			<flow:exit-flow return-path="#RESULT:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:exec-method this-doc="DDO" method="Cerrar"/>
			<flow:call-action else="ERROR" action="OK" eq="5" if="#DDO:@c_estado"/>
			<flow:exit-flow return-path="#RESULT:"/>
		</flow:action>
		<flow:action name="OK">
			<doc:set-attribute from-value="OK" to-attr-path="#RESULT:@result"/>
		</flow:action>
		<flow:action name="ERROR">
			<doc:set-attribute from-value="ERROR" to-attr-path="#RESULT:@result"/>
		</flow:action>
	</flow:form>
</flow:flow>
