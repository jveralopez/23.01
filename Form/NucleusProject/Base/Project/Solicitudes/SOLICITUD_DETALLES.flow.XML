<flow:flow xmlns:flow="nomad_engine.flow" name="NucleusProject.Base.Project.Solicitudes.SOLICITUD_DETALLES.flow" extends="Nomad.base.HTML_XLS.flow">
	<flow:info label="Flow de control del reporte de Reclamos cargados en la Lista"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="REPORTE_TAREAS">
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusProject.Base.Project.TareasDeSolicitud.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:main>
</flow:flow>
