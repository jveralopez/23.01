<form:Form xmlns:form="nomad_engine.form" default_mode="CERRAR" name="NucleusProject.Base.Project.Solicitudes.CAMBIOS.guia.form" doc="source">
	<form:Title>
		<form:RowAligner name="title">
			<form:Row name="row1">
				<form:Label visible="CERRAR" name="CAMBIO_ESTADO" label="Solicitud - Cambio de Estado" nowrap="1" style="S3 LCol_w"/>
				<form:Label label="Solicitud - Derivar a Cliente" visible="DERIVAR" name="CAMBIO_ESTADO" nowrap="1" style="S3 LCol_w"/>
				<form:Label visible="RECHAZAR" label="Rechazar Solicitudes" name="CAMBIO_ESTADO" nowrap="1" style="S3 LCol_w"/>
				<form:Label visible="CERRAR_GADGET" label="Cerrar Solicitud" name="CAMBIO_ESTADO" nowrap="1" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="100%">
		<form:Blank name="blk1"/>
		<form:Columns width="100%" name="columns_CERRAR" visible="CERRAR">
			<form:Column width="100%" name="column_CERRAR">
				<form:Grid name="grid_cerrar" width="100%" nvalue="#SOURCE:" idvalue="#SOURCE:@id" doc="SOURCE" rows="10" paging="1" proto="&lt;ROW/&gt;" visible="CERRAR" allowdelall="0" allowhelper="0" allowdel="0" allownew="0" label="Solicitudes a cerrar">
					<form:GColumns>
						<form:GColumn name="gcol_sel">
							<form:CheckBox nvalue="#SOURCE:@check" name="check"/>
						</form:GColumn>
						<form:GColumn name="gcol_codigo">
							<form:TextBox name="c_solicitud" xsize="10" ysize="1" length="30" nvalue="#SOURCE:@c_solicitud" enabled="0" label="C&#243;digo"/>
						</form:GColumn>
						<form:GColumn name="gcol_descripcion">
							<form:TextBox length="100" label="Descripci&#243;n" name="d_solicitud" xsize="40" ysize="1" nvalue="#SOURCE:@d_solicitud" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="gcol_motivo_cambio">
							<form:TextBox xsize="80" length="1000" label="Motivo de cierre" name="o_motivo" ysize="3" nvalue="#SOURCE:@o_motivo"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
		<form:Columns visible="DERIVAR" name="columns_DERIVAR" width="100%">
			<form:Column name="column_DERIVAR" width="100%">
				<form:Grid name="grid_derivar" label="Solicitudes a Derivar" visible="DERIVAR" width="100%" nvalue="#SOURCE:" idvalue="#SOURCE:@id" doc="SOURCE" rows="10" paging="1" proto="&lt;ROW/&gt;" allowdelall="0" allowhelper="0" allowdel="0" allownew="0">
					<form:GColumns>
						<form:GColumn name="gcol_sel">
							<form:CheckBox nvalue="#SOURCE:@check" name="check"/>
						</form:GColumn>
						<form:GColumn name="gcol_codigo">
							<form:TextBox name="c_solicitud" xsize="10" ysize="1" length="30" nvalue="#SOURCE:@c_solicitud" enabled="0" label="C&#243;digo"/>
						</form:GColumn>
						<form:GColumn name="gcol_descripcion">
							<form:TextBox length="100" label="Descripci&#243;n" name="d_solicitud" xsize="40" ysize="1" nvalue="#SOURCE:@d_solicitud" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="gcol_motivo_cambio">
							<form:TextBox label="Motivo de Derivaci&#243;n a Cliente" xsize="80" length="1000" name="o_motivo" ysize="3" nvalue="#SOURCE:@o_motivo"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
		<form:Columns visible="RECHAZAR" name="columns_RECHAZAR" width="100%">
			<form:Column name="column_RECHAZAR" width="100%">
				<form:Grid label="Solicitudes a Rechazar" visible="RECHAZAR" name="grid_rechazar" width="100%" nvalue="#SOURCE:" idvalue="#SOURCE:@id" doc="SOURCE" rows="10" paging="1" proto="&lt;ROW/&gt;" allowdelall="0" allowhelper="0" allowdel="0" allownew="0">
					<form:GColumns>
						<form:GColumn name="gcol_sel">
							<form:CheckBox nvalue="#SOURCE:@check" name="check"/>
						</form:GColumn>
						<form:GColumn name="gcol_codigo">
							<form:TextBox name="c_solicitud" xsize="10" ysize="1" length="30" nvalue="#SOURCE:@c_solicitud" enabled="0" label="C&#243;digo"/>
						</form:GColumn>
						<form:GColumn name="gcol_descripcion">
							<form:TextBox length="100" label="Descripci&#243;n" name="d_solicitud" xsize="40" ysize="1" nvalue="#SOURCE:@d_solicitud" enabled="0"/>
						</form:GColumn>
						<form:GColumn name="gcol_motivo_cambio">
							<form:TextBox label="Motivo de Rechazo" xsize="80" length="1000" name="o_motivo" ysize="3" nvalue="#SOURCE:@o_motivo"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
		<form:Columns width="100%" visible="CERRAR_GADGET" name="columns_CERRAR_GADGET">
			<form:Column align="center" name="column_CERRAR_GADGET">
				<form:Hidden nvalue="#SOURCE:@id" name="id"/>
				<form:Blank name="blank1"/>
				<form:TextBox required="1" name="c_solicitud" xsize="10" ysize="1" length="30" nvalue="#SOURCE:@c_solicitud" enabled="0" label="C&#243;digo"/>
				<form:TextBox required="1" length="100" label="Descripci&#243;n" name="d_solicitud" xsize="50" ysize="1" nvalue="#SOURCE:@d_solicitud" enabled="0"/>
				<form:TextBox required="1" nvalue="#SOURCE:@o_motivo" xsize="50" length="1000" label="Motivo de cierre" name="o_motivo" ysize="4"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="bottom">
			<form:Row name="rowbottom">
				<form:Button startvalidate="1" note="Aceptar" descrip="Aceptar" img="OK" label="Aceptar" name="ACCEPT">
					<form:Event action="ACEPTAR" name="onclick" runat="client"/>
				</form:Button>
				<form:Button startvalidate="0" note="Cancelar" descrip="Cancelar" img="CANCEL" label="Cancelar" name="CANCEL">
					<form:Event action="CANCEL" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ACEPTAR()
{   
	//Formulario en Modo CERRAR
	if(Ctrl('main').GetMode()=='CERRAR')
	{
		var error="";
		for (var i=0; i&lt;Ctrl('grid_cerrar').TotalRowsCount(); i++)
		{
			if (Ctrl("grid_cerrar").GetCellXValue('check', i) == 1 &amp;&amp; Ctrl("grid_cerrar").GetCellXValue('o_motivo', i) == "")
					error = error + "[" + Ctrl("grid_cerrar").GetCellXValue('c_solicitud', i) +"] " + Ctrl("grid_cerrar").GetCellXValue('d_solicitud', i) + "\n";	
		}	
		if (error != "")
		{
			alert("Falta completar el motivo de cierre en las solicitudes: \n" + error);
			return false;
		}
		else
			Ctrl('main').DoEvent('ACCEPT');
	}                 
	
	//Formulario en Modo DERIVAR
	if(Ctrl('main').GetMode()=='DERIVAR')
	{
		var error="";
		for (var i=0; i&lt;Ctrl('grid_derivar').TotalRowsCount(); i++)
		{
			if (Ctrl("grid_derivar").GetCellXValue('check', i) == 1 &amp;&amp; Ctrl("grid_derivar").GetCellXValue('o_motivo', i) == "")
					error = error + "[" + Ctrl("grid_derivar").GetCellXValue('c_solicitud', i) +"] " + Ctrl("grid_derivar").GetCellXValue('d_solicitud', i) + "\n";	
		}	
		if (error != "")
		{
			alert("Falta completar el motivo de derivaci&#243;n a cliente: \n" + error);
			return false;
		}
		else
			Ctrl('main').DoEvent('ACCEPT');
	}       
	
	//Formulario en Modo RECHAZAR
	if(Ctrl('main').GetMode()=='RECHAZAR')
	{
		var error="";
		for (var i=0; i&lt;Ctrl('grid_rechazar').TotalRowsCount(); i++)
		{
			if (Ctrl("grid_rechazar").GetCellXValue('check', i) == 1 &amp;&amp; Ctrl("grid_rechazar").GetCellXValue('o_motivo', i) == "")
					error = error + "[" + Ctrl("grid_rechazar").GetCellXValue('c_solicitud', i) +"] " + Ctrl("grid_rechazar").GetCellXValue('d_solicitud', i) + "\n";	
		}	
		if (error != "")
		{
			alert("Falta completar el motivo de rechazo: \n" + error);
			return false;
		}
		else
			Ctrl('main').DoEvent('ACCEPT');
	}                      
	
	if(Ctrl('main').GetMode()=='CERRAR_GADGET')
	{                                          
		Ctrl('main').DoEvent('ACCEPT');
	}
	
}
	</form:Scripts>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
</form:Form>
