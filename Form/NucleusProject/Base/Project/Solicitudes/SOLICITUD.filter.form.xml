<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" extends="NucleusProject.Base.Project.Solicitudes.SOLICITUD.filter.autoform" name="NucleusProject.Base.Project.Solicitudes.SOLICITUD.filter" doc="source">
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col1">
				<form:RowAligner name="rower_fecha_sol">
					<form:Row name="row_fechas_sol">
						<form:DateTime label="Fecha Solicitud Desde" nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" name="f_des">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Blank name="blank_f1"/>
						<form:DateTime label="Fecha Solicitud Hasta" nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" name="f_has">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Row>
				</form:RowAligner>
				<form:TextBox xsize="40" nvalue="#source:@c_solicitud" label="Codigo" name="c_solicitud"/>
				<form:TextBox label="Nombre" xsize="40" nvalue="#source:@d_solicitud" name="d_solicitud"/>
				<form:ComboBox label="Responsable" xsize="40" required="0" nvalue="#source:@oi_recurso" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" name="oi_recurso" mode="QRY"/>
				<form:ComboBox queryname1="NucleusProject.Base.Project.Aplicaciones.APLICACION.INFO" name="oi_aplicacion" label="Aplicaci&#243;n" nvalue="#source:@oi_aplicacion" xsize="40" required="0" mode="QRY"/>
				<form:ComboBox prev="oi_aplicacion" queryname1="NucleusProject.Base.Project.Aplicaciones.MODULO.INFO" label="Modulo" xsize="40" required="0" nvalue="#source:@oi_modulo" name="oi_modulo" mode="QRY"/>
				<form:ComboBox label="Cliente" queryname1="NucleusProject.Base.Project.Clientes.CLIENTE.INFO" nvalue="#source:@oi_cliente" name="oi_cliente" xsize="40" required="0" mode="QRY"/>
				<form:ComboBox label="Contacto" queryname1="NucleusProject.Base.Project.Clientes.CONTACTO.INFO" nvalue="#source:@oi_contacto" name="oi_contacto" xsize="40" required="0" mode="QRY"/>
				<form:TextBox label="Numero de reclamo" xsize="40" nvalue="#source:@c_reclamo" name="c_reclamo"/>
				<form:TextBox nvalue="#source:@c_formulario" label="C&#243;digo de Formulario de Solicitud" name="c_formulario" xsize="40"/>
				<form:RowAligner name="rower_fecha_venc">
					<form:Row name="row_fechas_venc">
						<form:DateTime label="Fecha Implementaci&#243;n Desde" nvalue="#source:@f_desde_v" name="f_des_v" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
						<form:Blank name="blank_f1"/>
						<form:DateTime nvalue="#source:@f_hasta_v" name="f_has_v" label="Fecha Implementaci&#243;n Hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy">
							<form:SButtons>
								<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
									<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:DateTime>
					</form:Row>
				</form:RowAligner>
				<form:Blank name="sadfb"/>
				<form:RowAligner width="90%" name="rower_lista">
					<form:Row name="row_estado">
						<form:ListView arr-control="EST" docname="EST" nvalue="#source:@selected" rows="8" width="300px" label="Estados" name="Estados">
							<form:LVColumns>
								<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Estado" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
									<form:Event action="FullEST" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
									<form:Event action="ClearEST" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr nvalue="#source:EST" proto="&lt;C /&gt;" name="EST">
							<form:Attr name="id"/>
						</form:HiddenArr>
						<form:Blank name="blank-row1"/>
						<form:Blank name="blank-row2"/>
						<form:Blank name="blank-row3"/>
						<form:ListView nvalue="#source:@selected_clasif" arr-control="CLASIF" docname="CLASIF" label="Clasificaciones" name="Clasificaciones" rows="8" width="300px">
							<form:LVColumns>
								<form:LVColumn label="Clasificaci&#243;n" width="100%" attrname="des" type="string" sorteable="1" name="des"/>
							</form:LVColumns>
							<form:SButtons>
								<form:SButton name="Mark_clasif" img="table_check" descrip="Marcar los Elementos">
									<form:Event action="FullESTCLASIF" name="OnClick" runat="client"/>
								</form:SButton>
								<form:SButton name="UnMark_clasif" img="table_uncheck" descrip="Desmarcar los Elementos">
									<form:Event action="ClearESTCLASIF" name="OnClick" runat="client"/>
								</form:SButton>
							</form:SButtons>
						</form:ListView>
						<form:HiddenArr name="CLASIF" nvalue="#source:CLASIF" proto="&lt;C /&gt;">
							<form:Attr name="id"/>
						</form:HiddenArr>
					</form:Row>
				</form:RowAligner>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Scripts>
		function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}

function ClearESTCLASIF()
{
	Ctrl("CLASIF").DelAllRow();
	Ctrl("Clasificaciones").Refresh();
}

function FullESTCLASIF()
{
	Ctrl("CLASIF").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Clasificaciones").TotalRowsCount(); t++)
		Ctrl("CLASIF").AddRow().SetAttr("id", Ctrl("Clasificaciones").GetAttrValue(t, "id"));
	
	Ctrl("Clasificaciones").Refresh();
}
	</form:Scripts>
</form:Form>
