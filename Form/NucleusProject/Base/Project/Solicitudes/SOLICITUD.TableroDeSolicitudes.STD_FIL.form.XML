	<form:Scripts>
		var CFG,CHLCFG;
var TIT=null;
var T2T=null;

///////////////////////////////////////////////////////////////////////////////          
//EVENTOS
function ONLOAD_custom()
{                
	//Cargo la Configuracion
	CFG=new NomadXML(Ctrl("main").getResource("QRY_CFG"));
	CHLCFG=new NomadXML(Ctrl("main").getResource("QRY_CHILD"));

	//Modifico los Recursos
	ReplaceResource("QRY_IDS_OBJECT");
	ReplaceResource("QRY_IDS_PARENT");

	//Actualizo el Titulo
	if ((Ctrl("PAR"))&amp;&amp; (CFG.GetAttr("RESOURCE-PARENT")!="") &amp;&amp; (Ctrl("PARENT").GetXValue()!=""))
	{
		if (TIT==null)
			TIT=GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_IDS_PARENT"), '&lt;PARAM IDS="'+Ctrl("PARENT").GetXValue()+'"/&gt;');

		while(TIT!=null) 
		{
			if (TIT.GetAttr("descr")!="")
				Ctrl("PAR").SetXValue(" ("+TIT.GetAttr("descr")+")");
			TIT=TIT.FirstChild();
		}
	}

	if ((Ctrl("OBJ"))&amp;&amp; (CFG.GetAttr("RESOURCE-OBJECT")!="") &amp;&amp; (Ctrl("ID").GetXValue()!=""))
	{
		if (T2T==null)
			T2T=GetProxy().SQLService().GetXML(Ctrl("main").getResource("QRY_IDS_OBJECT"), '&lt;PARAM IDS="'+Ctrl("ID").GetXValue()+'"/&gt;');

		while(T2T!=null) 
		{
			if (T2T.GetAttr("descr")!="")
				Ctrl("OBJ").SetXValue(" '"+T2T.GetAttr("descr")+"'");
			T2T=T2T.FirstChild();
		}
	}
}

function ReplaceResource(recID)
{
	var recValue=Ctrl("main").getResource(recID);
	recValue=Replace(recValue,"#RESOURCE-PARENT#",CFG.GetAttr("RESOURCE-PARENT"));
	recValue=Replace(recValue,"#RESOURCE-OBJECT#",CFG.GetAttr("RESOURCE-OBJECT"  ));

	Ctrl("main").setResource(recValue, recID);
}

function DependCall(obj)
{
  var flowId=CHLCFG.FindElement2("CHILD","name",obj.ID()).GetAttr("flow");
  var flag  =CHLCFG.FindElement2("CHILD","name",obj.ID()).GetAttr("flag");

  if (flowId.indexOf(":")&gt;=0)
    appendFormInMain(flowId.split(":")[0], flowId.split(":")[1], '&lt;DATA PARENT="'+Ctrl("ID").GetXValue()+'" GRAND="'+Ctrl("PARENT").GetXValue()+'" /&gt;');
  else
    appendFormInMain(flowId              , "LIST"              , '&lt;DATA PARENT="'+Ctrl("ID").GetXValue()+'" GRAND="'+Ctrl("PARENT").GetXValue()+'" /&gt;');
}

function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}

function ClearCLASIF()
{
	Ctrl("CLASIF").DelAllRow();
	Ctrl("Clasificaciones").Refresh();
}

function FullCLASIF()
{
	Ctrl("CLASIF").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Clasificaciones").TotalRowsCount(); t++)
		Ctrl("CLASIF").AddRow().SetAttr("id", Ctrl("Clasificaciones").GetAttrValue(t, "id"));
	
	Ctrl("Clasificaciones").Refresh();
}
	</form:Scripts>
	<form:Scripts/>
	<form:Resources>
		<form:Resource declare="" name="QRY_IDS_OBJECT">
			<qry:include name="#RESOURCE-OBJECT#"/>
			<qry:main maxdeep="2" doc="PARAMIN">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAMIN:/PARAM"/>
				</qry:element>
			</qry:main>
		</form:Resource>
		<form:Resource declare="" name="QRY_IDS_PARENT">
			<qry:include name="#RESOURCE-PARENT#"/>
			<qry:main maxdeep="2" doc="PARAMIN">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAMIN:/PARAM"/>
				</qry:element>
			</qry:main>
		</form:Resource>
		<form:Resource name="QRY_CFG">
			<CFG resource-object="" resource-parent=""/>
		</form:Resource>
		<form:Resource name="QRY_CHILD">
			<CFG/>
		</form:Resource>
	</form:Resources>
	<form:Event action="ONLOAD_custom" name="OnLoad" runat="client"/>
</form:Form>
