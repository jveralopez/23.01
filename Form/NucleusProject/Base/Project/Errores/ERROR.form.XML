<form:Form xmlns:form="nomad_engine.form" extends="NucleusProject.Base.Project.Errores.ERROR.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusProject.Base.Project.Errores.ERROR">
	<form:Help>
		<form:Help-title text="Errores" name="TITLE"/>
		<form:Help-descr name="DESCR"/>
		<form:Help-note name="NOTE"/>
	</form:Help>
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Crear Errores chueka" nowrap="1" align="center" visible="NEW" style="S3 LCol_w" name="GEN_NEW"/>
				<form:Label nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" label="Modificar Errores" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Errores" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Errores" name="GEN_SHOW"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsERROR">
			<form:Column name="main_columnsERRORcolumn1">
				<form:TextBox required="1" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="Codigo" nvalue="#source:@c_error" name="c_error"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="50" length="100" label="Nombre" nvalue="#source:@d_nombre" name="d_nombre"/>
				<form:ComboBox xsize="40" mode="OPT" required="1" enabled="NEW|EDIT" label="Requiere fecha de vencimiento" nvalue="#source:@c_req_venc" name="c_req_venc">
					<options>
						<option text="No" value="1"/>
						<option text="Si" value="2"/>
					</options>
				</form:ComboBox>
				<form:NumberBox required="0" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" label="Cantidad de d&#237;as para vencer" nvalue="#source:@e_dias_venc" name="e_dias_venc"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observacion" nvalue="#source:@o_error" name="o_error"/>
			</form:Column>
		</form:Columns>
		<form:Blank visible="LIST|LIST_EDIT" name="blank_rowList"/>
		<form:ListView visible="LIST|LIST_EDIT" paging="1" rows="-250" docname="RS" name="LIST">
			<form:Event action="ListClick" name="OnClick" runat="client"/>
			<form:Event runat="client" action="ListDobleClick" name="OnDblClick"/>
			<form:LVColumns>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Codigo" attrname="c_error" name="c_error"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Nombre" attrname="d_nombre" name="d_nombre"/>
				<form:LVColumn additional="&lt;OPTS&gt;&lt;OPT value=&quot;1&quot; text=&quot;No&quot; /&gt;&lt;OPT value=&quot;2&quot; text=&quot;Si&quot; /&gt;&lt;/OPTS&gt;" align="left" sorteable="1" width="50px" type="enum" label="Requiere fecha de vencimiento" attrname="c_req_venc" name="c_req_venc"/>
				<form:LVColumn additional="###,###,##0" align="right" sorteable="1" width="50px" type="number" label="Cantidad de d&#237;as para vencer" attrname="e_dias_venc" name="e_dias_venc"/>
			</form:LVColumns>
		</form:ListView>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusProject/Base/Project/Errores/EDIT" visible="SHOW|LIST" descrip="Modificar el Registro" img="edit" label="Modificar" name="EDIT">
					<form:Event action="EDIT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusProject/Base/Project/Errores/NEW" visible="SHOW|LIST" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button mess="&#191;Est&#225; seguro que desa eliminar el registro?" policy="NucleusProject/Base/Project/Errores/DELETE" visible="SHOW|LIST|EDIT|DELETE" descrip="Eliminar un Registro" img="del" label="Eliminar" name="DELETE">
					<form:Event action="DELETE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusProject/Base/Project/Errores/SECURITY" visible="SHOW|LIST" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Guardar los Cambios realizados para que queden persistentes." startvalidate="1" visible="NEW|EDIT" img="save" label="Guardar" name="SAVE" X-POLICY="./FORM/NucleusProject/Base/Project/Errores/ERROR/form/SAVE">
					<form:Event action="SAVE" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function SAVE()
{
	if((Ctrl('c_req_venc').GetCValue() == "Si") &amp;&amp; (Ctrl('e_dias_venc').GetXValue() == ""))
	{
		alert("Debe cargar la cantidad de d&#237;as de vencimiento.");
		return false;
	}
	else
		Ctrl('main').DoEvent("SAVE");
}
	</form:Scripts>
	<form:Event action="SAVE" name="SAVE" runat="server"/>
</form:Form>
