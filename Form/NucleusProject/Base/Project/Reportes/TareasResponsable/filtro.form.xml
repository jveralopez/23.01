	<form:Scripts>
		function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}  

function Accept()
{ 
	//Valido que ingrese el campo si ingresa un orden
	var cantFiltros = 3;
	for (var i=0; i&lt;cantFiltros; i++)
	{ 
		var b = i+1;
		if(Ctrl("ORDEN"+b).GetXValue()!="")
		{
			if (Ctrl("campo"+b).GetXValue()== "") 	
	 		{ 
	 			switch(b)
	 			{
	 			case 1:
	 				var label = "Primer";
	 				break; 
	 			case 2:
	 				var label = "Segundo";
	 				break;
	 			case 3: 
	 				var label = "Tercer";
	 				break;
	 			}
	 			alert("Debe ingresar el campo a ordenar en el "+label+" Criterio de Ordenamiento");
	 			return false;
	 		}	
		}
	}
	 
	//Valido que ingrese las definiciones anteriores 
	for (var i=2; i&lt;=cantFiltros; i++)
	{   
	
		if (Ctrl("campo"+i).GetXValue()!= "") 	
	 	{
	   	if (Ctrl("campo"+(i-1)).GetXValue()== "") 
	    {  
	    	switch((i-1))
	 			{
	 			case 1:
	 				var label = "Primer";
	 				break; 
	 			case 2:
	 				var label = "Segundo";
	 				break;
	 			}
	    	alert("Debe ingresar la definici&#243;n del "+label+" Criterio de Ordenamiento");
	    	return false;
	    }
	  }
	}	
	return true;	
}
	</form:Scripts>
</form:Form>
