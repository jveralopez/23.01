<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="Nomad.Base.Project.TareasResponsable" extends="Nomad.base.HTML_XLS.flow" default_action="initialize">
	<flow:info label="Flow para Nomad.Base.Project.TareasResponsable">
		Flow para Nomad.Base.Project.Project
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA>
				<EST/>
			</DATA>
		</doc:define>
		<doc:define name="EST">
			<ROWS>
				<ROW des="Inicializada" id="I"/>
				<ROW des="Trabajando" id="T"/>
				<ROW des="Pausada" id="P"/>
				<ROW des="Finalizada" id="F"/>
				<ROW des="Anulada" id="A"/>
				<ROW des="Derivada a Testing" id="D"/>
			</ROWS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.TareasResponsable.filtro.form" mode="FILTER" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusProject.Base.Project.Reportes.TareasResponsable.filtro.form" name="NucleusProject.Base.Project.Reportes.TareasResponsable.filtro.form:FILTER" mode="FILTER" doc="SOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusProject.Base.Project.TareasResponsable" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text="jprFILTERDATA" text-path="#FILTERDATA:"/>
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusProject.Base.Project.TareasResponsable.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="002 - Tareas Responsable" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusProject.Base.Project.TareasResponsable" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc doc-path="#EST:" attach-id="EST"/>
		</flow:action>
		<flow:action name="CANCEL">
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
	</flow:form>
</flow:flow>
