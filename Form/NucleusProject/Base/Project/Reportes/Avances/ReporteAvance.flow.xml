<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusProject.Base.Project.Reportes.Avances.ReporteAvance.flow" extends="Nomad.Base.flow">
	<flow:info label="Flow para Reporte de Avance"/>
	<flow:declare>
		<doc:define name="REPORTDOM"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="REPORT_AVANCE">
			<!--flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
	<flow:param value="NucleusRH.BaytonRH.Legales.Rendiciones.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
	<flow:param doc-path="#SOURCE:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
</flow:exec-method>
<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/-->
			<flow:log text="logRendicionReport" text-path="#SOURCE:"/>
			<flow:html-gen template-file="NucleusProject.Base.Project.Avance.rpt" ext="html" out-file-path="#REPORTDOM:@report" input-doc-path="#SOURCE:"/>
			<flow:open-form mode="REPORT-AVANCE" doc-path="#REPORTDOM:" form-class="Nomad.report.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="REPORT-AVANCE" form-class="Nomad.report.form" name="Nomad.report.form" doc="SOURCE">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
