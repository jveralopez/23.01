<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.report.flow" name="Nomad.Base.Project.Recibos">
	<flow:info label="Flow para Nomad.Base.Project.TareasDeUnProyecto">
		Flow para Nomad.Base.Project.Project
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA recurso="" f_desde="" f_hasta=""/>
		</doc:define>
		<doc:define name="EST">
			<ROWS>
				<ROW des="Inicializada" id="I"/>
				<ROW des="Trabajando" id="T"/>
				<ROW des="Pausada" id="P"/>
				<ROW des="Finalizada" id="F"/>
				<ROW des="Anulada" id="A"/>
				<ROW des="Derivada a Testing" id="D"/>
			</ROWS>
		</doc:define>
		<doc:define name="IDsel">
			<ROWS/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.filtro.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.filtro.form:EDIT" form-class="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.filtro.form" extends="Nomad.Base.Report.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusProject.Base.Project.TareasDeUnProyecto" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:log text="logFilterDataCarmen" text-path="#FILTERDATA:"/>
			<flow:log text="logIDSelCarmen" text-path="#IDsel:"/>
			<flow:exec-method class="NucleusProject.Base.Project.Proyectos.PROYECTO" method="REPORTE_TAREAS_PROYECTO">
				<flow:param doc="FILTERDATA" type="Nomad.NSystem.Proxy.NomadXML" mode="inout" name="pxmlFILTERDATA"/>
				<flow:param doc="IDsel" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlIDsel"/>
			</flow:exec-method>
			<flow:log text-path="#FILTERDATA:" text="logResultCamenMerge"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusProject.Base.Project.TareasDeUnProyecto.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusProject.Base.Project.TareasDeUnProyecto.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusProject.Base.Project.TareasDeUnProyecto" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<flow:attach-doc doc-path="#EST:" attach-id="EST"/>
			<flow:log text-path="#EST:" text="logonshow"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.form:REPORT" form-class="NucleusProject.Base.Project.Reportes.TareasDeUnProyecto.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
