<form:Form xmlns:form="nomad_engine.form" name="NucleusProject.Base.Project.Reportes.Parte.filtro.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="001 - Reporte Parte" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center>
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:DateTime nvalue="#FILTERDATA:@f_desde" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" label="Fecha Desde" name="f_desde">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:DateTime nvalue="#FILTERADATA:@f_hasta" pattern="YYYYMMDD" required="1" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_hasta">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:ComboBox nvalue="#FILTERDATA:@oi_recurso" label="Recurso" xsize="40" required="0" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" name="oi_recurso" mode="QRY"/>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="ACCEPT" label="Aceptar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario">
					<form:Event action="BACK" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
