<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" extends="Nomad.base.HTML_XLS.flow" name="NucleusProject.Base.Project.Reportes.Parte.flow" default_action="initialize">
	<flow:info label="Flow para NucleusProject.Base.Project.Reportes.Parte">
		Flow para Nomad.Base.Project.Project
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATOS oi_recurso="" f_desde="" f_hasta=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form mode="FILTER" form-class="NucleusProject.Base.Project.Reportes.Parte.filtro.form" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusProject.Base.Project.Reportes.Parte.filtro.form:FILTER" mode="FILTER" form-class="NucleusProject.Base.Project.Reportes.Parte.filtro.form" doc="SOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusProject.Base.Project.Reportes.Parte" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusProject.Base.Project.Reportes.Parte" doc="FILTERDATA"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusProject.Base.Project.Parte.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#FILTERDATA:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="001 - Parte" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
