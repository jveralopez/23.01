<form:Form xmlns:form="nomad_engine.form" xmlns:SPA="nomad_engine.SPA" mess="&#191;Est&#225; seguro que desea cancelar la operaci&#243;n?" name="NucleusProject.Base.Project.Reportes.TareasPriorizadas.filtro.form" default_mode="FILTER" extends="nomad.filter.form" doc="source">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="007 - Tareas Priorizadas de un Responsable" nowrap="1" align="center" style="S3 LCol_w" name="GEN_FILTER"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center name="raTit">
		<form:Blank name="bl3" width="100%" visible=""/>
		<form:ComboBox label="Responsable" xsize="40" required="1" nvalue="#source:@oi_recurso" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" name="oi_recurso" mode="QRY"/>
		<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
			<form:SButtons>
				<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
					<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:DateTime>
		<form:Blank name="sadfb"/>
		<form:ListView arr-control="EST" docname="EST" nvalue="#source:@selected" rows="6" width="300px" label="Estados" name="Estados">
			<form:LVColumns>
				<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Estado" name="des"/>
			</form:LVColumns>
			<form:SButtons>
				<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
					<form:Event action="FullEST" name="OnClick" runat="client"/>
				</form:SButton>
				<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
					<form:Event action="ClearEST" name="OnClick" runat="client"/>
				</form:SButton>
			</form:SButtons>
		</form:ListView>
		<form:HiddenArr nvalue="#source:EST" proto="&lt;C /&gt;" name="EST">
			<form:Attr name="id"/>
		</form:HiddenArr>
		<form:Line name="line_2" width="100%"/>
		<form:Label label="Contenido" style="M1 LCol_g" align="center" visible="" name="lbl211"/>
		<form:Blank name="bl4"/>
		<form:RowAligner name="rowalOrdenamiento">
			<form:Row name="ra1">
				<form:CheckBox nvalue="#source:@l_estado" SPA:label="Estado de la tarea" name="ckb_estado"/>
				<form:Blank width="30px" name="bl5"/>
				<form:CheckBox nvalue="#source:@l_horas_imputadas" SPA:label="Horas imputadas" name="ckb_hi"/>
			</form:Row>
			<form:Row name="ra2">
				<form:CheckBox nvalue="#source:@l_desc_tarea" name="ckb_desc_tarea" SPA:label="Descripci&#243;n de la tarea"/>
				<form:Blank width="15px" name="bl6"/>
				<form:CheckBox nvalue="#source:@l_desc_proy" SPA:label="Descripci&#243;n del proyecto" name="ckb_desc_proy"/>
			</form:Row>
			<form:Row name="ra3">
				<form:CheckBox nvalue="#source:@l_desc_cliente" name="ckb_desc_cliente" SPA:label="Descripci&#243;n del cliente"/>
			</form:Row>
		</form:RowAligner>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" X-POLICY="./FORM/NucleusProject/Base/Project/Reportes/TareasDeUnProyecto/filtro/form/FILTER">
					<form:Event action="LABORALES" runat="server" name="onclick"/>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" X-POLICY="./FORM/NucleusProject/Base/Project/Reportes/TareasDeUnProyecto/filtro/form/BACK">
					<form:Event action="CANCEL" runat="server" name="onclick"/>
				</form:Button>
				<form:Button name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" visible="EDIT" X-POLICY="./FORM/NucleusProject/Base/Project/Reportes/TareasDeUnProyecto/filtro/form/ADD">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}
	</form:Scripts>
</form:Form>
