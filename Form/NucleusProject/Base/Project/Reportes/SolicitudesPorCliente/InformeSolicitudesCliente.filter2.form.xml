<form:Form xmlns:form="nomad_engine.form" name="InformeSolcitudesCliente" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="101 - Horas trabajadas sobre Solicitudes de Clientes" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:ComboBox queryname1="NucleusProject.Base.Project.Clientes.CLIENTE.INFO" xsize="40" required="1" label="Cliente" nvalue="#source:@oi_cliente" name="oi_cliente" mode="QRY"/>
				<form:ListView nvalue="#source:@selected_clasif" arr-control="CLASIF" docname="CLASIF" label="Clasificaciones" name="Clasificaciones" rows="8" width="300px">
					<form:LVColumns>
						<form:LVColumn label="Clasificaci&#243;n" width="100%" attrname="des" type="string" sorteable="1" name="des"/>
					</form:LVColumns>
					<form:SButtons>
						<form:SButton name="Mark_clasif" img="table_check" descrip="Marcar los Elementos">
							<form:Event action="FullESTCLASIF" name="OnClick" runat="client"/>
						</form:SButton>
						<form:SButton name="UnMark_clasif" img="table_uncheck" descrip="Desmarcar los Elementos">
							<form:Event action="ClearESTCLASIF" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:ListView>
				<form:HiddenArr proto="&lt;ROW /&gt;" name="CLASIF" nvalue="#IdSel:">
					<form:Attr name="id"/>
				</form:HiddenArr>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Help/>
	<form:Scripts>
		function ClearESTCLASIF()
{
	Ctrl("CLASIF").DelAllRow();
	Ctrl("Clasificaciones").Refresh();
}

function FullESTCLASIF()
{
	Ctrl("CLASIF").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Clasificaciones").TotalRowsCount(); t++)
		Ctrl("CLASIF").AddRow().SetAttr("id", Ctrl("Clasificaciones").GetAttrValue(t, "id"));
	
	Ctrl("Clasificaciones").Refresh();
}
	</form:Scripts>
</form:Form>
