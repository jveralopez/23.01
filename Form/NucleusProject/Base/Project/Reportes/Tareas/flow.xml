<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="initialize" extends="Nomad.Base.report.flow" name="Nomad.Base.Project.Recibos">
	<flow:info label="Flow para Nomad.Base.Project.Tareas">
		Flow para Nomad.Base.Project.Project
	</flow:info>
	<flow:declare>
		<doc:define name="FILTERDATA">
			<DATA recurso="" f_desde="" f_hasta=""/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.Tareas.filtro.form" mode="EDIT" doc-path="#FILTERDATA:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusProject.Base.Project.Reportes.Tareas.filtro.form:EDIT" form-class="NucleusProject.Base.Project.Reportes.Tareas.filtro.form" extends="Nomad.Base.Report.filtro.form" mode="EDIT" doc="SOURCE">
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusProject.Base.Project.Tareas" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:call-action eq="HTML" if="#FILTERDATA:@salida" action="ACCEPTHTML"/>
			<flow:call-action eq="EXCEL" if="#FILTERDATA:@salida" action="ACCEPTEXCEL"/>
		</flow:action>
		<flow:action name="ACCEPTHTML">
			<flow:html-gen ext="html" input-doc-path="#FILTERDATA:" template-file="NucleusProject.Base.Project.Tareas.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.Tareas.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="ACCEPTEXCEL">
			<flow:html-gen ext="xls" input-doc-path="#FILTERDATA:" template-file="NucleusProject.Base.Project.Tareas.rpt" out-file-path="#FILTERDATA:@report"/>
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.Tareas.form" mode="REPORT" doc-path="#FILTERDATA:"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusProject.Base.Project.Tareas" doc="FILTERDATA"/>
		</flow:action>
	</flow:form>
	<flow:form name="NucleusProject.Base.Project.Reportes.Tareas.form:REPORT" form-class="NucleusProject.Base.Project.Reportes.Tareas.form" extends="Nomad.report.form:REPORT" mode="REPORT" doc="SOURCE"/>
</flow:flow>
