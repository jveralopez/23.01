<form:Form xmlns:form="nomad_engine.form" name="NucleusProject.Base.Project.Reportes.Trello.TarjetasRoberto.filter.form" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="ZZZ - Tarjetas por Tablero" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column valign="middle" align="center" name="col43">
				<form:HTMLPaste name="htmlD">
					<table>
						<tr>
							<td>
								<DIV class="M1 LCol_t LLines" name="formato">
									Reporte que lista todas las tarjetas de los tableros y columnas especificadas
								</DIV>
							</td>
						</tr>
					</table>
				</form:HTMLPaste>
				<form:Blank name="blnk1"/>
				<form:TextBox xsize="50" label="App-Key Trello" name="key" nvalue="#source:@key" required="1"/>
				<form:TextBox xsize="50" required="1" label="Token Trello" name="token" nvalue="#source:@token"/>
				<form:Rower label="Tableros" separation="5" name="rwtableroList">
					<form:TextBox label="Tableros" nvalue="#source:@listtableros" name="listtableros" length="200" required="1" xsize="50"/>
					<form:Label name="lbl_tableros" label="Nombre de los tableros separados por ';'"/>
				</form:Rower>
				<form:Rower label="Columnas" separation="5" name="rwcolumnaList">
					<form:TextBox label="Columnas" nvalue="#source:@listcolumnas" name="listcolumnas" length="200" required="0" xsize="50"/>
					<form:Label name="lbl_columnas" label="Nombre de las columnas separadas por ';'"/>
				</form:Rower>
				<form:CheckBox visible="0" label="Mostrar descripci&#243;n" name="detalle" nvalue="#source:@detalle"/>
				<form:CheckBox label="Incluir archivadas" name="archivadas" nvalue="#source:@archivadas"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
