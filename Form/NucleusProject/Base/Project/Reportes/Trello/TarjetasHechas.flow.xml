<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusProject.Base.Project.Reportes.Trello.TarjetasHechas.flow" default_action="initialize" extends="Nomad.base.HTML_XLS.flow">
	<flow:info label="Tarjetas Hechas Trello flow"/>
	<flow:declare>
		<doc:define name="DOC">
			<DATOS/>
			<!--<ROWS/>
	</DATOS>    -->
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.Trello.TarjetasHechas.filter.form" mode="FILTER" doc-path="#DOC:"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusProject.Base.Project.Reportes.Trello.TarjetasHechas.filter.form" name="NucleusProject.Base.Project.Reportes.Trello.TarjetasHechas.filter.form.form:FILTER" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method priority="9" out-attr-path="#BATCHDOC:@batch-id" method="ReporteTarjetasHechas" class="NucleusProject.Base.Project.Tareas.TAREA">
				<flow:param doc="DOC" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="pxmlDOC"/>
			</flow:exec-method>
			<flow:log text-path="#DOC:" text="facuDDO"/>
			<!--<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
	<flow:param value="NucleusProject.Base.Project.TarjetasPorRecurso.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
	<flow:param doc-path="#DOC:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
</flow:exec-method>-->
			<doc:set-attribute from-value="YYY - Tarjetas Hechas" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data name="FILTER-NucleusProject.Base.Project.Trello.TarjetasHechas" doc-path="#DOC:"/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data name="FILTER-NucleusProject.Base.Project.Trello.TarjetasHechas" doc="DOC"/>
		</flow:action>
		<flow:action name="on-open">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
			<!--<doc:load-qry output-doc="CLASIF" qry="GetClasificaciones"/>
	<flow:attach-doc doc-path="#CLASIF:" attach-id="CLASIF"/>-->
		</flow:action>
	</flow:form>
</flow:flow>
