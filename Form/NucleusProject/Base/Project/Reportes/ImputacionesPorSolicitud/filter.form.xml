<form:Form xmlns:form="nomad_engine.form" name="InformeImputacionesPorSolicitudes" default_mode="FILTER" doc="source">
	<form:Title>
		<form:Label label="102 - Imputaciones por Solicitudes" name="lbl" align="center" style="S3 LCol_w" visible=""/>
	</form:Title>
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col43">
				<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="1" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:CheckBox label="Vista Detallada" required="1" name="l_detalle" nvalue="#source:@l_detalle"/>
				<form:Grid idvalue="#SOURCE:@id" nvalue="#source:CLIENTES" proto="&lt;CLIENTE/&gt;" width="400px" doc="SOURCE" enabled="" paging="1" allowdel="1" allownew="1" allowdelall="1" allowhelper="0" rows="3" descrip="" note="" name="grdDatosCli">
					<form:GColumns>
						<form:GColumn allow_order="0">
							<form:ComboBox queryname1="NucleusProject.Base.Project.Clientes.CLIENTE.INFO" xsize="37" required="1" label="Cliente" nvalue="#SOURCE:@id" name="oi_cliente" mode="QRY"/>
						</form:GColumn>
					</form:GColumns>
				</form:Grid>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner visible="FILTER" name="buttons2">
			<form:Row name="row_top2">
				<form:Button enabled="" visible="" name="btnAceptar" label="Aceptar" note="" descrip="Generar Reporte" img="ok" startvalidate="1">
					<form:Event action="ACCEPT" name="onclick" runat="client"/>
					<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
				</form:Button>
				<form:Button enabled="" name="btnCancelar" label="Volver" img="back" note="Vuelve a la pantalla anterior" descrip="Vuelve al menu principal sin ejecutar el formulario">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Help/>
	<form:Scripts>
		function ACCEPT()
{
    if(Ctrl('grdDatosCli').RowsCount() == 0)
    {
        alert('Debe seleccionar al menos un cliente'); 
        return false;
    }   
	else
	{
		for(i = 0; i&lt;Ctrl('grdDatosCli').RowsCount();i++)
		{
			 if(Ctrl('grdDatosCli').GetCellXValue('oi_cliente',i)=='')
			 {
			 	alert('Debe seleccionar al menos un cliente y no debe haber filas vacias');
			 	return false;
			 } 
		}
	}    
	
	Ctrl('btnAceptar').DoEvent('ACCEPT');
}
	</form:Scripts>
</form:Form>
