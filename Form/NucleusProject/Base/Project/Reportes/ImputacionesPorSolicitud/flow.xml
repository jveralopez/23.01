<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" name="NucleusProject.Base.Project.Reportes.ImputacionesPorSolicitudes" default_action="initialize" extends="Nomad.base.HTML_XLS.flow">
	<flow:info label="why"/>
	<flow:declare>
		<doc:define name="DOC">
			<DATOS>
				<ROWS/>
				<CLIENTES/>
			</DATOS>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Reportes.ImputacionesPorSolicitud.filter.form" mode="FILTER" doc-path="#DOC:"/>
		</flow:action>
	</flow:main>
	<flow:form name="NucleusProject.Base.Project.Reportes.ImputacionesPorSolicitud.filter.form:FILTER" form-class="NucleusProject.Base.Project.Reportes.ImputacionesPorSolicitud.filter.form" doc="SOURCE" mode="FILTER">
		<flow:action name="ACCEPT">
			<flow:log text="javier" text-path="#DOC:"/>
			<flow:exec-method method="ExecReportHTML" out-attr-path="#BATCHDOC:@batch-id" priority="9" class="Nomad.Base.Report.GeneralReport.REPORT">
				<flow:param value="NucleusProject.Base.Project.ImputacionesPorSolicitud.rpt" type="Nomad.NSystem.String" mode="in" name="ReportName"/>
				<flow:param doc-path="#DOC:" name="paramIN" type="Nomad.NSystem.Proxy.NomadXML" mode="in"/>
			</flow:exec-method>
			<doc:set-attribute from-value="102 - Imputaciones por Solicitudes" to-attr-path="#BATCHDOC:@title"/>
			<flow:open-form form-class="Nomad.base.HTML_XLS.form" parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
	</flow:form>
</flow:flow>
