<form:Form xmlns:form="nomad_engine.form" default_mode="SHOW" name="NucleusProject.Base.Project.Tareas.TAREA_MAIN.form" extends="NucleusProject.Base.Project.Tareas.TAREA.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
	<form:Center width="95%">
		<form:RowAligner visible="0" name="buttonlinks"/>
		<form:Blank name="blank_iter01"/>
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsTAREA">
			<form:Column name="main_columnsTAREAcolumn1">
				<form:ComboBox enabled="EDIT" xsize="40" queryname1="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO" mode="QRY" required="1" label="Proyecto" nvalue="#source:oi_proyecto/@value" name="oi_proyecto"/>
				<form:ComboBox xsize="40" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" mode="QRY" required="1" enabled="0" label="Recurso Asignado" nvalue="#source:oi_recurso/@value" name="oi_recurso"/>
				<form:DateTime pattern="YYYYMMDDHHMM" visible="SHOW" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Inicio" nvalue="#source:@f_inicio" name="f_inicio">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime pattern="YYYYMMDDHHMM" visible="SHOW" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Fin" nvalue="#source:@f_fin" name="f_fin">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime visible="0" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha Inicio Estimada" nvalue="#source:@f_inicio_est" name="f_inicio_est">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime visible="0" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy" label="Fecha Fin Estimada" nvalue="#source:@f_fin_est" name="f_fin_est">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Rower separation="5" name="e_estimado" label="Tiempo Estimado">
					<form:NumberBox name="e_estimado_aux" required="1" enabled="NEW|EDIT" mask="###.###.##0" xsize="12" nvalue="#source:@e_estimado"/>
					<form:ComboBox name="oi_unidad_tiempo_aux" queryname1="NucleusProject.Base.Project.UnidadesTiempo.UNIDAD_TIEMPO.INFO" xsize="20" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#source:oi_unidad_tiempo/@value"/>
				</form:Rower>
				<form:ComboBox visible="0" name="oi_unidad_tiempo" queryname1="NucleusProject.Base.Project.UnidadesTiempo.UNIDAD_TIEMPO.INFO" xsize="20" mode="QRY" required="1" enabled="NEW|EDIT" nvalue="#source:oi_unidad_tiempo/@value"/>
				<form:ComboBox xsize="40" mode="OPT" required="1" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado">
					<options>
						<option text="Inicializada" value="I"/>
						<option text="Asignar Personas" value="AP"/>
						<option text="Trabajando" value="T"/>
						<option text="Pausada" value="P"/>
						<option text="Finalizada" value="F"/>
						<option text="Anulada" value="A"/>
						<option text="Bloqueada" value="L"/>
						<option text="Derivada a Testing" value="D"/>
					</options>
				</form:ComboBox>
				<form:Wiki rheight="120px" rwidth="700px" mail-mode="S" share-mode="N" form-mode="N" flow-mode="N" window-mode="N" goto-mode="O" borderwidth="1" required="0" nvalue="#source:@o_tarea" enabled="NEW|EDIT" descrip="Detalle de la Tarea" label="Detalle" name="o_tarea">
					<form:SButtons>
						<form:SButton descrip="Imprimir" name="PRINT" img="PRINT">
							<form:Event action="Print" name="onclick" runat="object"/>
						</form:SButton>
						<form:SButton name="EDIT" img="EDIT" descrip="Modificar">
							<form:Event name="onclick" action="Edit" runat="object"/>
						</form:SButton>
					</form:SButtons>
				</form:Wiki>
				<form:TextBox visible="0" required="0" ysize="3" xsize="50" length="1000" label="Observaci&#243;n Tarea" nvalue="#source:@o_tarea" name="o_tarea"/>
				<form:TextBox label="Motivo de finalizaci&#243;n / anulaci&#243;n" nvalue="#source:@o_motivo" name="o_motivo" required="0" ysize="3" xsize="50" length="1000"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button policy="NucleusProject/Base/Project/Tareas/NEW" visible="0" descrip="Agregar un Registro" img="new" label="Agregar" name="ADD">
					<form:Event action="ADD" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="0" descrip="Duplica el Registro Seleccionado." img="duplicate" label="Duplicar" name="DUPLICAR">
					<form:Event action="DUP" name="onclick" runat="server"/>
				</form:Button>
				<form:Button policy="NucleusProject/Base/Project/Tareas/SECURITY" visible="0" descrip="Propiedades del Registro" img="lock" label="Seguridad" name="ADMIN">
					<form:Event action="ADMIN" name="onclick" runat="server"/>
				</form:Button>
				<form:Blank width="30px" name="sep1"/>
				<form:Button img="status_gre" visible="SHOW" descrip="Iniciar el Trabajo" label="Activar" name="WORK">
					<form:Event action="WORK" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="status_gre" visible="SHOW" descrip="Asignar el Trabajo" label="Asignar" name="ASIGN">
					<form:Event action="ASIGN" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="status_red" visible="SHOW" descrip="Detener el Trabajo" label="Detener" name="PAUSE">
					<form:Event action="PAUSE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button visible="SHOW" descrip="Iniciar el Trabajo" img="ok" label="Finalizar" name="FINALIZE">
					<form:Event action="FINALIZE" name="onclick" runat="server"/>
				</form:Button>
				<form:Button img="cancel" visible="SHOW" descrip="Iniciar el Trabajo" label="Anular" name="ANULE">
					<form:Event action="ANULE" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function OnLoad()
{
	switch(Ctrl("c_estado").GetXValue())
	{
		case "I":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,true);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break
		
		case "T":
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,(Ctrl("l_simul").GetXValue()=="1"?false:true));
			CtrlEnabled("PAUSE"   ,true);
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "P":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "F":
		case "A":
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
		
		default:
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,true );
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
	}
}
	</form:Scripts>
	<form:Event action="OnLoad" name="OnLoad" runat="client"/>
	<form:Right visible="0" width="200px"/>
</form:Form>
