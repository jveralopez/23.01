function Save()
{  
  
	if(Ctrl("f_fin_est").GetXValue() != "")
 	{
 		if(Ctrl("f_inicio").GetXValue() &gt; Ctrl("f_fin_est").GetXValue())
 		{   
 				alert("La fecha de inicio debe ser igual o anterior a la fecha de fin estimada"); 
 		  	return false;
 		}
 	} 
 	
 	if(Ctrl('main').GetMode() == "TRELLO" || (Ctrl('main').GetMode() == "NEW" &amp;&amp; Ctrl("l_trello").GetXValue()=="1"))
 	{
 		if(Ctrl("d_tarea_trello").GetXValue()=="")
 		{   
 				alert("La descripci&#243;n de la tarjeta es requerido"); 
 				Ctrl("d_tarea_trello").SetFocus();
 		  	return false;
 		}
 		
 		if(Ctrl("id_columna_trello").GetXValue()=="")
 		{   
 				alert("La columna es requerida");
 				Ctrl("id_columna_trello").SetFocus(); 
 		  	return false;
 		}
 	}
 	
 	return true; 
}   
    
//copiada de form BaseForms.iter (nombre real:iter_Show.form.xml)  para poder buscar tareas dentro de la lista    
function Find()
{
	Ctrl("LIST").filter("",Ctrl("iter_search").GetCValue());
}

function PanelTrello()
{
	if(Ctrl("cont").GetXValue()&gt;0)
	{
		if(Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility!="")
	 	{
	 		Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = ""; 		 		
	 		SetearValores();
	 	} 		
	 	else
	 	{
	 		Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = "hidden";
	 		Ctrl("d_tarea_trello").SetXValue("");
	 		Ctrl("f_fin_trello").SetXValue("");
	 		Ctrl("oi_recurso_trello").SetXValue("");
	 		Ctrl("o_tarea_trello").SetXValue("");
	 		
	 	}	
	}
	else
	{
		alert("No pertenece a ning&#250;n equipo de Trello.");
		Ctrl("l_trello").SetXValue(false);
	}
}  

function ActualizarNombreTarjeta()
{	
	if(Ctrl('main').GetMode() == "NEW" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
	{
		var name = "";
		name += Ctrl("c_tarea").GetCValue();
		if(name!="")
			name += " - ";
		name += Ctrl("d_tarea").GetCValue();
		
		Ctrl("d_tarea_trello").SetXValue(name);
	}
}

function SetearValores()
{
	ActualizarNombreTarjeta();	
	Ctrl("o_tarea_trello").SetXValue(Ctrl("o_tarea").GetXValue());
	Ctrl("oi_recurso_trello").SetXValue(Ctrl("oi_recurso").GetXValue());
	Ctrl("f_fin_trello").SetXValue(Ctrl("f_fin_est").GetXValue());	
}

function ActualizarDescripcionTrello()
{  	
	if(Ctrl('main').GetMode() == "NEW" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
	{
		Ctrl("o_tarea_trello").SetXValue(Ctrl("o_tarea").GetXValue());
	}	
}

function ActualizarRecursoTrello()
{	
	if(Ctrl('main').GetMode() == "NEW" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
	{
		Ctrl("oi_recurso_trello").SetXValue(Ctrl("oi_recurso").GetXValue());
	}	
}

function ActualizarFechaTrello()
{	
	if(Ctrl('main').GetMode() == "NEW" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
	{
		Ctrl("f_fin_trello").SetXValue(Ctrl("f_fin_est").GetXValue());
	}	
}

function TRELLO()
{  
	var MySQL = GetDatosTrello();	
	
	if(MySQL.GetAttr("D_ENLACE")=='0')
	{
		if (Ctrl("LIST")!=null)
		{ 
			openNewFlow("NucleusProject.Base.Project.Tareas.MAIN.flow","TRELLO",'&lt;DATA id="'+Ctrl("LIST").GetXValue()+'" oi_tarea="'+Ctrl("LIST").GetXValue()+'" /&gt;',"","L");	
		}
		else
		{
		  //Ctrl("oi_tarea").GetXValue()
		  openNewFlow("NucleusProject.Base.Project.Tareas.MAIN.flow","TRELLO",'&lt;DATA id="'+Ctrl("oi_tarea").GetXValue()+'" oi_tarea="'+Ctrl("oi_tarea").GetXValue()+'" /&gt;',"","L");		  
		}
	} 
	else
	{
		alert("La Tarea ya tiene una Tarjeta vinculada.");
		
		if(MySQL.GetAttr("C_EXTERNO")=='0')
			CtrlEnabled("TRELLO" 	,true);
		else
			CtrlEnabled("TRELLO" 	,false);
		 	
		if(MySQL.GetAttr("D_ENLACE")=='0')
			CtrlEnabled("SHOWTRELLO" 	,false);
		else
			CtrlEnabled("SHOWTRELLO" 	,true);	
	}

	
	
}   

function SHOWTRELLO()
{  
	var MySQL = GetDatosTrello();	
	
	if(MySQL.GetAttr("D_ENLACE")=='0')
		alert("La Tarea no est&#225; vinculada con ninguna Tarjeta en Trello.");
	else
		{
		   window.open("https://trello.com/c/"+MySQL.GetAttr("D_ENLACE"));
		   return;
		}
	
}
