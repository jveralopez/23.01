function OnLoad()
{          
	var c_estado; 
	 
  if(Ctrl('main').GetMode() == "NEW")
  {   	 
  	 //VGroupChangeStyle(Ctrl("groupDatosTarjeta"), "collapsed");
  	 Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = "hidden";
  }
	
	//Seteo la fecha de hoy por defecto 
	if(Ctrl('main').GetMode() == "NEW")
	{  
	 Ctrl('f_inicio').SetTypedValue(new Date());
	}
	
	if (Ctrl("LIST")!=null) c_estado=Ctrl("LIST").GetSelectAttrValue("c_estado"); 
	                   else c_estado=Ctrl("c_estado").GetXValue();
	                       
	switch(c_estado)
	{
		case "I":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,true);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
		
		case "T":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,true);
			CtrlEnabled("PARATEST",true);
			CtrlEnabled("PAUSE"   ,true);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,true);
		break;   
		
		case "D":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,true);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,true);
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "P":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "F":
		case "A":
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
		
		default:
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,true );
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
	}
	
	if(Ctrl('main').GetMode() == "LIST" || Ctrl('main').GetMode() == "SHOW") 
	{
		var MySQL = GetDatosTrello();	
	
		if(MySQL.GetAttr("C_EXTERNO")=='0')
			CtrlEnabled("TRELLO" 	,true);
		else
			CtrlEnabled("TRELLO" 	,false);
		 	
		if(MySQL.GetAttr("D_ENLACE")=='0')
			CtrlEnabled("SHOWTRELLO" 	,false);
		else
			CtrlEnabled("SHOWTRELLO" 	,true);		
	}
} 

function GetDatosTrello()
{
	if (Ctrl("LIST")!=null)
	{
		MySQL=GetProxy().SQLService().GetXML(Ctrl("main").getResource("qry_tarea_trello"), '&lt;DATA ID="'+Ctrl("LIST").GetXValue()+'" /&gt;');
	}
	else
	{
	  //Ctrl("oi_tarea").GetXValue()
	  MySQL=GetProxy().SQLService().GetXML(Ctrl("main").getResource("qry_tarea_trello"), '&lt;DATA ID="'+Ctrl("oi_tarea").GetXValue()+'" /&gt;');
	}
	
	return MySQL;
}

