			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					IIFISNULL(T.c_externo,0) as c_externo,
					IIFISNULL(T.D_ENLACE,0) as D_ENLACE
				FROM 
					PRY02_TAREAS as T
				WHERE
					T.oi_tarea={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@c_externo=''">
						<qry:then>
							<qry:attribute value="'0'" name="c_externo"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@c_externo" name="c_externo"/>
						</qry:else>
					</qry:if>
					<qry:if test="$r/@D_ENLACE=''">
						<qry:then>
							<qry:attribute value="'0'" name="D_ENLACE"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@D_ENLACE" name="D_ENLACE"/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
</form:Form>
