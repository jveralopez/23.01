<flow:flow xmlns:flow="nomad_engine.flow" extends="Nomad.Base.flow" name="NucleusProject.Base.Project.Tareas.Trello.ARCHIVAR.flow" default_action="initialize">
	<flow:info label="Flow para Archivar Tarjetas"/>
	<flow:declare/>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form form-class="NucleusProject.Base.Project.Tareas.Trello.ARCHIVAR.form" doc-path="#FILTERDATA:" mode="FILTER"/>
		</flow:action>
	</flow:main>
	<flow:form form-class="NucleusProject.Base.Project.Tareas.Trello.ARCHIVAR.form" name="NucleusProject.Base.Project.Tareas.Trello.ARCHIVAR.form:FILTER" doc="SOURCE" parent-doc="PARENTSOURCE" mode="FILTER">
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:log text-path="#SOURCE:" text="facuLog"/>
			<flow:exec-method class="NucleusProject.Base.Project.Tareas.TAREA" method="ArchivarTareas" out-attr-path="#BATCHDOC:@batch-id" priority="5"/>
			<flow:open-form form-class="nomad.base.batchtolist.form" mode="BATCH" doc-path="#BATCHDOC:"/>
		</flow:action>
	</flow:form>
</flow:flow>
