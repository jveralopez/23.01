function Save()
{  
  
	if(Ctrl("f_fin_est").GetXValue() != "")
 	{
 		if(Ctrl("f_inicio").GetXValue() &gt; Ctrl("f_fin_est").GetXValue())
 			{   
 				alert("La fecha de inicio debe ser igual o anterior a la fecha de fin estimada"); 
 		  	return false;
 			}
 	} 
 	return true; 
}   
    
