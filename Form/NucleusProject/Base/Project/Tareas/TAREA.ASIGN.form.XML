function OnLoad()
{          
	var c_estado; 
	
	
	
		
	//Seteo la fecha de hoy por defecto 
	if(Ctrl('main').GetMode() == "NEW")
	{  
	 Ctrl('f_inicio').SetTypedValue(new Date());
	}
	
	if(Ctrl('main').GetMode() != "TRELLO")
	{
		if (Ctrl("LIST")!=null) c_estado=Ctrl("LIST").GetSelectAttrValue("c_estado"); 
	                   else c_estado=Ctrl("c_estado").GetXValue();
	}	
	                       
	switch(c_estado)
	{
		case "I":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,true);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
		
		case "T":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,true);
			CtrlEnabled("PARATEST",true);
			CtrlEnabled("PAUSE"   ,true);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,true);
		break;   
		
		case "D":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,true);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,true);
			CtrlEnabled("FINALIZE",true);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "P":
			CtrlEnabled("EDIT"    ,true);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,true);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,true);
		break;

		case "F":
		case "A":
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,false);
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
		
		default:
			CtrlEnabled("EDIT"    ,false);
			CtrlEnabled("DELETE"  ,true );
			CtrlEnabled("WORK"    ,false);
			CtrlEnabled("ASIGN"   ,false);
			CtrlEnabled("PARATEST",false);
			CtrlEnabled("PAUSE"   ,false);
			CtrlEnabled("FINALIZE",false);
			CtrlEnabled("ANULE"   ,false);
		break;
	}
	
	if(Ctrl('main').GetMode() == "TRELLO")
	{		
  	if(!(Ctrl("cont").GetXValue()&gt;0))
  	{
			alert("No pertenece a ning&#250;n equipo de Trello");
	  	CtrlEnabled("TRELLO"    ,false);		
  	}
  	else
  	{
  	 	var d_tarea = "";
			
			d_tarea = Ctrl("c_tarea").GetXValue();
			if(d_tarea!="")
				d_tarea += " - ";
			d_tarea += Ctrl("d_tarea").GetXValue();
			
			Ctrl("d_tarea_trello").SetXValue(d_tarea);
			Ctrl("oi_recurso_trello").SetXValue(Ctrl("oi_recurso").GetXValue());
			Ctrl("f_fin_trello").SetXValue(Ctrl("f_fin").GetXValue());
			Ctrl("o_tarea_trello").SetXValue(Ctrl("o_tarea").GetXValue());
  	}
	}	
		
}

