<form:Form default_mode="COPY" name="NucleusProject.Base.Project.Tareas.TAREA_MAIN.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" xmlns:form="nomad_engine.form">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label label="Selecionar los Proyectos donde Copiar" nowrap="1" align="center" style="S3 LCol_w" name="TITLE"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner width="100%" visible="COPY" name="buttonlinks">
			<form:Row name="row_top">
				<form:Columns note="=== Iterador ===&#13;&#10;El [[wiki:Nomad.Generico.Iterador.wiki|iterador]] es una grupo de controles utizados para la navegacion entre los distintos registros filtrados." help-stop="1" width="100%" name="columns1">
					<form:Column width="100%" align="left" name="col1">
						<form:RowAligner name="rowsiter" align="left">
							<form:Row name="rowiter">
								<form:TextBox visible="COPY" xsize="50" length="100" name="iter_search" label="Buscar" ysize="1" descr="Busca.">
									<form:Event runat="client" name="onpressenter" action="Find"/>
									<form:SButtons>
										<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
											<form:Event runat="client" name="onclick" action="Find"/>
										</form:SButton>
									</form:SButtons>
								</form:TextBox>
							</form:Row>
						</form:RowAligner>
					</form:Column>
				</form:Columns>
			</form:Row>
		</form:RowAligner>
		<form:ListView arr-control="oi_proys" docname="RS" visible="COPY" paging="1" rows="-250" name="LIST">
			<form:LVColumns>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusProject.Base.Project.Proyectos.PROYECTO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Proyecto Padre" attrname="oi_proyecto_parent" name="oi_proyecto_parent"/>
				<form:LVColumn additional="&lt;combo action=&quot;COMBO&quot; flow=&quot;NucleusProject.Base.Project.TiposProyecto.TIPO_PROYECTO.Combo.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="combo" label="Tipo de Proyecto" attrname="oi_tipo_proyecto" name="oi_tipo_proyecto"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="C&#243;digo" attrname="c_proyecto" name="c_proyecto"/>
				<form:LVColumn align="left" sorteable="1" width="100px" type="string" label="Descripci&#243;n" attrname="d_proyecto" name="d_proyecto"/>
				<form:LVColumn additional="&lt;fk action=&quot;X2C&quot; flow=&quot;NucleusProject.Base.Project.Recursos.RECURSO.guia.autoflow&quot; /&gt;" align="left" sorteable="1" width="50px" type="fk" label="Lider de Proyecto" attrname="oi_recurso" name="oi_recurso"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Inicio Estimada" attrname="f_inicio_est" name="f_inicio_est"/>
				<form:LVColumn additional="dd/mm/yyyy" align="center" sorteable="1" width="50px" type="datetime" label="Fecha Fin Estimada" attrname="f_fin_est" name="f_fin_est"/>
			</form:LVColumns>
		</form:ListView>
		<form:HiddenArr nvalue="#source:" proto="&lt;ROW /&gt;" name="oi_proys">
			<form:Event action="Refresh" name="onpostadd" runat="client"/>
			<form:Event name="onpostdel" runat="client" action="Refresh"/>
			<form:Attr name="id"/>
		</form:HiddenArr>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button descrip="Duplicar" img="duplicate" label="Duplicar" name="DUPLICAR">
					<form:Event action="ACCEPT" name="onclick" runat="server"/>
				</form:Button>
				<form:Button descrip="Volver a la pantalla anterior." img="back" label="Volver" name="BACK">
					<form:Event action="BACK" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function Refresh()
{
	CtrlEnabled("DUPLICAR",Ctrl("oi_proys").CountRow()&gt;0?true:false);
}

	</form:Scripts>
	<form:Event action="Refresh" name="OnLoad" runat="client"/>
</form:Form>
