<form:Form xmlns:form="nomad_engine.form" default_mode="WORK" extends="nomad.childIter.form" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusProject.Base.Project.Tareas.TAREA_TRAZA">
	<form:Title width="90%">
		<form:RowAligner name="ralTitle">
			<form:Row name="row1">
				<form:Label nowrap="1" align="center" visible="NEW" style="S3 LCol_w" label="Crear Tareas Traza" name="GEN_NEW"/>
				<form:Label label="Tareas Traza de Trabajo" nowrap="1" align="center" visible="EDIT" style="S3 LCol_w" name="GEN_EDIT"/>
				<form:Label nowrap="1" align="center" visible="DELETE" style="S3 LCol_w" label="Eliminar Tareas Traza" name="GEN_DEL"/>
				<form:Label nowrap="1" align="center" visible="SHOW|LIST|LIST_EDIT" style="S3 LCol_w" label="Consultar Tareas Traza" name="GEN_SHOW"/>
				<form:Label dynamic="1" nvalue="#PARENTSOURCE:../@descr" nowrap="1" align="right" style="S3 LCol_w" name="ti_01"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner name="buttonlinks">
			<form:Row name="row_top">
				<form:Button startvalidate="1" visible="SHOW|EDIT" name="ITERATOR_FIRST" label="" img="first" descrip="Primer Registro" note="Ir al primer Registro">
					<form:Event runat="server" name="onclick" action="ITER:FIRST"/>
				</form:Button>
				<form:Button startvalidate="1" visible="SHOW|EDIT" name="ITERATOR_PREV" label="" img="prev" descrip="Anterior Registro" note="Ir al Registro Anterior">
					<form:Event runat="server" name="onclick" action="ITER:PREV"/>
				</form:Button>
				<form:TextBox visible="SHOW|EDIT" enabled="0" name="iter-position" length="4" xsize="4" ysize="1" descr="Indica o setea la posicion." required="False">
					<form:Event runat="server" name="OnChange" action="ITER:MOVETO"/>
				</form:TextBox>
				<form:Button startvalidate="1" visible="SHOW|EDIT" name="ITERATOR_NEXT" label="" img="next" descrip="Proximo Registro" note="Ir al Registro Proximo">
					<form:Event runat="server" name="onclick" action="ITER:NEXT"/>
				</form:Button>
				<form:Button startvalidate="1" visible="SHOW|EDIT" name="ITERATOR_LAST" label="" img="last" descrip="Ultimo Registro" note="Ir al Ultimo Registro">
					<form:Event runat="server" name="onclick" action="ITER:LAST"/>
				</form:Button>
				<form:TextBox visible="SHOW|EDIT" name="iter-size" length="4" xsize="4" ysize="1" descr="Indica o setea el size." enabled="0" required="False"/>
				<form:Blank visible="LIST|LIST_EDIT" name="blank_rowtop1"/>
				<form:TextBox visible="LIST|LIST_EDIT" xsize="50" length="100" name="iter-search" label="Buscar" ysize="1" descr="Busca.">
					<form:Event runat="client" name="onpressenter" action="Find"/>
					<form:SButtons>
						<form:SButton name="Search" label="Buscar" img="search" descrip="Ejecuta la busqueda.">
							<form:Event runat="client" name="onclick" action="Find"/>
						</form:SButton>
					</form:SButtons>
				</form:TextBox>
				<form:Blank name="ITERATOR_BLANK" width="100%"/>
				<form:Button label="Imprimir" visible="LIST" descrip="Imprimir la pantalla de lista" img="print" name="PRINT">
					<form:Event action="Imprimir" name="onclick" runat="client"/>
				</form:Button>
				<form:Button startvalidate="1" label="Registro" enabled="LIST|LIST_EDIT" visible="SHOW|EDIT|LIST|LIST_EDIT" note="Duplicar el Registro de la Base de Datos" descrip="Muestra el registro seleccionado" img="binocular" name="MOSTRAR">
					<form:Event action="SHOW" name="onclick" runat="server"/>
				</form:Button>
				<form:Button startvalidate="1" visible="SHOW|EDIT|LIST|LIST_EDIT" enabled="SHOW|EDIT" img="properties" note="Duplicar el Registro de la Base de Datos" descrip="Duplicar el Registro de la Base de Datos" label="Lista" name="LISTA">
					<form:Event action="LIST" name="onclick" runat="server"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
		<form:Columns visible="SHOW|EDIT|DELETE|NEW" name="main_columnsTAREA_TRAZA">
			<form:Column name="main_columnsTAREA_TRAZAcolumn1">
				<form:Combo nvalue="#DDO:oi_proyecto/@value" action="COMBO" flow="NucleusProject.Base.Project.Proyectos.PROYECTO.Combo.autoflow" required="1" enabled="0" label="Proyecto" name="oi_proyecto"/>
				<form:TextBox nvalue="#DDO:@c_tarea" required="1" enabled="0" ysize="1" xsize="30" length="30" label="C&#243;digo Tarea" name="c_tarea"/>
				<form:TextBox nvalue="#DDO:@d_tarea" required="1" enabled="0" ysize="1" xsize="50" length="100" label="Descripci&#243;n Tarea" name="d_tarea"/>
				<form:Combo nvalue="#DDO:@c_tipo_tarea" action="COMBO" flow="NucleusProject.Base.Project.Tareas.TAREA.c_tipo_tarea.Combo.autoflow" required="1" enabled="0" label="Tipo Tarea" name="c_tipo_tarea"/>
				<form:DateTime nvalue="#DDO:@f_inicio" pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Inicio" name="f_inicio">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#DDO:@f_fin" pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Fin" name="f_fin">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:Combo action="COMBO" flow="NucleusProject.Base.Project.Tareas.TAREA.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado" nvalue="#DDO:@c_estado" name="c_estado"/>
				<form:DateTime nvalue="#DDO:@f_limite" pattern="YYYYMMDD" required="0" enabled="0" mask="dd/mm/yyyy" label="Fecha Limite" name="f_limite">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox nvalue="#DDO:@o_tarea" required="0" enabled="0" ysize="4" xsize="50" length="1000" label="Observaci&#243;n Tarea" name="o_tarea"/>
				<form:FKInput nvalue="#DDO:TAREAS_TRAZA/TAREA_TRAZA/pry_oi_recurso/@value" enabled="NEW|EDIT" label="Recurso a Asignar" required="0" xsize="15" length="30" name="pry_oi_recurso">
					<form:STexts>
						<form:SText xsize="50" name="txt1"/>
					</form:STexts>
					<form:Helper name="NucleusProject.Base.Project.Recursos.RECURSO_PROYECTO.guia.flow" help="HELP" x2c="X2C" c2x="C2X">
						<helper-mess text="{this.Text.1}" id="{this.XVal}" code="{this.CVal}" oi_proyecto="{oi_proyecto.ReadXValue}"/>
					</form:Helper>
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="SEARCH" label="Search" name="SEARCH">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:FKInput>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="1" xsize="30" length="30" label="Causa" nvalue="#source:@c_causa" name="c_causa"/>
				<form:TextBox required="0" enabled="NEW|EDIT" ysize="4" xsize="50" length="1000" label="Observaci&#243;n" nvalue="#source:@o_observacion" name="o_observacion"/>
				<form:Hidden name="oi_tarea" nvalue="#DDO:TAREAS_TRAZA/TAREA_TRAZA/@oi_tarea"/>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="ACCEPT"/>
				</form:Button>
				<form:Button visible="0" name="ADD" label="Agregar" img="new" descrip="Agregar un Registro" note="Agregar el Registro">
					<form:Event runat="server" name="onclick" action="ADD"/>
				</form:Button>
				<form:Button visible="0" mess="&#191;Est&#225; seguro que desae eliminar el registro?" name="DELETE" label="Eliminar" img="del" descrip="Eliminar el Registro" note="Eliminar el Registro">
					<form:Event runat="server" name="onclick" action="DELETE"/>
				</form:Button>
				<form:Button visible="0" name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" startvalidate="1">
					<form:Event runat="server" name="onclick" action="BACK"/>
				</form:Button>
				<form:Button visible="0" name="PARENT" label="Ir al Raiz" img="back" descrip="Volver a la pantalla Raiz" note="Vuelve a la pantalla raiz del formulario" startvalidate="1">
					<form:Event action="PARENT" runat="server" name="onclick"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
</form:Form>
