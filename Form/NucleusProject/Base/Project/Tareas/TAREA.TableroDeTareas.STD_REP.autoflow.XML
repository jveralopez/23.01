<flow:flow xmlns:flow="nomad_engine.flow" xmlns:doc="nomad_engine.doc" default_action="FILTER" name="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_REP.autoflow" extends="Nomad.Base.HTML_XLS.flow">
	<flow:info label="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_REP.autoflow"/>
	<flow:declare>
		<doc:define name="DATA">
			<DATA oi_proyecto=""/>
		</doc:define>
		<doc:define name="PARENT"/>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="FILTER">
			<doc:set-attribute from-attr-path="#SOURCE:@ID" to-attr-path="#DATA:@ID"/>
			<doc:set-attribute from-attr-path="#SOURCE:@PARENT" to-attr-path="#DATA:@PARENT"/>
			<flow:open-form mode="FILTER" parent-doc-path="#SOURCE:" doc-path="#DATA:" form-class="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.autoform"/>
		</flow:action>
		<flow:action name="EXECUTE">
			<flow:exec-method priority="6" out-attr-path="#BATCHDOC:@batch-id" class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML">
				<flow:param type="Nomad.NSystem.String" mode="in" name="ReportName" value="NucleusProject.Base.Project.PizarraScrumTarea.rpt"/>
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<flow:open-form parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:" form-class="Nomad.base.HTML_XLS.form"/>
		</flow:action>
	</flow:main>
	<flow:form mode="FILTER" parent-doc="PARENT" doc="SOURCE" form-class="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.autoform" name="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.autoform:FILTER">
		<flow:action name="on-show">
			<flow:call-action action="Load-FILTER"/>
		</flow:action>
		<flow:action name="BACK">
			<flow:close-form/>
		</flow:action>
		<flow:action name="Load-FILTER">
			<flow:load-user-data doc="DATA" name="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.filter"/>
		</flow:action>
		<flow:action name="Save-FILTER">
			<flow:save-user-data doc-path="#DATA:" name="NucleusProject.Base.Project.Tareas.TAREA.TableroDeTareas.STD_FIL.filter"/>
		</flow:action>
		<flow:action name="ACCEPT">
			<flow:call-action action="Save-FILTER"/>
			<flow:exec-method priority="6" out-attr-path="#BATCHDOC:@batch-id" class="Nomad.Base.Report.GeneralReport.REPORT" method="ExecReportHTML">
				<flow:param type="Nomad.NSystem.String" mode="in" name="ReportName" value="NucleusProject.Base.Project.PizarraScrumTarea.rpt"/>
				<flow:param doc-path="#SOURCE:" type="Nomad.NSystem.Proxy.NomadXML" mode="in" name="xmlParam"/>
			</flow:exec-method>
			<doc:set-attribute to-attr-path="#BATCHDOC:@title" from-value="Pizarra Scrum de Tareas"/>
			<flow:open-form parent-doc-path="#SOURCE:" mode="SHOW" doc-path="#BATCHDOC:" form-class="Nomad.base.HTML_XLS.form"/>
		</flow:action>
	</flow:form>
</flow:flow>
