			<form:Row name="row1">
				<form:Label visible="PAUSE" name="GEN_PAUSE" nowrap="1" align="center" style="S3 LCol_w" label="DETENER la Tarea"/>
				<form:Label nowrap="1" align="center" visible="WORK" style="S3 LCol_w" label="ACTIVAR la Tarea" name="GEN_WORK"/>
				<form:Label visible="FINALIZE" name="GEN_FINALIZE" nowrap="1" align="center" style="S3 LCol_w" label="FINALIZAR la Tarea"/>
				<form:Label name="GEN_ANULE" label="ANULAR la Tarea" nowrap="1" align="center" visible="ANULE" style="S3 LCol_w"/>
				<form:Label label="Reasignar la Tarea" visible="ASIGN" name="GEN_ASIGN" nowrap="1" align="center" style="S3 LCol_w"/>
				<form:Label label="Derivar la Tarea a Testing" visible="PARATEST" name="GEN_PARATEST" nowrap="1" align="center" style="S3 LCol_w"/>
			</form:Row>
		</form:RowAligner>
	</form:Title>
	<form:Center width="95%">
		<form:RowAligner visible="0" name="buttonlinks"/>
		<form:Blank name="blank_iter01"/>
		<form:Columns name="main_columnsTAREA">
			<form:Column name="main_columnsTAREAcolumn1">
				<form:ComboBox queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" xsize="40" mode="QRY" required="1" enabled="0" label="Recurso Cambio" nvalue="#source:oi_recurso/@value" name="oi_recurso"/>
				<form:ComboBox queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO_ACT" nvalue="#source:oi_recurso_asi/@value" label="Recurso Asignado" name="oi_recurso_asi" xsize="40" mode="QRY" required="1">
					<form:Event action="ActualizarRecursoTrello" name="onchange" runat="client"/>
				</form:ComboBox>
				<!--form:ComboBox queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" visible="WORK" name="oi_recurso_asi_work" nvalue="#source:oi_recurso_asi/@value" label="Recurso Asignado" xsize="40" mode="QRY" required="1"/-->
				<form:Hidden xsize="12" label="Tarea" nvalue="#PARENTSOURCE:@id" name="oi_tarea"/>
				<form:Combo visible="0" action="COMBO" flow="NucleusProject.Base.Project.Tareas.TAREA_TRAZA.c_estado.Combo.autoflow" required="1" enabled="0" label="Estado" nvalue="#source:@c_estado" name="c_estado"/>
				<form:DateTime pattern="YYYYMMDD" required="1" enabled="0" mask="dd/mm/yyyy" label="Fecha Tarea" nvalue="#source:@f_fecha_tarea" name="f_fecha_tarea">
					<form:SButtons>
						<form:SButton visible="EDIT|NEW" img="Calendar" label="Calendar" name="Calendar">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:NumberBox width="30" label="Prioridad" enabled="ASIGN" name="e_prioridad" required="0" nvalue="#DDO:@e_prioridad" length="30"/>
				<form:TextBox enabled="PAUSE|WORK|ASIGN|ANULE|FINALIZE" required="0" ysize="1" xsize="30" length="30" label="Causa" nvalue="#source:@c_causa" name="c_causa"/>
				<form:TextBox enabled="PAUSE|WORK|ASIGN|PARATEST|ANULE|FINALIZE" ysize="10" required="0" xsize="80" length="4000" label="Observaci&#243;n" nvalue="#source:@o_observacion" name="o_observacion"/>
				<form:TextBox nvalue="#PARENTSOURCE:@o_motivo" visible="ANULE|FINALIZE" ysize="10" label="Motivo de finalizaci&#243;n / anulaci&#243;n" required="1" xsize="80" length="1000" name="o_motivo"/>
				<form:CheckBox enabled="WORK" visible="WORK" name="l_trello" nvalue="#source:@l_trello" label="Crear tarjeta en Trello" required="0">
					<form:Event action="PanelTrello" name="onclick" runat="client"/>
				</form:CheckBox>
				<form:Line visible="WORK" name="line1"/>
				<form:VGroup enabled="WORK" visible="WORK" background="1" name="groupDatosTarjeta" width="100%" border="1" collapse="0" label="Datos tarjeta Trello">
					<form:Columns name="main_columnsTARJETA">
						<form:Column name="main_columnsTARJETAcolumn1">
							<form:TextBox enabled="WORK" nvalue="#TABLEROSTRELLO:@d_tarea_trello" xsize="70" length="100" label="Nombre tarjeta" name="d_tarea_trello" required="0" ysize="1"/>
							<form:ComboBox enabled="WORK" visible="WORK" nvalue="#TABLEROSTRELLO:@id_columna_trello" label="Tablero - Columna Trello" name="id_columna_trello" required="0" docname="tableros" xsize="66" mode="DOC">
								<options/>
							</form:ComboBox>
							<form:ComboBox enabled="WORK" visible="WORK" nvalue="#TABLEROSTRELLO:@oi_recurso_trello" name="oi_recurso_trello" label="Miembro Asignado" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO_ACT" xsize="66" mode="QRY" required="0"/>
							<form:DateTime visible="WORK" nvalue="#TABLEROSTRELLO:@f_fin_trello" label="Fecha Vencimiento" name="f_fin_trello" pattern="YYYYMMDD" required="0" mask="dd/mm/yyyy">
								<form:SButtons>
									<form:SButton visible="WORK" img="Calendar" label="Calendar" name="Calendar">
										<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
									</form:SButton>
								</form:SButtons>
							</form:DateTime>
							<form:Wiki enabled="WORK" nvalue="#TABLEROSTRELLO:@o_tarea_trello" width="100%" label="Descripci&#243;n tarjeta" descrip="Descripci&#243;n de la Tarjeta" name="o_tarea_trello" border="1" height="190px" rheight="120px" rwidth="700px" mail-mode="S" share-mode="N" form-mode="N" flow-mode="N" window-mode="N" goto-mode="O" borderwidth="1" required="0">
								<form:SButtons>
									<form:SButton descrip="Imprimir" name="PRINT" img="PRINT">
										<form:Event action="Print" name="onclick" runat="object"/>
									</form:SButton>
									<form:SButton name="EDIT" img="EDIT" descrip="Modificar">
										<form:Event name="onclick" action="Edit" runat="object"/>
									</form:SButton>
								</form:SButtons>
							</form:Wiki>
							<form:Hidden name="cont" nvalue="#TABLEROSTRELLO:@cont"/>
						</form:Column>
					</form:Columns>
				</form:VGroup>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button visible="PAUSE|WORK|ASIGN|PARATEST|ANULE|FINALIZE" name="ACCEPT" label="Aceptar" img="ok" descrip="Acepta la operacion" note="Acepta la operacion sobre el formulario" startvalidate="1">
					<form:Event action="SAVE" name="onclick" runat="client"/>
				</form:Button>
				<form:Button visible="PAUSE|WORK|ASIGN|PARATEST|ANULE|FINALIZE" name="CANCEL" label="Cancelar" img="cancel" descrip="Cancelar la operacion" note="Cancela la operacion sobre el formulario">
					<form:Event runat="server" name="onclick" action="CANCEL"/>
				</form:Button>
				<form:Button visible="WORK" img="binocular" name="SHOWTRELLO" descrip="Ver Tarjeta en Tablero Trello" label="Ver en Trello">
					<form:Event action="SHOWTRELLO" name="onclick" runat="client"/>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function OnLoad()
{          
	var c_estado; 
	 
	if(Ctrl('main').GetMode() == "WORK") 
	{  
		Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = "hidden";
	
		var MySQL = GetDatosTrello();	
			 	
		if(MySQL.GetAttr("D_ENLACE")=='0')
		{ 
		   Ctrl("SHOWTRELLO").m_HTMLObject.style.visibility = "hidden";
			//CtrlEnabled("SHOWTRELLO" 	,false);		 	
		} 			
		else
		{
			CtrlEnabled("SHOWTRELLO" 	,true);
			CtrlEnabled("l_trello" 	,false);		 	
		}
			
	}
} 

function GetDatosTrello()
{
	MySQL=GetProxy().SQLService().GetXML(Ctrl("main").getResource("qry_tarea_trello"), '&lt;DATA ID="'+Ctrl("oi_tarea").GetXValue()+'" /&gt;');	
	return MySQL;
}

function PanelTrello()
{
	if(Ctrl("cont").GetXValue()&gt;0)
	{
		if(Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility!="")
	 	{
	 		Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = ""; 		 		
	 		SetearValores();
	 	} 		
	 	else
	 	{
	 		Ctrl("groupDatosTarjeta").m_HTMLObject.style.visibility = "hidden";
	 		Ctrl("d_tarea_trello").SetXValue("");
	 		Ctrl("f_fin_trello").SetXValue("");
	 		Ctrl("oi_recurso_trello").SetXValue("");
	 		Ctrl("o_tarea_trello").SetXValue("");
	 		
	 	}	
	}
	else
	{
		alert("No pertenece a ning&#250;n equipo de Trello.");
		Ctrl("l_trello").SetXValue(false);
	}
}

function SetearValores()
{
	var MySQL = GetDatosTrello();	
	
	var name = "";
	name += MySQL.GetAttr("c_tarea");
	if(name!="")
		name += " - ";
	name += MySQL.GetAttr("d_tarea");
		
	Ctrl("d_tarea_trello").SetXValue(name);
	Ctrl("o_tarea_trello").SetXValue(MySQL.GetAttr("o_tarea"));
	
	if(Ctrl("oi_recurso_asi").GetXValue()!="")
		Ctrl("oi_recurso_trello").SetXValue(Ctrl("oi_recurso_asi").GetXValue());
	else
		Ctrl("oi_recurso_trello").SetXValue(MySQL.GetAttr("oi_recurso"));
	
	Ctrl("f_fin_trello").SetXValue(MySQL.GetAttr("f_fin_est"));	
}

function SHOWTRELLO()
{  
	var MySQL = GetDatosTrello();	
	
	if(MySQL.GetAttr("D_ENLACE")=='0')
		alert("La Tarea no est&#225; vinculada con ninguna Tarjeta en Trello.");
	else
		{
		   window.open("https://trello.com/c/"+MySQL.GetAttr("D_ENLACE"));
		   return;
		}	
}  

function SAVE()
{	
 	if(Ctrl('main').GetMode() == "WORK" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
 	{
 		if(Ctrl("d_tarea_trello").GetXValue()=="")
 		{   
 				alert("La descripci&#243;n de la tarjeta es requerido"); 
 				Ctrl("d_tarea_trello").SetFocus();
 		  	return false;
 		}
 		
 		if(Ctrl("id_columna_trello").GetXValue()=="")
 		{   
 				alert("La columna es requerida");
 				Ctrl("id_columna_trello").SetFocus(); 
 		  	return false;
 		}
 		
 		Ctrl("main").DoEvent("TRELLO");
 	}
 	else
 		Ctrl("main").DoEvent("ACCEPT");
 	
 	
 	//return true; 
}              

function ActualizarRecursoTrello()
{ 
	if(Ctrl('main').GetMode() == "WORK" &amp;&amp; Ctrl("l_trello").GetXValue()=="1")
		Ctrl("oi_recurso_trello").SetXValue(Ctrl("oi_recurso_asi").GetXValue());
}
	</form:Scripts>
	<form:Event action="OnLoad" name="OnLoad" runat="client"/>
	<form:Resources>
		<form:Resource declare="&lt;DATA id=&quot;312&quot; /&gt;" name="qry_tarea_trello">
			<qry:main doc="PARAM">
				<qry:element name="ROW">
					<qry:insert-select doc-path="#PARAM:/DATA" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					IIFISNULL(T.c_externo,0) as c_externo,
					IIFISNULL(T.D_ENLACE,0) as D_ENLACE,
					T.c_tarea,
					T.d_tarea,
					T.f_fin_est,
					T.o_tarea,
					T.oi_recurso
				FROM 
					PRY02_TAREAS as T
				WHERE
					T.oi_tarea={#PARAM:@id}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@c_externo=''">
						<qry:then>
							<qry:attribute value="'0'" name="c_externo"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@c_externo" name="c_externo"/>
						</qry:else>
					</qry:if>
					<qry:if test="$r/@D_ENLACE=''">
						<qry:then>
							<qry:attribute value="'0'" name="D_ENLACE"/>
						</qry:then>
						<qry:else>
							<qry:attribute value="$r/@D_ENLACE" name="D_ENLACE"/>
						</qry:else>
					</qry:if>
					<qry:attribute value="$r/@c_tarea" name="c_tarea"/>
					<qry:attribute value="$r/@d_tarea" name="d_tarea"/>
					<qry:attribute value="$r/@f_fin_est" name="f_fin_est"/>
					<qry:attribute value="$r/@o_tarea" name="o_tarea"/>
					<qry:attribute value="$r/@oi_recurso" name="oi_recurso"/>
				</qry:out>
			</qry:select>
		</form:Resource>
	</form:Resources>
	<form:Event action="TRELLO" name="TRELLO" runat="server"/>
	<form:Event action="ACCEPT" name="ACCEPT" runat="server"/>
</form:Form>
