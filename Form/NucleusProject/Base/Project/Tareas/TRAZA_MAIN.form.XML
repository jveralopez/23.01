<form:Form xmlns:form="nomad_engine.form" xmlns:qry="nomad_engine.qry" default_mode="WORK" name="NucleusProject.Base.Project.Tareas.TAREA_TRAZA.form" extends="NucleusProject.Base.Project.Tareas.TAREA_TRAZA.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source">
