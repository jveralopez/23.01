<form:Form xmlns:form="nomad_engine.form" default_mode="FILTER" extends="NucleusProject.Base.Project.Tareas.TAREA.filter.autoform" mess="&#191;Est&#225; seguro que desa cancelar la operaci&#243;n?" doc="source" name="NucleusProject.Base.Project.Tareas.TAREA">
	<form:Center>
		<form:Blank visible="" width="100%" name="bl1"/>
		<form:Columns name="colums">
			<form:Column name="col1">
				<form:Rower enabled="FILTER" required="0" label="Proyecto" separation="2" name="oi_proyecto">
					<form:ComboBox name="oi_proyecto_C" xsize="40" queryname1="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO" mode="QRY" required="0" enabled="0" label="Proyecto" nvalue="#source:@oi_proyecto"/>
					<form:SButton img="delall" label="Borrar el Valor" name="oi_proyecto_D">
						<form:Event action="Clearoi_proyecto" name="onClick" runat="client"/>
					</form:SButton>
					<form:SButton label="Seleccionar un Proyecto" img="SEARCH" name="oi_proyecto_F">
						<form:Event action="Findoi_proyecto" name="onClick" runat="client"/>
					</form:SButton>
				</form:Rower>
				<form:DateTime nvalue="#source:@f_desde" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Desde" name="f_des">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:DateTime nvalue="#source:@f_hasta" pattern="YYYYMMDD" required="0" enabled="" mask="dd/mm/yyyy" label="Fecha Hasta" name="f_has">
					<form:SButtons>
						<form:SButton img="Calendar" label="Calendar" name="Calendar" visible="">
							<form:Event action="SHOW_HELPER" name="onclick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:DateTime>
				<form:TextBox xsize="40" nvalue="#source:@c_tarea" label="Codigo" name="c_tarea"/>
				<form:TextBox label="Nombre" xsize="40" nvalue="#source:@d_tarea" name="d_tarea"/>
				<form:ComboBox label="Responsable" xsize="40" required="0" nvalue="#source:@oi_recurso" queryname1="NucleusProject.Base.Project.Recursos.RECURSO.INFO" name="oi_recurso" mode="QRY"/>
				<form:Blank name="sadfb"/>
				<form:ListView arr-control="EST" docname="EST" nvalue="#source:@selected" rows="6" width="300px" label="Estados" name="Estados">
					<form:LVColumns>
						<form:LVColumn width="100%" attrname="des" type="string" sorteable="1" label="Estado" name="des"/>
					</form:LVColumns>
					<form:SButtons>
						<form:SButton img="table_check" descrip="Marcar los Elementos" name="Mark">
							<form:Event action="FullEST" name="OnClick" runat="client"/>
						</form:SButton>
						<form:SButton img="table_uncheck" descrip="Desmarcar los Elementos" name="UnMark">
							<form:Event action="ClearEST" name="OnClick" runat="client"/>
						</form:SButton>
					</form:SButtons>
				</form:ListView>
				<form:HiddenArr nvalue="#source:EST" proto="&lt;C /&gt;" name="EST">
					<form:Attr name="id"/>
				</form:HiddenArr>
			</form:Column>
		</form:Columns>
	</form:Center>
	<form:Bottom>
		<form:RowAligner name="buttonlinks">
			<form:Row name="row1">
				<form:Button startvalidate="1" name="FILTER" label="Filtrar" img="ok" descrip="Ejecuta el filtro sobre la Base de Datos" note="Guardar los Cambios en la Base de Datos" visible="FILTER" X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/FILTER">
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/FILTER/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/FILTER"/>
					</form:Policies>
					<form:Event name="onclick" runat="server" action="FILTER"/>
				</form:Button>
				<form:Button name="ADD" label="Agregar" img="new" descrip="Agregar un Registro a la Base de Datos" note="Agregar un Registro a la Base de Datos" X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/ADD">
					<form:Event runat="server" name="onclick" action="ADD"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/ADD/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/ADD"/>
					</form:Policies>
				</form:Button>
				<form:Button name="BACK" label="Volver" img="back" descrip="Volver a la pantalla anterior" note="Vuelve a la pantalla anterior del formulario" visible="FILTER" X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/BACK">
					<form:Event runat="server" name="onclick" action="BACK"/>
					<form:Policies>
						<form:Updateable X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/BACK/HAB"/>
						<form:Visible X-POLICY="./FORM/NucleusProject/Base/Project/Tareas/TAREA/filter/form/BACK"/>
					</form:Policies>
				</form:Button>
			</form:Row>
		</form:RowAligner>
	</form:Bottom>
	<form:Scripts>
		function ClearEST()
{
	Ctrl("EST").DelAllRow();
	Ctrl("Estados").Refresh();
}

function FullEST()
{
	Ctrl("EST").DelAllRow();     
	for (var t=0; t&lt;Ctrl("Estados").TotalRowsCount(); t++)
		Ctrl("EST").AddRow().SetAttr("id", Ctrl("Estados").GetAttrValue(t, "id"));
	
	Ctrl("Estados").Refresh();
}

function Clearoi_proyecto()
{
	Ctrl("oi_proyecto_C").SetXValue("");
}

function Findoi_proyecto()
{                    
	openNewFlowWait("NucleusProject.Base.Project.Proyectos.PROYECTO.guia.flow","HELP",'&lt;DATA oi_proyecto="'+Ctrl("oi_proyecto_C").GetXValue()+'" ESTADOS="ITL" /&gt;',new oi_proyectoReport(),"S");
}

function oi_proyectoReport()
{
	this.processResult = function(XML)
	{                 
		var myRESULT=new NomadXML(XML);
		Ctrl("oi_proyecto_C" ).SetXValue(myRESULT.GetAttr("oi_proyecto"));
	}
}
	</form:Scripts>
</form:Form>
