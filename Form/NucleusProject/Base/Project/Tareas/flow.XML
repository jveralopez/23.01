<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusProject.Base.Project.Tareas.flow.flow" default_action="initialize" extends="NucleusProject.Base.Project.Tareas.autoflow">
	<flow:info label="Flow para NucleusProject.Base.Project.Tareas"/>
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('SELECT t0.oi_tarea as oi_tarea, SEC.policy FROM PRY02_TAREAS as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Tareas.TAREA\') as SEC JOIN t0.oi_tarea LEFT OUTER SEC.id  ORDER BY oi_tarea asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_tarea"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define declare="&lt;DATOS f_desde=&quot;&quot; f_hasta=&quot;&quot; oi_proyecto=&quot;1925&quot; c_tarea=&quot;&quot; oi_recurso=&quot;&quot; selected=&quot;&quot;&gt;&#13;&#10;&#9;&lt;ROWS /&gt;&#13;&#10;&#9;&lt;EST nmd-col=&quot;1&quot;&gt;&#13;&#10;      &lt;C id=&quot;IT&quot;/&gt;&#13;&#10;&#9;&lt;/EST&gt;&#13;&#10;&lt;/DATOS&gt;" name="LIST">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
SELECT  
	t0.oi_tarea as oi_tarea
	, t0.c_tarea as c_tarea
	, t0.d_tarea as d_tarea
	, t0.f_inicio_est as f_inicio_est
	, t0.f_fin_est as f_fin_est
	, t0.f_inicio as f_inicio
	, t0.f_fin as f_fin
	, t0.e_estimado as e_estimado
	, t0.f_limite as f_limite
	, t0.e_prioridad as e_prioridad
	, t0.c_clasificacion
	, t0.c_estado as c_estado
	, t0.c_tarea as CODE
	, t0.d_tarea as TEXT
	, t0.oi_proyecto as oi_proyecto
	, t0.oi_recurso as oi_recurso
	, t0.oi_pry_imputa as oi_pry_imputa
	, t0.oi_unidad_tiempo as oi_unidad_tiempo
	, t0.oi_solicitud as oi_solicitud
	, t1.c_recurso 
	, t2.d_ape_y_nom
	, t3.c_unidad_tiempo
	, t3.d_unidad_tiempo
FROM 
	PRY02_TAREAS as t0
	, PRY05_RECURSOS as t1
	, PER01_PERSONAL as t2
	, PRY03_UND_TIEMPO as t3
JOIN
	t1.oi_recurso INNER t0.oi_recurso
	, t2.oi_personal INNER t1.oi_personal
	, t3.oi_unidad_tiempo INNER t0.oi_unidad_tiempo
WHERE
	1=1    
	{%? (string(#PARAM:@oi_proyecto)!='') {% AND t0.oi_proyecto = {#PARAM:@oi_proyecto} %} {% %} %}
	{%? (#PARAM:@f_hasta!='') {% AND t0.f_fin &lt;= {#PARAM:@f_hasta} %} {% %} %}
  {%? (#PARAM:@f_desde!='') {% AND t0.f_inicio &gt;= {#PARAM:@f_desde} %} {% %} %}
  {%? (string(#PARAM:@c_tarea)!='') {% AND CONTAIN(t0.c_tarea,{#PARAM:@c_tarea}) %} {% %} %}
  {%? (string(#PARAM:@d_tarea)!='') {% AND CONTAIN(t0.d_tarea,{#PARAM:@d_tarea}) %} {% %} %}
	{%? (string(#PARAM:@oi_recurso)!='') {% AND t0.oi_recurso = {#PARAM:@oi_recurso} %} {% %} %}
 	{%? (string(#PARAM:EST/C/@id)!='') {% AND CONTAIN({#PARAM:EST/C/@id},t0.c_estado) %} {%  %} %}
ORDER BY c_tarea asc
	')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_tarea"/>
						<qry:attribute name="c_tarea" value="$r/@c_tarea"/>
						<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
						<qry:attribute name="f_inicio_est" value="$r/@f_inicio_est"/>
						<qry:attribute name="f_fin_est" value="$r/@f_fin_est"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="f_fin" value="$r/@f_fin"/>
						<qry:attribute name="e_estimado" value="$r/@e_estimado"/>
						<qry:attribute name="f_limite" value="$r/@f_limite"/>
						<qry:attribute name="e_prioridad" value="$r/@e_prioridad"/>
						<qry:attribute name="c_clasificacion" value="$r/@c_clasificacion"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:attribute name="oi_recurso" value="'['+$r/@c_recurso+'] '+$r/@d_ape_y_nom"/>
						<qry:attribute name="oi_unidad_tiempo" value="'['+$r/@c_unidad_tiempo+'] '+$r/@c_unidad_tiempo"/>
						<qry:if test="$r/@oi_proyecto!=''">
							<qry:then>
								<qry:element name="oi_proyecto">
									<qry:attribute name="OI_FIND" value="$r/@oi_proyecto"/>
									<qry:insert-select name="NucleusProject.Base.Project.Proyectos.PROYECTO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_proyecto" value="'['+oi_proyecto/ROW/@COD+'] '+oi_proyecto/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_pry_imputa!=''">
							<qry:then>
								<qry:element name="oi_pry_imputa">
									<qry:attribute name="OI_FIND" value="$r/@oi_pry_imputa"/>
									<qry:insert-select name="NucleusProject.Base.Project.Proyectos.PROYECTO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_pry_imputa" value="'['+oi_pry_imputa/ROW/@COD+'] '+oi_pry_imputa/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:include name="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO"/>
		</qry:define>
		<doc:define name="EST">
			<ROWS>
				<ROW des="Inicializada" id="I"/>
				<ROW des="Trabajando" id="T"/>
				<ROW des="Pausada" id="P"/>
				<ROW des="Finalizada" id="F"/>
				<ROW des="Anulada" id="A"/>
				<ROW des="Derivada a Testing" id="D"/>
			</ROWS>
		</doc:define>
		<doc:define name="FILTERDATA">
			<DATOS f_desde="" f_hasta="">
				<ROWS/>
				<EST/>
			</DATOS>
		</doc:define>
		<doc:define name="QRY"/>
		<doc:define name="recurso"/>
		<qry:define name="FindResource">
			<qry:main doc="PARAM">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="SQL1">
				<qry:xquery>
					for $r in SQL('
			SELECT 
				P.oi_personal, R.oi_recurso
			FROM
				PER01_PERSONAL as P,
				PRY05_RECURSOS as R
			JOIN
				P.oi_personal inner R.oi_personal
			WHERE               
				P.oi_usuario_sistema = {#PROXY:@ETTY}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id_per" value="$r/@oi_personal"/>
					<qry:attribute name="id_rec" value="$r/@oi_recurso"/>
					<qry:attribute value="Now()" name="fh"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define class="NucleusProject.Base.Project.Tareas.TAREA" name="DDO_TAREA"/>
		<doc:define name="TABLEROSTRELLO">
			<TRELLO/>
		</doc:define>
		<doc:define name="TRELLO">
			<TARJETA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="initialize">
			<flow:open-form doc-path="#FILTERDATA:" mode="FILTER" form-class="NucleusProject.Base.Project.Tareas.TAREA.filter.form"/>
		</flow:action>
	</flow:main>
	<flow:group Name="TAREA">
		<flow:form doc="SOURCE" extends="NucleusProject.Base.Project.Tareas.TAREA.filter.autoform:FILTER" parent-doc="PARENTSOURCE" name="NucleusProject.Base.Project.Tareas.TAREA.filter.form:FILTER" form-class="NucleusProject.Base.Project.Tareas.TAREA.filter.form" mode="FILTER">
			<flow:action name="on-show">
				<flow:log text="jprEST" text-path="#EST:"/>
				<flow:log text="jprFILTERDATA" text-path="#FILTERDATA:"/>
				<flow:attach-doc doc-path="#EST:" attach-id="EST"/>
				<!--flow:call-action action="Load-FILTER"/-->
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusProject.Base.Project.Tareas.GTAREA.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
			<flow:action name="open-flow-SHOW">
				<doc:load-qry output-doc="QRY" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusProject.Base.Project.Tareas.GTAREA.form"/>
			</flow:action>
			<flow:action name="FILTER">
				<flow:log text="jprEST2" text-path="#EST:"/>
				<flow:log text="jprFILTERDATA" text-path="#FILTERDATA:"/>
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<flow:call-action action="Save-FILTER"/>
				<flow:call-action action="open-flow-LIST"/>
			</flow:action>
			<flow:action name="empty">
				<flow:open-form iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="EDIT" form-class="NucleusProject.Base.Project.Tareas.TAREA.noreg.autoform"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:load-qry output-doc="recurso" qry="FindResource"/>
				<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:set-attribute from-value="I" to-attr-path="#NEWDDOROOT:@c_estado"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_unidad_tiempo/@value" from-value="2"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_clasificacion" from-value="5"/>
				<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="TABLEROSTRELLO" class="NucleusProject.Base.Project.Tareas.TAREA" method="GetTableros"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusProject.Base.Project.Tareas.TAREA.noreg.autoform:EDIT" parent-doc="PARENTSOURCE" doc="SOURCE" name="NucleusProject.Base.Project.Tareas.TAREA.noreg.form:EDIT" form-class="NucleusProject.Base.Project.Tareas.TAREA.noreg.autoform" mode="EDIT">
			<flow:action name="open-flow-SHOW">
				<flow:open-form iter-index="#QRY:ROW/@id" parent-doc-path="#QRY:" doc-path="#DDO:" mode="SHOW" form-class="NucleusProject.Base.Project.Tareas.GTAREA.form"/>
			</flow:action>
			<flow:action name="open-flow-LIST">
				<flow:open-form form-class="NucleusProject.Base.Project.Tareas.GTAREA.form" iter-index="#QRY_LIST:ROW/@id" parent-doc-path="#QRY_LIST:" doc-path="#DDO:" mode="LIST"/>
			</flow:action>
			<flow:action name="on-move-iterator">
				<flow:call-action action="load-DDO"/>
				<flow:call-action action="goto-list"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:load-qry output-doc="recurso" qry="FindResource"/>
				<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:set-attribute from-value="I" to-attr-path="#NEWDDOROOT:@c_estado"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_unidad_tiempo/@value" from-value="2"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_clasificacion" from-value="5"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
			</flow:action>
		</flow:form>
		<flow:form extends="NucleusProject.Base.Project.Tareas.TAREA.autoform:SHOW" form-class="NucleusProject.Base.Project.Tareas.GTAREA.form" name="NucleusProject.Base.Project.Tareas.GTAREA.form:SHOW" parent-doc="PARENTSOURCE" doc="SOURCE" mode="SHOW">
			<flow:action name="new-DDO">
				<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			</flow:action>
			<flow:action name="load-DDO">
				<doc:load-object id-path="#iter-cursor:@value" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			</flow:action>
			<flow:action name="save-DDO">
				<doc:save-object class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			</flow:action>
			<flow:action name="delete-DDO">
				<doc:delete-object doc-path="#DDO:" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
				<doc:save-object class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			</flow:action>
			<flow:action name="open-flow-EDIT">
				<flow:open-form doc-path="#DDO:" mode="EDIT" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
			</flow:action>
			<flow:action name="open-flow-ADD">
				<doc:load-qry output-doc="recurso" qry="FindResource"/>
				<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
				<doc:set-attribute from-value="I" to-attr-path="#NEWDDOROOT:@c_estado"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_unidad_tiempo/@value" from-value="2"/>
				<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_clasificacion" from-value="5"/>
				<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="TABLEROSTRELLO" class="NucleusProject.Base.Project.Tareas.TAREA" method="GetTableros"/>
				<flow:open-form doc-path="#NEWDDOROOT:" mode="NEW" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
			</flow:action>
			<flow:action name="CALL:TAREA_TRAZA">
				<flow:open-form iter-index="#DDO:TAREAS_TRAZA/TAREA_TRAZA/@id" parent-doc-path="#DDO:TAREAS_TRAZA" doc-path="#DDO:TAREAS_TRAZA" mode="SHOW" form-class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA.noreg.autoform"/>
			</flow:action>
			<flow:action name="After-Change">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<doc:iter-refresh/>
				<flow:close-form next-action="open-flow-SHOW"/>
			</flow:action>
			<flow:action name="LIST">
				<doc:load-qry output-doc="QRY_LIST" qry="LIST" input-doc-path="#FILTERDATA:"/>
				<flow:close-form next-action="open-flow-LIST"/>
			</flow:action>
			<flow:action name="PAUSE">
				<doc:load-qry output-doc="recurso" qry="FindResource"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="P"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Detenida"/>
				<flow:open-form parent-doc-path="#DDO:" mode="PAUSE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
			</flow:action>
			<flow:action name="WORK">
				<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
				<flow:call-action if="#DDO:@f_inicio" eq="" action="SET-FINI"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="T"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Activada"/>
				<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="TABLEROSTRELLO" class="NucleusProject.Base.Project.Tareas.TAREA" method="GetTableros"/>
				<flow:open-form parent-doc-path="#DDO:" mode="WORK" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
			</flow:action>
			<flow:action name="FINALIZE">
				<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#DDO:@f_fin"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="F"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Finalizada"/>
				<flow:open-form parent-doc-path="#DDO:" mode="FINALIZE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
			</flow:action>
			<flow:action name="ANULE">
				<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#DDO:@f_fin"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="A"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Anulada"/>
				<flow:open-form parent-doc-path="#DDO:" mode="ANULE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
			</flow:action>
			<flow:action name="SET-FINI">
				<doc:set-attribute to-attr-path="#DDO:@f_inicio" from-attr-path="#recurso:@fh"/>
			</flow:action>
			<flow:action name="ASIGN">
				<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
				<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="T"/>
				<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
				<doc:set-attribute from-value="Reasignada" to-attr-path="#NEWDDO:@c_causa"/>
				<flow:open-form mode="ASIGN" parent-doc-path="#DDO:" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
			</flow:action>
			<flow:action name="PARATEST">
				<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
				<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
				<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
