<flow:flow xmlns:flow="nomad_engine.flow" xmlns:qry="nomad_engine.qry" xmlns:doc="nomad_engine.doc" name="NucleusProject.Base.Project.Tareas.MAIN.flow" default_action="initialize" extends="NucleusProject.Base.Project.Tareas.autoflow">
	<flow:declare>
		<qry:define name="FILTER">
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT 
		t0.oi_tarea as oi_tarea, 
		SEC.policy 
	FROM 
		PRY02_TAREAS as t0,
		PRY05_RECURSOS as re,
		PER01_PERSONAL as pe,
		NMD_SECURITY(class=\'NucleusProject.Base.Project.Tareas.TAREA\') as SEC 
	JOIN                  
		t0.oi_recurso INNER re.oi_recurso,
		re.oi_personal INNER pe.oi_personal,
		t0.oi_tarea LEFT OUTER SEC.id  
	WHERE
		(isNull(t0.f_fin) or DATE2NUMBER(t0.f_fin) &gt; (DATE2NUMBER(Now())-40)) and
		pe.oi_usuario_sistema = {#PROXY:@ETTY}
	ORDER BY 
		oi_tarea asc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_tarea"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="LIST">
			<qry:include name="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO"/>
			<qry:include name="NucleusProject.Base.Project.Recursos.RECURSO.INFO"/>
			<qry:include name="NucleusProject.Base.Project.Proyectos.PROYECTO.INFO"/>
			<qry:include name="NucleusProject.Base.Project.UnidadesTiempo.UNIDAD_TIEMPO.INFO"/>
			<qry:main maxdeep="2">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
	SELECT 
		t0.oi_tarea as oi_tarea, 
		t0.c_tarea as c_tarea, 
		t0.d_tarea as d_tarea, 
		t0.f_inicio_est as f_inicio_est, 
		t0.f_fin_est as f_fin_est, 
		t0.f_inicio as f_inicio, 
		t0.f_fin as f_fin, 
		t0.e_estimado as e_estimado, 
		t0.f_limite as f_limite, 
		t0.e_prioridad as e_prioridad, 
		t0.c_estado as c_estado,   
		t0.c_estado as c_clasificacion,
		SEC.policy, 
		t0.c_tarea as CODE, 
		t0.d_tarea as TEXT, 
		t0.oi_proyecto as oi_proyecto, 
		t0.oi_recurso as oi_recurso, 
		t0.oi_pry_imputa as oi_pry_imputa, 
		t0.oi_unidad_tiempo as oi_unidad_tiempo 
	FROM 
		PRY02_TAREAS as t0,
		PRY05_RECURSOS as re,
		PER01_PERSONAL as pe,
		NMD_SECURITY(class=\'NucleusProject.Base.Project.Tareas.TAREA\') as SEC 
	JOIN 
		t0.oi_recurso INNER re.oi_recurso,
		re.oi_personal INNER pe.oi_personal,
		t0.oi_tarea LEFT OUTER SEC.id  
	WHERE
		(isNull(t0.f_fin) or DATE2NUMBER(t0.f_fin) &gt; (DATE2NUMBER(Now())-40)) and
		pe.oi_usuario_sistema = {#PROXY:@ETTY}
	ORDER BY 
		oi_tarea asc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="policy" value="$r/@policy"/>
						<qry:attribute name="id" value="$r/@oi_tarea"/>
						<qry:attribute name="c_tarea" value="$r/@c_tarea"/>
						<qry:attribute name="d_tarea" value="$r/@d_tarea"/>
						<qry:attribute name="f_inicio_est" value="$r/@f_inicio_est"/>
						<qry:attribute name="f_fin_est" value="$r/@f_fin_est"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="f_fin" value="$r/@f_fin"/>
						<qry:attribute name="e_estimado" value="$r/@e_estimado"/>
						<qry:attribute name="f_limite" value="$r/@f_limite"/>
						<qry:attribute name="e_prioridad" value="$r/@e_prioridad"/>
						<qry:attribute name="c_estado" value="$r/@c_estado"/>
						<qry:attribute name="c_clasificacion" value="$r/@c_clasificacion"/>
						<qry:attribute name="CODE" value="$r/@CODE"/>
						<qry:attribute name="TEXT" value="$r/@TEXT"/>
						<qry:if test="$r/@oi_proyecto!=''">
							<qry:then>
								<qry:element name="oi_proyecto">
									<qry:attribute name="OI_FIND" value="$r/@oi_proyecto"/>
									<qry:insert-select name="NucleusProject.Base.Project.Proyectos.PROYECTO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_proyecto" value="'['+oi_proyecto/ROW/@COD+'] '+oi_proyecto/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_recurso!=''">
							<qry:then>
								<qry:element name="oi_recurso">
									<qry:attribute name="OI_FIND" value="$r/@oi_recurso"/>
									<qry:insert-select name="NucleusProject.Base.Project.Recursos.RECURSO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_recurso" value="'['+oi_recurso/ROW/@COD+'] '+oi_recurso/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_pry_imputa!=''">
							<qry:then>
								<qry:element name="oi_pry_imputa">
									<qry:attribute name="OI_FIND" value="$r/@oi_pry_imputa"/>
									<qry:insert-select name="NucleusProject.Base.Project.Proyectos.PROYECTO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_pry_imputa" value="'['+oi_pry_imputa/ROW/@COD+'] '+oi_pry_imputa/ROW/@DES"/>
							</qry:then>
						</qry:if>
						<qry:if test="$r/@oi_unidad_tiempo!=''">
							<qry:then>
								<qry:element name="oi_unidad_tiempo">
									<qry:attribute name="OI_FIND" value="$r/@oi_unidad_tiempo"/>
									<qry:insert-select name="NucleusProject.Base.Project.UnidadesTiempo.UNIDAD_TIEMPO.QUERY" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_unidad_tiempo" value="'['+oi_unidad_tiempo/ROW/@COD+'] '+oi_unidad_tiempo/ROW/@DES"/>
							</qry:then>
						</qry:if>
					</qry:element>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="TARMAX"/>
		<qry:define name="NEWCODE" declare="&lt;DATA ID=&quot;1&quot; /&gt;">
			<qry:main maxdeep="2" doc="PARAM">
				<qry:element name="ROW">
					<qry:attribute name="max" value="0"/>
					<qry:insert-select doc-path="#PARAM:DATA" name="SQL1"/>
					<qry:attribute name="max" value="1+number(./@max)"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="SQL1">
				<qry:xquery>
					for $r in sql('SELECT t.c_tarea as c_tarea FROM PRY02_TAREAS as t WHERE t.oi_proyecto={#PARAM:@ID}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="max" value="iif(number(./@max)&lt;number($r/@c_tarea),number($r/@c_tarea),./@max)"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<qry:define name="FindResource">
			<qry:main doc="PARAM">
				<qry:element name="ROW">
					<qry:insert-select name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="SQL1">
				<qry:xquery>
					for $r in SQL('
SELECT 
P.oi_personal, R.oi_recurso
FROM
PER01_PERSONAL as P,
PRY05_RECURSOS as R
JOIN
P.oi_personal inner R.oi_personal
    		WHERE               
	P.oi_usuario_sistema = {#PROXY:@ETTY}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id_per" value="$r/@oi_personal"/>
					<qry:attribute name="id_rec" value="$r/@oi_recurso"/>
					<qry:attribute value="Now()" name="fh"/>
				</qry:out>
			</qry:select>
		</qry:define>
		<doc:define name="recurso"/>
		<doc:define name="PARAMIN"/>
		<doc:define name="TABLEROSTRELLO">
			<TRELLO/>
		</doc:define>
		<doc:define name="TRELLO">
			<TARJETA/>
		</doc:define>
	</flow:declare>
	<flow:main doc="SOURCE">
		<flow:action name="SHOW">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<flow:open-form form-class="NucleusProject.Base.Project.Tareas.TAREA.ASIGN.form" mode="SHOW" doc-path="#DDO:"/>
		</flow:action>
		<flow:action name="EDIT">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:set-attribute to-attr-path="#PARAMIN:@oi_proy_originalt" from-attr-path="#DDO:oi_proyecto/@value"/>
			<flow:open-form mode="EDIT" doc-path="#DDO:" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
		</flow:action>
		<flow:action name="ADD">
			<doc:assign-value to-doc="PARAMIN" from-path="#SOURCE:"/>
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="TARMAX" qry="NEWCODE"/>
			<doc:load-qry output-doc="recurso" qry="FindResource"/>
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_proyecto/@value" from-attr-path="#SOURCE:@id"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_pry_imputa/@value" from-attr-path="#SOURCE:@id"/>
			<doc:set-attribute from-value="I" to-attr-path="#NEWDDOROOT:@c_estado"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:oi_unidad_tiempo/@value" from-value="2"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_clasificacion" from-value="5"/>
			<doc:set-attribute to-attr-path="#NEWDDOROOT:@c_tarea" from-attr-path="#TARMAX:@max"/>
			<!--doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
	<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
	<doc:set-attribute to-attr-path="#NEWDDO:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
	<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
	<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="I"/>
	<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
	<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Creacion de la Tarea"/>
	<doc:add-object parent-doc-path="#NEWDDOROOT:TAREAS_TRAZA" out-doc="NEWDDO" doc-path="#NEWDDO:"/-->
			<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="TABLEROSTRELLO" class="NucleusProject.Base.Project.Tareas.TAREA" method="GetTableros"/>
			<flow:open-form mode="NEW" doc-path="#NEWDDOROOT:" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
		</flow:action>
		<flow:action name="DEL">
			<doc:assign-value to-doc="PARAMIN" from-path="#SOURCE:"/>
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:delete-object doc-path="#DDO:"/>
			<doc:save-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:set-attribute from-value="" to-attr-path="#SOURCE:@id"/>
			<flow:exit-flow return-path="#SOURCE:"/>
		</flow:action>
		<flow:action name="COPY">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@oi_tarea" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:assign-value to-doc="PARAMIN" from-path="#SOURCE:"/>
			<doc:load-qry input-doc-path="#SOURCE:" output-doc="TARMAX" qry="NEWCODE"/>
			<doc:load-qry output-doc="recurso" qry="FindResource"/>
			<doc:new-object doc="NEWDDOROOT" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:set-attribute from-attr-path="#DDO:oi_proyecto/@value" to-attr-path="#NEWDDOROOT:oi_proyecto/@value"/>
			<doc:set-attribute from-attr-path="#DDO:@c_tarea" to-attr-path="#NEWDDOROOT:@c_tarea"/>
			<doc:set-attribute from-attr-path="#DDO:@d_tarea" to-attr-path="#NEWDDOROOT:@d_tarea"/>
			<doc:set-attribute from-attr-path="#DDO:oi_recurso/@value" to-attr-path="#NEWDDOROOT:oi_recurso/@value"/>
			<doc:set-attribute from-attr-path="#DDO:oi_pry_imputa/@value" to-attr-path="#NEWDDOROOT:oi_pry_imputa/@value"/>
			<doc:set-attribute from-attr-path="#DDO:oi_unidad_tiempo/@value" to-attr-path="#NEWDDOROOT:oi_unidad_tiempo/@value"/>
			<doc:set-attribute from-attr-path="#DDO:@e_estimado" to-attr-path="#NEWDDOROOT:@e_estimado"/>
			<doc:set-attribute from-attr-path="#DDO:@e_prioridad" to-attr-path="#NEWDDOROOT:@e_prioridad"/>
			<doc:set-attribute from-value="I" to-attr-path="#NEWDDOROOT:@c_estado"/>
			<doc:set-attribute from-attr-path="#DDO:@o_tarea" to-attr-path="#NEWDDOROOT:@o_tarea"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:oi_recurso/@value" from-attr-path="#recurso:@id_rec"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="I"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Creacion de la Tarea"/>
			<doc:add-object parent-doc-path="#NEWDDOROOT:TAREAS_TRAZA" out-doc="NEWDDO" doc-path="#NEWDDO:"/>
			<flow:open-form mode="COPY" doc-path="#NEWDDOROOT:" form-class="NucleusProject.Base.Project.Tareas.TAREA.form"/>
		</flow:action>
		<flow:action name="PAUSE">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:load-qry output-doc="recurso" qry="FindResource"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="P"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Detenida"/>
			<flow:open-form parent-doc-path="#DDO:" mode="PAUSE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
		</flow:action>
		<flow:action name="WORK">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
			<flow:call-action if="#DDO:@f_inicio" eq="" action="SET-FINI"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="T"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Activada"/>
			<flow:exec-method out-type="Nomad.NSystem.Proxy.NomadXML" out-doc="TABLEROSTRELLO" class="NucleusProject.Base.Project.Tareas.TAREA" method="GetTableros"/>
			<flow:open-form parent-doc-path="#DDO:" mode="WORK" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
		</flow:action>
		<flow:action name="FINALIZE">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#DDO:@f_fin"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="F"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Finalizada"/>
			<flow:open-form parent-doc-path="#DDO:" mode="FINALIZE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
		</flow:action>
		<flow:action name="ANULE">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#DDO:@f_fin"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso_asi/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="A"/>
			<doc:set-attribute from-attr-path="#recurso:@fh" to-attr-path="#NEWDDO:@f_fecha_tarea"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_causa" from-value="Anulada"/>
			<flow:open-form parent-doc-path="#DDO:" mode="ANULE" doc-path="#NEWDDO:" form-class="NucleusProject.Base.Project.Tareas.TRAZA_MAIN.form"/>
		</flow:action>
		<flow:action name="SET-FINI">
			<doc:set-attribute to-attr-path="#DDO:@f_inicio" from-attr-path="#recurso:@fh"/>
		</flow:action>
		<flow:action name="ASIGN">
			<doc:new-object doc="DDO" class="NucleusProject.Base.Project.Tareas.TAREA"/>
			<doc:load-object id-path="#SOURCE:@id" class="NucleusProject.Base.Project.Tareas.TAREA" doc="DDO"/>
			<doc:load-qry output-doc="recurso" input-doc-path="#PROXY:" qry="FindResource"/>
			<doc:new-object doc="NEWDDO" class="NucleusProject.Base.Project.Tareas.TAREA_TRAZA"/>
			<doc:set-attribute from-attr-path="#recurso:@id_rec" to-attr-path="#NEWDDO:oi_recurso/@value"/>
			<doc:set-attribute to-attr-path="#NEWDDO:@c_estado" from-value="T"/>
