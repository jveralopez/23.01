<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			me.oi_mot_egr,
			me.c_mot_egr,
			me.d_mot_egr
			
		FROM 
			SDP20_MOT_EGR as me
		ORDER BY
			d_mot_egr ASC
			
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_mot_egr"/>
			<qry:attribute name="" value="$r/@d_mot_egr"/>
		</qry:element>
	</qry:out>
</qry:select>