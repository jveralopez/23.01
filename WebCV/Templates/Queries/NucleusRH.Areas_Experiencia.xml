<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		
		SELECT 
			ae.oi_area_exp,
			ae.c_area_exp,
			ae.d_area_exp
			
		FROM 
			SDP18_AREAS_EXP as ae

		ORDER BY
			d_area_exp ASC
					
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_area_exp"/>
			<qry:attribute name="" value="$r/@d_area_exp"/>
		</qry:element>
	</qry:out>
</qry:select>