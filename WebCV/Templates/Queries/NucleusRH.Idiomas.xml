<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
	SELECT 
		i.oi_idioma,
		i.c_idioma,
		i.d_idioma
		
	FROM 
		ORG20_IDIOMAS as i

	ORDER BY
		d_idioma ASC
				
')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_idioma"/>
			<qry:attribute name="" value="$r/@d_idioma"/>
		</qry:element>
	</qry:out>
</qry:select>