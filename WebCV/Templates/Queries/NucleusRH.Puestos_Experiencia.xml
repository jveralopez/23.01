<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
	SELECT 
		p.oi_puesto_exp,
		p.c_puesto_exp,
		p.d_puesto_exp
		
	FROM 
		SDP09_PUESTO_EXP as p
	
	ORDER BY
		d_puesto_exp ASC
		
')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_puesto_exp"/>
			<qry:attribute name="" value="$r/@d_puesto_exp"/>
		</qry:element>
	</qry:out>
</qry:select>