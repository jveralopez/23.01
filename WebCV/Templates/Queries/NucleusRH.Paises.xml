<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				p.oi_pais,
				p.c_pais,
				p.d_pais
				
			FROM 
				ORG35_PAISES as p
			
			ORDER BY
				d_pais ASC
	
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_pais"/>
			<qry:attribute name="" value="$r/@d_pais"/>
		</qry:element>
	</qry:out>
</qry:select>