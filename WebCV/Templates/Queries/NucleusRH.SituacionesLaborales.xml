<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				sl.oi_sit_laboral,
				sl.c_sit_laboral,
				sl.d_sit_laboral
				
			FROM 
				SDP17_SIT_LABORALES as sl

			ORDER BY
				d_sit_laboral ASC
						
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_sit_laboral"/>
			<qry:attribute name="" value="$r/@d_sit_laboral"/>
		</qry:element>
	</qry:out>
</qry:select>
