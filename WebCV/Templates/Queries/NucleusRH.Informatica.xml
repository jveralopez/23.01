<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
	SELECT 
		i.oi_informatica,
		i.c_informatica,
		i.d_informatica
		
	FROM 
		SDP08_INFORMATICA as i
	
	ORDER BY
		d_informatica ASC
		
')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_informatica"/>
			<qry:attribute name="" value="$r/@d_informatica"/>
		</qry:element>
	</qry:out>
</qry:select>