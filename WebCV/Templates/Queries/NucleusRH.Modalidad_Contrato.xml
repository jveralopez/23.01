<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			mc.oi_mod_contr,
			mc.c_mod_contr,
			mc.d_mod_contr
			
		FROM 
			SDP21_MOD_CONTR as mc
			
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_mod_contr"/>
			<qry:attribute name="" value="$r/@d_mod_contr"/>
		</qry:element>
	</qry:out>
</qry:select>