<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'ARRAY'"/>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				e.oi_estudio,
				e.c_estudio,
				e.d_estudio,
				
				e.oi_area_est
				
			FROM 
				ORG11_ESTUDIOS as e
		
			ORDER BY
				oi_area_est ASC,
				d_estudio ASC
						
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="VALUE">
			<qry:attribute name="parent" value="$r/@oi_area_est"/>
			<qry:attribute name="value" value="$r/@oi_estudio + '|' + $r/@d_estudio"/>
		</qry:element>
	</qry:out>
</qry:select>