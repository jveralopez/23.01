<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			p.oi_nivel_estudio,
			p.c_nivel_estudio,
			p.d_nivel_estudio
			
		FROM 
			PER12_NIVELES_EST as p
	
		ORDER BY
			c_nivel_estudio ASC
			
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_nivel_estudio"/>
			<qry:attribute name="" value="$r/@d_nivel_estudio"/>
		</qry:element>
	</qry:out>
</qry:select>