<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				e.oi_estado_civil,
				e.c_estado_civil,
				e.d_estado_civil
				
			FROM 
				ORG22_EST_CIVIL as e

			ORDER BY
				d_estado_civil ASC
						
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_estado_civil"/>
			<qry:attribute name="" value="$r/@d_estado_civil"/>
		</qry:element>
	</qry:out>
</qry:select>
