<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			ut.oi_unidad_tiempo,
			ut.c_unidad_tiempo,
			ut.d_unidad_tiempo
			
		FROM 
			ORG25_UNIDADES_TPO as ut
			
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_unidad_tiempo"/>
			<qry:attribute name="" value="$r/@d_unidad_tiempo"/>
		</qry:element>
	</qry:out>
</qry:select>