<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			tf.oi_tipo_familiar,
			tf.c_tipo_familiar,
			tf.d_tipo_familiar
			
		FROM 
			PER15_TIPOS_FAM as tf

		ORDER BY
			d_tipo_familiar ASC
					
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_tipo_familiar"/>
			<qry:attribute name="" value="$r/@d_tipo_familiar"/>
		</qry:element>
	</qry:out>
</qry:select>
