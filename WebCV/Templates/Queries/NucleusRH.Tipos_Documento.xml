<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				td.oi_tipo_documento,
				td.c_tipo_documento,
				td.d_tipo_documento
				
			FROM 
				PER20_TIPOS_DOC as td
				
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_tipo_documento"/>
			<qry:attribute name="" value="$r/@d_tipo_documento"/>
		</qry:element>
	</qry:out>
</qry:select>