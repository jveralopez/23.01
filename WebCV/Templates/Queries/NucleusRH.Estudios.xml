<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			e.oi_estudio,
			e.c_estudio,
			e.d_estudio
			
		FROM 
			ORG11_ESTUDIOS as e

		ORDER BY
			d_estudio ASC
					
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_estudio"/>
			<qry:attribute name="" value="$r/@d_estudio"/>
		</qry:element>
	</qry:out>
</qry:select>
