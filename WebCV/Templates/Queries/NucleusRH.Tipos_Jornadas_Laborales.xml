<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
			SELECT 
				tj.oi_tipo_jor_lab,
				tj.c_tipo_jor_lab,
				tj.d_tipo_jor_lab
				
			FROM 
				SDP16_TIPOS_JORNADA as tj
				
		')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_tipo_jor_lab"/>
			<qry:attribute name="" value="$r/@d_tipo_jor_lab"/>
		</qry:element>
	</qry:out>
</qry:select>