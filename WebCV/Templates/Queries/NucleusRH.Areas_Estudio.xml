<qry:main doc="SOURCE">
	<qry:element name="RESULT">
		<qry:attribute name="type" value="'QUERY'"/>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="'-NMD_BLANK-'"/>
			<qry:attribute name="" value="'- Seleccione -'"/>
		</qry:element>
		<qry:insert-select name="sql1"/>
	</qry:element>
</qry:main>
<qry:select name="sql1" doc="SOURCE">
	<qry:xquery>
		for $r in sql('
		SELECT 
			a.oi_area_est,
			a.c_area_est,
			a.d_area_est
			
		FROM 
			ORG43_AREAS_EST as a

		ORDER BY
			d_area_est ASC
					
	')/ROWS/ROW
	</qry:xquery>
	<qry:out>
		<qry:element name="OPTION">
			<qry:attribute name="value" value="$r/@oi_area_est"/>
			<qry:attribute name="" value="$r/@d_area_est"/>
		</qry:element>
	</qry:out>
</qry:select>
