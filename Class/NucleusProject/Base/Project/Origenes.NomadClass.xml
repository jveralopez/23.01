<class-package xmlns:qry="nomad_engine.qry" root-class="ORIGEN" name="Origenes" meta-class="DB" languaje="SP">
	<class size="L" description="Origenes" access="direct" label="Origen" name="ORIGEN">
		<meta-properties>
			<db-properties desc-column="d_origen" code-column="c_origen" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRY12_ORIGENES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_origenes" code-attr="c_origenes" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_origen as oi_origen, t0.c_origen as c_origen, t0.d_departamento as d_departamento, t0.d_origen as d_origen, SEC.policy, t0.c_origen as CODE, t0.d_origen as TEXT FROM PRY12_ORIGENES as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Origenes.ORIGEN\') as SEC JOIN t0.oi_origen LEFT OUTER SEC.id  ORDER BY oi_origen asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_origen"/>
								<qry:attribute name="c_origen" value="$r/@c_origen"/>
								<qry:attribute name="d_departamento" value="$r/@d_departamento"/>
								<qry:attribute name="d_origen" value="$r/@d_origen"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_origen as oi_origen, SEC.policy FROM PRY12_ORIGENES as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Origenes.ORIGEN\') as SEC JOIN t0.oi_origen LEFT OUTER SEC.id  ORDER BY oi_origen asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_origen"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_origen" code-attr="c_origen" desc="d_origenes" code="c_origenes" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_origen">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_origen"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Codigo" name="c_origen" OriginalName="c_origen">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Codigo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_origen"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Departamento" name="d_departamento" OriginalName="d_departamento">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Departamento" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_departamento"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_origen" OriginalName="o_origen">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_origen"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripcion" name="d_origen" OriginalName="d_origen">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripcion" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_origen"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusProject.Base.Project.Origenes.ORIGEN.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusProject.Base.Project.Origenes.ORIGEN.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.Origenes.ORIGEN.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRY12_ORIGENES.oi_origen as ID,
  PRY12_ORIGENES.c_origen as COD,
  PRY12_ORIGENES.d_origen as DES
from
  PRY12_ORIGENES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.Origenes.ORIGEN.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRY12_ORIGENES.oi_origen) as CNT
from
  PRY12_ORIGENES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRY12_ORIGENES.oi_origen={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRY12_ORIGENES.d_origen,{#SOURCE:@TXT_FIND}) or contain(PRY12_ORIGENES.c_origen,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
