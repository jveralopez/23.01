			<qry:select name="qryAttrs" doc="PARAM">
				<qry:out>
					<OPTS>
						<option value="{#SIS.FECHA#}" text="SISTEMA - Fecha"/>
						<option value="{#SIS.HORA#}" text="SISTEMA - Hora"/>
						<option value="{#SOL.CODIGO#}" text="SOLICITUD - C&#243;digo de la solicitud"/>
						<option value="{#SOL.DESCRIPCION#}" text="SOLICITUD - Descripci&#243;n de la solicitud"/>
						<option value="{#SOL.CRITICIDAD#}" text="SOLICITUD - Criticidad de la solicitud"/>
						<option value="{#SOL.BASE#}" text="SOLICITUD - Incorporaci&#243;n al base"/>
