<class-package xmlns:qry="nomad_engine.qry" name="Textos_Mails" root-class="TEXTO_MAIL" meta-class="DB" languaje="SP">
	<class size="L" help="Colecci&#243;n de textos para mails que env&#237;a el m&#243;dulo." description="Textos de mails" access="direct" label="Texto Mail" name="TEXTO_MAIL">
		<meta-properties>
			<db-properties desc-column="d_texto_mail" code-column="c_texto_mail" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRY17_TEXTOS_MAILS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_textos_mails" code-attr="c_textos_mails" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_texto_mail as oi_texto_mail, t0.c_texto_mail as c_texto_mail, t0.d_texto_mail as d_texto_mail, SEC.policy, t0.c_texto_mail as CODE, t0.d_texto_mail as TEXT FROM PRY17_TEXTOS_MAILS as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL\') as SEC JOIN t0.oi_texto_mail LEFT OUTER SEC.id  ORDER BY oi_texto_mail asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_texto_mail"/>
								<qry:attribute name="c_texto_mail" value="$r/@c_texto_mail"/>
								<qry:attribute name="d_texto_mail" value="$r/@d_texto_mail"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_texto_mail as oi_texto_mail, SEC.policy FROM PRY17_TEXTOS_MAILS as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL\') as SEC JOIN t0.oi_texto_mail LEFT OUTER SEC.id  ORDER BY oi_texto_mail asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_texto_mail"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_texto_mail" code-attr="c_texto_mail" desc="d_textos_mails" code="c_textos_mails" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_texto_mail">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_texto_mail" OriginalName="c_texto_mail">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_texto_mail" OriginalName="d_texto_mail">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="Texto" name="t_texto_mail" OriginalName="t_texto_mail">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Texto" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(4000)" column="t_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRY17_TEXTOS_MAILS.oi_texto_mail as ID,
  PRY17_TEXTOS_MAILS.c_texto_mail as COD,
  PRY17_TEXTOS_MAILS.d_texto_mail as DES
from
  PRY17_TEXTOS_MAILS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRY17_TEXTOS_MAILS.oi_texto_mail) as CNT
from
  PRY17_TEXTOS_MAILS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRY17_TEXTOS_MAILS.oi_texto_mail={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRY17_TEXTOS_MAILS.d_texto_mail,{#SOURCE:@TXT_FIND}) or contain(PRY17_TEXTOS_MAILS.c_texto_mail,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="QRY_AttrsToReplace" description="Retorna la lista de atributos reemplazables.">
			<qry:include name="NucleusProject.Base.Project.Textos_Mails.TEXTO_MAIL.AttrsToReplace"/>
			<qry:main>
				<qry:insert-select name="qryAttrs"/>
			</qry:main>
		</resource>
