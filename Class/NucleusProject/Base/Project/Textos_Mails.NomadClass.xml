						<option value="{#CLI.DESCRIPCION#}" text="CLIENTE - Descripci&#243;n del cliente"/>
						<option value="{#CLI.RESPONSABLE#}" text="CLIENTE - Descripci&#243;n del reponsable del cliente"/>
						<option value="{#CLI.MAIL#}" text="CLIENTE - eMail del reponsable del cliente"/>
						<option value="{#CLI.HORASPENDIENTES#}" text="CLIENTE - Horas pendientes de soporte"/>
						<option value="{#CLI.HORASPENDCOND#}" text="CLIENTE - Criticidad Horas pendientes"/>
						<option value="{#PRO.CODIGO#}" text="PROYECTO - C&#243;digo del proyecto"/>
						<option value="{#PRO.DESCRIPCION#}" text="PROYECTO - Descripci&#243;n del proyecto"/>
						<option value="{#REC.CODIGO#}" text="RECURSO - C&#243;digo del recurso"/>
						<option value="{#REC.DESCRIPCION#}" text="RECURSO - Descripci&#243;n del recurso"/>
						<option value="{#REC.MAIL#}" text="RECURSO - eMail del recurso"/>
						<option value="{#MOD.CODIGO#}" text="MODULO - C&#243;digo del m&#243;dulo"/>
						<option value="{#MOD.DESCRIPCION#}" text="MODULO - Descripci&#243;n del m&#243;dulo"/>
						<option value="{#APL.CODIGO#}" text="APLICACION - C&#243;digo de aplicaci&#243;n"/>
						<option value="{#APL.DESCRIPCION#}" text="APLICACION - Descripci&#243;n de aplicaci&#243;n"/>
					</OPTS>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM cod=&quot;PASS&quot;/&gt;" name="QRY_Mails">
			<qry:main doc="PARAM">
				<qry:element name="objects">
					<qry:insert-select name="qryMain" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain" doc="PARAM">
				<qry:xquery>
					for $f in sql('
 				SELECT 
 					tm.c_texto_mail,
 					tm.d_texto_mail,
 					tm.t_texto_mail
				FROM 
					PRY17_TEXTOS_MAILS as tm
				WHERE 
					contain(tm.c_texto_mail, {#PARAM:@cod})
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="object">
						<qry:attribute name="t_texto_mail" value="$f/@t_texto_mail"/>
						<qry:attribute name="d_texto_mail" value="$f/@d_texto_mail"/>
						<qry:attribute name="c_texto_mail" value="$f/@c_texto_mail"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
