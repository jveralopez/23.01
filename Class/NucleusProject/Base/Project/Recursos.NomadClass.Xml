		<resource name="QRY_USUARIOS">
			<qry:main doc="SOURCE">
				<ROW>
					<qry:insert-select name="QRY_USUARIOS" doc-path=""/>
				</ROW>
			</qry:main>
			<qry:select doc="PARAM" name="QRY_USUARIOS">
				<qry:xquery>
					for $r in SQL('
			SELECT 
				REC.c_recurso,
				PER.d_ape_y_nom,
				EMP.e_numero_legajo,
				REC.c_externo
			FROM
				PRY05_RECURSOS as REC,
				PER01_PERSONAL as PER,
				PER02_PERSONAL_EMP as EMP
			JOIN
				REC.oi_personal INNER PER.oi_personal,
				PER.oi_personal LEFT OUTER EMP.oi_personal			
			WHERE
				ISNOTNULL(REC.c_externo)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<USUARIO>
						<qry:attribute name="usuario" value="$r/@c_recurso + iif($r/@e_numero_legajo!='','- ['+$r/@e_numero_legajo+'] ',' - ')+$r/@d_ape_y_nom"/>
						<qry:attribute name="c_externo" value="$r/@c_externo"/>
					</USUARIO>
				</qry:out>
			</qry:select>
		</resource>
