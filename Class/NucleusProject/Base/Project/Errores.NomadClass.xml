		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Requiere fecha de vencimiento" name="c_req_venc" OriginalName="c_req_venc">
			<meta-properties>
				<form-properties enum="NucleusProject.Base.Project.Errores.ERROR.c_req_venc" show-list="true" find-include="true" automatico="1" label="Requiere fecha de vencimiento" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_req_venc"/>
			</meta-properties>
