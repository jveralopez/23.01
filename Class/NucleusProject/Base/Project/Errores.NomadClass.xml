<class-package xmlns:qry="nomad_engine.qry" root-class="ERROR" name="Errores" meta-class="DB" languaje="SP">
	<class size="L" description="Errores" access="direct" label="Error" name="ERROR">
		<meta-properties>
			<db-properties desc-column="d_nombre" code-column="c_error" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRY13_ERRORES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_nombre" code-attr="c_errores" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
