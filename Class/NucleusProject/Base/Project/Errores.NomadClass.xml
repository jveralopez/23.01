							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_error as oi_error, t0.c_error as c_error, t0.d_nombre as d_nombre, t0.c_req_venc as c_req_venc, t0.e_dias_venc as e_dias_venc, SEC.policy, t0.c_error as CODE, t0.d_nombre as TEXT FROM PRY13_ERRORES as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Errores.ERROR\') as SEC JOIN t0.oi_error LEFT OUTER SEC.id  ORDER BY oi_error asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_error"/>
								<qry:attribute name="c_error" value="$r/@c_error"/>
								<qry:attribute name="d_nombre" value="$r/@d_nombre"/>
								<qry:attribute name="c_req_venc" value="$r/@c_req_venc"/>
								<qry:attribute name="e_dias_venc" value="$r/@e_dias_venc"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_error as oi_error, SEC.policy FROM PRY13_ERRORES as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.Errores.ERROR\') as SEC JOIN t0.oi_error LEFT OUTER SEC.id  ORDER BY oi_error asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_error"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_nombre" code-attr="c_error" desc="d_nombre" code="c_errores" automatico="1"/>
		</meta-properties>
