			<form-properties binary="NONE" desc-attr="d_tipos_proyecto" code-attr="c_tipos_proyecto" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
