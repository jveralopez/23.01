			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.TiposProyecto.TIPO_PROYECTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRY09_TIPOS_PROYECTO.oi_tipo_proyecto as ID,
  PRY09_TIPOS_PROYECTO.c_tipo_proyecto as COD,
  PRY09_TIPOS_PROYECTO.d_tipo_proyecto as DES
from
  PRY09_TIPOS_PROYECTO
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusProject.Base.Project.TiposProyecto.TIPO_PROYECTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRY09_TIPOS_PROYECTO.oi_tipo_proyecto) as CNT
from
  PRY09_TIPOS_PROYECTO
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRY09_TIPOS_PROYECTO.oi_tipo_proyecto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRY09_TIPOS_PROYECTO.d_tipo_proyecto,{#SOURCE:@TXT_FIND}) or contain(PRY09_TIPOS_PROYECTO.c_tipo_proyecto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
