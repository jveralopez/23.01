						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_proyecto as oi_tipo_proyecto, t0.c_tipo_proyecto as c_tipo_proyecto, t0.d_tipo_proyecto as d_tipo_proyecto, t0.c_image as c_image, t0.l_mos_objetivos as l_mos_objetivos, t0.l_mos_tarea as l_mos_tarea, SEC.policy, t0.c_tipo_proyecto as CODE, t0.d_tipo_proyecto as TEXT FROM PRY09_TIPOS_PROYECTO as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.TiposProyecto.TIPO_PROYECTO\') as SEC JOIN t0.oi_tipo_proyecto LEFT OUTER SEC.id  ORDER BY oi_tipo_proyecto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_proyecto"/>
								<qry:attribute name="c_tipo_proyecto" value="$r/@c_tipo_proyecto"/>
								<qry:attribute name="d_tipo_proyecto" value="$r/@d_tipo_proyecto"/>
								<qry:attribute name="c_image" value="$r/@c_image"/>
								<qry:attribute name="l_mos_objetivos" value="iif($r/@l_mos_objetivos='1','1','0')"/>
								<qry:attribute name="l_mos_tarea" value="iif($r/@l_mos_tarea='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_proyecto as oi_tipo_proyecto, SEC.policy FROM PRY09_TIPOS_PROYECTO as t0,NMD_SECURITY(class=\'NucleusProject.Base.Project.TiposProyecto.TIPO_PROYECTO\') as SEC JOIN t0.oi_tipo_proyecto LEFT OUTER SEC.id  ORDER BY oi_tipo_proyecto asc')/ROWS/ROW
