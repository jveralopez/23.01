<class-package xmlns:qry="nomad_engine.qry" root-class="SIT_LABORAL" name="SituacionesLaborales" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\SeleccionDePostulantes">
	<class size="S" help="Registra las situaciones laborales de las personas" description="Situaciones Laborales" access="direct" label="Situaci&#243;n Laboral" name="SIT_LABORAL">
		<meta-properties>
			<db-properties desc-column="d_sit_laboral" code-column="c_sit_laboral" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SDP17_SIT_LABORALES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_sit_laborales" code-attr="c_sit_laborales" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_sit_laboral as oi_sit_laboral, t0.c_sit_laboral as c_sit_laboral, t0.d_sit_laboral as d_sit_laboral, SEC.policy, t0.c_sit_laboral as CODE, t0.d_sit_laboral as TEXT FROM SDP17_SIT_LABORALES as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL\') as SEC JOIN t0.oi_sit_laboral LEFT OUTER SEC.id  ORDER BY oi_sit_laboral asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_sit_laboral"/>
								<qry:attribute name="c_sit_laboral" value="$r/@c_sit_laboral"/>
								<qry:attribute name="d_sit_laboral" value="$r/@d_sit_laboral"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_sit_laboral as oi_sit_laboral, SEC.policy FROM SDP17_SIT_LABORALES as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL\') as SEC JOIN t0.oi_sit_laboral LEFT OUTER SEC.id  ORDER BY oi_sit_laboral asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_sit_laboral"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_sit_laboral" code-attr="c_sit_laboral" desc="d_sit_laborales" code="c_sit_laborales" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_sit_laboral">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_sit_laboral"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_sit_laboral" OriginalName="c_sit_laboral">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_sit_laboral"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_sit_laboral" OriginalName="d_sit_laboral">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_sit_laboral"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_SDP17_SIT_LABORALES" msg="Ya se ha relacionado el Conocimiento en Inform&#225;tica seleccionado al CV" name="AK_KEY_SDP17_SIT_LABORALES">
			<key-attr assosiation="no" name="c_sit_laboral"/>
		</key>
		<resource declare="&lt;DATA   /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL.QUERY">
				<qry:out>
					<qry:element name="instance">
						<qry:append-doc name="INS" doc-path="."/>
						<qry:insert-select name="qry_usajobs"/>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:element>
					<qry:insert-select name="qry" doc-path="#SOURCE:"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.SituacionesLaborales.SIT_LABORAL.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SDP17_SIT_LABORALES.oi_sit_laboral) as CNT
from
  SDP17_SIT_LABORALES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SDP17_SIT_LABORALES.oi_sit_laboral={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SDP17_SIT_LABORALES.d_sit_laboral,{#SOURCE:@TXT_FIND}) or contain(SDP17_SIT_LABORALES.c_sit_laboral,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_usajobs">
				<qry:xquery>
					for $r in NOMAD('config/Context.cfg.xml')/context/apps/app/instance[upper-case(@id) = upper-case(#PROXY:@APP)]
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@jobs-url !='' and $r/@jobs-pass!='' and $r/@jobs-usr!='' ">
						<qry:then>
							<qry:attribute name="usa" value="'si'"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="qry" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SDP17_SIT_LABORALES.oi_sit_laboral as ID,
  SDP17_SIT_LABORALES.c_sit_laboral as COD,
  SDP17_SIT_LABORALES.d_sit_laboral as DES
from
  SDP17_SIT_LABORALES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:if test="contains($r/@COD,'JOBS_') and #INS:@usa != 'si'">
							<qry:then>
								<qry:attribute name="hts:delete" value="1"/>
							</qry:then>
						</qry:if>
						<qry:if test="not(contains($r/@COD,'JOBS_')) and #INS:@usa = 'si'">
							<qry:then>
								<qry:attribute name="hts:delete" value="1"/>
							</qry:then>
						</qry:if>
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
