<class-package xmlns:qry="nomad_engine.qry" root-class="MOT_EGR" name="MotivosEgreso" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\SeleccionDePostulantes">
	<class size="M" note="\\&#13;&#10;\\&#13;&#10;" help="Adminsitra los Motivos de Egreso para el CV" description="Motivos de Egreso" access="direct" label="Motivo Egreso" name="MOT_EGR">
		<meta-properties>
			<db-properties desc-column="d_mot_egr" code-column="c_mot_egr" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SDP20_MOT_EGR">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_mot_egr" code-attr="c_mot_egr" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mot_egr as oi_mot_egr, t0.c_mot_egr as c_mot_egr, t0.d_mot_egr as d_mot_egr, SEC.policy, t0.c_mot_egr as CODE, t0.d_mot_egr as TEXT, t0.oi_motivo_eg_per as oi_motivo_eg_per FROM SDP20_MOT_EGR as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR\') as SEC JOIN t0.oi_mot_egr LEFT OUTER SEC.id  ORDER BY oi_mot_egr asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mot_egr"/>
								<qry:attribute name="c_mot_egr" value="$r/@c_mot_egr"/>
								<qry:attribute name="d_mot_egr" value="$r/@d_mot_egr"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_motivo_eg_per!=''">
									<qry:then>
										<qry:element name="oi_motivo_eg_per">
											<qry:attribute name="OI_FIND" value="$r/@oi_motivo_eg_per"/>
											<qry:insert-select name="NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_motivo_eg_per" value="'['+oi_motivo_eg_per/ROW/@COD+'] '+oi_motivo_eg_per/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mot_egr as oi_mot_egr, SEC.policy FROM SDP20_MOT_EGR as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR\') as SEC JOIN t0.oi_mot_egr LEFT OUTER SEC.id  ORDER BY oi_mot_egr asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mot_egr"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_mot_egr" code-attr="c_mot_egr" desc="d_mot_egr" code="c_mot_egr" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_mot_egr">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_mot_egr"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_mot_egr" OriginalName="c_mot_egr">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_mot_egr"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_mot_egr" OriginalName="d_mot_egr">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_mot_egr"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Personal.Motivos_Egreso_Personal.MOTIVO_EG_PER" null="true" readonly="false" type="aggregation" label="Motivo Egreso Personal" name="oi_motivo_eg_per" OriginalName="oi_motivo_eg_per">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_motivo_eg_per"/>
				<form-properties label="Motivo Egreso Personal" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_motivo_eg_per"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_MOT_EGR" name="AK_MOT_EGR">
			<key-attr assosiation="no" name="c_mot_egr"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SDP20_MOT_EGR.oi_mot_egr as ID,
  SDP20_MOT_EGR.c_mot_egr as COD,
  SDP20_MOT_EGR.d_mot_egr as DES
from
  SDP20_MOT_EGR
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.MotivosEgreso.MOT_EGR.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SDP20_MOT_EGR.oi_mot_egr) as CNT
from
  SDP20_MOT_EGR
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SDP20_MOT_EGR.oi_mot_egr={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SDP20_MOT_EGR.d_mot_egr,{#SOURCE:@TXT_FIND}) or contain(SDP20_MOT_EGR.c_mot_egr,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
