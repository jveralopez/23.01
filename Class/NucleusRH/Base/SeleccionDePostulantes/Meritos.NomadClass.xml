<class-package xmlns:qry="nomad_engine.qry" root-class="MERITO" name="Meritos" DDOBase="NucleusRH\Base\SeleccionDePostulantes" meta-class="DB" languaje="SP">
	<class size="S" help="Registra los distintos m&#233;ritos a tener en cuenta al momento del reclutamiento" description="M&#233;ritos" access="direct" label="M&#233;rito" name="MERITO">
		<meta-properties>
			<db-properties desc-column="d_merito" code-column="c_merito" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SDP15_MERITOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_meritos" code-attr="c_meritos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_merito as oi_merito, t0.c_merito as c_merito, t0.d_merito as d_merito, t0.n_ponderacion as n_ponderacion, SEC.policy, t0.c_merito as CODE, t0.d_merito as TEXT FROM SDP15_MERITOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO\') as SEC JOIN t0.oi_merito LEFT OUTER SEC.id  ORDER BY oi_merito asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_merito"/>
								<qry:attribute name="c_merito" value="$r/@c_merito"/>
								<qry:attribute name="d_merito" value="$r/@d_merito"/>
								<qry:attribute name="n_ponderacion" value="$r/@n_ponderacion"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_merito as oi_merito, SEC.policy FROM SDP15_MERITOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO\') as SEC JOIN t0.oi_merito LEFT OUTER SEC.id  ORDER BY oi_merito asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_merito"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_merito" code-attr="c_merito" desc="d_meritos" code="c_meritos" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_merito">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_merito"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_merito" OriginalName="c_merito">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_merito"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_merito" OriginalName="d_merito">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_merito"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" label="Ponderaci&#243;n por Defecto" name="n_ponderacion" OriginalName="n_ponderacion">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Ponderaci&#243;n por Defecto" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="numeric(11,3)" column="n_ponderacion"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="F&#243;rmula" name="t_formula" OriginalName="t_formula">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="F&#243;rmula" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(4000)" column="t_formula"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_MERITO" name="AK_MERITO">
			<key-attr assosiation="no" name="c_merito"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SDP15_MERITOS.oi_merito as ID,
  SDP15_MERITOS.c_merito as COD,
  SDP15_MERITOS.d_merito as DES
from
  SDP15_MERITOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Meritos.MERITO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SDP15_MERITOS.oi_merito) as CNT
from
  SDP15_MERITOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SDP15_MERITOS.oi_merito={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SDP15_MERITOS.d_merito,{#SOURCE:@TXT_FIND}) or contain(SDP15_MERITOS.c_merito,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM meritoss=&quot;1&quot; /&gt;" description="Retorna los meritos con el codigo" name="QRY_Meritos">
			<qry:main doc="SOURCE">
				<qry:element name="MERITOS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAMS"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					m.oi_merito,
					m.c_merito,
					m.d_merito,
					m.t_formula
				
				FROM 
					SDP15_MERITOS as m

        WHERE
        	1 = 1
				
					{%? (#SOURCE:@meritos = '') 
							{% %}
							{% AND m.oi_merito IN ({%=#SOURCE:@meritos%}) %}
					%}
        

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="MERITO">
						<qry:attribute name="t_formula" value="$r/@t_formula"/>
						<qry:attribute name="d_merito" value="$r/@d_merito"/>
						<qry:attribute name="c_merito" value="$r/@c_merito"/>
						<qry:attribute name="oi_merito" value="$r/@oi_merito"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
