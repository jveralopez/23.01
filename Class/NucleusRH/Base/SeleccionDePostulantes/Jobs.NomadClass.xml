		<resource declare="&lt;DATA tipoCodificadora=&quot;ESTADOS_EST&quot; /&gt;" description="Get de codificadora parametro para web de postulantes" name="WEB_CODIFICADORAS">
			<qry:include name="NucleusRH.Base.SeleccionDePostulantes.CODIFICADORAS.query" mode="EXTERN"/>
			<qry:main doc="SOURCE" name="main">
				<qry:if test="$SOURCE/DATA/@tipoCodificadora = ''">
					<qry:then>
						<qry:insert-select name="qry_cod"/>
					</qry:then>
					<qry:else>
						<ROWS>
							<qry:insert-select name-calc="$SOURCE/DATA/@tipoCodificadora" doc-path="$SOURCE/DATA"/>
						</ROWS>
					</qry:else>
				</qry:if>
			</qry:main>
		</resource>
		<resource declare="&lt;DATA f_desde=&quot;20201211&quot; f_hasta=&quot;20201211&quot; mode=&quot;NEW&quot; /&gt;" name="QRY_AVISOS">
			<qry:main doc="SOURCE" name="main">
				<qry:append-doc name="PARAM" doc-path="#SOURCE:."/>
				<qry:element name="ROWS">
					<qry:insert-select name="qry_parametro"/>
					<qry:insert-select name="qryAvisos"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryAvisos">
				<qry:xquery>
					for $r in SQL('
			   SELECT
			   	AV.oi_aviso,
			   	AV.d_puesto,
			   	AV.o_aviso,
			   	AV.f_cierre,
			   	AV.f_aviso,
			   	AV.c_aviso,  
			   	AV.l_full_time,
			   	AV.l_part_time,
			   	AV.l_remoto,
			   	AV.l_temporal,  
			   	AV.l_publicar,
			   	AV.d_mail,
			   	AV.d_mail_alt_1,
			   	AV.d_mail_alt_2,
			   	AV.l_tag1 as l_tag1,
			   	AV.l_tag2 as l_tag2,
			   	AV.l_tag3 as l_tag3,
			   	AV.l_tag4 as l_tag4,
			   	AV.l_tag5 as l_tag5,
			   	AV.l_tag6 as l_tag6,
			   	AV.l_tag7 as l_tag7,
			   	AV.l_tag8 as l_tag8,
			    AV.l_tag9 as l_tag9,
			   	AV.l_tag10 as l_tag10,  	
			   	TJOR.c_tipo_jor_lab,
			   	TJOR.oi_tipo_jor_lab,
			   	JER.oi_jerarquia,
			   	JER.c_jerarquia,
			   	PEXP.oi_puesto_exp,
			   	PEXP.c_puesto_exp,
			   	P.oi_pais,
			   	P.c_pais,
			    PROV.oi_provincia,
			    PROV.c_provincia,
			    LOC.oi_localidad,
			    LOC.c_localidad	
			   FROM
			   	SDP05_AVISOS as AV,
			   	SDP16_TIPOS_JORNADA as TJOR,
			   	SDP07_JERARQUIA as JER,
			   	SDP09_PUESTO_EXP as PEXP,
			   	ORG35_PAISES as P,
			   	ORG35_PROVINCIAS as PROV,
			   	ORG19_LOCALIDADES as LOC,
			   	NMD_SECURITY(NMD_SECURITY.class=\'NucleusRH.Base.SeleccionDePostulantes.Avisos.AVISO\') as SEC
			   	      
			   	JOIN
			   	AV.oi_tipo_jor_lab LEFT OUTER TJOR.oi_tipo_jor_lab,
			   	AV.oi_jerarquia LEFT OUTER JER.oi_jerarquia,
			   	AV.oi_area_pe LEFT OUTER PEXP.oi_puesto_exp,
			   	AV.oi_pais LEFT OUTER P.oi_pais,
			   	AV.oi_provincia LEFT OUTER PROV.oi_provincia,
			   	AV.oi_localidad LEFT OUTER LOC.oi_localidad,
			   	AV.oi_aviso left outer SEC.Id
 
			   WHERE 
			   1=1
			    {%? (#PARAM:@f_desde!='') 				 		
					{% AND SEC.edit_time &gt;= {Datetime(#PARAM:@f_desde)}   %} 
					{% %}
				%} 
				{%? (#PARAM:@f_hasta!='') 				 		
					{% AND SEC.edit_time &lt;= {Datetime(Number(DateTime(#PARAM:@f_HASTA))+1)}      %} 
			 		{% %}
				 %}  
				 {%? (#PARAM:@l_internos!='1')  
					{% AND AV.c_tipo in (\'E\',\'I/E\') %} 
					{% %}
				%} 		
				AND (AV.l_publicar = 1  or  (AV.l_publicar = 0 and isnotnull(AV.oi_aviso_jobs)))
			    
				 
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<!--oferta laboral -->
						<qry:attribute name="place_lat" value="'0'"/>
						<qry:attribute name="place_lng" value="'0'"/>
						<qry:attribute name="is_full_time" value="$r/@l_full_time"/>
						<qry:attribute name="is_part_time" value="$r/@l_part_time"/>
						<qry:attribute name="is_remote" value="$r/@l_remoto"/>
						<qry:attribute name="is_temporal" value="$r/@l_temporal"/>
						<qry:attribute name="lowest_expected_salary" value="'0'"/>
						<qry:attribute name="highest_expected_salary" value="'0'"/>
						<qry:attribute name="title" value="$r/@d_puesto"/>
						<qry:attribute name="description" value="$r/@o_aviso"/>
						<qry:attribute name="oi_oferta_lab" value="$r/@oi_aviso"/>
						<qry:attribute name="external_id" value="$r/@oi_aviso"/>
						<qry:attribute name="f_cierre" value="iif($r/@f_cierre='','21000101',$r/@f_cierre)"/>
						<qry:attribute name="show_salary" value="'0'"/>
						<qry:attribute name="ask_income" value="'0'"/>
						<nucleus_offer>
							<!--nucleus offer -->
							<qry:attribute name="id" value="$r/@oi_aviso"/>
							<qry:attribute name="d_oferta_lab" value="$r/@d_puesto"/>
							<qry:attribute name="f_oferta_lab" value="$r/@f_aviso"/>
							<qry:attribute name="o_oferta_lab" value="$r/@o_aviso"/>
							<qry:attribute name="c_oferta_lab" value="$r/@c_aviso"/>
							<qry:attribute name="f_cierre" value="iif($r/@f_cierre='','21000101',$r/@f_cierre)"/>
							<qry:attribute name="l_publicacion_web" value="$r/@l_publicar"/>
							<qry:attribute name="c_destino_publi" value="'JOBS'"/>
							<!--SDP16_TIPOS_JORNADA -->
							<qry:attribute name="c_tipo_puesto" value="$r/@c_tipo_jornada"/>
							<qry:attribute name="oi_tipo_puesto" value="$r/@oi_tipo_jornada"/>
							<!--SDP07_JERARQUIA -->
							<qry:attribute name="c_seniority" value="$r/@c_jerarquia"/>
							<qry:attribute name="oi_seniority" value="$r/@oi_jerarquia"/>
							<!--SDP09_PUESTO_EXP -->
							<qry:attribute name="oi_area_lab" value="$r/@oi_puesto_exp"/>
							<qry:attribute name="c_area_lab" value="$r/@c_puesto_exp"/>
							<qry:attribute name="oi_pais" value="$r/@oi_pais"/>
							<qry:attribute name="c_pais" value="$r/@c_pais"/>
							<qry:attribute name="oi_provincia" value="$r/@oi_provincia"/>
							<qry:attribute name="c_provincia" value="$r/@c_provincia"/>
							<qry:attribute name="oi_localidad" value="$r/@oi_localidad"/>
							<qry:attribute name="c_localidad" value="$r/@c_localidad"/>
							<qry:attribute name="d_mail" value="''"/>
							<qry:attribute name="d_mail_alt_1" value="''"/>
							<qry:attribute name="d_mail_alt_2" value="''"/>
							<qry:attribute name="l_prof" value="$r/@l_tag1"/>
							<qry:attribute name="l_digital" value="$r/@l_tag2"/>
							<qry:attribute name="l_oficio" value="$r/@l_tag3"/>
							<qry:attribute name="l_primer" value="$r/@l_tag4"/>
							<qry:attribute name="l_junior" value="$r/@l_tag5"/>
							<qry:attribute name="l_semi" value="$r/@l_tag6"/>
							<qry:attribute name="l_senior" value="$r/@l_tag7"/>
							<qry:attribute name="l_mamedio" value="$r/@l_tag8"/>
							<qry:attribute name="l_gerencia" value="$r/@l_tag9"/>
							<qry:attribute name="l_clevel" value="$r/@l_tag10"/>
							<qry:attribute name="oi_oferta_lab" value="$r/@oi_aviso"/>
						</nucleus_offer>
					</ROW>
				</qry:out>
			</qry:select>
			<qry:select name="qry_parametro">
				<qry:xquery>
					for $r in SQL('
			SELECT  
			ORG26_PARAMETROS.d_valor
			FROM
			ORG26_PARAMETROS
			WHERE
			ORG26_PARAMETROS.c_parametro = \'WebInternos\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute-doc doc="PARAM" name="l_internos" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&#13;&#10;&lt;DATA f_desde=&quot;20191202&quot; f_hasta=&quot;20191202&quot; /&gt;" name="WEB_GET_POSTU_LEIDAS">
			<qry:main doc="SOURCE" name="">
				<ROWS>
					<qry:insert-select name="qryGetPostuLeidas" doc-path="#SOURCE:DATA"/>
				</ROWS>
			</qry:main>
			<qry:select name="qryGetPostuLeidas" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			  SELECT 
			   POSTU.oi_oferta_lab,
			   CV.c_cv,
			   CV.oi_tipo_documento,
			   CV.c_nro_doc
				FROM
				 POS01_POSTU_CV as POSTU,
				 POS01_CV as CV
				JOIN
				 POSTU.oi_cv INNER CV.oi_cv
				WHERE
				 POSTU.l_leido=1
				 AND CV.c_origen = \'WEB\'
				 {%? (#SOURCE:@f_desde!='') 				 		
				 		{% AND DATE2STRING(POSTU.f_postulacion) &gt;= {#SOURCE:@f_desde}   %} 				 		
				 		{% %}
				 %} 
				 {%? (#SOURCE:@f_hasta!='') 				 		
				 		{% AND DATE2STRING(POSTU.f_postulacion) &lt;= {#SOURCE:@f_hasta}   %} 
				 		{% %}
				 %} 
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="oi_oferta_lab" value="$r/@oi_oferta_lab"/>
						<qry:attribute name="c_cv" value="substring-after($r/@c_cv,'WEB')"/>
						<qry:attribute name="oi_tipo_documento" value="$r/@oi_tipo_documento"/>
						<qry:attribute name="c_nro_doc" value="$r/@c_nro_doc"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="HASH_ENDPOINTS">
			<qry:include mode="EXTERN" name="NucleusRH.Base.SeleccionDePostulantes.URLS.query"/>
			<qry:main name="main" doc="SOURCE">
				<qry:insert-select name="sql1"/>
			</qry:main>
		</resource>
		<resource name="QRY_PRUEBA">
			<qry:main name="" doc="">
				<qry:element name="ROWS">
					<ROW origen="id" destino="c_cv"/>
					<ROW origen="" destino="c_cv" value="D"/>
					<ROW origen="createdAt" destino="f_alta_cv"/>
					<ROW origen="" destino="l_alta_web" value="true"/>
					<ROW origen="updatedAt" destino="f_actualizacion"/>
				</qry:element>
			</qry:main>
		</resource>
