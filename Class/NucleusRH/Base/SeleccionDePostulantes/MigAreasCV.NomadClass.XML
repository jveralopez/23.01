<class-package xmlns:qry="nomad_engine.qry" name="MigAreasCV" DDOBase="NucleusRH\Base\SeleccionDePostulantes" root-class="AREA_CV" meta-class="DB" languaje="SP">
	<class description="Areas CV" label="Area CV" name="AREA_CV" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="SDP04_Areas_CV.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute length="30" type="Nomad.NSystem.String" label="C&#243;digo de CV" ParentId="1" null="false" readonly="false" default="''" name="c_cv" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Area" name="c_area" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importar Areas desde Archivo" name="ImportarAreasCV" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.SeleccionDePostulantes.MigAreasCV.AREA_CV" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:SDP04_Areas_CV.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
