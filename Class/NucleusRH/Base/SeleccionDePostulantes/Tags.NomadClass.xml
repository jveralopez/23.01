<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\SeleccionDePostulantes" root-class="TAG" name="Tags" meta-class="DB" languaje="SP">
	<class attr-desc="d_tag" attr-code="c_tag" description="Tags" label="Tag" size="M" name="TAG">
		<meta-properties>
			<!--<db-properties desc-column="d_tag" code-column="c_tag" generate="true" access-mode="new-edit-delete" optimistic-lock="version" table="SDP24_TAGS"/>-->
			<file-properties file="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG" id-gen="@c_tag"/>
		</meta-properties>
		<attribute readonly="false" null="false" label="id" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties>
				<db-properties generator="secuence" tracking-changes="no" unique="false" updatable="false" insertable="true" versionable="false" nullable="false" id="true" type="int" column="oi_tag"/>
			</meta-properties>
		</attribute>
		<attribute label="codigo" null="false" type="Nomad.NSystem.String" name="c_tag" manual="1">
			<meta-properties>
				<db-properties tracking-changes="no" generator="none" unique="false" updatable="false" insertable="true" versionable="false" nullable="false" id="false" type="varchar(30)" column="c_tag"/>
			</meta-properties>
		</attribute>
		<attribute null="false" type="Nomad.NSystem.String" name="d_tag" manual="1">
			<meta-properties>
				<db-properties tracking-changes="no" generator="none" unique="false" insertable="true" updatable="false" versionable="false" nullable="false" id="false" type="varchar(30)" column="d_tag"/>
			</meta-properties>
		</attribute>
		<resource name="INFO">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY" doc="SOURCE">
				<qry:out>
					<qry:if test="#SOURCE:@OI_FIND=''">
						<qry:then>
							<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY.PATH" doc-path="#SOURCE:"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="FILE" value="#SOURCE:@oi_find+'.TAG.XML'"/>
							<qry:insert-select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY.DDO" doc-path="."/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY.PATH" doc="SOURCE">
				<qry:xquery>
					for $r in METHOD('Nomad.Base.Report.Listas.INDICE:SuperComboIndex({\'NucleusRH\\\\Base\\\\SeleccionDePostulantes\\\\Tags\'},{\'NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.INFO\'},{#SOURCE:@TXT_FIND},{floor(#SOURCE:@START)},{floor(#SOURCE:@LEN)},{#SOURCE:@ORDERBY})')/*
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r/ROW"/>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.SeleccionDePostulantes.Tags.TAG.QUERY.DDO" doc="SOURCE">
				<qry:xquery>
					for $r in FILE('NucleusRH\\Base\\SeleccionDePostulantes\\Tags\\{%=#SOURCE:@file%}')/TAG
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@c_tag"/>
						<qry:attribute name="DES" value="$r/@d_tag"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="COUNT">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:attribute name="cantidad" value="'0'"/>
					<qry:insert-select name="qry_cantidad"/>
					<qry:attribute name="cantidad" value="count(./TAG)"/>
				</ROWS>
			</qry:main>
			<qry:select name="qry_cantidad">
				<qry:xquery>
					for $r in path('NucleusRH\\Base\\SeleccionDePostulantes\\Tags')/TAG
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
	<class label="Tag importada" size="L" name="TAGIMP" description="Tags importadas" access="direct">
		<meta-properties>
			<interface-properties file="Tags.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="1000" name="tag" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="qry_rows">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:Tags.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
