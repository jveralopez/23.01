<class-package xmlns:qry="nomad_engine.qry" root-class="TIPO_JOR_LAB" name="Tipos_Jornadas_Laborales" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\SeleccionDePostulantes">
	<class label="Tipo Jornada Laboral" size="S" help="Registra los diferentes tipos de Jornadas Laborales" description="Tipos de Jornada" access="direct" name="TIPO_JOR_LAB">
		<meta-properties>
			<db-properties desc-column="d_tipo_jor_lab" code-column="c_tipo_jor_lab" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SDP16_TIPOS_JORNADA">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipos_jornada" code-attr="c_tipos_jornada" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_jor_lab as oi_tipo_jor_lab, t0.c_tipo_jor_lab as c_tipo_jor_lab, t0.d_tipo_jor_lab as d_tipo_jor_lab, SEC.policy, t0.c_tipo_jor_lab as CODE, t0.d_tipo_jor_lab as TEXT FROM SDP16_TIPOS_JORNADA as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB\') as SEC JOIN t0.oi_tipo_jor_lab LEFT OUTER SEC.id  ORDER BY oi_tipo_jor_lab asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_jor_lab"/>
								<qry:attribute name="c_tipo_jor_lab" value="$r/@c_tipo_jor_lab"/>
								<qry:attribute name="d_tipo_jor_lab" value="$r/@d_tipo_jor_lab"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_jor_lab as oi_tipo_jor_lab, SEC.policy FROM SDP16_TIPOS_JORNADA as t0,NMD_SECURITY(class=\'NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB\') as SEC JOIN t0.oi_tipo_jor_lab LEFT OUTER SEC.id  ORDER BY oi_tipo_jor_lab asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_jor_lab"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_tipo_jor_lab" code-attr="c_tipo_jor_lab" desc="d_tipos_jornada" code="c_tipos_jornada" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_tipo_jor_lab">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_jor_lab"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_tipo_jor_lab" OriginalName="c_tipo_jor_lab">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_jor_lab"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_tipo_jor_lab" OriginalName="d_tipo_jor_lab">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_jor_lab"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_TIPOS_JORNADAS" name="AK_TIPOS_JORNADAS">
			<key-attr assosiation="no" name="c_tipo_jor_lab"/>
		</key>
		<resource include="true" declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.QUERY">
				<qry:out>
					<qry:element name="instance">
						<qry:append-doc name="INS" doc-path="."/>
						<qry:insert-select name="qry_usajobs"/>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:element>
					<qry:insert-select name="qry" doc-path="#SOURCE:"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.SeleccionDePostulantes.Tipos_Jornadas_Laborales.TIPO_JOR_LAB.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SDP16_TIPOS_JORNADA.oi_tipo_jor_lab) as CNT
from
  SDP16_TIPOS_JORNADA
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SDP16_TIPOS_JORNADA.oi_tipo_jor_lab={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SDP16_TIPOS_JORNADA.d_tipo_jor_lab,{#SOURCE:@TXT_FIND}) or contain(SDP16_TIPOS_JORNADA.c_tipo_jor_lab,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
			<qry:select name="qry_usajobs">
				<qry:xquery>
					for $r in NOMAD('config/Context.cfg.xml')/context/apps/app/instance[upper-case(@id) = upper-case(#PROXY:@APP)]
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@jobs-url !='' and $r/@jobs-pass!='' and $r/@jobs-usr!='' ">
						<qry:then>
							<qry:attribute name="usa" value="'si'"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="qry" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SDP16_TIPOS_JORNADA.oi_tipo_jor_lab as ID,
  SDP16_TIPOS_JORNADA.c_tipo_jor_lab as COD,
  SDP16_TIPOS_JORNADA.d_tipo_jor_lab as DES
from
  SDP16_TIPOS_JORNADA
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:if test="contains($r/@COD,'JOBS_') and #INS:@usa != 'si'">
							<qry:then>
								<qry:attribute name="hts:delete" value="1"/>
							</qry:then>
						</qry:if>
						<qry:if test="not(contains($r/@COD,'JOBS_')) and #INS:@usa = 'si'">
							<qry:then>
								<qry:attribute name="hts:delete" value="1"/>
							</qry:then>
						</qry:if>
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM PARENT=&quot;1&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT 
					SDP16_TIPOS_JORNADA.oi_tipo_jor_lab,
					SDP16_TIPOS_JORNADA.d_tipo_jor_lab
				FROM
					SDP16_TIPOS_JORNADA
				ORDER BY
					d_tipo_jor_lab ASC
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_tipo_jor_lab"/>
						<qry:attribute name="DES" value="$r/@d_tipo_jor_lab"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFOTIPOJOR" include="true" declare="&lt;DATA oi_find=&quot;1&quot; /&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#SOURCE:." name="qry"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
 select
  SDP16_TIPOS_JORNADA.oi_tipo_jor_lab as ID,
  SDP16_TIPOS_JORNADA.c_tipo_jor_lab as COD,
  SDP16_TIPOS_JORNADA.d_tipo_jor_lab as DES
from
  SDP16_TIPOS_JORNADA ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
