		<method description="Importar Experiencias desde Archivo" name="ImportarExperienciasCV" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.SeleccionDePostulantes.MigExperienciaCV.EXPERIENCIA_CV" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:SDP05_Experiencia_CV.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATOS oi_cv=&quot;29&quot; oi_puesto_exp=&quot;2&quot; f_ingreso=&quot;20110612&quot; /&gt;&#13;&#10;" name="QRY_EXISTE">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:attribute name="existe" value="'0'"/>
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					EXP.oi_experiencia
				FROM 
					SDP01_EXPERIENCIA AS EXP
				WHERE 
				  EXP.oi_cv = {#SOURCE:@oi_cv} AND
					EXP.oi_puesto_exp = {#SOURCE:@oi_puesto_exp} AND
					EXP.f_ingreso = {Datetime(#SOURCE:@f_ingreso)} 
					
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="existe" value="'1'"/>
				</qry:out>
			</qry:select>
		</resource>
