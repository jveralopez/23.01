<class-package xmlns:qry="nomad_engine.qry" root-class="TEST" name="Tests" meta-class="DB" languaje="SP">
	<class size="M" help="Administra los Tipos de Tests" description="Tests" access="direct" label="Test" name="TEST">
		<meta-properties>
			<db-properties desc-column="d_test" code-column="c_test" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="POS11_TESTS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tests" code-attr="c_tests" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_test as oi_test, t0.c_test as c_test, t0.d_test as d_test, SEC.policy, t0.c_test as CODE, t0.d_test as TEXT FROM POS11_TESTS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.Tests.TEST\') as SEC JOIN t0.oi_test LEFT OUTER SEC.id  ORDER BY oi_test asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_test"/>
								<qry:attribute name="c_test" value="$r/@c_test"/>
								<qry:attribute name="d_test" value="$r/@d_test"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_test as oi_test, SEC.policy FROM POS11_TESTS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.Tests.TEST\') as SEC JOIN t0.oi_test LEFT OUTER SEC.id  ORDER BY oi_test asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_test"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_tests" code="c_tests" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Postulantes.Tests.autoflow:initialize" desc-attr="d_test" code-attr="c_test" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_test">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_test"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_test" OriginalName="c_test">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_test"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_test" OriginalName="d_test">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_test"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="Key_2" name="key_2">
			<key-attr assosiation="no" name="c_test"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Postulantes.Tests.TEST.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Postulantes.Tests.TEST.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Postulantes.Tests.TEST.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  POS11_TESTS.oi_test as ID,
  POS11_TESTS.c_test as COD,
  POS11_TESTS.d_test as DES
from
  POS11_TESTS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Postulantes.Tests.TEST.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(POS11_TESTS.oi_test) as CNT
from
  POS11_TESTS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and POS11_TESTS.oi_test={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(POS11_TESTS.d_test,{#SOURCE:@TXT_FIND}) or contain(POS11_TESTS.c_test,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
