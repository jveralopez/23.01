<class-package xmlns:qry="nomad_engine.qry" name="Textos_Mails" root-class="TEXTO_MAIL" DDOBase="NucleusRH\Base\Postulantes" meta-class="DB" languaje="SP">
	<class size="L" help="Colecci&#243;n de textos para mails que env&#237;a el m&#243;dulo." description="Textos de mails" access="direct" label="Texto Mail" name="TEXTO_MAIL">
		<meta-properties>
			<db-properties desc-column="d_texto_mail" code-column="c_texto_mail" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="POS26_TEXTOS_MAILS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_textos_mails" code-attr="c_textos_mails" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_texto_mail as oi_texto_mail, t0.c_texto_mail as c_texto_mail, t0.d_texto_mail as d_texto_mail, SEC.policy, t0.c_texto_mail as CODE, t0.d_texto_mail as TEXT FROM POS26_TEXTOS_MAILS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.Textos_Mails.TEXTO_MAIL\') as SEC JOIN t0.oi_texto_mail LEFT OUTER SEC.id  ORDER BY oi_texto_mail asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_texto_mail"/>
								<qry:attribute name="c_texto_mail" value="$r/@c_texto_mail"/>
								<qry:attribute name="d_texto_mail" value="$r/@d_texto_mail"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_texto_mail as oi_texto_mail, SEC.policy FROM POS26_TEXTOS_MAILS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Postulantes.Textos_Mails.TEXTO_MAIL\') as SEC JOIN t0.oi_texto_mail LEFT OUTER SEC.id  ORDER BY oi_texto_mail asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_texto_mail"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Postulantes.Textos_Mails.autoflow:initialize" desc-attr="d_texto_mail" code-attr="c_texto_mail" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_texto_mail">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_texto_mail" OriginalName="c_texto_mail">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_texto_mail" OriginalName="d_texto_mail">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="Texto" name="t_texto_mail" OriginalName="t_texto_mail">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Texto" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(4000)" column="t_texto_mail"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource name="QRY_AttrsToReplace" description="Retorna la lista de atributos reemplazables.">
			<qry:include name="NucleusRH.Base.Postulantes.Textos_Mails.TEXTO_MAIL.AttrsToReplace"/>
			<qry:main>
				<qry:insert-select name="qryAttrs"/>
			</qry:main>
		</resource>
		<resource description="Lista de atributos reemplazables." name="AttrsToReplace">
			<qry:select name="qryAttrs" doc="PARAM">
				<qry:out>
					<OPTS>
						<option value="{#S.FECHA#}" text="SISTEMA - Fecha"/>
						<option value="{#S.HORA#}" text="SISTEMA - Hora"/>
						<option value="{#S.BIENVENIDO#}" text="SISTEMA - Bienvenido/a"/>
						<option value="{#S.ESTIMADO#}" text="SISTEMA - Estimado/a"/>
						<option value="{#C.NOMBRES#}" text="CV - Nombres"/>
						<option value="{#C.APELLIDO#}" text="CV - Apellido"/>
						<option value="{#C.PASSWORD#}" text="CV - Password"/>
						<option value="{#O.CODIGO#}" text="OFERTA - C&#243;digo"/>
						<option value="{#O.DECRIP#}" text="OFERTA - Descripci&#243;n"/>
					</OPTS>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM cod=&quot;PASS&quot;/&gt;" name="QRY_Mails">
			<qry:main doc="PARAM">
				<qry:element name="objects">
					<qry:insert-select name="qryMain" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain" doc="PARAM">
				<qry:xquery>
					for $f in sql('
 				SELECT 
 					tm.c_texto_mail,
 					tm.d_texto_mail,
 					tm.t_texto_mail
				FROM 
					POS26_TEXTOS_MAILS as tm
				WHERE 
					contain(tm.c_texto_mail, {#PARAM:@cod})
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="object">
						<qry:attribute name="t_texto_mail" value="$f/@t_texto_mail"/>
						<qry:attribute name="d_texto_mail" value="$f/@d_texto_mail"/>
						<qry:attribute name="c_texto_mail" value="$f/@c_texto_mail"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
