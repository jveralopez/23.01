		<resource name="INFO"/>
		<resource declare="&lt;DATA oi_busqueda=&quot;27&quot;/&gt;" description="Recupera el campo like para la busqueda simple" name="GET_BUSQUEDA">
			<qry:main name="qryMain" doc="SOURCE">
				<RESULT>
					<qry:insert-select name="qryGet" doc-path="$SOURCE/DATA"/>
				</RESULT>
			</qry:main>
			<qry:select name="qryGet" doc="PARAM">
				<qry:xquery>
					for $r in SQL
			('
			SELECT
			BUS.o_palabras_clave
			
			FROM
			POS28_BUSQUEDAS as BUS
			
			WHERE
			BUS.oi_busqueda = {$PARAM/@oi_busqueda}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="campo_like" value="$r/@o_palabras_clave"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA top=&quot;10&quot; oi_usuario_sistema=&quot;001AA0E914F9-51753AA603CF-00016C825F4D&quot;/&gt;" description="Recupera las ultimas 5 Busquedas del Usuario logueado" name="GET_MIS_BUSQUEDAS">
			<qry:main name="qryGetMisCarpetas" doc="SOURCE">
				<ROWS name="BUSQUEDAS">
					<qry:insert-select name="qryGetMias" doc-path="$SOURCE/DATA"/>
				</ROWS>
			</qry:main>
			<qry:select name="qryGetMias" doc="PARAM">
				<qry:xquery>
					for $r in SQL
			('
				{%? ($PARAM/@top!='')  {% maxsize {%=$PARAM/@top%} %} {% maxsize 5  %} %}				  
				SELECT
				 BUS.oi_busqueda,
				 BUS.d_busqueda,
				 BUS.f_busqueda,
				 BUS.e_cant_res
				 
				 FROM
				 POS28_BUSQUEDAS as BUS
				 
				 WHERE
				 BUS.oi_usuario_sistema = {$PARAM/@oi_usuario_sistema}
				 AND BUS.d_busqueda != \'\'
				 
				 ORDER BY f_busqueda DESC
				 
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="oi_busqueda" value="$r/@oi_busqueda"/>
						<qry:attribute name="d_busqueda" value="$r/@d_busqueda"/>
						<qry:attribute name="f_busqueda" value="format-date($r/@f_busqueda,'dd/mm/yyyy')"/>
						<qry:attribute name="e_cant_res" value="$r/@e_cant_res"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA top=&quot;10&quot; oi_usuario_sistema=&quot;001AA0E914F9-51753AA603CF-00016C825F4D&quot;/&gt;" include="true" name="GET_BUSQUEDAS_P" description="Recuepra las 5 busquedas mas utilizadas">
			<qry:main name="main" doc="SOURCE">
				<ROWS name="BUSQUEDAS">
					<qry:insert-select name="qryBusquedasP" doc-path="$SOURCE/DATA"/>
				</ROWS>
			</qry:main>
			<qry:select name="qryBusquedasP" doc="PARAM">
				<qry:xquery>
					for $r in SQL
			(' 
				{%? ($PARAM/@top!='')  {% maxsize {%=$PARAM/@top%} %} {% maxsize 5  %} %}
				SELECT
				
	      		BUS.d_busqueda,	       
				count(BUS.d_busqueda) as cantBus												
				
				FROM
				POS28_BUSQUEDAS as BUS							
				
				WHERE 
				BUS.d_busqueda != \'\'
				
								
				GROUP BY BUS.d_busqueda                 			 
				
				ORDER BY cantBus desc                      							   							 
			 	
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="d_busqueda" value="$r/@d_busqueda"/>
						<qry:attribute name="cantBus" value="$r/@cantBus"/>
						<qry:insert-select name="qryGetLastId" doc-path="."/>
					</ROW>
				</qry:out>
			</qry:select>
			<qry:select name="qryGetLastId" doc="PARAM">
				<qry:xquery>
					for $r in SQL
			('
			  SELECT
			 	BUS.oi_busqueda
			  
			  FROM
