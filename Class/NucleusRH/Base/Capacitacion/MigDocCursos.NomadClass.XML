<class-package xmlns:qry="nomad_engine.qry" root-class="DOC_CURSO" name="MigDocCursos" DDOBase="NucleusRH\Base\Capacitacion" meta-class="DB" languaje="SP">
	<class name="DOC_CURSO" description="Docentes del Curso" label="Docentes del Curso" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="CYD01_DOC_CURSO.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute null="false" label="C&#243;digo de Curso" name="c_curso" length="30" type="Nomad.NSystem.String" ParentId="1" readonly="false" default="''" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="c_docente" label="C&#243;digo de Docente" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="ImportarDocCursos" description="Importar Docentes de Cursos desde Archivo" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Capacitacion.MigDocCursos.DOC_CURSO" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:CYD01_DOC_CURSO.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
