<class-package xmlns:qry="nomad_engine.qry" root-class="PRESUPUESTO" languaje="SP" meta-class="DB" name="Presupuestos">
	<class size="M" help="Registra los Presupuestos" description="Presupuestos" access="direct" label="Presupuesto" name="PRESUPUESTO">
		<meta-properties>
			<db-properties desc-column="n_presupuesto" code-column="n_presupuesto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="CYD10_PRESUPUESTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="n_presupuesto" code-attr="n_presupuesto" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_presupuesto as oi_presupuesto, t0.n_presupuesto as n_presupuesto, t0.n_presupuesto as CODE, t0.n_presupuesto as TEXT, t0.oi_periodo as oi_periodo, t0.oi_estructura as oi_estructura FROM CYD10_PRESUPUESTOS as t0 ORDER BY oi_presupuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_presupuesto"/>
								<qry:attribute name="n_presupuesto" value="$r/@n_presupuesto"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_periodo" value="$r/@oi_periodo"/>
								<qry:attribute name="oi_estructura" value="$r/@oi_estructura"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_presupuesto as oi_presupuesto FROM CYD10_PRESUPUESTOS as t0 ORDER BY oi_presupuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_presupuesto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Capacitacion.Presupuestos.autoflow:initialize" desc-attr="n_presupuesto" code-attr="n_presupuesto" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_presupuesto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_presupuesto"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Capacitacion.Periodos.PERIODO" null="false" readonly="false" type="aggregation" label="Per&#237;odo" name="oi_periodo" OriginalName="oi_periodo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_periodo"/>
				<form-properties label="Per&#237;odo" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_periodo"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA" null="false" readonly="false" type="aggregation" label="Estructura Organizativa" name="oi_estructura" OriginalName="oi_estructura">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_estructura"/>
				<form-properties label="Estructura Organizativa" automatico="1" show-list="true" showassize="3" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_estructura"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" label="Monto" name="n_presupuesto" OriginalName="n_presupuesto">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Monto" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="numeric(11,3)" column="n_presupuesto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="Key_2" name="Key_2">
			<key-attr assosiation="yes" name="oi_periodo"/>
			<key-attr assosiation="yes" name="oi_estructura"/>
		</key>
		<policy name="REPORT" label="Ejecuci&#243;n de Reportes"/>
	</class>
</class-package>
