<class-package xmlns:qry="nomad_engine.qry" root-class="DOCENTE" languaje="SP" meta-class="DB" name="Docentes">
	<class size="M" help="Registra los Docentes" description="Docentes" access="direct" label="Docente" name="DOCENTE">
		<meta-properties>
			<db-properties desc-column="d_ape_y_nom" code-column="c_docente" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="CYD04_DOCENTES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_ape_y_nom" code-attr="c_docentes" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Personal.Legajo.PERSONAL.INFO"/>
					<qry:include name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_docente as oi_docente, t0.c_docente as c_docente, t0.c_nro_documento as c_nro_documento, t0.d_ape_y_nom as d_ape_y_nom, t0.d_direccion as d_direccion, t0.te_particular as te_particular, t0.te_celular as te_celular, SEC.policy, t0.c_docente as CODE, t0.d_ape_y_nom as TEXT, t0.oi_personal as oi_personal, t0.oi_tipo_documento as oi_tipo_documento FROM CYD04_DOCENTES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Capacitacion.Docentes.DOCENTE\') as SEC JOIN t0.oi_docente LEFT OUTER SEC.id  ORDER BY oi_docente asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_docente"/>
								<qry:attribute name="c_docente" value="$r/@c_docente"/>
								<qry:attribute name="c_nro_documento" value="$r/@c_nro_documento"/>
								<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom"/>
								<qry:attribute name="d_direccion" value="$r/@d_direccion"/>
								<qry:attribute name="te_particular" value="$r/@te_particular"/>
								<qry:attribute name="te_celular" value="$r/@te_celular"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_personal!=''">
									<qry:then>
										<qry:element name="oi_personal">
											<qry:attribute name="OI_FIND" value="$r/@oi_personal"/>
											<qry:insert-select name="NucleusRH.Base.Personal.Legajo.PERSONAL.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_personal" value="'['+oi_personal/ROW/@COD+'] '+oi_personal/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:if test="$r/@oi_tipo_documento!=''">
									<qry:then>
										<qry:element name="oi_tipo_documento">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipo_documento"/>
											<qry:insert-select name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipo_documento" value="'['+oi_tipo_documento/ROW/@COD+'] '+oi_tipo_documento/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_docente as oi_docente, SEC.policy FROM CYD04_DOCENTES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Capacitacion.Docentes.DOCENTE\') as SEC JOIN t0.oi_docente LEFT OUTER SEC.id  ORDER BY oi_docente asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_docente"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_ape_y_nom" code="c_docentes" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Capacitacion.Docentes.autoflow:initialize" desc-attr="d_ape_y_nom" code-attr="c_docente" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_docente">
			<meta-properties>
