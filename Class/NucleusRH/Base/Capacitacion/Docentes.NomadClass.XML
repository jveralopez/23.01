			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo Docente" name="c_docente" OriginalName="c_docente">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo Docente" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_docente"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Personal.Legajo.PERSONAL" null="true" readonly="false" type="aggregation" label="Persona" name="oi_personal" OriginalName="oi_personal">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_personal"/>
				<form-properties label="Persona" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_personal"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO" null="false" readonly="false" type="aggregation" label="Tipo Documento" name="oi_tipo_documento" OriginalName="oi_tipo_documento">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_tipo_documento"/>
				<form-properties label="Tipo Documento" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tipo_documento"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="N&#250;mero de Documento" name="c_nro_documento" OriginalName="c_nro_documento">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="N&#250;mero de Documento" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_nro_documento"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Apellido y Nombre" name="d_ape_y_nom" OriginalName="d_ape_y_nom">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Apellido y Nombre" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_ape_y_nom"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Direcci&#243;n" name="d_direccion" OriginalName="d_direccion">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Direcci&#243;n" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_direccion"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="50" type="Nomad.NSystem.String" label="Tel&#233;fono Particular" name="te_particular" OriginalName="te_particular">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Tel&#233;fono Particular" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(50)" column="te_particular"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="50" type="Nomad.NSystem.String" label="Tel&#233;fono Celular" name="te_celular" OriginalName="te_celular">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Tel&#233;fono Celular" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(50)" column="te_celular"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_CYD04_DO" name="AK_KEY_2_CYD04_DO">
			<key-attr assosiation="no" name="c_docente"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  CYD04_DOCENTES.oi_docente as ID,
  CYD04_DOCENTES.c_docente as COD,
  CYD04_DOCENTES.d_ape_y_nom as DES
from
  CYD04_DOCENTES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Capacitacion.Docentes.DOCENTE.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(CYD04_DOCENTES.oi_docente) as CNT
from
  CYD04_DOCENTES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and CYD04_DOCENTES.oi_docente={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(CYD04_DOCENTES.d_ape_y_nom,{#SOURCE:@TXT_FIND}) or contain(CYD04_DOCENTES.c_docente,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
