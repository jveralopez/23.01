<class-package xmlns:qry="nomad_engine.qry" root-class="CLASE" name="MigClases" DDOBase="NucleusRH\Base\Capacitacion" meta-class="DB" languaje="SP">
	<class description="Clase de Dictados" label="Clase de Dictados" name="CLASE" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="CYD02_CLASES_DICT.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute null="false" label="C&#243;digo de Curso" name="c_curso" length="30" type="Nomad.NSystem.String" ParentId="1" readonly="false" default="''" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="c_dictado" label="C&#243;digo de Dictado" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" type="Nomad.NSystem.DateTime" label="Fecha hora inicio" name="f_fecha_hora_ini" ParentId="1" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy HH:MM"/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.DateTime" null="false" name="f_fecha_hora_fin" label="Fecha Hora Fin" ParentId="1" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy HH:MM"/>
			</meta-properties>
		</attribute>
		<method description="Importar Clases de Dictados desde Archivo" name="ImportarClases" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Capacitacion.MigClases.CLASE" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:CYD02_CLASES_DICT.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
