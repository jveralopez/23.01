<class-package xmlns:qry="nomad_engine.qry" name="MigInscriptos" DDOBase="NucleusRH\Base\Capacitacion" root-class="INSCRIPTO" meta-class="DB" languaje="SP">
	<class description="Inscriptos Dictado" label="Inscriptos Dictado" name="INSCRIPTO" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="CYD02_INSCRIPTOS.csv" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute label="C&#243;digo de Curso" name="c_curso" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Dictado" name="c_dictado" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Empresa" name="c_empresa" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Personal" name="c_personal" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<!--attribute null="false" label="C&#243;digo de Personal" name="c_personal" readonly="false" default="''" length="30" type="Nomad.NSystem.String" OriginalName="d_resp_expedicion">
		<meta-properties>
			<interface-properties/>
		</meta-properties>
	</attribute-->
		<attribute null="false" length="30" type="Nomad.NSystem.String" label="C&#243;digo de Estado" readonly="false" default="''" name="c_estado" OriginalName="e_duracion_ctrato">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" label="Fecha Estado" name="f_estado" readonly="false" default="''" type="Nomad.NSystem.DateTime" description="Fecha Estado" OriginalName="f_vencimiento_doc">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute description="C&#243;digo de Estado de Aprobaci&#243;n" label="C&#243;digo de Estado de Aprobaci&#243;n" name="c_estado_aprob" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" OriginalName="c_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute description="Porcentaje Asistencia" label="Porcentaje Asistencia" name="n_asistencia" null="true" readonly="false" default="''" type="Nomad.NSystem.Double" OriginalName="d_origen_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Observaciones del Inscripto" name="o_inscripto" null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" OriginalName="o_documento_per">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importar Inscriptos desde Archivo" name="ImportarInscriptos" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Capacitacion.MigInscriptos.INSCRIPTO" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:CYD02_INSCRIPTOS.csv')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="QRY_PERSONAL_EMP" declare="&lt;DATOS oiPER=&quot;1&quot; /&gt;&#13;&#10;">
			<qry:main doc="SOURCE">
				<qry:element name="ROW">
					<qry:insert-select name="sql1" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					ORG03_EMPRESAS,
					PER02_PERSONAL_EMP
				JOIN
					PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
				WHERE 
				  PER02_PERSONAL_EMP.oi_personal = {#SOURCE:@oiPER}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
