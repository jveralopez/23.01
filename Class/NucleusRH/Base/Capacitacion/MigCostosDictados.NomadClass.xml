<class-package xmlns:qry="nomad_engine.qry" root-class="COSTO_DICTADO" name="MigCostosDictados" DDOBase="NucleusRH\Base\Capacitacion" meta-class="DB" languaje="SP">
	<class name="COSTO_DICTADO" description="Costos de Dictados" label="Costos de Dictados" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="DATOS.csv" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute label="C&#243;digo de Curso" name="c_curso" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Dictado" name="c_dictado" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de Item de Costo" name="c_item_costo" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Double" precision="3" label="Cantidad" name="n_cantidad" ParentId="1" null="true" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Costo Unitario" name="n_costo_uni" type="Nomad.NSystem.Double" ParentId="1" null="true" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="n_costo_total" label="Costo Total" type="Nomad.NSystem.Double" ParentId="1" null="true" readonly="false" default="''" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="ImportarCostosDictados" description="Importar Costos de Dictados desde Archivo" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Capacitacion.MigCostosDictados.COSTO_DICTADO" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:DATOS.csv')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
