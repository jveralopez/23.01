<class-package xmlns:qry="nomad_engine.qry" name="InterfacePosiciones" DDOBase="NucleusRH\Base\Personal" root-class="POSIC_PER" meta-class="DB" languaje="SP">
	<class label="Interface Posiciones" description="Interface Posiciones" name="POSIC_PER" size="M" note="Registra las categor&#237;as por las que pasa un empleado en su carrera en la Empresa." access="direct">
		<meta-properties>
			<interface-properties file="InterfacePosiciones.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute name="c_empresa" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Empresa" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="e_numero_legajo" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="N&#250;mero de Legajo" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" label="Puesto" name="c_puesto" null="false" readonly="false" default="''" type="Nomad.NSystem.String" OriginalName="c_categoria">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" label="Posici&#243;n" name="c_posicion" null="false" readonly="false" default="''" type="Nomad.NSystem.String" OriginalName="c_categoria">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Fecha Desde Posici&#243;n" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" name="f_desde" OriginalName="f_ingreso">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<method name="ImportarPosiciones" description="Importar Posiciones" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:InterfacePosiciones.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM oi_empresa=&quot;196&quot;/&gt;" name="QRY_VIGENTE">
			<qry:main doc="SOURCE">
				<qry:element name="DATO">
					<qry:attribute name="vigente" value="'0'"/>
					<qry:insert-select doc-path="#SOURCE:PARAM" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
					SELECT 
						ORG03_EMPRESAS.c_empresa, 
						ORG03_EMPRESAS.d_empresa, 
						ORG03_EMPRESAS.oi_unidad_org 
					FROM 
						ORG03_EMPRESAS 
					WHERE 
						ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="empresa" value="'[' + $r/@c_empresa + '] ' + $r/@d_empresa"/>
					<qry:attribute name="c_clase_org" value="$r/@c_empresa + ' POS'"/>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
					<qry:insert-select doc-path="." name="RS2"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			    SELECT 
			    	ORG02_CLASES_ORG.oi_clase_org, 
			    	ORG02_CLASES_ORG.c_clase_org, 
			    	ORG02_CLASES_ORG.d_clase_org, 
			    	ORG02_CLASES_ORG.oi_estructura_org, 
			    	ORG02_CLASES_ORG.o_clase_org,
			    	ORG02_CLASES_ORG.f_desde_vigencia
			    FROM 
			    	ORG02_CLASES_ORG 
			    WHERE 
			    	ORG02_CLASES_ORG.c_clase_org = \'{%=#SOURCE:@c_clase_org%}\'
			    	AND ORG02_CLASES_ORG.c_estado = \'V\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="empresa" value="#SOURCE:@empresa"/>
					<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
					<qry:attribute name="f_desde_vigencia" value="$r/@f_desde_vigencia"/>
					<qry:attribute name="c_clase_org" value="$r/@c_clase_org"/>
					<qry:attribute name="d_clase_org" value="$r/@d_clase_org"/>
					<qry:attribute name="oi_estructura_org" value="$r/@oi_estructura_org"/>
					<qry:attribute name="o_clase_org" value="$r/@o_clase_org"/>
					<qry:attribute name="vigente" value="'1'"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
