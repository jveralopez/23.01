<class-package xmlns:qry="nomad_engine.qry" name="Tipos_Servicio" meta-class="DB" languaje="SP" root-class="TIPO_SERVICIO" DDOBase="NucleusRH\Base\Personal">
	<class name="TIPO_SERVICIO" size="L" description="Tipos Servicio" access="direct" label="Tipo Servicio">
		<meta-properties>
			<db-properties desc-column="d_tipo_servicio" code-column="c_tipo_servicio" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER07_TIPOS_SERV">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipos_serv" code-attr="c_tipos_serv" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_servicio as oi_tipo_servicio, t0.c_tipo_servicio as c_tipo_servicio, t0.d_tipo_servicio as d_tipo_servicio, t0.c_tipo_servicio as CODE, t0.d_tipo_servicio as TEXT FROM PER07_TIPOS_SERV as t0 ORDER BY oi_tipo_servicio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_servicio"/>
								<qry:attribute name="c_tipo_servicio" value="$r/@c_tipo_servicio"/>
								<qry:attribute name="d_tipo_servicio" value="$r/@d_tipo_servicio"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_servicio as oi_tipo_servicio FROM PER07_TIPOS_SERV as t0 ORDER BY oi_tipo_servicio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_servicio"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties desc-attr="d_tipo_servicio" code-attr="c_tipo_servicio" flow-edit="NucleusRH.Base.Personal.Tipos_Servicio.autoflow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_tipo_servicio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_servicio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Tipo de Servicio. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_tipo_servicio" OriginalName="c_tipo_servicio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_servicio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Tipo de Servicio. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_tipo_servicio" OriginalName="d_tipo_servicio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_servicio"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_tipo_servicio" OriginalName="o_tipo_servicio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_tipo_servicio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK_I_TIP_SERV_PER_TIPO" name="AK_I_TIP_SERV_PER_TIPO">
			<key-attr assosiation="no" name="c_tipo_servicio"/>
		</key>
	</class>
</class-package>
