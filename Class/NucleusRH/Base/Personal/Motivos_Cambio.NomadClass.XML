<class-package xmlns:qry="nomad_engine.qry" name="Motivos_Cambio" meta-class="DB" languaje="SP" root-class="MOTIVO_CAMBIO" DDOBase="NucleusRH\Base\Personal">
	<class name="MOTIVO_CAMBIO" size="L" note="Mantiene los posibles motivos de cambio, ya sea de puesto, posicion , centro de costos, etc." description="Motivos Cambio" access="direct" label="Motivo Cambio">
		<meta-properties>
			<db-properties desc-column="d_motivo_cambio" code-column="c_motivo_cambio" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER05_MOT_CAMBIO">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_mot_cambio" code-attr="c_mot_cambio" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_motivo_cambio as oi_motivo_cambio, t0.c_motivo_cambio as c_motivo_cambio, t0.d_motivo_cambio as d_motivo_cambio, t0.c_motivo_cambio as CODE, t0.d_motivo_cambio as TEXT FROM PER05_MOT_CAMBIO as t0 ORDER BY oi_motivo_cambio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_motivo_cambio"/>
								<qry:attribute name="c_motivo_cambio" value="$r/@c_motivo_cambio"/>
								<qry:attribute name="d_motivo_cambio" value="$r/@d_motivo_cambio"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_motivo_cambio as oi_motivo_cambio FROM PER05_MOT_CAMBIO as t0 ORDER BY oi_motivo_cambio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_motivo_cambio"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Personal.Motivos_Cambio.flow:initialize" desc-attr="d_motivo_cambio" code-attr="c_motivo_cambio" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_motivo_cambio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_motivo_cambio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Motivo de Cambio. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_motivo_cambio" OriginalName="c_motivo_cambio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_motivo_cambio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Motivo de Cambio. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_motivo_cambio" OriginalName="d_motivo_cambio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_motivo_cambio"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_motivo_cambio" OriginalName="o_motivo_cambio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_motivo_cambio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK_I_MOT_CBIO_PER_MOTI" name="AK_I_MOT_CBIO_PER_MOTI">
			<key-attr assosiation="no" name="c_motivo_cambio"/>
		</key>
		<resource declare="&lt;PARAM OI_FIND=&quot;&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
SELECT 
PER05_MOT_CAMBIO.oi_motivo_cambio,
PER05_MOT_CAMBIO.d_motivo_cambio
FROM
PER05_MOT_CAMBIO
WHERE
1=1
{%?($PARAM/@OI_FIND!=''){% AND ORG03_EMPRESAS.oi_empresa = {$PARAM/@OI_FIND} %}{% %}%}
ORDER BY
oi_motivo_cambio ASC	
')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_motivo_cambio"/>
						<qry:attribute name="DES" value="$r/@d_motivo_cambio"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
