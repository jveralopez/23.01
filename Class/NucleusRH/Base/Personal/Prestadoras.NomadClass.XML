			<guia-properties desc-attr="d_plan_presta" code-attr="c_plan_presta" requiered-filter="false" enabled-filter="true" enabled-edit="false" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_plan_presta">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_plan_presta"/>
			</meta-properties>
		</attribute>
		<attribute ParentId="1" null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Prestadora" name="oi_prestadora" OriginalName="oi_prestadora">
			<meta-properties>
				<form-properties show-list="false" visible="false" find-include="false" automatico="1" label="OID Prestadora" read-only="false" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="oi_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Plan de la Prestadora. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_plan_presta" OriginalName="c_plan_presta">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_plan_presta"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n del Plan de la Prestadora. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_plan_presta" OriginalName="d_plan_presta">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_plan_presta"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_plan_presta" OriginalName="o_plan_presta">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_plan_presta"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="yes" descr="AK_I_PLAN_PREST_PER_PLAN" name="AK_I_PLAN_PREST_PER_PLAN">
			<key-attr assosiation="no" name="c_plan_presta"/>
		</key>
	</class>
</class-package>
