<class-package xmlns:qry="nomad_engine.qry" name="Prestadoras" meta-class="DB" languaje="SP" root-class="PRESTADORA" DDOBase="NucleusRH\Base\Personal">
	<class size="L" note="Mantiene las distintas Prestadoras por las que puede optar el Personal." description="Prestadoras" access="direct" label="Prestadora" name="PRESTADORA">
		<meta-properties>
			<db-properties desc-column="d_prestadora" code-column="c_prestadora" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER17_PRESTADORAS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_prestadoras" code-attr="c_prestadoras" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_prestadora as oi_prestadora, t0.c_prestadora as c_prestadora, t0.d_prestadora as d_prestadora, t0.c_prestadora as CODE, t0.d_prestadora as TEXT FROM PER17_PRESTADORAS as t0 ORDER BY oi_prestadora asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_prestadora"/>
								<qry:attribute name="c_prestadora" value="$r/@c_prestadora"/>
								<qry:attribute name="d_prestadora" value="$r/@d_prestadora"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_prestadora as oi_prestadora FROM PER17_PRESTADORAS as t0 ORDER BY oi_prestadora asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_prestadora"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Personal.Prestadoras.autoflow:initialize" desc-attr="d_prestadora" code-attr="c_prestadora" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_prestadora">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Prestadora. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_prestadora" OriginalName="c_prestadora">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Prestadora. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_prestadora" OriginalName="d_prestadora">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="15" type="Nomad.NSystem.String" description="Descripci&#243;n Corta de Prestadora. Puede ser alfanum&#233;rico de hasta 50 caracteres." label="Descripci&#243;n Corta" name="dc_prestadora" OriginalName="dc_prestadora">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Descripci&#243;n Corta" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(15)" column="dc_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_prestadora" OriginalName="o_prestadora">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_prestadora"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<assosiation description="Mantiene los distintos Planes por Prestadora." label="Planes Prestadora" name="PLANES_PREST" class="PLAN_PRESTA" type="composition" access="public">
			<meta-properties>
				<db-properties cascade="delete" not-found="exception" optimistic-lock="true" not-null="true" unique="true" insert="false" update="false" from-column="oi_prestadora"/>
				<form-properties label="Planes Prestadora" automatico="1" show-list="false" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="0..*" from="1">
				<db-properties to-column="oi_prestadora"/>
			</multiplicity>
		</assosiation>
		<key parent-include="no" descr="AK_I_PREST_PER_PRES" name="AK_I_PREST_PER_PRES">
			<key-attr assosiation="no" name="c_prestadora"/>
		</key>
	</class>
	<class label="Prestadora - Plan Prestadora" size="L" note="Mantiene los distintos Planes por Prestadora." description="Planes Prestadora" access="direct" name="PLAN_PRESTA">
		<meta-properties>
