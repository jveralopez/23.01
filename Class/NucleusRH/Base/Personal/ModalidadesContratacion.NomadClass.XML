			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_mod_contr"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_mod_contr" OriginalName="d_mod_contr">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_mod_contr"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Vigencia Desde" name="f_vigencia_desde" OriginalName="f_vigencia_desde">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Vigencia Desde" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_vigencia_desde"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Vigencia Hasta" name="f_vigencia_hasta" OriginalName="f_vigencia_hasta">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Vigencia Hasta" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_vigencia_hasta"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" label="Observaciones" name="o_mod_contr" OriginalName="o_mod_contr">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_mod_contr"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_CURSOS" name="AK1_ORG_CURSOS">
			<key-attr assosiation="no" name="c_mod_contr"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER35_MOD_CONTR.oi_mod_contr as ID,
  PER35_MOD_CONTR.c_mod_contr as COD,
  PER35_MOD_CONTR.d_mod_contr as DES
from
  PER35_MOD_CONTR
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER35_MOD_CONTR.oi_mod_contr) as CNT
from
  PER35_MOD_CONTR
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER35_MOD_CONTR.oi_mod_contr={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER35_MOD_CONTR.d_mod_contr,{#SOURCE:@TXT_FIND}) or contain(PER35_MOD_CONTR.c_mod_contr,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
