<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Personal" name="ModalidadesContratacion" root-class="MOD_CONTR" meta-class="DB" languaje="SP">
	<class size="M" note="Tabla donde se registran las modalidades de contratacion\\&#13;&#10;" help="Tabla donde se registran las modalidades de contratacion" description="Modalidad de Contratacion" access="direct" label="Modalidad" name="MOD_CONTR">
		<meta-properties>
			<db-properties desc-column="d_mod_contr" code-column="c_mod_contr" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER35_MOD_CONTR">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_mod_contr" code-attr="c_mod_contr" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mod_contr as oi_mod_contr, t0.c_mod_contr as c_mod_contr, t0.d_mod_contr as d_mod_contr, t0.f_vigencia_desde as f_vigencia_desde, t0.f_vigencia_hasta as f_vigencia_hasta, SEC.policy, t0.c_mod_contr as CODE, t0.d_mod_contr as TEXT FROM PER35_MOD_CONTR as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR\') as SEC JOIN t0.oi_mod_contr LEFT OUTER SEC.id  ORDER BY oi_mod_contr asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mod_contr"/>
								<qry:attribute name="c_mod_contr" value="$r/@c_mod_contr"/>
								<qry:attribute name="d_mod_contr" value="$r/@d_mod_contr"/>
								<qry:attribute name="f_vigencia_desde" value="$r/@f_vigencia_desde"/>
								<qry:attribute name="f_vigencia_hasta" value="$r/@f_vigencia_hasta"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mod_contr as oi_mod_contr, SEC.policy FROM PER35_MOD_CONTR as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.ModalidadesContratacion.MOD_CONTR\') as SEC JOIN t0.oi_mod_contr LEFT OUTER SEC.id  ORDER BY oi_mod_contr asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mod_contr"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_mod_contr" code="c_mod_contr" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Personal.ModalidadesContratacion.autoflow:initialize" desc-attr="d_mod_contr" code-attr="c_mod_contr" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_mod_contr">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_mod_contr"/>
			</meta-properties>
