<class-package xmlns:qry="nomad_engine.qry" name="TiposPersonal" meta-class="DB" languaje="SP" root-class="TIPO_PERSONAL" DDOBase="NucleusRH\Base\Personal">
	<class name="TIPO_PERSONAL" size="M" note="Mantiene los distintos Tipos de Personal.\\&#13;&#10;" help="Mantiene los distintos Tipos de Personal." description="Tipos Personal" access="direct" label="Tipo Personal">
		<meta-properties>
			<db-properties desc-column="d_tipo_personal" code-column="c_tipo_personal" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER11_TIPOS_PERS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipos_pers" code-attr="c_tipos_pers" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_personal as oi_tipo_personal, t0.c_tipo_personal as c_tipo_personal, t0.d_tipo_personal as d_tipo_personal, t0.l_bloqueo as l_bloqueo, SEC.policy, t0.c_tipo_personal as CODE, t0.d_tipo_personal as TEXT FROM PER11_TIPOS_PERS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL\') as SEC JOIN t0.oi_tipo_personal LEFT OUTER SEC.id  ORDER BY oi_tipo_personal asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_personal"/>
								<qry:attribute name="c_tipo_personal" value="$r/@c_tipo_personal"/>
								<qry:attribute name="d_tipo_personal" value="$r/@d_tipo_personal"/>
								<qry:attribute name="l_bloqueo" value="iif($r/@l_bloqueo='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_personal as oi_tipo_personal, SEC.policy FROM PER11_TIPOS_PERS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL\') as SEC JOIN t0.oi_tipo_personal LEFT OUTER SEC.id  ORDER BY oi_tipo_personal asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_personal"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_tipos_pers" code="c_tipos_pers" automatico="1"/>
			<guia-properties desc-attr="d_tipo_personal" code-attr="c_tipo_personal" flow-edit="NucleusRH.Base.Personal.TiposPersonal.flow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
