				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_personal"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Tipo de Personal." label="C&#243;digo" name="c_tipo_personal" OriginalName="c_tipo_personal">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_personal"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Tipo de Personal." label="Descripci&#243;n" name="d_tipo_personal" OriginalName="d_tipo_personal">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_personal"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_tipo_personal" OriginalName="o_tipo_personal">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_tipo_personal"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="'0'" type="Nomad.NSystem.Boolean" label="Bloqueo" name="l_bloqueo" OriginalName="l_bloqueo">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Bloqueo" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_bloqueo"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_I_TIPO_PER_PER_TIPO" name="AK_I_TIPO_PER_PER_TIPO">
			<key-attr assosiation="no" name="c_tipo_personal"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER11_TIPOS_PERS.oi_tipo_personal as ID,
  PER11_TIPOS_PERS.c_tipo_personal as COD,
  PER11_TIPOS_PERS.d_tipo_personal as DES
from
  PER11_TIPOS_PERS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER11_TIPOS_PERS.oi_tipo_personal) as CNT
from
  PER11_TIPOS_PERS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER11_TIPOS_PERS.oi_tipo_personal={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER11_TIPOS_PERS.d_tipo_personal,{#SOURCE:@TXT_FIND}) or contain(PER11_TIPOS_PERS.c_tipo_personal,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
