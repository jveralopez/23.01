				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_agencia"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_agencia" OriginalName="d_agencia">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_agencia"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Domicilio" name="d_domicilio" OriginalName="d_domicilio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Domicilio" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_domicilio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK_AGENCIAS" name="AK_AGENCIAS">
			<key-attr assosiation="no" name="c_agencia"/>
		</key>
	</class>
</class-package>
