							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_agencia as oi_agencia, t0.c_agencia as c_agencia, t0.d_agencia as d_agencia, t0.d_domicilio as d_domicilio, t0.c_agencia as CODE, t0.d_agencia as TEXT FROM PER32_AGENCIAS as t0 ORDER BY oi_agencia asc')/ROWS/ROW
