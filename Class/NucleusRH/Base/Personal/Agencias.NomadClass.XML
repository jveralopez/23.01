<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Personal" root-class="AGENCIA" languaje="SP" meta-class="DB" name="Agencias">
	<class size="L" description="Agencias Personal" access="direct" label="Agencia" name="AGENCIA">
		<meta-properties>
			<db-properties desc-column="d_agencia" code-column="c_agencia" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER32_AGENCIAS">
				<security table="NMD_SECURITY"/>
