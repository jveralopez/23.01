<class-package xmlns:qry="nomad_engine.qry" root-class="SOLICITUD" name="WFSolicitud" meta-class="DB" languaje="SP">
	<class label="Solicitud de cambio de Datos Personales" description="Solicitudes" access="direct" name="SOLICITUD">
		<meta-properties/>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_solicitud">
			<meta-properties/>
		</attribute>
		<attribute ParentJoin="VAC01_PERSONAL.oi_personal_emp" ParentId="1" null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Persona" name="oi_personal" OriginalName="oi_personal_emp">
			<meta-properties/>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="DNI" name="e_dni" OriginalName="e_dias_solicitud">
			<meta-properties/>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="256" type="Nomad.NSystem.String" label="e-mail" name="d_mail" OriginalName="o_solicitud">
			<meta-properties/>
		</attribute>
		<method label="Iniciar Valores" name="IniciarValores" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument pass="byref" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" name="XMLData"/>
			</arguments>
		</method>
		<method label="Enviar Solicitud" name="EnviarSolicitud" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument pass="byval" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" name="XMLData"/>
			</arguments>
		</method>
		<method label="Aprobar Solicitud" name="AprobarSolicitud" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument pass="byval" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" name="XMLData"/>
				<argument pass="byval" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" name="XMLList"/>
			</arguments>
		</method>
		<assosiation type="composition" class="VALOR" label="Valores" name="VALORES" manual="1">
			<meta-properties/>
			<multiplicity to="*" from="1"/>
		</assosiation>
		<resource declare="&lt;DATOS id=&quot;229&quot; /&gt;" name="Datos">
			<qry:main doc="PARAM">
				<qry:element name="D">
					<qry:insert-select name="Datos Personales" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="Datos Personales" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			select       
				p.oi_personal,              
				p.d_nombres,
				p.d_apellido,
				p.c_nro_documento,
				p.c_nro_cuil,
				p.d_apellido_materno,
				p.c_sexo,
				p.oi_grupo_sanguineo,
				p.d_email,
				p.te_celular,
				p.f_nacim,
				p.oi_local_nacim,
				p.oi_nacionalidad
			from	
				PER01_PERSONAL as p,
				PER02_PERSONAL_emp as e
			join
				p.oi_personal inner e.oi_personal
			where
				e.oi_personal_emp={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="fnd" value="1"/>
					<qry:attribute name="oi_personal" value="$r/@oi_personal"/>
					<C cod="d_nombres" lbl="Nombres">
						<qry:attribute name="val" value="$r/@d_nombres"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_apellido" lbl="Apellido">
						<qry:attribute name="val" value="$r/@d_apellido"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_apellido_materno" lbl="Apellido Materno">
						<qry:attribute name="val" value="$r/@d_apellido_materno"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="c_nro_documento" lbl="Nro de Documento">
						<qry:attribute name="val" value="$r/@c_nro_documento"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="c_nro_cuil" lbl="CUIL/CUIT">
						<qry:attribute name="val" value="$r/@c_nro_cuil"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="c_sexo" lbl="Sexo" typ="combo">
						<qry:attribute name="val" value="$r/@c_sexo"/>
						<O val="F" txt="Femenino"/>
						<O val="M" txt="Masculino"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="oi_grupo_sanguineo" lbl="Grupo Sanguineo" typ="fk-GRUPOSANGUINEO">
						<qry:attribute name="val" value="$r/@oi_grupo_sanguineo"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_email" lbl="E-Mail">
						<qry:attribute name="val" value="$r/@d_email"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="te_celular" lbl="Celular">
						<qry:attribute name="val" value="$r/@te_celular"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="f_nacim" lbl="Fecha de Nacimiento" typ="date">
						<qry:attribute name="val" value="$r/@f_nacim"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="oi_local_nacim" lbl="Localidad de Nacimiento" typ="fk-LOCALIDAD">
						<qry:attribute name="val" value="$r/@oi_local_nacim"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="oi_nacionalidad" lbl="Nacionalidad" typ="fk-NACIONALIDAD">
						<qry:attribute name="val" value="$r/@oi_nacionalidad"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<qry:insert-select name="Domicilio" doc-path="#PARAM:"/>
					<qry:if test="@fnd='1'">
						<qry:then>
							<C cod="oi_tipo_domicilio" lbl="Tipo de Domicilio" typ="fk-TIPODOMICILIO"/>
							<C cod="c_postal" lbl="Codigo Postal"/>
							<C cod="d_calle" lbl="Calle"/>
							<C cod="e_numero" lbl="Numero"/>
							<C cod="d_piso" lbl="Piso"/>
							<C cod="d_departamento" lbl="Departamento"/>
							<C cod="d_entre_calle_1" lbl="Entre Calle 1"/>
							<C cod="d_entre_calle_2" lbl="Entre Calle 2"/>
							<C cod="te_1" lbl="Telefono"/>
							<C cod="d_partido" lbl="Partido"/>
							<C cod="oi_localidad" lbl="Localidad" typ="fk-LOCALIDAD"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="Domicilio" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				select 
					D.oi_tipo_domicilio,
					D.c_postal,
					D.d_calle,
					D.e_numero,
					D.d_piso,
					D.d_departamento,
					D.d_entre_calle_1,
					D.d_entre_calle_2,
					D.oi_localidad,
					D.te_1,
					D.d_partido
				from 
					per01_domic_per as D,
					per02_personal_emp as P
				where 
					D.oi_personal=P.oi_personal and
					D.l_domic_fiscal=1 and P.oi_personal_emp={#PARAM:@id}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="fnd" value="0"/>
					<C cod="oi_tipo_domicilio" lbl="Tipo de Domicilio" typ="fk-TIPODOMICILIO">
						<qry:attribute name="val" value="$r/@oi_tipo_domicilio"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="c_postal" lbl="Codigo Postal">
						<qry:attribute name="val" value="$r/@c_postal"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_calle" lbl="Calle">
						<qry:attribute name="val" value="$r/@d_calle"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="e_numero" lbl="Numero">
						<qry:attribute name="val" value="$r/@e_numero"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_piso" lbl="Piso">
						<qry:attribute name="val" value="$r/@d_piso"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_departamento" lbl="Departamento">
						<qry:attribute name="val" value="$r/@d_departamento"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_entre_calle_1" lbl="Entre Calle 1">
						<qry:attribute name="val" value="$r/@d_entre_calle_1"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_entre_calle_2" lbl="Entre Calle 2">
						<qry:attribute name="val" value="$r/@d_entre_calle_2"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="te_1" lbl="Telefono">
						<qry:attribute name="val" value="$r/@te_1"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="d_partido" lbl="Partido">
						<qry:attribute name="val" value="$r/@d_partido"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
					<C cod="oi_localidad" lbl="Localidad" typ="fk-LOCALIDAD">
						<qry:attribute name="val" value="$r/@oi_localidad"/>
						<qry:insert-select name="PrettyValue" doc-path="."/>
					</C>
				</qry:out>
			</qry:select>
			<qry:select name="PrettyValue" doc="PARAM">
				<qry:out>
					<qry:append-doc name="LOC" doc-path="."/>
					<qry:switch test="#PARAM:@typ">
						<qry:case value="combo">
							<qry:attribute name="dsp" value="@val"/>
							<qry:insert-select name="PrettyCombo" doc-path="#PARAM:O[@val=#LOC:@val]"/>
						</qry:case>
						<qry:case value="date">
							<qry:attribute name="dsp" value="format_date(@val,'dd/mm/yyyy')"/>
						</qry:case>
						<qry:case value="fk-GRUPOSANGUINEO">
							<qry:insert-select name="GruposSanguineos" doc-path="."/>
						</qry:case>
						<qry:case value="fk-NACIONALIDAD">
							<qry:insert-select name="Nacionalidad" doc-path="."/>
						</qry:case>
						<qry:case value="fk-TIPODOMICILIO">
							<qry:insert-select name="TipoDomicilio" doc-path="."/>
						</qry:case>
						<qry:case value="fk-LOCALIDAD">
							<qry:insert-select name="Localidad" doc-path="."/>
						</qry:case>
						<qry:default>
							<qry:attribute name="dsp" value="@val"/>
						</qry:default>
					</qry:switch>
				</qry:out>
			</qry:select>
			<qry:select name="PrettyCombo" doc="PARAM">
				<qry:out>
					<qry:attribute name="dsp" value="#PARAM:@txt"/>
				</qry:out>
			</qry:select>
			<qry:select name="GruposSanguineos" doc="DOC">
				<qry:xquery>
					for $r in SQL('
				select g.c_grupo_sanguineo from PER10_GRUPOS_SANG as g where g.oi_grupo_sanguineo={#DOC:@val}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="dsp" value="$r/@c_grupo_sanguineo"/>
				</qry:out>
			</qry:select>
			<qry:select name="Nacionalidad" doc="DOC">
				<qry:xquery>
					for $r in SQL('select  N.d_nacionalidad from ORG12_NACIONALID as N where N.oi_nacionalidad={#DOC:@val}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="dsp" value="$r/@d_nacionalidad"/>
				</qry:out>
			</qry:select>
			<qry:select name="TipoDomicilio" doc="DOC">
				<qry:xquery>
					for $r in SQL('select T.d_tipo_domicilio from PER09_TIPOS_DOMIC as T where T.oi_tipo_domicilio={#DOC:@val}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="dsp" value="$r/@d_tipo_domicilio"/>
				</qry:out>
			</qry:select>
			<qry:select name="Localidad" doc="DOC">
				<qry:xquery>
					for $r in SQL('
				select  
				  A.d_pais, 
				  B.d_provincia, 
				  C.d_localidad 
				from 
				  ORG35_PAISES as A, 
				  ORG35_PROVINCIAS as B, 
				  ORG19_LOCALIDADES as C 
				where 
				  B.oi_provincia = C.oi_provincia and 
				  A.oi_pais=B.oi_pais and 
				  C.oi_localidad={#DOC:@val}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="dsp" value="$r/@d_localidad+'-'+$r/@d_provincia+'-'+$r/@d_pais"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
	<class description="Valores de los Campos de Solicitud" access="direct" label="Valor" name="VALOR">
		<meta-properties/>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_solicitud">
			<meta-properties/>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="32" type="Nomad.NSystem.String" label="Codigo" name="c_code" OriginalName="o_solicitud">
			<meta-properties/>
		</attribute>
		<attribute null="false" label="Valor" name="d_value" readonly="false" default="''" length="256" type="Nomad.NSystem.String" OriginalName="o_solicitud">
			<meta-properties/>
		</attribute>
	</class>
</class-package>
