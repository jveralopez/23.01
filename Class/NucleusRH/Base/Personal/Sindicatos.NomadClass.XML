<class-package xmlns:qry="nomad_engine.qry" name="Sindicatos" meta-class="DB" languaje="SP" root-class="SINDICATO" DDOBase="NucleusRH\Base\Personal">
	<class size="L" help="Mantiene los Sindicatos a los que est&#225;n afiliados los Empleados." description="Sindicatos" access="direct" label="Sindicato" name="SINDICATO">
		<meta-properties>
			<db-properties desc-column="d_sindicato" code-column="c_sindicato" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER30_SINDICATOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_sindicatos" code-attr="c_sindicatos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_sindicato as oi_sindicato, t0.c_sindicato as c_sindicato, t0.d_sindicato as d_sindicato, t0.d_interfaz as d_interfaz,t0.d_interfaz_gen as d_interfaz_gen, SEC.policy, t0.c_sindicato as CODE, t0.d_sindicato as TEXT, t0.oi_convenio as oi_convenio FROM PER30_SINDICATOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Sindicatos.SINDICATO\') as SEC JOIN t0.oi_sindicato LEFT OUTER SEC.id  ORDER BY oi_sindicato asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_sindicato"/>
								<qry:attribute name="c_sindicato" value="$r/@c_sindicato"/>
								<qry:attribute name="d_sindicato" value="$r/@d_sindicato"/>
								<qry:attribute name="d_interfaz" value="$r/@d_interfaz"/>
								<qry:attribute name="d_interfaz_gen" value="$r/@d_interfaz_gen"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_convenio!=''">
									<qry:then>
										<qry:element name="oi_convenio">
											<qry:attribute name="OI_FIND" value="$r/@oi_convenio"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Convenios.CONVENIO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_convenio" value="'['+oi_convenio/ROW/@COD+'] '+oi_convenio/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_sindicato as oi_sindicato, SEC.policy FROM PER30_SINDICATOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Sindicatos.SINDICATO\') as SEC JOIN t0.oi_sindicato LEFT OUTER SEC.id  ORDER BY oi_sindicato asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_sindicato"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_sindicatos" code="c_sindicatos" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Personal.Sindicatos.autoflow:initialize" desc-attr="d_sindicato" code-attr="c_sindicato" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_sindicato">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_sindicato"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Sindicato. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_sindicato" OriginalName="c_sindicato">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_sindicato"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Sindicato. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_sindicato" OriginalName="d_sindicato">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_sindicato"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Interfaz" name="d_interfaz" OriginalName="d_interfaz">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Interfaz" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_interfaz"/>
			</meta-properties>
		</attribute>
		<attribute label="Interfaz general" name="d_interfaz_gen" null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" OriginalName="d_interfaz">
			<meta-properties>
				<form-properties label="Interfaz general" show-list="true" find-include="true" automatico="1" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties column="d_interfaz_gen" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Convenios.CONVENIO" null="true" readonly="false" type="aggregation" label="Convenio" name="oi_convenio" OriginalName="oi_convenio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_convenio"/>
				<form-properties label="Convenio" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_convenio"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_sindicato" OriginalName="o_sindicato">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_sindicato"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_I_SIND_PER_SIND" name="AK_I_SIND_PER_SIND">
			<key-attr assosiation="no" name="c_sindicato"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER30_SINDICATOS.oi_sindicato as ID,
  PER30_SINDICATOS.c_sindicato as COD,
  PER30_SINDICATOS.d_sindicato as DES
from
  PER30_SINDICATOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER30_SINDICATOS.oi_sindicato) as CNT
from
  PER30_SINDICATOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER30_SINDICATOS.oi_sindicato={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER30_SINDICATOS.d_sindicato,{#SOURCE:@TXT_FIND}) or contain(PER30_SINDICATOS.c_sindicato,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM OI_PARENT=&quot;SUTEP_INT,ESTRELLA_ALTA&quot; TXT_FIND=&quot;&quot; WHERE=&quot;&quot; START=&quot;0&quot; LEN=&quot;13&quot; ORDERBY=&quot;COD&quot;/&gt;" name="INTERFACES">
			<qry:main doc="SOURCE" name="">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.QUERY">
				<qry:xquery>
					for $r in FILEIO('INTERFACE-DEF\\sindicatos.def.xml')/INTERFACE-TYPE/INTERFACE[@code =  #SOURCE:@value or @code = #SOURCE:@OI_FIND]
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@code" name="ID"/>
						<qry:attribute value="$r/@code" name="COD"/>
						<qry:attribute value="$r/@desc" name="DES"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in SPLIT('1;{%=#SOURCE:@oi_parent%}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="NucleusRH.Base.Personal.Sindicatos.SINDICATO.QUERY" doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
