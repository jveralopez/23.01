<class-package xmlns:qry="nomad_engine.qry" name="InterfaceRemuneraciones" DDOBase="NucleusRH\Base\Personal" root-class="REMUN_PER" meta-class="DB" languaje="SP">
	<class label="Interface Remuneraciones" description="Interface Remuneraciones" name="REMUN_PER" size="M" note="Registra las categor&#237;as por las que pasa un empleado en su carrera en la Empresa." access="direct">
		<meta-properties>
			<interface-properties file="InterfaceRemuneraciones.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute name="e_numero_legajo" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="N&#250;mero de Legajo" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Remuneraci&#243;n" name="n_remun_per" null="false" readonly="false" default="''" length="0" type="Nomad.NSystem.Double" OriginalName="c_categoria">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha Desde" name="f_desde" OriginalName="f_ingreso">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute length="2" label="Codigo motivo de cambio" default="''" readonly="false" null="true" type="Nomad.NSystem.String" name="c_motivo_cambio" manual="1">
			<meta-properties>
