<class-package xmlns:qry="nomad_engine.qry" name="Tipos_Documento" meta-class="DB" languaje="SP" root-class="TIPO_DOCUMENTO" DDOBase="NucleusRH\Base\Personal">
	<class name="TIPO_DOCUMENTO" size="M" description="Tipos de Documento" access="direct" label="Tipo Documento">
		<meta-properties>
			<db-properties desc-column="d_tipo_documento" code-column="c_tipo_documento" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER20_TIPOS_DOC">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipos_doc" code-attr="c_tipos_doc" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_documento as oi_tipo_documento, t0.c_tipo_documento as c_tipo_documento, t0.d_tipo_documento as d_tipo_documento, SEC.policy, t0.c_tipo_documento as CODE, t0.d_tipo_documento as TEXT FROM PER20_TIPOS_DOC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO\') as SEC JOIN t0.oi_tipo_documento LEFT OUTER SEC.id  ORDER BY oi_tipo_documento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_documento"/>
								<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento"/>
								<qry:attribute name="d_tipo_documento" value="$r/@d_tipo_documento"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_documento as oi_tipo_documento, SEC.policy FROM PER20_TIPOS_DOC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO\') as SEC JOIN t0.oi_tipo_documento LEFT OUTER SEC.id  ORDER BY oi_tipo_documento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_documento"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_tipos_doc" code="c_tipos_doc" automatico="1"/>
			<guia-properties desc-attr="d_tipo_documento" code-attr="c_tipo_documento" flow-edit="NucleusRH.Base.Personal.Tipos_Documento.autoflow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_tipo_documento">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_documento"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_tipo_documento" OriginalName="c_tipo_documento">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_documento"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_tipo_documento" OriginalName="d_tipo_documento">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_documento"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_tipo_documento" OriginalName="o_tipo_documento">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_tipo_documento"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_I_TIPO_DOC_PER_TIPO" name="AK_I_TIPO_DOC_PER_TIPO">
			<key-attr assosiation="no" name="c_tipo_documento"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER20_TIPOS_DOC.oi_tipo_documento as ID,
  PER20_TIPOS_DOC.c_tipo_documento as COD,
  PER20_TIPOS_DOC.d_tipo_documento as DES
from
  PER20_TIPOS_DOC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER20_TIPOS_DOC.oi_tipo_documento) as CNT
from
  PER20_TIPOS_DOC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER20_TIPOS_DOC.oi_tipo_documento={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER20_TIPOS_DOC.d_tipo_documento,{#SOURCE:@TXT_FIND}) or contain(PER20_TIPOS_DOC.c_tipo_documento,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM oi_tipo_documento=&quot;1&quot; /&gt;" description="Retorna informacion sobre el tipo de documento. Pueden agregarse campos." name="infoTipoDoc">
			<qry:main doc="SOURCE">
				<qry:element name="AVISO">
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					td.oi_tipo_documento,
					td.c_tipo_documento,
					td.d_tipo_documento,
					td.o_tipo_documento
					
				FROM 
					PER20_TIPOS_DOC as td
					
				WHERE 
					td.oi_tipo_documento = {#SOURCE:@oi_tipo_documento}
					
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_tipo_documento" value="$r/@oi_tipo_documento"/>
					<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento"/>
					<qry:attribute name="d_tipo_documento" value="$r/@d_tipo_documento"/>
					<qry:attribute name="o_tipo_documento" value="$r/@o_tipo_documento"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM PARENT=&quot;1&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT 
					PER20_TIPOS_DOC.oi_tipo_documento,
					PER20_TIPOS_DOC.d_tipo_documento
				FROM
					PER20_TIPOS_DOC
				ORDER BY
					d_tipo_documento ASC
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_tipo_documento"/>
						<qry:attribute name="DES" value="$r/@d_tipo_documento"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
