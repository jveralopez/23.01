<class-package xmlns:qry="nomad_engine.qry" root-class="MATERIA" name="Materias" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Personal">
	<class size="M" description="Materias de Cargo" access="direct" label="Materia" name="MATERIA">
		<meta-properties>
			<db-properties desc-column="d_materia" code-column="c_materia" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER39_MATERIAS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_materias" code-attr="c_materias" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_materia as oi_materia, t0.c_materia as c_materia, t0.d_materia as d_materia, SEC.policy, t0.c_materia as CODE, t0.d_materia as TEXT FROM PER39_MATERIAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Materias.MATERIA\') as SEC JOIN t0.oi_materia LEFT OUTER SEC.id  ORDER BY oi_materia asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_materia"/>
								<qry:attribute name="c_materia" value="$r/@c_materia"/>
								<qry:attribute name="d_materia" value="$r/@d_materia"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
