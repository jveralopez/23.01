						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_materia as oi_materia, SEC.policy FROM PER39_MATERIAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Materias.MATERIA\') as SEC JOIN t0.oi_materia LEFT OUTER SEC.id  ORDER BY oi_materia asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_materia"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_materia" code-attr="c_materia" desc="d_materias" code="c_materias" automatico="1"/>
		</meta-properties>
