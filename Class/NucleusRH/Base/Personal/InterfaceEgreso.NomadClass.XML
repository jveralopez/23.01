<class-package xmlns:qry="nomad_engine.qry" root-class="EgresoLegajos" name="InterfaceEgreso" DDOBase="NucleusRH\Base\Personal" meta-class="DB" languaje="SP">
	<class name="EgresoLegajos" label="Interface Remuneraciones" description="Interface Egreso" size="M" note="Registra las categor&#237;as por las que pasa un empleado en su carrera en la Empresa." access="direct">
		<meta-properties>
			<interface-properties file="InterfaceEgreso.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute name="e_numero_legajo" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="N&#250;mero de Legajo" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Fecha Egreso" name="f_egreso" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_ingreso">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute name="c_motivo_egreso" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Motivo de Egreso" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="Egreso" description="Egreso" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.String" pass="byval" name="oi_empresa"/>
			</arguments>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:InterfaceEgreso.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
