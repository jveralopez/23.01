			<form-properties binary="NONE" desc-attr="d_indic_activo" code-attr="c_indic_activo" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
