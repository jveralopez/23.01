							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_indic_activo as oi_indic_activo, t0.c_indic_activo as c_indic_activo, t0.d_indic_activo as d_indic_activo, t0.c_indic_activo as CODE, t0.d_indic_activo as TEXT FROM PER21_INDIC_ACTIVO as t0 ORDER BY oi_indic_activo asc')/ROWS/ROW
