<class-package xmlns:qry="nomad_engine.qry" name="Indicadores_Activo" meta-class="DB" languaje="SP" root-class="INDIC_ACTIVO" DDOBase="NucleusRH\Base\Personal">
	<class size="L" note="Mantiene los Estado que puede tener un empleado en la empresa." description="Indicador Activo" access="direct" label="Indicador Activo" name="INDIC_ACTIVO">
		<meta-properties>
			<db-properties desc-column="d_indic_activo" code-column="c_indic_activo" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER21_INDIC_ACTIVO">
				<security table="NMD_SECURITY"/>
