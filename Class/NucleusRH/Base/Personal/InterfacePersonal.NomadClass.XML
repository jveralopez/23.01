		<resource declare="&lt;DATA&#13;&#10;&#9;TABLE=&quot;PER20_TIPOS_DOC&quot;&#13;&#10;&#9;COLRET=&quot;oi_tipo_documento&quot;&#13;&#10;&#9;COLFND=&quot;c_tipo_documento&quot;&#13;&#10;&#9;COLVAL=&quot;DNI&quot;&#13;&#10;/&gt;&#13;&#10;&#9;" name="qry_findOI">
			<qry:main doc="PARAM">
				<qry:element name="RESULT">
					<qry:insert-select name="SQL" doc-path="#PARAM:/DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT {%=#PARAM:@TABLE %}.{%=#PARAM:@COLRET %} AS VALUE 
						FROM {%=#PARAM:@TABLE %} 
						WHERE {%=#PARAM:@TABLE %}.{%=#PARAM:@COLFND %}= {#PARAM:@COLVAL}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
