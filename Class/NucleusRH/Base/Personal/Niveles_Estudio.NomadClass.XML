		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER12_NIVELES_EST.oi_nivel_estudio as ID,
  PER12_NIVELES_EST.c_nivel_estudio as COD,
  PER12_NIVELES_EST.d_nivel_estudio as DES
from
  PER12_NIVELES_EST
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER12_NIVELES_EST.oi_nivel_estudio) as CNT
from
  PER12_NIVELES_EST
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER12_NIVELES_EST.oi_nivel_estudio={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER12_NIVELES_EST.d_nivel_estudio,{#SOURCE:@TXT_FIND}) or contain(PER12_NIVELES_EST.c_nivel_estudio,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAMS /&gt;" description="Retorna los niveles de estudios" name="QRY_NivelesEstudios">
			<qry:main doc="SOURCE">
				<qry:element name="NIVELES_ESTUDIO">
					<qry:insert-select name="sql1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
					n.oi_nivel_estudio,
					n.c_nivel_estudio,
					n.d_nivel_estudio
				
				FROM 
					PER12_NIVELES_EST as n

				WHERE
					1 = 1
					{%? (#SOURCE:PARAMS/@oi_nivel_estudio = '') 
							{% %}
							{% AND n.oi_nivel_estudio IN ({%=#SOURCE:PARAMS/@oi_nivel_estudio%}) %}
					%}
						
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="NIVEL_ESTUDIO">
						<qry:attribute name="d_nivel_estudio" value="$r/@d_nivel_estudio"/>
						<qry:attribute name="c_nivel_estudio" value="$r/@c_nivel_estudio"/>
						<qry:attribute name="oi_nivel_estudio" value="$r/@oi_nivel_estudio"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM PARENT=&quot;1&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT 
					PER12_NIVELES_EST.oi_nivel_estudio,
					PER12_NIVELES_EST.d_nivel_estudio
				FROM
