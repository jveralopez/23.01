					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_nivel_estudio as oi_nivel_estudio, SEC.policy FROM PER12_NIVELES_EST as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO\') as SEC JOIN t0.oi_nivel_estudio LEFT OUTER SEC.id  ORDER BY oi_nivel_estudio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_nivel_estudio"/>
