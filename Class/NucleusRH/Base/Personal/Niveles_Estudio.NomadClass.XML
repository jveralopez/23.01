							for $r in sql('SELECT t0.oi_nivel_estudio as oi_nivel_estudio, t0.c_nivel_estudio as c_nivel_estudio, t0.d_nivel_estudio as d_nivel_estudio, t0.e_peso as e_peso, SEC.policy, t0.c_nivel_estudio as CODE, t0.d_nivel_estudio as TEXT FROM PER12_NIVELES_EST as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO\') as SEC JOIN t0.oi_nivel_estudio LEFT OUTER SEC.id  ORDER BY oi_nivel_estudio asc')/ROWS/ROW
