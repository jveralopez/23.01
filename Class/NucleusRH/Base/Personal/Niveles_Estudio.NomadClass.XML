								<qry:attribute name="id" value="$r/@oi_nivel_estudio"/>
								<qry:attribute name="c_nivel_estudio" value="$r/@c_nivel_estudio"/>
								<qry:attribute name="d_nivel_estudio" value="$r/@d_nivel_estudio"/>
								<qry:attribute name="e_peso" value="$r/@e_peso"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
