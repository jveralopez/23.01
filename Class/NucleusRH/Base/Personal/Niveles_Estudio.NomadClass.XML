		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Nivel de Estudio." label="Descripci&#243;n" name="d_nivel_estudio" OriginalName="d_nivel_estudio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_nivel_estudio"/>
