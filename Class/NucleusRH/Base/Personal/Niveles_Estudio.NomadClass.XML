				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_nivel_estudio"/>
						<qry:attribute name="DES" value="$r/@d_nivel_estudio"/>
					</qry:element>
				</qry:out>
