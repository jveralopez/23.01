<class-package xmlns:qry="nomad_engine.qry" name="Niveles_Escolaridad" meta-class="DB" languaje="SP" root-class="NIVEL_ESCOL" DDOBase="NucleusRH\Base\Personal">
	<class size="M" help="Mantiene los distintos Niveles de Escolaridad que puede tener el Personal." description="Niveles Escolaridad" access="direct" label="Nivel Escolar" name="NIVEL_ESCOL">
		<meta-properties>
			<db-properties desc-column="d_nivel_escol" code-column="c_nivel_escol" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER08_NIVELES_ESC">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_niveles_esc" code-attr="c_niveles_esc" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_nivel_escol as oi_nivel_escol, t0.c_nivel_escol as c_nivel_escol, t0.d_nivel_escol as d_nivel_escol, t0.l_req_estudio as l_req_estudio, SEC.policy, t0.c_nivel_escol as CODE, t0.d_nivel_escol as TEXT FROM PER08_NIVELES_ESC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL\') as SEC JOIN t0.oi_nivel_escol LEFT OUTER SEC.id  ORDER BY oi_nivel_escol asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_nivel_escol"/>
								<qry:attribute name="c_nivel_escol" value="$r/@c_nivel_escol"/>
								<qry:attribute name="d_nivel_escol" value="$r/@d_nivel_escol"/>
								<qry:attribute name="l_req_estudio" value="iif($r/@l_req_estudio='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_nivel_escol as oi_nivel_escol, SEC.policy FROM PER08_NIVELES_ESC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL\') as SEC JOIN t0.oi_nivel_escol LEFT OUTER SEC.id  ORDER BY oi_nivel_escol asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_nivel_escol"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_niveles_esc" code="c_niveles_esc" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Personal.Niveles_Escolaridad.autoflow:initialize" desc-attr="d_nivel_escol" code-attr="c_nivel_escol" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_nivel_escol">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_nivel_escol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Nivel de Escolaridad. Puede ser alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_nivel_escol" OriginalName="c_nivel_escol">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_nivel_escol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Nivel de Escolaridad. Puede ser alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_nivel_escol" OriginalName="d_nivel_escol">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_nivel_escol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Requiere Estudio" name="l_req_estudio" OriginalName="l_req_estudio">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Requiere Estudio" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_req_estudio"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_nivel_escol" OriginalName="o_nivel_escol">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_nivel_escol"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_I_NIV_ESC_PER_NIVE" name="AK_I_NIV_ESC_PER_NIVE">
			<key-attr assosiation="no" name="c_nivel_escol"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PER08_NIVELES_ESC.oi_nivel_escol as ID,
  PER08_NIVELES_ESC.c_nivel_escol as COD,
  PER08_NIVELES_ESC.d_nivel_escol as DES
from
  PER08_NIVELES_ESC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Personal.Niveles_Escolaridad.NIVEL_ESCOL.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PER08_NIVELES_ESC.oi_nivel_escol) as CNT
from
  PER08_NIVELES_ESC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER08_NIVELES_ESC.oi_nivel_escol={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER08_NIVELES_ESC.d_nivel_escol,{#SOURCE:@TXT_FIND}) or contain(PER08_NIVELES_ESC.c_nivel_escol,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM PARENT=&quot;1&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT 
					PER08_NIVELES_ESC.oi_nivel_escol,
					PER08_NIVELES_ESC.d_nivel_escol
				FROM
					PER08_NIVELES_ESC
				ORDER BY
					d_nivel_escol ASC
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_nivel_escol"/>
						<qry:attribute name="DES" value="$r/@d_nivel_escol"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
