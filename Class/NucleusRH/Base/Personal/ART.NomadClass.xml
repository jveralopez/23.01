<class-package xmlns:qry="nomad_engine.qry" root-class="ART" name="ART" meta-class="DB" languaje="SP">
	<class size="M" description="ART" access="direct" label="ART" name="ART">
		<meta-properties>
			<db-properties desc-column="d_art" code-column="c_art" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PER33_ART">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_art" code-attr="c_art" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_art as oi_art, t0.c_art as c_art, t0.d_art as d_art, SEC.policy, t0.c_art as CODE, t0.d_art as TEXT FROM PER33_ART as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.ART.ART\') as SEC JOIN t0.oi_art LEFT OUTER SEC.id  ORDER BY oi_art asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_art"/>
								<qry:attribute name="c_art" value="$r/@c_art"/>
								<qry:attribute name="d_art" value="$r/@d_art"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_art as oi_art, SEC.policy FROM PER33_ART as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.ART.ART\') as SEC JOIN t0.oi_art LEFT OUTER SEC.id  ORDER BY oi_art asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_art"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_art" code="c_art" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Personal.ART.autoflow:initialize" desc-attr="d_art" code-attr="c_art" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_art">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_art"/>
			</meta-properties>
		</attribute>
