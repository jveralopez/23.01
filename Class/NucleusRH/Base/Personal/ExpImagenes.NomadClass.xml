<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Personal" root-class="EXPORTAR" name="ExpImagenes" meta-class="DB" languaje="SP">
	<class description="Exportacoin" label="Exportar" access="direct" size="M" name="EXPORTAR">
		<meta-properties/>
		<method modifier="static" access="public" label="metodo que exporta imagenes" name="ExportarImagenes">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="xmlIds"/>
			</arguments>
		</method>
		<resource include="true" name="QRY_FOTOS">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_SPLIT" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_SPLIT" doc="SOURCE">
				<qry:xquery>
					for $r in split('50;{%= string(#SOURCE:ROW/@id) %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="QRY_FOTOS" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_FOTOS" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			
			SELECT PER01_PERSONAL.oi_foto,PER01_PERSONAL.c_nro_documento,PER20_TIPOS_DOC.c_tipo_documento
			FROM PER01_PERSONAL,                                          
			PER20_TIPOS_DOC 
			JOIN
			PER01_PERSONAL.oi_tipo_documento INNER PER20_TIPOS_DOC.oi_tipo_documento
			where PER01_PERSONAL.oi_personal in ({%=#SOURCE:@value%})
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@oi_foto !=''">
						<qry:then>
							<qry:insert-element doc-path="$r"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
