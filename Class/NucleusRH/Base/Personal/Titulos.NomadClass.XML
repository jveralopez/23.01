						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_titulo as oi_titulo, t0.c_titulo as c_titulo, t0.d_titulo as d_titulo, SEC.policy, t0.c_titulo as CODE, t0.d_titulo as TEXT FROM PER04_TITULOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Titulos.TITULO\') as SEC JOIN t0.oi_titulo LEFT OUTER SEC.id  ORDER BY oi_titulo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_titulo"/>
								<qry:attribute name="c_titulo" value="$r/@c_titulo"/>
								<qry:attribute name="d_titulo" value="$r/@d_titulo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
