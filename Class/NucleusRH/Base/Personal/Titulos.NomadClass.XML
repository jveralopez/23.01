					for $r in SQL('
select
  Count(PER04_TITULOS.oi_titulo) as CNT
from
  PER04_TITULOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PER04_TITULOS.oi_titulo={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PER04_TITULOS.d_titulo,{#SOURCE:@TXT_FIND}) or contain(PER04_TITULOS.c_titulo,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
