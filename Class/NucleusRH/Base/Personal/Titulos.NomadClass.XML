							for $r in sql('SELECT t0.oi_titulo as oi_titulo, SEC.policy FROM PER04_TITULOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Personal.Titulos.TITULO\') as SEC JOIN t0.oi_titulo LEFT OUTER SEC.id  ORDER BY oi_titulo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_titulo"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
