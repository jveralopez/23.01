								<qry:attribute name="d_apellido" value="$r/@d_apellido" type="Nomad.NSystem.String"/>
								<qry:attribute name="d_nombres" value="$r/@d_nombres" type="Nomad.NSystem.String"/>
								<qry:attribute name="d_ape_y_nom" value="$r/@d_ape_y_nom" type="Nomad.NSystem.String"/>
								<qry:attribute name="d_empresa" value="$r/@d_empresa" type="Nomad.NSystem.String"/>
								<qry:element name="oi_tipo_documento">
									<qry:attribute name="value" value="$r/@oi_tipo_documento"/>
									<qry:insert-select name="sql2" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_tipo_documento_descr" value="./oi_tipo_documento/@code+'-'+./oi_tipo_documento/@text"/>
								<qry:element name="oi_foto">
									<qry:attribute name="value" value="$r/@oi_foto"/>
									<qry:insert-select name="sql3" doc-path="."/>
								</qry:element>
								<qry:attribute name="oi_foto_descr" value="./oi_foto/@code+'-'+./oi_foto/@text"/>
							</qry:element>
						</qry:out>
					</qry:select>
					<qry:select doc="PARAM" name="sql2">
						<qry:xquery>
							for $r in table('SELECT PER20_TIPOS_DOC.oi_tipo_documento oi_tipo_documento, PER20_TIPOS_DOC.c_tipo_documento c_tipo_documento, PER20_TIPOS_DOC.d_tipo_documento d_tipo_documento FROM PER20_TIPOS_DOC WHERE PER20_TIPOS_DOC.oi_tipo_documento={#PARAM:@value}')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:attribute name="id" value="$r/@oi_tipo_documento" type="Nomad.NSystem.Int"/>
							<qry:attribute name="c_tipo_documento" value="$r/@c_tipo_documento" type="Nomad.NSystem.String"/>
							<qry:attribute name="code" value="$r/@c_tipo_documento" type="Nomad.NSystem.String"/>
							<qry:attribute name="d_tipo_documento" value="$r/@d_tipo_documento" type="Nomad.NSystem.String"/>
							<qry:attribute name="text" value="$r/@d_tipo_documento" type="Nomad.NSystem.String"/>
						</qry:out>
					</qry:select>
					<qry:select doc="PARAM" name="sql3">
						<qry:xquery>
							for $r in table('SELECT PER19_IMAGENES.oi_imagen_per oi_imagen_per, PER19_IMAGENES.o_imagen o_imagen FROM PER19_IMAGENES WHERE PER19_IMAGENES.oi_imagen_per={#PARAM:@value}')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:attribute name="id" value="$r/@oi_imagen_per" type="Nomad.NSystem.Int"/>
							<qry:attribute name="code" value="$r/@oi_imagen_per" type="Nomad.NSystem.Int"/>
							<qry:attribute name="FILE" value="$r/@o_imagen" type="Nomad.NSystem.String"/>
							<qry:attribute name="text" value="$r/@o_imagen" type="Nomad.NSystem.String"/>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main>
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in table('SELECT VIS02_VISITANTES.oi_visitante oi_visitante FROM VIS02_VISITANTES ORDER BY VIS02_VISITANTES.oi_visitante ASC')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="id" value="$r/@oi_visitante" type="Nomad.NSystem.Int"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
		</meta-properties>
