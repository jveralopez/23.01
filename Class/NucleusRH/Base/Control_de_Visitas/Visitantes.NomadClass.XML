		<method modifier="final" access="public" name="GuardarVisitante">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE" type="lib">
					//TENGO EL VISITANTE QUE ESTOY CREANDO
NomadEnvironment.GetTrace().Info("VISITANTE -- " + this.SerializeAll());

//TENGO QUE RECUPERAR LA DESCRIPCION DEL TIPO DE DOCUMENTO. LEVANTO EL DDO DE TIPO DE DOCUMENTO
NucleusRH.Base.Personal.Tipos_Documento.TIPO_DOCUMENTO ddoTipoDoc;
ddoTipoDoc = this.Getoi_tipo_documento();
NomadEnvironment.GetTrace().Info("TIPO DOC -- " + ddoTipoDoc.SerializeAll());

//ARMO EL CODIGO DEL VISTANTE EN BASE A LA DESCRIPICION DEL TIPO DE DOCUMENTO Y EL NRO DE DOCUMENTO
this.c_visitante = ddoTipoDoc.c_tipo_documento.ToString() + this.c_nro_documento.ToString();

//GUARDO EL VISITANTE
NomadEnvironment.GetCurrentTransaction().SaveRefresh(this);
				</dotnet11-properties>
			</meta-properties>
			<arguments/>
		</method>
		<method modifier="static" access="public" name="CopyImg">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument pass="byval" type="Nomad.NSystem.String" name="visitaID"/>
			</arguments>
		</method>
		<resource declare="&lt;DATO oi_visita=&quot;8&quot;/&gt;" name="QRY_IMGS">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:DATO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql(' 
					SELECT VIS02_VISITANTES.oi_visitante, VIS02_VISITANTES.oi_foto, PER19_IMAGENES.o_imagen  
					FROM 
					VIS01_VISITAS_VIS,
					VIS02_VISITANTES, 
					PER19_IMAGENES
					JOIN 
					VIS01_VISITAS_VIS.oi_visitante INNER VIS02_VISITANTES.oi_visitante,
					VIS02_VISITANTES.oi_foto LEFT OUTER PER19_IMAGENES.oi_imagen_per
					WHERE
					VIS01_VISITAS_VIS.oi_visita = {#SOURCE:@oi_visita}
			')/ROWS/ROW
				</qry:xquery>
				<!--asterisco modificado -->
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_visitante" value="$r/@oi_visitante" type="Nomad.NSystem.Int"/>
						<qry:attribute name="oi_foto" value="$r/@oi_foto" type="Nomad.NSystem.Int"/>
						<qry:attribute name="o_imagen" value="$r/@o_imagen" type="Nomad.NSystem.Int"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<method modifier="final" access="public" name="LoadPhoto">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE" type="lib">
					//BUSCO AL ARCHIVO QUE GENERA EL USUARIO CUANDO UTILIZA LA CAMARA DE FOTOS
string fPath = Nomad.NSystem.Proxy.NomadProxy.GetProxy().RunPath + "TEMP\\";
string uName = Nomad.NSystem.Proxy.NomadProxy.GetProxy().UserName;
string fName = fPath + "Foto_" + uName + ".jpg";

NomadEnvironment.GetTrace().Info("DATOS -- " +fPath+ " - " +uName+ " - " +fName);

//PIDO EL STREAM DEL ARCHIVO PARA PASARSELO AL PUTFILE   
try
{
	System.IO.StreamReader sr = new System.IO.StreamReader(fName);	
	//GUARDO EL OBJETO IMAGEN EN LA BASE DE DATOS Y LE PEGO SU ID AL CAMPO OI_FOTO DEL VISITANTE
	this.oi_foto = Nomad.NSystem.Proxy.NomadProxy.GetProxy().BINService().PutFile("NucleusRH.Base.Personal.Imagenes.HEAD", "Foto_user.jpg", sr.BaseStream).Id;
	sr.Close();	
	System.IO.File.Delete(fName);	
}
catch
{
	throw new NomadAppException("No hay ninguna imagen disponible.");	
}
				</dotnet11-properties>
			</meta-properties>
			<arguments/>
		</method>
		<resource declare="&lt;DATA TXT_FIND=&quot;col&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  VIS02_VISITANTES.oi_visitante as ID,
  VIS02_VISITANTES.c_visitante as COD,
  VIS02_VISITANTES.d_ape_y_nom as DES
from
  VIS02_VISITANTES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %}  

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Control_de_Visitas.Visitantes.VISITANTE.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(VIS02_VISITANTES.oi_visitante) as CNT
from
  VIS02_VISITANTES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and VIS02_VISITANTES.oi_visitante={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(VIS02_VISITANTES.d_ape_y_nom,{#SOURCE:@TXT_FIND}) or contain(VIS02_VISITANTES.c_visitante,{#SOURCE:@TXT_FIND})) %} %}

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
