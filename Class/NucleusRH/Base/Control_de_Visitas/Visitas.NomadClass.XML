					for $r in sql(' 
				SELECT 
					Count(VIS01_VISITAS_VIS.oi_visita_vis) as CNT
				FROM 
					VIS01_VISITAS_VIS
				WHERE 
				 	VIS01_VISITAS_VIS.oi_visitante = {#SOURCE:@oi_visitante}
				 	AND
				 	ISNOTNULL(VIS01_VISITAS_VIS.f_fechahora_ent)
				 	AND                                         
				 	ISNULL(VIS01_VISITAS_VIS.f_fechahora_sal)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
