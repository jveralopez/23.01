		<resource name="QRY_CREDS">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT
					VIS01_VISITAS_VIS.d_credencial,
					VIS01_VISITAS_VIS.oi_visita_vis
				FROM 
					VIS01_VISITAS, 
					VIS01_VISITAS_VIS
				JOIN 
					VIS01_VISITAS.oi_visita INNER VIS01_VISITAS_VIS.oi_visita
				WHERE 
					VIS01_VISITAS_VIS.d_credencial != \'\'
					AND 
					(
						ISNULL(VIS01_VISITAS_VIS.f_fechahora_sal)
						OR 
						VIS01_VISITAS_VIS.f_fechahora_sal &gt; now()
					)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_visita_vis" value="$r/@oi_visita_vis"/>
						<qry:attribute name="d_credencial" value="$r/@d_credencial"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="QRY_DEL_VISITAS">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql(' 
		 			SELECT 
		 				ORG26_PARAMETROS.d_valor 
		 			FROM 
		 				ORG26_PARAMETROS 
		 			WHERE 
		 				ORG26_PARAMETROS.c_parametro = \'MinDel\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="RS2" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="RS2">
				<qry:xquery>
					for $r in sql(' 
				SELECT 
					VIS01_VISITAS.oi_visita
				FROM 
					VIS01_VISITAS, 
					VIS01_VISITAS_VIS
				JOIN
					VIS01_VISITAS.oi_visita INNER VIS01_VISITAS_VIS.oi_visita
				WHERE 
					DATEDIFF(VIS01_VISITAS.f_fechahora_ent_es, now()) &gt; {#SOURCE:@d_valor}
					AND ISNULL(VIS01_VISITAS_VIS.f_fechahora_ent)
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_visita" name="oi_visita"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
