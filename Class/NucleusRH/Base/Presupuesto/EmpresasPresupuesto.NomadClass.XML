<class-package xmlns:qry="nomad_engine.qry" root-class="EMPRESA" name="EmpresasPresupuesto" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Presupuesto">
	<class size="M" help="Tabla donde se registran los presupuestos." description="Empresas Presupuesto" extends="NucleusRH.Base.Organizacion.Empresas.EMPRESA" access="direct" label="Empresa" name="EMPRESA">
		<meta-properties>
			<db-properties desc-column="d_empresa" code-column="c_empresa" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRE13_EMPRESAS"/>
			<form-properties generate="true" binary="NONE" desc-attr="d_empresas" code-attr="c_empresas" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Presupuesto.TiposEmpleador.TIPO_EMP.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_empresa as oi_empresa, t1.oi_empresa as B_oi_empresa, t1.c_empresa as B_c_empresa, t1.d_empresa as B_d_empresa, SEC.policy, t1.c_empresa as CODE, t1.d_empresa as TEXT, t0.oi_tpo_empleador as oi_tpo_empleador FROM PRE13_EMPRESAS as t0,ORG03_EMPRESAS as t1,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC JOIN t0.oi_empresa RIGHT OUTER t1.oi_empresa,t1.oi_empresa LEFT OUTER SEC.id  ORDER BY oi_empresa asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="ID-PRE13_EMPRESAS" value="$r/@oi_empresa"/>
								<qry:attribute name="id" value="$r/@B_oi_empresa"/>
								<qry:attribute name="c_empresa" value="$r/@B_c_empresa"/>
								<qry:attribute name="d_empresa" value="$r/@B_d_empresa"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tpo_empleador!=''">
									<qry:then>
										<qry:element name="oi_tpo_empleador">
											<qry:attribute name="OI_FIND" value="$r/@oi_tpo_empleador"/>
											<qry:insert-select name="NucleusRH.Base.Presupuesto.TiposEmpleador.TIPO_EMP.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tpo_empleador" value="'['+oi_tpo_empleador/ROW/@COD+'] '+oi_tpo_empleador/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_empresa as oi_empresa, t1.oi_empresa as B_oi_empresa, SEC.policy FROM PRE13_EMPRESAS as t0,ORG03_EMPRESAS as t1,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Empresas.EMPRESA\') as SEC JOIN t0.oi_empresa RIGHT OUTER t1.oi_empresa,t1.oi_empresa LEFT OUTER SEC.id  ORDER BY oi_empresa asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="ID-PRE13_EMPRESAS" value="$r/@oi_empresa"/>
								<qry:attribute name="id" value="$r/@B_oi_empresa"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_empresas" code="c_empresas" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Presupuesto.EmpresasPresupuesto.autoflow:initialize" desc-attr="d_empresa" code-attr="c_empresa" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_empresa">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_empresa"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Presupuesto.TiposEmpleador.TIPO_EMP" null="true" readonly="false" type="aggregation" label="Tipo Empleador" name="oi_tpo_empleador" OriginalName="oi_tpo_empleador">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_tpo_empleador"/>
				<form-properties label="Tipo Empleador" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_tipo_emp"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaci&#243;n" name="o_empresa_pres" OriginalName="o_empresa_pres">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaci&#243;n" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_empresa_pres"/>
			</meta-properties>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.EmpresasPresupuesto.EMPRESA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.EmpresasPresupuesto.EMPRESA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.EmpresasPresupuesto.EMPRESA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRE13_EMPRESAS.oi_empresa as ID,
  PRE13_EMPRESAS.c_empresa as COD,
  PRE13_EMPRESAS.d_empresa as DES
from
  PRE13_EMPRESAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.EmpresasPresupuesto.EMPRESA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE13_EMPRESAS.oi_empresa) as CNT
from
  PRE13_EMPRESAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE13_EMPRESAS.oi_empresa={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE13_EMPRESAS.d_empresa,{#SOURCE:@TXT_FIND}) or contain(PRE13_EMPRESAS.c_empresa,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
