			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.Vacaciones.DIAS_VACA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE21_DIAS_VACA.oi_dias_vaca) as CNT
from
  PRE21_DIAS_VACA
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE21_DIAS_VACA.oi_dias_vaca={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE21_DIAS_VACA.e_ant_hasta,{#SOURCE:@TXT_FIND}) or contain(PRE21_DIAS_VACA.e_ant_desde,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
