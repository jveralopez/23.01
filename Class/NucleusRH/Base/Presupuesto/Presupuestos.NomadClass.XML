<class-package xmlns:qry="nomad_engine.qry" root-class="PRESUPUESTO" name="Presupuestos" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Presupuesto">
	<class size="M" help="Tabla donde se registran los presupuestos." description="Presupuesto" access="direct" label="Presupuesto" name="PRESUPUESTO">
		<meta-properties>
			<db-properties desc-column="d_presupuesto" code-column="c_presupuesto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRE12_PRESUPUESTO">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_presupuesto" code-attr="c_presupuesto" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Presupuesto.AniosFiscales.ANIO_FISCAL.INFO"/>
					<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_presupuesto as oi_presupuesto, t0.c_presupuesto as c_presupuesto, t0.d_presupuesto as d_presupuesto, t0.c_estado as c_estado, t0.f_alta as f_alta, t0.f_cierre as f_cierre, t0.e_seguimiento as e_seguimiento, SEC.policy, t0.c_presupuesto as CODE, t0.d_presupuesto as TEXT, t0.oi_anio_fiscal as oi_anio_fiscal, t0.oi_empresa as oi_empresa FROM PRE12_PRESUPUESTO as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO\') as SEC JOIN t0.oi_presupuesto LEFT OUTER SEC.id  ORDER BY oi_presupuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_presupuesto"/>
								<qry:attribute name="c_presupuesto" value="$r/@c_presupuesto"/>
								<qry:attribute name="d_presupuesto" value="$r/@d_presupuesto"/>
								<qry:attribute name="c_estado" value="$r/@c_estado"/>
								<qry:attribute name="f_alta" value="$r/@f_alta"/>
								<qry:attribute name="f_cierre" value="$r/@f_cierre"/>
								<qry:attribute name="e_seguimiento" value="$r/@e_seguimiento"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_anio_fiscal!=''">
									<qry:then>
										<qry:element name="oi_anio_fiscal">
											<qry:attribute name="OI_FIND" value="$r/@oi_anio_fiscal"/>
											<qry:insert-select name="NucleusRH.Base.Presupuesto.AniosFiscales.ANIO_FISCAL.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_anio_fiscal" value="'['+oi_anio_fiscal/ROW/@COD+'] '+oi_anio_fiscal/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:if test="$r/@oi_empresa!=''">
									<qry:then>
										<qry:element name="oi_empresa">
											<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_presupuesto as oi_presupuesto, SEC.policy FROM PRE12_PRESUPUESTO as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO\') as SEC JOIN t0.oi_presupuesto LEFT OUTER SEC.id  ORDER BY oi_presupuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_presupuesto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_presupuesto" code="c_presupuesto" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Presupuesto.Presupuestos.autoflow:initialize" desc-attr="d_presupuesto" code-attr="c_presupuesto" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_presupuesto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_presupuesto"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Presupuesto.AniosFiscales.ANIO_FISCAL" null="false" readonly="false" type="aggregation" label="Anio Fiscal" name="oi_anio_fiscal" OriginalName="oi_anio_fiscal">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_anio_fiscal"/>
				<form-properties label="Anio Fiscal" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_anio_fiscal"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Organizacion.Empresas.EMPRESA" null="false" readonly="false" type="aggregation" label="Empresa" name="oi_empresa" OriginalName="oi_empresa">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_empresa"/>
				<form-properties label="Empresa" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_empresa"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_presupuesto" OriginalName="c_presupuesto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_presupuesto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_presupuesto" OriginalName="d_presupuesto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_presupuesto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="'A'" length="30" type="Nomad.NSystem.String" description="C&#243;digo del Curso. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="Estado" name="c_estado" OriginalName="c_estado">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.c_estado" show-list="true" find-include="true" automatico="1" label="Estado" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_estado"/>
			</meta-properties>
		</attribute>
		<enum name="c_estado">
			<enum-value label="Abierto" value="A"/>
			<enum-value label="Pendiente" value="P"/>
			<enum-value label="Cerrado" value="C"/>
		</enum>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha de Alta" name="f_alta" OriginalName="f_alta">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha de Alta" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_alta"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha de Cierre" name="f_cierre" OriginalName="f_cierre">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha de Cierre" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_cierre"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.Int" label="Nivel de Seguimiento Actual" name="e_seguimiento" OriginalName="e_seguimiento">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Nivel de Seguimiento Actual" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="int" column="e_seguimiento"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" label="Observaciones" name="o_presupuesto" OriginalName="o_presupuesto">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_presupuesto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_CURSOS" name="AK1_ORG_CURSOS">
			<key-attr assosiation="yes" name="oi_anio_fiscal"/>
			<key-attr assosiation="no" name="c_presupuesto"/>
			<key-attr assosiation="yes" name="oi_empresa"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRE12_PRESUPUESTO.oi_presupuesto as ID,
  PRE12_PRESUPUESTO.c_presupuesto as COD,
  PRE12_PRESUPUESTO.d_presupuesto as DES
from
  PRE12_PRESUPUESTO
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.Presupuestos.PRESUPUESTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE12_PRESUPUESTO.oi_presupuesto) as CNT
from
  PRE12_PRESUPUESTO
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE12_PRESUPUESTO.oi_presupuesto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE12_PRESUPUESTO.d_presupuesto,{#SOURCE:@TXT_FIND}) or contain(PRE12_PRESUPUESTO.c_presupuesto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
