<class-package xmlns:qry="nomad_engine.qry" name="EstructuraReportes" root-class="EST_REPORTE" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Presupuesto">
	<class size="M" help="Aqui se definen la estructura de los reportes." description="Estructura del reporte" access="direct" label="Estructura Reporte" name="EST_REPORTE">
		<meta-properties>
			<db-properties desc-column="d_est_reporte" code-column="e_est_reporte" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRE06_EST_REPORTE">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_est_reporte" code-attr="e_est_reporte" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Presupuesto.DefinicionReportes.DEF_REPORTE.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_est_reporte as oi_est_reporte, t0.e_est_reporte as e_est_reporte, t0.d_est_reporte as d_est_reporte, t0.c_estado as c_estado, SEC.policy, t0.e_est_reporte as CODE, t0.d_est_reporte as TEXT, t0.oi_def_reporte as oi_def_reporte, t0.oi_nodo as oi_nodo FROM PRE06_EST_REPORTE as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE\') as SEC JOIN t0.oi_est_reporte LEFT OUTER SEC.id  ORDER BY oi_est_reporte asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_est_reporte"/>
								<qry:attribute name="e_est_reporte" value="$r/@e_est_reporte"/>
								<qry:attribute name="d_est_reporte" value="$r/@d_est_reporte"/>
								<qry:attribute name="c_estado" value="$r/@c_estado"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_def_reporte!=''">
									<qry:then>
										<qry:element name="oi_def_reporte">
											<qry:attribute name="OI_FIND" value="$r/@oi_def_reporte"/>
											<qry:insert-select name="NucleusRH.Base.Presupuesto.DefinicionReportes.DEF_REPORTE.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_def_reporte" value="'['+oi_def_reporte/ROW/@COD+'] '+oi_def_reporte/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_est_reporte as oi_est_reporte, SEC.policy FROM PRE06_EST_REPORTE as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE\') as SEC JOIN t0.oi_est_reporte LEFT OUTER SEC.id  ORDER BY oi_est_reporte asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_est_reporte"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_est_reporte" code="e_est_reporte" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Presupuesto.EstructuraReportes.autoflow:initialize" desc-attr="d_est_reporte" code-attr="e_est_reporte" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_est_reporte">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_est_reporte"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Presupuesto.DefinicionReportes.DEF_REPORTE" null="false" readonly="false" type="aggregation" label="Definicion Reporte" name="oi_def_reporte" OriginalName="oi_def_reporte">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_def_reporte"/>
				<form-properties label="Definicion Reporte" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_def_reporte"/>
			</multiplicity>
		</assosiation>
		<assosiation null="false" readonly="false" class="NODO" type="composition" label="Nodo Raiz" name="oi_nodo" OriginalName="oi_nodo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_nodo"/>
				<form-properties label="Nodo Raiz" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_nodo"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="true" default="'Autom&#225;tico'" type="Nomad.NSystem.Int" label="C&#243;digo" name="e_est_reporte" OriginalName="e_est_reporte">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="C&#243;digo" lock="false" read-only="true" visible="true" mandatory="true"/>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="true" unique="false" generator="child-secuence" id="false" nullable="false" type="int" column="e_est_reporte"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_est_reporte" OriginalName="d_est_reporte">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_est_reporte"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" label="Observaciones" name="o_est_reporte" OriginalName="o_est_reporte">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_est_reporte"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="'A'" length="30" type="Nomad.NSystem.String" label="Estado" name="c_estado" OriginalName="c_estado">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.c_estado" show-list="true" find-include="true" automatico="1" label="Estado" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(30)" column="c_estado"/>
			</meta-properties>
		</attribute>
		<enum name="c_estado">
			<enum-value label="Abierto" value="A"/>
			<enum-value label="Cerrado" value="C"/>
		</enum>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_CURSOS" name="AK1_ORG_CURSOS">
			<key-attr assosiation="no" name="e_est_reporte"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRE06_EST_REPORTE.oi_est_reporte as ID,
  PRE06_EST_REPORTE.e_est_reporte as COD,
  PRE06_EST_REPORTE.d_est_reporte as DES
from
  PRE06_EST_REPORTE
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.EstructuraReportes.EST_REPORTE.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE06_EST_REPORTE.oi_est_reporte) as CNT
from
  PRE06_EST_REPORTE
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE06_EST_REPORTE.oi_est_reporte={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE06_EST_REPORTE.d_est_reporte,{#SOURCE:@TXT_FIND}) or contain(PRE06_EST_REPORTE.e_est_reporte,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<method name="RepPorEstructura" label="M&#233;todo para reporte por estructura" modifier="static" note="&#13;&#10;&#13;&#10;" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" name="param" type="Nomad.NSystem.Object" pass="byval"/>
			</arguments>
		</method>
		<method name="RepPorLegajo" label="M&#233;todo para reporte por estructura" modifier="static" note="&#13;&#10;&#13;&#10;" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" name="param" type="Nomad.NSystem.Object" pass="byval"/>
			</arguments>
		</method>
		<resource declare="&lt;DATA oi_est_reporte=&quot;1&quot; oi_escenario=&quot;4&quot; oi_presupuesto=&quot;1&quot; oi_def_reporte=&quot;1&quot;/&gt;" name="QRY_DEF_REP">
			<qry:main doc="SOURCE">
				<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATA"/>
				<REPORT>
					<qry:insert-select name="DEFqry_REPORTE" doc-path=""/>
					<qry:attribute name="date" value="format_date(Now(),'dd/mm/yyyy HH:MM')"/>
					<GROUPS>
						<qry:attribute name="ORDEN" value="0"/>
						<qry:insert-select name="DEFqry_nodos_hijos" doc-path="."/>
					</GROUPS>
				</REPORT>
			</qry:main>
			<qry:select name="DEFqry_REPORTE" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT
				PRE12_PRESUPUESTO.d_presupuesto,
				PRE03_ESCENARIOS.e_numero
			FROM				
				PRE12_PRESUPUESTO,
				PRE03_ESCENARIOS
			JOIN
				PRE12_PRESUPUESTO.oi_presupuesto INNER PRE03_ESCENARIOS.oi_presupuesto
			WHERE
				PRE03_ESCENARIOS.oi_escenario = {#PARAMIN:@oi_escenario}
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="label" value="$r/@d_presupuesto + ' - ' + $r/@e_numero"/>
				</qry:out>
			</qry:select>
			<qry:select name="DEFqry_nodos_hijos" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT 
				PRE11_NIVELES.oi_nivel
			FROM   
				PRE11_NIVELES,
				PRE06_EST_REPORTE
			JOIN
				PRE11_NIVELES.oi_def_reporte INNER PRE06_EST_REPORTE.oi_def_reporte
			WHERE
				PRE06_EST_REPORTE.oi_est_reporte = {#PARAMIN:@oi_est_reporte} AND
				PRE11_NIVELES.e_orden IN
					(
						SELECT
							MIN(PRE11_NIVELES.e_orden) AS e_orden
						FROM
							PRE11_NIVELES,
							PRE06_EST_REPORTE
						JOIN
						  PRE11_NIVELES.oi_def_reporte INNER PRE06_EST_REPORTE.oi_def_reporte
			  		WHERE
			  			PRE06_EST_REPORTE.oi_est_reporte = {%=#PARAMIN:@oi_est_reporte%} AND
			  			PRE11_NIVELES.e_orden &gt; {%=#SOURCE:@ORDEN%}
			  	)

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<GROUP tag="NODO" type="title_collapse">
						<COLS>
							<COL name="d_nodo" label="Nivel"/>
						</COLS>
						<qry:attribute name="ORDEN" value="number(#SOURCE:@ORDEN) + 1"/>
						<qry:insert-select name="DEFqry_nodos_hijos" doc-path="."/>
						<GROUP tag="ITEM" type="table_title" label="Detalle:">
							<COLS>
								<COL name="d_clase" label="Clase" nowrap="1" style="width:20%"/>
								<COL name="d_tipo" label="Tipo" nowrap="1" style="width:20%"/>
								<COL name="d_item" label="Item" nowrap="1" style="width:30%"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalItem" label="Total" type="num" style="width:15%"/>
							</COLS>
							<FCOLS>
								<COL label="Total" colspan="3" style="text-align:right"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalNodo" label="Total" type="num" style="width:15%"/>
							</FCOLS>
						</GROUP>
						<GROUP tag="TIPO" type="table">
							<COLS>
								<COL name="d_clase" label="Clase" nowrap="1" style="width:20%"/>
								<COL name="d_tipo" label="Tipo" nowrap="1" style="width:50%"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalTipo" label="Total" type="num" style="width:15%"/>
							</COLS>
							<FCOLS>
								<COL label="Total" colspan="2" style="text-align:right"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalNodo" label="Total" type="num" style="width:15%"/>
							</FCOLS>
						</GROUP>
						<GROUP tag="CLASE" type="table_title" label="Total de Clase:">
							<COLS>
								<COL name="d_clase" label="Clase" nowrap="1" style="width:70%"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalClase" label="Total" type="num" style="width:15%"/>
							</COLS>
							<FCOLS>
								<COL label="Total" style="text-align:right"/>
								<qry:insert-select name="DEFqry_periodos"/>
								<COL name="totalNodo" label="Total" type="num" style="width:15%"/>
							</FCOLS>
						</GROUP>
					</GROUP>
				</qry:out>
			</qry:select>
			<qry:select name="DEFqry_periodos" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT
				PRE03_DETALLES.oi_detalle_pres,
				PRE01_PER_FISCAL.d_periodo_fiscal
			FROM
				PRE03_DETALLES,
				PRE01_PER_FISCAL
			JOIN
				PRE03_DETALLES.oi_periodo_fiscal INNER PRE01_PER_FISCAL.oi_periodo_fiscal
			WHERE
				PRE03_DETALLES.oi_escenario = {#PARAMIN:@oi_escenario} AND
				PRE01_PER_FISCAL.l_afecto_total = 1

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="COL">
						<qry:attribute name="name" value="'per' + $r/@oi_detalle_pres"/>
						<qry:attribute name="label" value="$r/@d_periodo_fiscal"/>
						<qry:attribute name="type" value="'num'"/>
						<qry:attribute name="style" value="'width:15%'"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA oi_est_reporte=&quot;1&quot; oi_escenario=&quot;4&quot; oi_presupuesto=&quot;1&quot; oi_def_reporte=&quot;1&quot;/&gt;" name="QRY_DATA_REP">
			<qry:main doc="SOURCE">
				<qry:append-doc name="PARAMIN" doc-path="#SOURCE:DATA"/>
				<qry:element name="DATA">
					<qry:insert-select name="qry_cabecera" doc-path="#SOURCE:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_cabecera" doc="SOURCE">
				<qry:xquery>
					for $r in sql('

			SELECT
				PRE06_NODOS.oi_nodo AS parent,
				PRE06_NODOS.d_nodo
			FROM 
				PRE06_EST_REPORTE, 
				PRE06_NODOS
			JOIN
				PRE06_EST_REPORTE.oi_nodo INNER PRE06_NODOS.oi_nodo
			WHERE
				PRE06_EST_REPORTE.oi_est_reporte = {#SOURCE:@oi_est_reporte}
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="NODO">
						<qry:attribute name="d_nodo" value="$r/@d_nodo"/>
						<qry:insert-select name="qry_nodos_hijos" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_nodos_hijos" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT 
				PRE06_NODOS.oi_nodo AS parent,
	      PRE06_NODOS.d_nodo,
	      PRE06_NODOS.c_valor_iden,
	      PRE06_NODOS.e_orden
			FROM   
				PRE06_NODOS
			WHERE  
				PRE06_NODOS.oi_nodo_padre = {#SOURCE:@parent}
			ORDER BY
				e_orden ASC

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="NODO">
						<qry:attribute name="d_nodo" value="$r/@d_nodo"/>
						<qry:attribute name="c_valor_iden" value="$r/@c_valor_iden"/>
						<qry:insert-select name="qry_nodos_hijos" doc-path="$r"/>
						<qry:insert-select name="qry_items" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_items" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT
				PRE11_ITEMS.oi_item,
				PRE18_CLASE_ITEM.c_clase_item,
				PRE19_TIPO_ITEM.c_tipo_item,
				PRE11_ITEMS.e_item,
				PRE18_CLASE_ITEM.d_clase_item,
				PRE19_TIPO_ITEM.d_tipo_item,
				PRE11_ITEMS.d_item
			FROM 
				PRE18_CLASE_ITEM,
				PRE11_ITEMS,
				PRE11_NIVELES,
				PRE19_TIPO_ITEM
			JOIN	
				PRE18_CLASE_ITEM.oi_clase_item INNER PRE11_ITEMS.oi_clase_item,				
				PRE11_ITEMS.oi_tipo_item INNER PRE19_TIPO_ITEM.oi_tipo_item,
				PRE11_ITEMS.oi_nivel INNER PRE11_NIVELES.oi_nivel
			WHERE
				PRE11_NIVELES.oi_def_reporte = {#PARAMIN:@oi_def_reporte}
			ORDER BY
				c_clase_item ASC,
				c_tipo_item ASC,
				e_item ASC

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ITEM">
						<qry:attribute name="oi_item" value="$r/@oi_item"/>
						<qry:attribute name="c_clase" value="$r/@c_clase_item"/>
						<qry:attribute name="c_tipo" value="$r/@c_tipo_item"/>
						<qry:attribute name="e_item" value="$r/@e_item"/>
						<qry:attribute name="d_clase" value="'['+$r/@c_clase_item+'] '+$r/@d_clase_item"/>
						<qry:attribute name="d_tipo" value="'['+$r/@c_tipo_item+'] '+$r/@d_tipo_item"/>
						<qry:attribute name="d_item" value="'['+$r/@e_item+'] '+$r/@d_item"/>
						<qry:attribute name="c_valor_iden" value="../@c_valor_iden"/>
						<qry:attribute name="totalItem" value="0"/>
						<qry:insert-select name="qry_periodos" doc-path="."/>
						<qry:attribute name="hts:delete" value="iif(@totalItem=0,1,0)"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qry_periodos" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
			
			SELECT 
				SUM(PRE05_DET_CONCEPTOS.n_valor_final) AS suma,
				PRE05_DET_CONCEPTOS.oi_detalle_pres
			FROM
				PRE05_DET_CONCEPTOS, 
				PRE03_DETALLES,
				PRE01_PER_FISCAL,
				PRE05_LEGAJOS,
				PRE11_CONC_ITEMS,
				PRE11_GRU_ITEMS
			JOIN
				PRE05_DET_CONCEPTOS.oi_detalle_pres INNER PRE03_DETALLES.oi_detalle_pres,
				PRE03_DETALLES.oi_periodo_fiscal INNER PRE01_PER_FISCAL.oi_periodo_fiscal,
				PRE05_DET_CONCEPTOS.oi_legajo INNER PRE05_LEGAJOS.oi_legajo,
				PRE05_LEGAJOS.oi_grupo INNER PRE11_GRU_ITEMS.oi_grupo,
				PRE05_DET_CONCEPTOS.oi_concepto INNER PRE11_CONC_ITEMS.oi_concepto
			WHERE
				PRE11_CONC_ITEMS.oi_item = PRE11_GRU_ITEMS.oi_item AND
				PRE05_DET_CONCEPTOS.c_ultimo_nivel = {#SOURCE:@c_valor_iden} AND
				PRE05_LEGAJOS.oi_escenario = {#PARAMIN:@oi_escenario} AND
				PRE11_CONC_ITEMS.oi_item = {#SOURCE:@oi_item} AND
				PRE01_PER_FISCAL.l_afecto_total = 1
			GROUP BY
				PRE05_DET_CONCEPTOS.oi_detalle_pres
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PERIODO">
						<qry:attribute name="per" value="'per'+$r/@oi_detalle_pres"/>
						<qry:attribute name="val" value="$r/@suma"/>
					</qry:element>
					<qry:attribute name="totalItem" value="number(@totalItem) + number($r/@suma)"/>
				</qry:out>
			</qry:select>
		</resource>
