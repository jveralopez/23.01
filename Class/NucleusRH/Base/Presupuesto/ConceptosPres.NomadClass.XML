<class-package xmlns:qry="nomad_engine.qry" root-class="CONCEPTO" name="ConceptosPres" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Presupuesto">
	<class size="M" help="Tabla codificadora de conceptos del modulo de presupuestacion." description="Conceptos Presupuesto" access="direct" label="Concepto" name="CONCEPTO">
		<meta-properties>
			<db-properties desc-column="d_concepto" code-column="e_concepto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRE07_CONCEPTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_conceptos" code-attr="e_concepto" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_concepto as oi_concepto, t0.e_concepto as e_concepto, t0.d_concepto as d_concepto, t0.d_formula as d_formula, t0.l_activo as l_activo, t0.e_secuencia as e_secuencia, t0.l_valorizable as l_valorizable, SEC.policy, t0.e_concepto as CODE, t0.d_concepto as TEXT, t0.oi_tipo_concepto as oi_tipo_concepto FROM PRE07_CONCEPTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO\') as SEC JOIN t0.oi_concepto LEFT OUTER SEC.id  ORDER BY oi_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_concepto"/>
								<qry:attribute name="e_concepto" value="$r/@e_concepto"/>
								<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
								<qry:attribute name="d_formula" value="$r/@d_formula"/>
								<qry:attribute name="l_activo" value="iif($r/@l_activo='1','1','0')"/>
								<qry:attribute name="e_secuencia" value="$r/@e_secuencia"/>
								<qry:attribute name="l_valorizable" value="iif($r/@l_valorizable='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tipo_concepto!=''">
									<qry:then>
										<qry:element name="oi_tipo_concepto">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipo_concepto"/>
											<qry:insert-select name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipo_concepto" value="'['+oi_tipo_concepto/ROW/@COD+'] '+oi_tipo_concepto/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_concepto as oi_concepto, SEC.policy FROM PRE07_CONCEPTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO\') as SEC JOIN t0.oi_concepto LEFT OUTER SEC.id  ORDER BY oi_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_concepto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_conceptos" code="e_concepto" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Presupuesto.ConceptosPres.autoflow:initialize" desc-attr="d_concepto" code-attr="e_concepto" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_concepto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="true" default="'Autom&#225;tico'" type="Nomad.NSystem.Int" label="C&#243;digo" name="e_concepto" OriginalName="e_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="C&#243;digo" lock="false" read-only="true" visible="true" mandatory="true"/>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="true" unique="false" generator="child-secuence" id="false" nullable="false" type="int" column="e_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_concepto" OriginalName="d_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="800" type="Nomad.NSystem.String" label="Formula Inicial" name="d_formula" OriginalName="d_formula">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Formula Inicial" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(800)" column="d_formula"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Activo" name="l_activo" OriginalName="l_activo">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Activo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_activo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Secuencia" name="e_secuencia" OriginalName="e_secuencia">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Secuencia" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="e_secuencia"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Es valorizable?" name="l_valorizable" OriginalName="l_valorizable">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Es valorizable?" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_valorizable"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO" null="true" readonly="false" type="aggregation" label="Tipo de Concepto" name="oi_tipo_concepto" OriginalName="oi_tipo_concepto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_tipo_concepto"/>
				<form-properties label="Tipo de Concepto" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_tipo_concepto"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" label="Observaciones" name="o_concepto" OriginalName="o_concepto">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_concepto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_CURSOS" name="AK1_ORG_CURSOS">
			<key-attr assosiation="no" name="e_concepto"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRE07_CONCEPTOS.oi_concepto as ID,
  PRE07_CONCEPTOS.e_concepto as COD,
  PRE07_CONCEPTOS.d_concepto as DES
from
  PRE07_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.ConceptosPres.CONCEPTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE07_CONCEPTOS.oi_concepto) as CNT
from
  PRE07_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE07_CONCEPTOS.oi_concepto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE07_CONCEPTOS.d_concepto,{#SOURCE:@TXT_FIND}) or contain(PRE07_CONCEPTOS.e_concepto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
