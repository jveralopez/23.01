<class-package xmlns:qry="nomad_engine.qry" root-class="TIPO_CONCEPTO" name="TiposConceptos" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Presupuesto">
	<class name="TIPO_CONCEPTO" size="L" help="Tabla donde se registran los tipos de conceptos" description="Tipos de Concepto" access="direct" label="Tipo de Concepto">
		<meta-properties>
			<db-properties desc-column="d_tipo_concepto" code-column="c_tipo_concepto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="PRE16_TIPO_CONC">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipo_conc" code-attr="c_tipo_conc" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_concepto as oi_tipo_concepto, t0.c_tipo_concepto as c_tipo_concepto, t0.d_tipo_concepto as d_tipo_concepto, t0.c_nombre_corto as c_nombre_corto, t0.l_novedades as l_novedades, SEC.policy, t0.c_tipo_concepto as CODE, t0.d_tipo_concepto as TEXT FROM PRE16_TIPO_CONC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO\') as SEC JOIN t0.oi_tipo_concepto LEFT OUTER SEC.id  ORDER BY oi_tipo_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_concepto"/>
								<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
								<qry:attribute name="d_tipo_concepto" value="$r/@d_tipo_concepto"/>
								<qry:attribute name="c_nombre_corto" value="$r/@c_nombre_corto"/>
								<qry:attribute name="l_novedades" value="iif($r/@l_novedades='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_concepto as oi_tipo_concepto, SEC.policy FROM PRE16_TIPO_CONC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO\') as SEC JOIN t0.oi_tipo_concepto LEFT OUTER SEC.id  ORDER BY oi_tipo_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_concepto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_tipo_conc" code="c_tipo_conc" automatico="1"/>
			<guia-properties desc-attr="d_tipo_concepto" code-attr="c_tipo_concepto" flow-edit="NucleusRH.Base.Presupuesto.TiposConceptos.autoflow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_tipo_concepto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_tipo_concepto" OriginalName="c_tipo_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_tipo_concepto" OriginalName="d_tipo_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Nombre Corto" name="c_nombre_corto" OriginalName="c_nombre_corto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Nombre Corto" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_nombre_corto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Novedades?" name="l_novedades" OriginalName="l_novedades">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Novedades?" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_novedades"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Curso. Puede ser un alfanum&#233;rico de hasta 1000 caracteres" label="Observaciones" name="o_tipo_concepto" OriginalName="o_tipo_concepto">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_tipo_concepto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_CURSOS" name="AK1_ORG_CURSOS">
			<key-attr assosiation="no" name="c_tipo_concepto"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  PRE16_TIPO_CONC.oi_tipo_concepto as ID,
  PRE16_TIPO_CONC.c_tipo_concepto as COD,
  PRE16_TIPO_CONC.d_tipo_concepto as DES
from
  PRE16_TIPO_CONC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Presupuesto.TiposConceptos.TIPO_CONCEPTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(PRE16_TIPO_CONC.oi_tipo_concepto) as CNT
from
  PRE16_TIPO_CONC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and PRE16_TIPO_CONC.oi_tipo_concepto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(PRE16_TIPO_CONC.d_tipo_concepto,{#SOURCE:@TXT_FIND}) or contain(PRE16_TIPO_CONC.c_tipo_concepto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
