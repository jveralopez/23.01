<class-package xmlns:qry="nomad_engine.qry" root-class="EQUIVALENCIA" name="MigCodLsdAfip" DDOBase="NucleusRH\Base\Liquidacion" meta-class="DB" languaje="SP">
	<class name="EQUIVALENCIA" description="Consumos" label="Consumo" access="direct" size="XL">
		<meta-properties>
			<interface-properties file="LIQ_CodLsdAfip.dat" mode="1" enter="1" separator=";" decimal=","/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties/>
		</attribute>
		<attribute label="C&#243;digo Concepto Nucleus" length="30" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_concepto" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Codigo LSD AFIP " length="30" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_lsd" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="ImportarCodLsdAfip" description="Importar cod LSD desde Archivo" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:LIQ_CodLsdAfip.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
