					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('{%? (#FILTER:@LEN='') {% %} {% maxsize {%=#FILTER:@LEN %} %} %}
SELECT 
  T0.oi_tipo_anticipo as ID, 
  T0.c_tipo_anticipo as COD, 
  T0.d_tipo_anticipo as DES
FROM 
  LIQ33_TIPO_ANTICIPOS as T0
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}
 order by COD asc
 
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
