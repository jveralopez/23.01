						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  T0.oi_tipo_anticipo as ID, 
  T0.c_tipo_anticipo as COD, 
  T0.d_tipo_anticipo as DES, 
  T0.c_tipo_anticipo as c_tipo_anticipo, 
  T0.d_tipo_anticipo as d_tipo_anticipo
FROM 
  LIQ33_TIPO_ANTICIPOS as T0
WHERE 
T0.oi_tipo_anticipo in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="c_tipo_anticipo" value="$r/@c_tipo_anticipo"/>
						<qry:attribute name="d_tipo_anticipo" value="$r/@d_tipo_anticipo"/>
