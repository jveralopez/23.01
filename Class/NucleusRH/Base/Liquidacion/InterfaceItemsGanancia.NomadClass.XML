<class-package xmlns:qry="nomad_engine.qry" name="InterfaceItemsGanancia" root-class="ENTRADA" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Liquidacion">
	<class description="Definici&#243;n de la interfaz de Items de Ganancia" name="ENTRADA" access="direct">
		<meta-properties>
			<interface-properties file="IntItemsGan.dat" separator=";" mode="1" enter="1" separador=";" decimal="." escape="\"/>
		</meta-properties>
		<attribute length="5" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties/>
		</attribute>
		<attribute null="false" label="Legajo" length="15" name="e_numero_legajo" type="Nomad.NSystem.Int" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" label="C&#243;digo" name="c_item_ig" length="30" type="Nomad.NSystem.String" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute readonly="false" null="false" label="A&#241;o" name="e_anio" length="4" type="Nomad.NSystem.Int" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="e_periodo_desde" label="Periodo desde" readonly="false" null="false" length="6" type="Nomad.NSystem.Int" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Periodo hasta" name="e_periodo_hasta" readonly="false" null="false" length="6" type="Nomad.NSystem.Int" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Double" length="15" label="Importe" name="n_importe" readonly="false" null="false" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="QRY_OIArchivo">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:IntItemsGan.dat')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAMS oi_empresa=&quot;164&quot; /&gt;" description="Retorna una lista de legajos accesibles por el ID" name="QRY_IDLegajos">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:PARAMS" name="qry_per"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_per">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					pe.oi_personal_emp,
					pe.e_numero_legajo
				FROM 
					per02_personal_emp  as pe
				WHERE
					pe.oi_empresa={#PARAM:@oi_empresa} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi" value="$r/@oi_personal_emp"/>
						<qry:attribute name="cod" value="$r/@e_numero_legajo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<method name="Importar" description="Importar los items de ganancia al legajo liquidaci&#243;n." modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="poi_empresa" type="Nomad.NSystem.String" pass="byval"/>
			</arguments>
		</method>
	</class>
</class-package>
