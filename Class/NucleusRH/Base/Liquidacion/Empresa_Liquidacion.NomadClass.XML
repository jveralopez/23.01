		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LIQ15_EMPRESAS.oi_empresa as ID,
  LIQ15_EMPRESAS.oi_empresa as PARENT,
  ORG03_EMPRESAS.c_empresa as COD,
  ORG03_EMPRESAS.d_empresa as DES
from
  LIQ15_EMPRESAS, ORG03_EMPRESAS
JOIN
	LIQ15_EMPRESAS.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LIQ15_EMPRESAS.oi_empresa) as CNT
from
  LIQ15_EMPRESAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LIQ15_EMPRESAS.oi_empresa={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LIQ15_EMPRESAS.d_empresa,{#SOURCE:@TXT_FIND}) or contain(LIQ15_EMPRESAS.c_empresa,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="QRY_PARAMETRO" description="Dado un codigo de parametro devuelve el oi">
