		<resource declare="&lt;PARAM c_parametro=&quot;JurisCentralizado&quot; oi_empresa=&quot;1&quot; /&gt;" description="Dado una empresa y un par&#225;metro, retorna el valor" name="QRY_PARAMETRO_POR_EMPRESA">
			<qry:main doc="PARAM" name="">
				<qry:element name="PARAMETRO">
					<qry:attribute name="c_parametro" value="#PARAM:./@c_parametro"/>
					<qry:insert-select name="QRY_VALOR" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="QRY_VALOR">
				<qry:xquery>
					for $r in SQL('
			
				SELECT
					e.d_valor

				FROM 
					LIQ15_PARAM_EMP AS e, 
					ORG26_PARAMETROS AS p 
				
				JOIN
					e.oi_parametro INNER p.oi_parametro

				WHERE 
					ucase(p.c_parametro) = {upper-case(#PARAM:@c_parametro)}
					AND e.oi_empresa = {#PARAM:@oi_empresa} 

			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="valor" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</resource>
