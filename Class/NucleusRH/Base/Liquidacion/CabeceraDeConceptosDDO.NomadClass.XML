			<form-properties generate="true" binary="NONE" desc-attr="oi_cab_conc_ddo" code-attr="oi_cab_conc_ddo" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
