		<resource declare="&lt;FILTRO oi_empresa=&quot;1&quot; oi_var_ejec_ddo=&quot;1701&quot; oi_tipo_liq=&quot;1&quot; /&gt;" include="false" name="QryConceptos">
			<qry:main doc="PARAM">
				<qry:element name="object">
					<qry:attribute name="id" value="'%1'"/>
					<qry:attribute name="class" value="'NucleusRH.Base.Liquidacion.CabeceraDeConceptosDDO.CAB_CONC_DDO'"/>
					<qry:append-doc name="PARAMIN" doc-path="#PARAM:/FILTRO"/>
					<qry:insert-select doc-path="#PARAM:" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:out>
					<qry:element name="CAB_CONC_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:attribute name="Hash" value=""/>
						<qry:attribute name="descr" value=""/>
						<qry:element name="CONCEPTOS">
							<qry:append-doc name="CONCEPTOS" doc-path="."/>
							<qry:insert-select doc-path="#PARAM:FILTRO" name="sql2"/>
						</qry:element>
						<qry:element name="GRUPO_VAR">
							<qry:insert-select doc-path="#PARAM:FILTRO" name="sql4"/>
						</qry:element>
						<sql3>
							<qry:insert-select doc-path="." name="sql3"/>
						</sql3>
						<sql5>
							<qry:insert-select doc-path="." name="sql5"/>
						</sql5>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:xquery>
					for $r in sql('
SELECT
t.oi_concepto,
t.c_concepto,
t.d_concepto,
t4.c_grupo_tliq,
t2.c_tipo_concepto,
t1.c_clase_concepto,
t.ca_fig_recibo,
t.ca_acum_ganancia,
t.n_coef_ganancia,
t.ca_tipo_asiento,
t.c_version,
t.l_activo,
t.l_retroactivo,
t.t_formula,
t.e_secuencia,
t.e_etapa,
t.l_interno, t.l_ej_ajuste
FROM
LIQ14_CONCEPTOS AS t,
LIQ13_CLASES_CONC AS t1,
LIQ12_TIPOS_CONC AS t2,
LIQ02_GRUPOS_TLIQ as t4, 
LIQ02_TLIQ_GRUPO as t5 
JOIN
t.oi_grupo_tliq INNER t4.oi_grupo_tliq,
t4.oi_grupo_tliq INNER t5.oi_grupo_tliq,
t.oi_tipo_concepto left outer t2.oi_tipo_concepto,
t.oi_clase_concepto left outer t1.oi_clase_concepto
WHERE
t5.oi_tipo_liq = {%=#PARAM:@oi_tipo_liq%} and
t.l_activo = 1 and
t.oi_grupo_empresa in (SELECT
x1.oi_grupo_empresa
FROM
LIQ24_GRUPOS_EMPRE as x1,
LIQ24_EMP_GRUPOEMP as x2
JOIN
x1.oi_grupo_empresa INNER x2.oi_grupo_empresa
WHERE 
x2.oi_empresa = {%=#PARAM:@oi_empresa %})

UNION

SELECT     
t.oi_concepto,
t.c_concepto,
t.d_concepto,
t4.c_grupo_tliq,
t2.c_tipo_concepto,
t1.c_clase_concepto,
t.ca_fig_recibo,
t.ca_acum_ganancia,
t.n_coef_ganancia,
t.ca_tipo_asiento,
t.c_version,
t.l_activo,
t.l_retroactivo,
t.t_formula,
t.e_secuencia,
t.e_etapa,
t.l_interno, t.l_ej_ajuste
FROM
LIQ14_CONCEPTOS AS t,
LIQ13_CLASES_CONC AS t1,
LIQ12_TIPOS_CONC AS t2, 
LIQ02_GRUPOS_TLIQ as t4, 
LIQ02_TLIQ_GRUPO as t5 
JOIN
t.oi_grupo_tliq INNER t4.oi_grupo_tliq,
t4.oi_grupo_tliq INNER t5.oi_grupo_tliq,
t.oi_tipo_concepto left outer t2.oi_tipo_concepto,
t.oi_clase_concepto left outer t1.oi_clase_concepto
WHERE
t5.oi_tipo_liq = {%=#PARAM:@oi_tipo_liq%} and
t.l_activo = 1 and
isnull(t.oi_grupo_empresa)

ORDER BY
e_secuencia ASC, 
c_concepto ASC
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="CONCEPTO_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:attribute name="oi_concepto" value="$r/@oi_concepto"/>
						<qry:attribute name="Codigo" value="$r/@c_concepto"/>
						<qry:attribute name="Descripcion" value="$r/@d_concepto"/>
						<qry:attribute name="Version" value="$r/@c_version"/>
						<qry:attribute name="GrupoTipoLiquidacion" value="$r/@c_grupo_tliq"/>
						<qry:attribute name="TipoConcepto" value="$r/@c_tipo_concepto"/>
						<qry:attribute name="ClaseConcepto" value="$r/@c_clase_concepto"/>
						<qry:attribute name="GrupoEmpresas" value="$r/@c_grupo_empresa"/>
						<qry:attribute name="FiguraEnRecibo" value="$r/@ca_fig_recibo"/>
						<qry:attribute name="AcumulaGanancia" value="$r/@ca_acum_ganancia"/>
						<qry:attribute name="CoeficienteGanancia" value="$r/@n_coef_ganancia"/>
						<qry:attribute name="TipoAsiento" value="$r/@ca_tipo_asiento"/>
						<qry:attribute name="Activo" value="$r/@l_activo"/>
						<qry:attribute name="Retroactivo" value="$r/@l_retroactivo"/>
						<qry:attribute name="Formula" value="$r/@t_formula"/>
						<qry:attribute name="Secuencia" value="$r/@e_secuencia"/>
						<qry:attribute name="Etapa" value="$r/@e_etapa"/>
						<qry:attribute name="Interno" value="$r/@l_interno"/>
						<qry:attribute name="EjecutaAjuste" value="$r/@l_ej_ajuste"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql3">
				<qry:xquery>
					for $r in sql('
SELECT               
t.oi_concepto,
t.c_tipo_parametro ,  
tt.c_tipo_dato,    
tt.oi_variable_ddo ,
tt.c_variable,
t.c_alias,
t.t_formula
FROM 
LIQ14_CONC_VAR as t, 
LIQ95_VARIABLES as tt,
liq09_variables as tv, 
LIQ14_CONCEPTOS as tq
JOIN
tv.c_variable INNER tt.c_variable,
t.oi_concepto INNER tq.oi_concepto,
t.oi_variable INNER tv.oi_variable
WHERE
tt.oi_var_ejec_ddo = {%= #PARAMIN:@oi_var_ejec_ddo %} 
UNION
SELECT        
t.oi_concepto,
t.c_tipo_parametro,
t.c_tipo_dato,     
null as oi_variable_ddo,
t.c_alias as c_variable,
t.c_alias,
t.t_formula
FROM 
LIQ14_CONC_VAR as t, 
LIQ14_CONCEPTOS as tq
JOIN
t.oi_concepto INNER tq.oi_concepto
WHERE                                     
isNull(t.oi_variable)   
')/ROWS/ROW orderby $r/@c_variable asc
				</qry:xquery>
				<qry:out>
					<qry:element name="CONC_VARIAB_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:attribute name="oi_concepto" value="$r/@oi_concepto"/>
						<qry:attribute name="CodigoVariable" value="$r/@c_variable"/>
						<qry:attribute name="Alias" value="iif($r/@c_alias='',$r/@c_variable,$r/@c_alias)"/>
						<qry:attribute name="TipoParametro" value="$r/@c_tipo_parametro"/>
						<qry:attribute name="TipoDato" value="$r/@c_tipo_dato"/>
						<qry:attribute name="t_formula" value="$r/@t_formula"/>
						<qry:element name="OIDVariable">
							<qry:attribute name="value" value="$r/@oi_variable_ddo" class="NucleusRH.Base.Liquidacion.VariablesPorEjecucionDDO.VARIABLE_DDO"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="sql5" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('SELECT t.c_tipo_concepto, t.o_acumular FROM LIQ12_TIPOS_CONC as t')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@o_acumular != ''">
						<qry:then>
							<qry:insert-select name="sql6" doc-path="$r"/>
							<TIPO>
								<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
								<qry:attribute name="o_acumular" value="$r/@o_acumular"/>
							</TIPO>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="sql6" doc="SOURCE">
				<qry:xquery>
					for $r in SPLIT('1;{%=$SOURCE/@o_acumular%}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="not(contains(@vars,$r/@value))">
						<qry:then>
							<qry:attribute name="vars" value="concat(@vars,',',$r/@value)"/>
							<qry:insert-select name="sql7" doc-path="$r"/>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="sql7" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
SELECT               
tt.c_tipo_dato,    
tt.oi_variable_ddo,
tt.c_variable
FROM 
LIQ95_VARIABLES as tt
WHERE
tt.oi_var_ejec_ddo = {#PARAMIN:@oi_var_ejec_ddo} and tt.c_variable = {#SOURCE:@value}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<VARI>
						<qry:attribute name="id" value="$r/@oi_variable_ddo"/>
						<qry:attribute name="codigo" value="$r/@c_variable"/>
						<qry:attribute name="tipo" value="$r/@c_tipo_dato"/>
					</VARI>
				</qry:out>
			</qry:select>
			<qry:select name="sql4" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT      
LIQ31_GRUPOS.c_grupo,
LIQ31_GRUPO_VAR.c_columna,
LIQ09_VARIABLES.c_variable
FROM
LIQ31_GRUPO_VAR,
LIQ31_GRUPOS,
LIQ09_VARIABLES
JOIN
LIQ31_GRUPOS.oi_grupo INNER LIQ31_GRUPO_VAR.oi_grupo,
LIQ09_VARIABLES.oi_variable INNER LIQ31_GRUPO_VAR.oi_variable			
order by c_grupo asc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="GRUPO_VAR_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:attribute name="Grupo" value="$r/@c_grupo"/>
						<qry:attribute name="Columna" value="$r/@c_columna"/>
						<qry:attribute name="Variable" value="$r/@c_variable"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
