			<guia-properties flow-edit="NucleusRH.Base.Liquidacion.CabeceraDeConceptosDDO.autoflow:initialize" desc-attr="oi_cab_conc_ddo" code-attr="oi_cab_conc_ddo" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_cab_conc_ddo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_cab_conc_ddo"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="40" type="Nomad.NSystem.String" label="h_hash" name="Hash" OriginalName="h_hash">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="h_hash" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(40)" column="h_hash"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<assosiation label="Conceptos en la Liquidacion" name="CONCEPTOS" class="CONCEPTO_DDO" type="composition" access="public">
			<meta-properties>
				<db-properties cascade="delete" not-found="exception" optimistic-lock="true" not-null="true" unique="true" insert="false" update="false" from-column="oi_cab_conc_ddo"/>
