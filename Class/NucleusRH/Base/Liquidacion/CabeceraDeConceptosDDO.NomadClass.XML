						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_cab_conc_ddo as oi_cab_conc_ddo FROM LIQ96_CAB_CONCEPT as t0 ORDER BY oi_cab_conc_ddo asc')/ROWS/ROW
						</qry:xquery>
