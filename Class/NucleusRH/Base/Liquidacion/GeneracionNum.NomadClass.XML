<class-package xmlns:qry="nomad_engine.qry" root-class="GENERACION" name="GeneracionNum" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Liquidacion">
	<class name="GENERACION" size="L" help="Almacena las generaciones de numeros de recibos." description="Generaciones de Numeros de Recibos" access="direct" label="Generacion">
		<meta-properties>
			<db-properties desc-column="oi_generacion" code-column="oi_generacion" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LIQ27_GEN_NUM">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="oi_generacion" code-attr="oi_generacion" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_generacion as oi_generacion, t0.f_generacion as f_generacion, t0.c_empresa as c_empresa, t0.d_empresa as d_empresa, t0.c_liquidacion as c_liquidacion, t0.d_liquidacion as d_liquidacion, t0.c_num_desde as c_num_desde, t0.c_num_hasta as c_num_hasta, t0.e_ult_ejecucion as e_ult_ejecucion, SEC.policy, t0.oi_generacion as CODE, t0.oi_generacion as TEXT FROM LIQ27_GEN_NUM as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.GeneracionNum.GENERACION\') as SEC JOIN t0.oi_generacion LEFT OUTER SEC.id  ORDER BY oi_generacion asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_generacion"/>
								<qry:attribute name="f_generacion" value="$r/@f_generacion"/>
								<qry:attribute name="c_empresa" value="$r/@c_empresa"/>
								<qry:attribute name="d_empresa" value="$r/@d_empresa"/>
								<qry:attribute name="c_liquidacion" value="$r/@c_liquidacion"/>
								<qry:attribute name="d_liquidacion" value="$r/@d_liquidacion"/>
								<qry:attribute name="c_num_desde" value="$r/@c_num_desde"/>
								<qry:attribute name="c_num_hasta" value="$r/@c_num_hasta"/>
								<qry:attribute name="e_ult_ejecucion" value="$r/@e_ult_ejecucion"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_generacion as oi_generacion, SEC.policy FROM LIQ27_GEN_NUM as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.GeneracionNum.GENERACION\') as SEC JOIN t0.oi_generacion LEFT OUTER SEC.id  ORDER BY oi_generacion asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_generacion"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Liquidacion.GeneracionNum.autoflow:initialize" desc-attr="oi_generacion" code-attr="oi_generacion" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
