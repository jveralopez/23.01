				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_num_desde"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="'1'" length="30" type="Nomad.NSystem.String" label="Numero Hasta" name="c_num_hasta" OriginalName="c_num_hasta">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Numero Hasta" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_num_hasta"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="ID Ejeuccion de la Liquidacion" name="e_ult_ejecucion" OriginalName="e_ult_ejecucion">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="ID Ejeuccion de la Liquidacion" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="e_ult_ejecucion"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK_I_CONC_LIQ_CONC" name="AK_I_CONC_LIQ_CONC">
			<key-attr assosiation="no" name="c_empresa"/>
			<key-attr assosiation="no" name="f_generacion"/>
			<key-attr assosiation="no" name="c_liquidacion"/>
		</key>
		<method description="Para una liquidacion ddo y para un numero desde se colocan todos los numeros de recibos" modifier="static" access="public" label="Generar Numero" name="GenerarNumero">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument description="Es el Id de la liquidacion con la cual voy a trabajar" type="Nomad.NSystem.Int" pass="byval" name="idLiquidacion"/>
				<argument description="Numero desde para la generacion de numeros de recibos" type="Nomad.NSystem.Int" pass="byval" name="NumDesde"/>
				<argument type="Nomad.NSystem.Int" pass="byval" name="idParametro"/>
