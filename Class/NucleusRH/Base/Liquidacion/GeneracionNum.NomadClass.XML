			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Nombre de Empresa" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_empresa"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo de Liquidacion" name="c_liquidacion" OriginalName="c_liquidacion">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo de Liquidacion" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_liquidacion"/>
