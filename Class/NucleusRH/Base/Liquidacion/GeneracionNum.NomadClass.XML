			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" patern="YYYYMMDDHHMM" label="Fecha Generacion" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_generacion"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo de Empresa" name="c_empresa" OriginalName="c_empresa">
			<meta-properties>
