					LIQ32_SUBGRUPO_LSD as subGrp,
					NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.SubgrupoLSD.SUBGRUPO\') as SEC
				JOIN subGrp.oi_subgrupo LEFT OUTER SEC.id
				ORDER BY
					e_lsd_inicial asc
				')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
