			</meta-properties>
			<arguments>
				<argument class="NucleusRH.Base.Liquidacion.SubgrupoLSD.SUBGRUPO" type="Nomad.NSystem.Object" pass="byval" name="DDOSUBGRUPO"/>
			</arguments>
