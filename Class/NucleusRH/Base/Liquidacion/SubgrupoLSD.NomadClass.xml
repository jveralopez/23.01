			<form-properties enabled-filter="false" enabled-admin="true" enabled-delete="true" enabled-edit="true" enabled-new="true" desc-attr="d_subgrupo" code-attr="d_subgrupo" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('
		SELECT
			subGrp.oi_subgrupo as oi_subgrupo,
			subGrp.e_lsd_inicial as e_lsd_inicial,
			subGrp.e_lsd_final as e_lsd_final,
			subGrp.d_subgrupo as d_subgrupo,
			SEC.policy,
			subGrp.e_lsd_inicial as CODE,
			subGrp.e_lsd_inicial as CODE_INI,
			subGrp.e_lsd_final as CODE_FIN,
			subGrp.d_subgrupo as TEXT
		FROM
			LIQ32_SUBGRUPO_LSD as subGrp,
			NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.SubgrupoLSD.SUBGRUPO\') as SEC
		JOIN subGrp.oi_subgrupo LEFT OUTER SEC.id
		ORDER BY
			e_lsd_inicial asc
				')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_subgrupo"/>
								<qry:attribute name="e_lsd_inicial" value="$r/@e_lsd_inicial"/>
								<qry:attribute name="e_lsd_final" value="$r/@e_lsd_final"/>
								<qry:attribute name="d_subgrupo" value="$r/@d_subgrupo"/>
