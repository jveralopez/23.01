		<resource name="QRY_ValidarCodigo" declare="&lt;PARAM c_lsd_inicial='1' c_lsd_final='160000' /&gt;">
			<qry:main name="qry_validar" doc="SOURCE">
				<qry:element name="SUBGRUPOS">
					<qry:insert-select name="qry_validar" doc-path="#SOURCE:/PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_validar" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			select
			LIQ32_SUBGRUPO_LSD.oi_subgrupo,
			LIQ32_SUBGRUPO_LSD.d_subgrupo
			from
			LIQ32_SUBGRUPO_LSD
			where
			LIQ32_SUBGRUPO_LSD.e_lsd_inicial &lt;= {#SOURCE:@e_lsd_final}
			and LIQ32_SUBGRUPO_LSD.e_lsd_final &gt;= {#SOURCE:@e_lsd_inicial}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="SUBGRUPO">
						<qry:attribute name="oi_subgrupo" value="$r/@oi_subgrupo"/>
						<qry:attribute name="d_subgrupo" value="$r/@d_subgrupo"/>
					</qry:element>
				</qry:out>
			</qry:select>
