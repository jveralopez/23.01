								<qry:attribute name="CODE_INI" value="$r/@CODE_INI"/>
								<qry:attribute name="CODE_FIN" value="$r/@CODE_FIN"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
