 	LIQ32_SUBGRUPO_LSD.d_subgrupo   
 	
{%?($FILTER/@order!='') {% ,LIQ32_SUBGRUPO_LSD.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
