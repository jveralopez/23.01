<class-package xmlns:qry="nomad_engine.qry" name="InterfaceDistribucionCentroCosto" root-class="ENTRADA" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Liquidacion">
	<class description="Definici&#243;n de la interfaz de Distribucion de Centro de Costo" name="ENTRADA" access="direct">
		<meta-properties>
			<interface-properties file="IntDistCC.dat" separator=";" mode="1" enter="1" separador=";" decimal="." escape="\"/>
		</meta-properties>
		<attribute length="5" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties/>
		</attribute>
		<attribute null="false" label="Legajo" length="15" name="e_numero_legajo" type="Nomad.NSystem.Int" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" label="C&#243;digo" name="c_ccosto" length="30" type="Nomad.NSystem.String" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute label="Porcentaje Distribuci&#243;n" length="1000" default="''" type="Nomad.NSystem.String" name="n_p_distrib" readonly="false" null="true" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="1000" default="''" type="Nomad.NSystem.String" name="o_distrib_cos" label="Observaciones" readonly="false" null="true" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="QRY_OIArchivo">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:IntDistCC.dat')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<method description="Importar Distribucion de Centro de Costo al legajo liquidaci&#243;n." name="Importar" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="poi_empresa" type="Nomad.NSystem.String" pass="byval"/>
			</arguments>
		</method>
		<resource declare="&lt;PARAMS oi_empresa=&quot;164&quot; /&gt;" description="Retorna una lista de legajos accesibles por el ID" name="QRY_IDLegajos">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="#PARAM:PARAMS" name="qry_per"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="qry_per">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					pe.oi_personal_emp,
					pe.e_numero_legajo
				FROM 
					per02_personal_emp  as pe
				WHERE
					pe.oi_empresa={#PARAM:@oi_empresa} ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi" value="$r/@oi_personal_emp"/>
						<qry:attribute name="cod" value="$r/@e_numero_legajo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
