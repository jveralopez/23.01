			<meta-properties>
				<form-properties show-list="false" visible="false" find-include="false" automatico="1" label="OID Tipo Liquidaci&#243;n" lock="false" read-only="false" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="oi_tipo_liq"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Personal.TiposPersonal.TIPO_PERSONAL" null="false" readonly="false" type="aggregation" label="Tipo Personal" name="oi_tipo_personal" OriginalName="oi_tipo_personal">
			<meta-properties>
