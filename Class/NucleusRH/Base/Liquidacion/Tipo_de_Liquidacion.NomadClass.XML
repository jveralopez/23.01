							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_liq as oi_tipo_liq, SEC.policy FROM LIQ01_TIPOS_LIQ as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ\') as SEC JOIN t0.oi_tipo_liq LEFT OUTER SEC.id  ORDER BY oi_tipo_liq asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_liq"/>
							</qry:element>
