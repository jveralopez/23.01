				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_liq as oi_tipo_liq, t0.c_tipo_liq as c_tipo_liq, t0.d_tipo_liq as d_tipo_liq, t0.l_egresados as l_egresados, SEC.policy, t0.c_tipo_liq as CODE, t0.d_tipo_liq as TEXT FROM LIQ01_TIPOS_LIQ as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Tipo_de_Liquidacion.TIPO_LIQ\') as SEC JOIN t0.oi_tipo_liq LEFT OUTER SEC.id  ORDER BY oi_tipo_liq asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_liq"/>
								<qry:attribute name="c_tipo_liq" value="$r/@c_tipo_liq"/>
								<qry:attribute name="d_tipo_liq" value="$r/@d_tipo_liq"/>
								<qry:attribute name="l_egresados" value="iif($r/@l_egresados='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
