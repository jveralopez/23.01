				<form-properties label="Tipo Personal" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tipo_personal"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="yes" unique="yes" descr="AK_I_TIPO_LIQ_LIQ_TIPO" name="AK_I_TIPO_LIQ_LIQ_TIPO">
			<key-attr assosiation="yes" name="oi_tipo_personal"/>
		</key>
