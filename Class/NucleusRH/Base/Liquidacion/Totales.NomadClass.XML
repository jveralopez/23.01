						<qry:xquery>
							for $r in sql('SELECT t0.oi_total as oi_total, t0.c_total as c_total, t0.d_total as d_total, SEC.policy, t0.c_total as CODE, t0.d_total as TEXT, t0.oi_variable as oi_variable FROM LIQ30_TOTALES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Totales.TOTAL\') as SEC JOIN t0.oi_total LEFT OUTER SEC.id  ORDER BY oi_total asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_total"/>
								<qry:attribute name="c_total" value="$r/@c_total"/>
								<qry:attribute name="d_total" value="$r/@d_total"/>
