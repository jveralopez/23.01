<class-package xmlns:qry="nomad_engine.qry" name="InterfaceRangosIG" root-class="ENTRADA" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Liquidacion">
	<class description="Definici&#243;n de la interfaz de Rangos de Ganancias" name="ENTRADA" access="direct">
		<meta-properties>
			<interface-properties file="IntRangosIG.dat" separator=";" mode="1" enter="1" separador=";" decimal="," escape="\"/>
		</meta-properties>
		<attribute length="5" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties/>
		</attribute>
		<attribute null="true" label="Mes" length="15" name="Mes" type="Nomad.NSystem.Int" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="ImporteDesde" type="Nomad.NSystem.Double" label="Enero" readonly="false" null="true" length="8" precision="3" manual="1">
			<meta-properties>
				<interface-properties mask=""/>
			</meta-properties>
		</attribute>
		<attribute name="ImporteHasta" label="Febrero" type="Nomad.NSystem.Double" readonly="false" null="true" length="8" precision="3" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="CuotaFija" type="Nomad.NSystem.Double" label="Marzo" readonly="false" null="true" length="8" precision="3" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="Porcentaje" type="Nomad.NSystem.Double" label="Abril" readonly="false" null="true" length="8" precision="3" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="QRY_OIArchivo">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:IntRangosIG.dat')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<method name="Importar" description="Importar los items de ganancia al legajo liquidaci&#243;n." modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="e_anio"/>
			</arguments>
		</method>
		<resource declare="&lt;DATA e_anio=&quot;2014&quot; /&gt;" name="qry_rangos_anio">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="$SOURCE/DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('SELECT t.oi_ig FROM LIQ06_IG as t WHERE t.e_anio = {$SOURCE/@e_anio}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_ig"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
