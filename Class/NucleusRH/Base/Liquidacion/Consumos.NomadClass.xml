<class-package xmlns:qry="nomad_engine.qry" name="Consumos" DDOBase="NucleusRH\Base\Liquidacion" root-class="CONSUMO" meta-class="DB" languaje="SP">
	<class attr-desc="d_consumo" attr-code="c_consumo" description="Consumos" label="Consumo" access="direct" size="M" name="CONSUMO">
		<meta-properties>
			<db-properties generate="true" desc-column="d_consumo" code-column="c_consumo" tracking-changes="true" access-mode="new-edit-delete" optimistic-lock="version" table="LIQ08_CONSUMOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<combo-properties desc="d_consumo" code="c_consumo" automatico="1"/>
			<form-properties desc-attr="d_consumo" binary="NONE" code-attr="c_consumo" enabled-filter="true" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_consumo as oi_consumo, t0.c_consumo as c_consumo, t0.d_consumo as d_consumo, SEC.policy, t0.c_consumo as CODE, t0.d_consumo as TEXT FROM LIQ08_CONSUMOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Consumos.CONSUMO\') as SEC JOIN t0.oi_consumo LEFT OUTER SEC.id  ORDER BY oi_consumo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_consumo"/>
								<qry:attribute name="c_consumo" value="$r/@c_consumo"/>
								<qry:attribute name="d_consumo" value="$r/@d_consumo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_consumo as oi_consumo, t0.c_consumo as c_consumo, t0.d_consumo as d_consumo, SEC.policy, t0.c_consumo as CODE, t0.d_consumo as TEXT FROM LIQ08_CONSUMOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Consumos.CONSUMO\') as SEC JOIN t0.oi_consumo LEFT OUTER SEC.id  ORDER BY oi_consumo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_consumo"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
		</meta-properties>
		<attribute label="Id" default="''" readonly="true" null="false" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties>
				<db-properties tracking-changes="yes" generator="secuence" unique="true" updatable="false" insertable="true" versionable="true" nullable="false" id="true" type="int" column="oi_consumo"/>
				<form-properties automatico="0" show-list="true" find-include="false" mandatory="true" lock="false" visible="false" read-only="true" label="Id"/>
			</meta-properties>
		</attribute>
		<attribute inList="true" length="30" precision="0" label="Codigo" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_consumo" manual="1">
			<meta-properties>
				<db-properties tracking-changes="yes" generator="none" unique="false" updatable="true" insertable="true" versionable="true" nullable="false" id="false" type="varchar(30)" column="c_consumo"/>
				<form-properties automatico="0" show-list="true" find-include="true" mandatory="true" lock="false" read-only="false" visible="true" label="Codigo"/>
			</meta-properties>
		</attribute>
		<attribute length="100" inList="true" label="Descripcion" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="d_consumo" manual="1">
			<meta-properties>
				<db-properties tracking-changes="yes" unique="false" generator="none" updatable="true" insertable="true" versionable="true" nullable="false" id="false" type="varchar(100)" column="d_consumo"/>
				<form-properties automatico="0" show-list="true" find-include="true" mandatory="true" lock="false" visible="true" read-only="false" label="Descripcion"/>
			</meta-properties>
		</attribute>
		<assosiation type="aggregation" inList="true" label="Tipo de Consumo" default="''" readonly="false" null="false" class="NucleusRH.Base.Liquidacion.Tipo_Consumo.TIPO_CONSUMO" name="oi_tipo_consumo" manual="1">
			<meta-properties>
				<db-properties not-found="ignore" cascade="none" unique="false" updatable="false" insertable="true" versionable="true" nullable="false" from-column="oi_tipo_consumo"/>
				<form-properties automatico="0" show-list="true" mandatory="true" visible="true" read-only="false" label="Tipo de Consumo"/>
			</meta-properties>
			<multiplicity from="1..*" to="1">
				<db-properties to-column="oi_tipo_consumo"/>
			</multiplicity>
		</assosiation>
		<key unique="yes" msg="Consumo" name="AK01_consumos" manual="1">
			<key-attr name="c_consumo"/>
		</key>
		<resource name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('{%? (#FILTER:@LEN='') {% %} {% maxsize {%=#FILTER:@LEN %} %} %}
SELECT 
  LIQ08_CONSUMOS.oi_consumo as ID, 
  LIQ08_CONSUMOS.c_consumo as COD, 
  LIQ08_CONSUMOS.d_consumo as DES
{%?($FILTER/@order!='') {% ,LIQ08_CONSUMOS.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM 
  LIQ08_CONSUMOS
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}

 order by COD asc
 
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  LIQ08_CONSUMOS.oi_consumo as ID, 
  LIQ08_CONSUMOS.c_consumo as COD, 
  LIQ08_CONSUMOS.d_consumo as DES, 
  LIQ08_CONSUMOS.c_consumo as c_consumo, 
  LIQ08_CONSUMOS.d_consumo as d_consumo, 
  LIQ08_TIPO_CONSUMO.d_tipo_consumo as DES_oi_tipo_consumo
FROM 
  LIQ08_CONSUMOS, 
  LIQ08_TIPO_CONSUMO
JOIN 
  LIQ08_CONSUMOS.oi_tipo_consumo LEFT OUTER LIQ08_TIPO_CONSUMO.oi_tipo_consumo
WHERE 
LIQ08_CONSUMOS.oi_consumo in ({%=$PARAM/@IDS %})
ORDER BY
COD asc')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="c_consumo" value="$r/@c_consumo"/>
						<qry:attribute name="d_consumo" value="$r/@d_consumo"/>
						<qry:attribute name="oi_tipo_consumo" value="$r/@DES_oi_tipo_consumo"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Liquidacion.Consumos.CONSUMO.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Liquidacion.Consumos.CONSUMO.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  LIQ08_CONSUMOS.oi_consumo as ID, 
  LIQ08_CONSUMOS.c_consumo as COD, 
  LIQ08_CONSUMOS.d_consumo as DES
FROM 
  LIQ08_CONSUMOS
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
