				<form-properties show-list="true" find-include="false" automatico="1" label="Orden" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="int" column="e_orden"/>
