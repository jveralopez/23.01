			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LIQ12_TIPOS_CONC.oi_tipo_concepto as ID,
  LIQ12_TIPOS_CONC.c_tipo_concepto as COD,
  LIQ12_TIPOS_CONC.d_tipo_concepto as DES
from
  LIQ12_TIPOS_CONC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LIQ12_TIPOS_CONC.oi_tipo_concepto) as CNT
from
  LIQ12_TIPOS_CONC
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LIQ12_TIPOS_CONC.oi_tipo_concepto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LIQ12_TIPOS_CONC.d_tipo_concepto,{#SOURCE:@TXT_FIND}) or contain(LIQ12_TIPOS_CONC.c_tipo_concepto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
