<class-package xmlns:qry="nomad_engine.qry" name="Tipos_Concepto" meta-class="DB" languaje="SP" root-class="TIPO_CONCEPTO" DDOBase="NucleusRH\Base\Liquidacion">
	<class name="TIPO_CONCEPTO" size="M" description="Tipos de Conceptos" access="direct" label="Tipo Concepto">
		<meta-properties>
			<db-properties desc-column="d_tipo_concepto" code-column="c_tipo_concepto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LIQ12_TIPOS_CONC">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_tipos_conc" code-attr="c_tipos_conc" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
