							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_concepto as oi_tipo_concepto, t0.c_tipo_concepto as c_tipo_concepto, t0.d_tipo_concepto as d_tipo_concepto, t0.l_nolistado as l_nolistado, t0.e_orden as e_orden, SEC.policy, t0.c_tipo_concepto as CODE, t0.d_tipo_concepto as TEXT FROM LIQ12_TIPOS_CONC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO\') as SEC JOIN t0.oi_tipo_concepto LEFT OUTER SEC.id  ORDER BY oi_tipo_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_concepto"/>
								<qry:attribute name="c_tipo_concepto" value="$r/@c_tipo_concepto"/>
								<qry:attribute name="d_tipo_concepto" value="$r/@d_tipo_concepto"/>
								<qry:attribute name="l_nolistado" value="iif($r/@l_nolistado='1','1','0')"/>
								<qry:attribute name="e_orden" value="$r/@e_orden"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_concepto as oi_tipo_concepto, SEC.policy FROM LIQ12_TIPOS_CONC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Tipos_Concepto.TIPO_CONCEPTO\') as SEC JOIN t0.oi_tipo_concepto LEFT OUTER SEC.id  ORDER BY oi_tipo_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_concepto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
