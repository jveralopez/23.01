<class-package xmlns:qry="nomad_engine.qry" name="InterfaceConceptosMan" root-class="ENTRADA" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Liquidacion">
	<class description="Definici&#243;n de la interfaz de Conceptos Manuales" name="ENTRADA" access="direct">
		<meta-properties>
			<interface-properties file="IntItemsGan.dat" separator=";" mode="1" enter="1" separador=";" decimal="." escape="\"/>
		</meta-properties>
		<attribute length="5" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties/>
		</attribute>
		<attribute null="false" label="Legajo" length="15" name="e_numero_legajo" type="Nomad.NSystem.Int" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="c_concepto" null="false" label="C&#243;digo" length="30" type="Nomad.NSystem.String" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Double" length="15" label="Valor" name="n_valor" readonly="false" null="false" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="15" type="Nomad.NSystem.Double" label="Cantidad" name="n_cantidad" readonly="false" null="false" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" type="Nomad.NSystem.String" label="Centro de costo" name="c_centro_costo" readonly="false" null="true" precision="0" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="QRY_OIArchivo">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:IntItemsGan.dat')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<method name="Importar" description="Importar los items de ganancia al legajo liquidaci&#243;n." modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="poi_liquidacion" type="Nomad.NSystem.String" pass="byval"/>
			</arguments>
		</method>
	</class>
</class-package>
