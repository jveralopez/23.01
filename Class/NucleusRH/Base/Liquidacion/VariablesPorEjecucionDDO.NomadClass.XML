		<resource include="false" declare="&lt;FILTRO oi_empresa=&quot;1&quot; oi_tipo_liq=&quot;1&quot;/&gt;" name="CargarVariablesALiquidacion">
			<qry:main doc="PARAM">
				<qry:element name="object">
					<qry:attribute name="id" value="'%1'"/>
					<qry:attribute name="class" value="'NucleusRH.Base.Liquidacion.VariablesPorEjecucionDDO.VAR_EJEC_DDO'"/>
					<qry:attribute name="nmd-status" value="'~i,'"/>
					<qry:insert-select doc-path="#PARAM:/FILTRO" name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:out>
					<qry:element name="VAR_EJEC_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:element name="VARIABLES">
							<qry:insert-select doc-path="#PARAM:" name="sql2"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="sql2">
				<qry:out>
					<qry:element name="VARIABLE_DDO">
						<qry:attribute name="nmd-status" value="'~i,'"/>
						<qry:attribute name="id" value="'%1'"/>
						<qry:attribute name="TipoDeVariable" value="$r/@c_tipo_variable"/>
						<qry:attribute name="Codigo" value="$r/@c_variable"/>
						<qry:attribute name="Descripcion" value="$r/@d_variable"/>
						<qry:attribute name="TipoDeDato" value="$r/@c_tipo_dato"/>
						<qry:attribute name="Apertura" value="$r/@l_apertura"/>
						<qry:attribute name="Valor" value="$r/@n_valor"/>
						<qry:attribute name="Reservada" value="$r/@l_reservada"/>
					</qry:element>
				</qry:out>
				<qry:xquery>
					for $r in sql('
SELECT  
	t.oi_variable as oi_variable,  
	t.c_tipo_variable,  
	t.c_variable,  
	t.d_variable,  
	t.c_tipo_dato,  
	t.l_apertura,  
	t.n_valor,  
	t.l_reservada
FROM 
	LIQ09_VARIABLES as t,
	LIQ14_CONC_VAR as tc,
	LIQ14_CONCEPTOS as c,          
	LIQ02_TLIQ_GRUPO as tg,
	(
		SELECT
			x1.oi_grupo_empresa
		FROM
			LIQ24_GRUPOS_EMPRE as x1,
			LIQ24_EMP_GRUPOEMP as x2
		JOIN
			x1.oi_grupo_empresa INNER x2.oi_grupo_empresa
		WHERE 
			x2.oi_empresa = {%=#PARAM:@oi_empresa %}
	) as ge
JOIN
	tc.oi_variable INNER t.oi_variable,
	tc.oi_concepto INNER c.oi_concepto,
	c.oi_grupo_tliq INNER tg.oi_grupo_tliq,
	c.oi_grupo_empresa left outer ge.oi_grupo_empresa
WHERE
	tg.oi_tipo_liq = {#PARAM:@oi_tipo_liq} and
	c.l_activo = 1
GROUP BY t.oi_variable,
	t.c_tipo_variable,
	t.c_variable,
	t.d_variable,
	t.c_tipo_dato,
	t.l_apertura,
	t.n_valor,
	t.l_reservada

UNION

SELECT  
	v.oi_variable,
	v.c_tipo_variable,  
	v.c_variable,  
	v.d_variable,  
	v.c_tipo_dato,  
	v.l_apertura,  
	v.n_valor,  
	v.l_reservada
FROM 
	LIQ09_VARIABLES as v
WHERE
	v.c_tipo_variable IN (\'5\',\'6\',\'9\')
ORDER BY
	c_variable ASC
			')/ROWS/ROW
				</qry:xquery>
			</qry:select>
		</resource>
