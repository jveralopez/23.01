							for $r in sql('SELECT t0.oi_var_ejec_ddo as oi_var_ejec_ddo, SEC.policy, t0.oi_var_ejec_ddo as CODE, t0.oi_var_ejec_ddo as TEXT FROM LIQ95_VAR_EJEC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.VariablesPorEjecucionDDO.VAR_EJEC_DDO\') as SEC JOIN t0.oi_var_ejec_ddo LEFT OUTER SEC.id  ORDER BY oi_var_ejec_ddo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
