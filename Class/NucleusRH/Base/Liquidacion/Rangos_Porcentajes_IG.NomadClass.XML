		<meta-properties>
			<db-properties desc-column="oi_ig" code-column="oi_ig" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LIQ06_IG">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="oi_ig" code-attr="oi_ig" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
