					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_ig as oi_ig, t0.e_anio as e_anio, t0.e_mes as e_mes, t0.n_tot_imp_d as n_tot_imp_d, t0.n_tot_imp_h as n_tot_imp_h, t0.n_cuota as n_cuota, t0.n_p_rango as n_p_rango, SEC.policy, t0.oi_ig as CODE, t0.oi_ig as TEXT FROM LIQ06_IG as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG\') as SEC JOIN t0.oi_ig LEFT OUTER SEC.id  ORDER BY oi_ig asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_ig"/>
								<qry:attribute name="e_anio" value="$r/@e_anio"/>
								<qry:attribute name="e_mes" value="$r/@e_mes"/>
								<qry:attribute name="n_tot_imp_d" value="$r/@n_tot_imp_d"/>
								<qry:attribute name="n_tot_imp_h" value="$r/@n_tot_imp_h"/>
								<qry:attribute name="n_cuota" value="$r/@n_cuota"/>
								<qry:attribute name="n_p_rango" value="$r/@n_p_rango"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_ig as oi_ig, SEC.policy FROM LIQ06_IG as t0,NMD_SECURITY(class=\'NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.IG\') as SEC JOIN t0.oi_ig LEFT OUTER SEC.id  ORDER BY oi_ig asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_ig"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Liquidacion.Rangos_Porcentajes_IG.flow:initialize" desc-attr="oi_ig" code-attr="oi_ig" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="0"/>
