		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LIQ09_VARIABLES.oi_variable as ID,
  LIQ09_VARIABLES.c_variable as COD,
  LIQ09_VARIABLES.d_variable as DES
from
  LIQ09_VARIABLES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Liquidacion.Variables.VARIABLE.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LIQ09_VARIABLES.oi_variable) as CNT
from
  LIQ09_VARIABLES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LIQ09_VARIABLES.oi_variable={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LIQ09_VARIABLES.d_variable,{#SOURCE:@TXT_FIND}) or contain(LIQ09_VARIABLES.c_variable,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATOS oi_var=&quot;1404&quot;/&gt;" name="qry_CodigosVariables" description="recupera el oi_variable a partir de un codigo">
			<qry:main doc="PARAM">
				<qry:element name="VARS">
					<qry:insert-select name="qry_var" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_var" doc="PARAM">
				<qry:xquery>
					for $r in SQL(' 
				SELECT
					v.oi_variable,
					v.c_externo,
					v.c_tipo_dato
				FROM 
					LIQ09_VARIABLES as v
				WHERE 
					v.oi_variable = {#PARAM:@oi_var}
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="VAR">
						<qry:attribute value="$r/@c_tipo_dato" name="c_tipo_dato"/>
						<qry:attribute value="$r/@c_externo" name="c_variable"/>
						<qry:attribute value="$r/@oi_variable" name="oi_variable"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
