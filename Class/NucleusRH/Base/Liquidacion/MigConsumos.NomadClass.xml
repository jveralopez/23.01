<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Liquidacion" root-class="CONSUMOS" name="MigConsumos" meta-class="DB" languaje="SP">
	<class description="Consumos" label="Consumo" access="direct" size="XL" name="CONSUMOS">
		<meta-properties>
			<interface-properties file="LIQ_Consumos.dat" mode="1" enter="1" separator=";" decimal=","/>
		</meta-properties>
		<attribute length="30" label="Codigo consumo persona" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_consumo_per" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" label="codigo empresa" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_empresa" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" label="numero de legajo" default="''" readonly="false" null="false" type="Nomad.NSystem.Int" name="e_numero_legajo" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" label="Codigo de consumo" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_consumo" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute precision="0" length="10" label="Fecha de consumo" default="''" readonly="false" null="false" type="Nomad.NSystem.DateTime" name="f_consumo" manual="1">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute precision="2" default="''" length="20" label="Importe" readonly="false" null="false" type="Nomad.NSystem.String" name="e_importe" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="100" label="Observaciones" default="''" readonly="false" null="true" type="Nomad.NSystem.String" name="d_observaciones" manual="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importar Consumos desde Archivo" modifier="static" access="public" name="ImportarConsumos">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:LIQ_Consumos.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
