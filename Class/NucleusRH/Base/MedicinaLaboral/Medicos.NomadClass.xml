							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_medico as oi_medico, t0.d_apellido as d_apellido, t0.d_nombres as d_nombres, t0.te_particular as te_particular, SEC.policy, t0.c_nro_documento as CODE, t0.d_apellido as TEXT, t0.oi_localidad as oi_localidad, t0.oi_especialidad as oi_especialidad FROM MED03_MEDICOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.MedicinaLaboral.Medicos.MEDICO\') as SEC JOIN t0.oi_medico LEFT OUTER SEC.id  ORDER BY oi_medico asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_medico"/>
								<qry:attribute name="d_apellido" value="$r/@d_apellido"/>
								<qry:attribute name="d_nombres" value="$r/@d_nombres"/>
								<qry:attribute name="te_particular" value="$r/@te_particular"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
