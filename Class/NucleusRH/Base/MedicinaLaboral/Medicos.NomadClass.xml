							for $r in sql('SELECT t0.oi_medico as oi_medico, SEC.policy FROM MED03_MEDICOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.MedicinaLaboral.Medicos.MEDICO\') as SEC JOIN t0.oi_medico LEFT OUTER SEC.id  ORDER BY oi_medico asc')/ROWS/ROW
