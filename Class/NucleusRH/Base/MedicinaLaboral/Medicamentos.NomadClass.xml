{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  MED08_MEDICAMENTOS.oi_medicamento as ID,
  MED08_MEDICAMENTOS.c_medicamento as COD,
