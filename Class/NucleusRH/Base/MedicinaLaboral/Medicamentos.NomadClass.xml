{%? (#SOURCE:@OI_FIND='') {% %} {% and MED08_MEDICAMENTOS.oi_medicamento={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(MED08_MEDICAMENTOS.d_medicamento,{#SOURCE:@TXT_FIND}) or contain(MED08_MEDICAMENTOS.c_medicamento,{#SOURCE:@TXT_FIND})) %} %} 
