		<resource description="Retorna los OI de las evaluaciones asignados al Evento." name="qryEvaluaciones" declare="&lt;DATA evento=&quot;2&quot; /&gt;">
			<qry:main doc="PARAM">
				<qry:element name="objects">
					<qry:insert-select name="qryClase" doc-path="#PARAM:DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryClase" doc="PARAM">
				<qry:xquery>
					for $f in sql(' 

			SELECT
				p.e_numero_legajo,
				e.oi_evaluacion,
				e.c_estado
			
			FROM 
				eva02_evaluacion AS e,
				per02_Personal_emp AS p
				
			JOIN		
				e.oi_personal_emp INNER p.oi_personal_emp
			WHERE
				e.oi_evento = ({%=#PARAM:@evento %})
									
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="object">
						<qry:attribute value="$f/@e_numero_legajo" name="e_numero_legajo"/>
						<qry:attribute value="$f/@oi_evaluacion" name="oi_evaluacion"/>
						<qry:attribute value="$f/@c_estado" name="c_estado"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATOS oi_evento=&quot;3&quot; oi_personal_emps=&quot;-1, 82&quot;/&gt;" description="Retorna los datos de los evaluadores y los evaluados de un Evento." name="qryEvaluadoresEvaluados">
			<qry:main doc="PARAM">
				<qry:element name="objects">
					<qry:insert-select name="qryMain" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain" doc="PARAM">
				<qry:xquery>
					for $f in sql(' 

			SELECT
				eve.oi_evaluador, 
				eve.oi_personal_emp,
				p_emp.d_ape_y_nom as nom_evaluado,
				p_ev.d_ape_y_nom as nom_evaluador,
				p_ev.oi_usuario_sistema as oi_usuario_evaluador,
				pe_emp.e_numero_legajo as legajo_evaluado
			
			FROM
			
				EVA02_EVALUACION as eve,
				PER02_PERSONAL_EMP as pe_ev,
				PER02_PERSONAL_EMP as pe_emp,
				PER01_PERSONAL as p_ev,
				PER01_PERSONAL as p_emp
			
			JOIN
				eve.oi_evaluador INNER pe_ev.oi_personal_emp,
				eve.oi_personal_emp INNER pe_emp.oi_personal_emp,
				pe_ev.oi_personal INNER p_ev.oi_personal,
				pe_emp.oi_personal INNER p_emp.oi_personal
			
			WHERE
				eve.oi_evento = ({%=#PARAM:@oi_evento %}) 
			    {%? (#PARAM:@oi_personal_emps != '') {% AND eve.oi_personal_emp IN ({%= #PARAM:@oi_personal_emps%}) %} {% %} %}

			ORDER BY 
				oi_evaluador ASC
			    
			
									
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="object">
						<qry:attribute value="$f/@oi_usuario_evaluador" name="oi_usuario_evaluador"/>
						<qry:attribute value="$f/@legajo_evaluado" name="legajo_evaluado"/>
						<qry:attribute value="$f/@nom_evaluado" name="nom_evaluado"/>
						<qry:attribute value="$f/@oi_personal_emp" name="oi_personal_emp"/>
						<qry:attribute value="$f/@nom_evaluador" name="nom_evaluador"/>
						<qry:attribute value="$f/@oi_evaluador" name="oi_evaluador"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATO oi_evento=&quot;3&quot;/&gt;" name="QRY_ADMINISTRAR">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="RS1" doc-path="#SOURCE:DATO"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql(' 
				SELECT EVA02_EVALUACION.oi_evaluacion,
				PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.e_numero_legajo,
				PER01_PERSONAL.d_ape_y_nom
				FROM EVA02_EVALUACION, PER02_PERSONAL_EMP, PER01_PERSONAL
				JOIN EVA02_EVALUACION.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
				PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE EVA02_EVALUACION.oi_evento = {#SOURCE:@oi_evento}
      ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@oi_evaluacion" name="oi_evaluacion"/>
						<qry:attribute value="$r/@oi_personal_emp" name="oi_personal_emp"/>
						<qry:attribute value="$r/@e_numero_legajo + ' - ' + $r/@d_ape_y_nom" name="persona"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
