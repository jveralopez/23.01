  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and EVA03_MOTIVO_EVA.oi_mot_eval={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(EVA03_MOTIVO_EVA.d_mot_eval,{#SOURCE:@TXT_FIND}) or contain(EVA03_MOTIVO_EVA.c_mot_eval,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
