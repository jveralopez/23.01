						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mot_eval as oi_mot_eval, t0.c_mot_eval as c_mot_eval, t0.d_mot_eval as d_mot_eval, SEC.policy, t0.c_mot_eval as CODE, t0.d_mot_eval as TEXT FROM EVA03_MOTIVO_EVA as t0,NMD_SECURITY(class=\'NucleusRH.Base.Evaluacion.Motivos_Evaluacion.MOT_EVAL\') as SEC JOIN t0.oi_mot_eval LEFT OUTER SEC.id  ORDER BY oi_mot_eval asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mot_eval"/>
								<qry:attribute name="c_mot_eval" value="$r/@c_mot_eval"/>
								<qry:attribute name="d_mot_eval" value="$r/@d_mot_eval"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
