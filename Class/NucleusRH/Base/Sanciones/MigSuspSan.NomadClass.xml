<class-package xmlns:qry="nomad_engine.qry" name="MigSuspSan" root-class="SUSP_SANCION" DDOBase="NucleusRH\Base\Sanciones" meta-class="DB" languaje="SP">
	<class name="SUSP_SANCION" description="Legajos de Sanci&#243;n" label="Legajos de Sanci&#243;n" size="L" note="Registra los Cursos que posee el Personal." access="direct">
		<meta-properties>
			<interface-properties file="SAN03_SUSP_PER.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute label="C&#243;digo de Empresa" name="c_empresa" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" OriginalName="oi_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" description="N&#250;mero de Legajo." label="Numero Legajo" name="e_numero_legajo" OriginalName="e_numero_legajo">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute description="Fecha Hora Sancion" label="Fecha Hora Sanci&#243;n" name="f_fechahora_sanc" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_vencimiento_doc">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy HH:MM"/>
			</meta-properties>
		</attribute>
		<attribute description="Fecha Inicio Sancion" label="Fecha Inicio" name="f_fechahora_ini" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_vencimiento_doc">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute description="Fecha Fin Sancion" label="Fecha Fin Sanci&#243;n" name="f_fechahora_fin" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_vencimiento_doc">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute null="false" description="D&#237;as de Suspensi&#243;n" label="D&#237;as de Suspensi&#243;n" name="e_dias_susp" readonly="false" default="''" type="Nomad.NSystem.Int" OriginalName="e_numero_legajo">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importar Suspensi&#243;n de Sanciones desde Archivo" name="ImportarSuspSan" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Sanciones.MigSuspSan.SUSP_SANCION" library="" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:SAN03_SUSP_PER.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATOS oi_personal_emp = &quot;11567&quot; f_fechahora_sanc= &quot;20120411152900&quot; /&gt;" name="QRY_SANCION">
			<qry:main doc="PARAM">
				<qry:element name="DATOS">
					<qry:insert-select doc-path="#PARAM:DATOS" name="RS1"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
        SELECT 
        	SAN03_SANCION_PER.oi_sancion_per,
        	SAN03_SANCION_PER.oi_sancion
        FROM 
        	SAN03_SANCION_PER 
     		WHERE 
     			SAN03_SANCION_PER.oi_personal_emp = {#SOURCE:@oi_personal_emp} 
     			AND SAN03_SANCION_PER.f_fechahora_sanc = {Datetime(#SOURCE:@f_fechahora_sanc)}
		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_sancion_per" value="$r/@oi_sancion_per"/>
					<qry:attribute name="oi_sancion" value="$r/@oi_sancion"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
