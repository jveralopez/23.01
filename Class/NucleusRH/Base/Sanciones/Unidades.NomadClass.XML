							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_unidad as oi_unidad, t0.c_unidad as c_unidad, t0.d_unidad as d_unidad, SEC.policy, t0.c_unidad as CODE, t0.d_unidad as TEXT FROM SAN04_UNIDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Sanciones.Unidades.UNIDAD\') as SEC JOIN t0.oi_unidad LEFT OUTER SEC.id  ORDER BY oi_unidad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_unidad"/>
								<qry:attribute name="c_unidad" value="$r/@c_unidad"/>
								<qry:attribute name="d_unidad" value="$r/@d_unidad"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
