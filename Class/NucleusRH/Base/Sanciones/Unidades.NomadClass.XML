	<class size="S" description="Unidades de Sanciones" access="direct" label="Unidad" name="UNIDAD">
		<meta-properties>
			<db-properties desc-column="d_unidad" code-column="c_unidad" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SAN04_UNIDADES">
				<security table="NMD_SECURITY"/>
