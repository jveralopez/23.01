							for $r in sql('SELECT t0.oi_unidad as oi_unidad, SEC.policy FROM SAN04_UNIDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Sanciones.Unidades.UNIDAD\') as SEC JOIN t0.oi_unidad LEFT OUTER SEC.id  ORDER BY oi_unidad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_unidad"/>
							</qry:element>
						</qry:out>
					</qry:select>
