			<form-properties binary="NONE" desc-attr="d_unidades" code-attr="c_unidades" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
