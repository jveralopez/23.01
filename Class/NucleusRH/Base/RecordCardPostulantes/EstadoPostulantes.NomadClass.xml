		<method description="Ejecuta un query devuelve su resultado como xml" return-class="System.Xml.XmlDocument" label="Obtiene el DDO del RC" return-type="Nomad.NSystem.Object" access="public" name="ObtieneDDORC">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument description="Par&#225;metros para el query que crea el DDO de recordcard" type="Nomad.NSystem.String" pass="byval" name="parametrosQry"/>
			</arguments>
		</method>
		<resource declare="&lt;param id=&quot;114596&quot; /&gt;" description="Query que obtiene los datos de los cambios de Cantidad de pedidos" name="QRY">
			<qry:main doc="SOURCE">
				<qry:element name="object">
					<qry:attribute value="'NucleusRH.Base.RecordCardPostulantes.EstadoPostulantes.ACCION_REAL'" name="class"/>
					<qry:attribute value="'~i,'" name="nmd-status"/>
					<qry:insert-select doc-path="#SOURCE:/param" name="RC"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RC">
				<qry:xquery>
					for $r in table('select  
pos01_cv.c_legajo, 
pos01_cv.d_ape_y_nom,
pos01_cv.c_estado,
pos01_cv.c_cv, 
pos01_cv.oi_cv,
pos01_cv.c_ult_estado,
pos01_cv.d_mot_cambio,
pos01_cv.oi_mot_cambio,
pos01_cv.l_legales,
pos01_cv.l_carta_doc,
pos01_cv.c_nro_doc
from pos01_cv
			where 
     pos01_cv.oi_cv= {%=#SOURCE:@id%}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="no-object">
						<qry:attribute value="$r/@oi_cv" name="oi_cv"/>
						<qry:attribute value="iif($r/@c_estado='D','Disponible',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='A','En Dotaci&#243;n',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='E','Efectivizado',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='N','No Llamar',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='R','Reasignable',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='V','Vencido',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='P','Conflictivos Pendientes',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='J','Estado Judicial',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='S','Acuerdo - Seclo',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='D','Disponible',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='A','En Dotaci&#243;n',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='E','Efectivizado',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='N','No Llamar',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='R','Reasignable',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='V','Vencido',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='P','Conflictivos Pendientes',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='J','Estado Judicial',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='S','Acuerdo - Seclo',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="'Se cambi&#243; el Estado del Postulante de: '+ @c_ult_estado + ' a: ' + @c_estado" name="descr"/>
						<qry:if test="$r/@c_estado = $r/@c_ult_estado">
							<qry:then>
								<qry:attribute value="'Se cambiaron Datos del CV desde Legales'" name="descr"/>
							</qry:then>
							<qry:else/>
						</qry:if>
						<qry:insert-select name="qry_motivo" doc-path="$r"/>
						<qry:attribute value="@descr + ' [mot: ' + @motivo + ' | '+ $r/@d_mot_cambio + ']'" name="descr"/>
					</qry:element>
					<qry:element name="ACCION_REAL">
						<qry:attribute value="'~i,'" name="nmd-status"/>
						<qry:attribute value="$r/@c_legajo" name="c_legajo"/>
						<qry:attribute value="$r/@c_nro_doc" name="c_nro_doc"/>
						<qry:attribute value="$r/@d_ape_y_nom" name="d_ape_y_nom"/>
						<qry:attribute value="$r/@c_estado" name="c_estado"/>
						<qry:attribute value="$r/@c_cv" name="c_cv"/>
						<qry:attribute value="$r/@d_mot_cambio" name="d_mot_cambio"/>
						<qry:attribute value="$r/@l_legales" name="l_legales"/>
						<qry:attribute value="$r/@l_carta_doc" name="l_carta_doc"/>
						<qry:attribute value="iif($r/@c_estado='D','Disponible',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='A','En Dotaci&#243;n',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='E','Efectivizado',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='N','No Llamar',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='R','Reasignable',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='V','Vencido',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='P','Conflictivos Pendientes',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='J','Estado Judicial',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_estado='S','Acuerdo - Seclo',@c_estado)" name="c_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='D','Disponible',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='A','En Dotaci&#243;n',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='E','Efectivizado',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='N','No Llamar',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='R','Reasignable',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='V','Vencido',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='P','Conflictivos Pendientes',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='J','Estado Judicial',@c_ult_estado)" name="c_ult_estado"/>
						<qry:attribute value="iif($r/@c_ult_estado='S','Acuerdo - Seclo',@c_ult_estado)" name="c_ult_estado"/>
						<qry:element name="oi_evento">
							<qry:attribute value="'0'" name="oi_evento"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qry_motivo">
				<qry:xquery>
					for $r in sql('
SELECT
	POS07_MOT_CAMBIOS.c_mot_cambio,
	POS07_MOT_CAMBIOS.d_mot_cambio
FROM
	POS07_MOT_CAMBIOS
WHERE
	POS07_MOT_CAMBIOS.oi_mot_cambio = {#PARAM:@oi_mot_cambio}  
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@c_mot_cambio +' - ' + $r/@d_mot_cambio" name="motivo"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
