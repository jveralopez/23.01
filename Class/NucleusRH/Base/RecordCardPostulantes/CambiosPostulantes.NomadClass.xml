		<resource declare="&lt;param id=&quot;2727&quot; o_accion=&quot;Se modificaron Datos (no principales) del Postulante&quot; /&gt;" description="Query que obtiene los datos de los cambios" name="QRY">
			<qry:main doc="SOURCE">
				<qry:element name="object">
					<qry:attribute value="'NucleusRH.Base.RecordCardPostulantes.CambiosPostulantes.ACCION_REAL'" name="class"/>
					<qry:attribute value="'~i,'" name="nmd-status"/>
					<qry:insert-select doc-path="#SOURCE:/param" name="RC"/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="RC">
				<qry:xquery>
					for $r in table('select  
pos01_cv.c_legajo, 
pos01_cv.d_ape_y_nom,
pos01_cv.c_cv, 
pos01_cv.oi_cv,
pos01_cv.c_nro_doc
from pos01_cv
			where 
     pos01_cv.oi_cv= {%=#SOURCE:@id%}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="no-object">
						<qry:attribute value="$r/@oi_cv" name="oi_cv"/>
						<qry:attribute value="#SOURCE:@o_accion" name="descr"/>
					</qry:element>
					<qry:element name="ACCION_REAL">
						<qry:attribute value="'~i,'" name="nmd-status"/>
						<qry:attribute value="$r/@c_cv" name="c_cv"/>
						<qry:attribute value="$r/@c_legajo" name="c_legajo"/>
						<qry:attribute value="$r/@c_nro_doc" name="c_nro_doc"/>
