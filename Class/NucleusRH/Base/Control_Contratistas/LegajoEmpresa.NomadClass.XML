		<resource name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
select
CCO02_PER_EMP_CONT.oi_personal_emp as ID,
PER02_PERSONAL_EMP.oi_empresa as PARENT,
PER02_PERSONAL_EMP.e_numero_legajo AS COD, 
PER01_PERSONAL.d_ape_y_nom AS DES, 
ORG03_EMPRESAS.c_empresa as c_empresa,
ORG03_EMPRESAS.d_empresa as d_empresa

{%?($FILTER/@order!='') {% ,CCO02_PER_EMP_CONT.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM
CCO02_PER_EMP_CONT,
PER02_PERSONAL_EMP,
CCO01_EMPRESAS_CONT,
PER01_PERSONAL,
ORG03_EMPRESAS

JOIN
CCO02_PER_EMP_CONT.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal,
CCO01_EMPRESAS_CONT.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa,
CCO01_EMPRESAS_CONT.oi_empresa inner  ORG03_EMPRESAS.oi_empresa
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) 
 or contain(ucase(COD),{upper-case($FILTER/@search)})
 or contain(ucase(ORG03_EMPRESAS.c_empresa),{upper-case($FILTER/@search)})
 or contain(ucase( ORG03_EMPRESAS.d_empresa),{upper-case($FILTER/@search)})
  
 ) %}
 {% %}
%} 


{%?($FILTER/@order!='')
  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {% %}
%}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
