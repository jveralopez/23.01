<class-package xmlns:qry="nomad_engine.qry" root-class="GRUPO" name="Grupos" meta-class="DB" languaje="SP">
	<class size="L" description="Grupos" access="direct" label="Grupo" name="GRUPO">
		<meta-properties>
			<db-properties desc-column="d_grupo" code-column="c_grupo" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SEG02_GRUPOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_grupos" code-attr="c_grupos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_grupo as oi_grupo, t0.c_grupo as c_grupo, t0.d_grupo as d_grupo, t0.d_gruposeg as d_gruposeg, SEC.policy, t0.c_grupo as CODE, t0.d_grupo as TEXT FROM SEG02_GRUPOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Seguridad.Grupos.GRUPO\') as SEC JOIN t0.oi_grupo LEFT OUTER SEC.id  ORDER BY oi_grupo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_grupo"/>
								<qry:attribute name="c_grupo" value="$r/@c_grupo"/>
								<qry:attribute name="d_grupo" value="$r/@d_grupo"/>
								<qry:attribute name="d_gruposeg" value="$r/@d_gruposeg"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_grupo as oi_grupo, SEC.policy FROM SEG02_GRUPOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Seguridad.Grupos.GRUPO\') as SEC JOIN t0.oi_grupo LEFT OUTER SEC.id  ORDER BY oi_grupo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_grupo"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_grupos" code="c_grupos" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Seguridad.Grupos.autoflow:initialize" desc-attr="d_grupo" code-attr="c_grupo" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_grupo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_grupo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_grupo" OriginalName="c_grupo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_grupo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_grupo" OriginalName="d_grupo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_grupo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="ID Grupo Seguridad" name="oi_grupo_seguridad" OriginalName="oi_grupo_seguridad">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="oi_grupo_seguridad"/>
				<form-properties show-list="false" find-include="false" automatico="0" label="ID Grupo Seguridad" lock="false" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n GS" name="d_gruposeg" OriginalName="d_gruposeg">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n GS" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(100)" column="d_gruposeg"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_SEG02_GRUPOS" name="AK_SEG02_GRUPOS">
			<key-attr assosiation="no" name="c_grupo"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Seguridad.Grupos.GRUPO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SEG02_GRUPOS.oi_grupo as ID,
  SEG02_GRUPOS.c_grupo as COD,
  SEG02_GRUPOS.d_grupo as DES
from
  SEG02_GRUPOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Seguridad.Grupos.GRUPO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SEG02_GRUPOS.oi_grupo) as CNT
from
  SEG02_GRUPOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SEG02_GRUPOS.oi_grupo={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SEG02_GRUPOS.d_grupo,{#SOURCE:@TXT_FIND}) or contain(SEG02_GRUPOS.c_grupo,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_GS" declare="&lt;DATA  /&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY" doc="SOURCE">
				<qry:out>
					<qry:if test="#SOURCE:@OI_FIND=''">
						<qry:then>
							<qry:insert-select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY.PATH" doc-path="#SOURCE:"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="FILE" value="#SOURCE:@oi_find+'.GRUPO.XML'"/>
							<qry:insert-select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY.DDO" doc-path="."/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY.PATH" doc="SOURCE">
				<qry:xquery>
					for $r in METHOD('Nomad.Base.Report.Listas.INDICE:SuperComboIndex({\'Nomad\\\\Base\\\\Login\\\\Grupos\'},{\'Nomad.Base.Login.Grupos.GRUPO.INFO\'},{#SOURCE:@TXT_FIND},{floor(#SOURCE:@START)},{floor(#SOURCE:@LEN)},{#SOURCE:@ORDERBY})')/*
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r/ROW"/>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.Seguridad.Grupos.GRUPO.QUERY.DDO" doc="SOURCE">
				<qry:xquery>
					for $r in FILE('Nomad\\Base\\Login\\Grupos\\{%=#SOURCE:@file%}')/GRUPO
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
