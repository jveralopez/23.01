		<method modifier="static" access="public" label="updTablasFact" name="updTablasFact">
			<meta-properties>
				<dotnet11-properties type="source">
					Nomad.NSystem.Base.NomadBatch objBatch;
string param_anio;
string param_Mes;
int pAnio;
int pMes;
string xmlString;
                                      
Nomad.NSystem.Base.NomadBatch.Trace("*********  Comienza la ejecucion de Actualizacion de Dimensiones **************");         


	NucleusRH.Base.Indicadores.Ejecuciones.clsDimensiones nmdDim;
    
	xmlString=NucleusRH.Base.Indicadores.Ejecuciones.EJECUCION.Resources.rec_XMLDimensiones;
	nmdDim = new NucleusRH.Base.Indicadores.Ejecuciones.clsDimensiones();
      
	objBatch = Nomad.NSystem.Base.NomadBatch.GetBatch("Iniciando...", "Ejecutando");

	objBatch.SetSubBatch(0, 100);

		Nomad.NSystem.Base.NomadBatch.Trace("* date_AnioMes" + date_AnioMes + " length : " + date_AnioMes.Length );
		
		param_anio= date_AnioMes.Substring(0,4)  ;
		param_Mes= date_AnioMes.Substring(4,2);
		            
		
		NomadEnvironment.GetTrace().Info("* param_anio" + param_anio );
		NomadEnvironment.GetTrace().Info("* param_Mes" + param_Mes );
		pAnio =Int32.Parse(param_anio); 
		pMes = Int32.Parse(param_Mes);

	nmdDim.ConectaNomadDim(xmlString,pAnio,pMes , str_Tablas); 

		objBatch.SetMess(" Fin actualizacion");     
Nomad.NSystem.Base.NomadBatch.Trace("********* Fin del proceso **************");
				</dotnet11-properties>
			</meta-properties>
			<arguments>
				<argument pass="byval" type="Nomad.NSystem.String" name="str_Tablas"/>
				<argument name="date_AnioMes" type="Nomad.NSystem.String" pass="byval"/>
			</arguments>
		</method>
