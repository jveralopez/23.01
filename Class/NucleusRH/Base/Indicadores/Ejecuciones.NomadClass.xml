							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_ejecucion as oi_ejecucion, t0.c_ejecucion as c_ejecucion, t0.d_ejecucion as d_ejecucion, t0.c_estado as c_estado, t0.f_Inicio_ejec as f_Inicio_ejec, t0.f_fin_ejec as f_fin_ejec, t0.c_mes_anio as c_mes_anio, t0.c_modulo_tco as c_modulo_tco, SEC.policy, t0.c_ejecucion as CODE, t0.d_ejecucion as TEXT FROM TCO01_EJECUCIONES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Indicadores.Ejecuciones.EJECUCION\') as SEC JOIN t0.oi_ejecucion LEFT OUTER SEC.id  ORDER BY oi_ejecucion asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_ejecucion"/>
								<qry:attribute name="c_ejecucion" value="$r/@c_ejecucion"/>
								<qry:attribute name="d_ejecucion" value="$r/@d_ejecucion"/>
								<qry:attribute name="c_estado" value="$r/@c_estado"/>
								<qry:attribute name="f_Inicio_ejec" value="$r/@f_Inicio_ejec"/>
								<qry:attribute name="f_fin_ejec" value="$r/@f_fin_ejec"/>
								<qry:attribute name="c_mes_anio" value="$r/@c_mes_anio"/>
								<qry:attribute name="c_modulo_tco" value="$r/@c_modulo_tco"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
