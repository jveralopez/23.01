			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Contrato. Puede ser alfanum&#233;rico de hasta   30 caracteres." label="C&#243;digo" name="c_contrato" OriginalName="c_contrato">
