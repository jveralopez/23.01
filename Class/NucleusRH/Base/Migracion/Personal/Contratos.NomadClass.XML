		<method description="Importar Contratos desde Archivo" modifier="static" access="public" name="ImportarContratos">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Migracion.Personal.Contratos.CONTRATO" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:PER00_Contratos.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
