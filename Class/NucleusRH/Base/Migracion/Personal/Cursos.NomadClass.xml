		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_curso_per" OriginalName="o_documento_per">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importar Cursos desde Archivo" name="ImportarCursos" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties library="" class="NucleusRH.Base.Migracion.Personal.Cursos.CURSO_PER" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:PER13_Cursos.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA oi_personal='2749' oi_curso='2' f_fin_curso='20180701' d_titulo='CCNA Routing &amp;amp; Switching' /&gt;" include="true" name="QRY_DUPLICADAS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT PER01_CURSOS_PER.oi_curso_ext_per
FROM PER01_CURSOS_PER
WHERE PER01_CURSOS_PER.oi_personal = {#SOURCE:@oi_personal} and
PER01_CURSOS_PER.oi_curso = {#SOURCE:@oi_curso} and
PER01_CURSOS_PER.f_fin_curso = {#SOURCE:@f_fin_curso} and
PER01_CURSOS_PER.d_curso_ext_per = {#SOURCE:@d_titulo}

')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="oi_curso_ext_per" value="$r/@oi_curso_ext_per"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
