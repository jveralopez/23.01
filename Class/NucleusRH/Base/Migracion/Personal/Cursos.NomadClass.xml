		</attribute>
		<attribute name="c_unidad_tiempo" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="Unidad de Tiempo" label="Unidad de Tiempo" OriginalName="c_documento">
			<meta-properties>
