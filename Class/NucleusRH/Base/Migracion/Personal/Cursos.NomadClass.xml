			</meta-properties>
		</attribute>
		<attribute label="C&#243;digo de &#193;rea de Curso" length="30" type="Nomad.NSystem.String" ParentId="1" null="false" readonly="false" default="''" name="c_area_curso" OriginalName="c_tipo_documento">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="T&#237;tulo del Curso" label="T&#237;tulo" name="d_titulo" OriginalName="d_resp_expedicion">
			<meta-properties>
