		<resource name="QRY_REGISTROS">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:PER04_Legajos.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource description="Devuelve la unidad organizativa determinada por una posicion y el organigrama de posiciones de una empresa" declare="&lt;DATOS oi_posicion=&quot;70&quot; oi_empresa=&quot;167&quot;/&gt;" name="QRY_DATOS_POS">
			<qry:main doc="SOURCE" maxdeep="1">
				<qry:element name="DATOS">
					<qry:insert-select name="QRY_EMPRESA" doc-path="#SOURCE:DATOS"/>
					<qry:insert-select name="QRY_ESTRUCTURA" doc-path="#SOURCE:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="QRY_EMPRESA" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG03_EMPRESAS.c_empresa
				FROM ORG03_EMPRESAS
				WHERE ORG03_EMPRESAS.oi_empresa = {#SOURCE:@oi_empresa}				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="QRY_CLASE" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_CLASE" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT ORG02_CLASES_ORG.oi_clase_org
				FROM ORG02_CLASES_ORG
				WHERE ORG02_CLASES_ORG.c_clase_org = {#SOURCE:@c_empresa} + \' POS \'				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
				</qry:out>
			</qry:select>
			<qry:select name="QRY_ESTRUCTURA" doc="SOURCE">
				<qry:xquery>
					for $r in sql('				
					SELECT ORG04_POSICIONES.oi_unidad_org
					FROM ORG04_POSICIONES
					WHERE ORG04_POSICIONES.oi_posicion = {#SOURCE:@oi_posicion}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_unidad_org" value="$r/@oi_unidad_org"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA oi_empresa='1' /&gt;" name="QRY_CALENDARIO">
			<qry:main doc="SOURCE" name="">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_calendarios" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_calendarios" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
	SELECT 
	ORG27_CAL_FERIADOS.oi_calendario,
	ORG03_EMPRESAS.c_empresa,
	ORG27_CAL_FERIADOS.c_calendario 
	FROM 
	ORG27_CAL_FERIADOS, 
	ORG03_FERIADOS_EMP,
	ORG03_EMPRESAS
	JOIN 
	org27_cal_feriados.oi_calendario INNER ORG03_FERIADOS_EMP.oi_calendario,   
	ORG03_EMPRESAS.oi_empresa INNER  ORG03_FERIADOS_EMP.oi_empresa
	WHERE 
	ORG03_FERIADOS_EMP.oi_empresa = {#SOURCE:@oi_empresa}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="codigo" value="concat($r/@c_empresa,'_',$r/@c_calendario)"/>
						<qry:attribute name="oi_calendario" value="$r/@oi_calendario"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
