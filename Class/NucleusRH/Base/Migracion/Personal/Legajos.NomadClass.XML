		<method description="Importar Legajos desde Archivo" modifier="static" access="public" name="ImportarLegajos">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Migracion.Personal.Legajos.PERSONAL_EMP" type="lib"/>
			</meta-properties>
			<arguments/>
