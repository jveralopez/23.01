					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_item_costo as oi_item_costo, t0.c_item_costo as c_item_costo, t0.d_item_costo as d_item_costo, t0.n_costo as n_costo, SEC.policy, t0.c_item_costo as CODE, t0.d_item_costo as TEXT, t0.oi_tipo_costo as oi_tipo_costo FROM SEL05_ITEMS_COSTO as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Items_Costo.ITEM_COSTO\') as SEC JOIN t0.oi_item_costo LEFT OUTER SEC.id  ORDER BY oi_item_costo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_item_costo"/>
								<qry:attribute name="c_item_costo" value="$r/@c_item_costo"/>
								<qry:attribute name="d_item_costo" value="$r/@d_item_costo"/>
								<qry:attribute name="n_costo" value="$r/@n_costo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tipo_costo!=''">
									<qry:then>
										<qry:element name="oi_tipo_costo">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipo_costo"/>
											<qry:insert-select name="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Costos.TIPO_COSTO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipo_costo" value="'['+oi_tipo_costo/ROW/@COD+'] '+oi_tipo_costo/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_item_costo as oi_item_costo, SEC.policy FROM SEL05_ITEMS_COSTO as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Items_Costo.ITEM_COSTO\') as SEC JOIN t0.oi_item_costo LEFT OUTER SEC.id  ORDER BY oi_item_costo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_item_costo"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
