				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_tipo_costo"/>
				<form-properties automatico="0" label="Tipo Costo" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tipo_costo"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" label="Monto Costo" name="n_costo" OriginalName="n_costo">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="numeric(11,3)" column="n_costo"/>
				<form-properties automatico="0" show-list="true" find-include="false" label="Monto Costo" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
		</attribute>
