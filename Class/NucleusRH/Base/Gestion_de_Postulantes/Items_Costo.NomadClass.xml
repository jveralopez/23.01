		<meta-properties>
			<db-properties desc-column="d_item_costo" code-column="c_item_costo" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SEL05_ITEMS_COSTO">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_items_costo" code-attr="c_items_costo" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
