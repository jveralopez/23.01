			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Items_Costo.ITEM_COSTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SEL05_ITEMS_COSTO.oi_item_costo as ID,
  SEL05_ITEMS_COSTO.c_item_costo as COD,
