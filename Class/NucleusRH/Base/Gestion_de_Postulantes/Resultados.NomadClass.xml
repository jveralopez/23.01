			<form-properties binary="NONE" desc-attr="d_resultados" code-attr="c_resultados" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_resultado as oi_resultado, t0.c_resultado as c_resultado, t0.d_resultado as d_resultado, SEC.policy, t0.c_resultado as CODE, t0.d_resultado as TEXT FROM SEL08_RESULTADOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO\') as SEC JOIN t0.oi_resultado LEFT OUTER SEC.id  ORDER BY oi_resultado asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_resultado"/>
								<qry:attribute name="c_resultado" value="$r/@c_resultado"/>
								<qry:attribute name="d_resultado" value="$r/@d_resultado"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
