<class-package xmlns:qry="nomad_engine.qry" root-class="RESULTADO" name="Resultados" DDOBase="NucleusRH\Base\Gestion_de_postulantes" languaje="SP" meta-class="DB">
	<class size="M" help="Registra los Resultados posibles que podria tener un reclutado en un examen o subexamen." description="Resultados" access="direct" label="Resultado" name="RESULTADO">
		<meta-properties>
			<db-properties desc-column="d_resultado" code-column="c_resultado" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SEL08_RESULTADOS">
				<security table="NMD_SECURITY"/>
