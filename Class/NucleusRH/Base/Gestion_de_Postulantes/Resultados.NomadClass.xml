						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_resultado as oi_resultado, SEC.policy FROM SEL08_RESULTADOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO\') as SEC JOIN t0.oi_resultado LEFT OUTER SEC.id  ORDER BY oi_resultado asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_resultado"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_resultados" code="c_resultados" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Gestion_de_Postulantes.Resultados.autoflow:initialize" desc-attr="d_resultado" code-attr="c_resultado" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
