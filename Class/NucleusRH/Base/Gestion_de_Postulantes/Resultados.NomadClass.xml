				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_resultado"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_resultado" OriginalName="o_resultado">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_resultado"/>
				<form-properties automatico="0" show-list="false" find-include="false" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_SEL08_RESULTADOS" name="AK_SEL08_RESULTADOS">
			<key-attr assosiation="no" name="c_resultado"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SEL08_RESULTADOS.oi_resultado as ID,
  SEL08_RESULTADOS.c_resultado as COD,
  SEL08_RESULTADOS.d_resultado as DES
from
  SEL08_RESULTADOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Resultados.RESULTADO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SEL08_RESULTADOS.oi_resultado) as CNT
from
  SEL08_RESULTADOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SEL08_RESULTADOS.oi_resultado={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SEL08_RESULTADOS.d_resultado,{#SOURCE:@TXT_FIND}) or contain(SEL08_RESULTADOS.c_resultado,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
