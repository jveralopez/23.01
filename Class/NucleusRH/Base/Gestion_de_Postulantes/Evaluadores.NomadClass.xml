			<guia-properties flow-edit="NucleusRH.Base.Gestion_de_Postulantes.Evaluadores.autoflow:initialize" desc-attr="d_evaluador" code-attr="d_razon_social" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
