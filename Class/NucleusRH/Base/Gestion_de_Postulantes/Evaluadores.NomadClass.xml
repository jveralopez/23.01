				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_evaluador as oi_evaluador, SEC.policy FROM SEL11_EVALUADORES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Evaluadores.EVALUADOR\') as SEC JOIN t0.oi_evaluador LEFT OUTER SEC.id  ORDER BY oi_evaluador asc')/ROWS/ROW
						</qry:xquery>
