					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_evaluador as oi_evaluador, t0.d_razon_social as d_razon_social, t0.d_evaluador as d_evaluador, t0.c_nro_cuit as c_nro_cuit, t0.te_evaluador as te_evaluador, t0.d_domicilio as d_domicilio, t0.d_email as d_email, SEC.policy, t0.d_razon_social as CODE, t0.d_evaluador as TEXT FROM SEL11_EVALUADORES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Evaluadores.EVALUADOR\') as SEC JOIN t0.oi_evaluador LEFT OUTER SEC.id  ORDER BY oi_evaluador asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_evaluador"/>
