<class-package xmlns:qry="nomad_engine.qry" languaje="SP" meta-class="DB" name="Factores" root-class="FACTOR" DDOBase="NucleusRH\Base\Gestion_de_postulantes">
	<class size="L" help="Registra los Distintos Factores a Evaluar de cada Subexamen" description="Factores" access="direct" label="Factor" name="FACTOR">
		<meta-properties>
			<db-properties desc-column="d_factor" code-column="c_factor" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SEL17_FACTORES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_factores" code-attr="c_factores" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.TIPO_ESCALA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_factor as oi_factor, t0.c_factor as c_factor, t0.d_factor as d_factor, SEC.policy, t0.c_factor as CODE, t0.d_factor as TEXT, t0.oi_tipo_escala as oi_tipo_escala FROM SEL17_FACTORES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR\') as SEC JOIN t0.oi_factor LEFT OUTER SEC.id  ORDER BY oi_factor asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_factor"/>
								<qry:attribute name="c_factor" value="$r/@c_factor"/>
								<qry:attribute name="d_factor" value="$r/@d_factor"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tipo_escala!=''">
									<qry:then>
										<qry:element name="oi_tipo_escala">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipo_escala"/>
											<qry:insert-select name="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.TIPO_ESCALA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipo_escala" value="'['+oi_tipo_escala/ROW/@COD+'] '+oi_tipo_escala/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_factor as oi_factor, SEC.policy FROM SEL17_FACTORES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR\') as SEC JOIN t0.oi_factor LEFT OUTER SEC.id  ORDER BY oi_factor asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_factor"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_factores" code="c_factores" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Gestion_de_Postulantes.Factores.autoflow:initialize" desc-attr="d_factor" code-attr="c_factor" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_factor">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_factor"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_factor" OriginalName="c_factor">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_factor"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_factor" OriginalName="d_factor">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_factor"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Gestion_de_Postulantes.Tipos_Escala.TIPO_ESCALA" null="true" readonly="false" type="aggregation" label="Tipo Escala" name="oi_tipo_escala" OriginalName="oi_tipo_escala">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_tipo_escala"/>
				<form-properties automatico="0" label="Tipo Escala" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_tipo_escala"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_SEL07_FACTORES" name="AK_SEL07_FACTORES">
			<key-attr assosiation="no" name="c_factor"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SEL17_FACTORES.oi_factor as ID,
  SEL17_FACTORES.c_factor as COD,
  SEL17_FACTORES.d_factor as DES
from
  SEL17_FACTORES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Factores.FACTOR.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SEL17_FACTORES.oi_factor) as CNT
from
  SEL17_FACTORES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SEL17_FACTORES.oi_factor={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SEL17_FACTORES.d_factor,{#SOURCE:@TXT_FIND}) or contain(SEL17_FACTORES.c_factor,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
