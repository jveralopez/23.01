<class-package xmlns:qry="nomad_engine.qry" meta-class="DB" languaje="SP" name="Cartas" root-class="CARTA" DDOBase="NucleusRH\Base\Gestion_de_postulantes">
	<class size="M" help="Registra los tipos de cartas para enviar." description="Cartas" access="direct" label="Carta" name="CARTA">
		<meta-properties>
			<db-properties desc-column="d_carta" code-column="c_carta" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="SEL14_CARTAS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_cartas" code-attr="c_cartas" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_carta as oi_carta, t0.c_carta as c_carta, t0.d_carta as d_carta, SEC.policy, t0.c_carta as CODE, t0.d_carta as TEXT FROM SEL14_CARTAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA\') as SEC JOIN t0.oi_carta LEFT OUTER SEC.id  ORDER BY oi_carta asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_carta"/>
								<qry:attribute name="c_carta" value="$r/@c_carta"/>
								<qry:attribute name="d_carta" value="$r/@d_carta"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_carta as oi_carta, SEC.policy FROM SEL14_CARTAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA\') as SEC JOIN t0.oi_carta LEFT OUTER SEC.id  ORDER BY oi_carta asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_carta"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_cartas" code="c_cartas" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Gestion_de_Postulantes.Cartas.autoflow:initialize" desc-attr="d_carta" code-attr="c_carta" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_carta">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_carta"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_carta" OriginalName="c_carta">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_carta"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_carta" OriginalName="d_carta">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_carta"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_SEL14_CARTAS" name="AK_SEL14_CARTAS">
			<key-attr assosiation="no" name="c_carta"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  SEL14_CARTAS.oi_carta as ID,
  SEL14_CARTAS.c_carta as COD,
  SEL14_CARTAS.d_carta as DES
from
  SEL14_CARTAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Gestion_de_Postulantes.Cartas.CARTA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(SEL14_CARTAS.oi_carta) as CNT
from
  SEL14_CARTAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and SEL14_CARTAS.oi_carta={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(SEL14_CARTAS.d_carta,{#SOURCE:@TXT_FIND}) or contain(SEL14_CARTAS.c_carta,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
