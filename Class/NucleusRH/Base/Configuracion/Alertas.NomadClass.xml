		<resource name="INFO" declare="&lt;DATA  /&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Configuracion.Alertas.ALERTA.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Configuracion.Alertas.ALERTA.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  CFG01_ALERTAS.oi_alerta as ID, 
  CFG01_ALERTAS.oi_alerta as COD, 
  CFG01_ALERTAS.d_alerta as DES
FROM 
  CFG01_ALERTAS
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA search=&quot;&quot; order=&quot;&quot; asc=&quot;0&quot; /&gt;" name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('SELECT 
  CFG01_ALERTAS.oi_alerta as ID, 
  CFG01_ALERTAS.oi_alerta as COD, 
  CFG01_ALERTAS.d_alerta as DES
{%?($FILTER/@order!='') {% ,CFG01_ALERTAS.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM 
  CFG01_ALERTAS
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}

{%?($FILTER/@order!='')
  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {% %}
%}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM IDS=&quot;101&quot; /&gt;&#13;&#10;&#13;&#10;&#13;&#10;" name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  CFG01_ALERTAS.oi_alerta as ID, 
  CFG01_ALERTAS.oi_alerta as COD, 
  CFG01_ALERTAS.d_alerta as DES, 
  CFG01_ALERTAS.d_tipo_alerta as d_tipo_alerta, 
  CFG01_ALERTAS.d_alerta as d_alerta, 
  CFG01_ALERTAS.f_ult_aviso as f_ult_aviso, 
  CFG01_ALERTAS.d_mail_group as d_mail_group, 
  CFG05_MAILS.d_mail as DES_oi_mail, 
  CFG07_PROG.d_prog as DES_oi_prog,
  CFG07_PROG.c_estado as c_estado,
  CFG07_PROG.f_inicio as f_inicio,
  CFG07_PROG.f_fin as f_fin,
  CFG07_PROG.f_ult_ejecucion as f_ult_ejecucion,
  CFG07_PROG.f_pro_ejecucion as f_pro_ejecucion
FROM 
  CFG01_ALERTAS, 
  CFG05_MAILS, 
  CFG07_PROG
JOIN 
  CFG01_ALERTAS.oi_mail LEFT OUTER CFG05_MAILS.oi_mail, 
  CFG01_ALERTAS.oi_prog LEFT OUTER CFG07_PROG.oi_prog
WHERE 
CFG01_ALERTAS.oi_alerta in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="d_tipo_alerta" value="$r/@d_tipo_alerta"/>
						<qry:attribute name="d_alerta" value="$r/@d_alerta"/>
						<qry:attribute name="f_ult_aviso" value="$r/@f_ult_aviso"/>
						<qry:attribute name="d_mail_group" value="$r/@d_mail_group"/>
						<qry:attribute name="oi_mail" value="$r/@DES_oi_mail"/>
						<qry:attribute name="oi_prog" value="$r/@DES_oi_prog"/>
						<qry:attribute name="c_estado" value="iif($r/@c_estado='','I',$r/@c_estado)"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="f_fin" value="$r/@f_fin"/>
						<qry:attribute name="f_ult_ejecucion" value="$r/@f_ult_ejecucion"/>
						<qry:attribute name="f_pro_ejecucion" value="$r/@f_pro_ejecucion"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
