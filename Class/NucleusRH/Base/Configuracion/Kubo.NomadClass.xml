		<resource name="QRY_PERSONAL_TODO">
			<qry:main name="main" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			SELECT 
			PER02_PERSONAL_EMP.e_numero_legajo,
			ORG03_EMPRESAS.c_empresa,
			PER02_PERSONAL_EMP.oi_personal_emp
			FROM
			PER02_PERSONAL_EMP,
			ORG03_EMPRESAS
			JOIN
			PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
			WHERE
			PER02_PERSONAL_EMP.oi_indic_activo != \'4\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
						<qry:attribute name="c_personal_emp" value="concat($r/@c_empresa,'_',$r/@e_numero_legajo)"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA e_numero_legajo='101' c_empresa='100' f_inicio='20210507' /&gt;" name="QRY_LICENCIAS">
			<qry:main doc="SOURCE" name="main">
				<qry:element name="ROW">
					<qry:attribute name="existe" value="'0'"/>
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="sql1">
				<qry:xquery>
					for $r in SQL('		
	select L.oi_licen_per_ddo
from  
LIQ97_LICEN_PER  as L,   
LIQ97_PERSONAL_EMP as PER
JOIN
L.oi_per_emp_ddo INNER PER.oi_per_emp_ddo 
WHere 
PER.e_numero_legajo = {#SOURCE:@e_numero_legajo}
and PER.c_empresa = {#SOURCE:@c_empresa}
and L.f_inicio = {datetime(#SOURCE:@f_inicio)}		
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="existe" value="'1'"/>
				</qry:out>
			</qry:select>
		</resource>
