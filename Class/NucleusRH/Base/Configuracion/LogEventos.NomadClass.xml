		<resource declare="&lt;X c_evento=&quot;2&quot; /&gt;" name="QUERY_TASK" include="false">
			<qry:main doc="PARAM">
				<TASKS>
					<qry:insert-select name="SQL1" doc-path="$PARAM/."/>
				</TASKS>
			</qry:main>
			<qry:select name="SQL1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
select
CFG07_PROG.oi_prog,
CFG07_PROG_DETS.c_grupo_evento,
CFG07_PROG_DETS.c_evento,
CFG07_PROG_DETS.c_modo_evento,
CFG07_PROG_DETS.d_horas
from
CFG07_PROG,
CFG07_PROG_DETS
join
CFG07_PROG.oi_prog inner CFG07_PROG_DETS.oi_prog
where      
CFG07_PROG.c_estado=\'A\' and
CFG07_PROG.f_inicio&lt;={Now()} and
(isnull(CFG07_PROG.f_fin) or CFG07_PROG.f_fin&gt;={Now()}) and
CFG07_PROG_DETS.c_tipo=\'E\' 
{%? ($PARAM/@c_grupo_evento!='') {% and CFG07_PROG_DETS.c_grupo_evento={$PARAM/@c_grupo_evento} %} {% %} %}
{%? ($PARAM/@c_evento!='') {% and CFG07_PROG_DETS.c_evento={$PARAM/@c_evento} %} {% %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="oi" value="$r/@oi_prog"/>
						<qry:attribute name="eve" value="$r/@c_grupo_evento+'.'+$r/@c_evento"/>
						<qry:attribute name="hora" value="$r/@d_horas"/>
						<qry:attribute name="modo" value="$r/@c_modo_evento"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('{%? (#FILTER:@LEN='') {% %} {% maxsize {%=#FILTER:@LEN %} %} %}
SELECT 
  CFG10_LOGEVENTOS.oi_logevento as ID, 
  CFG10_LOGEVENTOS.oi_logevento as COD, 
  CFG10_LOGEVENTOS.d_logevento as DES
{%?($FILTER/@order!='') {% ,CFG10_LOGEVENTOS.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM 
  CFG10_LOGEVENTOS
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}

{%?($FILTER/@order!='')
  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {% %}
%}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  CFG10_LOGEVENTOS.oi_logevento as ID, 
  CFG10_LOGEVENTOS.oi_logevento as COD, 
  CFG10_LOGEVENTOS.d_logevento as DES, 
  CFG10_LOGEVENTOS.f_logevento as f_logevento, 
  CFG10_LOGEVENTOS.c_grupo_evento as c_grupo_evento, 
  CFG10_LOGEVENTOS.c_evento as c_evento, 
  CFG10_LOGEVENTOS.d_evento as d_evento, 
  CFG10_LOGEVENTOS.c_loglevel as c_loglevel, 
  CFG10_LOGEVENTOS.d_logevento as d_logevento
FROM 
  CFG10_LOGEVENTOS
WHERE 
CFG10_LOGEVENTOS.oi_logevento in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="f_logevento" value="$r/@f_logevento"/>
						<qry:attribute name="c_grupo_evento" value="$r/@c_grupo_evento"/>
						<qry:attribute name="c_evento" value="$r/@c_evento"/>
						<qry:attribute name="d_evento" value="$r/@d_evento"/>
						<qry:attribute name="c_loglevel" value="$r/@c_loglevel"/>
						<qry:attribute name="d_logevento" value="$r/@d_logevento"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO" declare="&lt;DATA TXT_FIND=&quot;&quot; START=&quot;0&quot; LEN=&quot;11&quot; ORDERBY=&quot;COD&quot; OI_PARENT=&quot;&quot; WHERE=&quot;&quot;/&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Configuracion.LogEventos.LOGEVENTO.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Configuracion.LogEventos.LOGEVENTO.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  CFG10_LOGEVENTOS.oi_logevento as ID, 
  CFG10_LOGEVENTOS.oi_logevento as COD, 
  CFG10_LOGEVENTOS.d_logevento as DES
FROM 
  CFG10_LOGEVENTOS
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="GRUPO_EVENTO" declare="&lt;DATA OI_FIND=&quot;&quot;/&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY" doc="SOURCE">
				<qry:out>
					<qry:if test="#SOURCE:@OI_FIND=''">
						<qry:then>
							<qry:insert-select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.PATH" doc-path="#SOURCE:"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="FILE" value="#SOURCE:@oi_find+'.event.XML'"/>
							<qry:insert-select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO" doc-path="."/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.PATH" doc="SOURCE">
				<qry:xquery>
					for $r in METHOD('Nomad.Base.Report.Listas.INDICE:SuperComboIndex({\'..\\\\..\\\\APP\\\\{%=#PROXY:@PATH%}\\\\Event\'},{\'NucleusRH.Base.Configuracion.Eventos.EVENTO.GRUPO_EVENTO\'},{#SOURCE:@TXT_FIND},{floor(#SOURCE:@START)},{floor(#SOURCE:@LEN)},{#SOURCE:@ORDERBY})')/*
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r/ROW"/>
				</qry:out>
			</qry:select>
			<qry:select name="NucleusRH.Base.Configuracion.Eventos.EVENTO.QUERY.DDO" doc="SOURCE">
				<qry:xquery>
					for $r in FILESTORE('Event\\{%=#SOURCE:@file%}')/GEVENT
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="substring($SOURCE/@file,0,string-length($SOURCE/@file)-10)"/>
						<qry:attribute name="COD" value="Nmd-crc(upper-case($SOURCE/@file))"/>
						<qry:attribute name="DES" value="$r/@label"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
