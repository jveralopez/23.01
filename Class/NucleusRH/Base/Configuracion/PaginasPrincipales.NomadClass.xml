						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Configuracion.PaginasPrincipales.PAG_RAIZ.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  CFG04_PAG_RAIZ.oi_pag_raiz as ID,
  CFG04_PAG_RAIZ.c_pag_raiz as COD,
  CFG04_PAG_RAIZ.d_pag_raiz as DES
from
  CFG04_PAG_RAIZ
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Configuracion.PaginasPrincipales.PAG_RAIZ.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(CFG04_PAG_RAIZ.oi_pag_raiz) as CNT
from
  CFG04_PAG_RAIZ
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and CFG04_PAG_RAIZ.oi_pag_raiz={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(CFG04_PAG_RAIZ.d_pag_raiz,{#SOURCE:@TXT_FIND}) or contain(CFG04_PAG_RAIZ.c_pag_raiz,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA search=&quot;&quot; order=&quot;&quot; asc=&quot;0&quot; /&gt;" name="INFO_IDS">
			<qry:main doc="PARAIN">
				<qry:element name="ROWS">
					<qry:append-doc name="FILTER" doc-path="#PARAIN:/DATA"/>
					<qry:insert-select name="IDS"/>
				</qry:element>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
select
  T.oi_pag_raiz as ID
{%?($FILTER/@order!='') {% ,T.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}      
from
  CFG04_PAG_RAIZ as T
where
 1=1
{%?($FILTER/@search!='')
 {% and (contain(ucase(T.c_pag_raiz),{upper-case($FILTER/@search)}) or
         contain(ucase(T.d_pag_raiz),{upper-case($FILTER/@search)})
        ) %}
 {% %}
%}      

{%?($FILTER/@order!='')
 {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
 {% %}
%}      


')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute name="id" value="$r/@ID"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM IDS=&quot;2&quot; /&gt;&#13;&#10;&#13;&#10;&#13;&#10;" name="INFO_IDS_LIST">
			<qry:main maxdeep="2" doc="PARAMIN">
				<qry:element name="ROWS">
					<qry:if test="count(#PARAMIN:/PARAM)&gt;0">
						<qry:then>
