						</qry:then>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in sql('
				SELECT 
					T.oi_pag_raiz, 
					T.c_pag_raiz, 
					T.d_pag_raiz,
					T.oi_pagina,
					P.d_pagina
				FROM 
					CFG04_PAG_RAIZ as T,
					CFG03_PAGINAS as P
				JOIN
					T.oi_pagina LEFT OUTER P.oi_pagina
				WHERE
					T.oi_pag_raiz in ({%=$PARAM/@IDS %})
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="id" value="$r/@oi_pag_raiz"/>
						<qry:attribute name="c_pag_raiz" value="$r/@c_pag_raiz"/>
						<qry:attribute name="d_pag_raiz" value="$r/@d_pag_raiz"/>
						<qry:attribute name="oi_pagina" value="$r/@d_pagina"/>
						<qry:attribute name="descr" value="$r/@c_pag_raiz+'-'+$r/@d_pag_raiz"/>
					</qry:element>
				</qry:out>
			</qry:select>
