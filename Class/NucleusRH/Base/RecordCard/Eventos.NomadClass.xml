<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\RecordCard\Eventos" root-class="EVENTO" name="Eventos" meta-class="DB" languaje="SP">
	<class size="L" help="Aqui se registran los distintos eventos de las acciones del Record Card." description="Eventos" access="direct" label="Evento" name="EVENTO">
		<meta-properties>
			<db-properties desc-column="d_evento" code-column="oi_evento" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="REC02_EVENTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_eventos" code-attr="oi_evento" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_evento as oi_evento, t0.f_evento as f_evento, t0.d_usuario as d_usuario, t0.d_evento as d_evento, SEC.policy, t0.oi_evento as CODE, t0.d_evento as TEXT, t0.oi_accion as oi_accion FROM REC02_EVENTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.RecordCard.Eventos.EVENTO\') as SEC JOIN t0.oi_evento LEFT OUTER SEC.id  ORDER BY oi_evento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_evento"/>
								<qry:attribute name="f_evento" value="$r/@f_evento"/>
								<qry:attribute name="d_usuario" value="$r/@d_usuario"/>
								<qry:attribute name="d_evento" value="$r/@d_evento"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_accion" value="$r/@oi_accion"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_evento as oi_evento, SEC.policy FROM REC02_EVENTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.RecordCard.Eventos.EVENTO\') as SEC JOIN t0.oi_evento LEFT OUTER SEC.id  ORDER BY oi_evento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_evento"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.RecordCard.Eventos.autoflow:initialize" desc-attr="d_evento" code-attr="oi_evento" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_evento">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_evento"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.RecordCard.Acciones.ACCION" null="false" readonly="false" type="aggregation" label="Accion" name="oi_accion" OriginalName="oi_accion">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_accion"/>
				<form-properties label="Accion" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_accion"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha del Evento" name="f_evento" OriginalName="f_evento">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha del Evento" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_evento"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Usuario" name="d_usuario" OriginalName="d_usuario">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Usuario" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_usuario"/>
			</meta-properties>
		</attribute>
		<attribute length="1000" null="false" readonly="false" default="''" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_evento" OriginalName="d_evento">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties type="varchar(1000)" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" column="d_evento"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<assosiation description="Aqui se registran los datos especificos de cada clase definida para la accion en un evento en particular." label="Eventos por Clase" name="EVEN_CLASES" class="EVEN_CLASE" type="composition" access="public">
			<meta-properties>
				<db-properties cascade="delete" not-found="exception" optimistic-lock="true" not-null="true" unique="true" insert="false" update="false" from-column="oi_evento"/>
				<form-properties label="Eventos por Clase" automatico="1" show-list="false" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="0..*" from="1">
				<db-properties to-column="oi_evento"/>
			</multiplicity>
		</assosiation>
	</class>
	<class size="L" help="Aqui se registran los datos especificos de cada clase definida para la accion en un evento en particular." description="Eventos por Clase" access="direct" label="Eventos de Clases" name="EVEN_CLASE">
		<meta-properties>
			<db-properties desc-column="oi_even_clase" code-column="oi_even_clase" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="REC02_EVEN_CLASES"/>
			<form-properties binary="NONE" desc-attr="oi_even_clase" code-attr="oi_even_clase" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main doc="PARAM" maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select doc-path="#PARAM:./EVEN_CLASE[substring_before(@nmd-status,',')!='~d' and substring_before(@nmd-status,',')!='~x']" name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in #PARAM:
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="id" value="$r/@id"/>
								<qry:attribute name="e_objeto" value="$r/@e_objeto"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_clase_acc" value="$r/oi_clase_acc/@value"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
			</form-properties>
			<guia-properties desc-attr="oi_even_clase" code-attr="oi_even_clase" requiered-filter="false" enabled-filter="true" enabled-edit="false" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_even_clase">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_even_clase"/>
			</meta-properties>
		</attribute>
		<attribute ParentJoin="REC02_EVENTOS.oi_evento" ParentId="1" null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Evento" name="oi_evento" OriginalName="oi_evento">
			<meta-properties>
				<form-properties show-list="false" visible="false" find-include="false" automatico="1" label="OID Evento" lock="false" read-only="false" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="oi_evento"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.RecordCard.Acciones.CLASE_ACC" null="false" readonly="false" type="aggregation" label="Clases de Acciones" name="oi_clase_acc" OriginalName="oi_clase_acc">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_clase_acc"/>
				<form-properties label="Clases de Acciones" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_clase_acc"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="ID del Objeto" name="e_objeto" OriginalName="e_objeto">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="ID del Objeto" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="e_objeto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="yes" unique="yes" descr="Key_2" name="Key_2">
			<key-attr assosiation="yes" name="oi_clase_acc"/>
			<key-attr assosiation="no" name="e_objeto"/>
		</key>
	</class>
</class-package>
