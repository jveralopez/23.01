<class-package xmlns:qry="nomad_engine.qry" root-class="ACCION_REAL" name="AccionesReales" meta-class="DB" languaje="SP">
	<class size="L" note="aqui se registran todas las acciones propiamente dichas que se llevaran en los distintos record cards." description="Acciones Reales" access="direct" label="Accion Real" name="ACCION_REAL">
		<meta-properties>
			<db-properties desc-column="oi_accion_real" code-column="oi_accion_real" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="REC03_ACCION_REAL">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="oi_accion_real" code-attr="oi_accion_real" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_accion_real as oi_accion_real, t0.oi_accion_real as CODE, t0.oi_accion_real as TEXT, t0.oi_evento as oi_evento FROM REC03_ACCION_REAL as t0 ORDER BY oi_accion_real asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_accion_real"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_evento" value="$r/@oi_evento"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_accion_real as oi_accion_real FROM REC03_ACCION_REAL as t0 ORDER BY oi_accion_real asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_accion_real"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.RecordCard.AccionesReales.autoflow:initialize" desc-attr="oi_accion_real" code-attr="oi_accion_real" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_accion_real">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_accion_real"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.RecordCard.Eventos.EVENTO" null="false" readonly="false" type="aggregation" label="Evento" name="oi_evento" OriginalName="oi_evento">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_evento"/>
				<form-properties label="Evento" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_evento"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<method description="Guarda una accion y crea el recordcard" name="GuardarAccion" label="Guarda Acci&#243;n" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument description="C&#243;digo de la acci&#243;n" type="Nomad.NSystem.String" pass="byval" name="accion"/>
				<argument class="Nomad.NSystem.Document.NmdXmlDocument" description="Par&#225;metros para el query que crea el DDO de recordcard" name="parametrosQry" type="Nomad.NSystem.Object" pass="byval"/>
				<argument description="Clase del record card que hay que generar" type="Nomad.NSystem.String" pass="byval" name="claseRC"/>
			</arguments>
		</method>
		<method description="Ejecuta un query en la clase hija y devuelve su resultado como XML" return-class="System.Xml.XmlDocument" label="Obtiene el DDO del RC" return-type="Nomad.NSystem.Object" modifier="virtual" access="public" name="ObtieneDDORC">
			<meta-properties>
				<dotnet11-properties type="lib">
					return("&lt;/nada&gt;")
				</dotnet11-properties>
			</meta-properties>
			<arguments>
				<argument description="Par&#225;metros para el query que crea el DDO de recordcard" type="Nomad.NSystem.String" pass="byval" name="parametrosQry"/>
			</arguments>
		</method>
	</class>
</class-package>
