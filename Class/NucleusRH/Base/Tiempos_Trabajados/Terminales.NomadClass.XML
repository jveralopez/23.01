		SELECT 
			ORG02_ESTRUCTURAS.oi_estr_padre
		FROM 
			ORG02_ESTRUCTURAS
		WHERE 
			ORG02_ESTRUCTURAS.oi_estructura = {#PARAM:@oi_estructura} 
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
