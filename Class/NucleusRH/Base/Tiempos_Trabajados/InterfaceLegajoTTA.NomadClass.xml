		<method label="ImportarLegajosTTA" description="Importa LegajosTTA" name="ImportarLegajosTTA" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.InterfaceLegajoTTA.PERSONAL" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="qry_legajos">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA    &#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#9;TABLE=&quot;PER20_TIPOS_DOC&quot;&#13;&#10;&#9;COLRET=&quot;oi_tipo_documento&quot;&#13;&#10;&#9;COLFND=&quot;c_tipo_documento&quot;&#13;&#10;&#9;COLVAL=&quot;DNI&quot;&#13;&#10;/&gt;&#13;&#10;&#9;" name="qry_findOI">
			<qry:main doc="PARAM">
				<qry:element name="RESULT">
					<qry:insert-select name="SQL" doc-path="#PARAM:/DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT {%=#PARAM:@TABLE %}.{%=#PARAM:@COLRET %} AS VALUE 
						FROM {%=#PARAM:@TABLE %} 
						WHERE {%=#PARAM:@TABLE %}.{%=#PARAM:@COLFND %}= {#PARAM:@COLVAL}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="ID" value="$r/@value"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA&#13;&#10;&#9;TABLE=&quot;PER01_PERSONAL&quot;&#13;&#10;&#9;COLRET=&quot;oi_personal&quot;&#13;&#10;&#9;COLFND1=&quot;c_nro_documento&quot;&#13;&#10;&#9;COLVAL1=&quot;24980567&quot;&#13;&#10;&#9;COLFND2=&quot;c_nro_documento&quot;&#13;&#10;&#9;COLVAL2=&quot;24980567&quot;&#13;&#10;/&gt;&#13;&#10;&#9;" name="qry_findOI2">
			<qry:main doc="PARAM">
				<qry:element name="RESULT">
					<qry:insert-select name="SQL" doc-path="#PARAM:/DATA"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT {%=#PARAM:@TABLE %}.{%=#PARAM:@COLRET %} AS VALUE 
						FROM {%=#PARAM:@TABLE %} 
						WHERE {%=#PARAM:@TABLE %}.{%=#PARAM:@COLFND1 %}= {#PARAM:@COLVAL1} 
						AND {%=#PARAM:@TABLE %}.{%=#PARAM:@COLFND2 %}= {#PARAM:@COLVAL2}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="ID" value="$r/@value"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
