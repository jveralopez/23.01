<class-package xmlns:qry="nomad_engine.qry" root-class="LICENCIAS" DDOBase="NucleusRH\Base\Tiempos_Trabajados" languaje="SP" meta-class="DB" name="Interfaces">
	<class size="L" label="LICENCIAS" name="LICENCIAS" description="InterfaceLicencias" access="direct">
		<meta-properties>
			<interface-properties file="INTlicencias.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="30" name="empresa" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" name="legajo" type="Nomad.NSystem.Int">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" name="licencia" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.DateTime" name="f_desde">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.DateTime" name="f_hasta">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute length="1000" name="observaciones" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="ImportarLicencias" description="Importar Legajos" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource name="qry_rows">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:INTlicencias.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM oi_personal_emp=&quot;229&quot; f_desde=&quot;20080424&quot; f_hasta=&quot;20080425&quot;/&gt;&#13;&#10;&#13;&#10;" name="qry_fichadas">
			<qry:main name="" doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				SELECT
					TTA07_FICHADASING.oi_fichadasing
				FROM
					TTA07_FICHADASING
				WHERE
					TTA07_FICHADASING.oi_personal_emp = {#PARAM:@oi_personal_emp}
					and DATE2STRING(TTA07_FICHADASING.f_fechahora) &gt;= {#PARAM:@f_desde}
					and DATE2STRING(TTA07_FICHADASING.f_fechahora) &lt;= {#PARAM:@f_hasta}	
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="fichada" value="$r/@oi_fichadasing"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
