<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" name="SPInterfaceFichadas" meta-class="DB" languaje="SP">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties separator=";" file="regist.dat" mode="1" enter="1" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id">
			<meta-properties/>
		</attribute>
		<attribute type="Nomad.NSystem.Int" name="legajo">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="50" type="Nomad.NSystem.String" name="fecha_hora">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Boolean" name="entrada">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Boolean" name="salida">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.SRFInterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
