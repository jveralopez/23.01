						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_banco_hora as oi_banco_hora, SEC.policy FROM TTA21_BANCO_HORA as t0,NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA\') as SEC JOIN t0.oi_banco_hora LEFT OUTER SEC.id  ORDER BY oi_banco_hora asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_banco_hora"/>
