		<meta-properties>
			<db-properties desc-column="d_banco_hora" code-column="c_banco_hora" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="TTA21_BANCO_HORA">
				<security table="NMD_SECURITY"/>
