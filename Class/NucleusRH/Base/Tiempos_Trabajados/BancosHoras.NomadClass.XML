				<form-properties enum="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.c_unidad_tiempo" show-list="false" find-include="true" automatico="1" label="Unidad de tiempo" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
		</attribute>
		<enum name="c_unidad_tiempo">
