							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_banco_hora as oi_banco_hora, t0.c_banco_hora as c_banco_hora, t0.d_banco_hora as d_banco_hora, t0.c_unidad_tiempo as c_unidad_tiempo, t0.l_verifica_rango as l_verifica_rango, SEC.policy, t0.c_banco_hora as CODE, t0.d_banco_hora as TEXT FROM TTA21_BANCO_HORA as t0,NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA\') as SEC JOIN t0.oi_banco_hora LEFT OUTER SEC.id  ORDER BY oi_banco_hora asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_banco_hora"/>
								<qry:attribute name="c_banco_hora" value="$r/@c_banco_hora"/>
								<qry:attribute name="d_banco_hora" value="$r/@d_banco_hora"/>
								<qry:attribute name="l_verifica_rango" value="iif($r/@l_verifica_rango='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="c_unidad_tiempo" value="$r/@c_unidad_tiempo"/>
							</qry:element>
						</qry:out>
					</qry:select>
