		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  TTA21_BANCO_HORA.oi_banco_hora as ID,
  TTA21_BANCO_HORA.c_banco_hora as COD,
  TTA21_BANCO_HORA.d_banco_hora as DES
from
  TTA21_BANCO_HORA
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.BancosHoras.BANCO_HORA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(TTA21_BANCO_HORA.oi_banco_hora) as CNT
from
  TTA21_BANCO_HORA
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and TTA21_BANCO_HORA.oi_banco_hora={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(TTA21_BANCO_HORA.d_banco_hora,{#SOURCE:@TXT_FIND}) or contain(TTA21_BANCO_HORA.c_banco_hora,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource description="Retorna el id de banco de hora a trav&#233;s de un c&#243;digo" declare="&lt;PARAM c_banco=&quot;H&quot;/&gt;" name="GET_BANCO">
			<qry:main doc="SOURCE" name="MAIN">
				<qry:element name="RESULT">
					<qry:append-doc name="FILTRO" doc-path="."/>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL(' 
				SELECT 
					TTA21_BANCO_HORA.oi_banco_hora
				FROM
					TTA21_BANCO_HORA
				WHERE
					TTA21_BANCO_HORA.c_banco_hora = {#SOURCE:@c_banco} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@oi_banco_hora"/>
				</qry:out>
			</qry:select>
		</resource>
