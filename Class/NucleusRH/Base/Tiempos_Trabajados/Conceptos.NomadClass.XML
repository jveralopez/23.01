						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  TTA15_CONCEPTOS.oi_concepto as ID,
  TTA15_CONCEPTOS.c_concepto as COD,
  TTA15_CONCEPTOS.d_concepto as DES
from
  TTA15_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Conceptos.CONCEPTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(TTA15_CONCEPTOS.oi_concepto) as CNT
from
  TTA15_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and TTA15_CONCEPTOS.oi_concepto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(TTA15_CONCEPTOS.d_concepto,{#SOURCE:@TXT_FIND}) or contain(TTA15_CONCEPTOS.c_concepto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="qry_conceptos">
			<qry:main name="" doc="">
				<qry:element name="ROWS">
					<qry:insert-select name="SQL1"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="">
				<qry:xquery>
					for $r in SQL('
SELECT   
	c.oi_concepto as id,
	c.c_concepto as code,
	c.c_coleccion as coll,
	c.t_formula as formula,
	c.e_secuencia
FROM
	TTA15_CONCEPTOS as c
WHERE
	c.l_activo=1
ORDER BY 
	e_secuencia asc
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="CONCEPTO">
						<qry:attribute name="id" value="$r/@id"/>
						<qry:attribute name="code" value="$r/@code"/>
						<qry:attribute name="coll" value="$r/@coll"/>
						<qry:attribute name="formula" value="$r/@formula"/>
						<qry:insert-select name="SQL2" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="SQL2" doc="in">
				<qry:xquery>
					for $r in SQL('
SELECT   
	cv.oi_variable,
	cv.c_tipo_parametro,
	v.c_variable,
	v.c_tipo_dato,
	v.l_colleccion
FROM
	TTA15_CONC_VAR as cv,
	TTA16_VARIABLES as v
WHERE                
	cv.oi_variable=v.oi_variable and
	cv.oi_concepto={$in/@id}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="VAR">
						<qry:attribute name="oi_variable" value="$r/@oi_variable"/>
						<qry:attribute name="variable" value="$r/@c_variable"/>
						<qry:attribute name="var_mode" value="$r/@c_tipo_parametro"/>
						<qry:attribute name="var_type" value="$r/@c_tipo_dato"/>
						<qry:attribute name="var_coll" value="$r/@l_colleccion"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<method modifier="static" access="public" name="GenerarArchivo">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" name="Param" type="Nomad.NSystem.Object" pass="byval"/>
				<argument type="Nomad.NSystem.String" pass="byval" name="Mode"/>
