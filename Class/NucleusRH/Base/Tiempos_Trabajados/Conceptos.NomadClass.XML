		</method>
		<resource declare="&lt;FILTRO gcustom=&quot;&quot; formato=&quot;P&quot; oi_liquidacion=&quot;302&quot; gpers=&quot;&quot; empresa=&quot;2&quot; activos=&quot;&quot; nombre=&quot;&quot; documento=&quot;&quot; sexo=&quot;&quot; grupo_sanguineo=&quot;&quot; listlegajos=&quot;&quot; oi_indic_activo=&quot;&quot; egresado=&quot;&quot; oi_forma_pago=&quot;&quot; oi_tipo_personal=&quot;&quot; fecha_desde=&quot;&quot; fecha_hasta=&quot;&quot; oi_grupo_ccosto=&quot;&quot; oi_centro_costo=&quot;&quot; oi_convenio=&quot;&quot; soloconvenio=&quot;&quot; oi_categoria=&quot;&quot; oi_ubicacion_desde=&quot;&quot; oi_ubicacion_hasta=&quot;&quot; oi_estructura=&quot;&quot; escructura_childs=&quot;&quot; oi_contrato=&quot;&quot; oi_afjp=&quot;&quot; oi_obra_social=&quot;&quot; oi_sindicato=&quot;&quot; l_afiliado_sind=&quot;0&quot; legajo_reloj_desde=&quot;&quot; legajo_reloj_hasta=&quot;&quot; chksinreloj=&quot;&quot; tarjeta_desde=&quot;&quot; tarjeta_hasta=&quot;&quot; chksintarjeta=&quot;&quot; oi_horario=&quot;&quot; oi_escuadra=&quot;&quot; tipo=&quot;&quot; oi_grupo_horario=&quot;&quot; legID=&quot;&quot; leg_where=&quot;&quot;&gt;&lt;PERSONAS&gt;&lt;ROW VALUES=&quot;304,409,410,453&quot; /&gt;&lt;/PERSONAS&gt;&lt;/FILTRO&gt;" name="QRY_CONCEPTOS">
			<qry:main doc="PARAM">
				<qry:append-doc name="FILTRO" doc-path="#PARAM:/FILTRO"/>
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_CONCEPTOS" doc-path="#PARAM:FILTRO/PERSONAS/ROW"/>
				</qry:element>
			</qry:main>
			<qry:select doc="PARAM" name="QRY_CONCEPTOS">
				<qry:xquery>
					for $r in sql('
				SELECT 					
					TTA10_LIQUIDACPERS.oi_liquidacionpers,					
					TTA15_CONCEPTOS.c_externo,					
					SUM(TTA10_CONC_PER.n_valor) as n_valor,										
					PER02_PERSONAL_EMP.e_numero_legajo,
					TTA15_CONCEPTOS.o_concepto
				FROM 
					TTA10_CONC_PER, 
					TTA10_LIQUIDACPERS, 
					TTA15_CONCEPTOS,
					PER02_PERSONAL_EMP					
				JOIN 
					TTA10_CONC_PER.oi_liquidacionpers INNER TTA10_LIQUIDACPERS.oi_liquidacionpers,
					TTA10_CONC_PER.oi_concepto INNER TTA15_CONCEPTOS.oi_concepto,
					TTA10_LIQUIDACPERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp
				WHERE 
					TTA10_LIQUIDACPERS.oi_liquidacion = {#FILTRO:@oi_liquidacion} 
					{%? (string(#PARAM:@VALUES)!='') {% AND TTA10_LIQUIDACPERS.oi_personal_emp in ({%=string(#PARAM:@VALUES) %}) %} {%  %} %}
					AND len(TTA15_CONCEPTOS.c_externo)&gt;0
					AND TTA10_CONC_PER.n_valor != 0
				GROUP BY            					
					TTA10_LIQUIDACPERS.oi_liquidacionpers,					
					TTA15_CONCEPTOS.c_externo,
					PER02_PERSONAL_EMP.e_numero_legajo,
					TTA15_CONCEPTOS.o_concepto					
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:if test="$r/@n_valor != '0'">
						<qry:then>
							<qry:element name="ROW">
								<qry:attribute value="$r/@oi_liquidacionpers" name="oi_liquidacionpers"/>
								<qry:attribute value="$r/@e_numero_legajo" name="e_numero_legajo"/>
								<qry:attribute value="$r/@c_externo" name="c_externo"/>
								<qry:attribute value="$r/@n_valor" name="cantidad"/>
								<qry:attribute value="$r/@o_concepto" name="o_concepto"/>
							</qry:element>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</resource>
