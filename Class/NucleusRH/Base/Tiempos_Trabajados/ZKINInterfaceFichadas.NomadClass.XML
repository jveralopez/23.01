<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" name="ZKINInterfaceFichadas" meta-class="DB" languaje="SP">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties separator="&#9;" file="regist.dat" mode="1" enter="1" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute type="Nomad.NSystem.String" length="16" name="legajo" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="64" name="nombre" type="Nomad.NSystem.String" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.String" length="32" name="fecha" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="50" type="Nomad.NSystem.String" name="tipo" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" type="Nomad.NSystem.String" name="evento" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="30" type="Nomad.NSystem.String" name="terminal" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.ZKINInterfaceFichadas.FICHADASIN" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="QRY_TERMINAL" declare="&lt;DATOS c_terminal=&quot;01&quot; /&gt;" description="Retorna el oi terminal a trav&#233;s de un c&#243;digo">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_terminal" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_terminal" doc="PARAM">
				<qry:xquery>
					for $r in sql('
            SELECT 
                TERM.oi_terminal 
                    
            FROM 
            	TTA05_TERMINALES as TERM 
            
            WHERE 
            	TERM.c_terminal = {#PARAM:@c_terminal}

             ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_terminal" value="$r/@oi_terminal"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
