<class-package xmlns:qry="nomad_engine.qry" name="DMO2InterfaceFichadas" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" languaje="SP" meta-class="DB">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties string="&quot;" file="regist.dat" mode="1" enter="1" separator="," decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.String" name="fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="100" name="usuario" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.String" name="legajo">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="300" name="dpto" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="300" null="true" name="shiftCampo" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" null="true" name="leave" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.String" name="hora_entrada">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.String" name="hora_salida">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" name="exception" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" name="regular_hours" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" name="overtime_hours" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" name="total_work_hours" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.DMO2InterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
