		<resource name="INFO">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Tiempos_Trabajados.NovedadesRol.NOVEDAD_ROL.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Tiempos_Trabajados.NovedadesRol.NOVEDAD_ROL.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
			
				{%?(#SOURCE:@START='')
					{% %}
					{% fromrow {%=#SOURCE:@START%} %}
				%}
				{%?(#SOURCE:@LEN='')
					{% %}
					{% maxsize {%=#SOURCE:@LEN%} %}
				%}
				
				SELECT
					SEC.policy as policy, 
				  TTA24_NOVEDADES_ROL.oi_novedad_rol as ID, 
				  TTA01_TIPOHORAS.c_tipohora as COD, 
				  TTA24_NOVEDADES_ROL.d_novedad_rol as DES
				
				FROM
					NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.NovedadesRol.NOVEDAD_ROL\') as SEC, 
				  TTA24_NOVEDADES_ROL,
				  TTA01_TIPOHORAS
				
				JOIN
					TTA24_NOVEDADES_ROL.oi_novedad_rol LEFT OUTER SEC.id,
					TTA24_NOVEDADES_ROL.oi_tipohora INNER TTA01_TIPOHORAS.oi_tipohora
					
				WHERE
					1=1
					{%?(#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
					{%?(#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
					{%?(#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE%} %} %}
					and TTA24_NOVEDADES_ROL.l_habilitar = 1					
					
				{%?(#SOURCE:@ORDERBY='')
					{% order by COD asc %}
					{% order by {%=#SOURCE:@ORDERBY%} asc %}
				%}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
			
				{%?(#FILTER:@LEN='')
					{% %}
					{% maxsize {%=#FILTER:@LEN%} %}
				%}

				SELECT 
				  TTA24_NOVEDADES_ROL.oi_novedad_rol as ID				  
					{%?($FILTER/@order!='')
						{% ,TTA24_NOVEDADES_ROL.{%=$FILTER/@order%} as COL_ORDER %}
						{% %}
					%}

				FROM 
				  TTA24_NOVEDADES_ROL
				  {%?($FILTER/@search!='')
						{% ,TTA01_TIPOHORAS %}
						{% %}
					%}
				
				{%?($FILTER/@search!='')
					{% JOIN
						   TTA24_NOVEDADES_ROL.oi_tipohora INNER TTA01_TIPOHORAS.oi_tipohora %}
					{% %}
				%}
				
				WHERE
					1=1
					{%?($FILTER/@search!='')
						{% and (contain(ucase(TTA24_NOVEDADES_ROL.d_novedad_rol),{upper-case($FILTER/@search)})
					 		 or contain(ucase(TTA01_TIPOHORAS.d_tipohora),{upper-case($FILTER/@search)})) %}
						{% %}
					%}
					{%?($FILTER/@d_rol!='')
						{% and TTA24_NOVEDADES_ROL.d_rol = {$FILTER/@d_rol} %}
						{% %}
					%}

				{%?($FILTER/@order!='')
				  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc')%} %}
				  {% %}
				%}
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST">
			<qry:include name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO"/>
			<qry:include name="Nomad.Base.Security.Roles.ROL.INFO"/>
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			
			SELECT 
			  TTA24_NOVEDADES_ROL.oi_novedad_rol as ID,
			  TTA24_NOVEDADES_ROL.d_novedad_rol as DES,
			  TTA24_NOVEDADES_ROL.oi_tipohora,
			  TTA24_NOVEDADES_ROL.d_rol,
			  TTA24_NOVEDADES_ROL.l_habilitar

			FROM 
  			TTA24_NOVEDADES_ROL

			WHERE 
				TTA24_NOVEDADES_ROL.oi_novedad_rol in ({%=$PARAM/@IDS %})
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@DES" name="d_novedad_rol"/>
						<qry:element name="oi_tipohora">
							<qry:attribute name="OI_FIND" value="$r/@oi_tipohora"/>
							<qry:insert-select name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="oi_tipohora" value="'['+oi_tipohora/ROW/@COD+'] '+oi_tipohora/ROW/@DES"/>
						<qry:element name="d_rol">
							<qry:attribute name="OI_FIND" value="$r/@d_rol"/>
							<qry:insert-select name="Nomad.Base.Security.Roles.ROL.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="d_rol" value="'['+d_rol/ROW/@COD+'] '+d_rol/ROW/@DES"/>
						<qry:attribute name="l_habilitar" value="$r/@l_habilitar"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_SIN_SEG">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Tiempos_Trabajados.NovedadesRol.NOVEDAD_ROL.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
