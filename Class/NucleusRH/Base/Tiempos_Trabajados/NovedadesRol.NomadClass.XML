					for $r in SQL('
			
				{%?(#SOURCE:@START='')
					{% %}
					{% fromrow {%=#SOURCE:@START%} %}
				%}
				{%?(#SOURCE:@LEN='')
					{% %}
					{% maxsize {%=#SOURCE:@LEN%} %}
				%}
				
				SELECT					
				  TTA24_NOVEDADES_ROL.oi_novedad_rol as ID, 
				  TTA01_TIPOHORAS.c_tipohora as COD, 
				  TTA24_NOVEDADES_ROL.d_novedad_rol as DES
				
				FROM					
				  TTA24_NOVEDADES_ROL,
				  TTA01_TIPOHORAS
				
				JOIN					
					TTA24_NOVEDADES_ROL.oi_tipohora INNER TTA01_TIPOHORAS.oi_tipohora
					
				WHERE
					1=1
					{%?(#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
					{%?(#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
					{%?(#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE%} %} %}										
					
				{%?(#SOURCE:@ORDERBY='')
					{% order by COD asc %}
					{% order by {%=#SOURCE:@ORDERBY%} asc %}
				%}
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
