<class-package xmlns:qry="nomad_engine.qry" name="Kubo" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="KUBO" languaje="SP" meta-class="DB">
	<class note="Esta clase contendra todos los metodos disponibles en Nomad que seran utilizados desde Kubo" description="Kubo" label="Kubo" size="XL" access="direct" name="KUBO">
		<meta-properties/>
		<method label="Importa Fichadas a FichadasIng" modifier="static" access="public" name="FichadaManual">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="oi_personal_emp" type="Nomad.NSystem.Int" pass="byval"/>
				<argument type="Nomad.NSystem.String" pass="byval" name="c_tipo"/>
				<argument name="e_numero_legajo" type="Nomad.NSystem.Int" pass="byval"/>
			</arguments>
		</method>
		<resource name="QRY_TERMINAL">
			<qry:main doc="SOURCE" name="main">
				<ROWS>
					<!--qry:attribute name="c_terminal" value="''"/-->
					<qry:insert-select name="sql1"/>
				</ROWS>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT 
				ORG26_PARAMETROS.c_parametro,
				ORG26_PARAMETROS.d_valor
			FROM 
				ORG26_PARAMETROS
			WHERE 
				ORG26_PARAMETROS.c_modulo = \'TTA\' 
				AND ORG26_PARAMETROS.c_parametro IN (\'TPortal\')
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_terminal" value="$r/@d_valor"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
	<class access="direct" size="M" name="ApiKubo">
		<meta-properties/>
		<method modifier="static" access="public" label="Obtener fichadas desde ndoc" name="ObtenerFichadas">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="xmlParam"/>
			</arguments>
		</method>
		<method label="Obtiene Fichadas desde NucleusDoc y las crea, actualiza o anula en RH autom&#225;ticamente" name="ObtenerFichadas_AUTO" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
	</class>
</class-package>
