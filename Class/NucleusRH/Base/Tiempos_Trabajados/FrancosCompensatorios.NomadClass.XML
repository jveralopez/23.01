		<resource name="QRY_PROC" declare="&lt;FILTRO oi_personal_emp=&quot;339&quot;/&gt;">
			<qry:main doc="SOURCE">
				<qry:element name="PROCS">
					<qry:insert-select name="sql1" doc-path="#SOURCE:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					TTA10_LIQUIDACJOR.f_fecjornada,
					SUM(TTA10_LIQUIDACPROC.n_horas_fc) AS n_horas_fc
				FROM 
					TTA10_LIQUIDACPROC, 
				TTA10_LIQUIDACJOR,
				TTA10_LIQUIDACPERS
				JOIN 
					TTA10_LIQUIDACPROC.oi_liquidacjor INNER TTA10_LIQUIDACJOR.oi_liquidacjor,
					TTA10_LIQUIDACPERS.oi_liquidacionpers INNER TTA10_LIQUIDACJOR.oi_liquidacionpers					
				WHERE
					TTA10_LIQUIDACPROC.n_horas_fc &gt; 0
					AND TTA10_LIQUIDACJOR.f_fecjornada &gt;= {Datetime(now() - 180)}
					AND TTA10_LIQUIDACPERS.oi_personal_emp = {#SOURCE:@oi_personal_emp}
				GROUP BY 
					TTA10_LIQUIDACJOR.f_fecjornada
				ORDER BY 
					f_fecjornada ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<PROC>
						<qry:attribute name="f_fecjornada" value="$r/@f_fecjornada"/>
						<qry:attribute name="n_horas_fc" value="$r/@n_horas_fc"/>
					</PROC>
				</qry:out>
			</qry:select>
		</resource>
