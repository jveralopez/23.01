<class-package xmlns:qry="nomad_engine.qry" description="Novedades con Seguridad" root-class="NOVEDAD_SEC" name="NovedadesSec" DDOBase="NucleusRH\Base\Tiempos_Trabajados" meta-class="DB" languaje="SP">
	<class attr-desc="id" attr-code="id" name="NOVEDAD_SEC" size="L" help="Registra las Novedades del Personal" description="Novedades" access="direct" label="Novedad">
		<meta-properties>
			<db-properties desc-column="oi_novedad_sec" code-column="oi_novedad_sec" table="TTA25_NOVEDADES_SEC" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_novedad">
			<meta-properties>
				<db-properties column="oi_novedad_sec" tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int"/>
			</meta-properties>
		</attribute>
		<assosiation label="Empresa - Legajo" name="oi_personal_emp" class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" null="false" readonly="false" type="aggregation" OriginalName="oi_tipohora">
			<meta-properties>
				<db-properties updatable="true" insertable="true" from-column="oi_personal_emp" tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_personal_emp"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Tiempos_Trabajados.NovedadesRol.NOVEDAD_ROL" name="oi_novedad_rol" label="Tipo de Hora" default="''" null="false" readonly="false" type="aggregation" OriginalName="oi_licencia">
			<meta-properties>
				<db-properties from-column="oi_novedad_rol" updatable="true" insertable="true" tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_novedad_rol"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha" name="f_fecha" OriginalName="f_fecha">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_fecha"/>
			</meta-properties>
		</attribute>
		<attribute length="6" type="Nomad.NSystem.String" name="e_horadesde" null="false" readonly="false" default="''" label="Hora Desde" OriginalName="e_horainicio">
			<meta-properties>
				<db-properties type="varchar(6)" column="e_horadesde" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false"/>
			</meta-properties>
		</attribute>
		<attribute length="6" type="Nomad.NSystem.String" name="e_horahasta" label="Hora Hasta" null="false" readonly="false" default="''" OriginalName="e_horafin">
			<meta-properties>
				<db-properties type="varchar(6)" column="e_horahasta" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_novedad" OriginalName="d_novedad">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_novedad"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_novedad" OriginalName="o_novedad">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_novedad"/>
			</meta-properties>
		</attribute>
		<attribute null="false" name="d_user_crea" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Creado por Usuario" OriginalName="d_usuario_int">
			<meta-properties>
				<db-properties nullable="false" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" type="varchar(100)" column="d_user_crea"/>
			</meta-properties>
		</attribute>
		<attribute name="f_crea" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha de Creaci&#243;n" OriginalName="f_carga_int">
			<meta-properties>
				<db-properties nullable="false" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" type="datetime" column="f_crea"/>
			</meta-properties>
		</attribute>
		<attribute readonly="false" label="Novedad" name="oi_novedad" null="true" default="''" type="Nomad.NSystem.Int" OriginalName="oi_licencia_per">
			<meta-properties>
				<db-properties unique="true" tracking-changes="yes" id="false" column="oi_novedad" versionable="false" insertable="true" updatable="true" generator="none" nullable="true" type="int"/>
			</meta-properties>
		</attribute>
		<method return-class="Nomad.NSystem.Proxy.NomadXML" return-type="Nomad.NSystem.Object" modifier="static" access="public" name="ValidarNovedad">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="xmlNovedad" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval"/>
			</arguments>
		</method>
		<method name="AltaNovedadSec" access="public" modifier="static">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="NucleusRH.Base.Tiempos_Trabajados.NovedadesSec.NOVEDAD_SEC" type="Nomad.NSystem.Object" pass="byval" name="DDO"/>
			</arguments>
		</method>
		<method name="BajaNovedadSec" access="public" modifier="static">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.String" pass="byval" name="ID"/>
			</arguments>
		</method>
		<resource declare="&lt;DATA/&gt;" name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				SEC.policy as policy,
			  TTA25_NOVEDADES_SEC.oi_novedad_sec as ID
				{%?($FILTER/@order!='')
					{% ,TTA25_NOVEDADES_SEC.{%=$FILTER/@order%} as COL_ORDER %}
					{% ,TTA25_NOVEDADES_SEC.f_fecha as f_fecha %}
				%}
				{%?($FILTER/@f_desde='' and $FILTER/@f_hasta='')
					{% ,ADDDAYS(NOW(),-30) as f_fecha_desde %}
					{% %}
				%}				
				
			FROM
				NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC,
			  TTA25_NOVEDADES_SEC
			  {%?($FILTER/@search!='')
			  	{% ,PER02_PERSONAL_EMP
			  		 ,PER01_PERSONAL
			  		 ,ORG03_EMPRESAS
  					 ,TTA24_NOVEDADES_ROL
  					 ,TTA01_TIPOHORAS %}
  				{% %}
				%}			
			
			JOIN
				TTA25_NOVEDADES_SEC.oi_personal_emp LEFT OUTER SEC.id
				{%?($FILTER/@search!='')			  	 
		  		{% ,TTA25_NOVEDADES_SEC.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp
		  		   ,PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
		  		   ,PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
					   ,TTA25_NOVEDADES_SEC.oi_novedad_rol INNER TTA24_NOVEDADES_ROL.oi_novedad_rol
					   ,TTA24_NOVEDADES_ROL.oi_tipohora INNER TTA01_TIPOHORAS.oi_tipohora %}
					{% %}
				%}		
			
			WHERE
				1=1			
				{%?($FILTER/@search!='')
				 {% and (contain(ucase(ORG03_EMPRESAS.c_empresa),{upper-case($FILTER/@search)})
				 		or contain(ucase(PER02_PERSONAL_EMP.e_numero_legajo),{upper-case($FILTER/@search)})
				 		or contain(ucase(PER01_PERSONAL.d_ape_y_nom),{upper-case($FILTER/@search)})
				 		or contain(ucase(TTA01_TIPOHORAS.d_tipohora),{upper-case($FILTER/@search)})
				 		or contain(ucase(TTA25_NOVEDADES_SEC.d_user_crea),{upper-case($FILTER/@search)})) %}
				 {% %}
				%}
				{%?($FILTER/@f_desde!='')
					{% and TTA25_NOVEDADES_SEC.f_fecha &gt;= {$FILTER/@f_desde} %}
					{% %}
				%}				
				{%?($FILTER/@f_hasta!='')
					{% and TTA25_NOVEDADES_SEC.f_fecha &lt;= {$FILTER/@f_hasta} %}
					{% %}
				%}
				{%?($FILTER/@l_current_user=1)
					{% and TTA25_NOVEDADES_SEC.d_user_crea = {$PROXY/@ETTY} %}
					{% %}
				%}				
				{%?($FILTER/@f_desde='' and $FILTER/@f_hasta='')
					{% and TTA25_NOVEDADES_SEC.f_fecha &gt;= f_fecha_desde %}
					{% %}
				%}				
				
			{%?($FILTER/@order!='')
			  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc')%} %}
			  {% order by f_fecha desc %}
			%}				
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM IDS=&quot;5&quot;/&gt;" name="INFO_IDS_LIST">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO"/>
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			
			SELECT				 
			  TTA25_NOVEDADES_SEC.oi_novedad_sec,
			  PER02_PERSONAL_EMP.oi_empresa,
			  TTA25_NOVEDADES_SEC.oi_personal_emp,
			  TTA01_TIPOHORAS.oi_tipohora,
			  TTA01_TIPOHORAS.c_tipohora,
			  TTA01_TIPOHORAS.d_tipohora,
			  TTA05_TERMINALES.oi_estructura,
			  TTA25_NOVEDADES_SEC.f_fecha,
			  TTA25_NOVEDADES_SEC.e_horadesde,
			  TTA25_NOVEDADES_SEC.e_horahasta,
			  TTA25_NOVEDADES_SEC.d_novedad,
			  TTA25_NOVEDADES_SEC.o_novedad,
			  TTA25_NOVEDADES_SEC.d_user_crea,
			  TTA24_NOVEDADES_ROL.l_eliminar_1,
			  TTA24_NOVEDADES_ROL.l_eliminar_2,
			  TTA25_NOVEDADES_SEC.oi_novedad
			  
			FROM				
  			TTA25_NOVEDADES_SEC,
  			PER02_PERSONAL_EMP,
  			TTA24_NOVEDADES_ROL,
  			TTA05_TERMINALES,
  			TTA01_TIPOHORAS  			
  		
  		JOIN  			  			
  			TTA25_NOVEDADES_SEC.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
  			TTA25_NOVEDADES_SEC.oi_novedad_rol INNER TTA24_NOVEDADES_ROL.oi_novedad_rol,
  			TTA24_NOVEDADES_ROL.oi_terminal INNER TTA05_TERMINALES.oi_terminal,
  			TTA24_NOVEDADES_ROL.oi_tipohora INNER TTA01_TIPOHORAS.oi_tipohora
  			
			WHERE 
				TTA25_NOVEDADES_SEC.oi_novedad_sec in ({%=$PARAM/@IDS%})
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="id" value="$r/@oi_novedad_sec"/>
						<qry:element name="oi_empresa">
							<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
							<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+']'"/>
						<qry:element name="oi_personal_emp">
							<qry:attribute name="OI_FIND" value="$r/@oi_personal_emp"/>
							<qry:insert-select name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="oi_personal_emp" value="'['+oi_personal_emp/ROW/@COD+'] '+oi_personal_emp/ROW/@DES"/>
						<qry:attribute name="oi_tipohora" value="'['+$r/@c_tipohora+'] '+$r/@d_tipohora"/>
						<qry:attribute name="f_fecha" value="$r/@f_fecha"/>
						<qry:attribute name="e_horadesde" value="'00000000'+$r/@e_horadesde"/>
						<qry:attribute name="e_horahasta" value="'00000000'+$r/@e_horahasta"/>
						<qry:attribute name="d_novedad" value="$r/@d_novedad"/>
						<qry:attribute name="d_user_crea" value="$r/@d_user_crea"/>
						<qry:attribute name="l_eliminar_1" value="$r/@l_eliminar_1"/>
						<qry:attribute name="l_eliminar_2" value="$r/@l_eliminar_2"/>
						<qry:attribute name="color" value="'E50000'"/>
						<!--ROJO/-->
						<qry:insert-select name="BuscarNovPer" doc-path="$r"/>
					</ROW>
				</qry:out>
			</qry:select>
			<qry:select name="BuscarNovPer" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
				SELECT 
   				TTA04_NOVEDADES.oi_tipohora,   				
   				TTA04_NOVEDADES.oi_estructura,
					ADDMINS(TTA04_NOVEDADES.f_fecha,TTA04_NOVEDADES.e_horainicio) as f_desde,
					ADDMINS(TTA04_NOVEDADES.f_fecha,TTA04_NOVEDADES.e_horafin) as f_hasta,
					TTA04_NOVEDADES.d_novedad,
					TTA04_NOVEDADES.o_novedad

				FROM
					TTA04_NOVEDADES
				
				WHERE
					TTA04_NOVEDADES.oi_novedad = {$PARAM/@oi_novedad}			
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="color" value="'FFD800'"/>
					<!--AMARILLO/-->
					<qry:if test="$r/@oi_tipohora = $PARAM/@oi_tipohora">
						<qry:then>
							<qry:if test="$r/@oi_estructura = $PARAM/@oi_estructura">
								<qry:then>
									<qry:attribute name="f_desde" value="concat($PARAM/@f_fecha,$PARAM/@e_horadesde)"/>
									<qry:if test="$r/@f_desde = @f_desde">
										<qry:then>
											<qry:attribute name="f_hasta" value="concat($PARAM/@f_fecha,$PARAM/@e_horahasta)"/>
											<qry:if test="$r/@f_hasta = @f_hasta">
												<qry:then>
													<qry:if test="$r/@d_novedad = $PARAM/@d_novedad">
														<qry:then>
															<qry:if test="$r/@o_novedad = $PARAM/@o_novedad">
																<qry:then>
																	<qry:attribute name="color" value="'3FBF00'"/>
																	<!--VERDE/-->
																</qry:then>
															</qry:if>
														</qry:then>
													</qry:if>
												</qry:then>
											</qry:if>
										</qry:then>
									</qry:if>
								</qry:then>
							</qry:if>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
