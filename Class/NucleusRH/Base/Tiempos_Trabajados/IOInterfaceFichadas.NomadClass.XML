<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" name="IOInterfaceFichadas" meta-class="DB" languaje="SP">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties separator="," file="regist.dat" mode="1" enter="1" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="100" name="nro_tarjeta" type="Nomad.NSystem.String" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.DateTime" length="26" name="fecha_login" OriginalName="c_personal">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy  HH:MM:SS"/>
			</meta-properties>
		</attribute>
		<attribute null="true" type="Nomad.NSystem.DateTime" length="26" name="fecha_logout" OriginalName="c_personal">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy  HH:MM:SS"/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.IOInterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM d_nro_tarjeta=&quot;PAILAN&quot; /&gt;" description="Retorna nro legajo a partir de nro de tarjeta" name="qry_nro_legajo">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="qry_legajo" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry_legajo" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
            SELECT  
              TTA04_PERSONAL.e_nro_legajo_reloj 
            FROM 
              TTA04_PERSONAL 
            WHERE
            	TTA04_PERSONAL.d_nro_tarjeta = {#SOURCE:@d_nro_tarjeta}  
            ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="e_numero_legajo" value="$r/@e_nro_legajo_reloj"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
