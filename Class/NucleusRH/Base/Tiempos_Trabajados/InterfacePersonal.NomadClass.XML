<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="PERSONAL" languaje="SP" meta-class="DB" name="InterfacePersonal">
	<class extends="NucleusRH.Base.Personal.InterfacePersonal.PERSONAL" description="FichadasIngresadas" access="direct" name="PERSONAL">
		<meta-properties>
			<interface-properties file="personalTTA.dat" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="16" name="LEGAJO_RELOJ" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="16" name="TARGETA" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method name="ImportarLegajosTTA" description="Importar Legajos" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.InterfacePersonal.PERSONAL" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_empresa"/>
			</arguments>
		</method>
		<resource name="qry_legajos">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:personalTTA.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
