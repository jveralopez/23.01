<class-package xmlns:qry="nomad_engine.qry" name="DMOInterfaceFichadas" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" languaje="SP" meta-class="DB">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties file="regist.dat" mode="1" enter="1" separator="," decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.String" OriginalName="f_fecha" name="fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Int" name="legajo" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="usuario" length="10" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="dpto" length="10" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="true" name="shiftCampo" length="10" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute null="true" name="diaday" length="10" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.DateTime" length="10" name="hora_entrada">
			<meta-properties>
				<interface-properties mask="HH:MM"/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.DateTime" length="10" precision="0" name="hora_salida">
			<meta-properties>
				<interface-properties mask="HH:MM"/>
			</meta-properties>
		</attribute>
		<attribute name="resultado" length="10" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="firstIn" length="30" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="lastOut" length="30" type="Nomad.NSystem.String" OriginalName="f_fecha">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="cien" type="Nomad.NSystem.String" length="5">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="cincuenta" type="Nomad.NSystem.String" length="5">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="breaktime" type="Nomad.NSystem.String" length="5">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="worktime" type="Nomad.NSystem.String" length="5">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.SRFInterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
