		<resource description="Retorna todos los tipos de horas." name="QRY_Horarios">
			<qry:main doc="PARAM">
				<qry:element name="horarios">
					<qry:insert-select name="qryMain"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain">
				<qry:xquery>
					for $f in sql('
            	SELECT
					h.oi_horario,
					h.c_horario,
					h.d_horario,
					h.e_dias,
					h.d_tipohorario,
					h.c_estado,
					h.o_horario,
					h.l_controla_fic,
					h.e_tolpreing,
					h.e_tolposing,
					h.e_tolpreegr,
					h.e_tolposegr,
					h.c_color            	

            	FROM 
            		TTA02_HORARIOS as h
            	
            ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="horario">
						<qry:attribute name="c_color" value="$f/@c_color"/>
						<qry:attribute name="e_tolposegr" value="$f/@e_tolposegr"/>
						<qry:attribute name="e_tolpreegr" value="$f/@e_tolpreegr"/>
						<qry:attribute name="e_tolposing" value="$f/@e_tolposing"/>
						<qry:attribute name="e_tolpreing" value="$f/@e_tolpreing"/>
						<qry:attribute name="l_controla_fic" value="$f/@l_controla_fic"/>
						<qry:attribute name="d_tipohorario" value="$f/@d_tipohorario"/>
						<qry:attribute name="e_dias" value="$f/@e_dias"/>
						<qry:attribute name="d_horario" value="$f/@d_horario"/>
						<qry:attribute name="c_horario" value="$f/@c_horario"/>
						<qry:attribute name="oi_horario" value="$f/@oi_horario"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource description="DEVUELVE &quot;1&quot; si algun Legajo tiene asignado el Horario o si Horario esta en la tabla TTA11_ESPERANZAPER" declare="&lt;DATO oi_horario=&quot;1&quot;/&gt;" name="QRY_HORARIOS_PERS">
			<qry:main doc="PARAM">
				<qry:element name="ROW">
					<qry:attribute name="flaghor" value="0"/>
					<qry:attribute name="flagesp" value="0"/>
					<qry:insert-select name="RS1" doc-path="#PARAM:DATO"/>
					<qry:insert-select name="RS2" doc-path="#PARAM:DATO"/>
				</qry:element>
			</qry:main>
			<qry:select name="RS1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
					SELECT TTA04_HORARIOSPERS.oi_horariopers
					FROM TTA04_HORARIOSPERS
					WHERE TTA04_HORARIOSPERS.oi_horario = {#PARAM:@oi_horario}
 			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="flaghor" value="1"/>
				</qry:out>
			</qry:select>
			<qry:select name="RS2" doc="PARAM">
				<qry:xquery>
					for $r in sql('
					SELECT TTA11_ESPERANZAPER.oi_esperanzaper
					FROM TTA11_ESPERANZAPER
					WHERE TTA11_ESPERANZAPER.oi_horario = {#PARAM:@oi_horario}
 			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="flagesp" value="1"/>
				</qry:out>
			</qry:select>
		</resource>
