<class-package xmlns:qry="nomad_engine.qry" root-class="VARIABLE" name="Variables" DDOBase="NucleusRH\Base\Tiempos_Trabajados" languaje="SP" meta-class="DB">
	<class size="M" description="Variables para Tiempos" access="direct" label="Variable" name="VARIABLE">
		<meta-properties>
			<db-properties desc-column="d_variable" code-column="c_variable" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="TTA16_VARIABLES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_variables" code-attr="c_variables" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_variable as oi_variable, t0.c_tipo_variable as c_tipo_variable, t0.c_variable as c_variable, t0.d_variable as d_variable, t0.c_tipo_dato as c_tipo_dato, t0.l_colleccion as l_colleccion, t0.n_valor as n_valor, t0.c_externo as c_externo, SEC.policy, t0.c_variable as CODE, t0.d_variable as TEXT, t0.oi_tipohora as oi_tipohora FROM TTA16_VARIABLES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE\') as SEC JOIN t0.oi_variable LEFT OUTER SEC.id  ORDER BY oi_variable asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_variable"/>
								<qry:attribute name="c_tipo_variable" value="$r/@c_tipo_variable"/>
								<qry:attribute name="c_variable" value="$r/@c_variable"/>
								<qry:attribute name="d_variable" value="$r/@d_variable"/>
								<qry:attribute name="c_tipo_dato" value="$r/@c_tipo_dato"/>
								<qry:attribute name="l_colleccion" value="iif($r/@l_colleccion='1','1','0')"/>
								<qry:attribute name="n_valor" value="$r/@n_valor"/>
								<qry:attribute name="c_externo" value="$r/@c_externo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tipohora!=''">
									<qry:then>
										<qry:element name="oi_tipohora">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipohora"/>
											<qry:insert-select name="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipohora" value="'['+oi_tipohora/ROW/@COD+'] '+oi_tipohora/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_variable as oi_variable, SEC.policy FROM TTA16_VARIABLES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE\') as SEC JOIN t0.oi_variable LEFT OUTER SEC.id  ORDER BY oi_variable asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_variable"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_variable" code-attr="c_variable" desc="d_variables" code="c_variables" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_variable">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_variable"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Tipo Variable" name="c_tipo_variable" OriginalName="c_tipo_variable">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.c_tipo_variable" show-list="true" find-include="true" automatico="1" label="Tipo Variable" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_variable"/>
			</meta-properties>
		</attribute>
		<enum name="c_tipo_variable">
			<enum-value label="Persona Fijo" value="PERFIJ"/>
			<enum-value label="Persona Novedad" value="PERNOV"/>
			<enum-value label="Persona Acumulador" value="PERACC"/>
			<enum-value label="Procesamiento Novedad" value="LIQNOV"/>
			<enum-value label="Tipo de Hora" value="TIPHOR"/>
			<enum-value label="Auxiliar" value="AUX"/>
		</enum>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_variable" OriginalName="c_variable">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_variable"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_variable" OriginalName="d_variable">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_variable"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Tipo de Dato" name="c_tipo_dato" OriginalName="c_tipo_dato">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.c_tipo_dato" show-list="true" find-include="true" automatico="1" label="Tipo de Dato" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_dato"/>
			</meta-properties>
		</attribute>
		<enum name="c_tipo_dato">
			<enum-value label="Fecha" value="DateTime"/>
			<enum-value label="Entero" value="int"/>
			<enum-value label="Decimal" value="double"/>
			<enum-value label="Logico" value="bool"/>
		</enum>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Colecci&#243;n" name="l_colleccion" OriginalName="l_colleccion">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Colecci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_colleccion"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" label="Valor" name="n_valor" OriginalName="n_valor">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Valor" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="numeric(11,3)" column="n_valor"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Tiempos_Trabajados.Tipos_Horas.TIPOHORA" null="true" readonly="false" type="aggregation" label="Tipo Hora" name="oi_tipohora" OriginalName="oi_tipohora">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_tipohora"/>
				<form-properties label="Tipo Hora" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_tipohora"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo Externo" name="c_externo" OriginalName="c_externo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo Externo" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(30)" column="c_externo"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_variable" OriginalName="o_variable">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_variable"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_I_VARIABLE_LIQ_VARI" name="AK_I_VARIABLE_LIQ_VARI">
			<key-attr assosiation="no" name="c_variable"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  TTA16_VARIABLES.oi_variable as ID,
  TTA16_VARIABLES.c_variable as COD,
  TTA16_VARIABLES.d_variable as DES
from
  TTA16_VARIABLES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Tiempos_Trabajados.Variables.VARIABLE.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(TTA16_VARIABLES.oi_variable) as CNT
from
  TTA16_VARIABLES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and TTA16_VARIABLES.oi_variable={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(TTA16_VARIABLES.d_variable,{#SOURCE:@TXT_FIND}) or contain(TTA16_VARIABLES.c_variable,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="qry_variables">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1" doc-path="#PARAM:"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('
SELECT 
	v.oi_variable as id, 
	v.c_tipo_variable, 
	v.c_variable, 
	v.c_tipo_dato,
	v.l_colleccion,
	v.n_valor,
	v.oi_tipohora
FROM 
	TTA16_VARIABLES as v
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
