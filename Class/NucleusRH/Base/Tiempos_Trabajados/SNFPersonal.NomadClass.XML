			<interface-properties file="personal.nom" mode="1" enter="1" separator=";" decimal="."/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute type="Nomad.NSystem.String" length="5" name="legajo" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="tarjeta" type="Nomad.NSystem.String" description="numero de targeta" length="8">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="estado" length="1" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="mensaje" length="2" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="64" type="Nomad.NSystem.String" name="nombre" OriginalName="l_entrada">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ExportarNomina">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.SNFPersonal.NOMINA" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
