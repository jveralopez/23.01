		<resource declare="&lt;PARAM oi_personal_emp=&quot;15958&quot; oi_banco_hora=&quot;1&quot; /&gt;" name="FC_A_COMPENSAR">
			<qry:main doc="SOURCE" name="MAIN">
				<qry:element name="RESULT">
					<qry:insert-select name="SQL1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
				SELECT 
					TTA20_REGISTRO_FC.oi_registro_fc,
					TTA20_REGISTRO_FC.f_registro_fc
				FROM
					TTA20_REGISTRO_FC
				WHERE
					TTA20_REGISTRO_FC.l_aprob = 1
					AND TTA20_REGISTRO_FC.n_saldo &gt; 0
					AND TTA20_REGISTRO_FC.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND TTA20_REGISTRO_FC.oi_banco_hora = {#SOURCE:@oi_banco_hora}
				ORDER BY
					f_registro_fc ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_registro_fc" value="$r/@oi_registro_fc"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM oi_personal_emp=&quot;15958&quot; oi_banco_hora=&quot;2&quot; n_saldo=&quot;2&quot;/&gt;" name="FC_A_RECALCULAR">
			<qry:main doc="SOURCE" name="MAIN">
				<qry:element name="RESULT">
					<qry:append-doc name="FILTRO" doc-path="."/>
					<qry:attribute name="noreg" value="'1'"/>
					<qry:insert-select name="VencimientoFC" doc-path="#SOURCE:PARAM"/>
					<qry:insert-select name="SQL1" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="VencimientoFC">
				<qry:xquery>
					for $r in sql('     
				SELECT 
					ORG26_PARAMETROS.oi_parametro, 
					ORG26_PARAMETROS.d_valor,
					ADDMONTHS(NOW(),STRING2NUMBER(ORG26_PARAMETROS.d_valor)*(-1)) as fecha
				FROM 
					ORG26_PARAMETROS
				WHERE 
					ORG26_PARAMETROS.c_parametro = \'VencimientoFC\'
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="fecha_vencimiento" value="substring($r/@fecha,0,8)"/>
				</qry:out>
			</qry:select>
			<qry:select name="SQL1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL(' 
				MAXSIZE 1
				SELECT 
					TTA20_REGISTRO_FC.oi_registro_fc,
					TTA20_REGISTRO_FC.f_registro_fc
				FROM
					TTA20_REGISTRO_FC
				WHERE
					TTA20_REGISTRO_FC.l_aprob = 1
					AND TTA20_REGISTRO_FC.n_saldo &gt;= {#SOURCE:@n_saldo}
					AND TTA20_REGISTRO_FC.oi_personal_emp = {#SOURCE:@oi_personal_emp}
					AND TTA20_REGISTRO_FC.oi_banco_hora = {#SOURCE:@oi_banco_hora} 
					{%? (#SOURCE:FILTRO/@fecha_vencimiento = '') {% %} {% AND TTA20_REGISTRO_FC.f_registro_fc &gt;= {Datetime(#SOURCE:FILTRO/@fecha_vencimiento)} %} %}	
				ORDER BY
					f_registro_fc ASC
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@oi_registro_fc"/>
					<qry:attribute name="noreg" value="'0'"/>
				</qry:out>
			</qry:select>
