<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="MENSAJE" languaje="SP" meta-class="DB" name="Mensajes">
	<class size="M" note="Almacena los diferentes Mensajes que se cargar&#225;n en los Terminales." description="Mensajes del Terminal" access="direct" label="Mensaje" name="MENSAJE">
		<meta-properties>
			<db-properties desc-column="d_mensaje" code-column="c_mensaje" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="TTA12_MEN_TERMINAL">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_men_terminal" code-attr="c_men_terminal" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mensaje as oi_mensaje, t0.c_mensaje as c_mensaje, t0.d_mensaje as d_mensaje, t0.c_mensaje as CODE, t0.d_mensaje as TEXT FROM TTA12_MEN_TERMINAL as t0 ORDER BY oi_mensaje asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mensaje"/>
								<qry:attribute name="c_mensaje" value="$r/@c_mensaje"/>
								<qry:attribute name="d_mensaje" value="$r/@d_mensaje"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_mensaje as oi_mensaje FROM TTA12_MEN_TERMINAL as t0 ORDER BY oi_mensaje asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_mensaje"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Tiempos_Trabajados.Mensajes.autoflow:initialize" desc-attr="d_mensaje" code-attr="c_mensaje" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_mensaje">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_mensaje"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_mensaje" OriginalName="c_mensaje">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_mensaje"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Mensaje" name="d_mensaje" OriginalName="d_mensaje">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Mensaje" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_mensaje"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK_TTA12_MEN_TERMINAL" msg="Ya existe un Mensaje con el c&#243;digo especificado" name="AK_TTA12_MEN_TERMINAL">
			<key-attr assosiation="no" name="c_mensaje"/>
		</key>
	</class>
</class-package>
