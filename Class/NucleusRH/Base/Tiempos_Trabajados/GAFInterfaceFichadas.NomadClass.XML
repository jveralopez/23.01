<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" languaje="SP" meta-class="DB" name="GAFInterfaceFichadas">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties file="regist.dat" mode="0" enter="1"/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute name="legajo" type="Nomad.NSystem.String" length="8" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="sep1" type="Nomad.NSystem.String" length="1" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" type="Nomad.NSystem.DateTime" OriginalName="f_fecha" name="fecha">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute name="sep2" type="Nomad.NSystem.String" length="1" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="hora" type="Nomad.NSystem.DateTime" length="5">
			<meta-properties>
				<interface-properties mask="HH:MM"/>
			</meta-properties>
		</attribute>
		<attribute name="sep3" type="Nomad.NSystem.String" length="1" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="lector" OriginalName="l_entrada" length="1" type="Nomad.NSystem.String">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.GAFInterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
