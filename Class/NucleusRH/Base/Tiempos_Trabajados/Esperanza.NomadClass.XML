		<key parent-include="no" descr="AK_TTA03_ESPERANZA" msg="Ya existe un registro de Esperanza para la Empresa, Calendario, Horario, Escuadra, Fecha y Hora de Inicio" name="AK_TTA03_ESPERANZA">
			<key-attr assosiation="yes" name="oi_calendario"/>
			<key-attr assosiation="yes" name="oi_horario"/>
			<key-attr assosiation="yes" name="oi_escuadra"/>
			<key-attr assosiation="no" name="e_semana"/>
		</key>
		<resource declare="&lt;DATOS Macro=&quot;(  ( e.f_horaInicio &amp;gt;= {DateTime(\'20070924000000\')} AND e.f_HoraFin &amp;lt; {DateTime(\'20071124000000\')} AND e.oi_horario = 1  )  ) &quot; oi_empresa=&quot;10&quot; oi_calendario=&quot;2&quot; /&gt;" description="Retorna las esperanzas." name="QRY_Esperanzas">
			<qry:main doc="PARAM">
				<qry:element name="objects">
					<qry:insert-select name="qryMain" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain" doc="PARAM">
				<qry:xquery>
					for $f in sql('
			SELECT 
				e.oi_tipoHora, 
                e.f_horaInicio, 
                e.f_horaFin, 
                e.e_posicion, 
                e.oi_horario, 
                e.oi_estructura, 
                th.c_tipoHora, 
                th.l_controla_fichada, 

                th.e_sumariza_aus, 
                th.e_sumariza_pre, 
                th.l_requiereaut 
 			
 			FROM 
 				TTA03_Esperanza as e, 
 				TTA01_TipoHoras as th 

			JOIN           
				e.oi_tipoHora INNER th.oi_tipoHora

			WHERE 
				e.oi_empresa = {#PARAM:@oi_empresa}
				AND e.oi_calendario = {#PARAM:@oi_calendario}
				{%? (#PARAM:@Macro != '') {% AND {%= #PARAM:@Macro %} %} {% %} %}				
			
			ORDER BY
				f_horaInicio ASC
			

            ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="object">
						<qry:attribute name="oi_tipoHora" value="$f/@oi_tipoHora"/>
						<qry:attribute name="f_FechaHoraInicio" value="$f/@f_HoraInicio"/>
						<qry:attribute name="f_FechaHoraFin" value="$f/@f_HoraFin"/>
						<qry:attribute name="e_posicion" value="$f/@e_posicion"/>
						<qry:attribute name="oi_horario" value="$f/@oi_horario"/>
						<qry:attribute name="oi_estructura" value="$f/@oi_estructura"/>
						<qry:attribute name="oi_tipoHora" value="$f/@oi_tipoHora"/>
						<qry:attribute name="c_tipoHora" value="$f/@c_tipoHora"/>
						<qry:attribute name="l_controla_fichada" value="$f/@l_controla_fichada"/>
						<qry:attribute name="e_sumariza_aus" value="$f/@e_sumariza_aus"/>
						<qry:attribute name="e_sumariza_pre" value="$f/@e_sumariza_pre"/>
						<qry:attribute name="l_requiereaut" value="$f/@l_requiereaut"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATOS fecDesde=&quot;20200101&quot; fecHasta=&quot;20200301&quot;   sPosiciones=&quot;0,1,2,3,4,5,6&quot;  oi_horario=&quot;27&quot;    oi_calendario=&quot;1&quot; /&gt;" description="arma la hash" name="QRY_ObtieneHash">
			<qry:main doc="PARAM" name="">
				<qry:append-doc name="FILTRO" doc-path="#PARAM:DATOS"/>
				<qry:insert-select name="filtro_Inicial" doc-path="#FILTRO:"/>
			</qry:main>
			<qry:select name="filtro_Inicial" doc="PARAM">
				<qry:xquery>
					for $r in sql ('
SELECT
Hor.oi_horario as oi_horario
, Hor.c_horario as c_horario
, Hor.e_dias as e_dias
, Hor.d_tipohorario as d_tipohorario
, Hor.c_estado as c_estado
FROM   TTA02_HORARIOS as Hor
WHERE  Hor.oi_horario = {#FILTRO:@oi_horario}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="Objects">
						<qry:element name="Feriados">
							<qry:insert-select name="qryFeriados" doc-path="#FILTRO:"/>
						</qry:element>
						<qry:element name="Horarios">
							<qry:insert-select name="qryHorario" doc-path="$r"/>
						</qry:element>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="PARAM" name="qryFeriados">
				<qry:xquery>
					for $r in sql(' SELECT  org.oi_dia_feriado , org.f_feriado, org.c_tipo 
								FROM ORG27_DIAS_FERIADOS as org
							 WHERE   org.oi_calendario={#FILTRO:@oi_calendario} and 
				 ( org.f_feriado&gt;={DateTime(#FILTRO:@fecDesde)}  and  org.f_feriado&lt;={DateTime(#FILTRO:@fecHasta)} )
            ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="Feriado">
						<qry:attribute value="$r/@oi_dia_feriado" name="oi_dia_feriado"/>
						<qry:attribute value="$r/@f_feriado" name="f_feriado"/>
						<qry:attribute value="$r/@c_tipo" name="c_tipo"/>
						<qry:attribute value="concat(@c_tipo,'_',@f_feriado)" name="c_feriado"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="DocHor" name="qryHorario">
				<qry:out>
					<qry:insert-select doc-path="#FILTRO:" name="qryDetalles"/>
					<qry:element name="Horario">
						<qry:attribute value="#DocHor:@oi_horario" name="oi_horario"/>
						<qry:attribute value="#DocHor:@c_horario" name="c_horario"/>
						<qry:attribute value="#DocHor:@e_dias" name="e_dias"/>
						<qry:attribute value="#DocHor:@d_tipohorario" name="d_tipohorario"/>
						<qry:attribute value="#DocHor:@c_estado" name="c_estado"/>
						<qry:insert-select doc-path="#FILTRO:" name="qryPosiciones"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="DocPos" name="qryPosiciones">
				<qry:xquery>
					for $r in sql ('
SELECT  
 TUR_DET.e_posicion as e_posicion
, TURNOS.c_turno as c_turnoT
, TURNOS.c_estado as c_estadoT
, TUR_DET.oi_estructura  as oi_estructura
, Hor.c_horario as c_horarioH
, Hor.e_dias as e_diasH
, Hor.d_tipohorario as d_tipohorarioH
, Hor.c_estado as c_estado_H        
, TURNOS.oi_turno 
FROM   TTA02_HORA_TUR_DET  as TUR_DET   
			, TTA14_TURNOS as TURNOS 
			, TTA02_HORARIOS as Hor

JOIN  TUR_DET.oi_turno INNER  TURNOS.oi_turno , 
		TUR_DET.oi_horario INNER  Hor.oi_horario  

WHERE  TUR_DET.oi_horario = {#DocPos:@oi_horario}  
  AND TUR_DET.e_posicion  in ({%=#DocPos:@sPosiciones%}) 
   ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="Posicion">
						<qry:attribute value="$r/@e_posicion" name="e_posicion"/>
						<qry:attribute value="$r/@c_turnoT" name="c_turnoT"/>
						<qry:attribute value="$r/@oi_turno" name="oi_turno"/>
						<qry:attribute value="$r/@oi_estructura" name="oi_estructura"/>
						<qry:insert-select doc-path="#DETALLE:ROW[@oi_turno=$r/@oi_turno]" name="qryPosicionesDet"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="qryPosicionesDet" doc="PI">
				<qry:out>
					<qry:element name="det">
						<qry:attribute value="#PI:@e_hora_inicio" name="e_hora_inicio"/>
						<qry:attribute value="#PI:@e_hora_fin" name="e_hora_fin"/>
						<qry:attribute value="#PI:@oi_tipo_hs_norm" name="oi_tipo_hs_norm"/>
						<qry:attribute value="#PI:@oi_tipo_hs_dom" name="oi_tipo_hs_dom"/>
						<qry:attribute value="#PI:@oi_tipo_hs_fer" name="oi_tipo_hs_fer"/>
						<qry:attribute value="#PI:@oi_tipo_hs_domfer" name="oi_tipo_hs_domfer"/>
						<qry:attribute value="#PI:@oi_tipo_hs_nolab" name="oi_tipo_hs_nolab"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="DocPos" name="qryDetalles">
				<qry:xquery>
					for $d in sql ('
SELECT  
	TURNOS.e_hora_inicio,
	TURNOS.e_hora_fin,
	TURNOS.oi_tipo_hs_norm,
	TURNOS.oi_tipo_hs_dom,
	TURNOS.oi_tipo_hs_fer,
	TURNOS.oi_tipo_hs_domfer,
	TURNOS.oi_tipo_hs_nolab,
	TURNOS.oi_turno

FROM
	TTA02_HORA_TUR_DET as TUR_DET,
	TTA14_TURNOS_DET as TURNOS,
	TTA02_HORARIOS as Hor

JOIN
	TUR_DET.oi_turno INNER  TURNOS.oi_turno, 
	TUR_DET.oi_horario INNER  Hor.oi_horario  

WHERE
	TUR_DET.oi_horario = {#DocPos:@oi_horario}  
  AND TUR_DET.e_posicion  in ({%=#DocPos:@sPosiciones%}) 
  
GROUP BY
	TURNOS.e_hora_inicio,
	TURNOS.e_hora_fin,
	TURNOS.oi_tipo_hs_norm,
	TURNOS.oi_tipo_hs_dom,
	TURNOS.oi_tipo_hs_fer,
	TURNOS.oi_tipo_hs_domfer,
	TURNOS.oi_tipo_hs_nolab,
	TURNOS.oi_turno
	
ORDER BY e_hora_inicio ASC

   ')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:element name="TEMP">
						<qry:attribute name="hts:delete" value="1"/>
						<qry:insert-element doc-path="$d"/>
						<qry:append-doc name="DETALLE" doc-path="./ROWS"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
