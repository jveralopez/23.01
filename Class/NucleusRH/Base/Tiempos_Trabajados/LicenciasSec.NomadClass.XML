		<method return-type="Nomad.NSystem.Boolean" modifier="static" access="public" label="GuardarLicenciaPorRol" name="GuardarLicenciaPorRol">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument description="oi de licencia por persona" name="id" type="Nomad.NSystem.String" pass="byval"/>
			</arguments>
			<event-subscribe method="GuardarLicenciaPorRol" class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" runinerror="no"/>
		</method>
		<resource declare="&lt;DATA/&gt;" name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
			  			
			SELECT
				SEC.policy as policy,
			  TTA23_LICENCIAS_SEC.oi_licencia_sec as ID
				{%?($FILTER/@order!='')
					{% ,TTA23_LICENCIAS_SEC.{%=$FILTER/@order%} as COL_ORDER %}
					{% ,TTA23_LICENCIAS_SEC.f_inicio as f_inicio %}
				%}
				{%?($FILTER/@f_desde='' and $FILTER/@f_hasta='')
					{% ,ADDDAYS(NOW(),-30) as f_inicio_desde %}
					{% %}
				%}				
				
			FROM
				NMD_SECURITY(class=\'NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP\') as SEC,								
			  TTA23_LICENCIAS_SEC
			  {%?($FILTER/@search!='')
			  	{% ,PER02_PERSONAL_EMP
			  		 ,PER01_PERSONAL
			  		 ,ORG03_EMPRESAS
  					 ,TTA22_LICENCIAS_ROL
  					 ,PER16_LICENCIAS %}
  				{% %}
				%}			
			
			JOIN
				TTA23_LICENCIAS_SEC.oi_personal_emp LEFT OUTER SEC.id
				{%?($FILTER/@search!='')
		  		{% ,TTA23_LICENCIAS_SEC.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp
		  		   ,PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
		  		   ,PER02_PERSONAL_EMP.oi_empresa INNER ORG03_EMPRESAS.oi_empresa
					   ,TTA23_LICENCIAS_SEC.oi_licencia_rol INNER TTA22_LICENCIAS_ROL.oi_licencia_rol
					   ,TTA22_LICENCIAS_ROL.oi_licencia INNER PER16_LICENCIAS.oi_licencia %}
					{% %}
				%}		
			
			WHERE
				1=1			
				{%?($FILTER/@search!='')
				 {% and (contain(ucase(ORG03_EMPRESAS.c_empresa),{upper-case($FILTER/@search)})
				 		or contain(ucase(PER02_PERSONAL_EMP.e_numero_legajo),{upper-case($FILTER/@search)})
				 		or contain(ucase(PER01_PERSONAL.d_ape_y_nom),{upper-case($FILTER/@search)})
				 		or contain(ucase(PER16_LICENCIAS.d_licencia),{upper-case($FILTER/@search)})
				 		or contain(ucase(TTA23_LICENCIAS_SEC.d_user_crea),{upper-case($FILTER/@search)})) %}
				 {% %}
				%}
				{%?($FILTER/@f_desde!='')
					{% and TTA23_LICENCIAS_SEC.f_inicio &gt;= {$FILTER/@f_desde} %}
					{% %}
				%}				
				{%?($FILTER/@f_hasta!='')
					{% and TTA23_LICENCIAS_SEC.f_fin &lt;= {$FILTER/@f_hasta} %}
					{% %}
				%}
				{%?($FILTER/@l_current_user=1)
					{% and TTA23_LICENCIAS_SEC.d_user_crea = {$PROXY/@ETTY} %}
					{% %}
				%}				
				{%?($FILTER/@f_desde='' and $FILTER/@f_hasta='')
					{% and TTA23_LICENCIAS_SEC.f_inicio &gt;= f_inicio_desde %}
					{% %}
				%}				
				
			{%?($FILTER/@order!='')
			  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc')%} %}
			  {% order by f_inicio desc %}
			%}				
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST" declare="&lt;PARAM IDS=&quot;31&quot;/&gt;">
			<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
			<qry:include name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.INFO"/>
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('
			
			SELECT				 
			  TTA23_LICENCIAS_SEC.oi_licencia_sec,
			  PER02_PERSONAL_EMP.oi_empresa,
			  TTA23_LICENCIAS_SEC.oi_personal_emp,
			  PER16_LICENCIAS.oi_licencia,
			  PER16_LICENCIAS.c_licencia as c_licencia,
  			PER16_LICENCIAS.d_licencia as d_licencia,
			  TTA23_LICENCIAS_SEC.f_inicio,
			  TTA23_LICENCIAS_SEC.f_fin,
			  TTA23_LICENCIAS_SEC.e_cant_dias,
				TTA23_LICENCIAS_SEC.e_anio_corresp,
				TTA23_LICENCIAS_SEC.o_licencia,
			  TTA23_LICENCIAS_SEC.d_user_crea,
			  TTA22_LICENCIAS_ROL.l_eliminar_1,
			  TTA22_LICENCIAS_ROL.l_eliminar_2,
			  TTA23_LICENCIAS_SEC.oi_licencia_per
			  
			FROM				
  			TTA23_LICENCIAS_SEC,
  			PER02_PERSONAL_EMP,
  			TTA22_LICENCIAS_ROL,
  			PER16_LICENCIAS
  		
  		JOIN  			  			
  			TTA23_LICENCIAS_SEC.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
  			TTA23_LICENCIAS_SEC.oi_licencia_rol INNER TTA22_LICENCIAS_ROL.oi_licencia_rol,
  			TTA22_LICENCIAS_ROL.oi_licencia INNER PER16_LICENCIAS.oi_licencia
  			
			WHERE 
				TTA23_LICENCIAS_SEC.oi_licencia_sec in ({%=$PARAM/@IDS%})
				
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="id" value="$r/@oi_licencia_sec"/>
						<qry:element name="oi_empresa">
							<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
							<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+']'"/>
						<qry:element name="oi_personal_emp">
							<qry:attribute name="OI_FIND" value="$r/@oi_personal_emp"/>
							<qry:insert-select name="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP.QUERY" doc-path="."/>
						</qry:element>
						<qry:attribute name="oi_personal_emp" value="'['+oi_personal_emp/ROW/@COD+'] '+oi_personal_emp/ROW/@DES"/>
						<qry:attribute name="oi_licencia" value="'['+$r/@c_licencia+'] '+$r/@d_licencia"/>
						<qry:attribute name="f_inicio" value="$r/@f_inicio"/>
						<qry:attribute name="f_fin" value="$r/@f_fin"/>
						<qry:attribute name="d_user_crea" value="$r/@d_user_crea"/>
						<qry:attribute name="l_eliminar_1" value="$r/@l_eliminar_1"/>
						<qry:attribute name="l_eliminar_2" value="$r/@l_eliminar_2"/>
						<qry:attribute name="color" value="'E50000'"/>
						<qry:insert-select name="BuscarLicPer" doc-path="$r"/>
					</ROW>
				</qry:out>
			</qry:select>
			<qry:select name="BuscarLicPer" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
				SELECT
					PER02_LICEN_PER.oi_licencia,
					PER02_LICEN_PER.f_inicio,
					PER02_LICEN_PER.f_fin,
					PER02_LICEN_PER.e_cant_dias,
					PER02_LICEN_PER.e_anio_corresp,
					PER02_LICEN_PER.o_licencia_per
				
				FROM
					PER02_LICEN_PER
				
				WHERE
					PER02_LICEN_PER.oi_licencia_per = {$PARAM/@oi_licencia_per}			
			
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="color" value="'FFD800'"/>
					<qry:if test="$r/@oi_licencia = $PARAM/@oi_licencia">
						<qry:then>
							<qry:if test="$r/@f_inicio = $PARAM/@f_inicio">
								<qry:then>
									<qry:if test="$r/@f_fin = $PARAM/@f_fin">
										<qry:then>
											<qry:if test="$r/@e_cant_dias = $PARAM/@e_cant_dias">
												<qry:then>
													<qry:if test="$r/@e_anio_corresp = $PARAM/@e_anio_corresp">
														<qry:then>
															<qry:if test="$r/@o_licencia_per = $PARAM/@o_licencia">
																<qry:then>
																	<qry:attribute name="color" value="'3FBF00'"/>
																</qry:then>
															</qry:if>
														</qry:then>
													</qry:if>
												</qry:then>
											</qry:if>
										</qry:then>
									</qry:if>
								</qry:then>
							</qry:if>
						</qry:then>
					</qry:if>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
