<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Tiempos_Trabajados" root-class="FICHADASING" languaje="SP" meta-class="DB" name="ERTInterfaceFichadas">
	<class description="FichadasIngresadas" access="direct" name="FICHADASING">
		<meta-properties>
			<interface-properties file="regist.dat" mode="0" enter="1"/>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" name="id" OriginalName="oi_fichadasing">
			<meta-properties/>
		</attribute>
		<attribute length="15" type="Nomad.NSystem.String" name="legajo" OriginalName="c_personal">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="dia" type="Nomad.NSystem.String" OriginalName="f_fecha" length="2">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="mes" type="Nomad.NSystem.String" OriginalName="f_fecha" length="2">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="ano" type="Nomad.NSystem.String" OriginalName="f_fecha" length="2">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="hora" type="Nomad.NSystem.String" length="4">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="sentido" type="Nomad.NSystem.String" OriginalName="f_fecha" length="1">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="funcion" type="Nomad.NSystem.String" OriginalName="f_fecha" length="2">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute name="reloj" type="Nomad.NSystem.String" OriginalName="f_fecha" length="3">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ImportarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.Base.Tiempos_Trabajados.SRFInterfaceFichadas.FICHADASING" type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.Int" pass="byval" name="oi_terminal"/>
			</arguments>
		</method>
		<resource name="qry_fichadas">
			<qry:main>
				<qry:insert-select name="sql1"/>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:regist.dat')/ROWS
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
