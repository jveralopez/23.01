<class-package xmlns:qry="nomad_engine.qry" name="Fichadas_NI" root-class="Fichadas_NI" meta-class="DB" languaje="SP">
	<class attr-desc="legajoReloj" attr-code="legajoReloj" description="Fichadas" label="Fichada" name="Fichadas_NI" access="direct">
		<meta-properties>
			<db-properties table="TTA99_Fichadas_NI" desc-column="legajoReloj" code-column="legajoReloj" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version">
				<security table="NMD_SECURITY"/>
			</db-properties>
		</meta-properties>
		<attribute null="false" readonly="false" default="" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_fichada">
			<meta-properties>
				<db-properties updatable="false" insertable="true" tracking-changes="no" versionable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_fichada"/>
			</meta-properties>
		</attribute>
		<attribute label="Legajo Reloj" name="legajoReloj" null="false" readonly="false" default="" type="Nomad.NSystem.Int" OriginalName="legajoReloj">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="legajoReloj"/>
			</meta-properties>
		</attribute>
		<attribute label="Fecha Hora" name="fechaHora" type="Nomad.NSystem.DateTime" null="false" readonly="false" default="" OriginalName="fechaHora">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="fechaHora" patern="YYYYMMDDHHMMSS"/>
			</meta-properties>
		</attribute>
		<attribute length="30" type="Nomad.NSystem.String" label="Terminal" name="terminal" null="false" readonly="false" default="" OriginalName="terminal">
			<meta-properties>
				<db-properties type="varchar(30)" column="terminal" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false"/>
			</meta-properties>
		</attribute>
		<attribute label="Tipo Evento" name="tipoEvento" null="false" readonly="false" default="" length="1" type="Nomad.NSystem.String" OriginalName="tipoEvento">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(1)" column="tipoEvento"/>
			</meta-properties>
		</attribute>
		<attribute length="1" default="" null="false" label="Leido Nucleus" readonly="false" type="Nomad.NSystem.String" name="leidoNucleus">
			<meta-properties>
				<db-properties nullable="false" type="varchar(1)" tracking-changes="yes" generator="none" unique="false" updatable="true" insertable="true" versionable="true" id="false" column="leidoNucleus"/>
			</meta-properties>
		</attribute>
		<attribute length="1000" name="observaciones" default="" null="true" label="Observaciones" readonly="false" type="Nomad.NSystem.String">
			<meta-properties>
				<db-properties column="observaciones" type="varchar(1000)" nullable="true" tracking-changes="yes" generator="none" unique="false" updatable="true" insertable="true" versionable="true" id="false"/>
			</meta-properties>
		</attribute>
		<resource description="Recupera las fichadas que no estan procesadas" name="qry_fichadas">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="SQL" doc-path="."/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL" doc="PARAM">
				<qry:xquery>
					for $r in sql('
				
					MAXSIZE 40000
					SELECT 
						TTA99_Fichadas_NI.oi_fichada
					FROM
						TTA99_Fichadas_NI
					WHERE
						TTA99_Fichadas_NI.leidoNucleus = \'N\'
						
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@oi_fichada"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="qry_terminal" description="Recupera la terminal a partir de un codigo">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="SQL" doc-path="#SOURCE:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="SQL" doc="PARAM">
				<qry:xquery>
					for $r in sql('
						SELECT 
							TTA05_TERMINALES.oi_terminal
						FROM
							TTA05_TERMINALES
						WHERE
							TTA05_TERMINALES.c_terminal = {#PARAM:@c_terminal}
					')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="oi_terminal" value="$r/@oi_terminal"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<method description="Importa Fichadas a FichadasIng" modifier="static" access="public" name="ProcesarFichadas">
			<meta-properties>
				<dotnet11-properties class="NucleusRH.ASSARH.Tiempos_Trabajados.Fichadas_NI.Fichadas_NI" type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
	</class>
</class-package>
