<class-package xmlns:qry="nomad_engine.qry" root-class="NOVEDAD" name="Novedades" DDOBase="NucleusRH\Base\Portal_Empleado" languaje="SP" meta-class="DB">
	<class size="L" help="Registra las Novedades para ser visualizadas desde el Portal" description="Novedades del Portal" access="direct" label="Novedad" name="NOVEDAD">
		<meta-properties>
			<db-properties desc-column="d_novedad" code-column="oi_novedad" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="POR02_NOVEDADES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_novedades" code-attr="oi_novedad" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Portal_Empleado.Tipos_Novedades.TIPONOVEDAD.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_novedad as oi_novedad, t0.d_novedad as d_novedad, t0.f_fecha as f_fecha, t0.f_desde as f_desde, t0.f_hasta as f_hasta, t0.c_estado as c_estado, SEC.policy, t0.oi_novedad as CODE, t0.d_novedad as TEXT, t0.oi_tiponovedad as oi_tiponovedad, t0.oi_imagen_por as oi_imagen_por FROM POR02_NOVEDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD\') as SEC JOIN t0.oi_novedad LEFT OUTER SEC.id  ORDER BY oi_novedad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_novedad"/>
								<qry:attribute name="d_novedad" value="$r/@d_novedad"/>
								<qry:attribute name="f_fecha" value="$r/@f_fecha"/>
								<qry:attribute name="f_desde" value="$r/@f_desde"/>
								<qry:attribute name="f_hasta" value="$r/@f_hasta"/>
								<qry:attribute name="c_estado" value="$r/@c_estado"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tiponovedad!=''">
									<qry:then>
										<qry:element name="oi_tiponovedad">
											<qry:attribute name="OI_FIND" value="$r/@oi_tiponovedad"/>
											<qry:insert-select name="NucleusRH.Base.Portal_Empleado.Tipos_Novedades.TIPONOVEDAD.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tiponovedad" value="'['+oi_tiponovedad/ROW/@COD+'] '+oi_tiponovedad/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:attribute name="oi_imagen_por" value="$r/@oi_imagen_por"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_novedad as oi_novedad, SEC.policy FROM POR02_NOVEDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD\') as SEC JOIN t0.oi_novedad LEFT OUTER SEC.id  ORDER BY oi_novedad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_novedad"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_novedad" code-attr="oi_novedad" desc="d_novedades" code="oi_novedad" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_novedad">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_novedad"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de la novedad. Es utilizada en los reportes del portal como t&#237;tulo." label="Descripci&#243;n" name="d_novedad" OriginalName="d_novedad">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_novedad"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Portal_Empleado.Tipos_Novedades.TIPONOVEDAD" null="false" readonly="false" description="Tipo de novedad" type="aggregation" label="Tipo de Novedad" name="oi_tiponovedad" OriginalName="oi_tiponovedad">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_tiponovedad"/>
				<form-properties label="Tipo de Novedad" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tiponovedad"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Descripci&#243;n larga o contenido de la novedad." label="Contenido" name="o_contenido" OriginalName="o_contenido">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Contenido" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_contenido"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="substring(now(),0,8)" type="Nomad.NSystem.DateTime" description="Fecha de la novedad." label="Fecha" name="f_fecha" OriginalName="f_fecha">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_fecha"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="substring(now(),0,8)" type="Nomad.NSystem.DateTime" description="Fecha inicio en que la novedad tendr&#225; vigencia." label="Vigencia Desde" name="f_desde" OriginalName="f_desde">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Vigencia Desde" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_desde"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.DateTime" description="Fecha hasta en que la novedad tendr&#225; vigencia." label="Vigencia Hasta" name="f_hasta" OriginalName="f_hasta">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Vigencia Hasta" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="datetime" column="f_hasta"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="'A'" length="1" type="Nomad.NSystem.String" description="Estado de la novedad." label="Estado" name="c_estado" OriginalName="c_estado">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD.c_estado" show-list="true" find-include="true" automatico="1" label="Estado" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(1)" column="c_estado"/>
			</meta-properties>
		</attribute>
		<enum name="c_estado">
			<enum-value label="Activo" value="A"/>
			<enum-value label="Inactivo" value="I"/>
		</enum>
		<assosiation class="NucleusRH.Base.Portal_Empleado.Imagenes.HEAD" null="true" readonly="false" type="aggregation" label="Imagen Portal" name="oi_imagen_por" OriginalName="oi_imagen_por">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_imagen_por"/>
				<form-properties show-list="false" label="Imagen Portal" automatico="0" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_imagen_por"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  POR02_NOVEDADES.oi_novedad as ID,
  POR02_NOVEDADES.oi_novedad as COD,
  POR02_NOVEDADES.d_novedad as DES
from
  POR02_NOVEDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Portal_Empleado.Novedades.NOVEDAD.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(POR02_NOVEDADES.oi_novedad) as CNT
from
  POR02_NOVEDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and POR02_NOVEDADES.oi_novedad={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(POR02_NOVEDADES.d_novedad,{#SOURCE:@TXT_FIND}) or contain(POR02_NOVEDADES.oi_novedad,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
