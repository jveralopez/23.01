					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_proceso as oi_proceso, SEC.policy FROM QYR13_PROCESOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Procesos.PROCESO\') as SEC JOIN t0.oi_proceso LEFT OUTER SEC.id  ORDER BY oi_proceso asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_proceso"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_proceso" code-attr="c_proceso" desc="d_procesos" code="c_procesos" automatico="1"/>
		</meta-properties>
