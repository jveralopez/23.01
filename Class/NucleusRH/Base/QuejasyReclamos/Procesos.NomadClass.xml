<class-package xmlns:qry="nomad_engine.qry" root-class="PROCESO" name="Procesos" meta-class="DB" languaje="SP">
	<class size="M" description="Procesos" access="direct" label="Proceso" name="PROCESO">
		<meta-properties>
			<db-properties desc-column="d_proceso" code-column="c_proceso" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="QYR13_PROCESOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_procesos" code-attr="c_procesos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_proceso as oi_proceso, t0.c_proceso as c_proceso, t0.d_proceso as d_proceso, SEC.policy, t0.c_proceso as CODE, t0.d_proceso as TEXT FROM QYR13_PROCESOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Procesos.PROCESO\') as SEC JOIN t0.oi_proceso LEFT OUTER SEC.id  ORDER BY oi_proceso asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_proceso"/>
								<qry:attribute name="c_proceso" value="$r/@c_proceso"/>
								<qry:attribute name="d_proceso" value="$r/@d_proceso"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
