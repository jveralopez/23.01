<class-package xmlns:qry="nomad_engine.qry" root-class="SOLUCION" name="Soluciones" meta-class="DB" languaje="SP">
	<class size="L" description="Soluciones" access="direct" label="Solucion" name="SOLUCION">
		<meta-properties>
			<db-properties desc-column="oi_solucion" code-column="oi_solucion" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="QYR03_SOLUCIONES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="oi_solucion" code-attr="oi_solucion" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_solucion as oi_solucion, t0.f_solucion as f_solucion, t0.l_vigente as l_vigente, SEC.policy, t0.oi_solucion as CODE, t0.oi_solucion as TEXT, t0.oi_tipo_problema as oi_tipo_problema FROM QYR03_SOLUCIONES as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION\') as SEC JOIN t0.oi_solucion LEFT OUTER SEC.id  ORDER BY oi_solucion asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_solucion"/>
								<qry:attribute name="f_solucion" value="$r/@f_solucion"/>
								<qry:attribute name="l_vigente" value="iif($r/@l_vigente='1','1','0')"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_tipo_problema!=''">
									<qry:then>
										<qry:element name="oi_tipo_problema">
											<qry:attribute name="OI_FIND" value="$r/@oi_tipo_problema"/>
											<qry:insert-select name="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tipo_problema" value="'['+oi_tipo_problema/ROW/@COD+'] '+oi_tipo_problema/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_solucion as oi_solucion, SEC.policy FROM QYR03_SOLUCIONES as t0,NMD_SECURITY(class=\'NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION\') as SEC JOIN t0.oi_solucion LEFT OUTER SEC.id  ORDER BY oi_solucion asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_solucion"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="oi_solucion" code-attr="oi_solucion" desc="oi_solucion" code="oi_solucion" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_solucion">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_solucion"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.QuejasyReclamos.Tipo_Problema.TIPO_PROBLEMA" null="false" readonly="false" type="aggregation" label="Tipo Problema" name="oi_tipo_problema" OriginalName="oi_tipo_problema">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_tipo_problema"/>
				<form-properties label="Tipo Problema" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tipo_problema"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha de Carga" name="f_solucion" OriginalName="f_solucion">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha de Carga" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_solucion"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="Texto" name="t_solucion" OriginalName="t_solucion">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Texto" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(4000)" column="t_solucion"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Vigente" name="l_vigente" OriginalName="l_vigente">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Vigente" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_vigente"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  QYR03_SOLUCIONES.oi_solucion as ID,
  QYR03_SOLUCIONES.oi_solucion as COD,
  QYR03_SOLUCIONES.oi_solucion as DES
from
  QYR03_SOLUCIONES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.QuejasyReclamos.Soluciones.SOLUCION.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(QYR03_SOLUCIONES.oi_solucion) as CNT
from
  QYR03_SOLUCIONES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and QYR03_SOLUCIONES.oi_solucion={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(QYR03_SOLUCIONES.oi_solucion,{#SOURCE:@TXT_FIND}) or contain(QYR03_SOLUCIONES.oi_solucion,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
