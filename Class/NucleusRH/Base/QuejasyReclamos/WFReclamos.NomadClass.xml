		<resource name="QRY_LEGAJOS">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select doc-path="" name="sql1"/>
					<!--qry:element name="NUEVAS"-->
					<qry:insert-select doc-path="." name="OFICINAS_INACT"/>
					<!--/qry:element-->
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG02_CLASES_ORG.oi_estructura_org as oi_estructura
				FROM 
					ORG02_CLASES_ORG
				WHERE 
					ORG02_CLASES_ORG.c_clase_org = \'QYR\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="sql3"/>
					<qry:insert-select doc-path="$r" name="sql2"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql2" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG02_ESTRUCTURAS.oi_estructura as oi_estructura
				FROM ORG02_ESTRUCTURAS
				WHERE ORG02_ESTRUCTURAS.oi_estr_padre = {#SOURCE:@oi_estructura}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select doc-path="$r" name="sql3"/>
					<qry:insert-select doc-path="$r" name="sql2"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql3" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT  
					ORG03_EMPRESAS.d_empresa,
					ORG03_EMPRESAS.c_empresa,
					PER01_PERSONAL.d_ape_y_nom,
					PER02_PERSONAL_EMP.e_numero_legajo,
					PER02_PERSONAL_EMP.oi_ubicacion,
					PER01_PERSONAL.oi_usuario_sistema,
					ORG01_UNI_ORG.oi_unidad_org,
					ORG01_UNI_ORG.d_unidad_org,
					ORG02_ESTRUC_PERS.l_responsable,
					ORG02_ESTRUCTURAS.oi_estructura,
					PER02_PERSONAL_EMP.oi_personal_emp
				FROM 
					ORG02_ESTRUC_PERS, 
					ORG02_ESTRUCTURAS, 
					ORG01_UNI_ORG, 
					PER02_PERSONAL_EMP, 
					PER01_PERSONAL, 
					ORG03_EMPRESAS
				JOIN
					PER02_PERSONAL_EMP.oi_personal_emp INNER ORG02_ESTRUC_PERS.oi_personal_emp
					,PER01_PERSONAL.oi_personal INNER PER02_PERSONAL_EMP.oi_personal
					,ORG03_EMPRESAS.oi_empresa INNER PER02_PERSONAL_EMP.oi_empresa
					,ORG02_ESTRUC_PERS.oi_estructura INNER ORG02_ESTRUCTURAS.oi_estructura
					,ORG02_ESTRUCTURAS.oi_unidad_org INNER ORG01_UNI_ORG.oi_unidad_org
				WHERE 
					ORG02_ESTRUC_PERS.oi_estructura = {#SOURCE:@oi_estructura}
					AND PER01_PERSONAL.oi_usuario_sistema != \'\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="LEGAJOS">
						<qry:attribute name="e_numero_legajo" value="$r/@e_numero_legajo"/>
						<qry:attribute name="d_usuario" value="$r/@oi_usuario_sistema"/>
						<qry:attribute name="l_responsable" value="$r/@l_responsable"/>
						<qry:attribute name="c_oficina" value="$r/@oi_estructura+'_'+$r/@oi_personal_emp+'_'+$r/@oi_unidad_org"/>
						<qry:attribute name="oi_ubicacion" value="$r/@oi_ubicacion"/>
						<qry:attribute name="d_ape_y_nom" value="iif($r/@l_responsable=0,$r/@d_ape_y_nom+' ('+$r/@c_empresa+'_'+$r/@d_empresa+')',$r/@d_unidad_org +'_'+$r/@d_ape_y_nom + ' ('+$r/@c_empresa+'_'+$r/@d_empresa+') ')"/>
						<qry:attribute name="oi_estruc_pers" value="$r/@oi_estruc_pers"/>
						<qry:attribute name="oi_oficina" value="'0'"/>
						<qry:insert-select doc-path="." name="sql4"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="sql4" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT  
					QYR08_OFICINAS.oi_oficina,
					QYR08_OFICINAS.l_inactiva
				FROM 
					QYR08_OFICINAS
				WHERE 
					QYR08_OFICINAS.c_oficina = {#SOURCE:@c_oficina} 
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_oficina" value="iif($r/@oi_oficina='','0',$r/@oi_oficina)"/>
					<qry:attribute name="l_inactiva" value="$r/@l_inactiva"/>
				</qry:out>
			</qry:select>
			<qry:select name="OFICINAS_INACT" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT  
					QYR08_OFICINAS.oi_oficina,
					QYR08_OFICINAS.c_oficina,
					QYR08_OFICINAS.l_inactiva,
					PER01_PERSONAL.oi_usuario_sistema
				FROM 
					QYR08_OFICINAS,
					ORG02_ESTRUCTURAS,
					ORG02_ESTRUC_PERS,
					PER02_PERSONAL_EMP,
					PER01_PERSONAL
				JOIN
					QYR08_OFICINAS.oi_unidad_org INNER ORG02_ESTRUCTURAS.oi_unidad_org,
					ORG02_ESTRUCTURAS.oi_estructura INNER ORG02_ESTRUC_PERS.oi_estructura,
					ORG02_ESTRUC_PERS.oi_personal_emp INNER PER02_PERSONAL_EMP.oi_personal_emp,
					PER02_PERSONAL_EMP.oi_personal INNER PER01_PERSONAL.oi_personal
				WHERE 
					QYR08_OFICINAS.oi_oficina NOT IN ({%=string(#SOURCE:LEGAJOS/@oi_oficina)%})
					AND QYR08_OFICINAS.l_inactiva = 0
					AND PER01_PERSONAL.oi_usuario_sistema != \'\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="OFICINA_NEW">
						<qry:attribute name="oi_oficina" value="$r/@oi_oficina"/>
						<qry:attribute name="d_usuario" value="$r/@oi_usuario_sistema"/>
						<qry:attribute name="c_oficina" value="$r/@c_oficina"/>
						<qry:insert-select doc-path="$r" name="sql4"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
	</class>
