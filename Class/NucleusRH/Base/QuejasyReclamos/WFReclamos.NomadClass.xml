		<resource description="Devuelve los ids de las instancias del WF de QYR y los oi_reclamo" name="getIdsInstancias">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in FS('./NOMAD/DB/NOMAD/BASE/WORKFLOW/WORKFLOWINSTANCIAS')/LIST/FILE[STARTS_WITH(@name, #PROXY:@app+'.NucleusRH.Base.QuejasyReclamos.Reclamo')]
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="name" value="$r/@name"/>
						<qry:insert-select name="sql2" doc-path="$r"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select name="sql2" doc="SOURCE">
				<qry:xquery>
					for $r in FILE('Nomad\\Base\\Workflow\\WorkflowInstancias\\{%=#SOURCE:@name%}')/WFI
				</qry:xquery>
				<qry:out>
					<qry:attribute name="id" value="$r/@id"/>
					<qry:attribute name="oi_reclamo" value="$r/DATOS/RECLAMO/@oi_reclamo"/>
				</qry:out>
			</qry:select>
		</resource>
		<method modifier="static" access="public" label="Cierre automatico del reclamo" name="CierreAuto">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments/>
		</method>
		<resource description="Devuelve la cantidad de dias necesarios para que los reclamos se cierren automaticamente" name="getParametro">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					ORG26_PARAMETROS.d_valor 
				FROM 
					ORG26_PARAMETROS
				WHERE 
					ORG26_PARAMETROS.c_modulo = \'QYR\' AND 
					ORG26_PARAMETROS.c_parametro = \'CIERRE_AUTO\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="d_valor" value="$r/@d_valor"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource description="Devuelve la cantidad de dias necesarios para que los reclamos se cierren automaticamente" name="getReclamos">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in sql('
				SELECT 
					QYR01_RECLAMOS.oi_reclamo,
					QYR01_RECLAMOS.n_historico,
					QYR01_HISTORICOS.f_reclamo
				FROM 
					QYR01_RECLAMOS,
					QYR01_HISTORICOS
				JOIN
					QYR01_RECLAMOS.oi_reclamo INNER QYR01_HISTORICOS.oi_reclamo
				WHERE 
					QYR01_RECLAMOS.n_historico = QYR01_HISTORICOS.n_historico AND
					QYR01_RECLAMOS.c_estado = \'En espera de conformidad\'
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="oi_reclamo" value="$r/@oi_reclamo"/>
						<qry:attribute name="n_historico" value="$r/@n_historico"/>
						<qry:attribute name="f_reclamo" value="$r/@f_reclamo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<method name="Sincronizar" modifier="static" access="public" label="Sincronizar las oficinas">
			<meta-properties>
