{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  QYR07_PROVEEDORES.oi_proveedor as ID,
  QYR07_PROVEEDORES.c_proveedor as COD,
