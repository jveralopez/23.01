{%? (#SOURCE:@OI_FIND='') {% %} {% and QYR07_PROVEEDORES.oi_proveedor={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(QYR07_PROVEEDORES.d_proveedor,{#SOURCE:@TXT_FIND}) or contain(QYR07_PROVEEDORES.c_proveedor,{#SOURCE:@TXT_FIND})) %} %} 
