		<method note="Este m&#233;todo se definio en esta clase, ya que se requiere poder obtener las solicitudes de vacaciones de un legajo y no pueden generarse controladores en una clase extendida (el lugar ideal ser&#237;a situarlo en LegajoVacaciones.PERSONAL_EMP)" name="GetVacaciones" return-class="System.Collections.Generic.SortedList&lt;string,object&gt;" return-type="Nomad.NSystem.Object" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="PAR" type="Nomad.NSystem.Int" pass="byval"/>
				<argument name="dias_prev" type="Nomad.NSystem.Int" pass="byval"/>
				<argument name="dias_post" type="Nomad.NSystem.Int" pass="byval"/>
			</arguments>
			<controller name="MATRIZ_VAC.GetVacaciones" login="0"/>
		</method>
		<resource include="true" declare="&lt;PARAM oi_personal_emp=&quot;1429&quot; dias_prev=&quot;365&quot; dias_post=&quot;0&quot;/&gt;" name="GET_SOL">
			<qry:main doc="PARAM">
				<qry:append-doc name="FILTER" doc-path="#PARAM:."/>
				<qry:element name="ROWS">
					<qry:attribute name="OI" value="'int'"/>
					<qry:attribute name="f_desde_solicitud" value="'datetime'"/>
					<qry:attribute name="f_hasta_solicitud" value="'datetime'"/>
					<qry:attribute name="DIAS" value="'int'"/>
					<qry:attribute name="ESTADO" value="'string'"/>
					<qry:attribute name="fi" value="now-date() - #PARAM:./@dias_prev"/>
					<qry:attribute name="ff" value="now-date() + #PARAM:./@dias_post"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT     
					SOL.oi_solicitud as oi_solicitud,
					SOL.f_desde_solicitud as f_desde_solicitud,
					SOL.f_hasta_solicitud as f_hasta_solicitud,
					SOL.e_dias_solicitud as e_dias_solicitud,
					EST.d_estado_solic as d_estado_solic                       
				FROM
					VAC01_SOLICITUDES as SOL,  
					VAC02_ESTADOS_SOL as EST
				JOIN
					EST.oi_estado_solic INNER SOL.oi_estado_solic
				WHERE    
					SOL.oi_personal_emp = {#PARAM:@oi_personal_emp}    
					AND (SOL.f_desde_solicitud &gt;= {Datetime(#PARAM:@fi)}
					OR SOL.f_hasta_solicitud &lt;= {Datetime(#PARAM:@ff)})
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="OI" value="$r/@oi_solicitud"/>
						<qry:attribute name="f_desde_solicitud" value="$r/@f_desde_solicitud"/>
						<qry:attribute name="f_hasta_solicitud" value="$r/@f_hasta_solicitud"/>
						<qry:attribute name="DIAS" value="$r/@e_dias_solicitud"/>
						<qry:attribute name="ESTADO" value="$r/@d_estado_solic"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="GET_SALDO" declare="&lt;PARAM oi_personal_emp=&quot;1429&quot; dias_prev=&quot;365&quot; dias_post=&quot;0&quot;/&gt;">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="SALDO" value="'int'"/>
