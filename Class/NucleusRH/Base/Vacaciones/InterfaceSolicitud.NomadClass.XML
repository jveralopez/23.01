<class-package xmlns:qry="nomad_engine.qry" root-class="SOLICITUD" name="InterfaceSolicitud" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Vacaciones">
	<class label="Definici&#243;n de la interfaz de Solicitud de Vacaciones" description="Definici&#243;n de la interfaz de Solicitudes de Vaciones" name="SOLICITUD" access="direct">
		<meta-properties>
			<interface-properties file="solicitudes.dat" separator=";" mode="1" enter="1" separador=";" decimal="." escape="\"/>
		</meta-properties>
		<attribute name="e_numero_legajo" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="N&#250;mero de Legajo" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="10" label="Fecha Desde Solicitud" name="f_desde_solicitud" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_ingreso">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute length="10" name="f_hasta_solicitud" label="Fecha Hasta Solicitud" null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" OriginalName="f_ingreso">
			<meta-properties>
				<interface-properties mask="dd/mm/yyyy"/>
			</meta-properties>
		</attribute>
		<attribute length="100" name="d_motivo_solic" null="true" readonly="false" default="''" type="Nomad.NSystem.String" label="Motivo" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<attribute length="1000" name="o_solicitud" label="Observacion" null="true" readonly="false" default="''" type="Nomad.NSystem.String" OriginalName="c_empresa">
			<meta-properties>
				<interface-properties/>
			</meta-properties>
		</attribute>
		<resource name="QRY_OIArchivo">
			<qry:main>
				<qry:element name="ROWS">
					<qry:insert-select name="sql1"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in INTERFACE('GET_PTR:solicitudes.dat')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-element doc-path="$r"/>
				</qry:out>
			</qry:select>
		</resource>
		<method name="Importar" description="Importar Solicitudes de Vacaciones" modifier="static" access="public">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument type="Nomad.NSystem.String" pass="byval" name="oi_empresa"/>
			</arguments>
		</method>
	</class>
</class-package>
