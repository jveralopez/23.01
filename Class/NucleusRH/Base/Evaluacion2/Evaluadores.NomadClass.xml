<class-package xmlns:qry="nomad_engine.qry" name="Evaluadores" meta-class="DB" languaje="SP" root-class="EVALUADOR360" DDOBase="NucleusRH\Base\Evaluacion2">
	<class size="S" attr-desc="id" attr-code="id" description="Evaluadores" label="Evaluador" name="EVALUADOR360">
		<meta-properties>
			<db-properties desc-column="oi_evaluador360" code-column="oi_evaluador360" access-mode="new-edit-delete" generate="true" optimistic-lock="version" table="EDD06_EVALUADORES">
				<security table="NMD_SECURITY"/>
			</db-properties>
		</meta-properties>
		<attribute type="Nomad.NSystem.Int" null="false" readonly="true" inList="false" description="Clave Unica de la Clase" label="Id" name="id">
			<meta-properties>
				<db-properties generator="secuence" updatable="false" insertable="true" nullable="false" unique="true" id="true" type="int" column="oi_evaluador360"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" inList="true" null="false" readonly="false" type="aggregation" label="Legajo" name="oi_personal_emp">
			<meta-properties>
				<db-properties type="int" cascade="none" not-found="exception" updatable="true" insertable="true" nullable="false" unique="false" from-column="oi_personal_emp"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_personal_emp"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" inList="true" null="false" readonly="false" type="aggregation" label="Evaluador" name="oi_evaluador">
			<meta-properties>
				<db-properties type="int" cascade="none" not-found="exception" updatable="true" insertable="true" nullable="false" unique="false" from-column="oi_evaluador"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_personal_emp"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Evaluacion2.Roles.ROL" inList="true" null="false" readonly="false" type="aggregation" label="Rol" name="oi_rol">
			<meta-properties>
				<db-properties type="int" cascade="none" not-found="exception" updatable="true" insertable="true" nullable="false" unique="false" from-column="oi_rol"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_rol"/>
			</multiplicity>
		</assosiation>
		<attribute inList="false" default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="yes" name="AK_EDD06_EVALUADORES">
			<key-attr assosiation="no" name="oi_personal_emp"/>
			<key-attr assosiation="no" name="oi_evaluador"/>
		</key>
		<method modifier="static" access="public" label="Guardar" name="Guardar">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="datos"/>
			</arguments>
		</method>
		<resource declare="&lt;FILTRO oi_personal_emp=&quot;11581&quot; /&gt;" include="true" name="qry_evaluadores">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:insert-select name="qry1" doc-path="#PARAM:FILTRO"/>
				</qry:element>
			</qry:main>
			<qry:select name="qry1" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
SELECT e.oi_evaluador360, e.oi_evaluador, e.oi_rol
FROM EDD06_EVALUADORES as e
WHERE e.oi_personal_emp = {$PARAM/@oi_personal_emp}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="id" value="$r/@oi_evaluador360"/>
						<qry:attribute name="oi_evaluador" value="$r/@oi_evaluador"/>
						<qry:attribute name="oi_rol" value="$r/@oi_rol"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
