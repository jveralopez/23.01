<class-package xmlns:qry="nomad_engine.qry" name="Elementos_Proteccion_Personal" meta-class="DB" languaje="SP" root-class="ELEMENTO_PP" DDOBase="NucleusRH\Base\Organizacion">
	<class size="L" help="Tabla codificadora de Elementos de Protecci&#243;n Personal, en donde se registrar&#225; para cada uno el C&#243;digo, la Descripci&#243;n, el Costo estimado y Observaciones." description="Elementos de Protecci&#243;n Personal" access="direct" label="Elemento Protecci&#243;n Personal" name="ELEMENTO_PP">
		<meta-properties>
			<db-properties desc-column="d_elemento_pp" code-column="c_elemento_pp" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG07_ELEMENTOS_PP">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_elementos_pp" code-attr="c_elementos_pp" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Unidades_de_Tiempo.UNIDAD_TIEMPO.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_elemento_pp as oi_elemento_pp, t0.c_elemento_pp as c_elemento_pp, t0.d_elemento_pp as d_elemento_pp, t0.e_duracion as e_duracion, t0.n_valor as n_valor, SEC.policy, t0.c_elemento_pp as CODE, t0.d_elemento_pp as TEXT, t0.oi_unidad_tiempo as oi_unidad_tiempo FROM ORG07_ELEMENTOS_PP as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP\') as SEC JOIN t0.oi_elemento_pp LEFT OUTER SEC.id  ORDER BY oi_elemento_pp asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_elemento_pp"/>
								<qry:attribute name="c_elemento_pp" value="$r/@c_elemento_pp"/>
								<qry:attribute name="d_elemento_pp" value="$r/@d_elemento_pp"/>
								<qry:attribute name="e_duracion" value="$r/@e_duracion"/>
								<qry:attribute name="n_valor" value="$r/@n_valor"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_unidad_tiempo!=''">
									<qry:then>
										<qry:element name="oi_unidad_tiempo">
											<qry:attribute name="OI_FIND" value="$r/@oi_unidad_tiempo"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Unidades_de_Tiempo.UNIDAD_TIEMPO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_unidad_tiempo" value="'['+oi_unidad_tiempo/ROW/@COD+'] '+oi_unidad_tiempo/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_elemento_pp as oi_elemento_pp, SEC.policy FROM ORG07_ELEMENTOS_PP as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP\') as SEC JOIN t0.oi_elemento_pp LEFT OUTER SEC.id  ORDER BY oi_elemento_pp asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_elemento_pp"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_elementos_pp" code="c_elementos_pp" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.autoflow:initialize" desc-attr="d_elemento_pp" code-attr="c_elemento_pp" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_elemento_pp">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_elemento_pp"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo del Elemento de Protecci&#243;n Personal. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_elemento_pp" OriginalName="c_elemento_pp">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_elemento_pp"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n del Elemento de Protecci&#243;n Personal. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_elemento_pp" OriginalName="d_elemento_pp">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_elemento_pp"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" type="Nomad.NSystem.Int" label="Duraci&#243;n" name="e_duracion" OriginalName="e_duracion">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Duraci&#243;n" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="int" column="e_duracion"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Unidades_de_Tiempo.UNIDAD_TIEMPO" null="true" readonly="false" type="aggregation" label="Unidad Tiempo" name="oi_unidad_tiempo" OriginalName="oi_unidad_tiempo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_unidad_tiempo"/>
				<form-properties label="Unidad Tiempo" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_unidad_tiempo"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" description="Costo estimado del Elemento de Protecci&#243;n Personal." label="Valor" name="n_valor" OriginalName="n_valor">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Valor" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="numeric(11,3)" column="n_valor"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="'0'" type="Nomad.NSystem.Int" description="Registra la cantidad total a partir de la cual se calcula el stock de EPP en base a los que han sido entregados" label="Cantidad Total" name="e_cant_total" OriginalName="e_cant_total">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="int" column="e_cant_total"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Elemento de Protecci&#243;n Personal. Puede ser un alfanum&#233;rico de hasta 1000 caracteres." label="Observaciones" name="o_elemento_pp" OriginalName="o_elemento_pp">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_elemento_pp"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_ELEMENTOS_PP" name="AK1_ORG_ELEMENTOS_PP">
			<key-attr assosiation="no" name="c_elemento_pp"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG07_ELEMENTOS_PP.oi_elemento_pp as ID,
  ORG07_ELEMENTOS_PP.c_elemento_pp as COD,
  ORG07_ELEMENTOS_PP.d_elemento_pp as DES
from
  ORG07_ELEMENTOS_PP
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Elementos_Proteccion_Personal.ELEMENTO_PP.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG07_ELEMENTOS_PP.oi_elemento_pp) as CNT
from
  ORG07_ELEMENTOS_PP
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG07_ELEMENTOS_PP.oi_elemento_pp={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG07_ELEMENTOS_PP.d_elemento_pp,{#SOURCE:@TXT_FIND}) or contain(ORG07_ELEMENTOS_PP.c_elemento_pp,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<policy name="REPORT" label="Ejecuci&#243;n de Reportes"/>
	</class>
</class-package>
