<class-package xmlns:qry="nomad_engine.qry" root-class="ESTRUC_PERS_AUX" name="Estructuras2" meta-class="DB" languaje="SP" DDOBase="NucleusRH\Base\Organizacion">
	<class name="ESTRUC_PERS_AUX" label="Estructura Personas" size="M" help="Guarda las personas asignadas a una Estructura Organizativa (Un determinado nodo del Organigrama)." description="Personal Asignado" access="direct">
		<meta-properties>
			<db-properties generate="false" desc-column="oi_personal_emp" code-column="oi_personal_emp" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="dirty" table="ORG02_ESTRUC_PERS"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_estruc_pers">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_estruc_pers"/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Int" class="NucleusRH.Base.Personal.LegajoEmpresa.PERSONAL_EMP" null="false" readonly="false" label="Empresa - Legajo" name="oi_personal_emp" OriginalName="oi_personal_emp">
			<meta-properties>
				<db-properties nullable="false" generator="none" unique="false" tracking-changes="yes" insertable="true" updatable="true" versionable="true" id="false" type="int" column="oi_personal_emp"/>
			</meta-properties>
		</attribute>
		<attribute type="Nomad.NSystem.Int" class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG" null="true" readonly="false" label="Organigrama" name="oi_clase_org" OriginalName="oi_clase_org">
			<meta-properties>
				<db-properties nullable="false" generator="none" unique="false" tracking-changes="yes" insertable="true" updatable="true" versionable="true" id="false" type="int" column="oi_clase_org"/>
			</meta-properties>
		</attribute>
		<attribute ParentJoin="ORG02_ESTRUCTURAS.oi_estructura" ParentId="1" null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Estructura Organizativa" name="oi_estructura" OriginalName="oi_estructura">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="oi_estructura"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Responsable" name="l_responsable" OriginalName="l_responsable">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_responsable"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="0" type="Nomad.NSystem.Boolean" label="Staff" name="l_staff" OriginalName="l_staff">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="smallint" column="l_staff"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;PARAM oi_clase_org=&quot;1&quot; oi_estructura=&quot;11&quot; oi_personal_emp=&quot;235&quot; /&gt;&#13;&#10;&#13;&#10;" description="Retorna el OI de la estructura_pers correspondiente a una estructura y un legajo, para una clase." name="QRY_ID_ESTRUCTURA_PERS">
			<qry:main doc="PARAM">
				<qry:element name="ESTRUC_PERS">
					<qry:insert-select name="qryEstrucPers" doc-path="#PARAM:PARAM"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryEstrucPers" doc="PARAM">
				<qry:xquery>
					for $f in sql('

				SELECT 
					ep.oi_estruc_pers,
					ep.l_responsable,
					ep.l_staff
				FROM 
					ORG02_ESTRUC_PERS as ep
				WHERE 
					ep.oi_clase_org = {#PARAM:@oi_clase_org} 
					AND ep.oi_estructura = {#PARAM:@oi_estructura} 
					AND ep.oi_personal_emp = {#PARAM:@oi_personal_emp} 
			
            ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="oi_estruc_pers" value="$f/@oi_estruc_pers"/>
					<qry:attribute name="l_responsable" value="$f/@l_responsable"/>
					<qry:attribute name="l_staff" value="$f/@l_staff"/>
					<qry:attribute name="oi_clase_org" value="#PARAM:@oi_clase_org"/>
					<qry:attribute name="oi_estructura" value="#PARAM:@oi_estructura"/>
					<qry:attribute name="oi_personal_emp" value="#PARAM:@oi_personal_emp"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
