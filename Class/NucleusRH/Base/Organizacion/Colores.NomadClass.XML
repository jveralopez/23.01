<class-package xmlns:qry="nomad_engine.qry" root-class="COLOR" name="Colores" meta-class="DB" languaje="SP">
	<class size="M" description="Colores" access="direct" label="Color" name="COLOR">
		<meta-properties>
			<db-properties desc-column="d_color" code-column="c_color" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG38_COLORES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_colores" code-attr="c_colores" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_color as oi_color, t0.c_color as c_color, t0.d_color as d_color, t0.c_rgb as c_rgb, t0.c_color as CODE, t0.d_color as TEXT FROM ORG38_COLORES as t0 ORDER BY oi_color asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_color"/>
								<qry:attribute name="c_color" value="$r/@c_color"/>
								<qry:attribute name="d_color" value="$r/@d_color"/>
								<qry:attribute name="c_rgb" value="$r/@c_rgb"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_color as oi_color FROM ORG38_COLORES as t0 ORDER BY oi_color asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_color"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Colores.autoflow:initialize" desc-attr="d_color" code-attr="c_color" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_color">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_color"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_color" OriginalName="c_color">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_color"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_color" OriginalName="d_color">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_color"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="RGB" name="c_rgb" OriginalName="c_rgb">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" patern="[0123456789ABCDEF]" label="RGB" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(30)" column="c_rgb"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="Key_2" name="Key_2">
			<key-attr assosiation="no" name="c_color"/>
		</key>
	</class>
</class-package>
