<class-package xmlns:qry="nomad_engine.qry" name="Estudios" meta-class="DB" languaje="SP" root-class="ESTUDIO" DDOBase="NucleusRH\Base\Organizacion">
	<class size="L" help="Tabla codificadora de Estudios, en donde se registrar&#225; para cada uno el C&#243;digo, la Descripci&#243;n  Observaciones." description="Estudios" access="direct" label="Estudio" name="ESTUDIO">
		<meta-properties>
			<db-properties desc-column="d_estudio" code-column="c_estudio" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG11_ESTUDIOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties guia-parent="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST" binary="NONE" desc-attr="d_estudios" code-attr="c_estudios" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST.INFO"/>
					<qry:include name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_estudio as oi_estudio, t0.c_estudio as c_estudio, t0.d_estudio as d_estudio, t0.oi_nivel_estudio as oi_nivel_estudio, SEC.policy, t0.c_estudio as CODE, t0.d_estudio as TEXT, t0.oi_area_est as oi_area_est FROM ORG11_ESTUDIOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Estudios.ESTUDIO\') as SEC JOIN t0.oi_estudio LEFT OUTER SEC.id  ORDER BY oi_estudio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_estudio"/>
								<qry:attribute name="c_estudio" value="$r/@c_estudio"/>
								<qry:attribute name="d_estudio" value="$r/@d_estudio"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_area_est!=''">
									<qry:then>
										<qry:element name="oi_area_est">
											<qry:attribute name="OI_FIND" value="$r/@oi_area_est"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_area_est" value="'['+oi_area_est/ROW/@COD+'] '+oi_area_est/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:if test="$r/@oi_nivel_estudio!=''">
									<qry:then>
										<qry:element name="oi_nivel_estudio">
											<qry:attribute name="OI_FIND" value="$r/@oi_nivel_estudio"/>
											<qry:insert-select name="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_nivel_estudio" value="'['+oi_nivel_estudio/ROW/@COD+'] '+oi_nivel_estudio/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_estudio as oi_estudio, SEC.policy FROM ORG11_ESTUDIOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Estudios.ESTUDIO\') as SEC JOIN t0.oi_estudio LEFT OUTER SEC.id  ORDER BY oi_estudio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_estudio"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties parent="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST" desc="d_estudios" code="c_estudios" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Estudios.autoflow:initialize" guia-parent="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST" desc-attr="d_estudio" code-attr="c_estudio" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_estudio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_estudio"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST" null="false" readonly="false" type="aggregation" label="&#193;rea Estudio" name="oi_area_est" OriginalName="oi_area_est">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_area_est"/>
				<form-properties label="&#193;rea Estudio" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_area_est"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Estudio. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_estudio" OriginalName="c_estudio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_estudio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Nombre del Estudio. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_estudio" OriginalName="d_estudio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_estudio"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones relacionadas al Estudio. Puede ser un alfanum&#233;rico de hasta 1000 caracteres." label="Observaciones" name="o_estudio" OriginalName="o_estudio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_estudio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK1_ORG_ESTUDIOS" name="AK1_ORG_ESTUDIOS">
			<key-attr assosiation="no" name="c_estudio"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:include name="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST.INFO"/>
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG11_ESTUDIOS.oi_estudio as ID,
  ORG11_ESTUDIOS.c_estudio as COD,
  ORG11_ESTUDIOS.d_estudio as DES,
  ORG11_ESTUDIOS.oi_area_est as PARENT
from
  ORG11_ESTUDIOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
						<qry:insert-select doc-path="." name="NucleusRH.Base.Organizacion.Areas_Estudios.AREA_EST.QUERY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Estudios.ESTUDIO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG11_ESTUDIOS.oi_estudio) as CNT
from
  ORG11_ESTUDIOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG11_ESTUDIOS.oi_estudio={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG11_ESTUDIOS.d_estudio,{#SOURCE:@TXT_FIND}) or contain(ORG11_ESTUDIOS.c_estudio,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and ORG11_ESTUDIOS.oi_area_est={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;PARAM PARENT=&quot;1&quot; /&gt;" name="GUIA">
			<qry:main doc="PARAM">
				<qry:element name="ROWS">
					<qry:attribute name="VAL" value="'int'"/>
					<qry:attribute name="DES" value="'string'"/>
					<qry:insert-select name="sql1" doc-path="#PARAM:."/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="PARAM">
				<qry:xquery>
					for $r in sql('    
				SELECT 
					ORG11_ESTUDIOS.oi_estudio,
					ORG11_ESTUDIOS.d_estudio
				FROM
					ORG11_ESTUDIOS
				ORDER BY
					d_estudio ASC
			')ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute name="VAL" value="$r/@oi_estudio"/>
						<qry:attribute name="DES" value="$r/@d_estudio"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<assosiation label="Nivel de Estudio" name="oi_nivel_estudio" class="NucleusRH.Base.Personal.Niveles_Estudio.NIVEL_ESTUDIO" null="false" readonly="false" type="aggregation" OriginalName="oi_area_est">
			<meta-properties>
				<db-properties from-column="oi_nivel_estudio" tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="true" type="int"/>
				<form-properties mandatory="false" label="Nivel de Estudio" automatico="1" show-list="true" read-only="false" visible="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_nivel_estudio"/>
			</multiplicity>
		</assosiation>
	</class>
</class-package>
