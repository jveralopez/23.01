					for $r in SQL('
select
  Count(ORG41_RUBROS.oi_rubro) as CNT
from
  ORG41_RUBROS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG41_RUBROS.oi_rubro={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG41_RUBROS.d_rubro,{#SOURCE:@TXT_FIND}) or contain(ORG41_RUBROS.c_rubro,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
