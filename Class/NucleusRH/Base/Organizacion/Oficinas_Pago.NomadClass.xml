<class-package xmlns:qry="nomad_engine.qry" root-class="OFICINA_PAGO" name="Oficinas_Pago" meta-class="DB" languaje="SP">
	<class description="Oficinas de pago" name="OFICINA_PAGO" label="Oficina de pago" size="M" note="Registra los Municipios / Departamentos / Partidos de una localidad." access="direct">
		<meta-properties>
			<db-properties desc-column="d_oficina_pago" code-column="c_oficina_pago" table="ORG53_OFICINAS_PAGO" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties enabled-filter="false" desc-attr="d_oficina_pago" code-attr="c_oficina_pago" generate="true" binary="NONE" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('
						SELECT 
							t0.oi_oficina_pago as oi_oficina_pago, 
							t0.c_oficina_pago as c_oficina_pago, 
							t0.d_oficina_pago as d_oficina_pago, 
							t0.c_oficina_pago as CODE, 
							t0.d_oficina_pago as TEXT 

						FROM 
							ORG53_OFICINAS_PAGO as t0,
							NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Oficinas_Pago.OFICINA_PAGO\') as SEC 
						JOIN 
							t0.oi_oficina_pago LEFT OUTER SEC.id  
						ORDER BY 
							oi_oficina_pago asc
				')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_oficina_pago"/>
								<qry:attribute name="c_oficina_pago" value="$r/@c_oficina_pago"/>
								<qry:attribute name="d_oficina_pago" value="$r/@d_oficina_pago"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('
						SELECT 
							t0.oi_oficina_pago as oi_oficina_pago, 
							SEC.policy 
						FROM 
							ORG53_OFICINAS_PAGO as t0,
							NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Oficinas_Pago.OFICINA_PAGO\') as SEC 
						JOIN 
							t0.oi_oficina_pago LEFT OUTER SEC.id  
						ORDER BY 
							oi_oficina_pago asc
						')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_oficina_pago"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties desc-attr="d_centro_costo" code-attr="c_centro_costo" flow-edit="NucleusRH.Base.Organizacion.Centros_de_Costos.flow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_municipio">
			<meta-properties>
				<db-properties column="oi_oficina_pago" tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int"/>
			</meta-properties>
		</attribute>
		<attribute name="c_oficina_pago" null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" OriginalName="c_municipio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties column="c_oficina_pago" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)"/>
			</meta-properties>
		</attribute>
		<attribute name="d_oficina_pago" null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" OriginalName="d_municipio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties column="d_oficina_pago" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)"/>
			</meta-properties>
		</attribute>
		<attribute name="o_oficina_pago" null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" OriginalName="o_municipio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties column="o_oficina_pago" tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD" null="true" readonly="false" type="aggregation" label="Localidad" name="oi_localidad" OriginalName="oi_localidad">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_localidad"/>
				<form-properties show-list="false" label="Localidad" automatico="0" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_localidad"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key name="AK_OFICINAS_PAGO" parent-include="no" descr="AK_MUNICIPIOS">
			<key-attr name="c_oficina_pago" assosiation="no"/>
		</key>
	</class>
</class-package>
