						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_auxiliar as oi_auxiliar, SEC.policy FROM ORG50_AUXILIARES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Auxiliar.AUXILIAR\') as SEC JOIN t0.oi_auxiliar LEFT OUTER SEC.id  ORDER BY oi_auxiliar asc')/ROWS/ROW
