<class-package xmlns:qry="nomad_engine.qry" name="Vistas" meta-class="DB" languaje="SP" root-class="VISTA">
	<class size="M" help="Se registran las diferentes Vistas definidas a trav&#233;s de los Orgranigramas" description="Vistas" access="direct" label="Vista" name="VISTA">
		<meta-properties>
			<db-properties desc-column="d_vista" code-column="c_vista" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG42_VISTAS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_vistas" code-attr="c_vistas" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_vista as oi_vista, t0.c_vista as c_vista, t0.d_vista as d_vista, SEC.policy, t0.c_vista as CODE, t0.d_vista as TEXT, t0.oi_clase_org as oi_clase_org FROM ORG42_VISTAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Vistas.VISTA\') as SEC JOIN t0.oi_vista LEFT OUTER SEC.id  ORDER BY oi_vista asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_vista"/>
								<qry:attribute name="c_vista" value="$r/@c_vista"/>
								<qry:attribute name="d_vista" value="$r/@d_vista"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_clase_org" value="$r/@oi_clase_org"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_vista as oi_vista, SEC.policy FROM ORG42_VISTAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Vistas.VISTA\') as SEC JOIN t0.oi_vista LEFT OUTER SEC.id  ORDER BY oi_vista asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_vista"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_vista" code-attr="c_vista" desc="d_vistas" code="c_vistas" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_vista">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_vista"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_vista" OriginalName="c_vista">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_vista"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_vista" OriginalName="d_vista">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_vista"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Clases_Organizativas.CLASE_ORG" null="false" readonly="false" type="aggregation" label="Organigrama" name="oi_clase_org" OriginalName="oi_clase_org">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_clase_org"/>
				<form-properties label="Organigrama" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_clase_org"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Organizacion.Clases_Organizativas.ESTRUCTURA" null="false" readonly="false" type="aggregation" label="Estructura Organizativa" name="oi_estructura" OriginalName="oi_estructura">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_estructura"/>
				<form-properties show-list="false" label="Estructura Organizativa" automatico="0" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_estructura"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Niveles" name="e_niveles" OriginalName="e_niveles">
			<meta-properties>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="int" column="e_niveles"/>
				<form-properties show-list="false" find-include="false" automatico="0" label="Niveles" lock="false" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_VISTAS" name="AK_VISTAS">
			<key-attr assosiation="no" name="c_vista"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Vistas.VISTA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Vistas.VISTA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG42_VISTAS.oi_vista as ID,
  ORG42_VISTAS.c_vista as COD,
  ORG42_VISTAS.d_vista as DES
from
  ORG42_VISTAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Vistas.VISTA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG42_VISTAS.oi_vista) as CNT
from
  ORG42_VISTAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG42_VISTAS.oi_vista={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG42_VISTAS.d_vista,{#SOURCE:@TXT_FIND}) or contain(ORG42_VISTAS.c_vista,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="$r/@CNT" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
