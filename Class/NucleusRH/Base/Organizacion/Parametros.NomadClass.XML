								<qry:attribute name="d_clase" value="$r/@d_clase"/>
								<qry:attribute name="c_parametro" value="$r/@c_parametro"/>
								<qry:attribute name="d_parametro" value="$r/@d_parametro"/>
								<qry:attribute name="d_tipo_parametro" value="$r/@d_tipo_parametro"/>
								<qry:attribute name="c_padre" value="$r/@c_padre"/>
								<qry:attribute name="e_longitud" value="$r/@e_longitud"/>
								<qry:attribute name="d_valor" value="$r/@d_valor"/>
								<qry:attribute name="l_bloqueado" value="$r/@l_bloqueado"/>
