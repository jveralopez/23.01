		<key parent-include="no" descr="AK_PARAMETROS" name="AK_PARAMETROS">
			<key-attr assosiation="no" name="c_parametro"/>
			<key-attr assosiation="no" name="c_modulo"/>
			<key-attr assosiation="no" name="d_clase"/>
			<key-attr assosiation="no" name="c_padre"/>
		</key>
		<resource declare="&lt;DATOS c_modulo=&quot;VAC&quot; c_parametro=&quot;NOTIF&quot;/&gt;" description="Obtiene un par&#225;metro a partir del M&#243;dulo, Clase, C&#243;digo" name="GET_PARAM">
			<qry:main doc="PARAM">
				<qry:insert-select doc-path="#PARAM:DATOS" name="RS1"/>
			</qry:main>
			<qry:select doc="SOURCE" name="RS1">
				<qry:xquery>
					for $r in sql('
        SELECT ORG26_PARAMETROS.oi_parametro, ORG26_PARAMETROS.c_modulo,
        ORG26_PARAMETROS.d_clase, ORG26_PARAMETROS.c_parametro,
        ORG26_PARAMETROS.d_parametro, ORG26_PARAMETROS.d_tipo_parametro,
        ORG26_PARAMETROS.e_longitud, ORG26_PARAMETROS.d_valor,
        ORG26_PARAMETROS.l_bloqueado, ORG26_PARAMETROS.o_parametro
        FROM ORG26_PARAMETROS
        WHERE ORG26_PARAMETROS.c_modulo = {#SOURCE:@c_modulo}        
        AND ORG26_PARAMETROS.c_parametro = {#SOURCE:@c_parametro}
        {%? (#SOURCE:@d_clase != '') {% AND ORG26_PARAMETROS.d_clase = {#SOURCE:@d_clase} %} {% %} %}        
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="PARAMETRO">
						<qry:attribute name="oi_parametro" value="$r/@oi_parametro"/>
						<qry:attribute name="c_modulo" value="$r/@c_modulo"/>
						<qry:attribute name="d_clase" value="$r/@d_clase"/>
						<qry:attribute name="c_parametro" value="$r/@c_parametro"/>
						<qry:attribute name="d_parametro" value="$r/@d_parametro"/>
						<qry:attribute name="d_tipo_parametro" value="$r/@d_tipo_parametro"/>
						<qry:attribute name="e_longitud" value="$r/@e_longitud"/>
						<qry:attribute name="d_valor" value="$r/@d_valor"/>
						<qry:attribute name="l_bloqueado" value="$r/@l_bloqueado"/>
						<qry:attribute name="o_parametro" value="$r/@o_parametro"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<policy name="LIQREAD" label="Modulo Liquidacion READ"/>
		<resource declare="&lt;DATOS c_modulo=&quot;TTA&quot; c_parametro=&quot;TolPreIng&quot;  d_clase_pueba=&quot;\'Fichadas\', \'Esperanza\'&quot;/&gt;" description="Retorna parametros seg&#250;n filtros incorporados," name="QRY_Parametros">
			<qry:main doc="PARAM">
				<qry:element name="params">
					<qry:insert-select name="qryMain" doc-path="#PARAM:DATOS"/>
				</qry:element>
			</qry:main>
			<qry:select name="qryMain" doc="PARAM">
				<qry:xquery>
					for $f in sql('
                SELECT
                	p.c_modulo,
                	p.d_clase,
                	p.c_parametro, 
                	p.d_valor,
                	p.c_padre
                    
                FROM 
                	ORG26_Parametros as p 

                WHERE
                1 = 1
                {%? (#PARAM:@c_modulo != '') {% AND p.c_modulo = {#PARAM:@c_modulo} %} {% %} %}
                
                {%? (#PARAM:@d_clase != '') {% AND p.d_clase IN ({%= #PARAM:@d_clase %}) %} {% %} %}
                
                {%? (#PARAM:@c_parametro != '') {% AND p.c_parametro = {#PARAM:@c_parametro} %} {% %} %}
                
                ')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="param">
						<qry:attribute name="c_padre" value="$f/@c_padre"/>
						<qry:attribute name="d_valor" value="$f/@d_valor"/>
						<qry:attribute name="c_parametro" value="$f/@c_parametro"/>
						<qry:attribute name="d_clase" value="$f/@d_clase"/>
						<qry:attribute name="c_modulo" value="$f/@c_modulo"/>
					</qry:element>
				</qry:out>
			</qry:select>
		</resource>
		<method modifier="static" access="public" label="Guarda el valor de los parametros del modulo TTA" name="GuardarTTA">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="paramINI"/>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="paramOUT"/>
			</arguments>
		</method>
		<method modifier="static" access="public" label="Guarda el valor de los parametros del modulo POS" name="GuardarPOS">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="paramINI"/>
				<argument class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object" pass="byval" name="paramOUT"/>
			</arguments>
		</method>
		<method return-class="Nomad.NSystem.Proxy.NomadXML" return-type="Nomad.NSystem.Object" modifier="static" access="public" label="ObtenerValores" name="ObtenerValores">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="PARAM" pass="byval" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object"/>
			</arguments>
		</method>
		<method modifier="static" access="public" label="GuardarValores" name="GuardarValores">
			<meta-properties>
				<dotnet11-properties type="lib"/>
			</meta-properties>
			<arguments>
				<argument name="PARAM" pass="byval" class="Nomad.NSystem.Proxy.NomadXML" type="Nomad.NSystem.Object"/>
			</arguments>
		</method>
		<resource declare="&#9;&lt;PARAMS&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;PathForm572&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Ruta para almacenar Formularios 572&quot; d_tipo_parametro=&quot;A&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;cant_dec_liq&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Cantidad de decimales a usar en la liquidaci&amp;#243;n&quot; d_tipo_parametro=&quot;E&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;ProxNumDesde&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Pr&amp;#243;ximo numero de recibo desde&quot; d_tipo_parametro=&quot;E&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;noValidarCerradas&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Indica si se debe omitir la validaci&amp;#243;n de liquidaciones cerradas (listas, libro ley)&quot; d_tipo_parametro=&quot;L&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;numDeLibroLey&quot; d_clase=&quot;LibroLey&quot; d_parametro=&quot;Pr&amp;#243;ximo n&amp;#250;mero de p&amp;#225;g. de Libro de Sueldos (por empresa)&quot; d_tipo_parametro=&quot;E&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;AdmNumRec&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Administrar N&amp;#250;meros de Recibos&quot; d_tipo_parametro=&quot;L&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;PlantillaLibroLey&quot; d_clase=&quot;LibroLey&quot; d_parametro=&quot;Se utiliza plantilla para Libro de Sueldos&quot; d_tipo_parametro=&quot;L&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;DomicilioLibroLey&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Mostrar domicilios en Libro de Sueldos&quot; d_tipo_parametro=&quot;L&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;FamiliaresLibroLey&quot; d_clase=&quot;LIQ&quot; d_parametro=&quot;Mostrar familiares en Libro de Sueldos&quot; d_tipo_parametro=&quot;L&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;flowPivot&quot; d_clase=&quot;REPORTE&quot; d_parametro=&quot;Indica el flow para abrir desde el legajo&quot; d_tipo_parametro=&quot;A&quot;/&gt;&#13;&#10;&#9;&#9;&lt;PARAM c_modulo=&quot;LIQ&quot; c_parametro=&quot;flowRecibos&quot; d_clase=&quot;REPORTE&quot; d_parametro=&quot;Indica el flow para abrir los recibos desde el legajo&quot; d_tipo_parametro=&quot;A&quot;/&gt;&#13;&#10;&#9;&lt;/PARAMS&gt;&#13;&#10;" name="ObtenerValores">
			<qry:main doc="SOURCE">
				<PARAMS>
					<qry:insert-element doc-path="#SOURCE:/PARAMS/PARAM"/>
					<qry:append-doc name="PARAMS" doc-path="."/>
					<qry:insert-select name="sql1"/>
				</PARAMS>
			</qry:main>
			<qry:select name="sql1">
				<qry:xquery>
					for $r in SQL('
			SELECT p.oi_parametro, p.c_parametro, p.c_modulo, p.d_clase, p.d_valor
			FROM ORG26_PARAMETROS AS p
			')/ROWS/ROW,
			$s in $PARAMS/PARAM
			where $r/@c_parametro = $s/@c_parametro and
			$r/@c_modulo = $s/@c_modulo and
			$r/@d_clase = $s/@d_clase
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="sql2" doc-path="$r" to-element="$s"/>
				</qry:out>
			</qry:select>
			<qry:select name="sql2" doc="SOURCE">
				<qry:out>
					<qry:attribute name="oi_parametro" value="$SOURCE/@oi_parametro"/>
					<qry:attribute name="d_valor" value="$SOURCE/@d_valor"/>
				</qry:out>
			</qry:select>
		</resource>
