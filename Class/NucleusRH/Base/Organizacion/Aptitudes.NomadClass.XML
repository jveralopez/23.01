			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Aptitudes.autoflow:initialize" desc-attr="d_aptitud" code-attr="c_aptitud" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
