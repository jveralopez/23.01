				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_aptitud"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_aptitud" OriginalName="d_aptitud">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(1000)" column="d_aptitud"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Escalas.ESCALA" null="false" readonly="false" type="aggregation" label="Escala" name="oi_escala" OriginalName="oi_escala">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_escala"/>
				<form-properties label="Escala" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_escala"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaciones" name="o_aptitud" OriginalName="o_aptitud">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_aptitud"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="Comentarios" name="t_aptitud" OriginalName="t_aptitud">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Comentarios" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(4000)" column="t_aptitud"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="Key_2" name="ak_org28_aptitudes">
			<key-attr assosiation="no" name="c_aptitud"/>
