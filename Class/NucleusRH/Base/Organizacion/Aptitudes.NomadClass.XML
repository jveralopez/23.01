<class-package xmlns:qry="nomad_engine.qry" languaje="SP" meta-class="DB" DDOBase="NucleusRH\Base\Organizacion" root-class="APTITUD" name="Aptitudes">
	<class attr-desc="d_aptitud" attr-code="c_aptitud" size="M" note="Tabla codificadora de Aptitudes, en donde se registrarpara cada una el Cla Descripciy Observaciones. \\&#13;&#10;" help="Tabla codificadora de Aptitudes, en donde se registrar&#225; para cada una el C&#243;digo, la Descripci&#243;n y Observaciones." description="Aptitudes" access="direct" label="aptitud" name="APTITUD">
		<meta-properties>
			<db-properties desc-column="d_aptitud" code-column="c_aptitud" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG28_APTITUDES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_aptitudes" code-attr="c_aptitudes" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Escalas.ESCALA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_aptitud as oi_aptitud, t0.c_aptitud as c_aptitud, t0.d_aptitud as d_aptitud, SEC.policy, t0.c_aptitud as CODE, t0.d_aptitud as TEXT, t0.oi_escala as oi_escala FROM ORG28_APTITUDES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Aptitudes.APTITUD\') as SEC JOIN t0.oi_aptitud LEFT OUTER SEC.id  ORDER BY oi_aptitud asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_aptitud"/>
								<qry:attribute name="c_aptitud" value="$r/@c_aptitud"/>
								<qry:attribute name="d_aptitud" value="$r/@d_aptitud"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_escala!=''">
									<qry:then>
										<qry:element name="oi_escala">
											<qry:attribute name="OI_FIND" value="$r/@oi_escala"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Escalas.ESCALA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_escala" value="'['+oi_escala/ROW/@COD+'] '+oi_escala/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_aptitud as oi_aptitud, SEC.policy FROM ORG28_APTITUDES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Aptitudes.APTITUD\') as SEC JOIN t0.oi_aptitud LEFT OUTER SEC.id  ORDER BY oi_aptitud asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_aptitud"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
