{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG19_LOCALIDADES.oi_localidad as ID,
  ORG19_LOCALIDADES.c_localidad as COD,
  ORG19_LOCALIDADES.d_localidad as DES,
  ORG19_LOCALIDADES.oi_provincia as PARENT
from
  ORG19_LOCALIDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
						<qry:insert-select doc-path="." name="NucleusRH.Base.Organizacion.Paises.PROVINCIA.QUERY"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG19_LOCALIDADES.oi_localidad) as CNT
from
  ORG19_LOCALIDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG19_LOCALIDADES.oi_localidad={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG19_LOCALIDADES.d_localidad,{#SOURCE:@TXT_FIND}) or contain(ORG19_LOCALIDADES.c_localidad,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and ORG19_LOCALIDADES.oi_provincia={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
