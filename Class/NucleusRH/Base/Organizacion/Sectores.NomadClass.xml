<class-package xmlns:qry="nomad_engine.qry" DDOBase="NucleusRH\Base\Organizacion" root-class="SECTOR" name="Sectores" meta-class="DB" languaje="SP">
	<class attr-desc="d_sector" attr-code="c_sector" description="Sectores" label="Sector" access="direct" size="L" name="SECTOR">
		<meta-properties>
			<db-properties generate="true" desc-column="d_sector" code-column="c_sector" tracking-changes="true" access-mode="new-edit-delete" optimistic-lock="version" table="ORG52_SECTORES">
				<security table="NMD_SECURITY"/>
			</db-properties>
		</meta-properties>
		<attribute label="oi departamento" default="''" readonly="false" null="false" type="Nomad.NSystem.Int" name="id" manual="1">
			<meta-properties>
				<db-properties tracking-changes="yes" generator="secuence" updatable="false" unique="true" insertable="true" versionable="true" nullable="false" id="true" type="int" column="oi_sector"/>
			</meta-properties>
		</attribute>
		<attribute inList="true" label="Codigo sector" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="c_sector" manual="1">
			<meta-properties>
				<form-properties automatico="1" find-include="true" mandatory="true" lock="false" visible="true" read-only="false" label="C&#243;digo" show-list="true"/>
				<db-properties tracking-changes="yes" generator="none" updatable="false" unique="true" insertable="true" versionable="true" nullable="false" id="false" type="varchar(100)" column="c_sector"/>
			</meta-properties>
		</attribute>
		<attribute label="Descripcion sector" inList="true" default="''" readonly="false" null="false" type="Nomad.NSystem.String" name="d_sector" manual="1">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" generator="none" unique="false" updatable="true" insertable="true" versionable="true" nullable="false" id="false" type="varchar(100)" column="d_sector"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Departamentos.DEPARTAMENTO" type="aggregation" name="oi_departamento" manual="1">
			<meta-properties>
				<db-properties updatable="true" insertable="true" versionable="true" nullable="false" unique="false" cascade="none" from-column="oi_departamento"/>
				<form-properties automatico="1" show-list="true" mandatory="true" visible="true" read-only="false" label="Departamento"/>
			</meta-properties>
			<multiplicity to="1" from="*">
				<db-properties to-column="oi_departamento"/>
			</multiplicity>
		</assosiation>
		<key unique="yes" parent-include="no" name="AK1_ORG_SECTORES" manual="1">
			<key-attr name="c_sector"/>
			<key-attr assosiation="yes" name="oi_departamento"/>
		</key>
		<resource name="INFO">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Organizacion.Sectores.SECTOR.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Organizacion.Sectores.SECTOR.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  ORG52_SECTORES.oi_sector as ID, 
  ORG52_SECTORES.c_sector as COD, 
  ORG52_SECTORES.d_sector as DES
FROM 
  ORG52_SECTORES
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('{%? (#FILTER:@LEN='') {% %} {% maxsize {%=#FILTER:@LEN %} %} %}
SELECT 
  ORG52_SECTORES.oi_sector as ID, 
  ORG52_SECTORES.c_sector as COD, 
  ORG52_SECTORES.d_sector as DES
{%?($FILTER/@order!='') {% ,ORG52_SECTORES.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM 
  ORG52_SECTORES
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}

{%?($FILTER/@order!='')
  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {% %}
%}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  ORG52_SECTORES.oi_sector as ID, 
  ORG52_SECTORES.c_sector as COD, 
  ORG52_SECTORES.d_sector as DES, 
  ORG52_SECTORES.c_sector as c_sector, 
  ORG52_SECTORES.d_sector as d_sector
FROM 
  ORG52_SECTORES
WHERE 
ORG52_SECTORES.oi_sector in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="c_sector" value="$r/@c_sector"/>
						<qry:attribute name="d_sector" value="$r/@d_sector"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
