<class-package xmlns:qry="nomad_engine.qry" name="Beneficios" meta-class="DB" languaje="SP" root-class="BENEFICIO" DDOBase="NucleusRH\Base\Organizacion">
	<class size="L" note="Tabla codificadora de Beneficios, en donde se registrar&#225; para cada uno el C&#243;digo, la Descripci&#243;n, el Tipo de Beneficio al cual pertenece, el Valor estimado del Beneficio y Observaciones." description="Beneficios" access="direct" label="Beneficio" name="BENEFICIO">
		<meta-properties>
			<db-properties desc-column="d_beneficio" code-column="c_beneficio" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG23_BENEFICIOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_beneficios" code-attr="c_beneficios" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_beneficio as oi_beneficio, t0.c_beneficio as c_beneficio, t0.d_beneficio as d_beneficio, t0.n_valor as n_valor, t0.c_beneficio as CODE, t0.d_beneficio as TEXT, t0.oi_tipo_benef as oi_tipo_benef FROM ORG23_BENEFICIOS as t0 ORDER BY oi_beneficio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_beneficio"/>
								<qry:attribute name="c_beneficio" value="$r/@c_beneficio"/>
								<qry:attribute name="d_beneficio" value="$r/@d_beneficio"/>
								<qry:attribute name="n_valor" value="$r/@n_valor"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_tipo_benef" value="$r/@oi_tipo_benef"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_beneficio as oi_beneficio FROM ORG23_BENEFICIOS as t0 ORDER BY oi_beneficio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_beneficio"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Beneficios.autoflow:initialize" desc-attr="d_beneficio" code-attr="c_beneficio" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_beneficio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_beneficio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo de Beneficio. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_beneficio" OriginalName="c_beneficio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_beneficio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n de Beneficio. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_beneficio" OriginalName="d_beneficio">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_beneficio"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Tipos_de_Beneficios.TIPO_BENEF" null="false" readonly="false" description="Tipo de Beneficio al cual pertenece el Beneficio." type="aggregation" label="Tipo Beneficio" name="oi_tipo_benef" OriginalName="oi_tipo_benef">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_tipo_benef"/>
				<form-properties label="Tipo Beneficio" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_tipo_benef"/>
			</multiplicity>
		</assosiation>
		<attribute null="true" readonly="false" default="''" precision="3" type="Nomad.NSystem.Double" description="Valor estimado del Beneficio." label="Valor" name="n_valor" OriginalName="n_valor">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Valor" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="numeric(11,3)" column="n_valor"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Beneficio. Puede ser un alfanum&#233;rico de hasta 1000 caracteres." label="Observaciones" name="o_beneficio" OriginalName="o_beneficio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_beneficio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK1_ORG_BENEFICIOS" name="AK1_ORG_BENEFICIOS">
			<key-attr assosiation="no" name="c_beneficio"/>
		</key>
	</class>
</class-package>
