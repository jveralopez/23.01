<class-package xmlns:qry="nomad_engine.qry" name="Atributos" meta-class="DB" languaje="SP" root-class="ATRIBUTO" DDOBase="NucleusRH\Base\Organizacion">
	<class size="L" note="Tabla codificadora de Atributos, en donde se registrar&#225; para cada uno el C&#243;digo, la Descripci&#243;n y Observaciones. Estos son los atributos para los cuales se cargar&#225;n valores en las Unidades Organizativas, dependiendo de la asociaci&#243;n Tipo Unidad Organizativa - Atributo." description="Atributos" access="direct" label="Atributo" name="ATRIBUTO">
		<meta-properties>
			<db-properties desc-column="d_atributo" code-column="c_atributo" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG15_ATRIBUTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_atributos" code-attr="c_atributos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_atributo as oi_atributo, t0.c_atributo as c_atributo, t0.d_atributo as d_atributo, t0.c_atributo as CODE, t0.d_atributo as TEXT FROM ORG15_ATRIBUTOS as t0 ORDER BY oi_atributo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_atributo"/>
								<qry:attribute name="c_atributo" value="$r/@c_atributo"/>
								<qry:attribute name="d_atributo" value="$r/@d_atributo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_atributo as oi_atributo FROM ORG15_ATRIBUTOS as t0 ORDER BY oi_atributo asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_atributo"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Atributos.autoflow:initialize" desc-attr="d_atributo" code-attr="c_atributo" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_atributo">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_atributo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo del Atributo. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_atributo" OriginalName="c_atributo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_atributo"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n del Atributo. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_atributo" OriginalName="d_atributo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_atributo"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Atributo. Puede ser un alfanum&#233;rico de hasta 1000 caracteres." label="Observaciones" name="o_atributo" OriginalName="o_atributo">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_atributo"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK1_ORG_ATRIBUTOS" name="AK1_ORG_ATRIBUTOS">
			<key-attr assosiation="no" name="c_atributo"/>
		</key>
	</class>
</class-package>
