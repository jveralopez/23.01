<class-package xmlns:qry="nomad_engine.qry" name="Tipos_Empresa" meta-class="DB" languaje="SP" root-class="TIPO_EMPRESA" DDOBase="NucleusRH\Base\Organizacion">
	<class name="TIPO_EMPRESA" size="L" note="Tabla codificadora de Tipos de Empresa, en donde se registrar&#225; para cada una el C&#243;digo, la Descripci&#243;n y Observaciones." description="Tipos de Empresa" access="direct" label="Tipo Empresa">
		<meta-properties>
			<db-properties desc-column="d_tipo_empresa" code-column="c_tipo_empresa" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG05_TIPOS_EMPR">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_tipos_empr" code-attr="c_tipos_empr" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_empresa as oi_tipo_empresa, t0.c_tipo_empresa as c_tipo_empresa, t0.d_tipo_empresa as d_tipo_empresa, t0.c_tipo_empresa as CODE, t0.d_tipo_empresa as TEXT FROM ORG05_TIPOS_EMPR as t0 ORDER BY oi_tipo_empresa asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_empresa"/>
								<qry:attribute name="c_tipo_empresa" value="$r/@c_tipo_empresa"/>
								<qry:attribute name="d_tipo_empresa" value="$r/@d_tipo_empresa"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_empresa as oi_tipo_empresa FROM ORG05_TIPOS_EMPR as t0 ORDER BY oi_tipo_empresa asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_empresa"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties desc-attr="d_tipo_empresa" code-attr="c_tipo_empresa" flow-edit="NucleusRH.Base.Organizacion.Tipos_Empresa.autoflow:initialize" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_tipo_empresa">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_tipo_empresa"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" description="C&#243;digo del Tipo de Empresa. Puede ser un alfanum&#233;rico de hasta 30 caracteres." label="C&#243;digo" name="c_tipo_empresa" OriginalName="c_tipo_empresa">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_tipo_empresa"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" description="Descripci&#243;n del Tipo de Empresa. Puede ser un alfanum&#233;rico de hasta 100 caracteres." label="Descripci&#243;n" name="d_tipo_empresa" OriginalName="d_tipo_empresa">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_tipo_empresa"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" description="Observaciones del Tipo de Empresa. Puede ser un alfanum&#233;rico de hasta 1000 caracteres." label="Observaciones" name="o_tipo_empresa" OriginalName="o_tipo_empresa">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaciones" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_tipo_empresa"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="no" descr="AK1_ORG_TIPOS_EMPRESA" name="AK1_ORG_TIPOS_EMPRESA">
			<key-attr assosiation="no" name="c_tipo_empresa"/>
		</key>
	</class>
</class-package>
