<class-package xmlns:qry="nomad_engine.qry" name="Actividades" meta-class="DB" languaje="SP" root-class="ACTIVIDAD">
	<class DDO-RESULT="EDT" size="L" note="Registra todas las Actividades\\&#13;&#10;" help="Registra todas las Actividades" description="Actividades" access="direct" label="Actividad" name="ACTIVIDAD">
		<meta-properties DDO-RESULT="EDT">
			<db-properties desc-column="d_actividad" code-column="c_actividad" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="ORG34_ACTIVIDADES">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_actividades" code-attr="c_actividades" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_actividad as oi_actividad, t0.c_actividad as c_actividad, t0.d_actividad as d_actividad, SEC.policy, t0.c_actividad as CODE, t0.d_actividad as TEXT, t0.oi_sub_rubro as oi_sub_rubro FROM ORG34_ACTIVIDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD\') as SEC JOIN t0.oi_actividad LEFT OUTER SEC.id  ORDER BY oi_actividad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_actividad"/>
								<qry:attribute name="c_actividad" value="$r/@c_actividad"/>
								<qry:attribute name="d_actividad" value="$r/@d_actividad"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_sub_rubro" value="$r/@oi_sub_rubro"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_actividad as oi_actividad, SEC.policy FROM ORG34_ACTIVIDADES as t0,NMD_SECURITY(class=\'NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD\') as SEC JOIN t0.oi_actividad LEFT OUTER SEC.id  ORDER BY oi_actividad asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_actividad"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_actividades" code="c_actividades" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Organizacion.Actividades.autoflow:initialize" desc-attr="d_actividad" code-attr="c_actividad" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_actividad">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_actividad"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_actividad" OriginalName="c_actividad">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_actividad"/>
			</meta-properties>
		</attribute>
		<attribute DDO-RESULT="EDT" null="false" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_actividad" OriginalName="d_actividad">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(1000)" column="d_actividad"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Rubros.SUB_RUBRO" null="true" readonly="false" type="aggregation" label="Rubro - SubRubro" name="oi_sub_rubro" OriginalName="oi_sub_rubro">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_sub_rubro"/>
				<form-properties label="Rubro - SubRubro" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_sub_rubro"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_ORG34_AC" name="AK_KEY_2_ORG34_AC">
			<key-attr assosiation="no" name="c_actividad"/>
		</key>
		<resource DDO-RESULT="EDT" declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG34_ACTIVIDADES.oi_actividad as ID,
  ORG34_ACTIVIDADES.c_actividad as COD,
  ORG34_ACTIVIDADES.d_actividad as DES
from
  ORG34_ACTIVIDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Actividades.ACTIVIDAD.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG34_ACTIVIDADES.oi_actividad) as CNT
from
  ORG34_ACTIVIDADES
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG34_ACTIVIDADES.oi_actividad={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG34_ACTIVIDADES.d_actividad,{#SOURCE:@TXT_FIND}) or contain(ORG34_ACTIVIDADES.c_actividad,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
