		<resource declare="&lt;PARAM oi_centro_costo=&quot;5&quot;/&gt;" name="QRY_VALIDAR">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:insert-select name="QRY_LEGAJOS" doc-path="#SOURCE:PARAM"/>
					<qry:if test="@flag=''">
						<qry:then>
							<qry:insert-select name="QRY_POSICIONES" doc-path="#SOURCE:PARAM"/>
						</qry:then>
						<qry:else/>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="QRY_LEGAJOS">
				<qry:xquery>
					for $r in sql(' 
          SELECT 
          per02_personal_emp.oi_personal_emp 
          FROM 
          per02_personal_emp
          WHERE 
          per02_personal_emp.oi_ctro_costo_ult = {#SOURCE:@oi_centro_costo}
          and per02_personal_emp.oi_indic_activo != 4
	 		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="LEGAJOS">
						<qry:attribute value="$r/@oi_personal_emp" name="id"/>
					</qry:element>
					<qry:attribute value="'LEG'" name="flag"/>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="QRY_POSICIONES">
				<qry:xquery>
					for $r in sql(' 
          SELECT 
          org04_posiciones.oi_posicion 
          FROM 
          org04_posiciones
          WHERE 
          org04_posiciones.oi_centro_costo = {#SOURCE:@oi_centro_costo}
	 		')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="POSIC">
						<qry:attribute value="$r/@oi_posicion" name="id"/>
					</qry:element>
					<qry:attribute value="'POS'" name="flag"/>
				</qry:out>
			</qry:select>
