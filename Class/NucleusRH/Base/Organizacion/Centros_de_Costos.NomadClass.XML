			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  ORG08_CS_COSTO.oi_centro_costo as ID,
  ORG08_CS_COSTO.c_centro_costo as COD,
  ORG08_CS_COSTO.d_centro_costo as DES
from
  ORG08_CS_COSTO
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and ORG08_CS_COSTO.l_activo = 1 and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {%  %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 
{%? (#SOURCE:@WHERE='') {% %} {% and ORG08_CS_COSTO.l_activo = 1 and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Organizacion.Centros_de_Costos.CENTRO_COSTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(ORG08_CS_COSTO.oi_centro_costo) as CNT
from
  ORG08_CS_COSTO
Where
  1=1 AND ORG08_CS_COSTO.l_activo=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ORG08_CS_COSTO.oi_centro_costo={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ORG08_CS_COSTO.d_centro_costo,{#SOURCE:@TXT_FIND}) or contain(ORG08_CS_COSTO.c_centro_costo,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
