			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Direcci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_direccion"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo Postal" name="c_cod_postal" OriginalName="c_cod_postal">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo Postal" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(30)" column="c_cod_postal"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD" null="true" readonly="false" type="aggregation" label="Zonas - Localidad" name="oi_localidad" OriginalName="oi_localidad">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_localidad"/>
				<form-properties label="Zonas - Localidad" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_localidad"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG50_DOM_SEDE_JUD.oi_dom_sede_jud as ID,
  LEG50_DOM_SEDE_JUD.oi_dom_sede_jud as COD,
  LEG50_DOM_SEDE_JUD.d_direccion as DES
from
  LEG50_DOM_SEDE_JUD
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG50_DOM_SEDE_JUD.oi_dom_sede_jud) as CNT
from
  LEG50_DOM_SEDE_JUD
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG50_DOM_SEDE_JUD.oi_dom_sede_jud={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG50_DOM_SEDE_JUD.d_direccion,{#SOURCE:@TXT_FIND}) or contain(LEG50_DOM_SEDE_JUD.oi_dom_sede_jud,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
