<class-package xmlns:qry="nomad_engine.qry" root-class="DOM_SEDE_JUD" name="DomiciliosJudiciales" meta-class="DB" languaje="SP">
	<class size="L" description="Domicilios Sede Judicial" access="direct" label="Domicilio Sede Judicial" name="DOM_SEDE_JUD">
		<meta-properties>
			<db-properties desc-column="d_direccion" code-column="oi_dom_sede_jud" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG50_DOM_SEDE_JUD">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_direccion" code-attr="oi_dom_sede_jud" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_dom_sede_jud as oi_dom_sede_jud, t0.d_direccion as d_direccion, t0.c_cod_postal as c_cod_postal, SEC.policy, t0.oi_dom_sede_jud as CODE, t0.d_direccion as TEXT, t0.oi_localidad as oi_localidad FROM LEG50_DOM_SEDE_JUD as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD\') as SEC JOIN t0.oi_dom_sede_jud LEFT OUTER SEC.id  ORDER BY oi_dom_sede_jud asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_dom_sede_jud"/>
								<qry:attribute name="d_direccion" value="$r/@d_direccion"/>
								<qry:attribute name="c_cod_postal" value="$r/@c_cod_postal"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_localidad!=''">
									<qry:then>
										<qry:element name="oi_localidad">
											<qry:attribute name="OI_FIND" value="$r/@oi_localidad"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Localidades.LOCALIDAD.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_localidad" value="'['+oi_localidad/ROW/@COD+'] '+oi_localidad/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_dom_sede_jud as oi_dom_sede_jud, SEC.policy FROM LEG50_DOM_SEDE_JUD as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.DomiciliosJudiciales.DOM_SEDE_JUD\') as SEC JOIN t0.oi_dom_sede_jud LEFT OUTER SEC.id  ORDER BY oi_dom_sede_jud asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_dom_sede_jud"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_direccion" code="oi_dom_sede_jud" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Legales.DomiciliosJudiciales.autoflow:initialize" desc-attr="d_direccion" code-attr="oi_dom_sede_jud" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
