<class-package xmlns:qry="nomad_engine.qry" root-class="DOCUMENTO" name="Documentos" meta-class="DB" languaje="SP">
	<class size="S" description="Documentos Adjuntos" access="direct" label="Documento" name="DOCUMENTO">
		<meta-properties>
			<db-properties desc-column="d_doc_dig" code-column="oi_documento" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG05_DOCUMENTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_doc_dig" code-attr="oi_documento" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Legales.Carpetas.CARPETA.INFO"/>
					<qry:include name="NucleusRH.Base.Legales.Tareas.TAREA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_documento as oi_documento, t0.d_doc_dig as d_doc_dig, t0.f_doc_dig as f_doc_dig, SEC.policy, t0.oi_documento as CODE, t0.d_doc_dig as TEXT, t0.oi_doc_digital as oi_doc_digital, t0.oi_carpeta as oi_carpeta, t0.oi_tarea as oi_tarea FROM LEG05_DOCUMENTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Documentos.DOCUMENTO\') as SEC JOIN t0.oi_documento LEFT OUTER SEC.id  ORDER BY oi_documento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_documento"/>
								<qry:attribute name="d_doc_dig" value="$r/@d_doc_dig"/>
								<qry:attribute name="f_doc_dig" value="$r/@f_doc_dig"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:attribute name="oi_doc_digital" value="$r/@oi_doc_digital"/>
								<qry:if test="$r/@oi_carpeta!=''">
									<qry:then>
										<qry:element name="oi_carpeta">
											<qry:attribute name="OI_FIND" value="$r/@oi_carpeta"/>
											<qry:insert-select name="NucleusRH.Base.Legales.Carpetas.CARPETA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_carpeta" value="'['+oi_carpeta/ROW/@COD+'] '+oi_carpeta/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:if test="$r/@oi_tarea!=''">
									<qry:then>
										<qry:element name="oi_tarea">
											<qry:attribute name="OI_FIND" value="$r/@oi_tarea"/>
											<qry:insert-select name="NucleusRH.Base.Legales.Tareas.TAREA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_tarea" value="'['+oi_tarea/ROW/@COD+'] '+oi_tarea/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_documento as oi_documento, SEC.policy FROM LEG05_DOCUMENTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Documentos.DOCUMENTO\') as SEC JOIN t0.oi_documento LEFT OUTER SEC.id  ORDER BY oi_documento asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_documento"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_doc_dig" code="oi_documento" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Legales.Documentos.autoflow:initialize" desc-attr="d_doc_dig" code-attr="oi_documento" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_documento">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_documento"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Legales.DocumentosDigitales.HEAD" null="false" readonly="false" type="aggregation" label="Documento Digital" name="oi_doc_digital" OriginalName="oi_doc_digital">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_doc_digital"/>
				<form-properties label="Documento Digital" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_doc_digital"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Legales.Carpetas.CARPETA" null="false" readonly="false" type="aggregation" label="Carpeta" name="oi_carpeta" OriginalName="oi_carpeta">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_carpeta"/>
				<form-properties label="Carpeta" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_carpeta"/>
			</multiplicity>
		</assosiation>
		<assosiation class="NucleusRH.Base.Legales.Tareas.TAREA" null="true" readonly="false" type="aggregation" label="Tarea" name="oi_tarea" OriginalName="oi_tarea">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_tarea"/>
				<form-properties label="Tarea" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_tarea"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_doc_dig" OriginalName="d_doc_dig">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_doc_dig"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha" name="f_doc_dig" OriginalName="f_doc_dig">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Fecha" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_doc_dig"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaci&#243;n" name="o_doc_dig" OriginalName="o_doc_dig">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaci&#243;n" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_doc_dig"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_LEG03_DO" name="AK_KEY_2_LEG03_DO">
			<key-attr assosiation="yes" name="oi_doc_digital"/>
			<key-attr assosiation="yes" name="oi_carpeta"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG05_DOCUMENTOS.oi_documento as ID,
  LEG05_DOCUMENTOS.oi_documento as COD,
  LEG05_DOCUMENTOS.d_doc_dig as DES
from
  LEG05_DOCUMENTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Documentos.DOCUMENTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG05_DOCUMENTOS.oi_documento) as CNT
from
  LEG05_DOCUMENTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG05_DOCUMENTOS.oi_documento={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG05_DOCUMENTOS.d_doc_dig,{#SOURCE:@TXT_FIND}) or contain(LEG05_DOCUMENTOS.oi_documento,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
