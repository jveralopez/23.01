<class-package xmlns:qry="nomad_engine.qry" root-class="CAUSAL" name="CausalesBaja" meta-class="DB" languaje="SP">
	<class size="S" help="Codificadora de causales de baja" description="Causales de Baja" access="direct" label="Causal de Baja" name="CAUSAL">
		<meta-properties>
			<db-properties desc-column="d_causal" code-column="c_causal" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG59_CAUSALES_BAJA">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_causales_baja" code-attr="c_causales_baja" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_causal as oi_causal, t0.c_causal as c_causal, t0.d_causal as d_causal, SEC.policy, t0.c_causal as CODE, t0.d_causal as TEXT FROM LEG59_CAUSALES_BAJA as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.CausalesBaja.CAUSAL\') as SEC JOIN t0.oi_causal LEFT OUTER SEC.id  ORDER BY oi_causal asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_causal"/>
								<qry:attribute name="c_causal" value="$r/@c_causal"/>
								<qry:attribute name="d_causal" value="$r/@d_causal"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_causal as oi_causal, SEC.policy FROM LEG59_CAUSALES_BAJA as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.CausalesBaja.CAUSAL\') as SEC JOIN t0.oi_causal LEFT OUTER SEC.id  ORDER BY oi_causal asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_causal"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Legales.CausalesBaja.autoflow:initialize" desc-attr="d_causal" code-attr="c_causal" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
			<templates>
				<templates name="MAIN">
					<template-STD_LIST name="MAIN">
						<cfg del="1" edit="1" add="1" list-resource="INFO_IDS_LIST" id-resource="INFO_IDS">
							<col order="1" show="string_short" name="c_causal"/>
							<col show="string_med" name="d_causal"/>
						</cfg>
					</template-STD_LIST>
					<template-STD_REG name="MAIN">
						<cfg del="1" edit="1" add="1">
							<ctrl enable="1" req="1" show="string_short" name="c_causal"/>
							<ctrl enable="1" req="1" show="string_med" name="d_causal"/>
						</cfg>
					</template-STD_REG>
					<template-STD name="MAIN">
						<cfg add="1"/>
					</template-STD>
				</templates>
			</templates>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_causal">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_causal"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_causal" OriginalName="c_causal">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_causal"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_causal" OriginalName="d_causal">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_causal"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_LEG31_ES" name="AK_KEY_2_LEG31_ES">
			<key-attr assosiation="no" name="c_causal"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusRH.Base.Legales.CausalesBaja.CAUSAL.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusRH.Base.Legales.CausalesBaja.CAUSAL.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  LEG59_CAUSALES_BAJA.oi_causal as ID, 
  LEG59_CAUSALES_BAJA.c_causal as COD, 
  LEG59_CAUSALES_BAJA.d_causal as DES
FROM 
  LEG59_CAUSALES_BAJA
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource declare="&lt;DATA parent=&quot;&quot; search=&quot;&quot; /&gt;" name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('
			
	SELECT 
  LEG59_CAUSALES_BAJA.oi_causal as ID, 
  LEG59_CAUSALES_BAJA.c_causal as COD, 
  LEG59_CAUSALES_BAJA.d_causal as DES
FROM 
  LEG59_CAUSALES_BAJA

		WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(LEG59_CAUSALES_BAJA.c_causal),{upper-case($FILTER/@search)})
 or contain(ucase(LEG59_CAUSALES_BAJA.d_causal),{upper-case($FILTER/@search)})
 ) %}
 {% %}
%}
	  
{%?($FILTER/@order!='')
  {% order by {%=$FILTER/@order %} {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {%ORDER BY COD ASC %}
%}
 
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  LEG59_CAUSALES_BAJA.oi_causal as ID, 
  LEG59_CAUSALES_BAJA.c_causal as COD, 
  LEG59_CAUSALES_BAJA.d_causal as DES,
  LEG59_CAUSALES_BAJA.c_causal as c_causal, 
  LEG59_CAUSALES_BAJA.d_causal as d_causal
FROM 
  LEG59_CAUSALES_BAJA
WHERE 
LEG59_CAUSALES_BAJA.oi_causal in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="c_causal" value="$r/@c_causal"/>
						<qry:attribute name="d_causal" value="$r/@d_causal"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
