<class-package xmlns:qry="nomad_engine.qry" root-class="MONEDA" name="Monedas" meta-class="DB" languaje="SP">
	<class size="S" help="Codificadora de monedas" description="Monedas" access="direct" label="Moneda" name="MONEDA">
		<meta-properties>
			<db-properties desc-column="d_moneda" code-column="oi_moneda" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG38_MONEDAS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_monedas" code-attr="oi_moneda" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_moneda as oi_moneda, t0.d_moneda as d_moneda, t0.c_simbolo as c_simbolo, SEC.policy, t0.oi_moneda as CODE, t0.d_moneda as TEXT FROM LEG38_MONEDAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Monedas.MONEDA\') as SEC JOIN t0.oi_moneda LEFT OUTER SEC.id  ORDER BY oi_moneda asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_moneda"/>
								<qry:attribute name="d_moneda" value="$r/@d_moneda"/>
								<qry:attribute name="c_simbolo" value="$r/@c_simbolo"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_moneda as oi_moneda, SEC.policy FROM LEG38_MONEDAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Monedas.MONEDA\') as SEC JOIN t0.oi_moneda LEFT OUTER SEC.id  ORDER BY oi_moneda asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_moneda"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc-attr="d_moneda" code-attr="oi_moneda" desc="d_monedas" code="oi_moneda" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_moneda">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_moneda"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_moneda" OriginalName="d_moneda">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_moneda"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="S&#237;mbolo" name="c_simbolo" OriginalName="c_simbolo">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="S&#237;mbolo" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(30)" column="c_simbolo"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_LEG38_MO" name="AK_KEY_2_LEG38_MO">
			<key-attr assosiation="no" name="d_moneda"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Monedas.MONEDA.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Monedas.MONEDA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Monedas.MONEDA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG38_MONEDAS.oi_moneda as ID,
  LEG38_MONEDAS.oi_moneda as COD,
  LEG38_MONEDAS.d_moneda as DES
from
  LEG38_MONEDAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Monedas.MONEDA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG38_MONEDAS.oi_moneda) as CNT
from
  LEG38_MONEDAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG38_MONEDAS.oi_moneda={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG38_MONEDAS.d_moneda,{#SOURCE:@TXT_FIND}) or contain(LEG38_MONEDAS.oi_moneda,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
