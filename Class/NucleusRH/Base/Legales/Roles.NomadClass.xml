<class-package xmlns:qry="nomad_engine.qry" root-class="ROL" name="Roles" meta-class="DB" languaje="SP">
	<class size="L" description="Roles" access="direct" label="Rol" name="ROL">
		<meta-properties>
			<db-properties desc-column="d_rol" code-column="c_rol" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG33_ROL">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="d_rol" code-attr="c_rol" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_rol as oi_rol, t0.c_rol as c_rol, t0.d_rol as d_rol, t0.c_partes as c_partes, t0.c_objeto_carpeta as c_objeto_carpeta, SEC.policy, t0.c_rol as CODE, t0.d_rol as TEXT FROM LEG33_ROL as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Roles.ROL\') as SEC JOIN t0.oi_rol LEFT OUTER SEC.id  ORDER BY oi_rol asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_rol"/>
								<qry:attribute name="c_rol" value="$r/@c_rol"/>
								<qry:attribute name="d_rol" value="$r/@d_rol"/>
								<qry:attribute name="c_partes" value="$r/@c_partes"/>
								<qry:attribute name="c_objeto_carpeta" value="$r/@c_objeto_carpeta"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_rol as oi_rol, SEC.policy FROM LEG33_ROL as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Roles.ROL\') as SEC JOIN t0.oi_rol LEFT OUTER SEC.id  ORDER BY oi_rol asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_rol"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_rol" code="c_rol" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Legales.Roles.autoflow:initialize" desc-attr="d_rol" code-attr="c_rol" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_rol">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_rol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_rol" OriginalName="c_rol">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_rol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_rol" OriginalName="d_rol">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_rol"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Rol obligatorio dentro de las partes" name="c_partes" OriginalName="c_partes">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Legales.Roles.ROL.c_partes" show-list="true" find-include="true" automatico="1" label="Rol obligatorio dentro de las partes" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_partes"/>
			</meta-properties>
		</attribute>
		<enum name="c_partes">
			<enum-value label="Si" value="1"/>
			<enum-value label="No" value="0"/>
		</enum>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="Se permite la carga de objeto carpeta para el rol" name="c_objeto_carpeta" OriginalName="c_objeto_carpeta">
			<meta-properties>
				<form-properties enum="NucleusRH.Base.Legales.Roles.ROL.c_objeto_carpeta" show-list="true" find-include="true" automatico="1" label="Se permite la carga de objeto carpeta para el rol" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_objeto_carpeta"/>
			</meta-properties>
		</attribute>
		<enum name="c_objeto_carpeta">
			<enum-value label="Si" value="1"/>
			<enum-value label="No" value="0"/>
		</enum>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<assosiation label="Clasificaciones por Rol" name="CLASIF_ROL" class="CLASIF_ROL" type="composition" access="public">
			<meta-properties>
				<db-properties cascade="delete" not-found="exception" optimistic-lock="true" not-null="true" unique="true" insert="false" update="false" from-column="oi_rol"/>
				<form-properties label="Clasificaciones por Rol" automatico="1" show-list="false" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="0..*" from="1">
				<db-properties to-column="oi_rol"/>
			</multiplicity>
		</assosiation>
		<key unique="yes" parent-include="no" descr="AK_KEY_2_LEG33_RO" name="AK_KEY_2_LEG33_RO">
			<key-attr assosiation="no" name="c_rol"/>
		</key>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Roles.ROL.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Roles.ROL.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Roles.ROL.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG33_ROL.oi_rol as ID,
  LEG33_ROL.c_rol as COD,
  LEG33_ROL.d_rol as DES
from
  LEG33_ROL
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Roles.ROL.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG33_ROL.oi_rol) as CNT
from
  LEG33_ROL
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG33_ROL.oi_rol={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG33_ROL.d_rol,{#SOURCE:@TXT_FIND}) or contain(LEG33_ROL.c_rol,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
	<class size="M" description="Clasificaciones por Rol" access="direct" label="Clasif Rol" name="CLASIF_ROL">
		<meta-properties>
			<db-properties desc-column="LEG41_CLASIF.d_clasif_suj" code-column="oi_clasif_rol" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG33_CLASIF_ROL"/>
			<form-properties binary="NONE" desc-attr="LEG41_CLASIF.d_clasif_suj" code-attr="oi_clasif_rol" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Legales.Clasif_Suj.CLASIF_SUJ.INFO"/>
					<qry:main doc="PARAM" maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select doc-path="#PARAM:./CLASIF_ROL[substring_before(@nmd-status,',')!='~d' and substring_before(@nmd-status,',')!='~x']" name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in #PARAM:
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="id" value="$r/@id"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/oi_clasif_suj/@value!=''">
									<qry:then>
										<qry:element name="oi_clasif_suj">
											<qry:attribute name="OI_FIND" value="$r/oi_clasif_suj/@value"/>
											<qry:insert-select name="NucleusRH.Base.Legales.Clasif_Suj.CLASIF_SUJ.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_clasif_suj" value="'['+oi_clasif_suj/ROW/@COD+'] '+oi_clasif_suj/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
			</form-properties>
			<guia-properties desc-attr="LEG41_CLASIF.d_clasif_suj" code-attr="oi_clasif_rol" requiered-filter="false" enabled-filter="true" enabled-edit="false" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_clasif_rol">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_clasif_rol"/>
			</meta-properties>
		</attribute>
		<attribute ParentJoin="LEG33_ROL.oi_rol" ParentId="1" null="true" readonly="false" default="''" type="Nomad.NSystem.Int" label="Rol" name="oi_rol" OriginalName="oi_rol">
			<meta-properties>
				<form-properties show-list="false" visible="false" find-include="false" automatico="1" label="OID Rol" lock="false" read-only="false" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="int" column="oi_rol"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Legales.Clasif_Suj.CLASIF_SUJ" null="true" readonly="false" type="aggregation" label="Clasif Sujeto" name="oi_clasif_suj" OriginalName="oi_clasif_suj">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="false" unique="false" insert="true" update="true" nullable="true" type="int" from-column="oi_clasif_suj"/>
				<form-properties label="Clasif Sujeto" automatico="1" show-list="true" read-only="false" visible="true" mandatory="false"/>
			</meta-properties>
			<multiplicity to="1" from="0..*">
				<db-properties to-column="oi_clasif_suj"/>
			</multiplicity>
		</assosiation>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key parent-include="yes" unique="yes" descr="AK_KEY_2_LEG33_CL" name="AK_KEY_2_LEG33_CL">
			<key-attr assosiation="yes" name="oi_clasif_suj"/>
		</key>
	</class>
</class-package>
