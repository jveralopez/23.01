							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG34_ESTADOS_TAREAS.oi_estado_tarea as ID,
  LEG34_ESTADOS_TAREAS.c_estado_tarea as COD,
  LEG34_ESTADOS_TAREAS.d_estado_tarea as DES
from
  LEG34_ESTADOS_TAREAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Estados_Tarea.ESTADO_TAREA.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG34_ESTADOS_TAREAS.oi_estado_tarea) as CNT
from
  LEG34_ESTADOS_TAREAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG34_ESTADOS_TAREAS.oi_estado_tarea={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG34_ESTADOS_TAREAS.d_estado_tarea,{#SOURCE:@TXT_FIND}) or contain(LEG34_ESTADOS_TAREAS.c_estado_tarea,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
