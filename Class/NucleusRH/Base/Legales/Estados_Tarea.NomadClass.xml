				</qry:element>
			</qry:main>
			<qry:select name="qryEstadoTarea" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
			
			SELECT
				LEG34_ESTADOS_TAREAS.oi_estado_tarea
			
			FROM
				LEG34_ESTADOS_TAREAS
							
			WHERE
			  LEG34_ESTADOS_TAREAS.c_estado_tarea = {#PARAM:@c_estado_tarea}
			
			')/ROWS/ROW
