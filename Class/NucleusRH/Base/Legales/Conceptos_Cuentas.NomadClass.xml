				<form-list-properties>
					<qry:include name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.INFO"/>
					<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_concepto_cta as oi_concepto_cta, SEC.policy, t0.oi_concepto_cta as CODE, t0.oi_concepto_cta as TEXT, t0.oi_concepto as oi_concepto, t0.oi_empresa as oi_empresa FROM LEG61_CONCEPTOS_CUENTAS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Conceptos_Cuentas.CONCEPTO_CTA\') as SEC JOIN t0.oi_concepto_cta LEFT OUTER SEC.id  ORDER BY oi_concepto_cta asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
