									<qry:then>
										<qry:element name="oi_concepto">
											<qry:attribute name="OI_FIND" value="$r/@oi_concepto"/>
											<qry:insert-select name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_concepto" value="'['+oi_concepto/ROW/@COD+'] '+oi_concepto/ROW/@DES"/>
									</qry:then>
								</qry:if>
								<qry:if test="$r/@oi_empresa!=''">
									<qry:then>
										<qry:element name="oi_empresa">
											<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
