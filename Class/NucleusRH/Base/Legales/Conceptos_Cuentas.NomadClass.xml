		<meta-properties>
			<db-properties desc-column="oi_concepto_cta" code-column="oi_concepto_cta" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG61_CONCEPTOS_CUENTAS">
