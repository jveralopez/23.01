					for $r in SQL('
select
  Count(LEG61_CONCEPTOS_CUENTAS.oi_concepto_cta) as CNT
from
  LEG61_CONCEPTOS_CUENTAS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG61_CONCEPTOS_CUENTAS.oi_concepto_cta={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG61_CONCEPTOS_CUENTAS.oi_concepto_cta,{#SOURCE:@TXT_FIND}) or contain(LEG61_CONCEPTOS_CUENTAS.oi_concepto_cta,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
