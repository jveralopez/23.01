<class-package xmlns:qry="nomad_engine.qry" root-class="CONCEPTO" name="Conceptos" meta-class="DB" languaje="SP">
	<class size="L" help="Conceptos de Gastos" description="Conceptos de Gastos" access="direct" label="Concepto" name="CONCEPTO">
		<meta-properties>
			<db-properties desc-column="d_concepto" code-column="c_concepto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG53_CONCEPTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties generate="true" binary="NONE" desc-attr="d_conceptos" code-attr="c_conceptos" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_concepto as oi_concepto, t0.c_concepto as c_concepto, t0.d_concepto as d_concepto, SEC.policy, t0.c_concepto as CODE, t0.d_concepto as TEXT FROM LEG53_CONCEPTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Conceptos.CONCEPTO\') as SEC JOIN t0.oi_concepto LEFT OUTER SEC.id  ORDER BY oi_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_concepto"/>
								<qry:attribute name="c_concepto" value="$r/@c_concepto"/>
								<qry:attribute name="d_concepto" value="$r/@d_concepto"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_concepto as oi_concepto, SEC.policy FROM LEG53_CONCEPTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Conceptos.CONCEPTO\') as SEC JOIN t0.oi_concepto LEFT OUTER SEC.id  ORDER BY oi_concepto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_concepto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="d_conceptos" code="c_conceptos" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Legales.Conceptos.autoflow:initialize" desc-attr="d_concepto" code-attr="c_concepto" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_concepto">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_concepto" OriginalName="c_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="C&#243;digo" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(30)" column="c_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Descripci&#243;n" name="d_concepto" OriginalName="d_concepto">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Descripci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_concepto"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="1000" type="Nomad.NSystem.String" label="Observaci&#243;n" name="o_concepto" OriginalName="o_concepto">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="Observaci&#243;n" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(1000)" column="o_concepto"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG53_CONCEPTOS.oi_concepto as ID,
  LEG53_CONCEPTOS.c_concepto as COD,
  LEG53_CONCEPTOS.d_concepto as DES
from
  LEG53_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.Conceptos.CONCEPTO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG53_CONCEPTOS.oi_concepto) as CNT
from
  LEG53_CONCEPTOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG53_CONCEPTOS.oi_concepto={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG53_CONCEPTOS.d_concepto,{#SOURCE:@TXT_FIND}) or contain(LEG53_CONCEPTOS.c_concepto,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
