							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_tipo_doc as oi_tipo_doc, t0.c_tipo_doc as c_tipo_doc, t0.d_tipo_doc as d_tipo_doc, SEC.policy, t0.c_tipo_doc as CODE, t0.d_tipo_doc as TEXT FROM LEG64_TIPOS_DOC as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.TiposDocumento.TIPO_DOC\') as SEC JOIN t0.oi_tipo_doc LEFT OUTER SEC.id  ORDER BY oi_tipo_doc asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_tipo_doc"/>
								<qry:attribute name="c_tipo_doc" value="$r/@c_tipo_doc"/>
								<qry:attribute name="d_tipo_doc" value="$r/@d_tipo_doc"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
							</qry:element>
