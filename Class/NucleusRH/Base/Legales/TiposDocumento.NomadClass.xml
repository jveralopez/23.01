		<meta-properties>
			<db-properties desc-column="d_tipo_doc" code-column="c_tipo_doc" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG64_TIPOS_DOC">
				<security table="NMD_SECURITY"/>
