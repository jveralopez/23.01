			<form-properties generate="true" binary="NONE" desc-attr="d_tipo_doc" code-attr="c_tipo_doc" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:main maxdeep="2">
