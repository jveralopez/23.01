			<qry:select name="getMontoAcuerdo" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				
					SELECT																		
						MAX(MON.oi_monto) as oi_monto
						               			
					FROM
						LEG01_PARTES as PAR,
						LEG01_OBJ_CARPETA as OCA,
						LEG02_MONTOS as MON,
						LEG36_TIPOS_DE_MONTOS as TMO
					
					JOIN
						PAR.oi_parte INNER OCA.oi_parte,						
						OCA.oi_obj_rec_carpeta INNER MON.oi_obj_rec_carpeta,
						MON.oi_tipo_monto INNER TMO.oi_tipo_monto
					
					WHERE
						PAR.oi_carpeta = {$PARAM/@oi_carpeta}
						AND TMO.c_tipo_monto = 3									
				
				')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:insert-select name="getMonto" doc-path="$r"/>
				</qry:out>
			</qry:select>
			<qry:select name="getMontoReclamo" doc="PARAM">
				<qry:xquery>
					for $r in SQL('
				
					SELECT																		
						MAX(MON.oi_monto) as oi_monto
						               			
					FROM
						LEG01_PARTES as PAR,
						LEG01_OBJ_CARPETA as OCA,
						LEG02_MONTOS as MON,
						LEG36_TIPOS_DE_MONTOS as TMO
					
					JOIN
						PAR.oi_parte INNER OCA.oi_parte,						
						OCA.oi_obj_rec_carpeta INNER MON.oi_obj_rec_carpeta,
