		<meta-properties>
			<db-properties desc-column="d_impuesto" code-column="c_impuesto" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG62_IMPUESTOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties enabled-filter="true" generate="true" binary="NONE" desc-attr="d_impuesto" code-attr="c_impuesto" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_impuesto as oi_impuesto, t0.c_impuesto as c_impuesto, t0.d_impuesto as d_impuesto, t0.l_iva as l_iva, t0.n_porcentaje as n_porcentaje, SEC.policy, t0.c_impuesto as CODE, t0.d_impuesto as TEXT, t0.oi_empresa as oi_empresa FROM LEG62_IMPUESTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Impuestos.IMPUESTO\') as SEC JOIN t0.oi_impuesto LEFT OUTER SEC.id  ORDER BY oi_impuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_impuesto"/>
								<qry:attribute name="c_impuesto" value="$r/@c_impuesto"/>
								<qry:attribute name="d_impuesto" value="$r/@d_impuesto"/>
								<qry:attribute name="l_iva" value="iif($r/@l_iva='1','1','0')"/>
								<qry:attribute name="n_porcentaje" value="$r/@n_porcentaje"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_empresa!=''">
									<qry:then>
										<qry:element name="oi_empresa">
											<qry:attribute name="OI_FIND" value="$r/@oi_empresa"/>
											<qry:insert-select name="NucleusRH.Base.Organizacion.Empresas.EMPRESA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_empresa" value="'['+oi_empresa/ROW/@COD+'] '+oi_empresa/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_impuesto as oi_impuesto, SEC.policy FROM LEG62_IMPUESTOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.Impuestos.IMPUESTO\') as SEC JOIN t0.oi_impuesto LEFT OUTER SEC.id  ORDER BY oi_impuesto asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_impuesto"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<guia-properties flow-edit="NucleusRH.Base.Legales.Impuestos.autoflow:initialize" desc-attr="d_impuesto" code-attr="c_impuesto" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
