				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_empresa"/>
				<form-properties label="Empresa" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_empresa"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" length="30" type="Nomad.NSystem.String" label="C&#243;digo" name="c_impuesto" OriginalName="c_impuesto">
