			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" label="Porcentaje" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="numeric(11,3)" column="n_porcentaje"/>
