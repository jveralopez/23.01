		<resource description="Devuelve los requerimientos del tipo de la carpeta" declare="&lt;PARAMS oi_tipo_carpeta=&quot;2&quot; oi_carpeta=&quot;118&quot;/&gt;" name="getReqTipo">
			<qry:main name="" doc="SOURCE">
				<qry:element name="XML">
					<qry:insert-select name="sql1" doc-path="#SOURCE:PARAMS"/>
				</qry:element>
			</qry:main>
			<qry:select name="sql1" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT
	LEG01_CARPETAS.oi_carpeta, 
	LEG42_TIPO_CARPETA.c_req_atr_proc,
	LEG42_TIPO_CARPETA.c_req_rad_tram,
	LEG42_TIPO_CARPETA.c_req_dom_const,
	LEG42_TIPO_CARPETA.c_req_obj_carpeta,
	LEG42_TIPO_CARPETA.c_req_carga_monto
FROM 
	LEG42_TIPO_CARPETA,
	LEG01_CARPETAS 
WHERE        
	LEG42_TIPO_CARPETA.oi_tipo_carpeta = {#SOURCE:@oi_tipo_carpeta} and
	LEG01_CARPETAS.oi_carpeta = {#SOURCE:@oi_carpeta}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<!--EVALUO EL ATRIBUTO PROCESAL DE LA CARPETA-->
					<qry:if test="$r/@c_req_atr_proc=1">
						<qry:then>
							<qry:attribute name="c_req_atr_proc" value="$r/@c_req_atr_proc"/>
							<qry:insert-select name="qry_atr_proc" doc-path="$r"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_req_atr_proc" value="$r/@c_req_atr_proc"/>
						</qry:else>
					</qry:if>
					<!--EVALUO LA RADICACION DEL TRAMITE DE LA CARPETA-->
					<qry:if test="$r/@c_req_rad_tram=1">
						<qry:then>
							<qry:attribute name="c_req_rad_tram" value="$r/@c_req_rad_tram"/>
							<qry:insert-select name="qry_rad_tram" doc-path="$r"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_req_rad_tram" value="$r/@c_req_rad_tram"/>
						</qry:else>
					</qry:if>
					<!--EVALUO EL DOMICILIO DE LA CARPETA-->
					<qry:if test="$r/@c_req_dom_const=1">
						<qry:then>
							<qry:attribute name="c_req_dom_const" value="$r/@c_req_dom_const"/>
							<!--qry:insert-select name="qry_dom_const" doc-path="#SOURCE:PARAMS"/-->
						</qry:then>
						<qry:else>
							<qry:attribute name="c_req_dom_const" value="$r/@c_req_dom_const"/>
						</qry:else>
					</qry:if>
					<!--EVALUO EL OBJETO DE LA CARPETA-->
					<qry:if test="$r/@c_req_obj_carpeta=1">
						<qry:then>
							<qry:attribute name="c_req_obj_carpeta" value="$r/@c_req_obj_carpeta"/>
							<qry:insert-select name="qry_obj_carpeta" doc-path="$r"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_req_obj_carpeta" value="$r/@c_req_obj_carpeta"/>
						</qry:else>
					</qry:if>
					<!--EVALUO EL MONTO DE LA CARPETA-->
					<qry:if test="$r/@c_req_carga_monto=1">
						<qry:then>
							<qry:attribute name="c_req_carga_monto" value="$r/@c_req_carga_monto"/>
							<qry:insert-select name="qry_carga_monto" doc-path="$r"/>
						</qry:then>
						<qry:else>
							<qry:attribute name="c_req_carga_monto" value="$r/@c_req_carga_monto"/>
						</qry:else>
					</qry:if>
				</qry:out>
			</qry:select>
			<!-- QRY ATRIBUTOS PROCESALES DE LA CARPETA -->
			<qry:select name="qry_atr_proc" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT 
	LEG01_ATRIB_PROC.oi_carpeta
FROM 
	LEG01_ATRIB_PROC,
	LEG01_CARPETAS
JOIN
	LEG01_ATRIB_PROC.oi_carpeta INNER LEG01_CARPETAS.oi_carpeta
WHERE        
	LEG01_ATRIB_PROC.oi_carpeta = {#SOURCE:@oi_carpeta}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_req_atr_proc" value="0"/>
				</qry:out>
			</qry:select>
			<!-- QRY RADICACION DE LA CARPETA -->
			<qry:select name="qry_rad_tram" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT 
	LEG01_RADICACION.oi_carpeta
FROM 
	LEG01_RADICACION,
	LEG01_CARPETAS
JOIN
	LEG01_RADICACION.oi_carpeta INNER LEG01_CARPETAS.oi_carpeta
WHERE        
	LEG01_RADICACION.oi_carpeta = {#SOURCE:@oi_carpeta}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_req_rad_tram" value="0"/>
				</qry:out>
			</qry:select>
			<!-- QRY OBJETO DE LA CARPETA -->
			<qry:select name="qry_obj_carpeta" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('
SELECT 
	LEG01_PARTES.oi_carpeta
FROM 
	LEG01_OBJ_CARPETA,
	LEG01_PARTES,
	LEG01_CARPETAS
JOIN
	LEG01_CARPETAS.oi_carpeta INNER LEG01_PARTES.oi_carpeta,  
	LEG01_PARTES.oi_parte INNER LEG01_OBJ_CARPETA.oi_parte  
	
WHERE        
	LEG01_PARTES.oi_carpeta = {#SOURCE:@oi_carpeta}
			')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="c_req_obj_carpeta" value="0"/>
				</qry:out>
