<class-package xmlns:qry="nomad_engine.qry" root-class="HIST_CAMBIO" name="HistCambios" meta-class="DB" languaje="SP">
	<class label="Historial de Cambios" size="M" description="Historial Cambios" access="direct" name="HIST_CAMBIO">
		<meta-properties>
			<db-properties desc-column="oi_hist_cambio" code-column="oi_hist_cambio" tracking-changes="false" access-mode="new-edit-delete" optimistic-lock="version" table="LEG55_HIST_CAMBIOS">
				<security table="NMD_SECURITY"/>
			</db-properties>
			<form-properties binary="NONE" desc-attr="oi_hist_cambio" code-attr="oi_hist_cambio" enabled-filter="false" enabled-delete="true" enabled-edit="true" enabled-new="true" enabled-admin="true" automatico="1">
				<form-list-properties>
					<qry:include name="NucleusRH.Base.Legales.Carpetas.CARPETA.INFO"/>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_hist_cambio as oi_hist_cambio, t0.f_cambio as f_cambio, t0.d_usuario as d_usuario, SEC.policy, t0.oi_hist_cambio as CODE, t0.oi_hist_cambio as TEXT, t0.oi_carpeta as oi_carpeta FROM LEG55_HIST_CAMBIOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO\') as SEC JOIN t0.oi_hist_cambio LEFT OUTER SEC.id  ORDER BY oi_hist_cambio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_hist_cambio"/>
								<qry:attribute name="f_cambio" value="$r/@f_cambio"/>
								<qry:attribute name="d_usuario" value="$r/@d_usuario"/>
								<qry:attribute name="CODE" value="$r/@CODE"/>
								<qry:attribute name="TEXT" value="$r/@TEXT"/>
								<qry:if test="$r/@oi_carpeta!=''">
									<qry:then>
										<qry:element name="oi_carpeta">
											<qry:attribute name="OI_FIND" value="$r/@oi_carpeta"/>
											<qry:insert-select name="NucleusRH.Base.Legales.Carpetas.CARPETA.QUERY" doc-path="."/>
										</qry:element>
										<qry:attribute name="oi_carpeta" value="'['+oi_carpeta/ROW/@COD+'] '+oi_carpeta/ROW/@DES"/>
									</qry:then>
								</qry:if>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-list-properties>
				<form-iter-properties>
					<qry:main maxdeep="2">
						<qry:element name="ROWS">
							<qry:insert-select name="sql1"/>
						</qry:element>
					</qry:main>
					<qry:select doc="PARAM" name="sql1">
						<qry:xquery>
							for $r in sql('SELECT t0.oi_hist_cambio as oi_hist_cambio, SEC.policy FROM LEG55_HIST_CAMBIOS as t0,NMD_SECURITY(class=\'NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO\') as SEC JOIN t0.oi_hist_cambio LEFT OUTER SEC.id  ORDER BY oi_hist_cambio asc')/ROWS/ROW
						</qry:xquery>
						<qry:out>
							<qry:element name="ROW">
								<qry:attribute name="policy" value="$r/@policy"/>
								<qry:attribute name="id" value="$r/@oi_hist_cambio"/>
							</qry:element>
						</qry:out>
					</qry:select>
				</form-iter-properties>
			</form-properties>
			<combo-properties desc="oi_hist_cambio" code="oi_hist_cambio" automatico="1"/>
			<guia-properties flow-edit="NucleusRH.Base.Legales.HistCambios.autoflow:initialize" desc-attr="oi_hist_cambio" code-attr="oi_hist_cambio" requiered-filter="false" enabled-filter="true" enabled-edit="true" automatico="1"/>
		</meta-properties>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.Int" label="Id" name="id" OriginalName="oi_hist_cambio">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="false" insertable="true" updatable="false" unique="true" generator="secuence" id="true" nullable="false" type="int" column="oi_hist_cambio"/>
			</meta-properties>
		</attribute>
		<assosiation class="NucleusRH.Base.Legales.Carpetas.CARPETA" null="false" readonly="false" type="aggregation" label="Carpeta" name="oi_carpeta" OriginalName="oi_carpeta">
			<meta-properties>
				<db-properties tracking-changes="no" versionable="true" cascade="none" not-found="exception" optimistic-lock="true" not-null="true" unique="false" insert="true" update="true" nullable="false" type="int" from-column="oi_carpeta"/>
				<form-properties label="Carpeta" automatico="1" show-list="true" read-only="false" visible="true" mandatory="true"/>
			</meta-properties>
			<multiplicity to="1" from="1..*">
				<db-properties to-column="oi_carpeta"/>
			</multiplicity>
		</assosiation>
		<attribute null="false" readonly="false" default="''" type="Nomad.NSystem.DateTime" label="Fecha Hora de Acci&#243;n" name="f_cambio" OriginalName="f_cambio">
			<meta-properties>
				<form-properties show-list="true" find-include="false" automatico="1" patern="YYYYMMDDHHMM" label="Fecha Hora de Acci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="datetime" column="f_cambio"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" length="100" type="Nomad.NSystem.String" label="Usuario Acci&#243;n" name="d_usuario" OriginalName="d_usuario">
			<meta-properties>
				<form-properties show-list="true" find-include="true" automatico="1" label="Usuario Acci&#243;n" lock="false" read-only="false" visible="true" mandatory="true"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="false" type="varchar(100)" column="d_usuario"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" length="4000" type="Nomad.NSystem.String" label="XML Cambio" name="o_xml_cambio" OriginalName="o_xml_cambio">
			<meta-properties>
				<form-properties show-list="false" find-include="false" automatico="1" label="XML Cambio" lock="false" read-only="false" visible="true" mandatory="false"/>
				<db-properties tracking-changes="yes" versionable="true" insertable="true" updatable="true" unique="false" generator="none" id="false" nullable="true" type="varchar(4000)" column="o_xml_cambio"/>
			</meta-properties>
		</attribute>
		<attribute default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<resource declare="&lt;DATA oi_find=&quot;1&quot; /&gt;" name="INFO">
			<qry:main doc="SOURCE">
				<qry:element name="ROWS">
					<qry:if test="#SOURCE:./@COUNT='1'">
						<qry:then>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO.COUNT"/>
						</qry:then>
						<qry:else>
							<qry:insert-select doc-path="#SOURCE:." name="NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO.QUERY"/>
						</qry:else>
					</qry:if>
				</qry:element>
			</qry:main>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO.QUERY">
				<qry:xquery>
					for $r in SQL('
{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %} 
 {%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %} 
select
  LEG55_HIST_CAMBIOS.oi_hist_cambio as ID,
  LEG55_HIST_CAMBIOS.oi_hist_cambio as COD,
  LEG55_HIST_CAMBIOS.oi_hist_cambio as DES
from
  LEG55_HIST_CAMBIOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(DES,{#SOURCE:@TXT_FIND}) or contain(COD,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and PARENT={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by DES asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:element name="ROW">
						<qry:attribute value="$r/@ID" name="ID"/>
						<qry:attribute value="$r/@COD" name="COD"/>
						<qry:attribute value="$r/@DES" name="DES"/>
						<qry:attribute value="$r/@PARENT" name="OI_FIND"/>
					</qry:element>
				</qry:out>
			</qry:select>
			<qry:select doc="SOURCE" name="NucleusRH.Base.Legales.HistCambios.HIST_CAMBIO.COUNT">
				<qry:xquery>
					for $r in SQL('
select
  Count(LEG55_HIST_CAMBIOS.oi_hist_cambio) as CNT
from
  LEG55_HIST_CAMBIOS
Where
  1=1 
{%? (#SOURCE:@OI_FIND='') {% %} {% and LEG55_HIST_CAMBIOS.oi_hist_cambio={#SOURCE:@OI_FIND} %} %} 
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(LEG55_HIST_CAMBIOS.oi_hist_cambio,{#SOURCE:@TXT_FIND}) or contain(LEG55_HIST_CAMBIOS.oi_hist_cambio,{#SOURCE:@TXT_FIND})) %} %} 
{%? (#SOURCE:@OI_PARENT='') {% %} {% and [PARENT]={#SOURCE:@OI_PARENT} %} %} 

{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute value="number(@COUNT)+number($r/@CNT)" name="COUNT"/>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
