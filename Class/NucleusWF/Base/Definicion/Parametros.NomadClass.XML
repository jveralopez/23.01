<class-package xmlns:qry="nomad_engine.qry" name="Parametros" meta-class="DB" languaje="SP" root-class="PARAM" DDOBase="NucleusWF\Base\Definicion">
	<class size="L" attr-desc="d_param" attr-code="c_param" description="Parametros del Workflow" label="Parametro" name="PARAM">
		<meta-properties>
			<db-properties desc-column="d_param" code-column="c_param" access-mode="new-edit-delete" generate="true" optimistic-lock="version" table="WRK06_PARAMS">
				<security table="NMD_SECURITY"/>
			</db-properties>
		</meta-properties>
		<enum name="c_type">
			<enum-value label="Boolean" value="bool"/>
			<enum-value label="Entero" value="int"/>
			<enum-value label="Texto" value="string"/>
		</enum>
		<attribute type="Nomad.NSystem.Int" null="false" readonly="true" inList="false" description="Clave Unica de la Clase" label="Id" name="id">
			<meta-properties>
				<db-properties generator="secuence" updatable="false" insertable="true" nullable="false" unique="true" id="true" type="int" column="oi_param"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" inList="true" length="30" type="Nomad.NSystem.String" label="Codigo" name="c_param">
			<meta-properties>
				<db-properties generator="none" updatable="true" insertable="true" nullable="false" unique="false" id="false" type="varchar(30)" column="c_param"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" inList="true" length="100" type="Nomad.NSystem.String" label="Descripcion" name="d_param">
			<meta-properties>
				<db-properties generator="none" updatable="true" insertable="true" nullable="false" unique="false" id="false" type="varchar(100)" column="d_param"/>
			</meta-properties>
		</attribute>
		<attribute null="false" readonly="false" default="''" inList="true" length="30" type="Nomad.NSystem.String" label="Tipo de Datos" name="c_type">
			<meta-properties>
				<db-properties generator="none" updatable="true" insertable="true" nullable="false" unique="false" id="false" type="varchar(30)" column="c_type"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" inList="true" length="100" type="Nomad.NSystem.String" label="Valor" name="d_value">
			<meta-properties>
				<db-properties generator="none" updatable="true" insertable="true" nullable="true" unique="false" id="false" type="varchar(100)" column="d_value"/>
			</meta-properties>
		</attribute>
		<attribute null="true" readonly="false" default="''" inList="true" length="100" type="Nomad.NSystem.String" label="Valor para Debug" name="d_value_debug">
			<meta-properties>
				<db-properties generator="none" updatable="true" insertable="true" nullable="true" unique="false" id="false" type="varchar(100)" column="d_value_debug"/>
			</meta-properties>
		</attribute>
		<attribute inList="false" default="'Nuevo'" length="1024" type="Nomad.NSystem.String" name="descr">
			<meta-properties/>
		</attribute>
		<key unique="yes" parent-include="no" descr="Key_2" name="KEY_2">
			<key-attr assosiation="no" name="c_param"/>
		</key>
		<resource include="false" name="INFO" declare="&lt;DATA oi_find=&quot;1&quot; /&gt;">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:insert-select name="NucleusWF.Base.Definicion.Parametros.PARAM.QUERY" doc-path="#SOURCE:."/>
				</ROWS>
			</qry:main>
			<qry:select name="NucleusWF.Base.Definicion.Parametros.PARAM.QUERY" doc="SOURCE">
				<qry:xquery>
					for $r in SQL('{%? (#SOURCE:@START='') {% %} {% fromrow {%=#SOURCE:@START %} %} %}
{%? (#SOURCE:@LEN='') {% %} {% maxsize {%=#SOURCE:@LEN %} %} %}
SELECT 
  WRK06_PARAMS.oi_param as ID, 
  WRK06_PARAMS.c_param as COD, 
  WRK06_PARAMS.d_param as DES
FROM 
  WRK06_PARAMS
WHERE 1=1
{%? (#SOURCE:@OI_FIND='') {% %} {% and ID={#SOURCE:@OI_FIND} %} %}
{%? (#SOURCE:@TXT_FIND='') {% %} {% and (contain(ucase(DES),{upper-case(#SOURCE:@TXT_FIND)}) or contain(ucase(COD),{upper-case(#SOURCE:@TXT_FIND)})) %} %}
{%? (#SOURCE:@WHERE='') {% %} {% and {%=#SOURCE:@WHERE %} %} %}
{%? (#SOURCE:@ORDERBY='') {% order by COD asc %} {%  order by {%=#SOURCE:@ORDERBY %} asc %} %}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute name="ID" value="$r/@id"/>
						<qry:attribute name="COD" value="$r/@COD"/>
						<qry:attribute name="DES" value="$r/@DES"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource include="false" declare="&lt;DATA search=&quot;&quot; order=&quot;&quot; asc=&quot;0&quot; /&gt;" name="INFO_IDS">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:append-doc name="FILTER" doc-path="#SOURCE:/DATA"/>
					<qry:insert-select name="IDS"/>
				</ROWS>
			</qry:main>
			<qry:select name="IDS">
				<qry:xquery>
					for $r in SQL('{%? (#FILTER:@LEN='') {% %} {% maxsize {%=#FILTER:@LEN %} %} %}
SELECT 
  WRK06_PARAMS.oi_param as ID, 
  WRK06_PARAMS.c_param as COD, 
  WRK06_PARAMS.d_param as DES
{%?($FILTER/@order!='') {% ,WRK06_PARAMS.{%=$FILTER/@order %} as COL_ORDER %} {% %} %}
FROM 
  WRK06_PARAMS
WHERE 1=1

{%?($FILTER/@search!='')
 {% and (contain(ucase(DES),{upper-case($FILTER/@search)}) or contain(ucase(COD),{upper-case($FILTER/@search)})) %}
 {% %}
%}

{%?($FILTER/@order!='')
  {% order by COL_ORDER {%=iif($FILTER/@asc='1','asc','desc') %} %}
  {% %}
%}
')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<qry:attribute name="count" value="$r/../@CNT"/>
					<qry:attribute name="total" value="$r/../@CNT"/>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
		<resource include="false" declare="&lt;PARAM IDS=&quot;11&quot; /&gt;&#13;&#10;&#13;&#10;&#13;&#10;" name="INFO_IDS_LIST">
			<qry:main doc="SOURCE">
				<ROWS>
					<qry:if test="#SOURCE:/PARAM/@IDS!=''">
						<qry:then>
							<qry:insert-select name="SQL1" doc-path="#SOURCE:/PARAM"/>
						</qry:then>
					</qry:if>
				</ROWS>
			</qry:main>
			<qry:select doc="PARAM" name="sql1">
				<qry:xquery>
					for $r in SQL('SELECT 
  WRK06_PARAMS.oi_param as ID, 
  WRK06_PARAMS.c_param as COD, 
  WRK06_PARAMS.d_param as DES, 
  WRK06_PARAMS.c_param as c_param, 
  WRK06_PARAMS.d_param as d_param, 
  WRK06_PARAMS.c_type as c_type, 
  WRK06_PARAMS.d_value as d_value, 
  WRK06_PARAMS.d_value_debug as d_value_debug
FROM 
  WRK06_PARAMS
WHERE 
WRK06_PARAMS.oi_param in ({%=$PARAM/@IDS %})')/ROWS/ROW
				</qry:xquery>
				<qry:out>
					<ROW>
						<qry:attribute value="$r/@ID" name="id"/>
						<qry:attribute value="$r/@COD+'-'+$r/@DES" name="descr"/>
						<qry:attribute name="c_param" value="$r/@c_param"/>
						<qry:attribute name="d_param" value="$r/@d_param"/>
						<qry:attribute name="c_type" value="$r/@c_type"/>
						<qry:attribute name="d_value" value="$r/@d_value"/>
						<qry:attribute name="d_value_debug" value="$r/@d_value_debug"/>
					</ROW>
				</qry:out>
			</qry:select>
		</resource>
	</class>
</class-package>
