<interface:interface doc="source" name="NucleusRH.Base.Liquidacion.Interfaces.InterfaceContable"
	xmlns:interface="nomad:interface"
	xmlns:qry="nomad:query"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	>
	<interface:query>
		<qry:exec-method
			class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA"
			method="EjecutarInterfaceContable"/>	
	</interface:query>
	<interface:block file-sufix="/@sufix">
		<xsl:output method="text"/>
		<xsl:template match="/DATOS">
			<xsl:apply-templates select="Registro"/>
		</xsl:template>
		<xsl:template match="Registro">
			<xsl:value-of select="@valor"/>
			<xsl:text>&#13;&#10;</xsl:text>
		</xsl:template>
	</interface:block>
</interface:interface>
