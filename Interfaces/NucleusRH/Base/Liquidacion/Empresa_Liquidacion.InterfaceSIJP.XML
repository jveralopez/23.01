<interface:interface doc="source" name="NucleusRH.Base.Liquidacion.Interfaces.SIJP"
	xmlns:interface="nomad:interface"
	xmlns:qry="nomad:query"
	xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
	xmlns:fo="http://www.w3.org/1999/XSL/Format"
	>
	<interface:for-each>
		<qry:exec-method
			class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA"
			method="EjecutarSIJP"/>	
	</interface:for-each>		
	<interface:query>
		<qry:exec-method
			class="NucleusRH.Base.Liquidacion.Empresa_Liquidacion.EMPRESA"
			method="PIPE"/>
	</interface:query>
	<interface:block file-sufix="/PERSONAS_VALIDAS/@sufix">
		<xsl:output method="text"/>
		<xsl:template match="/">
			<xsl:apply-templates select="PERSONAS_VALIDAS/PERSONAS"/>
		</xsl:template>
		<xsl:template match="PERSONAS">
			<xsl:apply-templates select="PERSONA"/>
		</xsl:template>
		<xsl:template match="PERSONA">
			<xsl:value-of select="@valor"/>
			<xsl:text>&#13;&#10;</xsl:text>
		</xsl:template>
	</interface:block>
</interface:interface>
