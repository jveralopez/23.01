<qry:define xmlns:qry="nomad_engine.qry" declare="&lt;DATOS urlBase=&quot;16.1&quot; /&gt;" name="URLS" include="true">
	<qry:select name="qry_urls" doc="SOURCE">
		<qry:out>
			<ROWS>
				<qry:if test="contains(#SOURCE:@urlBase,'.')">
					<qry:then/>
					<!--En caso de haber urls por subversion agregar un switch - case. Ej: 16.1 -->
				</qry:if>
				<qry:if test="count(./ROW) = 0">
					<qry:then>
						<qry:switch test="substring-before(#SOURCE:@urlBase,'.')">
							<qry:case value="16">
								<ROW cod="crearEmpresa" url="Documentos/ApiEmpresas/Crear"/>
								<ROW cod="obtenerEmpresa" url="Documentos/ApiEmpresas/Obtener"/>
								<ROW cod="listarEmpresa" url="Documentos/ApiEmpresas/Listar"/>
								<ROW cod="crearEmpleado" url="Documentos/ApiEmpleados/Crear"/>
								<ROW cod="obtenerEmpleado" url="Documentos/ApiEmpleados/Obtener"/>
								<ROW cod="listarEmpleados" url="Documentos/ApiEmpleados/Listar"/>
							</qry:case>
							<qry:case value="default">
								<ROW cod="crearEmpresa" url="Empresas/ApiEmpresas/Crear "/>
								<ROW cod="obtenerEmpresa" url="Empresas/ApiEmpresas/Obtener"/>
								<ROW cod="listarEmpresa" url="Empresas/ApiEmpresas/Listar"/>
								<ROW cod="crearEmpleado" url="Empresas/ApiEmpleados/Crear"/>
								<ROW cod="obtenerEmpleado" url="Empresas/ApiEmpleados/Obtener"/>
								<ROW cod="listarEmpleados" url="Empresas/ApiEmpleados/Listar"/>
								<ROW cod="agregarMovimientoCC" url="Empresas/ApiEmpleados/AgregarMovimientoCC"/>				
								<ROW cod="listarLicencias" url="Empresas/ApiEmpleados/ListarLicencias"/>											
								<ROW cod="listarTotalesCC" url="Empresas/ApiEmpleados/ListarTotalesCC"/>
								<ROW cod="listarFichadas" url="Fichadas/ApiFichada/Listar"/>
							</qry:case>
						</qry:switch>
					</qry:then>
				</qry:if>
			</ROWS>
		</qry:out>
	</qry:select>
</qry:define>
