				<qry:attribute name="n_resultado3" value="iif($r/@n_resultado3='','null',format-number($r/@n_resultado3, 0, 2, '.', '', ''))"/>
				<qry:attribute name="d_cus1" value="$r/@d_cus1"/>
				<qry:attribute name="d_cus2" value="$r/@d_cus2"/>
				<qry:attribute name="d_cus3" value="$r/@d_cus3"/>
				<qry:attribute name="d_cus4" value="$r/@d_cus4"/>
				<qry:attribute name="d_cus5" value="$r/@d_cus5"/>
				<qry:insert-select name="RESULT_AUX" doc-path="$EVALUADORES/EVALUADOR"/>
				<qry:insert-select name="SUBOBJETIVO360" doc-path="$r"/>
				<qry:insert-select name="SUBOBJETIVO_CUSTOM" doc-path="$r"/>
			</SUBITEM>
		</qry:out>
	</qry:select>
	<qry:select name="ESCALAS" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
ESC.oi_escala as oi_escala, 
ESC.c_escala as c_escala, 
ESC.d_escala as d_escala
from 
org29_escalas as ESC
where
ESC.oi_escala in ({%=substring(#SOURCE:@oi_escalas,1,string_length(#SOURCE:@oi_escalas)-2) %})
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ESCALA prev="0">
				<qry:attribute name="oi_escala" value="$r/@oi_escala"/>
				<qry:insert-select name="VALORES" doc-path="$r"/>
				<qry:switch test="COUNT(./VAL)">
					<qry:case value="0">
						<qry:attribute name="enum" value="0"/>
						<qry:attribute name="max" value="100"/>
						<qry:attribute name="min" value="0"/>
					</qry:case>
					<qry:case value="1">
						<qry:attribute name="enum" value="0"/>
						<qry:attribute name="max" value="max(./VAL/@VAL_hasta)"/>
						<qry:attribute name="min" value="min(./VAL/@VAL_desde)"/>
					</qry:case>
					<qry:default>
						<qry:attribute name="enum" value="1"/>
						<qry:attribute name="max" value="max(./VAL/@VAL_hasta)"/>
						<qry:attribute name="min" value="min(./VAL/@VAL_desde)"/>
					</qry:default>
				</qry:switch>
				<qry:attribute name="prev" value="''"/>
				<qry:insert-select name="VALORES_CHK" doc-path="." to-element="./VAL"/>
				<qry:insert-select name="ESCALA_CUSTOM" doc-path="$r"/>
			</ESCALA>
		</qry:out>
	</qry:select>
	<qry:select name="VALORES" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
V.oi_val_escala,
V.c_valor,
V.d_valor,	
V.n_val_desde,
V.n_val_hasta
from 
org29_val_escalas as V
where
V.oi_escala={#SOURCE:@oi_escala}
order by
n_val_desde ASC
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<VAL>
				<qry:attribute name="VAL_id" value="$r/@oi_valor"/>
				<qry:attribute name="VAL_cod" value="$r/@c_valor"/>
				<qry:attribute name="VAL_des" value="$r/@d_valor"/>
				<qry:attribute name="VAL_desde" value="$r/@n_val_desde"/>
				<qry:attribute name="VAL_hasta" value="$r/@n_val_hasta"/>
				<qry:attribute name="VAL_min" value="$r/@n_val_desde"/>
				<qry:attribute name="VAL_max" value="$r/@n_val_hasta"/>
			</VAL>
			<qry:attribute name="prev" value="$r/@n_val_hasta"/>
		</qry:out>
	</qry:select>
	<qry:select name="ESC" doc="SOURCE">
		<qry:out>
			<qry:if test="#SOURCE:@oi_escala!=''">
				<qry:then>
					<qry:attribute name="oi_escalas" value="iif(contains(@oi_escalas,','+#SOURCE:@oi_escala+','), @oi_escalas, @oi_escalas+#SOURCE:@oi_escala+',')"/>
				</qry:then>
			</qry:if>
			<qry:if test="#SOURCE:@oi_escala_item!=''">
				<qry:then>
					<qry:attribute name="oi_escalas" value="iif(contains(@oi_escalas,','+#SOURCE:@oi_escala_item+','), @oi_escalas, @oi_escalas+#SOURCE:@oi_escala_item+',')"/>
				</qry:then>
			</qry:if>
			<qry:if test="#SOURCE:@oi_escala_subitem!=''">
				<qry:then>
					<qry:attribute name="oi_escalas" value="iif(contains(@oi_escalas,','+#SOURCE:@oi_escala_subitem+','), @oi_escalas, @oi_escalas+#SOURCE:@oi_escala_subitem+',')"/>
				</qry:then>
			</qry:if>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUADORES" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	PER.d_ape_y_nom, 
	EVA.c_estado, 
	EVA.oi_personal_emp, 
	ROL.oi_rol,
	ROL.d_rol,
	ROL.c_rol
from 
	edd03_eva_evaluad as EVA,
	edd05_roles as ROL,
	per02_personal_emp as LEG,
	per01_personal as PER
join
	EVA.oi_rol INNER ROL.oi_rol,
	EVA.oi_personal_emp INNER LEG.oi_personal_emp,
	LEG.oi_personal INNER PER.oi_personal
where
	EVA.oi_evaluacion = {#SOURCE:@oi_evaluacion}              
order by
	c_rol asc, oi_personal_emp asc
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<EVALUADOR>
				<qry:attribute name="d_ape_y_nom" value="iif($SOURCE/@show_label=1,$r/@d_ape_y_nom,$r/@d_rol)"/>
				<qry:attribute name="oi_personal_emp" value="$r/@oi_personal_emp"/>
				<qry:attribute name="oi_rol" value="$r/@oi_rol"/>
				<qry:attribute name="d_rol" value="$r/@d_rol"/>
				<qry:attribute name="c_estado" value="$r/@c_estado"/>
				<qry:insert-select name="EVALUADOR_CUSTOM" doc-path="$r"/>
			</EVALUADOR>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUACION360" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.n_resultado,
	EVA.o_comentario,  
	EVA.oi_personal_emp
from 
	edd03_eva_evaluad as EVA
where
	EVA.oi_evaluacion = {#SOURCE:@oi_evaluacion}              
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name-calc="'EVA_n_res_'+$r/@oi_personal_emp" value="iif($r/@n_resultado='','null',format-number($r/@n_resultado, 0, 2, '.', '', ''))"/>
			<qry:attribute name-calc="'EVA_o_com_'+$r/@oi_personal_emp" value="$r/@o_comentario"/>
		</qry:out>
	</qry:select>
	<qry:select name="PLANTILLA360" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.n_resultado,
	EVA.o_comentario,  
	EVA.oi_personal_emp
from 
	edd03_pla_evaluad as EVA
where
	EVA.oi_plantilla = {#SOURCE:@oi_plantilla}              
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name-calc="'EVA_n_res_'+$r/@oi_personal_emp" value="iif($r/@n_resultado='','null',format-number($r/@n_resultado, 0, 2, '.', '', ''))"/>
			<qry:attribute name-calc="'EVA_o_com_'+$r/@oi_personal_emp" value="$r/@o_comentario"/>
		</qry:out>
	</qry:select>
	<qry:select name="OBJETIVO360" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.n_resultado,
	EVA.oi_personal_emp
from 
	edd03_obj_evaluad as EVA
where
	EVA.oi_objetivo = {#SOURCE:@oi_objetivo}              
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name-calc="'EVA_n_res_'+$r/@oi_personal_emp" value="iif($r/@n_resultado='','null',format-number($r/@n_resultado, 0, 2, '.', '', ''))"/>
		</qry:out>
	</qry:select>
	<qry:select name="SUBOBJETIVO360" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.n_resultado,
	EVA.oi_personal_emp
from 
	edd03_sub_evaluad as EVA
where
	EVA.oi_subobjetivo = {#SOURCE:@oi_subobjetivo}              
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name-calc="'EVA_n_res_'+$r/@oi_personal_emp" value="iif($r/@n_resultado='','null',format-number($r/@n_resultado, 0, 2, '.', '', ''))"/>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUADOR360" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	PER.d_ape_y_nom,
	LEG.oi_personal_emp
	
from 
	per02_personal_emp as LEG,
	per01_personal as PER,
	PER21_INDIC_ACTIVO as ACT
join
	LEG.oi_personal INNER PER.oi_personal,
	LEG.oi_indic_activo INNER ACT.oi_indic_activo
where 
	ACT.c_indic_activo = \'A\' and 
	PER.oi_usuario_sistema = {$PROXY/@ETTY}              
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="oi_evaluador_360" value="$r/@oi_personal_emp"/>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUADOR360_EVALUADOR" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.oi_evaluador as oi_personal_emp
from 
	edd03_evaluacion as EVA
where 
	EVA.oi_evaluacion = {$SOURCE/@oi_evaluacion}
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="oi_evaluador_360" value="$r/@oi_personal_emp"/>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUADOR360_EVALUADO" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.oi_personal_emp as oi_personal_emp
from 
	edd03_evaluacion as EVA
where 
	EVA.oi_evaluacion = {$SOURCE/@oi_evaluacion}
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="oi_evaluador_360" value="$r/@oi_personal_emp"/>
		</qry:out>
	</qry:select>
	<qry:select name="EVALUADOR360_SUPERVISOR" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
select 
	EVA.oi_supervisor as oi_personal_emp
from 
	edd03_evaluacion as EVA
where 
	EVA.oi_evaluacion = {$SOURCE/@oi_evaluacion}
')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<qry:attribute name="oi_evaluador_360" value="$r/@oi_personal_emp"/>
		</qry:out>
	</qry:select>
	<qry:select name="RESULT_AUX" doc="r">
		<qry:out>
			<qry:attribute name-calc="'EVA_n_res_'+$r/@oi_personal_emp" value="'null'"/>
		</qry:out>
	</qry:select>
	<qry:select name="VALORES_CHK" doc="SOURCE">
		<qry:out>
			<qry:if test="@VAL_min=min(../VAL/@VAL_min)">
				<qry:then>
					<qry:attribute name="VAL_min" value="-99999999"/>
				</qry:then>
			</qry:if>
			<qry:if test="@VAL_max=max(../VAL/@VAL_max)">
				<qry:then>
					<qry:attribute name="VAL_max" value="99999999"/>
				</qry:then>
			</qry:if>
		</qry:out>
	</qry:select>
	<qry:select name="REPORT_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="PLANTILLA_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="OBJETIVO_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="SUBOBJETIVO_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="EVALUADORES_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="EVALUADOR_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="ESCALAS_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="ESCALA_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
	<qry:select name="FINAL_CUSTOM" doc="SOURCE">
		<qry:out/>
	</qry:select>
</qry:define>
