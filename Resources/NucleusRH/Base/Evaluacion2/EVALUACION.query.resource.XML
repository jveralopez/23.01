	L1.oi_personal inner H1.oi_personal) as LE,
	
	(select
	L1.oi_empresa      as oi_empresa,
	E1.c_empresa       as codemp,
	E1.d_empresa       as empresa,
	L1.oi_personal_emp as oi_personal_emp,
	L1.f_ingreso       as fingreso,
	L1.e_numero_legajo as legajo,
	H1.d_ape_y_nom     as nombre,
	H1.oi_foto         as foto
	from
	PER02_PERSONAL_EMP as L1,
	ORG03_EMPRESAS     as E1,
	PER01_PERSONAL     as H1
	join
	E1.oi_empresa inner L1.oi_empresa,
	L1.oi_personal inner H1.oi_personal) as EE,
	
	(select
	L1.oi_empresa      as oi_empresa,
	E1.c_empresa       as codemp,
	E1.d_empresa       as empresa,
	L1.oi_personal_emp as oi_personal_emp,
	L1.f_ingreso       as fingreso,
	L1.e_numero_legajo as legajo,
	H1.d_ape_y_nom     as nombre,
	H1.oi_foto         as foto
	from
	PER02_PERSONAL_EMP as L1,
	ORG03_EMPRESAS     as E1,
	PER01_PERSONAL     as H1
	join
	E1.oi_empresa inner L1.oi_empresa,
	L1.oi_personal inner H1.oi_personal) as SE

join
	EV.oi_evento inner E.oi_evento,
	EV.oi_tipo_eval inner ET.oi_tipo_eval,
	E.oi_personal_emp inner LE.oi_personal_emp,
	E.oi_evaluador inner EE.oi_personal_emp,
	E.oi_supervisor left outer SE.oi_personal_emp,
	E.oi_uni_evaluado left outer LU.oi_unidad_org,
	E.oi_uni_evaluador left outer EU.oi_unidad_org,
	E.oi_uni_supervisor left outer SU.oi_unidad_org,
	E.oi_pos_evaluado left outer LP.oi_posicion,
	E.oi_pos_evaluador left outer EP.oi_posicion,
	E.oi_pos_supervisor left outer SP.oi_posicion

WHERE            
	E.oi_evaluacion={#SOURCE:@oi_evaluacion}
')/ROWS/ROW
