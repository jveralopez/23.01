<qry:define xmlns:qry="nomad_engine.qry" declare="&lt;param oi_evaluacion=&quot;1084&quot; mode=&quot;PREEVALUAR&quot; oi_ev2aluador_360=&quot;11446&quot;/&gt;" name="QueryEvaluacion">
	<qry:main doc="SOURCE">
		<qry:insert-select name="MAIN" doc-path="#SOURCE:."/>
	</qry:main>
	<qry:select doc="SOURCE" name="MAIN">
		<qry:out>
			<REPORT>
				<EVALUADORES>
					<qry:append-doc name="EVALUADORES" doc-path="."/>
					<qry:if test="$SOURCE/@oi_evaluacion!=''">
						<qry:then>
							<qry:insert-select name="EVALUADORES" doc-path="$SOURCE"/>
						</qry:then>
					</qry:if>
					<qry:attribute name="oi_evaluador_360" value="$SOURCE/@oi_evaluador_360"/>
					<qry:switch test="$SOURCE/@mode">
						<qry:case value="EVALUADOR">
							<qry:insert-select name="EVALUADOR360_EVALUADOR" doc-path="$SOURCE"/>
						</qry:case>
						<qry:case value="EVALUADO">
							<qry:insert-select name="EVALUADOR360_EVALUADO" doc-path="$SOURCE"/>
						</qry:case>
						<qry:case value="SUPERVISOR">
							<qry:insert-select name="EVALUADOR360_SUPERVISOR" doc-path="$SOURCE"/>
						</qry:case>
					</qry:switch>
					<qry:if test="@oi_evaluador_360=''">
						<qry:then>
							<qry:insert-select name="EVALUADOR360"/>
						</qry:then>
					</qry:if>
					<qry:if test="@oi_evaluador_360=''">
						<qry:then>
							<qry:attribute name="oi_evaluador_360" value="0"/>
						</qry:then>
					</qry:if>
					<qry:insert-select name="EVALUADORES_CUSTOM" doc-path="$SOURCE"/>
				</EVALUADORES>
				<qry:attribute name="eva360_count" value="count(EVALUADORES/*)"/>
				<qry:attribute name="mode" value="$SOURCE/@mode"/>
				<qry:attribute name="timestamp" value="Now()"/>
				<qry:if test="$SOURCE/@oi_evaluacion=''">
					<qry:then>
						<qry:insert-select name="REPORT_PREVIEW" doc-path="$SOURCE"/>
					</qry:then>
					<qry:else>
						<qry:insert-select name="REPORT" doc-path="$SOURCE"/>
					</qry:else>
				</qry:if>
				<qry:insert-select name="ESC" doc-path="PLANTILLA"/>
				<qry:insert-select name="ESC" doc-path="PLANTILLA/ITEM"/>
				<qry:insert-select name="ESC" doc-path="PLANTILLA/ITEM/SUBITEM"/>
				<ESCALAS>
					<qry:insert-select name="ESCALAS" doc-path=".."/>
					<qry:insert-select name="ESCALAS_CUSTOM" doc-path="$SOURCE"/>
				</ESCALAS>
				<qry:insert-select name="FINAL_CUSTOM" doc-path="$SOURCE"/>
				<qry:attribute name="editable" value="$SOURCE/@editable"/>
			</REPORT>
		</qry:out>
	</qry:select>
