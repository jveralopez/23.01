	<qry:select doc="SOURCE" name="TIPOS_DOC">
		<qry:xquery>
			for $r in SQL
			(' 
			    SELECT
			    TD.oi_tipo_documento,
			    TD.c_tipo_documento,
			    TD.d_tipo_documento
			    
			    FROM
			    PER20_TIPOS_DOC as TD
                 
                ORDER BY d_tipo_documento asc
			    
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ROW>
				<qry:attribute name="external_id" value="$r/@oi_tipo_documento"/>
				<qry:attribute name="code" value="$r/@c_tipo_documento"/>
				<qry:attribute name="description" value="$r/@d_tipo_documento"/>
				<qry:attribute name="type" value="#SOURCE:@tipoCodificadora"/>
			</ROW>
		</qry:out>
	</qry:select>
	<qry:select doc="SOURCE" name="EST_CIVIL">
		<qry:xquery>
			for $r in SQL
			(' 
			    SELECT
			    ECV.oi_estado_civil,
			    ECV.c_estado_civil,
			    ECV.d_estado_civil
			    
			    FROM
			    ORG22_EST_CIVIL as ECV

			    ORDER BY d_estado_civil asc 
			     
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ROW>
				<qry:attribute name="external_id" value="$r/@oi_estado_civil"/>
				<qry:attribute name="code" value="$r/@c_estado_civil"/>
				<qry:attribute name="description" value="$r/@d_estado_civil"/>
				<qry:attribute name="type" value="#SOURCE:@tipoCodificadora"/>
			</ROW>
		</qry:out>
	</qry:select>
	<qry:select doc="SOURCE" name="PAISES">
		<qry:xquery>
			for $r in SQL
			(' 
			    SELECT
			    PAIS.oi_pais,
			    PAIS.c_pais,
			    PAIS.d_pais
			    
			    FROM
			    ORG35_PAISES as PAIS
                                 
               ORDER BY d_pais asc 
			    
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ROW>
				<qry:attribute name="external_id" value="$r/@oi_pais"/>
				<qry:attribute name="code" value="$r/@c_pais"/>
				<qry:attribute name="description" value="$r/@d_pais"/>
				<qry:attribute name="type" value="#SOURCE:@tipoCodificadora"/>
			</ROW>
		</qry:out>
	</qry:select>
	<qry:select name="PROVINCIAS" doc="SOURCE">
		<qry:xquery>
			for $r in SQL('
			SELECT
				PCIA.oi_provincia,				
				PCIA.c_provincia,
				PCIA.d_provincia,
				PAIS.c_pais,
				PAIS.oi_pais
			FROM
				ORG35_PROVINCIAS as PCIA,
				ORG35_PAISES as PAIS
			JOIN
				PCIA.oi_pais INNER PAIS.oi_pais
			ORDER BY d_provincia asc  
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ROW>
				<qry:attribute name="external_id" value="$r/@oi_provincia"/>
				<qry:attribute name="code" value="$r/@c_provincia"/>
				<qry:attribute name="description" value="$r/@d_provincia"/>
				<qry:attribute name="parentId" value="$r/@oi_pais"/>
				<qry:attribute name="type" value="#SOURCE:@tipoCodificadora"/>
			</ROW>
			<qry:attribute name="claseParent" value="'PAISES'"/>
		</qry:out>
	</qry:select>
	<qry:select name="LOCALIDADES" doc="SOURCE">
		<qry:xquery>
			for $r in SQL
			(' 
			     SELECT
				    LOC.oi_localidad,
				    LOC.c_localidad,
				    LOC.d_localidad,
			      PCIA.oi_provincia
			    FROM
				    ORG19_LOCALIDADES as LOC,
				    ORG35_PROVINCIAS as PCIA
			     
			    JOIN
			    	LOC.oi_provincia INNER PCIA.oi_provincia			     
			    ORDER BY 
			    	d_localidad asc  
			    
			')/ROWS/ROW
		</qry:xquery>
		<qry:out>
			<ROW>
				<qry:if test="substring-before($r/@d_localidad,' (') != ../@desc_anterior">
					<qry:then>
						<qry:attribute name="external_id" value="$r/@oi_localidad"/>
						<qry:attribute name="code" value="$r/@c_localidad"/>
						<qry:attribute name="description" value="substring-before($r/@d_localidad,' (')"/>
						<qry:attribute name="parentId" value="$r/@oi_provincia"/>
						<qry:attribute name="type" value="#SOURCE:@tipoCodificadora"/>
					</qry:then>
					<qry:else>
						<qry:attribute name="hts:delete" value="1"/>
					</qry:else>
				</qry:if>
			</ROW>
			<qry:attribute name="desc_anterior" value="substring-before($r/@d_localidad,' (')"/>
			<qry:attribute name="claseParent" value="'PROVINCIAS'"/>
		</qry:out>
	</qry:select>
